##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
900:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
900#    lw $t0,-8($s2) # get word with hash bits from this
904#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
908#    addu $t0,$t1

912#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
916:mth_equals_Object:
916#    move $t0,$s2 # first pointer (this)
920#    lw $t1,($sp) # second pointer
924#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
925##...subu $at,$t0,$t1
929##...sltiu $t0,$at,1

932#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
936:mth_hashCode_String:
936#    move $t0,$s2 # put this pointer in t0

940#    li $t2,0 # current hash value
944#    lw $t1,-4($t0) # negative of number of characters in string
948#    beq $t1,$zero,done_hashCode_String # if zero length => done
952#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
956#    and $t0,0xfffffffc # adjust for padding
957##...lui $at,65535
961##...ori $at,$at,0xfffc
965##...and $t0,$t0,$at
968#    subu $t1,$t0,$t1 # address at end of string +12
972:loop_hashCode_String:    
972#    sll $t4,$t2,5 # multiply by 32
976#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
980#    lbu $t3,-12($t0) # current character
984#    addu $t2,$t3 # add in current character
988#    addu $t0,1 # go to next character's address
992#    bne $t0,$t1,loop_hashCode_String # loop back if more
996:done_hashCode_String:    

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1004:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1004#    subu $sp,4
1008#    sw $ra,($sp)
    
    # get hash value
1012#    lw $t2,-12($s2) # vtable address
1016#    lw $t0,($t2) # method address
1020#    jalr $t0
1024#    subu $sp,8 # push result (int in $t0) on stack
1028#    sw $s5,4($sp)
1032#    sw $t0,($sp)

    # compute print-size of hash value
1036#    li $t0, 1
1040#    lw $t1, ($sp)
1044#    srl $t1,$t1,4
1048#    beq $t1,$zero,toString_skip_loop
1052:toString_loop_top:
1052#    addu $t0,1
1056#    srl $t1,$t1,4
1060#    bne $t1,$zero,toString_loop_top
1064:toString_skip_loop:
1064#    subu $sp,8
1068#    sw $s5,4($sp)
1072#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1076#    lw $t2,-12($s2) # vtable address
1080#    move $t0,$t2
1084:toString_checkTagBit:
1084#    subu $t0,1
1088#    lb $t1,($t0)
1092#    and $t1,0x80
1093##...lui $at,0
1097##...ori $at,$at,0x80
1101##...and $t1,$t1,$at
1104#    beq $t1,$zero,toString_checkTagBit
1108#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1112#    subu $sp,8
1116#    sw $t1,($sp)
1120#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1124#    move $s7,$zero # -4 offset header word
1128#    lw $t4,8($sp) # bytes for hash value
1132#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1136#    addu $t4,8
1140#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1144#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1148#    li $t0,CLASS_String # store string vtable address into ...
1152#    sw $t0,-12($s7) # ... -12 offset in object header
1156#    lw $t2,-12($s2) # our object's vtable address
1160#    lw $t5,4($sp) # number characters in prefix
1164#    lw $t1,12($sp) # number of characters in hashcode
1168#    addu $t3,$t1,$t5 # number of characters in string ...
1172#    addu $t3,1 # ... including the '@' character
1176#    subu $t0,$zero,$t3 # store negated length into ...
1180#    sw $t0,-4($s7) # ... -4 offset header word
1184#    lw $t0,-8($s7) # get -8 offset header-word
1188#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1189##...slt $at,$t0,$zero
1193##...beq $at,$zero,1212
1196#    and $t0,0xff # mask off object's hash value ...
1197##...lui $at,0
1201##...ori $at,$at,0xff
1205##...and $t0,$t0,$at
1208#    sw $t0,-8($s7) # ... and store back into -8 header-word
1212:skipMask_toString:
1212#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1216#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1220#    subu $t4,$t2,$t5
1224:toString_copyLoop:    
1224#    lb $t3,($t4)
1228#    and $t3,0x7f # mask off sign bit (in case first word)
1229##...lui $at,0
1233##...ori $at,$at,0x7f
1237##...and $t3,$t3,$at
1240#    sb $t3,-8($t0)
1244#    addu $t4,1
1248#    addu $t0,1
1252#    blt $t4,$t2,toString_copyLoop
1253##...slt $at,$t4,$t2
1257##...bne $at,$zero,1224

    # copy the '@' sign
1260#    li $t3,'@'
1264#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1268#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1272#    lw $t3,20($sp) # hash code to print
1276:toString_hashCopyLoop:
1276#    and $t4,$t3,0xf
1280#    srl $t3,4
1284#    lb $t4,hexChars($t4)
1288#    sb $t4,-8($t2)
1292#    subu $t2,$t2,1
1296#    bgt $t2,$t0,toString_hashCopyLoop
1297##...slt $at,$t0,$t2
1301##...bne $at,$zero,1276

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1304#    addu $sp,28
1308#    lw $ra,($sp)
1312#    addu $sp,4
1316#    move $t0, $s7 # return string we created
1320#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1324:mth_equals_String:
    
    # quick test for obvious false
1324#    lw $t0,($sp) # second parameter
1328#    beq $t0,$zero,goEsFalse # go return false if null
1332#    lw $t1,-12($t0) # vtable pointer
1336#    la $t2,CLASS_String # string vtable pointer
1340#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1344#    subu $sp,12
1348#    sw $ra,8($sp)
1352#    sw $s2,4($sp)
1356#    sw $t0,($sp)
1360#    jal mth_compareTo_String
1364#    lw $s2, 4($sp) #restore this pointer and pop parameters
1368#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1372#    seq $t0,$t0,$zero
1373##...subu $at,$t0,$zero
1377##...sltiu $t0,$at,1

    # pop return address and return $t0
1380#    lw $ra,($sp)
1384#    addu $sp,4

1388#    jr $ra # return
    
1392:goEsFalse:
    # put 0 in $t0 and return
1392#    li $t0, 0
1396#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1400:mth_toString_String:
    #we are a string, so return this.
1400#    move $t0, $s2
1404#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1408:mth_readLine_Lib:
    
1408#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1412#    sw $ra, 4($sp) # save $ra
1416#    move $t1,$sp # save "original" sp

1420:  doRead:

    # read the character
1420#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1424#    subu $t2,$v0,13
1428#    bne $t2,$zero,notReturnRL
1432#    jal readLogicalChar
1436#    subu $t2,$v0,10 # check for newline
1440#    beq $t2,$zero,foundNewLine
1444#    sw $v0,lastCharRead # push back character into queue
1448#    j foundNewLine # go process the line

1452:  notReturnRL:

    # at this point, $v0 has our character

1452#    subu $t0,$v0,10
1456#    beq $t0,$zero,foundNewLine
1460#    blt $v0,$zero,foundEof
1461##...slt $at,$v0,$zero
1465##...bne $at,$zero,1480

    # we have a character, so push it onto stack
1468#    subu $sp,$sp,4
1472#    sw $v0,($sp)

    # loop back up to get next character
1476#    j doRead

1480:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1480#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1484#    li $s7, 0 # return-value: null
1488#    j rlReturn # return

1492:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1492#    subu $t0,$t1,$sp # number of chars we read (times 4)
1496#    srl $s6,$t0,2 # number of words on stack with chars
1500#    subu $sp,$sp,4 # push char-count ...
1504#    sw $s6,($sp) # ... onto stack
1508#    addu $t2,$t0,5 # GC tag, incl. for count-word
1512#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1516#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1520#    srl $s6,$s6,2  # data words in object
1524#    move $s7,$zero # object words in object
1528#    jal newObject  # allocate space
    
    # store header words
1532#    la $t0,CLASS_String
1536#    sw $t0,-12($s7)# store class tag (String) into object
1540#    lw $t2,4($sp) # char-count
1544#    sll $t1,$t2,2 # 4 times number of chars
1548#    subu $t2,$zero,$t2 # negative of char-count
1552#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1556#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1560#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1561##...slt $at,$t0,$zero
1565##...beq $at,$zero,1584
1568#    and $t0,0xff # mask off object's hash value ...
1569##...lui $at,0
1573##...ori $at,$at,0xff
1577##...and $t0,$t0,$at
1580#    sw $t0,-8($s7) # ... and store back into -8 header-word
1584:  skipMask_readLine:

1584#    sll $t0,$t0,2 # data bytes in object
1588#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1592#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1596#    addu $sp,$sp,8 # pop redundant object-pointer and count
1600#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1604#    beq $sp,$t1,rlReturn
1608:  charCopyLoop:
1608#    lw $t2,($sp)
1612#    sb $t2,-9($t0)
1616#    addu $sp,$sp,4
1620#    subu $t0,$t0,1
1624#    bne $sp,$t1,charCopyLoop
1628:  rlReturn:

1628#    lw $ra, 4($sp)
1632#    addu $sp, 8   # pop $ra and pointless word off stack
1636#    move $t0, $s7 # return string we allocated in $s7
1640#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1644:mth_readInt_Lib:

    # save $ra by pushing onto stack
1644#    subu $sp,$sp,4
1648#    sw $ra,($sp)

1652:  riSkipWhiteLoop:
    # read a character
1652#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1656#    subu $t0,$v0,32
1660#    bgt $t0,$zero,nonWhite
1661##...slt $at,$zero,$t0
1665##...bne $at,$zero,1708
1668#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1672#    subu $t0,$v0,10
1676#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1680#    subu $t0,$v0,9
1684#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1688#    subu $t0,$v0,13
1692#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1696#    subu $t0,$v0,12
1700#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1704#    j badIntegerFormat # illegal integer char: abort program

1708:  nonWhite:
1708#    subu $t0,$v0,'-'
1712#    li $t4,1 # final multiplier
1716#    bne $t0,$zero,helpReadInt # go read
1720#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1724#    jal readLogicalChar

1728:  helpReadInt:
1728#    li $t2,10
1732#    subu $t1,$v0,'0' # convert digit to 0-9 value
1736#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1737##...sltu $at,$t1,$t2
1741##...beq $at,$zero,3988
1744#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1748:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1748#    jal readLogicalChar # read next character
1752#    subu $t1,$v0,'0' # convert digit to 0-9 value
1756#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1757##...sltu $at,$t1,$t2
1761##...beq $at,$zero,1780

1764#    mul $t3,$t3,$t2 # multiply old value by 10
1765##...mult $t3,$t2
1769##...mflo $t3
1772#    addu $t3,$t3,$t1 # add in value of new digit
1776#    j digitLoop

1780:  doneDigitLoop:

    # "push back" unused character into queue
1780#    sw $v0,lastCharRead

    # restore return address
1784#    lw $ra,($sp)
1788#    addu $sp, 4

    # multiply by sign and put return value in $t0
1792#    mult $t3,$t4 # multiply to account for poss. minus sign
1796#    mflo $t3
1800#    move $t0, $t3
    
    # return
1804#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1808:mth_readChar_Lib:

    # save $ra by pushing onto stack
1808#    subu $sp,$sp,4
1812#    sw $ra,($sp)

      # read the character
1816#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1820#    lw $ra,($sp)
1824#    addu $sp, 4
1828#    move $t0, $v0

    # return
1832#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
1836:mth_printStr_Lib:
    # check for null, printing "(null)", if so
1836#    lw $t0,($sp)
1840#    bne $t0,$zero,psNotNull

    # print "(null)"
1844#    la $a0,nullStr
1848#    li $v0,4
1852#    syscall
1856#    j donePrintStr
    
1860:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)

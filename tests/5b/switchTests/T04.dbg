    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3500#    lw $t1,-12($t2) # vtable pointer
3504#    li $t0,dataArrayVTableStart # address of vtable for first data array
3508#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3509##...slt $at,$t1,$t0
3513##...bne $at,$zero,3532

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3516:  skipToNextObj:
3516#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3520#    sll $t1,$t1,2 # convert to byte-count
3524#    addu $t0,$t2,$t1 # skip over object
3528#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3532:  gcNotDataArray:
3532#    lw $t3,-4($t2) # # object words (negative treated as zero)
3536#    bge $t3,$zero,gcH2Neg2
3537##...slt $at,$t3,$zero
3541##...beq $at,$zero,3548
3544#    move $t3,$zero
3548:  gcH2Neg2:
3548#    sll $t3,$t3,2 # # object bytes
3552#    move $t0,$t2 # address of first pointer in object
3556#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3560#    beq $t0,$s1,gcTestIterDone2
    
3564:  gcNextPointerInObject:
    # get pointer from object
3564#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3568#    bleu $t1,$t6,gcGoNextPointerSlot
3569##...sltu $at,$t6,$t1
3573##...beq $at,$zero,3716
3576#    bgtu $t1,$t7,gcGoNextPointerSlot
3577##...sltu $at,$t7,$t1
3581##...bne $at,$zero,3716

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3584#    lw $t8,-8($t1) # possible forwarding tag
3588#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3592#    lw $t8,-4($t1) # forwarding pointer: object's new address
3596#    sw $t8,($t0) # update pointer in object
3600#    j gcGoNextPointerSlot # do next iteration

3604:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3604#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3605##...slt $at,$t8,$zero
3609##...beq $at,$zero,3624
3612#    and $t8,0xff # mask off hash bits
3613##...lui $at,0
3617##...ori $at,$at,0xff
3621##...and $t8,$t8,$at

3624:  gcSkip5:
3624#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3628#    addu $t8,$t8,8 # ... add in bytes for header-words
3632#    subu $t4,$t1,$t8 # address of first word of source object
3636#    lw $t3,-4($t1) # # words in positive-offset portion
3640#    bge $t3,$zero,gcNoNeg
3641##...slt $at,$t3,$zero
3645##...beq $at,$zero,3652
3648#    move $t3,$zero # negative treated as zero
3652:  gcNoNeg:
3652#    sll $t3,$t3,2 # bytes in negative-offset portion
3656#    addu $t3,$t3,$t1 # address one word past last word of source

3660#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3664#    lw $s0,($t4)
3668#    lw $t9,-8($t1)
3672#    sw $t9,($t4)
3676#    sw $s0,-8($t1)

    # copy all source bytes to the target
3680:  gCinnerCopy2:
3680#    lw $s0,($t4)
3684#    sw $s0,($s3)
3688#    addu $t4,$t4,4
3692#    addu $s3,$s3,4
3696#    bltu $t4,$t3,gCinnerCopy2
3697##...sltu $at,$t4,$t3
3701##...bne $at,$zero,3680

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3704#    sw $zero,-8($t1) # 0 in first header-slot
3708#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3712#    sw $t8,($t0)

3716:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3716#    addu $t0,$t0,4
3720#    bltu $t0,$s1,gcNextPointerInObject
3721##...sltu $at,$t0,$s1
3725##...bne $at,$zero,3564

3728:  gcTestIterDone2:
3728#    bltu $t0,$s3,gcHeapCopyLoop
3729##...sltu $at,$t0,$s3
3733##...bne $at,$zero,3448

    ###### end outer loop to copy all non-stack-direct objects ######

3736:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3736#    lw $s2,($sp)
3740#    addu $sp,$sp,4

    # mark us as having already GC'd
3744#    move $t5,$s5

    # go try and allocate again
3748#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3752:vm_init:

    # mark bottom of stack
3752#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3756#    move $s2,$zero

    #set up the "five" register
3760#    li $s5,5

3764#    la $s3,seg0_start
3768#    la $s4,seg0_end
3769##...lui $s4,16
3773##...addiu $s4,$s4,4708
    
    # return
3776#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3780:divide:
    # get parameters; abort if divisor zero
3780#    lw $t0,($sp)
3784#    lw $t1,8($sp)
3788#    beq $t0,$zero,divByZeroError
    
    # perform division
3792#    div $t1,$t0
3796#    mflo $t0

    # store result, adjust stack and return
3800#    addu $sp,$sp,8 # adjust stack
3804#    sw $t0,($sp) # store result
3808#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3812:remainder:
    # get parameters; abort if divisor zero
3812#    lw $t0,($sp)
3816#    lw $t1,8($sp)
3820#    beq $t0,$zero,divByZeroError
    
    # perform division
3824#    div $t1,$t0
3828#    mfhi $t0

    # store result, adjust stack and return
3832#    addu $sp,$sp,8 # adjust stack
3836#    sw $t0,($sp) # store result
3840#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3844:checkCast:
    # get object, allow immediately if null
3844#    lw $t2,($sp)
3848#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3852#    lw $t2,-12($t2) # vtable address
3856#    bge $t2,$t1,castException
3857##...slt $at,$t2,$t1
3861##...beq $at,$zero,3996
3864#    blt $t2,$t0,castException
3865##...slt $at,$t2,$t0
3869##...bne $at,$zero,3996
    
    # return, leaving object unchanged on stack
3872:  checkCastReturn:    
3872#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3876:instanceOf:
    # get object, go return false if null
3876#    lw $t2,($sp)
3880#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3884#    lw $t2,-12($t2) # vtable address
3888#    sge $t0,$t2,$t0 # are we >= the lower limit?
3889##...slt $t0,$t2,$t0
3893##...xori $t0,$t0,0x1
3896#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3900#    and $t2,$t0,$t1
3904#    sw $t2,($sp)
3908:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3908#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3912:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3912#    li $v0,4 # syscall-code for print-string
3916#    syscall
3920:exit:
    # print termination message
3920#    li $v0,4 # syscall-code for print-string
3924#    la $a0,exitString
3928#    syscall

    # terminate execution
3932#    li $v0,10 #syscall-code for "exit"
3936#    syscall

3940:outOfHeapMemory:
3940#    la $a0,heapMemoryMsg
3944#    j exitError
3948:divByZeroError:
3948#    la $a0,divByZeroMsg
3952#    j exitError
3956:strIndexOutOfBounds:
3956#    la $a0,strIndexOutOfBoundsMsg
3960#    j exitError
3964:arrayIndexOutOfBounds:
3964#    la $a0,arrayIndexOutOfBoundsMsg
3968#    j exitError
3972:arraySizeOutOfBounds:
3972#    la $a0,arraySizeOutOfBoundsMsg
3976#    j exitError
3980:nullPtrException:
3980#    la $a0,nullPtrExceptionMsg
3984#    j exitError
3988:badIntegerFormat:
3988#    la $a0,badIntegerFormatMsg
3992#    j exitError
3996:castException:
3996#    la $a0,castExceptionMsg
4000#    j exitError
############## data section ################
    .data
4344:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4360:cur_seg:
    .word 0

4364:lastCharRead:
    .word -2 # -2 => no buffered character
4368:prevHashConstant:
    .word 0x2785173c
4372:gcCount:
    .word 0

4376:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4403:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4426:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4461:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4495:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4528:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4559:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4607:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4628:gcMsg: 
      .asciiz "\nGC!\n"
4634:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4666:nullStr:
    .asciiz "null"
4671:trueString:
    .asciiz "true"
4676:falseString:
    .asciiz "false"
4682:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4701:newlineString:
    .asciiz "\n"
    
    .align 2
4704:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4708:seg0_start:
    .space 0x100000
1053284:seg0_end:
1053284:seg1_start:
    .space 0x100000
2101860:seg1_end:

###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1260:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1260#    lw $t0,-8($s2) # get word with hash bits from this
1264#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1268#    addu $t0,$t1

1272#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1276:mth_equals_Object:
1276#    move $t0,$s2 # first pointer (this)
1280#    lw $t1,($sp) # second pointer
1284#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1285##...subu $at,$t0,$t1
1289##...sltiu $t0,$at,1

1292#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1296:mth_hashCode_String:
1296#    move $t0,$s2 # put this pointer in t0

1300#    li $t2,0 # current hash value
1304#    lw $t1,-4($t0) # negative of number of characters in string
1308#    beq $t1,$zero,done_hashCode_String # if zero length => done
1312#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1316#    and $t0,0xfffffffc # adjust for padding
1317##...lui $at,65535
1321##...ori $at,$at,0xfffc
1325##...and $t0,$t0,$at
1328#    subu $t1,$t0,$t1 # address at end of string +12
1332:loop_hashCode_String:    
1332#    sll $t4,$t2,5 # multiply by 32
1336#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1340#    lbu $t3,-12($t0) # current character
1344#    addu $t2,$t3 # add in current character
1348#    addu $t0,1 # go to next character's address
1352#    bne $t0,$t1,loop_hashCode_String # loop back if more
1356:done_hashCode_String:    

    # push int on stack
1356#    move $t0, $t2 # put $t2 in return slot
1360#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1364:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1364#    subu $sp,4
1368#    sw $ra,($sp)
    
    # get hash value
1372#    lw $t2,-12($s2) # vtable address
1376#    lw $t0,($t2) # method address
1380#    jalr $t0
1384#    subu $sp,8 # push result (int in $t0) on stack
1388#    sw $s5,4($sp)
1392#    sw $t0,($sp)

    # compute print-size of hash value
1396#    li $t0, 1
1400#    lw $t1, ($sp)
1404#    srl $t1,$t1,4
1408#    beq $t1,$zero,toString_skip_loop
1412:toString_loop_top:
1412#    addu $t0,1
1416#    srl $t1,$t1,4
1420#    bne $t1,$zero,toString_loop_top
1424:toString_skip_loop:
1424#    subu $sp,8
1428#    sw $s5,4($sp)
1432#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1436#    lw $t2,-12($s2) # vtable address
1440#    move $t0,$t2
1444:toString_checkTagBit:
1444#    subu $t0,1
1448#    lb $t1,($t0)
1452#    and $t1,0x80
1453##...lui $at,0
1457##...ori $at,$at,0x80
1461##...and $t1,$t1,$at
1464#    beq $t1,$zero,toString_checkTagBit
1468#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1472#    subu $sp,8
1476#    sw $t1,($sp)
1480#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1484#    move $s7,$zero # -4 offset header word
1488#    lw $t4,8($sp) # bytes for hash value
1492#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1496#    addu $t4,8
1500#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1504#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1508#    li $t0,CLASS_String # store string vtable address into ...
1512#    sw $t0,-12($s7) # ... -12 offset in object header
1516#    lw $t2,-12($s2) # our object's vtable address
1520#    lw $t5,4($sp) # number characters in prefix
1524#    lw $t1,12($sp) # number of characters in hashcode
1528#    addu $t3,$t1,$t5 # number of characters in string ...
1532#    addu $t3,1 # ... including the '@' character
1536#    subu $t0,$zero,$t3 # store negated length into ...
1540#    sw $t0,-4($s7) # ... -4 offset header word
1544#    lw $t0,-8($s7) # get -8 offset header-word
1548#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1549##...slt $at,$t0,$zero
1553##...beq $at,$zero,1572
1556#    and $t0,0xff # mask off object's hash value ...
1557##...lui $at,0
1561##...ori $at,$at,0xff
1565##...and $t0,$t0,$at
1568#    sw $t0,-8($s7) # ... and store back into -8 header-word
1572:skipMask_toString:
1572#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1576#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1580#    subu $t4,$t2,$t5
1584:toString_copyLoop:    
1584#    lb $t3,($t4)
1588#    and $t3,0x7f # mask off sign bit (in case first word)
1589##...lui $at,0
1593##...ori $at,$at,0x7f
1597##...and $t3,$t3,$at
1600#    sb $t3,-8($t0)
1604#    addu $t4,1
1608#    addu $t0,1
1612#    blt $t4,$t2,toString_copyLoop
1613##...slt $at,$t4,$t2
1617##...bne $at,$zero,1584

    # copy the '@' sign
1620#    li $t3,'@'
1624#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1628#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1632#    lw $t3,20($sp) # hash code to print
1636:toString_hashCopyLoop:
1636#    and $t4,$t3,0xf
1640#    srl $t3,4
1644#    lb $t4,hexChars($t4)
1648#    sb $t4,-8($t2)
1652#    subu $t2,$t2,1
1656#    bgt $t2,$t0,toString_hashCopyLoop
1657##...slt $at,$t0,$t2
1661##...bne $at,$zero,1636

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1664#    addu $sp,28
1668#    lw $ra,($sp)
1672#    addu $sp,4
1676#    move $t0, $s7 # return string we created
1680#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1684:mth_equals_String:
    
    # quick test for obvious false
1684#    lw $t0,($sp) # second parameter
1688#    beq $t0,$zero,goEsFalse # go return false if null
1692#    lw $t1,-12($t0) # vtable pointer
1696#    la $t2,CLASS_String # string vtable pointer
1700#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1704#    subu $sp,12
1708#    sw $ra,8($sp)
1712#    sw $s2,4($sp)
1716#    sw $t0,($sp)
1720#    jal mth_compareTo_String
1724#    lw $s2, 4($sp) #restore this pointer and pop parameters
1728#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1732#    seq $t0,$t0,$zero
1733##...subu $at,$t0,$zero
1737##...sltiu $t0,$at,1

    # pop return address and return $t0
1740#    lw $ra,($sp)
1744#    addu $sp,4

1748#    jr $ra # return
    
1752:goEsFalse:
    # put 0 in $t0 and return
1752#    li $t0, 0
1756#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1760:mth_toString_String:
    #we are a string, so return this.
1760#    move $t0, $s2
1764#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1768:mth_readLine_Lib:
    
1768#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1772#    sw $ra, 4($sp) # save $ra
1776#    move $t1,$sp # save "original" sp

1780:  doRead:

    # read the character
1780#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1784#    subu $t2,$v0,13
1788#    bne $t2,$zero,notReturnRL
1792#    jal readLogicalChar
1796#    subu $t2,$v0,10 # check for newline
1800#    beq $t2,$zero,foundNewLine
1804#    sw $v0,lastCharRead # push back character into queue
1808#    j foundNewLine # go process the line

1812:  notReturnRL:

    # at this point, $v0 has our character

1812#    subu $t0,$v0,10
1816#    beq $t0,$zero,foundNewLine
1820#    blt $v0,$zero,foundEof
1821##...slt $at,$v0,$zero
1825##...bne $at,$zero,1840

    # we have a character, so push it onto stack
1828#    subu $sp,$sp,4
1832#    sw $v0,($sp)

    # loop back up to get next character
1836#    j doRead

1840:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1840#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1844#    li $s7, 0 # return-value: null
1848#    j rlReturn # return

1852:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1852#    subu $t0,$t1,$sp # number of chars we read (times 4)
1856#    srl $s6,$t0,2 # number of words on stack with chars
1860#    subu $sp,$sp,4 # push char-count ...
1864#    sw $s6,($sp) # ... onto stack
1868#    addu $t2,$t0,5 # GC tag, incl. for count-word
1872#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1876#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1880#    srl $s6,$s6,2  # data words in object
1884#    move $s7,$zero # object words in object
1888#    jal newObject  # allocate space
    
    # store header words
1892#    la $t0,CLASS_String
1896#    sw $t0,-12($s7)# store class tag (String) into object
1900#    lw $t2,4($sp) # char-count
1904#    sll $t1,$t2,2 # 4 times number of chars
1908#    subu $t2,$zero,$t2 # negative of char-count
1912#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1916#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1920#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1921##...slt $at,$t0,$zero
1925##...beq $at,$zero,1944
1928#    and $t0,0xff # mask off object's hash value ...
1929##...lui $at,0
1933##...ori $at,$at,0xff
1937##...and $t0,$t0,$at
1940#    sw $t0,-8($s7) # ... and store back into -8 header-word
1944:  skipMask_readLine:

1944#    sll $t0,$t0,2 # data bytes in object
1948#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1952#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1956#    addu $sp,$sp,8 # pop redundant object-pointer and count
1960#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1964#    beq $sp,$t1,rlReturn
1968:  charCopyLoop:
1968#    lw $t2,($sp)
1972#    sb $t2,-9($t0)
1976#    addu $sp,$sp,4
1980#    subu $t0,$t0,1
1984#    bne $sp,$t1,charCopyLoop
1988:  rlReturn:

1988#    lw $ra, 4($sp)
1992#    addu $sp, 8   # pop $ra and pointless word off stack
1996#    move $t0, $s7 # return string we allocated in $s7
2000#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2004:mth_readInt_Lib:

    # save $ra by pushing onto stack
2004#    subu $sp,$sp,4
2008#    sw $ra,($sp)

2012:  riSkipWhiteLoop:
    # read a character
2012#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2016#    subu $t0,$v0,32
2020#    bgt $t0,$zero,nonWhite
2021##...slt $at,$zero,$t0
2025##...bne $at,$zero,2068
2028#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2032#    subu $t0,$v0,10
2036#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2040#    subu $t0,$v0,9
2044#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2048#    subu $t0,$v0,13
2052#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2056#    subu $t0,$v0,12
2060#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2064#    j badIntegerFormat # illegal integer char: abort program

2068:  nonWhite:

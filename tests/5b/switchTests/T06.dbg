    # storing digits on stack until we reach 0
2888:  itsNonNegLoop:
2888#    divu $t1,$t3
2892#    mflo $t1 # quotient
2896#    mfhi $t4 # remainder
2900#    addu $t4,$t4,'0' # turn remainder into digit
2904#    subu $sp,$sp,4

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3740#    sw $zero,-8($t1) # 0 in first header-slot
3744#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
3748#    sw $t2,4($t0)
3752#    lw $zero,-8($t2)
3756#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
3760#    j gcTestIterDone1

3764:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
3764#    subu $t0,$t0,$t1
3768#    subu $t0,$t0,3

3772:  gcTestIterDone1:
3772#    bgeu $t0,$sp,gcStackCopyLoop
3773##...sltu $at,$t0,$sp
3777##...beq $at,$zero,3588

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
3780#    lw $t1,cur_seg
3784#    la $t0,seg0_start
3788#    beq $t1,$zero,gcSkip4
3792#    la $t0,seg1_start
3793##...lui $t0,16
3797##...addiu $t0,$t0,5076


3800:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
3800#    bgeu $t0,$s3,gcFinishUp
3801##...sltu $at,$t0,$s3
3805##...beq $at,$zero,4096

    ###### begin outer loop to copy all non-stack-direct objects ######

3808:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
3808#    lw $t1,($t0) # (what will be) first header word for current object
3812#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
3816#    bge $t2,$zero,gcSkip4a # are there hash bits?
3817##...slt $at,$t2,$zero
3821##...beq $at,$zero,3836
3824#    and $t2,0xff # mask off hash bits
3825##...lui $at,0
3829##...ori $at,$at,0xff
3833##...and $t2,$t2,$at
3836:gcSkip4a:    
3836#    sll $t2,$t2,2 # # data bytes
3840#    addu $t2,$t2,8 # to skip header words
3844#    addu $t2,$t0,$t2 # pointer to new object
3848#    lw $t3,-8($t2) # word to swap
3852#    sw $t1,-8($t2) # store header word
3856#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3860#    lw $t1,-12($t2) # vtable pointer
3864#    li $t0,dataArrayVTableStart # address of vtable for first data array
3868#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3869##...slt $at,$t1,$t0
3873##...bne $at,$zero,3892

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3876:  skipToNextObj:
3876#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3880#    sll $t1,$t1,2 # convert to byte-count
3884#    addu $t0,$t2,$t1 # skip over object
3888#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3892:  gcNotDataArray:
3892#    lw $t3,-4($t2) # # object words (negative treated as zero)
3896#    bge $t3,$zero,gcH2Neg2
3897##...slt $at,$t3,$zero
3901##...beq $at,$zero,3908
3904#    move $t3,$zero
3908:  gcH2Neg2:
3908#    sll $t3,$t3,2 # # object bytes
3912#    move $t0,$t2 # address of first pointer in object
3916#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3920#    beq $t0,$s1,gcTestIterDone2
    
3924:  gcNextPointerInObject:
    # get pointer from object
3924#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3928#    bleu $t1,$t6,gcGoNextPointerSlot
3929##...sltu $at,$t6,$t1
3933##...beq $at,$zero,4076
3936#    bgtu $t1,$t7,gcGoNextPointerSlot
3937##...sltu $at,$t7,$t1
3941##...bne $at,$zero,4076

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3944#    lw $t8,-8($t1) # possible forwarding tag
3948#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3952#    lw $t8,-4($t1) # forwarding pointer: object's new address
3956#    sw $t8,($t0) # update pointer in object
3960#    j gcGoNextPointerSlot # do next iteration

3964:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3964#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3965##...slt $at,$t8,$zero
3969##...beq $at,$zero,3984
3972#    and $t8,0xff # mask off hash bits
3973##...lui $at,0
3977##...ori $at,$at,0xff
3981##...and $t8,$t8,$at

3984:  gcSkip5:
3984#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3988#    addu $t8,$t8,8 # ... add in bytes for header-words
3992#    subu $t4,$t1,$t8 # address of first word of source object
3996#    lw $t3,-4($t1) # # words in positive-offset portion
4000#    bge $t3,$zero,gcNoNeg
4001##...slt $at,$t3,$zero
4005##...beq $at,$zero,4012
4008#    move $t3,$zero # negative treated as zero
4012:  gcNoNeg:
4012#    sll $t3,$t3,2 # bytes in negative-offset portion
4016#    addu $t3,$t3,$t1 # address one word past last word of source

4020#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4024#    lw $s0,($t4)
4028#    lw $t9,-8($t1)
4032#    sw $t9,($t4)
4036#    sw $s0,-8($t1)

    # copy all source bytes to the target
4040:  gCinnerCopy2:
4040#    lw $s0,($t4)
4044#    sw $s0,($s3)
4048#    addu $t4,$t4,4
4052#    addu $s3,$s3,4
4056#    bltu $t4,$t3,gCinnerCopy2
4057##...sltu $at,$t4,$t3
4061##...bne $at,$zero,4040

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4064#    sw $zero,-8($t1) # 0 in first header-slot
4068#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4072#    sw $t8,($t0)

4076:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4076#    addu $t0,$t0,4
4080#    bltu $t0,$s1,gcNextPointerInObject
4081##...sltu $at,$t0,$s1
4085##...bne $at,$zero,3924

4088:  gcTestIterDone2:
4088#    bltu $t0,$s3,gcHeapCopyLoop
4089##...sltu $at,$t0,$s3
4093##...bne $at,$zero,3808

    ###### end outer loop to copy all non-stack-direct objects ######

4096:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4096#    lw $s2,($sp)
4100#    addu $sp,$sp,4

    # mark us as having already GC'd
4104#    move $t5,$s5

    # go try and allocate again
4108#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4112:vm_init:

    # mark bottom of stack
4112#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4116#    move $s2,$zero

    #set up the "five" register
4120#    li $s5,5

4124#    la $s3,seg0_start
4128#    la $s4,seg0_end
4129##...lui $s4,16
4133##...addiu $s4,$s4,5076
    
    # return
4136#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4140:divide:
    # get parameters; abort if divisor zero
4140#    lw $t0,($sp)
4144#    lw $t1,8($sp)
4148#    beq $t0,$zero,divByZeroError
    
    # perform division
4152#    div $t1,$t0
4156#    mflo $t0

    # store result, adjust stack and return
4160#    addu $sp,$sp,8 # adjust stack
4164#    sw $t0,($sp) # store result
4168#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4172:remainder:
    # get parameters; abort if divisor zero
4172#    lw $t0,($sp)
4176#    lw $t1,8($sp)
4180#    beq $t0,$zero,divByZeroError
    
    # perform division
4184#    div $t1,$t0
4188#    mfhi $t0

    # store result, adjust stack and return
4192#    addu $sp,$sp,8 # adjust stack
4196#    sw $t0,($sp) # store result
4200#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4204:checkCast:
    # get object, allow immediately if null
4204#    lw $t2,($sp)
4208#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4212#    lw $t2,-12($t2) # vtable address
4216#    bge $t2,$t1,castException
4217##...slt $at,$t2,$t1
4221##...beq $at,$zero,4356
4224#    blt $t2,$t0,castException
4225##...slt $at,$t2,$t0
4229##...bne $at,$zero,4356
    
    # return, leaving object unchanged on stack
4232:  checkCastReturn:    
4232#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4236:instanceOf:
    # get object, go return false if null
4236#    lw $t2,($sp)
4240#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4244#    lw $t2,-12($t2) # vtable address
4248#    sge $t0,$t2,$t0 # are we >= the lower limit?
4249##...slt $t0,$t2,$t0
4253##...xori $t0,$t0,0x1
4256#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4260#    and $t2,$t0,$t1
4264#    sw $t2,($sp)
4268:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4268#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4272:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4272#    li $v0,4 # syscall-code for print-string
4276#    syscall
4280:exit:
    # print termination message
4280#    li $v0,4 # syscall-code for print-string
4284#    la $a0,exitString
4288#    syscall

    # terminate execution
4292#    li $v0,10 #syscall-code for "exit"
4296#    syscall

4300:outOfHeapMemory:
4300#    la $a0,heapMemoryMsg
4304#    j exitError
4308:divByZeroError:
4308#    la $a0,divByZeroMsg
4312#    j exitError
4316:strIndexOutOfBounds:
4316#    la $a0,strIndexOutOfBoundsMsg
4320#    j exitError
4324:arrayIndexOutOfBounds:
4324#    la $a0,arrayIndexOutOfBoundsMsg
4328#    j exitError
4332:arraySizeOutOfBounds:
4332#    la $a0,arraySizeOutOfBoundsMsg
4336#    j exitError
4340:nullPtrException:
4340#    la $a0,nullPtrExceptionMsg
4344#    j exitError
4348:badIntegerFormat:
4348#    la $a0,badIntegerFormatMsg
4352#    j exitError
4356:castException:
4356#    la $a0,castExceptionMsg
4360#    j exitError
############## data section ################
    .data
4712:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4728:cur_seg:
    .word 0

4732:lastCharRead:
    .word -2 # -2 => no buffered character
4736:prevHashConstant:
    .word 0x2785173c
4740:gcCount:
    .word 0

4744:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4771:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4794:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4829:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4863:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4896:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4927:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4975:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4996:gcMsg: 
      .asciiz "\nGC!\n"
5002:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5034:nullStr:
    .asciiz "null"
5039:trueString:
    .asciiz "true"
5044:falseString:
    .asciiz "false"
5050:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5069:newlineString:
    .asciiz "\n"
    
    .align 2
5072:stack_bottom:
    .word 0


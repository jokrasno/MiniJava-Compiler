    
    # allocate memory
3220#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
3224#    srl $s6,$s6,2
3228#    move $s7,$zero # no "object" words in object
3232#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
3236#    lw $t0,4($sp)
3240#    addu $sp,$sp,8

    # store "String" tag into class field
3244#    subu $s7,$s7,8 # address of header-1 word
3248#    la $t1,CLASS_String
3252#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
3256#    lw $t4,($s7) # # data words in source string
3260#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
3261##...slt $at,$t4,$zero
3265##...beq $at,$zero,3284
3268#    and $t4,0xff # mask off object's hash value ...
3269##...lui $at,0
3273##...ori $at,$at,0xff
3277##...and $t4,$t4,$at
3280#    sw $t4,($s7) # ... and store back into -8 header-word
3284:skipMask_intToString:
    
    # store negative of char-count into header-2 word
3284#    subu $t0,$zero,$t0
3288#    sw $t0,4($s7)

3292#    lw $t1,($s7) # number of data words in string
3296#    sll $t1,$t1,2 # number data bytes in string
3300#    subu $t1,$s7,$t1 # first location to store chars in string
3304#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
3308:  itsLoop:
3308#    lw $t2,($sp)
3312#    addu $sp,$sp,4
3316#    sb $t2,($t1)
3320#    addu $t1,$t1,1
3324#    bne $t1,$t0,itsLoop

    ####################################################
    # At this point
    # - ($t0+15)&0xfffffffe is our return value
    # - ($sp) contains garbage (old GC tag)
    # - 4($sp) contains return address
    ####################################################

    # adjust stack, restore return address; return
3328#    lw $ra,4($sp)
3332#    addu $sp,$sp,8
3336#    addu $t0,$t0,15
3340#    and $t0,$t0,0xfffffffc
3341##...lui $at,65535
3345##...ori $at,$at,0xfffc
3349##...and $t0,$t0,$at
3352#    jr $ra

########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
3356:mth_intToChar_Lib:
    # save return address
3356#    subu $sp,$sp,4
3360#    sw $ra,($sp)

    # allocate object
3364#    li $s6,2
3368#    move $s7,$zero
3372#    jal newObject

    # get n from string.
3376#    lw $t1,8($sp)

    # store "String" tag into class field
3380#    la $t0,CLASS_String
3384#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
3388#    lw $t4,-8($s7) # # data words in source string
3392#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
3393##...slt $at,$t4,$zero
3397##...beq $at,$zero,3416
3400#    and $t4,0xff # mask off object's hash value ...
3401##...lui $at,0
3405##...ori $at,$at,0xff
3409##...and $t4,$t4,$at
3412#    sw $t4,-8($s7) # ... and store back into -8 header-word
3416:  skipMask_intToChar:

    # store data in string
3416#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
3420#    li $t0,-1
3424#    sw $t0,-4($s7)

    # we're returning $s7
3428#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
3432#    lw $ra,4($sp)
3436#    addu $sp,$sp,8

    # return
3440#    jr $ra

########################################################
# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
3444:mth_compareTo_String:
    # get string pointers and check parameter for null
3444#    lw $t0,($sp) # second string
3448#    beq $t0,$zero,nullPtrException
3452#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
3456#    lw $t2,-4($t0) # negative length of second string
3460#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
3464#    slt $t4,$t3,$t2
3468#    slt $t5,$t2,$t3
3472#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
3476#    lw $t2,-8($t0) # # data words in second string
3480#    lw $t3,-8($t1) # # data words in first string
3484#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
3488#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
3492#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
3496#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
3500#    beq $zero,$t5,skipStrCmpLenzz
3504#    move $t2,$t3
3508:  skipStrCmpLenzz:
3508#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
3512:  cmpLoopzz:
3512#    lw $t3,-8($t1) # word from str2
3516#    lw $t4,-8($t0) # word from str1
3520#    bne $t3,$t4,cmpNotEqualzz
3524#    addu $t1,$t1,4
3528#    addu $t0,$t0,4
3532#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
3536#    j cmpHitLimitzz

3540:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
3540#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
3544#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
3548#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
3552:  cmpHitLimitzz:
3552#    move $t0, $t5 # store return value
3556#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
3560:readLogicalChar:

    # check if we already have a character
3560#    lw $v0,lastCharRead
3564#    li $t0,-2
3568#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
3572#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
3576#    jr $ra # return
    
3580:  doReadCh:
    # we need to actually read a character: read and return
3580#    li $v0,12 # use system call to read a character
3584#    syscall
3588#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
3592:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
3592#    blt $s7,$zero arraySizeOutOfBounds
3593##...slt $at,$s7,$zero
3597##...bne $at,$zero,4588

    # mark the fact that we have not yet GC'd for this allocation
3600#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

3604:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
3604#    addu $t0,$s6,$s7
3608#    sll $t0,$t0,2
3612#    addu $t0,$t0,8 # amount of memory needed
3616#    addu $t1,$t0,$s3
3620#    bgtu $t1,$s4,doGC
3621##...sltu $at,$s4,$t1
3625##...bne $at,$zero,3748

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
3628#    move $t2,$s3
3632:  zeroObjLoop:
3632#    sw $zero,($s3)
3636#    lw $zero,($s3)

3640#    addu $s3,4
3644#    bltu $s3,$t1,zeroObjLoop
3645##...sltu $at,$s3,$t1
3649##...bne $at,$zero,3632

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
3652#    sll $t0,$s7,2    # number of post-header bytes
3656#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
3660#    li $t2,255
3664#    bgeu $s6,$t2 firstHeaderLarge
3665##...sltu $at,$s6,$t2
3669##...beq $at,$zero,3716
3672#    lw $t1,prevHashConstant
3676#    addu $t1,0x12b68fd2
3677##...lui $at,4791
3681##...addiu $at,$at,-28718
3685##...addu $t1,$at,$t1
3688#    sw $t1,prevHashConstant # update hash constant
3692#    or $t1,0x80000000 # set top bit
3693##...lui $at,32768
3697##...or $t1,$at,$t1
3700#    and $t1,0xffffff00 # clear low bit
3701##...lui $at,65535
3705##...ori $at,$at,0xff00
3709##...and $t1,$t1,$at
3712#    or $s6,$t1
3716:firstHeaderLarge:
3716#    sw $s6,-8($t0) # store header-1 value
3720#    lw $zero,-8($t0)

    # store second header-value
3724#    sw $s7,-4($t0)   # second header-word
3728#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
3732#    move $s7,$t0
3736#    subu $sp,$sp,4
3740#    sw $t0,($sp)

3744#    jr $ra
    
3748:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
3748#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
3752#    lw $t5,gcCount
3756#    addu $t5,1
3760#    sw $t5,gcCount

    # save $s2 (our only rooted register) on the stack
    # so that the garbage collector processes it
3764#    subu $sp,$sp,4
3768#    sw $s2,($sp)

    # set $s3 to the address of the new segment and the
    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
3772#    lw $t0,cur_seg
3776#    move $t7,$s4
3780#    la $t6,seg1_start
3781##...lui $t6,16
3785##...addiu $t6,$t6,5180
3788#    la $s3,seg0_start
3792#    la $s4,seg0_end
3793##...lui $s4,16
3797##...addiu $s4,$s4,5180
3800#    sw $zero,cur_seg
3804#    bne $t0,$zero,skipGc1
3808#    la $t6,seg0_start
3812#    la $s3,seg1_start
3813##...lui $s3,16
3817##...addiu $s3,$s3,5180
3820#    la $s4,seg1_end
3821##...lui $s4,32
3825##...addiu $s4,$s4,5180
3828#    sw $s5,cur_seg
3832:  skipGc1:
3832#    li $t5,0x80000000
3836#    lw $t0,stack_bottom
3840#    subu $t0,4


    ###############################################################
    # at this point:
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first address of the target space
    # - $s4 contains the limit address of the target space
    # - cur_seg has been updated to refer to the target space
    # - $t0 contains the address of the deepest stack element
    # - $sp contains the address of the top stack element
    # - $s2 is available for use, having been pushed onto the stack
    # - $t5 contains the value 0x80000000
    ###############################################################

    ###### begin outer loop to copy all stack-direct objects ######

3844:  gcStackCopyLoop:
3844#    lw $t1,($t0) # current stack element

    # test if we have a GC tag
3848#    sll $t2,$t1,31 # zero iff low bit was zero
3852#    bne $t2,$zero,gcBump # go skip data values if low bit not zero

    # bump stack-address pointer
3856#    subu $t0,$t0,4

    # if value is out of range (which includes null=0), and is
    # therefore does not refer to an object on the heap, just go
    # loop back and do the next one
3860#    bleu $t1,$t6,gcTestIterDone1
3861##...sltu $at,$t6,$t1
3865##...beq $at,$zero,4028
3868#    bgtu $t1,$t7,gcTestIterDone1
3869##...sltu $at,$t7,$t1
3873##...bne $at,$zero,4028

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3876#    lw $t2,-8($t1) # possible forwarding tag
3880#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
3884#    lw $t2,-4($t1) # forwarding pointer: object's new address
3888#    sw $t2,4($t0) # update stack value
3892#    j gcTestIterDone1 # do next iteration

3896:  gcNoForward1:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    # compute the amount of space that is needed
3896#    bge $t2,$zero,gcSkip2
3897##...slt $at,$t2,$zero
3901##...beq $at,$zero,3916
3904#    and $t2,0xff #### mask off hash value
3905##...lui $at,0
3909##...ori $at,$at,0xff
3913##...and $t2,$t2,$at
    #### OLD
    #### subu $t2,$zero,$t2 # set to 1 if -1 (number of data words)

3916:  gcSkip2:
3916#    sll $t2,$t2,2
3920#    addu $t2,$t2,8
3924#    subu $t4,$t1,$t2 # address of first word of source
3928#    lw $t3,-4($t1) # number of object words (negative means zero)
3932#    bge $t3,$zero,gcH2Neg1
3933##...slt $at,$t3,$zero
3937##...beq $at,$zero,3944
3940#    move $t3,$zero
3944:  gcH2Neg1:
3944#    sll $t3,$t3,2
3948#    addu $t3,$t3,$t1 # address one word past last word of source

3952#    addu $t2,$s3,$t2 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object (i.e., the address just beyond the object's header)
    # - $t2 contains the pointer to the target object
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0-2
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger" in the target space
3956#    lw $s0,($t4)
3960#    lw $s1,-8($t1)
3964#    sw $s1,($t4)
3968#    sw $s0,-8($t1)
    
    # copy all source bytes to the target
3972:  gCinnerCopy1:
3972#    lw $s0,($t4)
3976#    sw $s0,($s3)
3980#    addu $t4,$t4,4
3984#    addu $s3,$s3,4
3988#    bltu $t4,$t3,gCinnerCopy1
3989##...sltu $at,$t4,$t3
3993##...bne $at,$zero,3972

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3996#    sw $zero,-8($t1) # 0 in first header-slot
4000#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
4004#    sw $t2,4($t0)
4008#    lw $zero,-8($t2)
4012#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
4016#    j gcTestIterDone1

4020:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
4020#    subu $t0,$t0,$t1
4024#    subu $t0,$t0,3

4028:  gcTestIterDone1:
4028#    bgeu $t0,$sp,gcStackCopyLoop
4029##...sltu $at,$t0,$sp
4033##...beq $at,$zero,3844

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
4036#    lw $t1,cur_seg
4040#    la $t0,seg0_start
4044#    beq $t1,$zero,gcSkip4
4048#    la $t0,seg1_start
4049##...lui $t0,16
4053##...addiu $t0,$t0,5180


4056:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
4056#    bgeu $t0,$s3,gcFinishUp
4057##...sltu $at,$t0,$s3
4061##...beq $at,$zero,4352

    ###### begin outer loop to copy all non-stack-direct objects ######

4064:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
4064#    lw $t1,($t0) # (what will be) first header word for current object
4068#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
4072#    bge $t2,$zero,gcSkip4a # are there hash bits?
4073##...slt $at,$t2,$zero
4077##...beq $at,$zero,4092
4080#    and $t2,0xff # mask off hash bits
4081##...lui $at,0
4085##...ori $at,$at,0xff
4089##...and $t2,$t2,$at
4092:gcSkip4a:    
4092#    sll $t2,$t2,2 # # data bytes
4096#    addu $t2,$t2,8 # to skip header words
4100#    addu $t2,$t0,$t2 # pointer to new object
4104#    lw $t3,-8($t2) # word to swap
4108#    sw $t1,-8($t2) # store header word
4112#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
4116#    lw $t1,-12($t2) # vtable pointer
4120#    li $t0,dataArrayVTableStart # address of vtable for first data array
4124#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
4125##...slt $at,$t1,$t0
4129##...bne $at,$zero,4148

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
4132:  skipToNextObj:
4132#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
4136#    sll $t1,$t1,2 # convert to byte-count
4140#    addu $t0,$t2,$t1 # skip over object
4144#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
4148:  gcNotDataArray:
4148#    lw $t3,-4($t2) # # object words (negative treated as zero)
4152#    bge $t3,$zero,gcH2Neg2
4153##...slt $at,$t3,$zero
4157##...beq $at,$zero,4164
4160#    move $t3,$zero
4164:  gcH2Neg2:
4164#    sll $t3,$t3,2 # # object bytes
4168#    move $t0,$t2 # address of first pointer in object
4172#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
4176#    beq $t0,$s1,gcTestIterDone2
    
4180:  gcNextPointerInObject:
    # get pointer from object
4180#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
4184#    bleu $t1,$t6,gcGoNextPointerSlot
4185##...sltu $at,$t6,$t1
4189##...beq $at,$zero,4332
4192#    bgtu $t1,$t7,gcGoNextPointerSlot
4193##...sltu $at,$t7,$t1
4197##...bne $at,$zero,4332

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4200#    lw $t8,-8($t1) # possible forwarding tag
4204#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
4208#    lw $t8,-4($t1) # forwarding pointer: object's new address
4212#    sw $t8,($t0) # update pointer in object
4216#    j gcGoNextPointerSlot # do next iteration

4220:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
4220#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
4221##...slt $at,$t8,$zero
4225##...beq $at,$zero,4240
4228#    and $t8,0xff # mask off hash bits
4229##...lui $at,0
4233##...ori $at,$at,0xff
4237##...and $t8,$t8,$at

4240:  gcSkip5:
4240#    sll $t8,$t8,2 # bytes in negative-offset portion ...
4244#    addu $t8,$t8,8 # ... add in bytes for header-words
4248#    subu $t4,$t1,$t8 # address of first word of source object
4252#    lw $t3,-4($t1) # # words in positive-offset portion
4256#    bge $t3,$zero,gcNoNeg
4257##...slt $at,$t3,$zero
4261##...beq $at,$zero,4268
4264#    move $t3,$zero # negative treated as zero
4268:  gcNoNeg:
4268#    sll $t3,$t3,2 # bytes in negative-offset portion
4272#    addu $t3,$t3,$t1 # address one word past last word of source

4276#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4280#    lw $s0,($t4)
4284#    lw $t9,-8($t1)
4288#    sw $t9,($t4)
4292#    sw $s0,-8($t1)

    # copy all source bytes to the target
4296:  gCinnerCopy2:
4296#    lw $s0,($t4)
4300#    sw $s0,($s3)
4304#    addu $t4,$t4,4
4308#    addu $s3,$s3,4
4312#    bltu $t4,$t3,gCinnerCopy2
4313##...sltu $at,$t4,$t3
4317##...bne $at,$zero,4296

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4320#    sw $zero,-8($t1) # 0 in first header-slot
4324#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4328#    sw $t8,($t0)

4332:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4332#    addu $t0,$t0,4
4336#    bltu $t0,$s1,gcNextPointerInObject
4337##...sltu $at,$t0,$s1
4341##...bne $at,$zero,4180

4344:  gcTestIterDone2:
4344#    bltu $t0,$s3,gcHeapCopyLoop
4345##...sltu $at,$t0,$s3
4349##...bne $at,$zero,4064

    ###### end outer loop to copy all non-stack-direct objects ######

4352:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4352#    lw $s2,($sp)
4356#    addu $sp,$sp,4

    # mark us as having already GC'd
4360#    move $t5,$s5

    # go try and allocate again
4364#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4368:vm_init:

    # mark bottom of stack
4368#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4372#    move $s2,$zero

    #set up the "five" register
4376#    li $s5,5

4380#    la $s3,seg0_start
4384#    la $s4,seg0_end
4385##...lui $s4,16
4389##...addiu $s4,$s4,5180
    
    # return
4392#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4396:divide:
    # get parameters; abort if divisor zero
4396#    lw $t0,($sp)
4400#    lw $t1,8($sp)
4404#    beq $t0,$zero,divByZeroError
    
    # perform division
4408#    div $t1,$t0
4412#    mflo $t0

    # store result, adjust stack and return
4416#    addu $sp,$sp,8 # adjust stack
4420#    sw $t0,($sp) # store result
4424#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4428:remainder:
    # get parameters; abort if divisor zero
4428#    lw $t0,($sp)
4432#    lw $t1,8($sp)
4436#    beq $t0,$zero,divByZeroError
    
    # perform division
4440#    div $t1,$t0
4444#    mfhi $t0

    # store result, adjust stack and return
4448#    addu $sp,$sp,8 # adjust stack
4452#    sw $t0,($sp) # store result
4456#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4460:checkCast:
    # get object, allow immediately if null
4460#    lw $t2,($sp)
4464#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4468#    lw $t2,-12($t2) # vtable address
4472#    bge $t2,$t1,castException
4473##...slt $at,$t2,$t1
4477##...beq $at,$zero,4612
4480#    blt $t2,$t0,castException
4481##...slt $at,$t2,$t0
4485##...bne $at,$zero,4612
    
    # return, leaving object unchanged on stack
4488:  checkCastReturn:    
4488#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4492:instanceOf:
    # get object, go return false if null
4492#    lw $t2,($sp)
4496#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4500#    lw $t2,-12($t2) # vtable address
4504#    sge $t0,$t2,$t0 # are we >= the lower limit?
4505##...slt $t0,$t2,$t0
4509##...xori $t0,$t0,0x1
4512#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4516#    and $t2,$t0,$t1
4520#    sw $t2,($sp)
4524:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4524#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4528:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4528#    li $v0,4 # syscall-code for print-string
4532#    syscall
4536:exit:
    # print termination message
4536#    li $v0,4 # syscall-code for print-string
4540#    la $a0,exitString
4544#    syscall

    # terminate execution
4548#    li $v0,10 #syscall-code for "exit"
4552#    syscall

4556:outOfHeapMemory:
4556#    la $a0,heapMemoryMsg
4560#    j exitError
4564:divByZeroError:
4564#    la $a0,divByZeroMsg
4568#    j exitError
4572:strIndexOutOfBounds:
4572#    la $a0,strIndexOutOfBoundsMsg
4576#    j exitError
4580:arrayIndexOutOfBounds:
4580#    la $a0,arrayIndexOutOfBoundsMsg
4584#    j exitError
4588:arraySizeOutOfBounds:
4588#    la $a0,arraySizeOutOfBoundsMsg
4592#    j exitError
4596:nullPtrException:
4596#    la $a0,nullPtrExceptionMsg
4600#    j exitError
4604:badIntegerFormat:
4604#    la $a0,badIntegerFormatMsg
4608#    j exitError
4612:castException:
4612#    la $a0,castExceptionMsg
4616#    j exitError
############## data section ################
    .data
4816:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4832:cur_seg:
    .word 0

4836:lastCharRead:
    .word -2 # -2 => no buffered character
4840:prevHashConstant:
    .word 0x2785173c
4844:gcCount:
    .word 0

4848:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4875:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4898:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4933:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4967:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5000:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5031:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5079:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5100:gcMsg: 
      .asciiz "\nGC!\n"
5106:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5138:nullStr:
    .asciiz "null"
5143:trueString:
    .asciiz "true"
5148:falseString:
    .asciiz "false"
5154:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5173:newlineString:
    .asciiz "\n"
    
    .align 2
5176:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5180:seg0_start:
    .space 0x100000

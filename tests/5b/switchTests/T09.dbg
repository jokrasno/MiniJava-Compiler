##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1516:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1516#    lw $t0,-8($s2) # get word with hash bits from this
1520#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1524#    addu $t0,$t1

1528#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1532:mth_equals_Object:
1532#    move $t0,$s2 # first pointer (this)
1536#    lw $t1,($sp) # second pointer
1540#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1541##...subu $at,$t0,$t1
1545##...sltiu $t0,$at,1

1548#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1552:mth_hashCode_String:
1552#    move $t0,$s2 # put this pointer in t0

1556#    li $t2,0 # current hash value
1560#    lw $t1,-4($t0) # negative of number of characters in string
1564#    beq $t1,$zero,done_hashCode_String # if zero length => done
1568#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1572#    and $t0,0xfffffffc # adjust for padding
1573##...lui $at,65535
1577##...ori $at,$at,0xfffc
1581##...and $t0,$t0,$at
1584#    subu $t1,$t0,$t1 # address at end of string +12
1588:loop_hashCode_String:    
1588#    sll $t4,$t2,5 # multiply by 32
1592#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1596#    lbu $t3,-12($t0) # current character
1600#    addu $t2,$t3 # add in current character
1604#    addu $t0,1 # go to next character's address
1608#    bne $t0,$t1,loop_hashCode_String # loop back if more
1612:done_hashCode_String:    

    # push int on stack
1612#    move $t0, $t2 # put $t2 in return slot
1616#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1620:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1620#    subu $sp,4
1624#    sw $ra,($sp)
    
    # get hash value
1628#    lw $t2,-12($s2) # vtable address
1632#    lw $t0,($t2) # method address
1636#    jalr $t0
1640#    subu $sp,8 # push result (int in $t0) on stack
1644#    sw $s5,4($sp)
1648#    sw $t0,($sp)

    # compute print-size of hash value
1652#    li $t0, 1
1656#    lw $t1, ($sp)
1660#    srl $t1,$t1,4
1664#    beq $t1,$zero,toString_skip_loop
1668:toString_loop_top:
1668#    addu $t0,1
1672#    srl $t1,$t1,4
1676#    bne $t1,$zero,toString_loop_top
1680:toString_skip_loop:
1680#    subu $sp,8
1684#    sw $s5,4($sp)
1688#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1692#    lw $t2,-12($s2) # vtable address
1696#    move $t0,$t2
1700:toString_checkTagBit:
1700#    subu $t0,1
1704#    lb $t1,($t0)
1708#    and $t1,0x80
1709##...lui $at,0
1713##...ori $at,$at,0x80
1717##...and $t1,$t1,$at
1720#    beq $t1,$zero,toString_checkTagBit
1724#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1728#    subu $sp,8
1732#    sw $t1,($sp)
1736#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1740#    move $s7,$zero # -4 offset header word
1744#    lw $t4,8($sp) # bytes for hash value
1748#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1752#    addu $t4,8
1756#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1760#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1764#    li $t0,CLASS_String # store string vtable address into ...
1768#    sw $t0,-12($s7) # ... -12 offset in object header
1772#    lw $t2,-12($s2) # our object's vtable address
1776#    lw $t5,4($sp) # number characters in prefix
1780#    lw $t1,12($sp) # number of characters in hashcode
1784#    addu $t3,$t1,$t5 # number of characters in string ...
1788#    addu $t3,1 # ... including the '@' character
1792#    subu $t0,$zero,$t3 # store negated length into ...
1796#    sw $t0,-4($s7) # ... -4 offset header word
1800#    lw $t0,-8($s7) # get -8 offset header-word
1804#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1805##...slt $at,$t0,$zero
1809##...beq $at,$zero,1828
1812#    and $t0,0xff # mask off object's hash value ...
1813##...lui $at,0
1817##...ori $at,$at,0xff
1821##...and $t0,$t0,$at
1824#    sw $t0,-8($s7) # ... and store back into -8 header-word
1828:skipMask_toString:
1828#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1832#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1836#    subu $t4,$t2,$t5
1840:toString_copyLoop:    
1840#    lb $t3,($t4)
1844#    and $t3,0x7f # mask off sign bit (in case first word)
1845##...lui $at,0
1849##...ori $at,$at,0x7f
1853##...and $t3,$t3,$at
1856#    sb $t3,-8($t0)
1860#    addu $t4,1
1864#    addu $t0,1
1868#    blt $t4,$t2,toString_copyLoop
1869##...slt $at,$t4,$t2
1873##...bne $at,$zero,1840

    # copy the '@' sign
1876#    li $t3,'@'
1880#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1884#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1888#    lw $t3,20($sp) # hash code to print
1892:toString_hashCopyLoop:
1892#    and $t4,$t3,0xf
1896#    srl $t3,4
1900#    lb $t4,hexChars($t4)
1904#    sb $t4,-8($t2)
1908#    subu $t2,$t2,1
1912#    bgt $t2,$t0,toString_hashCopyLoop
1913##...slt $at,$t0,$t2
1917##...bne $at,$zero,1892

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1920#    addu $sp,28
1924#    lw $ra,($sp)
1928#    addu $sp,4
1932#    move $t0, $s7 # return string we created
1936#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1940:mth_equals_String:
    
    # quick test for obvious false
1940#    lw $t0,($sp) # second parameter
1944#    beq $t0,$zero,goEsFalse # go return false if null
1948#    lw $t1,-12($t0) # vtable pointer
1952#    la $t2,CLASS_String # string vtable pointer
1956#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1960#    subu $sp,12
1964#    sw $ra,8($sp)
1968#    sw $s2,4($sp)
1972#    sw $t0,($sp)
1976#    jal mth_compareTo_String
1980#    lw $s2, 4($sp) #restore this pointer and pop parameters
1984#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1988#    seq $t0,$t0,$zero
1989##...subu $at,$t0,$zero
1993##...sltiu $t0,$at,1

    # pop return address and return $t0
1996#    lw $ra,($sp)
2000#    addu $sp,4

2004#    jr $ra # return
    
2008:goEsFalse:
    # put 0 in $t0 and return
2008#    li $t0, 0
2012#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2016:mth_toString_String:
    #we are a string, so return this.
2016#    move $t0, $s2
2020#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2024:mth_readLine_Lib:
    
2024#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2028#    sw $ra, 4($sp) # save $ra
2032#    move $t1,$sp # save "original" sp

2036:  doRead:

    # read the character
2036#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2040#    subu $t2,$v0,13
2044#    bne $t2,$zero,notReturnRL
2048#    jal readLogicalChar
2052#    subu $t2,$v0,10 # check for newline
2056#    beq $t2,$zero,foundNewLine
2060#    sw $v0,lastCharRead # push back character into queue
2064#    j foundNewLine # go process the line

2068:  notReturnRL:

    # at this point, $v0 has our character

2068#    subu $t0,$v0,10
2072#    beq $t0,$zero,foundNewLine
2076#    blt $v0,$zero,foundEof
2077##...slt $at,$v0,$zero
2081##...bne $at,$zero,2096

    # we have a character, so push it onto stack
2084#    subu $sp,$sp,4
2088#    sw $v0,($sp)

    # loop back up to get next character
2092#    j doRead

2096:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2096#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2100#    li $s7, 0 # return-value: null
2104#    j rlReturn # return

2108:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2108#    subu $t0,$t1,$sp # number of chars we read (times 4)
2112#    srl $s6,$t0,2 # number of words on stack with chars
2116#    subu $sp,$sp,4 # push char-count ...
2120#    sw $s6,($sp) # ... onto stack
2124#    addu $t2,$t0,5 # GC tag, incl. for count-word
2128#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2132#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2136#    srl $s6,$s6,2  # data words in object
2140#    move $s7,$zero # object words in object
2144#    jal newObject  # allocate space
    
    # store header words
2148#    la $t0,CLASS_String
2152#    sw $t0,-12($s7)# store class tag (String) into object
2156#    lw $t2,4($sp) # char-count
2160#    sll $t1,$t2,2 # 4 times number of chars
2164#    subu $t2,$zero,$t2 # negative of char-count
2168#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2172#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2176#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2177##...slt $at,$t0,$zero
2181##...beq $at,$zero,2200
2184#    and $t0,0xff # mask off object's hash value ...
2185##...lui $at,0
2189##...ori $at,$at,0xff
2193##...and $t0,$t0,$at
2196#    sw $t0,-8($s7) # ... and store back into -8 header-word
2200:  skipMask_readLine:

2200#    sll $t0,$t0,2 # data bytes in object
2204#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2208#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2212#    addu $sp,$sp,8 # pop redundant object-pointer and count
2216#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2220#    beq $sp,$t1,rlReturn
2224:  charCopyLoop:
2224#    lw $t2,($sp)
2228#    sb $t2,-9($t0)
2232#    addu $sp,$sp,4
2236#    subu $t0,$t0,1
2240#    bne $sp,$t1,charCopyLoop
2244:  rlReturn:

2244#    lw $ra, 4($sp)
2248#    addu $sp, 8   # pop $ra and pointless word off stack
2252#    move $t0, $s7 # return string we allocated in $s7
2256#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2260:mth_readInt_Lib:

    # save $ra by pushing onto stack
2260#    subu $sp,$sp,4
2264#    sw $ra,($sp)

2268:  riSkipWhiteLoop:
    # read a character
2268#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2272#    subu $t0,$v0,32
2276#    bgt $t0,$zero,nonWhite
2277##...slt $at,$zero,$t0
2281##...bne $at,$zero,2324
2284#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2288#    subu $t0,$v0,10
2292#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2296#    subu $t0,$v0,9
2300#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2304#    subu $t0,$v0,13
2308#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2312#    subu $t0,$v0,12
2316#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2320#    j badIntegerFormat # illegal integer char: abort program

2324:  nonWhite:
2324#    subu $t0,$v0,'-'
2328#    li $t4,1 # final multiplier
2332#    bne $t0,$zero,helpReadInt # go read

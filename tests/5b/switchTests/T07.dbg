    # greater
3048#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
3052#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
3056#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
3060:  cmpHitLimitzz:
3060#    move $t0, $t5 # store return value
3064#    jr $ra # return

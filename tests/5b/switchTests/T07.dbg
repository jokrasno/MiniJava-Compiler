3588#    and $t2,0xff # mask off hash bits
3589##...lui $at,0
3593##...ori $at,$at,0xff
3597##...and $t2,$t2,$at
3600:gcSkip4a:    
3600#    sll $t2,$t2,2 # # data bytes
3604#    addu $t2,$t2,8 # to skip header words
3608#    addu $t2,$t0,$t2 # pointer to new object
3612#    lw $t3,-8($t2) # word to swap
3616#    sw $t1,-8($t2) # store header word
3620#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3624#    lw $t1,-12($t2) # vtable pointer
3628#    li $t0,dataArrayVTableStart # address of vtable for first data array
3632#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3633##...slt $at,$t1,$t0
3637##...bne $at,$zero,3656

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3640:  skipToNextObj:
3640#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3644#    sll $t1,$t1,2 # convert to byte-count
3648#    addu $t0,$t2,$t1 # skip over object
3652#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3656:  gcNotDataArray:
3656#    lw $t3,-4($t2) # # object words (negative treated as zero)
3660#    bge $t3,$zero,gcH2Neg2
3661##...slt $at,$t3,$zero
3665##...beq $at,$zero,3672
3668#    move $t3,$zero
3672:  gcH2Neg2:
3672#    sll $t3,$t3,2 # # object bytes
3676#    move $t0,$t2 # address of first pointer in object
3680#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3684#    beq $t0,$s1,gcTestIterDone2
    
3688:  gcNextPointerInObject:
    # get pointer from object
3688#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3692#    bleu $t1,$t6,gcGoNextPointerSlot
3693##...sltu $at,$t6,$t1
3697##...beq $at,$zero,3840
3700#    bgtu $t1,$t7,gcGoNextPointerSlot
3701##...sltu $at,$t7,$t1
3705##...bne $at,$zero,3840

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3708#    lw $t8,-8($t1) # possible forwarding tag
3712#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3716#    lw $t8,-4($t1) # forwarding pointer: object's new address
3720#    sw $t8,($t0) # update pointer in object
3724#    j gcGoNextPointerSlot # do next iteration

3728:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3728#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3729##...slt $at,$t8,$zero
3733##...beq $at,$zero,3748
3736#    and $t8,0xff # mask off hash bits
3737##...lui $at,0
3741##...ori $at,$at,0xff
3745##...and $t8,$t8,$at

3748:  gcSkip5:
3748#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3752#    addu $t8,$t8,8 # ... add in bytes for header-words
3756#    subu $t4,$t1,$t8 # address of first word of source object
3760#    lw $t3,-4($t1) # # words in positive-offset portion
3764#    bge $t3,$zero,gcNoNeg
3765##...slt $at,$t3,$zero
3769##...beq $at,$zero,3776
3772#    move $t3,$zero # negative treated as zero
3776:  gcNoNeg:
3776#    sll $t3,$t3,2 # bytes in negative-offset portion
3780#    addu $t3,$t3,$t1 # address one word past last word of source

3784#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3788#    lw $s0,($t4)
3792#    lw $t9,-8($t1)
3796#    sw $t9,($t4)
3800#    sw $s0,-8($t1)

    # copy all source bytes to the target
3804:  gCinnerCopy2:
3804#    lw $s0,($t4)
3808#    sw $s0,($s3)
3812#    addu $t4,$t4,4
3816#    addu $s3,$s3,4
3820#    bltu $t4,$t3,gCinnerCopy2
3821##...sltu $at,$t4,$t3
3825##...bne $at,$zero,3804

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3828#    sw $zero,-8($t1) # 0 in first header-slot
3832#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3836#    sw $t8,($t0)

3840:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3840#    addu $t0,$t0,4
3844#    bltu $t0,$s1,gcNextPointerInObject
3845##...sltu $at,$t0,$s1
3849##...bne $at,$zero,3688

3852:  gcTestIterDone2:
3852#    bltu $t0,$s3,gcHeapCopyLoop
3853##...sltu $at,$t0,$s3
3857##...bne $at,$zero,3572

    ###### end outer loop to copy all non-stack-direct objects ######

3860:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3860#    lw $s2,($sp)
3864#    addu $sp,$sp,4

    # mark us as having already GC'd
3868#    move $t5,$s5

    # go try and allocate again
3872#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3876:vm_init:

    # mark bottom of stack
3876#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3880#    move $s2,$zero

    #set up the "five" register
3884#    li $s5,5

3888#    la $s3,seg0_start
3892#    la $s4,seg0_end
3893##...lui $s4,16
3897##...addiu $s4,$s4,4804
    
    # return
3900#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3904:divide:
    # get parameters; abort if divisor zero
3904#    lw $t0,($sp)
3908#    lw $t1,8($sp)
3912#    beq $t0,$zero,divByZeroError
    
    # perform division
3916#    div $t1,$t0
3920#    mflo $t0

    # store result, adjust stack and return
3924#    addu $sp,$sp,8 # adjust stack
3928#    sw $t0,($sp) # store result
3932#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3936:remainder:
    # get parameters; abort if divisor zero
3936#    lw $t0,($sp)
3940#    lw $t1,8($sp)
3944#    beq $t0,$zero,divByZeroError
    
    # perform division
3948#    div $t1,$t0
3952#    mfhi $t0

    # store result, adjust stack and return
3956#    addu $sp,$sp,8 # adjust stack
3960#    sw $t0,($sp) # store result
3964#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3968:checkCast:
    # get object, allow immediately if null
3968#    lw $t2,($sp)
3972#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3976#    lw $t2,-12($t2) # vtable address
3980#    bge $t2,$t1,castException
3981##...slt $at,$t2,$t1
3985##...beq $at,$zero,4120
3988#    blt $t2,$t0,castException
3989##...slt $at,$t2,$t0
3993##...bne $at,$zero,4120
    
    # return, leaving object unchanged on stack
3996:  checkCastReturn:    
3996#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4000:instanceOf:
    # get object, go return false if null
4000#    lw $t2,($sp)
4004#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4008#    lw $t2,-12($t2) # vtable address
4012#    sge $t0,$t2,$t0 # are we >= the lower limit?
4013##...slt $t0,$t2,$t0
4017##...xori $t0,$t0,0x1
4020#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4024#    and $t2,$t0,$t1
4028#    sw $t2,($sp)
4032:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4032#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4036:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4036#    li $v0,4 # syscall-code for print-string
4040#    syscall
4044:exit:
    # print termination message
4044#    li $v0,4 # syscall-code for print-string
4048#    la $a0,exitString
4052#    syscall

    # terminate execution
4056#    li $v0,10 #syscall-code for "exit"
4060#    syscall

4064:outOfHeapMemory:
4064#    la $a0,heapMemoryMsg
4068#    j exitError
4072:divByZeroError:
4072#    la $a0,divByZeroMsg
4076#    j exitError
4080:strIndexOutOfBounds:
4080#    la $a0,strIndexOutOfBoundsMsg
4084#    j exitError
4088:arrayIndexOutOfBounds:
4088#    la $a0,arrayIndexOutOfBoundsMsg
4092#    j exitError
4096:arraySizeOutOfBounds:
4096#    la $a0,arraySizeOutOfBoundsMsg
4100#    j exitError
4104:nullPtrException:
4104#    la $a0,nullPtrExceptionMsg
4108#    j exitError
4112:badIntegerFormat:
4112#    la $a0,badIntegerFormatMsg
4116#    j exitError
4120:castException:
4120#    la $a0,castExceptionMsg
4124#    j exitError
############## data section ################
    .data
4440:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4456:cur_seg:
    .word 0

4460:lastCharRead:
    .word -2 # -2 => no buffered character
4464:prevHashConstant:
    .word 0x2785173c
4468:gcCount:
    .word 0

4472:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4499:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4522:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4557:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4591:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4624:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4655:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4703:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4724:gcMsg: 
      .asciiz "\nGC!\n"
4730:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4762:nullStr:
    .asciiz "null"
4767:trueString:
    .asciiz "true"
4772:falseString:
    .asciiz "false"
4778:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4797:newlineString:
    .asciiz "\n"
    
    .align 2
4800:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4804:seg0_start:
    .space 0x100000
1053380:seg0_end:
1053380:seg1_start:
    .space 0x100000
2101956:seg1_end:

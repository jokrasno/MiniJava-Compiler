###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1532:mth_readLine_Lib:
    
1532#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1536#    sw $ra, 4($sp) # save $ra
1540#    move $t1,$sp # save "original" sp

1544:  doRead:

    # read the character
1544#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1548#    subu $t2,$v0,13
1552#    bne $t2,$zero,notReturnRL
1556#    jal readLogicalChar
1560#    subu $t2,$v0,10 # check for newline
1564#    beq $t2,$zero,foundNewLine
1568#    sw $v0,lastCharRead # push back character into queue
1572#    j foundNewLine # go process the line

1576:  notReturnRL:

    # at this point, $v0 has our character

1576#    subu $t0,$v0,10
1580#    beq $t0,$zero,foundNewLine
1584#    blt $v0,$zero,foundEof
1585##...slt $at,$v0,$zero
1589##...bne $at,$zero,1604

    # we have a character, so push it onto stack
1592#    subu $sp,$sp,4
1596#    sw $v0,($sp)

    # loop back up to get next character
1600#    j doRead

1604:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1604#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1608#    li $s7, 0 # return-value: null
1612#    j rlReturn # return

1616:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1616#    subu $t0,$t1,$sp # number of chars we read (times 4)
1620#    srl $s6,$t0,2 # number of words on stack with chars
1624#    subu $sp,$sp,4 # push char-count ...
1628#    sw $s6,($sp) # ... onto stack
1632#    addu $t2,$t0,5 # GC tag, incl. for count-word
1636#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1640#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1644#    srl $s6,$s6,2  # data words in object
1648#    move $s7,$zero # object words in object
1652#    jal newObject  # allocate space
    
    # store header words
1656#    la $t0,CLASS_String
1660#    sw $t0,-12($s7)# store class tag (String) into object
1664#    lw $t2,4($sp) # char-count
1668#    sll $t1,$t2,2 # 4 times number of chars
1672#    subu $t2,$zero,$t2 # negative of char-count
1676#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1680#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1684#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1685##...slt $at,$t0,$zero
1689##...beq $at,$zero,1708
1692#    and $t0,0xff # mask off object's hash value ...
1693##...lui $at,0
1697##...ori $at,$at,0xff
1701##...and $t0,$t0,$at
1704#    sw $t0,-8($s7) # ... and store back into -8 header-word
1708:  skipMask_readLine:

1708#    sll $t0,$t0,2 # data bytes in object
1712#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1716#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1720#    addu $sp,$sp,8 # pop redundant object-pointer and count
1724#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1728#    beq $sp,$t1,rlReturn
1732:  charCopyLoop:
1732#    lw $t2,($sp)
1736#    sb $t2,-9($t0)
1740#    addu $sp,$sp,4
1744#    subu $t0,$t0,1
1748#    bne $sp,$t1,charCopyLoop
1752:  rlReturn:

1752#    lw $ra, 4($sp)
1756#    addu $sp, 8   # pop $ra and pointless word off stack
1760#    move $t0, $s7 # return string we allocated in $s7
1764#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1768:mth_readInt_Lib:

    # save $ra by pushing onto stack
1768#    subu $sp,$sp,4
1772#    sw $ra,($sp)

1776:  riSkipWhiteLoop:
    # read a character
1776#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1780#    subu $t0,$v0,32
1784#    bgt $t0,$zero,nonWhite
1785##...slt $at,$zero,$t0
1789##...bne $at,$zero,1832
1792#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1796#    subu $t0,$v0,10
1800#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1804#    subu $t0,$v0,9
1808#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1812#    subu $t0,$v0,13
1816#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1820#    subu $t0,$v0,12
1824#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1828#    j badIntegerFormat # illegal integer char: abort program

1832:  nonWhite:
1832#    subu $t0,$v0,'-'
1836#    li $t4,1 # final multiplier
1840#    bne $t0,$zero,helpReadInt # go read
1844#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1848#    jal readLogicalChar

1852:  helpReadInt:
1852#    li $t2,10
1856#    subu $t1,$v0,'0' # convert digit to 0-9 value
1860#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1861##...sltu $at,$t1,$t2
1865##...beq $at,$zero,4112
1868#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1872:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1872#    jal readLogicalChar # read next character
1876#    subu $t1,$v0,'0' # convert digit to 0-9 value
1880#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1881##...sltu $at,$t1,$t2
1885##...beq $at,$zero,1904

1888#    mul $t3,$t3,$t2 # multiply old value by 10
1889##...mult $t3,$t2
1893##...mflo $t3
1896#    addu $t3,$t3,$t1 # add in value of new digit
1900#    j digitLoop

1904:  doneDigitLoop:

    # "push back" unused character into queue
1904#    sw $v0,lastCharRead

    # restore return address
1908#    lw $ra,($sp)
1912#    addu $sp, 4

    # multiply by sign and put return value in $t0
1916#    mult $t3,$t4 # multiply to account for poss. minus sign
1920#    mflo $t3
1924#    move $t0, $t3
    
    # return
1928#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1932:mth_readChar_Lib:

    # save $ra by pushing onto stack
1932#    subu $sp,$sp,4
1936#    sw $ra,($sp)

      # read the character
1940#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1944#    lw $ra,($sp)
1948#    addu $sp, 4
1952#    move $t0, $v0

    # return
1956#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
1960:mth_printStr_Lib:

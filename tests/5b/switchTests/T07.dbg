3189##...addiu $at,$at,-28718
3193##...addu $t1,$at,$t1
3196#    sw $t1,prevHashConstant # update hash constant
3200#    or $t1,0x80000000 # set top bit
3201##...lui $at,32768
3205##...or $t1,$at,$t1
3208#    and $t1,0xffffff00 # clear low bit
3209##...lui $at,65535
3213##...ori $at,$at,0xff00
3217##...and $t1,$t1,$at
3220#    or $s6,$t1
3224:firstHeaderLarge:
3224#    sw $s6,-8($t0) # store header-1 value

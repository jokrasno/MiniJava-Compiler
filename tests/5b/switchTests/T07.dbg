###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1448:mth_equals_String:
    
    # quick test for obvious false
1448#    lw $t0,($sp) # second parameter
1452#    beq $t0,$zero,goEsFalse # go return false if null
1456#    lw $t1,-12($t0) # vtable pointer
1460#    la $t2,CLASS_String # string vtable pointer
1464#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1468#    subu $sp,12
1472#    sw $ra,8($sp)
1476#    sw $s2,4($sp)
1480#    sw $t0,($sp)
1484#    jal mth_compareTo_String
1488#    lw $s2, 4($sp) #restore this pointer and pop parameters
1492#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1496#    seq $t0,$t0,$zero
1497##...subu $at,$t0,$zero
1501##...sltiu $t0,$at,1

    # pop return address and return $t0
1504#    lw $ra,($sp)
1508#    addu $sp,4

1512#    jr $ra # return
    
1516:goEsFalse:

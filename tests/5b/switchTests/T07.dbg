###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1060:mth_hashCode_String:
1060#    move $t0,$s2 # put this pointer in t0

1064#    li $t2,0 # current hash value
1068#    lw $t1,-4($t0) # negative of number of characters in string
1072#    beq $t1,$zero,done_hashCode_String # if zero length => done
1076#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1080#    and $t0,0xfffffffc # adjust for padding
1081##...lui $at,65535
1085##...ori $at,$at,0xfffc
1089##...and $t0,$t0,$at
1092#    subu $t1,$t0,$t1 # address at end of string +12
1096:loop_hashCode_String:    
1096#    sll $t4,$t2,5 # multiply by 32
1100#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1104#    lbu $t3,-12($t0) # current character
1108#    addu $t2,$t3 # add in current character
1112#    addu $t0,1 # go to next character's address
1116#    bne $t0,$t1,loop_hashCode_String # loop back if more
1120:done_hashCode_String:    

    # push int on stack
1120#    move $t0, $t2 # put $t2 in return slot
1124#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1128:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1128#    subu $sp,4
1132#    sw $ra,($sp)
    
    # get hash value
1136#    lw $t2,-12($s2) # vtable address
1140#    lw $t0,($t2) # method address
1144#    jalr $t0
1148#    subu $sp,8 # push result (int in $t0) on stack
1152#    sw $s5,4($sp)
1156#    sw $t0,($sp)

    # compute print-size of hash value
1160#    li $t0, 1
1164#    lw $t1, ($sp)
1168#    srl $t1,$t1,4
1172#    beq $t1,$zero,toString_skip_loop
1176:toString_loop_top:
1176#    addu $t0,1
1180#    srl $t1,$t1,4
1184#    bne $t1,$zero,toString_loop_top
1188:toString_skip_loop:
1188#    subu $sp,8
1192#    sw $s5,4($sp)
1196#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1200#    lw $t2,-12($s2) # vtable address
1204#    move $t0,$t2
1208:toString_checkTagBit:
1208#    subu $t0,1
1212#    lb $t1,($t0)
1216#    and $t1,0x80
1217##...lui $at,0
1221##...ori $at,$at,0x80
1225##...and $t1,$t1,$at
1228#    beq $t1,$zero,toString_checkTagBit
1232#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1236#    subu $sp,8
1240#    sw $t1,($sp)
1244#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1248#    move $s7,$zero # -4 offset header word
1252#    lw $t4,8($sp) # bytes for hash value
1256#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1260#    addu $t4,8
1264#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1268#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1272#    li $t0,CLASS_String # store string vtable address into ...
1276#    sw $t0,-12($s7) # ... -12 offset in object header
1280#    lw $t2,-12($s2) # our object's vtable address
1284#    lw $t5,4($sp) # number characters in prefix
1288#    lw $t1,12($sp) # number of characters in hashcode
1292#    addu $t3,$t1,$t5 # number of characters in string ...
1296#    addu $t3,1 # ... including the '@' character
1300#    subu $t0,$zero,$t3 # store negated length into ...
1304#    sw $t0,-4($s7) # ... -4 offset header word
1308#    lw $t0,-8($s7) # get -8 offset header-word
1312#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1313##...slt $at,$t0,$zero
1317##...beq $at,$zero,1336
1320#    and $t0,0xff # mask off object's hash value ...
1321##...lui $at,0
1325##...ori $at,$at,0xff
1329##...and $t0,$t0,$at
1332#    sw $t0,-8($s7) # ... and store back into -8 header-word
1336:skipMask_toString:
1336#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1340#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1344#    subu $t4,$t2,$t5
1348:toString_copyLoop:    
1348#    lb $t3,($t4)
1352#    and $t3,0x7f # mask off sign bit (in case first word)
1353##...lui $at,0
1357##...ori $at,$at,0x7f
1361##...and $t3,$t3,$at
1364#    sb $t3,-8($t0)
1368#    addu $t4,1
1372#    addu $t0,1
1376#    blt $t4,$t2,toString_copyLoop
1377##...slt $at,$t4,$t2
1381##...bne $at,$zero,1348

    # copy the '@' sign
1384#    li $t3,'@'
1388#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1392#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1396#    lw $t3,20($sp) # hash code to print
1400:toString_hashCopyLoop:
1400#    and $t4,$t3,0xf
1404#    srl $t3,4
1408#    lb $t4,hexChars($t4)
1412#    sb $t4,-8($t2)
1416#    subu $t2,$t2,1
1420#    bgt $t2,$t0,toString_hashCopyLoop
1421##...slt $at,$t0,$t2
1425##...bne $at,$zero,1400

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1428#    addu $sp,28
1432#    lw $ra,($sp)
1436#    addu $sp,4
1440#    move $t0, $s7 # return string we created
1444#    jr $ra

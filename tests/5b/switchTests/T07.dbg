########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
3068:readLogicalChar:

    # check if we already have a character
3068#    lw $v0,lastCharRead
3072#    li $t0,-2
3076#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
3080#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
3084#    jr $ra # return
    
3088:  doReadCh:
    # we need to actually read a character: read and return
3088#    li $v0,12 # use system call to read a character
3092#    syscall
3096#    jr $ra # return

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1480#    subu $sp,12
1484#    sw $ra,8($sp)
1488#    sw $s2,4($sp)
1492#    sw $t0,($sp)

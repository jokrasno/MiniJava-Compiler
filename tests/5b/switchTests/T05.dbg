1508#    seq $t0,$t0,$zero
1509##...subu $at,$t0,$zero
1513##...sltiu $t0,$at,1

    # pop return address and return $t0
1516#    lw $ra,($sp)
1520#    addu $sp,4

1524#    jr $ra # return
    
1528:goEsFalse:
    # put 0 in $t0 and return
1528#    li $t0, 0
1532#    jr $ra # return

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1544:mth_readLine_Lib:
    
1544#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1548#    sw $ra, 4($sp) # save $ra
1552#    move $t1,$sp # save "original" sp

1556:  doRead:

    # read the character
1556#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1560#    subu $t2,$v0,13
1564#    bne $t2,$zero,notReturnRL
1568#    jal readLogicalChar
1572#    subu $t2,$v0,10 # check for newline
1576#    beq $t2,$zero,foundNewLine
1580#    sw $v0,lastCharRead # push back character into queue
1584#    j foundNewLine # go process the line

1588:  notReturnRL:

    # at this point, $v0 has our character

1588#    subu $t0,$v0,10
1592#    beq $t0,$zero,foundNewLine
1596#    blt $v0,$zero,foundEof
1597##...slt $at,$v0,$zero
1601##...bne $at,$zero,1616

    # we have a character, so push it onto stack
1604#    subu $sp,$sp,4
1608#    sw $v0,($sp)

    # loop back up to get next character
1612#    j doRead

1616:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1616#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1620#    li $s7, 0 # return-value: null
1624#    j rlReturn # return

1628:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1628#    subu $t0,$t1,$sp # number of chars we read (times 4)
1632#    srl $s6,$t0,2 # number of words on stack with chars
1636#    subu $sp,$sp,4 # push char-count ...
1640#    sw $s6,($sp) # ... onto stack
1644#    addu $t2,$t0,5 # GC tag, incl. for count-word
1648#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1652#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1656#    srl $s6,$s6,2  # data words in object
1660#    move $s7,$zero # object words in object
1664#    jal newObject  # allocate space
    
    # store header words
1668#    la $t0,CLASS_String
1672#    sw $t0,-12($s7)# store class tag (String) into object
1676#    lw $t2,4($sp) # char-count
1680#    sll $t1,$t2,2 # 4 times number of chars
1684#    subu $t2,$zero,$t2 # negative of char-count
1688#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1692#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1696#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1697##...slt $at,$t0,$zero
1701##...beq $at,$zero,1720
1704#    and $t0,0xff # mask off object's hash value ...
1705##...lui $at,0
1709##...ori $at,$at,0xff
1713##...and $t0,$t0,$at
1716#    sw $t0,-8($s7) # ... and store back into -8 header-word
1720:  skipMask_readLine:

1720#    sll $t0,$t0,2 # data bytes in object
1724#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1728#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1732#    addu $sp,$sp,8 # pop redundant object-pointer and count
1736#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1740#    beq $sp,$t1,rlReturn
1744:  charCopyLoop:
1744#    lw $t2,($sp)
1748#    sb $t2,-9($t0)
1752#    addu $sp,$sp,4
1756#    subu $t0,$t0,1
1760#    bne $sp,$t1,charCopyLoop
1764:  rlReturn:

1764#    lw $ra, 4($sp)
1768#    addu $sp, 8   # pop $ra and pointless word off stack
1772#    move $t0, $s7 # return string we allocated in $s7
1776#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1780:mth_readInt_Lib:

    # save $ra by pushing onto stack
1780#    subu $sp,$sp,4
1784#    sw $ra,($sp)

1788:  riSkipWhiteLoop:
    # read a character
1788#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1792#    subu $t0,$v0,32
1796#    bgt $t0,$zero,nonWhite
1797##...slt $at,$zero,$t0
1801##...bne $at,$zero,1844
1804#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1808#    subu $t0,$v0,10
1812#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1816#    subu $t0,$v0,9
1820#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1824#    subu $t0,$v0,13
1828#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1832#    subu $t0,$v0,12
1836#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1840#    j badIntegerFormat # illegal integer char: abort program

1844:  nonWhite:
1844#    subu $t0,$v0,'-'
1848#    li $t4,1 # final multiplier
1852#    bne $t0,$zero,helpReadInt # go read
1856#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1860#    jal readLogicalChar

1864:  helpReadInt:
1864#    li $t2,10
1868#    subu $t1,$v0,'0' # convert digit to 0-9 value
1872#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1873##...sltu $at,$t1,$t2
1877##...beq $at,$zero,4124
1880#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1884:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1884#    jal readLogicalChar # read next character
1888#    subu $t1,$v0,'0' # convert digit to 0-9 value
1892#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1893##...sltu $at,$t1,$t2
1897##...beq $at,$zero,1916

1900#    mul $t3,$t3,$t2 # multiply old value by 10
1901##...mult $t3,$t2
1905##...mflo $t3
1908#    addu $t3,$t3,$t1 # add in value of new digit
1912#    j digitLoop

1916:  doneDigitLoop:

    # "push back" unused character into queue
1916#    sw $v0,lastCharRead

    # restore return address
1920#    lw $ra,($sp)
1924#    addu $sp, 4

    # multiply by sign and put return value in $t0
1928#    mult $t3,$t4 # multiply to account for poss. minus sign
1932#    mflo $t3
1936#    move $t0, $t3
    
    # return
1940#    jr $ra

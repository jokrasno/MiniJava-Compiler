1972#    lw $t0,($sp)
1976#    bne $t0,$zero,psNotNull

    # print "(null)"
1980#    la $a0,nullStr
1984#    li $v0,4
1988#    syscall
1992#    j donePrintStr
    
1996:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
1996#    subu $t0,$t0,8
2000#    lw $t1,($t0) # number of data words, but needs modification
2004#    blt $t1,$zero,skipPrintStr1

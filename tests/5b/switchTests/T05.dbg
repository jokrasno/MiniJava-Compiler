    # greater
3060#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
3064#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
3068#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
3072:  cmpHitLimitzz:
3072#    move $t0, $t5 # store return value
3076#    jr $ra # return

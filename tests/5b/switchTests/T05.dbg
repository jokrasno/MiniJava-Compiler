    # buffer and return
3092#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
3096#    jr $ra # return
    
3100:  doReadCh:
    # we need to actually read a character: read and return
3100#    li $v0,12 # use system call to read a character
3104#    syscall
3108#    jr $ra # return

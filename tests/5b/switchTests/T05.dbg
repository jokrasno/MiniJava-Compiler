1325##...slt $at,$t0,$zero
1329##...beq $at,$zero,1348
1332#    and $t0,0xff # mask off object's hash value ...
1333##...lui $at,0
1337##...ori $at,$at,0xff
1341##...and $t0,$t0,$at
1344#    sw $t0,-8($s7) # ... and store back into -8 header-word
1348:skipMask_toString:
1348#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1352#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1356#    subu $t4,$t2,$t5
1360:toString_copyLoop:    
1360#    lb $t3,($t4)
1364#    and $t3,0x7f # mask off sign bit (in case first word)
1365##...lui $at,0
1369##...ori $at,$at,0x7f
1373##...and $t3,$t3,$at
1376#    sb $t3,-8($t0)

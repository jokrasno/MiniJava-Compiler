3644#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3645##...slt $at,$t1,$t0
3649##...bne $at,$zero,3668

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3652:  skipToNextObj:
3652#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3656#    sll $t1,$t1,2 # convert to byte-count
3660#    addu $t0,$t2,$t1 # skip over object
3664#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3668:  gcNotDataArray:
3668#    lw $t3,-4($t2) # # object words (negative treated as zero)
3672#    bge $t3,$zero,gcH2Neg2
3673##...slt $at,$t3,$zero
3677##...beq $at,$zero,3684
3680#    move $t3,$zero
3684:  gcH2Neg2:
3684#    sll $t3,$t3,2 # # object bytes
3688#    move $t0,$t2 # address of first pointer in object
3692#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3696#    beq $t0,$s1,gcTestIterDone2
    
3700:  gcNextPointerInObject:
    # get pointer from object
3700#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3704#    bleu $t1,$t6,gcGoNextPointerSlot
3705##...sltu $at,$t6,$t1
3709##...beq $at,$zero,3852
3712#    bgtu $t1,$t7,gcGoNextPointerSlot
3713##...sltu $at,$t7,$t1
3717##...bne $at,$zero,3852

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3720#    lw $t8,-8($t1) # possible forwarding tag
3724#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3728#    lw $t8,-4($t1) # forwarding pointer: object's new address
3732#    sw $t8,($t0) # update pointer in object
3736#    j gcGoNextPointerSlot # do next iteration

3740:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3740#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3741##...slt $at,$t8,$zero
3745##...beq $at,$zero,3760
3748#    and $t8,0xff # mask off hash bits
3749##...lui $at,0
3753##...ori $at,$at,0xff
3757##...and $t8,$t8,$at

3760:  gcSkip5:
3760#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3764#    addu $t8,$t8,8 # ... add in bytes for header-words
3768#    subu $t4,$t1,$t8 # address of first word of source object
3772#    lw $t3,-4($t1) # # words in positive-offset portion
3776#    bge $t3,$zero,gcNoNeg
3777##...slt $at,$t3,$zero
3781##...beq $at,$zero,3788
3784#    move $t3,$zero # negative treated as zero
3788:  gcNoNeg:
3788#    sll $t3,$t3,2 # bytes in negative-offset portion
3792#    addu $t3,$t3,$t1 # address one word past last word of source

3796#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3800#    lw $s0,($t4)
3804#    lw $t9,-8($t1)
3808#    sw $t9,($t4)
3812#    sw $s0,-8($t1)

    # copy all source bytes to the target
3816:  gCinnerCopy2:
3816#    lw $s0,($t4)
3820#    sw $s0,($s3)
3824#    addu $t4,$t4,4
3828#    addu $s3,$s3,4
3832#    bltu $t4,$t3,gCinnerCopy2
3833##...sltu $at,$t4,$t3
3837##...bne $at,$zero,3816

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3840#    sw $zero,-8($t1) # 0 in first header-slot
3844#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3848#    sw $t8,($t0)

3852:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3852#    addu $t0,$t0,4
3856#    bltu $t0,$s1,gcNextPointerInObject
3857##...sltu $at,$t0,$s1
3861##...bne $at,$zero,3700

3864:  gcTestIterDone2:
3864#    bltu $t0,$s3,gcHeapCopyLoop
3865##...sltu $at,$t0,$s3
3869##...bne $at,$zero,3584

    ###### end outer loop to copy all non-stack-direct objects ######

3872:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3872#    lw $s2,($sp)
3876#    addu $sp,$sp,4

    # mark us as having already GC'd
3880#    move $t5,$s5

    # go try and allocate again
3884#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3888:vm_init:

    # mark bottom of stack
3888#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3892#    move $s2,$zero

    #set up the "five" register
3896#    li $s5,5

3900#    la $s3,seg0_start
3904#    la $s4,seg0_end
3905##...lui $s4,16
3909##...addiu $s4,$s4,4800
    
    # return
3912#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3916:divide:
    # get parameters; abort if divisor zero
3916#    lw $t0,($sp)
3920#    lw $t1,8($sp)
3924#    beq $t0,$zero,divByZeroError
    
    # perform division
3928#    div $t1,$t0
3932#    mflo $t0

    # store result, adjust stack and return
3936#    addu $sp,$sp,8 # adjust stack
3940#    sw $t0,($sp) # store result
3944#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3948:remainder:
    # get parameters; abort if divisor zero
3948#    lw $t0,($sp)
3952#    lw $t1,8($sp)
3956#    beq $t0,$zero,divByZeroError
    
    # perform division
3960#    div $t1,$t0
3964#    mfhi $t0

    # store result, adjust stack and return
3968#    addu $sp,$sp,8 # adjust stack
3972#    sw $t0,($sp) # store result
3976#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3980:checkCast:
    # get object, allow immediately if null
3980#    lw $t2,($sp)
3984#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3988#    lw $t2,-12($t2) # vtable address
3992#    bge $t2,$t1,castException
3993##...slt $at,$t2,$t1
3997##...beq $at,$zero,4132
4000#    blt $t2,$t0,castException
4001##...slt $at,$t2,$t0
4005##...bne $at,$zero,4132
    
    # return, leaving object unchanged on stack
4008:  checkCastReturn:    
4008#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4012:instanceOf:
    # get object, go return false if null
4012#    lw $t2,($sp)
4016#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4020#    lw $t2,-12($t2) # vtable address
4024#    sge $t0,$t2,$t0 # are we >= the lower limit?
4025##...slt $t0,$t2,$t0
4029##...xori $t0,$t0,0x1
4032#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4036#    and $t2,$t0,$t1
4040#    sw $t2,($sp)
4044:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4044#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4048:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4048#    li $v0,4 # syscall-code for print-string
4052#    syscall
4056:exit:
    # print termination message
4056#    li $v0,4 # syscall-code for print-string
4060#    la $a0,exitString
4064#    syscall

    # terminate execution
4068#    li $v0,10 #syscall-code for "exit"
4072#    syscall

4076:outOfHeapMemory:
4076#    la $a0,heapMemoryMsg
4080#    j exitError
4084:divByZeroError:
4084#    la $a0,divByZeroMsg
4088#    j exitError
4092:strIndexOutOfBounds:
4092#    la $a0,strIndexOutOfBoundsMsg
4096#    j exitError
4100:arrayIndexOutOfBounds:
4100#    la $a0,arrayIndexOutOfBoundsMsg
4104#    j exitError
4108:arraySizeOutOfBounds:
4108#    la $a0,arraySizeOutOfBoundsMsg
4112#    j exitError
4116:nullPtrException:
4116#    la $a0,nullPtrExceptionMsg
4120#    j exitError
4124:badIntegerFormat:
4124#    la $a0,badIntegerFormatMsg
4128#    j exitError
4132:castException:
4132#    la $a0,castExceptionMsg
4136#    j exitError
############## data section ################
    .data
4436:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4452:cur_seg:
    .word 0

4456:lastCharRead:
    .word -2 # -2 => no buffered character
4460:prevHashConstant:
    .word 0x2785173c
4464:gcCount:
    .word 0

4468:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4495:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4518:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4553:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4587:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4620:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4651:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4699:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4720:gcMsg: 
      .asciiz "\nGC!\n"
4726:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4758:nullStr:
    .asciiz "null"
4763:trueString:
    .asciiz "true"
4768:falseString:
    .asciiz "false"
4774:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4793:newlineString:
    .asciiz "\n"
    
    .align 2
4796:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4800:seg0_start:
    .space 0x100000
1053376:seg0_end:
1053376:seg1_start:
    .space 0x100000
2101952:seg1_end:

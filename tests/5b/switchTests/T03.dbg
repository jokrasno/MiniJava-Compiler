
    # compute the amount of space that is needed
3392#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3393##...slt $at,$t8,$zero
3397##...beq $at,$zero,3412
3400#    and $t8,0xff # mask off hash bits
3401##...lui $at,0
3405##...ori $at,$at,0xff
3409##...and $t8,$t8,$at

3412:  gcSkip5:
3412#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3416#    addu $t8,$t8,8 # ... add in bytes for header-words
3420#    subu $t4,$t1,$t8 # address of first word of source object
3424#    lw $t3,-4($t1) # # words in positive-offset portion
3428#    bge $t3,$zero,gcNoNeg
3429##...slt $at,$t3,$zero
3433##...beq $at,$zero,3440
3436#    move $t3,$zero # negative treated as zero
3440:  gcNoNeg:
3440#    sll $t3,$t3,2 # bytes in negative-offset portion
3444#    addu $t3,$t3,$t1 # address one word past last word of source

3448#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3452#    lw $s0,($t4)
3456#    lw $t9,-8($t1)
3460#    sw $t9,($t4)
3464#    sw $s0,-8($t1)

    # copy all source bytes to the target
3468:  gCinnerCopy2:
3468#    lw $s0,($t4)
3472#    sw $s0,($s3)
3476#    addu $t4,$t4,4
3480#    addu $s3,$s3,4
3484#    bltu $t4,$t3,gCinnerCopy2
3485##...sltu $at,$t4,$t3
3489##...bne $at,$zero,3468

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3492#    sw $zero,-8($t1) # 0 in first header-slot
3496#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3500#    sw $t8,($t0)

3504:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3504#    addu $t0,$t0,4
3508#    bltu $t0,$s1,gcNextPointerInObject
3509##...sltu $at,$t0,$s1
3513##...bne $at,$zero,3352

3516:  gcTestIterDone2:
3516#    bltu $t0,$s3,gcHeapCopyLoop
3517##...sltu $at,$t0,$s3
3521##...bne $at,$zero,3236

    ###### end outer loop to copy all non-stack-direct objects ######

3524:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3524#    lw $s2,($sp)
3528#    addu $sp,$sp,4

    # mark us as having already GC'd
3532#    move $t5,$s5

    # go try and allocate again
3536#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3540:vm_init:

    # mark bottom of stack
3540#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3544#    move $s2,$zero

    #set up the "five" register
3548#    li $s5,5

3552#    la $s3,seg0_start
3556#    la $s4,seg0_end
3557##...lui $s4,16
3561##...addiu $s4,$s4,4436
    
    # return
3564#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3568:divide:
    # get parameters; abort if divisor zero
3568#    lw $t0,($sp)
3572#    lw $t1,8($sp)
3576#    beq $t0,$zero,divByZeroError
    
    # perform division
3580#    div $t1,$t0
3584#    mflo $t0

    # store result, adjust stack and return
3588#    addu $sp,$sp,8 # adjust stack
3592#    sw $t0,($sp) # store result
3596#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3600:remainder:
    # get parameters; abort if divisor zero
3600#    lw $t0,($sp)
3604#    lw $t1,8($sp)
3608#    beq $t0,$zero,divByZeroError
    
    # perform division
3612#    div $t1,$t0
3616#    mfhi $t0

    # store result, adjust stack and return
3620#    addu $sp,$sp,8 # adjust stack
3624#    sw $t0,($sp) # store result
3628#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3632:checkCast:
    # get object, allow immediately if null
3632#    lw $t2,($sp)
3636#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3640#    lw $t2,-12($t2) # vtable address
3644#    bge $t2,$t1,castException
3645##...slt $at,$t2,$t1
3649##...beq $at,$zero,3784
3652#    blt $t2,$t0,castException
3653##...slt $at,$t2,$t0
3657##...bne $at,$zero,3784
    
    # return, leaving object unchanged on stack
3660:  checkCastReturn:    
3660#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3664:instanceOf:
    # get object, go return false if null
3664#    lw $t2,($sp)
3668#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3672#    lw $t2,-12($t2) # vtable address
3676#    sge $t0,$t2,$t0 # are we >= the lower limit?
3677##...slt $t0,$t2,$t0
3681##...xori $t0,$t0,0x1
3684#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3688#    and $t2,$t0,$t1
3692#    sw $t2,($sp)
3696:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3696#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3700:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3700#    li $v0,4 # syscall-code for print-string
3704#    syscall
3708:exit:
    # print termination message
3708#    li $v0,4 # syscall-code for print-string
3712#    la $a0,exitString
3716#    syscall

    # terminate execution
3720#    li $v0,10 #syscall-code for "exit"
3724#    syscall

3728:outOfHeapMemory:
3728#    la $a0,heapMemoryMsg
3732#    j exitError
3736:divByZeroError:
3736#    la $a0,divByZeroMsg
3740#    j exitError
3744:strIndexOutOfBounds:
3744#    la $a0,strIndexOutOfBoundsMsg
3748#    j exitError
3752:arrayIndexOutOfBounds:
3752#    la $a0,arrayIndexOutOfBoundsMsg
3756#    j exitError
3760:arraySizeOutOfBounds:
3760#    la $a0,arraySizeOutOfBoundsMsg
3764#    j exitError
3768:nullPtrException:
3768#    la $a0,nullPtrExceptionMsg
3772#    j exitError
3776:badIntegerFormat:
3776#    la $a0,badIntegerFormatMsg
3780#    j exitError
3784:castException:
3784#    la $a0,castExceptionMsg
3788#    j exitError
############## data section ################
    .data
4072:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4088:cur_seg:
    .word 0

4092:lastCharRead:
    .word -2 # -2 => no buffered character
4096:prevHashConstant:
    .word 0x2785173c
4100:gcCount:
    .word 0

4104:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4131:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4154:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4189:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4223:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4256:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4287:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4335:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4356:gcMsg: 
      .asciiz "\nGC!\n"
4362:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4394:nullStr:
    .asciiz "null"
4399:trueString:
    .asciiz "true"
4404:falseString:
    .asciiz "false"
4410:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4429:newlineString:
    .asciiz "\n"
    
    .align 2
4432:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4436:seg0_start:
    .space 0x100000
1053012:seg0_end:
1053012:seg1_start:
    .space 0x100000
2101588:seg1_end:

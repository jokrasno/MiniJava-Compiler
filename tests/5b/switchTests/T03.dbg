###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1196:mth_readLine_Lib:
    
1196#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1200#    sw $ra, 4($sp) # save $ra
1204#    move $t1,$sp # save "original" sp

1208:  doRead:

    # read the character
1208#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1212#    subu $t2,$v0,13
1216#    bne $t2,$zero,notReturnRL
1220#    jal readLogicalChar
1224#    subu $t2,$v0,10 # check for newline
1228#    beq $t2,$zero,foundNewLine
1232#    sw $v0,lastCharRead # push back character into queue
1236#    j foundNewLine # go process the line

1240:  notReturnRL:

    # at this point, $v0 has our character

1240#    subu $t0,$v0,10
1244#    beq $t0,$zero,foundNewLine
1248#    blt $v0,$zero,foundEof
1249##...slt $at,$v0,$zero
1253##...bne $at,$zero,1268

    # we have a character, so push it onto stack
1256#    subu $sp,$sp,4
1260#    sw $v0,($sp)

    # loop back up to get next character
1264#    j doRead

1268:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1268#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1272#    li $s7, 0 # return-value: null
1276#    j rlReturn # return

1280:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1280#    subu $t0,$t1,$sp # number of chars we read (times 4)
1284#    srl $s6,$t0,2 # number of words on stack with chars
1288#    subu $sp,$sp,4 # push char-count ...
1292#    sw $s6,($sp) # ... onto stack
1296#    addu $t2,$t0,5 # GC tag, incl. for count-word
1300#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1304#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1308#    srl $s6,$s6,2  # data words in object
1312#    move $s7,$zero # object words in object
1316#    jal newObject  # allocate space
    
    # store header words
1320#    la $t0,CLASS_String
1324#    sw $t0,-12($s7)# store class tag (String) into object
1328#    lw $t2,4($sp) # char-count
1332#    sll $t1,$t2,2 # 4 times number of chars
1336#    subu $t2,$zero,$t2 # negative of char-count
1340#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1344#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1348#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1349##...slt $at,$t0,$zero
1353##...beq $at,$zero,1372
1356#    and $t0,0xff # mask off object's hash value ...
1357##...lui $at,0
1361##...ori $at,$at,0xff
1365##...and $t0,$t0,$at
1368#    sw $t0,-8($s7) # ... and store back into -8 header-word
1372:  skipMask_readLine:

1372#    sll $t0,$t0,2 # data bytes in object
1376#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1380#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1384#    addu $sp,$sp,8 # pop redundant object-pointer and count
1388#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1392#    beq $sp,$t1,rlReturn
1396:  charCopyLoop:
1396#    lw $t2,($sp)
1400#    sb $t2,-9($t0)
1404#    addu $sp,$sp,4
1408#    subu $t0,$t0,1
1412#    bne $sp,$t1,charCopyLoop
1416:  rlReturn:

1416#    lw $ra, 4($sp)
1420#    addu $sp, 8   # pop $ra and pointless word off stack
1424#    move $t0, $s7 # return string we allocated in $s7
1428#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1432:mth_readInt_Lib:

    # save $ra by pushing onto stack
1432#    subu $sp,$sp,4
1436#    sw $ra,($sp)

1440:  riSkipWhiteLoop:
    # read a character
1440#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1444#    subu $t0,$v0,32
1448#    bgt $t0,$zero,nonWhite
1449##...slt $at,$zero,$t0
1453##...bne $at,$zero,1496
1456#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1460#    subu $t0,$v0,10
1464#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1468#    subu $t0,$v0,9
1472#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1476#    subu $t0,$v0,13
1480#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1484#    subu $t0,$v0,12
1488#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1492#    j badIntegerFormat # illegal integer char: abort program

1496:  nonWhite:
1496#    subu $t0,$v0,'-'
1500#    li $t4,1 # final multiplier
1504#    bne $t0,$zero,helpReadInt # go read
1508#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1512#    jal readLogicalChar

1516:  helpReadInt:
1516#    li $t2,10
1520#    subu $t1,$v0,'0' # convert digit to 0-9 value
1524#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1525##...sltu $at,$t1,$t2
1529##...beq $at,$zero,3776
1532#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1536:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1536#    jal readLogicalChar # read next character
1540#    subu $t1,$v0,'0' # convert digit to 0-9 value
1544#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1545##...sltu $at,$t1,$t2
1549##...beq $at,$zero,1568

1552#    mul $t3,$t3,$t2 # multiply old value by 10
1553##...mult $t3,$t2
1557##...mflo $t3
1560#    addu $t3,$t3,$t1 # add in value of new digit
1564#    j digitLoop

1568:  doneDigitLoop:

    # "push back" unused character into queue
1568#    sw $v0,lastCharRead

    # restore return address
1572#    lw $ra,($sp)
1576#    addu $sp, 4

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
688:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
688#    lw $t0,-8($s2) # get word with hash bits from this
692#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
696#    addu $t0,$t1

700#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
704:mth_equals_Object:
704#    move $t0,$s2 # first pointer (this)
708#    lw $t1,($sp) # second pointer
712#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
713##...subu $at,$t0,$t1
717##...sltiu $t0,$at,1

720#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
724:mth_hashCode_String:
724#    move $t0,$s2 # put this pointer in t0

728#    li $t2,0 # current hash value
732#    lw $t1,-4($t0) # negative of number of characters in string
736#    beq $t1,$zero,done_hashCode_String # if zero length => done
740#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
744#    and $t0,0xfffffffc # adjust for padding
745##...lui $at,65535
749##...ori $at,$at,0xfffc
753##...and $t0,$t0,$at
756#    subu $t1,$t0,$t1 # address at end of string +12
760:loop_hashCode_String:    
760#    sll $t4,$t2,5 # multiply by 32
764#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
768#    lbu $t3,-12($t0) # current character
772#    addu $t2,$t3 # add in current character
776#    addu $t0,1 # go to next character's address
780#    bne $t0,$t1,loop_hashCode_String # loop back if more
784:done_hashCode_String:    

    # push int on stack
784#    move $t0, $t2 # put $t2 in return slot
788#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
792:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
792#    subu $sp,4
796#    sw $ra,($sp)
    
    # get hash value
800#    lw $t2,-12($s2) # vtable address
804#    lw $t0,($t2) # method address
808#    jalr $t0
812#    subu $sp,8 # push result (int in $t0) on stack
816#    sw $s5,4($sp)
820#    sw $t0,($sp)

    # compute print-size of hash value
824#    li $t0, 1
828#    lw $t1, ($sp)
832#    srl $t1,$t1,4
836#    beq $t1,$zero,toString_skip_loop
840:toString_loop_top:
840#    addu $t0,1
844#    srl $t1,$t1,4
848#    bne $t1,$zero,toString_loop_top
852:toString_skip_loop:
852#    subu $sp,8
856#    sw $s5,4($sp)
860#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
864#    lw $t2,-12($s2) # vtable address
868#    move $t0,$t2
872:toString_checkTagBit:
872#    subu $t0,1
876#    lb $t1,($t0)
880#    and $t1,0x80
881##...lui $at,0
885##...ori $at,$at,0x80
889##...and $t1,$t1,$at
892#    beq $t1,$zero,toString_checkTagBit
896#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
900#    subu $sp,8
904#    sw $t1,($sp)
908#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
912#    move $s7,$zero # -4 offset header word
916#    lw $t4,8($sp) # bytes for hash value
920#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
924#    addu $t4,8
928#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
932#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

936#    li $t0,CLASS_String # store string vtable address into ...
940#    sw $t0,-12($s7) # ... -12 offset in object header
944#    lw $t2,-12($s2) # our object's vtable address
948#    lw $t5,4($sp) # number characters in prefix
952#    lw $t1,12($sp) # number of characters in hashcode
956#    addu $t3,$t1,$t5 # number of characters in string ...
960#    addu $t3,1 # ... including the '@' character
964#    subu $t0,$zero,$t3 # store negated length into ...
968#    sw $t0,-4($s7) # ... -4 offset header word
972#    lw $t0,-8($s7) # get -8 offset header-word
976#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
977##...slt $at,$t0,$zero
981##...beq $at,$zero,1000
984#    and $t0,0xff # mask off object's hash value ...
985##...lui $at,0
989##...ori $at,$at,0xff
993##...and $t0,$t0,$at
996#    sw $t0,-8($s7) # ... and store back into -8 header-word
1000:skipMask_toString:
1000#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1004#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1008#    subu $t4,$t2,$t5
1012:toString_copyLoop:    
1012#    lb $t3,($t4)
1016#    and $t3,0x7f # mask off sign bit (in case first word)
1017##...lui $at,0
1021##...ori $at,$at,0x7f
1025##...and $t3,$t3,$at
1028#    sb $t3,-8($t0)

1080#    subu $t2,$t2,1
1084#    bgt $t2,$t0,toString_hashCopyLoop
1085##...slt $at,$t0,$t2
1089##...bne $at,$zero,1064

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1092#    addu $sp,28
1096#    lw $ra,($sp)
1100#    addu $sp,4
1104#    move $t0, $s7 # return string we created
1108#    jr $ra

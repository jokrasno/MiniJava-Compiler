1189##...slt $at,$zero,$t0
1193##...bne $at,$zero,1236
1196#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1200#    subu $t0,$v0,10
1204#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1208#    subu $t0,$v0,9
1212#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1216#    subu $t0,$v0,13
1220#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1224#    subu $t0,$v0,12
1228#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1232#    j badIntegerFormat # illegal integer char: abort program

1236:  nonWhite:
1236#    subu $t0,$v0,'-'
1240#    li $t4,1 # final multiplier
1244#    bne $t0,$zero,helpReadInt # go read
1248#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1252#    jal readLogicalChar

1256:  helpReadInt:
1256#    li $t2,10
1260#    subu $t1,$v0,'0' # convert digit to 0-9 value
1264#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1265##...sltu $at,$t1,$t2
1269##...beq $at,$zero,3516
1272#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1276:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1276#    jal readLogicalChar # read next character
1280#    subu $t1,$v0,'0' # convert digit to 0-9 value
1284#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1285##...sltu $at,$t1,$t2
1289##...beq $at,$zero,1308

1292#    mul $t3,$t3,$t2 # multiply old value by 10
1293##...mult $t3,$t2
1297##...mflo $t3
1300#    addu $t3,$t3,$t1 # add in value of new digit
1304#    j digitLoop

1308:  doneDigitLoop:

    # "push back" unused character into queue
1308#    sw $v0,lastCharRead

    # restore return address
1312#    lw $ra,($sp)
1316#    addu $sp, 4

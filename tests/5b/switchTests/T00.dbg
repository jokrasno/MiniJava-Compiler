###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
936:mth_readLine_Lib:
    
936#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
940#    sw $ra, 4($sp) # save $ra
944#    move $t1,$sp # save "original" sp

948:  doRead:

    # read the character
948#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
952#    subu $t2,$v0,13
956#    bne $t2,$zero,notReturnRL
960#    jal readLogicalChar
964#    subu $t2,$v0,10 # check for newline
968#    beq $t2,$zero,foundNewLine
972#    sw $v0,lastCharRead # push back character into queue
976#    j foundNewLine # go process the line

980:  notReturnRL:

    # at this point, $v0 has our character

980#    subu $t0,$v0,10
984#    beq $t0,$zero,foundNewLine
988#    blt $v0,$zero,foundEof
989##...slt $at,$v0,$zero
993##...bne $at,$zero,1008

    # we have a character, so push it onto stack
996#    subu $sp,$sp,4
1000#    sw $v0,($sp)

    # loop back up to get next character
1004#    j doRead

1008:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1008#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1012#    li $s7, 0 # return-value: null
1016#    j rlReturn # return

1020:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1020#    subu $t0,$t1,$sp # number of chars we read (times 4)
1024#    srl $s6,$t0,2 # number of words on stack with chars
1028#    subu $sp,$sp,4 # push char-count ...
1032#    sw $s6,($sp) # ... onto stack
1036#    addu $t2,$t0,5 # GC tag, incl. for count-word
1040#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1044#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1048#    srl $s6,$s6,2  # data words in object
1052#    move $s7,$zero # object words in object
1056#    jal newObject  # allocate space
    
    # store header words
1060#    la $t0,CLASS_String
1064#    sw $t0,-12($s7)# store class tag (String) into object
1068#    lw $t2,4($sp) # char-count
1072#    sll $t1,$t2,2 # 4 times number of chars
1076#    subu $t2,$zero,$t2 # negative of char-count
1080#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1084#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1088#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1089##...slt $at,$t0,$zero
1093##...beq $at,$zero,1112
1096#    and $t0,0xff # mask off object's hash value ...
1097##...lui $at,0
1101##...ori $at,$at,0xff
1105##...and $t0,$t0,$at
1108#    sw $t0,-8($s7) # ... and store back into -8 header-word
1112:  skipMask_readLine:

1112#    sll $t0,$t0,2 # data bytes in object
1116#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1120#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1124#    addu $sp,$sp,8 # pop redundant object-pointer and count
1128#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1132#    beq $sp,$t1,rlReturn
1136:  charCopyLoop:
1136#    lw $t2,($sp)
1140#    sb $t2,-9($t0)
1144#    addu $sp,$sp,4
1148#    subu $t0,$t0,1
1152#    bne $sp,$t1,charCopyLoop
1156:  rlReturn:

1156#    lw $ra, 4($sp)
1160#    addu $sp, 8   # pop $ra and pointless word off stack
1164#    move $t0, $s7 # return string we allocated in $s7
1168#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1172:mth_readInt_Lib:

    # save $ra by pushing onto stack
1172#    subu $sp,$sp,4
1176#    sw $ra,($sp)

1180:  riSkipWhiteLoop:
    # read a character
1180#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 

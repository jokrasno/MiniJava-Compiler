##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
428:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
428#    lw $t0,-8($s2) # get word with hash bits from this
432#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
436#    addu $t0,$t1

440#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
444:mth_equals_Object:
444#    move $t0,$s2 # first pointer (this)
448#    lw $t1,($sp) # second pointer
452#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
453##...subu $at,$t0,$t1
457##...sltiu $t0,$at,1

460#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
464:mth_hashCode_String:
464#    move $t0,$s2 # put this pointer in t0

468#    li $t2,0 # current hash value
472#    lw $t1,-4($t0) # negative of number of characters in string
476#    beq $t1,$zero,done_hashCode_String # if zero length => done
480#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
484#    and $t0,0xfffffffc # adjust for padding
485##...lui $at,65535
489##...ori $at,$at,0xfffc
493##...and $t0,$t0,$at
496#    subu $t1,$t0,$t1 # address at end of string +12
500:loop_hashCode_String:    
500#    sll $t4,$t2,5 # multiply by 32
504#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
508#    lbu $t3,-12($t0) # current character
512#    addu $t2,$t3 # add in current character
516#    addu $t0,1 # go to next character's address
520#    bne $t0,$t1,loop_hashCode_String # loop back if more
524:done_hashCode_String:    

    # push int on stack
524#    move $t0, $t2 # put $t2 in return slot
528#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
532:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
532#    subu $sp,4
536#    sw $ra,($sp)
    
    # get hash value
540#    lw $t2,-12($s2) # vtable address
544#    lw $t0,($t2) # method address
548#    jalr $t0
552#    subu $sp,8 # push result (int in $t0) on stack
556#    sw $s5,4($sp)
560#    sw $t0,($sp)

    # compute print-size of hash value
564#    li $t0, 1
568#    lw $t1, ($sp)
572#    srl $t1,$t1,4
576#    beq $t1,$zero,toString_skip_loop
580:toString_loop_top:
580#    addu $t0,1
584#    srl $t1,$t1,4
588#    bne $t1,$zero,toString_loop_top
592:toString_skip_loop:
592#    subu $sp,8
596#    sw $s5,4($sp)
600#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
604#    lw $t2,-12($s2) # vtable address
608#    move $t0,$t2
612:toString_checkTagBit:
612#    subu $t0,1
616#    lb $t1,($t0)
620#    and $t1,0x80
621##...lui $at,0
625##...ori $at,$at,0x80
629##...and $t1,$t1,$at
632#    beq $t1,$zero,toString_checkTagBit
636#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
640#    subu $sp,8
644#    sw $t1,($sp)
648#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
652#    move $s7,$zero # -4 offset header word
656#    lw $t4,8($sp) # bytes for hash value
660#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
664#    addu $t4,8
668#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
672#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

676#    li $t0,CLASS_String # store string vtable address into ...
680#    sw $t0,-12($s7) # ... -12 offset in object header
684#    lw $t2,-12($s2) # our object's vtable address
688#    lw $t5,4($sp) # number characters in prefix
692#    lw $t1,12($sp) # number of characters in hashcode
696#    addu $t3,$t1,$t5 # number of characters in string ...
700#    addu $t3,1 # ... including the '@' character
704#    subu $t0,$zero,$t3 # store negated length into ...
708#    sw $t0,-4($s7) # ... -4 offset header word
712#    lw $t0,-8($s7) # get -8 offset header-word
716#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
717##...slt $at,$t0,$zero
721##...beq $at,$zero,740
724#    and $t0,0xff # mask off object's hash value ...
725##...lui $at,0
729##...ori $at,$at,0xff
733##...and $t0,$t0,$at
736#    sw $t0,-8($s7) # ... and store back into -8 header-word
740:skipMask_toString:
740#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
744#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
748#    subu $t4,$t2,$t5
752:toString_copyLoop:    
752#    lb $t3,($t4)
756#    and $t3,0x7f # mask off sign bit (in case first word)
757##...lui $at,0
761##...ori $at,$at,0x7f
765##...and $t3,$t3,$at
768#    sb $t3,-8($t0)
772#    addu $t4,1
776#    addu $t0,1
780#    blt $t4,$t2,toString_copyLoop
781##...slt $at,$t4,$t2
785##...bne $at,$zero,752

    # copy the '@' sign
788#    li $t3,'@'
792#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
796#    addu $t2,$t0,$t1 # address of last byte in string to store +8
800#    lw $t3,20($sp) # hash code to print
804:toString_hashCopyLoop:
804#    and $t4,$t3,0xf
808#    srl $t3,4
812#    lb $t4,hexChars($t4)
816#    sb $t4,-8($t2)
820#    subu $t2,$t2,1
824#    bgt $t2,$t0,toString_hashCopyLoop
825##...slt $at,$t0,$t2
829##...bne $at,$zero,804

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
832#    addu $sp,28
836#    lw $ra,($sp)
840#    addu $sp,4
844#    move $t0, $s7 # return string we created
848#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
852:mth_equals_String:
    
    # quick test for obvious false
852#    lw $t0,($sp) # second parameter
856#    beq $t0,$zero,goEsFalse # go return false if null

3284#    move $s2,$zero

    #set up the "five" register
3288#    li $s5,5

3292#    la $s3,seg0_start
3296#    la $s4,seg0_end
3297##...lui $s4,16
3301##...addiu $s4,$s4,4108
    
    # return
3304#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3308:divide:
    # get parameters; abort if divisor zero
3308#    lw $t0,($sp)
3312#    lw $t1,8($sp)
3316#    beq $t0,$zero,divByZeroError
    
    # perform division
3320#    div $t1,$t0
3324#    mflo $t0

    # store result, adjust stack and return
3328#    addu $sp,$sp,8 # adjust stack
3332#    sw $t0,($sp) # store result
3336#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3340:remainder:
    # get parameters; abort if divisor zero
3340#    lw $t0,($sp)
3344#    lw $t1,8($sp)
3348#    beq $t0,$zero,divByZeroError
    
    # perform division
3352#    div $t1,$t0
3356#    mfhi $t0

    # store result, adjust stack and return
3360#    addu $sp,$sp,8 # adjust stack
3364#    sw $t0,($sp) # store result
3368#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3372:checkCast:
    # get object, allow immediately if null
3372#    lw $t2,($sp)
3376#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3380#    lw $t2,-12($t2) # vtable address
3384#    bge $t2,$t1,castException
3385##...slt $at,$t2,$t1
3389##...beq $at,$zero,3524
3392#    blt $t2,$t0,castException
3393##...slt $at,$t2,$t0
3397##...bne $at,$zero,3524
    
    # return, leaving object unchanged on stack
3400:  checkCastReturn:    
3400#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3404:instanceOf:
    # get object, go return false if null
3404#    lw $t2,($sp)
3408#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3412#    lw $t2,-12($t2) # vtable address
3416#    sge $t0,$t2,$t0 # are we >= the lower limit?
3417##...slt $t0,$t2,$t0
3421##...xori $t0,$t0,0x1
3424#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3428#    and $t2,$t0,$t1
3432#    sw $t2,($sp)
3436:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3436#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3440:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3440#    li $v0,4 # syscall-code for print-string
3444#    syscall
3448:exit:
    # print termination message
3448#    li $v0,4 # syscall-code for print-string
3452#    la $a0,exitString
3456#    syscall

    # terminate execution
3460#    li $v0,10 #syscall-code for "exit"
3464#    syscall

3468:outOfHeapMemory:
3468#    la $a0,heapMemoryMsg
3472#    j exitError
3476:divByZeroError:
3476#    la $a0,divByZeroMsg
3480#    j exitError
3484:strIndexOutOfBounds:
3484#    la $a0,strIndexOutOfBoundsMsg
3488#    j exitError
3492:arrayIndexOutOfBounds:
3492#    la $a0,arrayIndexOutOfBoundsMsg
3496#    j exitError
3500:arraySizeOutOfBounds:
3500#    la $a0,arraySizeOutOfBoundsMsg
3504#    j exitError
3508:nullPtrException:
3508#    la $a0,nullPtrExceptionMsg
3512#    j exitError
3516:badIntegerFormat:
3516#    la $a0,badIntegerFormatMsg
3520#    j exitError
3524:castException:
3524#    la $a0,castExceptionMsg
3528#    j exitError
############## data section ################
    .data
3744:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3760:cur_seg:
    .word 0

3764:lastCharRead:
    .word -2 # -2 => no buffered character
3768:prevHashConstant:
    .word 0x2785173c
3772:gcCount:
    .word 0

3776:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3803:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3826:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3861:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3895:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3928:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3959:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4007:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4028:gcMsg: 
      .asciiz "\nGC!\n"
4034:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4066:nullStr:
    .asciiz "null"
4071:trueString:
    .asciiz "true"
4076:falseString:
    .asciiz "false"
4082:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4101:newlineString:
    .asciiz "\n"
    
    .align 2
4104:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

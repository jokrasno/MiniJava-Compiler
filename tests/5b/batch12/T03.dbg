##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
272:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
272#    lw $t0,-8($s2) # get word with hash bits from this
276#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
280#    addu $t0,$t1

284#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
288:mth_equals_Object:
288#    move $t0,$s2 # first pointer (this)
292#    lw $t1,($sp) # second pointer
296#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
297##...subu $at,$t0,$t1
301##...sltiu $t0,$at,1

304#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
308:mth_hashCode_String:
308#    move $t0,$s2 # put this pointer in t0

312#    li $t2,0 # current hash value
316#    lw $t1,-4($t0) # negative of number of characters in string
320#    beq $t1,$zero,done_hashCode_String # if zero length => done
324#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
328#    and $t0,0xfffffffc # adjust for padding
329##...lui $at,65535
333##...ori $at,$at,0xfffc
337##...and $t0,$t0,$at
340#    subu $t1,$t0,$t1 # address at end of string +12
344:loop_hashCode_String:    
344#    sll $t4,$t2,5 # multiply by 32
348#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
352#    lbu $t3,-12($t0) # current character
356#    addu $t2,$t3 # add in current character
360#    addu $t0,1 # go to next character's address
364#    bne $t0,$t1,loop_hashCode_String # loop back if more
368:done_hashCode_String:    

    # push int on stack
368#    move $t0, $t2 # put $t2 in return slot
372#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
376:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
376#    subu $sp,4
380#    sw $ra,($sp)
    
    # get hash value
384#    lw $t2,-12($s2) # vtable address
388#    lw $t0,($t2) # method address
392#    jalr $t0
396#    subu $sp,8 # push result (int in $t0) on stack
400#    sw $s5,4($sp)
404#    sw $t0,($sp)

    # compute print-size of hash value
408#    li $t0, 1
412#    lw $t1, ($sp)
416#    srl $t1,$t1,4
420#    beq $t1,$zero,toString_skip_loop
424:toString_loop_top:
424#    addu $t0,1
428#    srl $t1,$t1,4
432#    bne $t1,$zero,toString_loop_top
436:toString_skip_loop:
436#    subu $sp,8
440#    sw $s5,4($sp)
444#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
448#    lw $t2,-12($s2) # vtable address
452#    move $t0,$t2
456:toString_checkTagBit:
456#    subu $t0,1
460#    lb $t1,($t0)
464#    and $t1,0x80
465##...lui $at,0
469##...ori $at,$at,0x80
473##...and $t1,$t1,$at
476#    beq $t1,$zero,toString_checkTagBit
480#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
484#    subu $sp,8
488#    sw $t1,($sp)
492#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
496#    move $s7,$zero # -4 offset header word
500#    lw $t4,8($sp) # bytes for hash value
504#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
508#    addu $t4,8
512#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
516#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

520#    li $t0,CLASS_String # store string vtable address into ...
524#    sw $t0,-12($s7) # ... -12 offset in object header
528#    lw $t2,-12($s2) # our object's vtable address
532#    lw $t5,4($sp) # number characters in prefix
536#    lw $t1,12($sp) # number of characters in hashcode
540#    addu $t3,$t1,$t5 # number of characters in string ...
544#    addu $t3,1 # ... including the '@' character
548#    subu $t0,$zero,$t3 # store negated length into ...
552#    sw $t0,-4($s7) # ... -4 offset header word
556#    lw $t0,-8($s7) # get -8 offset header-word
560#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
561##...slt $at,$t0,$zero
565##...beq $at,$zero,584
568#    and $t0,0xff # mask off object's hash value ...
569##...lui $at,0
573##...ori $at,$at,0xff
577##...and $t0,$t0,$at
580#    sw $t0,-8($s7) # ... and store back into -8 header-word
584:skipMask_toString:
584#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
588#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
592#    subu $t4,$t2,$t5
596:toString_copyLoop:    
596#    lb $t3,($t4)
600#    and $t3,0x7f # mask off sign bit (in case first word)
601##...lui $at,0
605##...ori $at,$at,0x7f
609##...and $t3,$t3,$at
612#    sb $t3,-8($t0)
616#    addu $t4,1
620#    addu $t0,1
624#    blt $t4,$t2,toString_copyLoop
625##...slt $at,$t4,$t2
629##...bne $at,$zero,596

    # copy the '@' sign
632#    li $t3,'@'
636#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
640#    addu $t2,$t0,$t1 # address of last byte in string to store +8
644#    lw $t3,20($sp) # hash code to print
648:toString_hashCopyLoop:
648#    and $t4,$t3,0xf
652#    srl $t3,4
656#    lb $t4,hexChars($t4)
660#    sb $t4,-8($t2)
664#    subu $t2,$t2,1
668#    bgt $t2,$t0,toString_hashCopyLoop
669##...slt $at,$t0,$t2
673##...bne $at,$zero,648

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
676#    addu $sp,28
680#    lw $ra,($sp)
684#    addu $sp,4
688#    move $t0, $s7 # return string we created
692#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
696:mth_equals_String:
    
    # quick test for obvious false
696#    lw $t0,($sp) # second parameter
700#    beq $t0,$zero,goEsFalse # go return false if null
704#    lw $t1,-12($t0) # vtable pointer
708#    la $t2,CLASS_String # string vtable pointer
712#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
716#    subu $sp,12
720#    sw $ra,8($sp)
724#    sw $s2,4($sp)
728#    sw $t0,($sp)
732#    jal mth_compareTo_String
736#    lw $s2, 4($sp) #restore this pointer and pop parameters
740#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
744#    seq $t0,$t0,$zero
745##...subu $at,$t0,$zero
749##...sltiu $t0,$at,1

    # pop return address and return $t0
752#    lw $ra,($sp)
756#    addu $sp,4

760#    jr $ra # return
    
764:goEsFalse:
    # put 0 in $t0 and return

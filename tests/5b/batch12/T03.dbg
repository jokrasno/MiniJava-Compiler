########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3124:vm_init:

    # mark bottom of stack
3124#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3128#    move $s2,$zero

    #set up the "five" register
3132#    li $s5,5

3136#    la $s3,seg0_start
3140#    la $s4,seg0_end
3141##...lui $s4,16
3145##...addiu $s4,$s4,3972
    
    # return
3148#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3152:divide:
    # get parameters; abort if divisor zero
3152#    lw $t0,($sp)
3156#    lw $t1,8($sp)
3160#    beq $t0,$zero,divByZeroError
    
    # perform division
3164#    div $t1,$t0
3168#    mflo $t0

    # store result, adjust stack and return
3172#    addu $sp,$sp,8 # adjust stack
3176#    sw $t0,($sp) # store result
3180#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3184:remainder:
    # get parameters; abort if divisor zero
3184#    lw $t0,($sp)
3188#    lw $t1,8($sp)
3192#    beq $t0,$zero,divByZeroError
    
    # perform division
3196#    div $t1,$t0
3200#    mfhi $t0

    # store result, adjust stack and return
3204#    addu $sp,$sp,8 # adjust stack
3208#    sw $t0,($sp) # store result
3212#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3216:checkCast:
    # get object, allow immediately if null
3216#    lw $t2,($sp)
3220#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3224#    lw $t2,-12($t2) # vtable address
3228#    bge $t2,$t1,castException
3229##...slt $at,$t2,$t1
3233##...beq $at,$zero,3368
3236#    blt $t2,$t0,castException
3237##...slt $at,$t2,$t0
3241##...bne $at,$zero,3368
    
    # return, leaving object unchanged on stack
3244:  checkCastReturn:    
3244#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3248:instanceOf:
    # get object, go return false if null
3248#    lw $t2,($sp)
3252#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3256#    lw $t2,-12($t2) # vtable address
3260#    sge $t0,$t2,$t0 # are we >= the lower limit?
3261##...slt $t0,$t2,$t0
3265##...xori $t0,$t0,0x1
3268#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3272#    and $t2,$t0,$t1
3276#    sw $t2,($sp)
3280:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3280#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3284:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3284#    li $v0,4 # syscall-code for print-string
3288#    syscall
3292:exit:
    # print termination message
3292#    li $v0,4 # syscall-code for print-string
3296#    la $a0,exitString
3300#    syscall

    # terminate execution
3304#    li $v0,10 #syscall-code for "exit"
3308#    syscall

3312:outOfHeapMemory:
3312#    la $a0,heapMemoryMsg
3316#    j exitError
3320:divByZeroError:
3320#    la $a0,divByZeroMsg
3324#    j exitError
3328:strIndexOutOfBounds:
3328#    la $a0,strIndexOutOfBoundsMsg
3332#    j exitError
3336:arrayIndexOutOfBounds:
3336#    la $a0,arrayIndexOutOfBoundsMsg
3340#    j exitError
3344:arraySizeOutOfBounds:
3344#    la $a0,arraySizeOutOfBoundsMsg
3348#    j exitError
3352:nullPtrException:
3352#    la $a0,nullPtrExceptionMsg
3356#    j exitError
3360:badIntegerFormat:
3360#    la $a0,badIntegerFormatMsg
3364#    j exitError
3368:castException:
3368#    la $a0,castExceptionMsg
3372#    j exitError
############## data section ################
    .data
3608:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3624:cur_seg:
    .word 0

3628:lastCharRead:
    .word -2 # -2 => no buffered character
3632:prevHashConstant:
    .word 0x2785173c
3636:gcCount:
    .word 0

3640:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3667:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3690:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3725:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3759:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3792:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3823:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3871:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3892:gcMsg: 
      .asciiz "\nGC!\n"
3898:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3930:nullStr:
    .asciiz "null"
3935:trueString:
    .asciiz "true"
3940:falseString:
    .asciiz "false"
3946:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3965:newlineString:
    .asciiz "\n"
    
    .align 2
3968:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3972:seg0_start:
    .space 0x100000
1052548:seg0_end:
1052548:seg1_start:
    .space 0x100000
2101124:seg1_end:

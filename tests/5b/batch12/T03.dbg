    # compute the amount of space that is needed
2976#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
2977##...slt $at,$t8,$zero
2981##...beq $at,$zero,2996
2984#    and $t8,0xff # mask off hash bits
2985##...lui $at,0
2989##...ori $at,$at,0xff
2993##...and $t8,$t8,$at

2996:  gcSkip5:
2996#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3000#    addu $t8,$t8,8 # ... add in bytes for header-words
3004#    subu $t4,$t1,$t8 # address of first word of source object

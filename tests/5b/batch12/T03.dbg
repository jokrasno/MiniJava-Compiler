###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
780:mth_readLine_Lib:
    
780#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
784#    sw $ra, 4($sp) # save $ra
788#    move $t1,$sp # save "original" sp

792:  doRead:

    # read the character
792#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
796#    subu $t2,$v0,13
800#    bne $t2,$zero,notReturnRL
804#    jal readLogicalChar
808#    subu $t2,$v0,10 # check for newline
812#    beq $t2,$zero,foundNewLine
816#    sw $v0,lastCharRead # push back character into queue
820#    j foundNewLine # go process the line

824:  notReturnRL:

    # at this point, $v0 has our character

824#    subu $t0,$v0,10
828#    beq $t0,$zero,foundNewLine
832#    blt $v0,$zero,foundEof
833##...slt $at,$v0,$zero
837##...bne $at,$zero,852

    # we have a character, so push it onto stack
840#    subu $sp,$sp,4
844#    sw $v0,($sp)

    # loop back up to get next character
848#    j doRead

852:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
852#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
856#    li $s7, 0 # return-value: null
860#    j rlReturn # return

864:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
864#    subu $t0,$t1,$sp # number of chars we read (times 4)
868#    srl $s6,$t0,2 # number of words on stack with chars
872#    subu $sp,$sp,4 # push char-count ...
876#    sw $s6,($sp) # ... onto stack
880#    addu $t2,$t0,5 # GC tag, incl. for count-word
884#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
888#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
892#    srl $s6,$s6,2  # data words in object
896#    move $s7,$zero # object words in object
900#    jal newObject  # allocate space
    
    # store header words
904#    la $t0,CLASS_String
908#    sw $t0,-12($s7)# store class tag (String) into object
912#    lw $t2,4($sp) # char-count
916#    sll $t1,$t2,2 # 4 times number of chars
920#    subu $t2,$zero,$t2 # negative of char-count
924#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
928#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
932#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
933##...slt $at,$t0,$zero
937##...beq $at,$zero,956
940#    and $t0,0xff # mask off object's hash value ...
941##...lui $at,0
945##...ori $at,$at,0xff
949##...and $t0,$t0,$at
952#    sw $t0,-8($s7) # ... and store back into -8 header-word
956:  skipMask_readLine:

956#    sll $t0,$t0,2 # data bytes in object
960#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
964#    subu $t0,$t0,$t2 # place to store last character (plus 9)
968#    addu $sp,$sp,8 # pop redundant object-pointer and count
972#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

976#    beq $sp,$t1,rlReturn
980:  charCopyLoop:
980#    lw $t2,($sp)
984#    sb $t2,-9($t0)
988#    addu $sp,$sp,4
992#    subu $t0,$t0,1
996#    bne $sp,$t1,charCopyLoop
1000:  rlReturn:

1000#    lw $ra, 4($sp)
1004#    addu $sp, 8   # pop $ra and pointless word off stack
1008#    move $t0, $s7 # return string we allocated in $s7
1012#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1016:mth_readInt_Lib:

    # save $ra by pushing onto stack
1016#    subu $sp,$sp,4
1020#    sw $ra,($sp)

1024:  riSkipWhiteLoop:
    # read a character
1024#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1028#    subu $t0,$v0,32
1032#    bgt $t0,$zero,nonWhite
1033##...slt $at,$zero,$t0
1037##...bne $at,$zero,1080
1040#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1044#    subu $t0,$v0,10
1048#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1052#    subu $t0,$v0,9
1056#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1060#    subu $t0,$v0,13
1064#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1068#    subu $t0,$v0,12
1072#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1076#    j badIntegerFormat # illegal integer char: abort program

1080:  nonWhite:
1080#    subu $t0,$v0,'-'
1084#    li $t4,1 # final multiplier
1088#    bne $t0,$zero,helpReadInt # go read
1092#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1096#    jal readLogicalChar

1100:  helpReadInt:
1100#    li $t2,10
1104#    subu $t1,$v0,'0' # convert digit to 0-9 value
1108#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1109##...sltu $at,$t1,$t2
1113##...beq $at,$zero,3360
1116#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1120:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1120#    jal readLogicalChar # read next character
1124#    subu $t1,$v0,'0' # convert digit to 0-9 value
1128#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1129##...sltu $at,$t1,$t2
1133##...beq $at,$zero,1152

1136#    mul $t3,$t3,$t2 # multiply old value by 10
1137##...mult $t3,$t2
1141##...mflo $t3
1144#    addu $t3,$t3,$t1 # add in value of new digit
1148#    j digitLoop

1152:  doneDigitLoop:

    # "push back" unused character into queue
1152#    sw $v0,lastCharRead

    # restore return address
1156#    lw $ra,($sp)
1160#    addu $sp, 4

    # multiply by sign and put return value in $t0
1164#    mult $t3,$t4 # multiply to account for poss. minus sign
1168#    mflo $t3
1172#    move $t0, $t3
    
    # return
1176#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1180:mth_readChar_Lib:

    # save $ra by pushing onto stack
1180#    subu $sp,$sp,4
1184#    sw $ra,($sp)

      # read the character
1188#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1192#    lw $ra,($sp)
1196#    addu $sp, 4
1200#    move $t0, $v0

    # return
1204#    jr $ra

########################################################
# printStr(str) - library method (class Lib)

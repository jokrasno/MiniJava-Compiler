1560#    lw $ra,4($sp) # restore $ra
1564#    addu $sp,$sp,8 # pop ra, and allocated newObject
1568#    move $t0, $s7 # we're returning the string we got back
                  # from newObject
    
    # return
1572#    jr $ra

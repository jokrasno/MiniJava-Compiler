1469##...slt $at,$t4,$zero
1473##...beq $at,$zero,1492
1476#    and $t4,0xff # mask off object's hash value ...
1477##...lui $at,0
1481##...ori $at,$at,0xff
1485##...and $t4,$t4,$at
1488#    sw $t4,-8($s7) # ... and store back into -8 header-word
1492:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1492#    lw $t1,8($sp) # k
1496#    lw $t2,16($sp) # n
1500#    subu $t0,$t2,$t1 # value to store
1504#    sw $t0,-4($s7) # store value
    
1508#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
1512#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
1516#    lw $t4,-8($t3) # data words in source string
1520#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
1524#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
1528#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
1532#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
1536#    lw $t2,-8($s7)   # data words in target string
1540#    sll $t2,$t2,2    # data bytes in target string
1544#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target

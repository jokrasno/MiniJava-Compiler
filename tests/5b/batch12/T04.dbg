########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
2328:readLogicalChar:

    # check if we already have a character
2328#    lw $v0,lastCharRead
2332#    li $t0,-2
2336#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
2340#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2344#    jr $ra # return
    
2348:  doReadCh:
    # we need to actually read a character: read and return
2348#    li $v0,12 # use system call to read a character
2352#    syscall
2356#    jr $ra # return

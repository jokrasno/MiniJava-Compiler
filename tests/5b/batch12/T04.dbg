###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
792:mth_readLine_Lib:
    
792#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
796#    sw $ra, 4($sp) # save $ra
800#    move $t1,$sp # save "original" sp

804:  doRead:

    # read the character
804#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
808#    subu $t2,$v0,13
812#    bne $t2,$zero,notReturnRL
816#    jal readLogicalChar
820#    subu $t2,$v0,10 # check for newline
824#    beq $t2,$zero,foundNewLine
828#    sw $v0,lastCharRead # push back character into queue
832#    j foundNewLine # go process the line

836:  notReturnRL:

    # at this point, $v0 has our character

836#    subu $t0,$v0,10
840#    beq $t0,$zero,foundNewLine
844#    blt $v0,$zero,foundEof
845##...slt $at,$v0,$zero
849##...bne $at,$zero,864

    # we have a character, so push it onto stack
852#    subu $sp,$sp,4
856#    sw $v0,($sp)

    # loop back up to get next character
860#    j doRead

864:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
864#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
868#    li $s7, 0 # return-value: null
872#    j rlReturn # return

876:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
876#    subu $t0,$t1,$sp # number of chars we read (times 4)
880#    srl $s6,$t0,2 # number of words on stack with chars
884#    subu $sp,$sp,4 # push char-count ...
888#    sw $s6,($sp) # ... onto stack
892#    addu $t2,$t0,5 # GC tag, incl. for count-word
896#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
900#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
904#    srl $s6,$s6,2  # data words in object
908#    move $s7,$zero # object words in object
912#    jal newObject  # allocate space
    
    # store header words
916#    la $t0,CLASS_String
920#    sw $t0,-12($s7)# store class tag (String) into object
924#    lw $t2,4($sp) # char-count
928#    sll $t1,$t2,2 # 4 times number of chars
932#    subu $t2,$zero,$t2 # negative of char-count
936#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
940#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
944#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
945##...slt $at,$t0,$zero
949##...beq $at,$zero,968
952#    and $t0,0xff # mask off object's hash value ...
953##...lui $at,0
957##...ori $at,$at,0xff
961##...and $t0,$t0,$at
964#    sw $t0,-8($s7) # ... and store back into -8 header-word
968:  skipMask_readLine:

968#    sll $t0,$t0,2 # data bytes in object
972#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
976#    subu $t0,$t0,$t2 # place to store last character (plus 9)
980#    addu $sp,$sp,8 # pop redundant object-pointer and count
984#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

988#    beq $sp,$t1,rlReturn
992:  charCopyLoop:
992#    lw $t2,($sp)
996#    sb $t2,-9($t0)
1000#    addu $sp,$sp,4
1004#    subu $t0,$t0,1
1008#    bne $sp,$t1,charCopyLoop
1012:  rlReturn:

1012#    lw $ra, 4($sp)
1016#    addu $sp, 8   # pop $ra and pointless word off stack
1020#    move $t0, $s7 # return string we allocated in $s7
1024#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1028:mth_readInt_Lib:

    # save $ra by pushing onto stack
1028#    subu $sp,$sp,4
1032#    sw $ra,($sp)

1036:  riSkipWhiteLoop:
    # read a character
1036#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1040#    subu $t0,$v0,32
1044#    bgt $t0,$zero,nonWhite
1045##...slt $at,$zero,$t0
1049##...bne $at,$zero,1092
1052#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1056#    subu $t0,$v0,10
1060#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1064#    subu $t0,$v0,9
1068#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1072#    subu $t0,$v0,13
1076#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1080#    subu $t0,$v0,12
1084#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1088#    j badIntegerFormat # illegal integer char: abort program

1092:  nonWhite:
1092#    subu $t0,$v0,'-'
1096#    li $t4,1 # final multiplier
1100#    bne $t0,$zero,helpReadInt # go read
1104#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1108#    jal readLogicalChar

1112:  helpReadInt:
1112#    li $t2,10
1116#    subu $t1,$v0,'0' # convert digit to 0-9 value
1120#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1121##...sltu $at,$t1,$t2
1125##...beq $at,$zero,3372
1128#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1132:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1132#    jal readLogicalChar # read next character
1136#    subu $t1,$v0,'0' # convert digit to 0-9 value
1140#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1141##...sltu $at,$t1,$t2
1145##...beq $at,$zero,1164

1148#    mul $t3,$t3,$t2 # multiply old value by 10
1149##...mult $t3,$t2
1153##...mflo $t3
1156#    addu $t3,$t3,$t1 # add in value of new digit
1160#    j digitLoop

1164:  doneDigitLoop:

    # "push back" unused character into queue
1164#    sw $v0,lastCharRead

    # restore return address
1168#    lw $ra,($sp)
1172#    addu $sp, 4

    # multiply by sign and put return value in $t0
1176#    mult $t3,$t4 # multiply to account for poss. minus sign
1180#    mflo $t3
1184#    move $t0, $t3
    
    # return
1188#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1192:mth_readChar_Lib:

    # save $ra by pushing onto stack
1192#    subu $sp,$sp,4
1196#    sw $ra,($sp)

      # read the character
1200#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1204#    lw $ra,($sp)
1208#    addu $sp, 4
1212#    move $t0, $v0

    # return
1216#    jr $ra

########################################################

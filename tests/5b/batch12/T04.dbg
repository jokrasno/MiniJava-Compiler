    # store String vtable address in vtable address field
1652#    la $t0,CLASS_String
1656#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
1660#    lw $t4,-8($s7) # # data words in source string
1664#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there

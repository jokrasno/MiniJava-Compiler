##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
284:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
284#    lw $t0,-8($s2) # get word with hash bits from this
288#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
292#    addu $t0,$t1

296#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
300:mth_equals_Object:
300#    move $t0,$s2 # first pointer (this)
304#    lw $t1,($sp) # second pointer
308#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
309##...subu $at,$t0,$t1
313##...sltiu $t0,$at,1

316#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
320:mth_hashCode_String:
320#    move $t0,$s2 # put this pointer in t0

324#    li $t2,0 # current hash value
328#    lw $t1,-4($t0) # negative of number of characters in string
332#    beq $t1,$zero,done_hashCode_String # if zero length => done
336#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
340#    and $t0,0xfffffffc # adjust for padding
341##...lui $at,65535
345##...ori $at,$at,0xfffc
349##...and $t0,$t0,$at
352#    subu $t1,$t0,$t1 # address at end of string +12
356:loop_hashCode_String:    
356#    sll $t4,$t2,5 # multiply by 32
360#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
364#    lbu $t3,-12($t0) # current character
368#    addu $t2,$t3 # add in current character
372#    addu $t0,1 # go to next character's address
376#    bne $t0,$t1,loop_hashCode_String # loop back if more
380:done_hashCode_String:    

    # push int on stack
380#    move $t0, $t2 # put $t2 in return slot
384#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
388:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
388#    subu $sp,4
392#    sw $ra,($sp)
    
    # get hash value
396#    lw $t2,-12($s2) # vtable address
400#    lw $t0,($t2) # method address
404#    jalr $t0
408#    subu $sp,8 # push result (int in $t0) on stack
412#    sw $s5,4($sp)
416#    sw $t0,($sp)

    # compute print-size of hash value
420#    li $t0, 1
424#    lw $t1, ($sp)
428#    srl $t1,$t1,4
432#    beq $t1,$zero,toString_skip_loop
436:toString_loop_top:
436#    addu $t0,1
440#    srl $t1,$t1,4
444#    bne $t1,$zero,toString_loop_top
448:toString_skip_loop:
448#    subu $sp,8
452#    sw $s5,4($sp)
456#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
460#    lw $t2,-12($s2) # vtable address
464#    move $t0,$t2
468:toString_checkTagBit:
468#    subu $t0,1
472#    lb $t1,($t0)
476#    and $t1,0x80
477##...lui $at,0
481##...ori $at,$at,0x80
485##...and $t1,$t1,$at
488#    beq $t1,$zero,toString_checkTagBit
492#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
496#    subu $sp,8
500#    sw $t1,($sp)
504#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
508#    move $s7,$zero # -4 offset header word
512#    lw $t4,8($sp) # bytes for hash value
516#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
520#    addu $t4,8
524#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
528#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

532#    li $t0,CLASS_String # store string vtable address into ...
536#    sw $t0,-12($s7) # ... -12 offset in object header
540#    lw $t2,-12($s2) # our object's vtable address
544#    lw $t5,4($sp) # number characters in prefix
548#    lw $t1,12($sp) # number of characters in hashcode
552#    addu $t3,$t1,$t5 # number of characters in string ...
556#    addu $t3,1 # ... including the '@' character
560#    subu $t0,$zero,$t3 # store negated length into ...
564#    sw $t0,-4($s7) # ... -4 offset header word
568#    lw $t0,-8($s7) # get -8 offset header-word
572#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
573##...slt $at,$t0,$zero
577##...beq $at,$zero,596
580#    and $t0,0xff # mask off object's hash value ...
581##...lui $at,0
585##...ori $at,$at,0xff
589##...and $t0,$t0,$at
592#    sw $t0,-8($s7) # ... and store back into -8 header-word
596:skipMask_toString:
596#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
600#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
604#    subu $t4,$t2,$t5
608:toString_copyLoop:    
608#    lb $t3,($t4)
612#    and $t3,0x7f # mask off sign bit (in case first word)
613##...lui $at,0
617##...ori $at,$at,0x7f
621##...and $t3,$t3,$at
624#    sb $t3,-8($t0)
628#    addu $t4,1
632#    addu $t0,1
636#    blt $t4,$t2,toString_copyLoop
637##...slt $at,$t4,$t2
641##...bne $at,$zero,608

    # copy the '@' sign
644#    li $t3,'@'
648#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
652#    addu $t2,$t0,$t1 # address of last byte in string to store +8
656#    lw $t3,20($sp) # hash code to print
660:toString_hashCopyLoop:
660#    and $t4,$t3,0xf
664#    srl $t3,4
668#    lb $t4,hexChars($t4)
672#    sb $t4,-8($t2)
676#    subu $t2,$t2,1
680#    bgt $t2,$t0,toString_hashCopyLoop
681##...slt $at,$t0,$t2
685##...bne $at,$zero,660

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
688#    addu $sp,28
692#    lw $ra,($sp)
696#    addu $sp,4
700#    move $t0, $s7 # return string we created
704#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
708:mth_equals_String:
    
    # quick test for obvious false
708#    lw $t0,($sp) # second parameter
712#    beq $t0,$zero,goEsFalse # go return false if null
716#    lw $t1,-12($t0) # vtable pointer
720#    la $t2,CLASS_String # string vtable pointer
724#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
728#    subu $sp,12
732#    sw $ra,8($sp)
736#    sw $s2,4($sp)
740#    sw $t0,($sp)
744#    jal mth_compareTo_String
748#    lw $s2, 4($sp) #restore this pointer and pop parameters
752#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
756#    seq $t0,$t0,$zero
757##...subu $at,$t0,$zero
761##...sltiu $t0,$at,1

    # pop return address and return $t0
764#    lw $ra,($sp)
768#    addu $sp,4

772#    jr $ra # return

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3136:vm_init:

    # mark bottom of stack
3136#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3140#    move $s2,$zero

    #set up the "five" register
3144#    li $s5,5

3148#    la $s3,seg0_start
3152#    la $s4,seg0_end
3153##...lui $s4,16
3157##...addiu $s4,$s4,3984
    
    # return
3160#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3164:divide:
    # get parameters; abort if divisor zero
3164#    lw $t0,($sp)
3168#    lw $t1,8($sp)
3172#    beq $t0,$zero,divByZeroError
    
    # perform division
3176#    div $t1,$t0
3180#    mflo $t0

    # store result, adjust stack and return
3184#    addu $sp,$sp,8 # adjust stack
3188#    sw $t0,($sp) # store result
3192#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3196:remainder:
    # get parameters; abort if divisor zero
3196#    lw $t0,($sp)
3200#    lw $t1,8($sp)
3204#    beq $t0,$zero,divByZeroError
    
    # perform division
3208#    div $t1,$t0
3212#    mfhi $t0

    # store result, adjust stack and return
3216#    addu $sp,$sp,8 # adjust stack
3220#    sw $t0,($sp) # store result
3224#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3228:checkCast:
    # get object, allow immediately if null
3228#    lw $t2,($sp)
3232#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3236#    lw $t2,-12($t2) # vtable address
3240#    bge $t2,$t1,castException
3241##...slt $at,$t2,$t1
3245##...beq $at,$zero,3380
3248#    blt $t2,$t0,castException
3249##...slt $at,$t2,$t0
3253##...bne $at,$zero,3380
    
    # return, leaving object unchanged on stack
3256:  checkCastReturn:    
3256#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3260:instanceOf:
    # get object, go return false if null
3260#    lw $t2,($sp)
3264#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3268#    lw $t2,-12($t2) # vtable address
3272#    sge $t0,$t2,$t0 # are we >= the lower limit?
3273##...slt $t0,$t2,$t0
3277##...xori $t0,$t0,0x1
3280#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3284#    and $t2,$t0,$t1
3288#    sw $t2,($sp)
3292:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3292#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3296:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3296#    li $v0,4 # syscall-code for print-string
3300#    syscall
3304:exit:
    # print termination message
3304#    li $v0,4 # syscall-code for print-string
3308#    la $a0,exitString
3312#    syscall

    # terminate execution
3316#    li $v0,10 #syscall-code for "exit"
3320#    syscall

3324:outOfHeapMemory:
3324#    la $a0,heapMemoryMsg
3328#    j exitError
3332:divByZeroError:
3332#    la $a0,divByZeroMsg
3336#    j exitError
3340:strIndexOutOfBounds:
3340#    la $a0,strIndexOutOfBoundsMsg
3344#    j exitError
3348:arrayIndexOutOfBounds:
3348#    la $a0,arrayIndexOutOfBoundsMsg
3352#    j exitError
3356:arraySizeOutOfBounds:
3356#    la $a0,arraySizeOutOfBoundsMsg
3360#    j exitError
3364:nullPtrException:
3364#    la $a0,nullPtrExceptionMsg
3368#    j exitError
3372:badIntegerFormat:
3372#    la $a0,badIntegerFormatMsg
3376#    j exitError
3380:castException:
3380#    la $a0,castExceptionMsg
3384#    j exitError
############## data section ################
    .data
3620:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3636:cur_seg:
    .word 0

3640:lastCharRead:
    .word -2 # -2 => no buffered character
3644:prevHashConstant:
    .word 0x2785173c
3648:gcCount:
    .word 0

3652:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3679:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3702:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3737:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3771:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3804:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3835:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3883:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3904:gcMsg: 
      .asciiz "\nGC!\n"
3910:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3942:nullStr:
    .asciiz "null"
3947:trueString:
    .asciiz "true"
3952:falseString:
    .asciiz "false"
3958:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3977:newlineString:
    .asciiz "\n"
    
    .align 2
3980:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3984:seg0_start:
    .space 0x100000
1052560:seg0_end:
1052560:seg1_start:
    .space 0x100000
2101136:seg1_end:

########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
1380:mth_substring_String:

    # save $ra by pushing onto stack
1380#    subu $sp,$sp,4
1384#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
1388#    move $t0,$s2
1392#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
1396#    lw $t0,-4($t0) # negative of string length
1400#    subu $t0,$zero,$t0 # string length
1404#    lw $t1,4($sp) # k
1408#    lw $t2,12($sp) # n
1412#    bgt $zero,$t2,strIndexOutOfBounds
1413##...slt $at,$t2,$zero
1417##...bne $at,$zero,3340
1420#    bgt $t2,$t1,strIndexOutOfBounds
1421##...slt $at,$t1,$t2
1425##...bne $at,$zero,3340
1428#    bgt $t1,$t0,strIndexOutOfBounds
1429##...slt $at,$t0,$t1
1433##...bne $at,$zero,3340

    # allocate memory
1436#    subu $s6,$t1,$t2 # # chars in target-string
1440#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1444#    srl $s6,$s6,2 # convert bytes-count to word-count
1448#    move $s7,$zero # (no object-bytes in string)
1452#    jal newObject

    # store "String" tag in object-type field
1456#    la $t0,CLASS_String
1460#    sw $t0,-12($s7)

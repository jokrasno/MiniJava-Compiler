1237##...slt $at,$zero,$t0
1241##...bne $at,$zero,1284
1244#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1248#    subu $t0,$v0,10
1252#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1256#    subu $t0,$v0,9
1260#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1264#    subu $t0,$v0,13
1268#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1272#    subu $t0,$v0,12
1276#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1280#    j badIntegerFormat # illegal integer char: abort program

1284:  nonWhite:
1284#    subu $t0,$v0,'-'
1288#    li $t4,1 # final multiplier
1292#    bne $t0,$zero,helpReadInt # go read
1296#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1300#    jal readLogicalChar

1304:  helpReadInt:
1304#    li $t2,10
1308#    subu $t1,$v0,'0' # convert digit to 0-9 value
1312#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1313##...sltu $at,$t1,$t2
1317##...beq $at,$zero,3564
1320#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1324:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1324#    jal readLogicalChar # read next character
1328#    subu $t1,$v0,'0' # convert digit to 0-9 value
1332#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1333##...sltu $at,$t1,$t2
1337##...beq $at,$zero,1356

1340#    mul $t3,$t3,$t2 # multiply old value by 10
1341##...mult $t3,$t2
1345##...mflo $t3
1348#    addu $t3,$t3,$t1 # add in value of new digit
1352#    j digitLoop

1356:  doneDigitLoop:

    # "push back" unused character into queue
1356#    sw $v0,lastCharRead

    # restore return address
1360#    lw $ra,($sp)
1364#    addu $sp, 4

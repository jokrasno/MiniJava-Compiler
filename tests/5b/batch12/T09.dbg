##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
476:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
476#    lw $t0,-8($s2) # get word with hash bits from this
480#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
484#    addu $t0,$t1

488#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
492:mth_equals_Object:
492#    move $t0,$s2 # first pointer (this)
496#    lw $t1,($sp) # second pointer
500#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
501##...subu $at,$t0,$t1
505##...sltiu $t0,$at,1

508#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
512:mth_hashCode_String:
512#    move $t0,$s2 # put this pointer in t0

516#    li $t2,0 # current hash value
520#    lw $t1,-4($t0) # negative of number of characters in string
524#    beq $t1,$zero,done_hashCode_String # if zero length => done
528#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
532#    and $t0,0xfffffffc # adjust for padding
533##...lui $at,65535
537##...ori $at,$at,0xfffc
541##...and $t0,$t0,$at
544#    subu $t1,$t0,$t1 # address at end of string +12
548:loop_hashCode_String:    
548#    sll $t4,$t2,5 # multiply by 32
552#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
556#    lbu $t3,-12($t0) # current character
560#    addu $t2,$t3 # add in current character
564#    addu $t0,1 # go to next character's address
568#    bne $t0,$t1,loop_hashCode_String # loop back if more
572:done_hashCode_String:    

    # push int on stack
572#    move $t0, $t2 # put $t2 in return slot
576#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
580:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
580#    subu $sp,4
584#    sw $ra,($sp)
    
    # get hash value
588#    lw $t2,-12($s2) # vtable address
592#    lw $t0,($t2) # method address
596#    jalr $t0
600#    subu $sp,8 # push result (int in $t0) on stack
604#    sw $s5,4($sp)
608#    sw $t0,($sp)

    # compute print-size of hash value
612#    li $t0, 1
616#    lw $t1, ($sp)
620#    srl $t1,$t1,4
624#    beq $t1,$zero,toString_skip_loop
628:toString_loop_top:
628#    addu $t0,1
632#    srl $t1,$t1,4
636#    bne $t1,$zero,toString_loop_top
640:toString_skip_loop:
640#    subu $sp,8
644#    sw $s5,4($sp)
648#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
652#    lw $t2,-12($s2) # vtable address
656#    move $t0,$t2
660:toString_checkTagBit:
660#    subu $t0,1
664#    lb $t1,($t0)
668#    and $t1,0x80
669##...lui $at,0
673##...ori $at,$at,0x80
677##...and $t1,$t1,$at
680#    beq $t1,$zero,toString_checkTagBit
684#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
688#    subu $sp,8
692#    sw $t1,($sp)
696#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
700#    move $s7,$zero # -4 offset header word
704#    lw $t4,8($sp) # bytes for hash value
708#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
712#    addu $t4,8
716#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
720#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

724#    li $t0,CLASS_String # store string vtable address into ...
728#    sw $t0,-12($s7) # ... -12 offset in object header
732#    lw $t2,-12($s2) # our object's vtable address
736#    lw $t5,4($sp) # number characters in prefix
740#    lw $t1,12($sp) # number of characters in hashcode
744#    addu $t3,$t1,$t5 # number of characters in string ...
748#    addu $t3,1 # ... including the '@' character
752#    subu $t0,$zero,$t3 # store negated length into ...
756#    sw $t0,-4($s7) # ... -4 offset header word
760#    lw $t0,-8($s7) # get -8 offset header-word
764#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
765##...slt $at,$t0,$zero
769##...beq $at,$zero,788
772#    and $t0,0xff # mask off object's hash value ...
773##...lui $at,0
777##...ori $at,$at,0xff
781##...and $t0,$t0,$at
784#    sw $t0,-8($s7) # ... and store back into -8 header-word
788:skipMask_toString:
788#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
792#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
796#    subu $t4,$t2,$t5
800:toString_copyLoop:    
800#    lb $t3,($t4)
804#    and $t3,0x7f # mask off sign bit (in case first word)
805##...lui $at,0
809##...ori $at,$at,0x7f
813##...and $t3,$t3,$at
816#    sb $t3,-8($t0)
820#    addu $t4,1
824#    addu $t0,1
828#    blt $t4,$t2,toString_copyLoop
829##...slt $at,$t4,$t2
833##...bne $at,$zero,800

    # copy the '@' sign
836#    li $t3,'@'
840#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value

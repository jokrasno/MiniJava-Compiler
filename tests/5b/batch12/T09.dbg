###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
900:mth_equals_String:
    
    # quick test for obvious false
900#    lw $t0,($sp) # second parameter
904#    beq $t0,$zero,goEsFalse # go return false if null
908#    lw $t1,-12($t0) # vtable pointer
912#    la $t2,CLASS_String # string vtable pointer
916#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
920#    subu $sp,12
924#    sw $ra,8($sp)
928#    sw $s2,4($sp)
932#    sw $t0,($sp)
936#    jal mth_compareTo_String
940#    lw $s2, 4($sp) #restore this pointer and pop parameters
944#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
948#    seq $t0,$t0,$zero
949##...subu $at,$t0,$zero
953##...sltiu $t0,$at,1

    # pop return address and return $t0
956#    lw $ra,($sp)
960#    addu $sp,4

964#    jr $ra # return
    
968:goEsFalse:
    # put 0 in $t0 and return
968#    li $t0, 0
972#    jr $ra # return

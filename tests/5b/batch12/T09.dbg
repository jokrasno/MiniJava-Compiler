
    # set up the forwarding pointer
3280#    sw $zero,-8($t1) # 0 in first header-slot
3284#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3288#    sw $t8,($t0)

3292:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3292#    addu $t0,$t0,4
3296#    bltu $t0,$s1,gcNextPointerInObject
3297##...sltu $at,$t0,$s1
3301##...bne $at,$zero,3140

3304:  gcTestIterDone2:
3304#    bltu $t0,$s3,gcHeapCopyLoop
3305##...sltu $at,$t0,$s3
3309##...bne $at,$zero,3024

    ###### end outer loop to copy all non-stack-direct objects ######

3312:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3312#    lw $s2,($sp)
3316#    addu $sp,$sp,4

    # mark us as having already GC'd
3320#    move $t5,$s5

    # go try and allocate again
3324#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3328:vm_init:

    # mark bottom of stack
3328#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3332#    move $s2,$zero

    #set up the "five" register
3336#    li $s5,5

3340#    la $s3,seg0_start
3344#    la $s4,seg0_end
3345##...lui $s4,16
3349##...addiu $s4,$s4,4200
    
    # return
3352#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3356:divide:
    # get parameters; abort if divisor zero
3356#    lw $t0,($sp)
3360#    lw $t1,8($sp)
3364#    beq $t0,$zero,divByZeroError
    
    # perform division
3368#    div $t1,$t0
3372#    mflo $t0

    # store result, adjust stack and return
3376#    addu $sp,$sp,8 # adjust stack
3380#    sw $t0,($sp) # store result
3384#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3388:remainder:
    # get parameters; abort if divisor zero
3388#    lw $t0,($sp)
3392#    lw $t1,8($sp)
3396#    beq $t0,$zero,divByZeroError
    
    # perform division
3400#    div $t1,$t0
3404#    mfhi $t0

    # store result, adjust stack and return
3408#    addu $sp,$sp,8 # adjust stack
3412#    sw $t0,($sp) # store result
3416#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3420:checkCast:
    # get object, allow immediately if null
3420#    lw $t2,($sp)
3424#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3428#    lw $t2,-12($t2) # vtable address
3432#    bge $t2,$t1,castException
3433##...slt $at,$t2,$t1
3437##...beq $at,$zero,3572
3440#    blt $t2,$t0,castException
3441##...slt $at,$t2,$t0
3445##...bne $at,$zero,3572
    
    # return, leaving object unchanged on stack
3448:  checkCastReturn:    
3448#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3452:instanceOf:
    # get object, go return false if null
3452#    lw $t2,($sp)
3456#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3460#    lw $t2,-12($t2) # vtable address
3464#    sge $t0,$t2,$t0 # are we >= the lower limit?
3465##...slt $t0,$t2,$t0
3469##...xori $t0,$t0,0x1
3472#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3476#    and $t2,$t0,$t1
3480#    sw $t2,($sp)
3484:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3484#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3488:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3488#    li $v0,4 # syscall-code for print-string
3492#    syscall
3496:exit:
    # print termination message
3496#    li $v0,4 # syscall-code for print-string
3500#    la $a0,exitString
3504#    syscall

    # terminate execution
3508#    li $v0,10 #syscall-code for "exit"
3512#    syscall

3516:outOfHeapMemory:
3516#    la $a0,heapMemoryMsg
3520#    j exitError
3524:divByZeroError:
3524#    la $a0,divByZeroMsg
3528#    j exitError
3532:strIndexOutOfBounds:
3532#    la $a0,strIndexOutOfBoundsMsg
3536#    j exitError
3540:arrayIndexOutOfBounds:
3540#    la $a0,arrayIndexOutOfBoundsMsg
3544#    j exitError
3548:arraySizeOutOfBounds:
3548#    la $a0,arraySizeOutOfBoundsMsg
3552#    j exitError
3556:nullPtrException:
3556#    la $a0,nullPtrExceptionMsg
3560#    j exitError
3564:badIntegerFormat:
3564#    la $a0,badIntegerFormatMsg
3568#    j exitError
3572:castException:
3572#    la $a0,castExceptionMsg
3576#    j exitError
############## data section ################
    .data
3836:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3852:cur_seg:
    .word 0

3856:lastCharRead:
    .word -2 # -2 => no buffered character
3860:prevHashConstant:
    .word 0x2785173c
3864:gcCount:
    .word 0

3868:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3895:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3918:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3953:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3987:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4020:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4051:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4099:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4120:gcMsg: 
      .asciiz "\nGC!\n"
4126:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4158:nullStr:
    .asciiz "null"
4163:trueString:
    .asciiz "true"
4168:falseString:
    .asciiz "false"
4174:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4193:newlineString:
    .asciiz "\n"
    
    .align 2
4196:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4200:seg0_start:
    .space 0x100000
1052776:seg0_end:
1052776:seg1_start:
    .space 0x100000
2101352:seg1_end:

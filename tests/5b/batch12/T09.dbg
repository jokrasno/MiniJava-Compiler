###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
984:mth_readLine_Lib:
    
984#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
988#    sw $ra, 4($sp) # save $ra
992#    move $t1,$sp # save "original" sp

996:  doRead:

    # read the character
996#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1000#    subu $t2,$v0,13
1004#    bne $t2,$zero,notReturnRL
1008#    jal readLogicalChar
1012#    subu $t2,$v0,10 # check for newline
1016#    beq $t2,$zero,foundNewLine
1020#    sw $v0,lastCharRead # push back character into queue
1024#    j foundNewLine # go process the line

1028:  notReturnRL:

    # at this point, $v0 has our character

1028#    subu $t0,$v0,10
1032#    beq $t0,$zero,foundNewLine
1036#    blt $v0,$zero,foundEof
1037##...slt $at,$v0,$zero
1041##...bne $at,$zero,1056

    # we have a character, so push it onto stack
1044#    subu $sp,$sp,4
1048#    sw $v0,($sp)

    # loop back up to get next character
1052#    j doRead

1056:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1056#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1060#    li $s7, 0 # return-value: null
1064#    j rlReturn # return

1068:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1068#    subu $t0,$t1,$sp # number of chars we read (times 4)
1072#    srl $s6,$t0,2 # number of words on stack with chars
1076#    subu $sp,$sp,4 # push char-count ...
1080#    sw $s6,($sp) # ... onto stack
1084#    addu $t2,$t0,5 # GC tag, incl. for count-word
1088#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1092#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1096#    srl $s6,$s6,2  # data words in object
1100#    move $s7,$zero # object words in object
1104#    jal newObject  # allocate space
    
    # store header words
1108#    la $t0,CLASS_String
1112#    sw $t0,-12($s7)# store class tag (String) into object
1116#    lw $t2,4($sp) # char-count
1120#    sll $t1,$t2,2 # 4 times number of chars
1124#    subu $t2,$zero,$t2 # negative of char-count
1128#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1132#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1136#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1137##...slt $at,$t0,$zero
1141##...beq $at,$zero,1160
1144#    and $t0,0xff # mask off object's hash value ...
1145##...lui $at,0
1149##...ori $at,$at,0xff
1153##...and $t0,$t0,$at
1156#    sw $t0,-8($s7) # ... and store back into -8 header-word
1160:  skipMask_readLine:

1160#    sll $t0,$t0,2 # data bytes in object
1164#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1168#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1172#    addu $sp,$sp,8 # pop redundant object-pointer and count
1176#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1180#    beq $sp,$t1,rlReturn
1184:  charCopyLoop:
1184#    lw $t2,($sp)
1188#    sb $t2,-9($t0)
1192#    addu $sp,$sp,4
1196#    subu $t0,$t0,1
1200#    bne $sp,$t1,charCopyLoop
1204:  rlReturn:

1204#    lw $ra, 4($sp)
1208#    addu $sp, 8   # pop $ra and pointless word off stack
1212#    move $t0, $s7 # return string we allocated in $s7
1216#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1220:mth_readInt_Lib:

    # save $ra by pushing onto stack

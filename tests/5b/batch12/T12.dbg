########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
1668:mth_substring_String:

    # save $ra by pushing onto stack
1668#    subu $sp,$sp,4
1672#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
1676#    move $t0,$s2
1680#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
1684#    lw $t0,-4($t0) # negative of string length
1688#    subu $t0,$zero,$t0 # string length
1692#    lw $t1,4($sp) # k
1696#    lw $t2,12($sp) # n
1700#    bgt $zero,$t2,strIndexOutOfBounds
1701##...slt $at,$t2,$zero
1705##...bne $at,$zero,3628
1708#    bgt $t2,$t1,strIndexOutOfBounds
1709##...slt $at,$t1,$t2
1713##...bne $at,$zero,3628
1716#    bgt $t1,$t0,strIndexOutOfBounds
1717##...slt $at,$t0,$t1
1721##...bne $at,$zero,3628

    # allocate memory
1724#    subu $s6,$t1,$t2 # # chars in target-string
1728#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1732#    srl $s6,$s6,2 # convert bytes-count to word-count
1736#    move $s7,$zero # (no object-bytes in string)
1740#    jal newObject

    # store "String" tag in object-type field
1744#    la $t0,CLASS_String
1748#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
1752#    lw $t4,-8($s7) # data words in source string
1756#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
1757##...slt $at,$t4,$zero
1761##...beq $at,$zero,1780
1764#    and $t4,0xff # mask off object's hash value ...
1765##...lui $at,0
1769##...ori $at,$at,0xff
1773##...and $t4,$t4,$at
1776#    sw $t4,-8($s7) # ... and store back into -8 header-word
1780:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1780#    lw $t1,8($sp) # k
1784#    lw $t2,16($sp) # n
1788#    subu $t0,$t2,$t1 # value to store
1792#    sw $t0,-4($s7) # store value
    
1796#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
1800#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
1804#    lw $t4,-8($t3) # data words in source string
1808#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
1812#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
1816#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
1820#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
1824#    lw $t2,-8($s7)   # data words in target string
1828#    sll $t2,$t2,2    # data bytes in target string
1832#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################

1580#    subu $t1,$t0,$t1 # first word in string
1584#    lw $t0,4($t0) # negative of string-length
1588#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
1592#    beq $t0,$t1,donePrintStr
1596:  psLoop:

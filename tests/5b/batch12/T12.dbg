##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
572:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
572#    lw $t0,-8($s2) # get word with hash bits from this
576#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
580#    addu $t0,$t1

584#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
588:mth_equals_Object:
588#    move $t0,$s2 # first pointer (this)
592#    lw $t1,($sp) # second pointer
596#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
597##...subu $at,$t0,$t1
601##...sltiu $t0,$at,1

604#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
608:mth_hashCode_String:
608#    move $t0,$s2 # put this pointer in t0

612#    li $t2,0 # current hash value
616#    lw $t1,-4($t0) # negative of number of characters in string
620#    beq $t1,$zero,done_hashCode_String # if zero length => done
624#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
628#    and $t0,0xfffffffc # adjust for padding
629##...lui $at,65535
633##...ori $at,$at,0xfffc
637##...and $t0,$t0,$at
640#    subu $t1,$t0,$t1 # address at end of string +12
644:loop_hashCode_String:    
644#    sll $t4,$t2,5 # multiply by 32
648#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
652#    lbu $t3,-12($t0) # current character
656#    addu $t2,$t3 # add in current character
660#    addu $t0,1 # go to next character's address
664#    bne $t0,$t1,loop_hashCode_String # loop back if more
668:done_hashCode_String:    

    # push int on stack
668#    move $t0, $t2 # put $t2 in return slot
672#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
676:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
676#    subu $sp,4
680#    sw $ra,($sp)
    
    # get hash value
684#    lw $t2,-12($s2) # vtable address
688#    lw $t0,($t2) # method address
692#    jalr $t0
696#    subu $sp,8 # push result (int in $t0) on stack
700#    sw $s5,4($sp)
704#    sw $t0,($sp)

    # compute print-size of hash value
708#    li $t0, 1
712#    lw $t1, ($sp)
716#    srl $t1,$t1,4
720#    beq $t1,$zero,toString_skip_loop
724:toString_loop_top:
724#    addu $t0,1
728#    srl $t1,$t1,4
732#    bne $t1,$zero,toString_loop_top
736:toString_skip_loop:
736#    subu $sp,8
740#    sw $s5,4($sp)
744#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
748#    lw $t2,-12($s2) # vtable address
752#    move $t0,$t2
756:toString_checkTagBit:
756#    subu $t0,1
760#    lb $t1,($t0)
764#    and $t1,0x80
765##...lui $at,0
769##...ori $at,$at,0x80
773##...and $t1,$t1,$at
776#    beq $t1,$zero,toString_checkTagBit
780#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
784#    subu $sp,8
788#    sw $t1,($sp)
792#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
796#    move $s7,$zero # -4 offset header word
800#    lw $t4,8($sp) # bytes for hash value
804#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
808#    addu $t4,8
812#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
816#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

820#    li $t0,CLASS_String # store string vtable address into ...
824#    sw $t0,-12($s7) # ... -12 offset in object header
828#    lw $t2,-12($s2) # our object's vtable address
832#    lw $t5,4($sp) # number characters in prefix
836#    lw $t1,12($sp) # number of characters in hashcode
840#    addu $t3,$t1,$t5 # number of characters in string ...
844#    addu $t3,1 # ... including the '@' character
848#    subu $t0,$zero,$t3 # store negated length into ...
852#    sw $t0,-4($s7) # ... -4 offset header word
856#    lw $t0,-8($s7) # get -8 offset header-word
860#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
861##...slt $at,$t0,$zero
865##...beq $at,$zero,884
868#    and $t0,0xff # mask off object's hash value ...
869##...lui $at,0
873##...ori $at,$at,0xff
877##...and $t0,$t0,$at
880#    sw $t0,-8($s7) # ... and store back into -8 header-word
884:skipMask_toString:
884#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
888#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
892#    subu $t4,$t2,$t5
896:toString_copyLoop:    
896#    lb $t3,($t4)
900#    and $t3,0x7f # mask off sign bit (in case first word)
901##...lui $at,0
905##...ori $at,$at,0x7f
909##...and $t3,$t3,$at
912#    sb $t3,-8($t0)
916#    addu $t4,1
920#    addu $t0,1
924#    blt $t4,$t2,toString_copyLoop
925##...slt $at,$t4,$t2
929##...bne $at,$zero,896

    # copy the '@' sign
932#    li $t3,'@'
936#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
940#    addu $t2,$t0,$t1 # address of last byte in string to store +8
944#    lw $t3,20($sp) # hash code to print
948:toString_hashCopyLoop:
948#    and $t4,$t3,0xf
952#    srl $t3,4
956#    lb $t4,hexChars($t4)
960#    sb $t4,-8($t2)
964#    subu $t2,$t2,1
968#    bgt $t2,$t0,toString_hashCopyLoop
969##...slt $at,$t0,$t2
973##...bne $at,$zero,948

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
976#    addu $sp,28
980#    lw $ra,($sp)
984#    addu $sp,4
988#    move $t0, $s7 # return string we created
992#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
996:mth_equals_String:
    
    # quick test for obvious false
996#    lw $t0,($sp) # second parameter
1000#    beq $t0,$zero,goEsFalse # go return false if null
1004#    lw $t1,-12($t0) # vtable pointer
1008#    la $t2,CLASS_String # string vtable pointer
1012#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1016#    subu $sp,12
1020#    sw $ra,8($sp)
1024#    sw $s2,4($sp)
1028#    sw $t0,($sp)
1032#    jal mth_compareTo_String
1036#    lw $s2, 4($sp) #restore this pointer and pop parameters
1040#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1044#    seq $t0,$t0,$zero
1045##...subu $at,$t0,$zero
1049##...sltiu $t0,$at,1

    # pop return address and return $t0
1052#    lw $ra,($sp)
1056#    addu $sp,4

1060#    jr $ra # return
    
1064:goEsFalse:
    # put 0 in $t0 and return
1064#    li $t0, 0
1068#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1072:mth_toString_String:
    #we are a string, so return this.
1072#    move $t0, $s2
1076#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1080:mth_readLine_Lib:
    
1080#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1084#    sw $ra, 4($sp) # save $ra
1088#    move $t1,$sp # save "original" sp

1092:  doRead:

    # read the character
1092#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1096#    subu $t2,$v0,13
1100#    bne $t2,$zero,notReturnRL
1104#    jal readLogicalChar
1108#    subu $t2,$v0,10 # check for newline
1112#    beq $t2,$zero,foundNewLine
1116#    sw $v0,lastCharRead # push back character into queue
1120#    j foundNewLine # go process the line

1124:  notReturnRL:

    # at this point, $v0 has our character

1124#    subu $t0,$v0,10
1128#    beq $t0,$zero,foundNewLine
1132#    blt $v0,$zero,foundEof
1133##...slt $at,$v0,$zero
1137##...bne $at,$zero,1152

    # we have a character, so push it onto stack
1140#    subu $sp,$sp,4
1144#    sw $v0,($sp)

    # loop back up to get next character
1148#    j doRead

1152:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1152#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1156#    li $s7, 0 # return-value: null
1160#    j rlReturn # return

1164:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1164#    subu $t0,$t1,$sp # number of chars we read (times 4)
1168#    srl $s6,$t0,2 # number of words on stack with chars
1172#    subu $sp,$sp,4 # push char-count ...
1176#    sw $s6,($sp) # ... onto stack
1180#    addu $t2,$t0,5 # GC tag, incl. for count-word
1184#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1188#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1192#    srl $s6,$s6,2  # data words in object
1196#    move $s7,$zero # object words in object
1200#    jal newObject  # allocate space
    
    # store header words
1204#    la $t0,CLASS_String
1208#    sw $t0,-12($s7)# store class tag (String) into object
1212#    lw $t2,4($sp) # char-count
1216#    sll $t1,$t2,2 # 4 times number of chars
1220#    subu $t2,$zero,$t2 # negative of char-count
1224#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1228#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1232#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1233##...slt $at,$t0,$zero
1237##...beq $at,$zero,1256
1240#    and $t0,0xff # mask off object's hash value ...
1241##...lui $at,0
1245##...ori $at,$at,0xff
1249##...and $t0,$t0,$at
1252#    sw $t0,-8($s7) # ... and store back into -8 header-word
1256:  skipMask_readLine:

1256#    sll $t0,$t0,2 # data bytes in object
1260#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1264#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1268#    addu $sp,$sp,8 # pop redundant object-pointer and count
1272#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1276#    beq $sp,$t1,rlReturn
1280:  charCopyLoop:
1280#    lw $t2,($sp)
1284#    sb $t2,-9($t0)
1288#    addu $sp,$sp,4
1292#    subu $t0,$t0,1
1296#    bne $sp,$t1,charCopyLoop
1300:  rlReturn:

1300#    lw $ra, 4($sp)
1304#    addu $sp, 8   # pop $ra and pointless word off stack
1308#    move $t0, $s7 # return string we allocated in $s7
1312#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1316:mth_readInt_Lib:

    # save $ra by pushing onto stack
1316#    subu $sp,$sp,4
1320#    sw $ra,($sp)

1324:  riSkipWhiteLoop:
    # read a character
1324#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1328#    subu $t0,$v0,32
1332#    bgt $t0,$zero,nonWhite
1333##...slt $at,$zero,$t0
1337##...bne $at,$zero,1380
1340#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1344#    subu $t0,$v0,10
1348#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1352#    subu $t0,$v0,9
1356#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1360#    subu $t0,$v0,13
1364#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1368#    subu $t0,$v0,12
1372#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1376#    j badIntegerFormat # illegal integer char: abort program

1380:  nonWhite:
1380#    subu $t0,$v0,'-'
1384#    li $t4,1 # final multiplier
1388#    bne $t0,$zero,helpReadInt # go read
1392#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1396#    jal readLogicalChar

1400:  helpReadInt:
1400#    li $t2,10
1404#    subu $t1,$v0,'0' # convert digit to 0-9 value
1408#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1409##...sltu $at,$t1,$t2
1413##...beq $at,$zero,3660
1416#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1420:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1420#    jal readLogicalChar # read next character
1424#    subu $t1,$v0,'0' # convert digit to 0-9 value
1428#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1429##...sltu $at,$t1,$t2
1433##...beq $at,$zero,1452

1436#    mul $t3,$t3,$t2 # multiply old value by 10
1437##...mult $t3,$t2
1441##...mflo $t3
1444#    addu $t3,$t3,$t1 # add in value of new digit
1448#    j digitLoop

1452:  doneDigitLoop:

    # "push back" unused character into queue
1452#    sw $v0,lastCharRead

    # restore return address
1456#    lw $ra,($sp)
1460#    addu $sp, 4

    # multiply by sign and put return value in $t0
1464#    mult $t3,$t4 # multiply to account for poss. minus sign
1468#    mflo $t3
1472#    move $t0, $t3
    
    # return
1476#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1480:mth_readChar_Lib:

    # save $ra by pushing onto stack
1480#    subu $sp,$sp,4
1484#    sw $ra,($sp)

      # read the character
1488#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1492#    lw $ra,($sp)
1496#    addu $sp, 4
1500#    move $t0, $v0

    # return
1504#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
1508:mth_printStr_Lib:
    # check for null, printing "(null)", if so
1508#    lw $t0,($sp)
1512#    bne $t0,$zero,psNotNull

    # print "(null)"
1516#    la $a0,nullStr
1520#    li $v0,4
1524#    syscall
1528#    j donePrintStr
    
1532:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
1532#    subu $t0,$t0,8
1536#    lw $t1,($t0) # number of data words, but needs modification
1540#    blt $t1,$zero,skipPrintStr1

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
2616:readLogicalChar:

    # check if we already have a character
2616#    lw $v0,lastCharRead
2620#    li $t0,-2
2624#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
2628#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2632#    jr $ra # return
    
2636:  doReadCh:
    # we need to actually read a character: read and return
2636#    li $v0,12 # use system call to read a character
2640#    syscall
2644#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
2648:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
2648#    blt $s7,$zero arraySizeOutOfBounds
2649##...slt $at,$s7,$zero
2653##...bne $at,$zero,3644

    # mark the fact that we have not yet GC'd for this allocation
2656#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

2660:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
2660#    addu $t0,$s6,$s7
2664#    sll $t0,$t0,2
2668#    addu $t0,$t0,8 # amount of memory needed
2672#    addu $t1,$t0,$s3
2676#    bgtu $t1,$s4,doGC
2677##...sltu $at,$s4,$t1
2681##...bne $at,$zero,2804

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
2684#    move $t2,$s3
2688:  zeroObjLoop:
2688#    sw $zero,($s3)
2692#    lw $zero,($s3)

2696#    addu $s3,4
2700#    bltu $s3,$t1,zeroObjLoop
2701##...sltu $at,$s3,$t1
2705##...bne $at,$zero,2688

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
2708#    sll $t0,$s7,2    # number of post-header bytes
2712#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
2716#    li $t2,255
2720#    bgeu $s6,$t2 firstHeaderLarge
2721##...sltu $at,$s6,$t2
2725##...beq $at,$zero,2772
2728#    lw $t1,prevHashConstant
2732#    addu $t1,0x12b68fd2
2733##...lui $at,4791
2737##...addiu $at,$at,-28718
2741##...addu $t1,$at,$t1
2744#    sw $t1,prevHashConstant # update hash constant
2748#    or $t1,0x80000000 # set top bit
2749##...lui $at,32768
2753##...or $t1,$at,$t1
2756#    and $t1,0xffffff00 # clear low bit
2757##...lui $at,65535
2761##...ori $at,$at,0xff00
2765##...and $t1,$t1,$at
2768#    or $s6,$t1
2772:firstHeaderLarge:
2772#    sw $s6,-8($t0) # store header-1 value
2776#    lw $zero,-8($t0)

    # store second header-value
2780#    sw $s7,-4($t0)   # second header-word
2784#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
2788#    move $s7,$t0
2792#    subu $sp,$sp,4
2796#    sw $t0,($sp)

2800#    jr $ra
    
2804:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
2804#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
2808#    lw $t5,gcCount
2812#    addu $t5,1
2816#    sw $t5,gcCount

    # save $s2 (our only rooted register) on the stack
    # so that the garbage collector processes it
2820#    subu $sp,$sp,4
2824#    sw $s2,($sp)

    # set $s3 to the address of the new segment and the
    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
2828#    lw $t0,cur_seg
2832#    move $t7,$s4
2836#    la $t6,seg1_start
2837##...lui $t6,16
2841##...addiu $t6,$t6,4288
2844#    la $s3,seg0_start
2848#    la $s4,seg0_end
2849##...lui $s4,16
2853##...addiu $s4,$s4,4288
2856#    sw $zero,cur_seg
2860#    bne $t0,$zero,skipGc1
2864#    la $t6,seg0_start
2868#    la $s3,seg1_start
2869##...lui $s3,16
2873##...addiu $s3,$s3,4288
2876#    la $s4,seg1_end
2877##...lui $s4,32
2881##...addiu $s4,$s4,4288
2884#    sw $s5,cur_seg
2888:  skipGc1:
2888#    li $t5,0x80000000
2892#    lw $t0,stack_bottom
2896#    subu $t0,4


    ###############################################################
    # at this point:
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first address of the target space
    # - $s4 contains the limit address of the target space
    # - cur_seg has been updated to refer to the target space
    # - $t0 contains the address of the deepest stack element
    # - $sp contains the address of the top stack element
    # - $s2 is available for use, having been pushed onto the stack
    # - $t5 contains the value 0x80000000
    ###############################################################

    ###### begin outer loop to copy all stack-direct objects ######

2900:  gcStackCopyLoop:
2900#    lw $t1,($t0) # current stack element

    # test if we have a GC tag
2904#    sll $t2,$t1,31 # zero iff low bit was zero
2908#    bne $t2,$zero,gcBump # go skip data values if low bit not zero

    # bump stack-address pointer
2912#    subu $t0,$t0,4

    # if value is out of range (which includes null=0), and is
    # therefore does not refer to an object on the heap, just go
    # loop back and do the next one
2916#    bleu $t1,$t6,gcTestIterDone1
2917##...sltu $at,$t6,$t1
2921##...beq $at,$zero,3084
2924#    bgtu $t1,$t7,gcTestIterDone1
2925##...sltu $at,$t7,$t1
2929##...bne $at,$zero,3084

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
2932#    lw $t2,-8($t1) # possible forwarding tag
2936#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
2940#    lw $t2,-4($t1) # forwarding pointer: object's new address
2944#    sw $t2,4($t0) # update stack value
2948#    j gcTestIterDone1 # do next iteration

2952:  gcNoForward1:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    # compute the amount of space that is needed
2952#    bge $t2,$zero,gcSkip2
2953##...slt $at,$t2,$zero
2957##...beq $at,$zero,2972
2960#    and $t2,0xff #### mask off hash value
2961##...lui $at,0
2965##...ori $at,$at,0xff
2969##...and $t2,$t2,$at
    #### OLD
    #### subu $t2,$zero,$t2 # set to 1 if -1 (number of data words)

2972:  gcSkip2:
2972#    sll $t2,$t2,2
2976#    addu $t2,$t2,8
2980#    subu $t4,$t1,$t2 # address of first word of source
2984#    lw $t3,-4($t1) # number of object words (negative means zero)
2988#    bge $t3,$zero,gcH2Neg1
2989##...slt $at,$t3,$zero
2993##...beq $at,$zero,3000
2996#    move $t3,$zero
3000:  gcH2Neg1:
3000#    sll $t3,$t3,2
3004#    addu $t3,$t3,$t1 # address one word past last word of source

3008#    addu $t2,$s3,$t2 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object (i.e., the address just beyond the object's header)
    # - $t2 contains the pointer to the target object
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0-2
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger" in the target space
3012#    lw $s0,($t4)
3016#    lw $s1,-8($t1)
3020#    sw $s1,($t4)
3024#    sw $s0,-8($t1)
    
    # copy all source bytes to the target
3028:  gCinnerCopy1:
3028#    lw $s0,($t4)
3032#    sw $s0,($s3)
3036#    addu $t4,$t4,4
3040#    addu $s3,$s3,4
3044#    bltu $t4,$t3,gCinnerCopy1
3045##...sltu $at,$t4,$t3
3049##...bne $at,$zero,3028

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3052#    sw $zero,-8($t1) # 0 in first header-slot
3056#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
3060#    sw $t2,4($t0)
3064#    lw $zero,-8($t2)
3068#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
3072#    j gcTestIterDone1

3076:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
3076#    subu $t0,$t0,$t1
3080#    subu $t0,$t0,3

3084:  gcTestIterDone1:
3084#    bgeu $t0,$sp,gcStackCopyLoop
3085##...sltu $at,$t0,$sp
3089##...beq $at,$zero,2900

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
3092#    lw $t1,cur_seg
3096#    la $t0,seg0_start
3100#    beq $t1,$zero,gcSkip4
3104#    la $t0,seg1_start
3105##...lui $t0,16
3109##...addiu $t0,$t0,4288


3112:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
3112#    bgeu $t0,$s3,gcFinishUp
3113##...sltu $at,$t0,$s3
3117##...beq $at,$zero,3408

    ###### begin outer loop to copy all non-stack-direct objects ######

3120:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
3120#    lw $t1,($t0) # (what will be) first header word for current object
3124#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
3128#    bge $t2,$zero,gcSkip4a # are there hash bits?
3129##...slt $at,$t2,$zero
3133##...beq $at,$zero,3148
3136#    and $t2,0xff # mask off hash bits
3137##...lui $at,0
3141##...ori $at,$at,0xff
3145##...and $t2,$t2,$at
3148:gcSkip4a:    
3148#    sll $t2,$t2,2 # # data bytes
3152#    addu $t2,$t2,8 # to skip header words
3156#    addu $t2,$t0,$t2 # pointer to new object
3160#    lw $t3,-8($t2) # word to swap
3164#    sw $t1,-8($t2) # store header word
3168#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3172#    lw $t1,-12($t2) # vtable pointer
3176#    li $t0,dataArrayVTableStart # address of vtable for first data array
3180#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3181##...slt $at,$t1,$t0
3185##...bne $at,$zero,3204

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3188:  skipToNextObj:
3188#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3192#    sll $t1,$t1,2 # convert to byte-count
3196#    addu $t0,$t2,$t1 # skip over object
3200#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3204:  gcNotDataArray:
3204#    lw $t3,-4($t2) # # object words (negative treated as zero)
3208#    bge $t3,$zero,gcH2Neg2
3209##...slt $at,$t3,$zero
3213##...beq $at,$zero,3220
3216#    move $t3,$zero
3220:  gcH2Neg2:
3220#    sll $t3,$t3,2 # # object bytes
3224#    move $t0,$t2 # address of first pointer in object
3228#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3232#    beq $t0,$s1,gcTestIterDone2
    
3236:  gcNextPointerInObject:
    # get pointer from object
3236#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3240#    bleu $t1,$t6,gcGoNextPointerSlot
3241##...sltu $at,$t6,$t1
3245##...beq $at,$zero,3388
3248#    bgtu $t1,$t7,gcGoNextPointerSlot
3249##...sltu $at,$t7,$t1
3253##...bne $at,$zero,3388

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3256#    lw $t8,-8($t1) # possible forwarding tag
3260#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3264#    lw $t8,-4($t1) # forwarding pointer: object's new address
3268#    sw $t8,($t0) # update pointer in object
3272#    j gcGoNextPointerSlot # do next iteration

3276:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3276#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3277##...slt $at,$t8,$zero
3281##...beq $at,$zero,3296
3284#    and $t8,0xff # mask off hash bits
3285##...lui $at,0
3289##...ori $at,$at,0xff
3293##...and $t8,$t8,$at

3296:  gcSkip5:
3296#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3300#    addu $t8,$t8,8 # ... add in bytes for header-words
3304#    subu $t4,$t1,$t8 # address of first word of source object
3308#    lw $t3,-4($t1) # # words in positive-offset portion
3312#    bge $t3,$zero,gcNoNeg
3313##...slt $at,$t3,$zero
3317##...beq $at,$zero,3324
3320#    move $t3,$zero # negative treated as zero
3324:  gcNoNeg:
3324#    sll $t3,$t3,2 # bytes in negative-offset portion
3328#    addu $t3,$t3,$t1 # address one word past last word of source

3332#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3336#    lw $s0,($t4)
3340#    lw $t9,-8($t1)
3344#    sw $t9,($t4)
3348#    sw $s0,-8($t1)

    # copy all source bytes to the target
3352:  gCinnerCopy2:
3352#    lw $s0,($t4)
3356#    sw $s0,($s3)
3360#    addu $t4,$t4,4
3364#    addu $s3,$s3,4
3368#    bltu $t4,$t3,gCinnerCopy2
3369##...sltu $at,$t4,$t3
3373##...bne $at,$zero,3352

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3376#    sw $zero,-8($t1) # 0 in first header-slot
3380#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3384#    sw $t8,($t0)

3388:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3388#    addu $t0,$t0,4
3392#    bltu $t0,$s1,gcNextPointerInObject
3393##...sltu $at,$t0,$s1
3397##...bne $at,$zero,3236

3400:  gcTestIterDone2:
3400#    bltu $t0,$s3,gcHeapCopyLoop
3401##...sltu $at,$t0,$s3
3405##...bne $at,$zero,3120

    ###### end outer loop to copy all non-stack-direct objects ######

3408:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3408#    lw $s2,($sp)
3412#    addu $sp,$sp,4

    # mark us as having already GC'd
3416#    move $t5,$s5

    # go try and allocate again
3420#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3424:vm_init:

    # mark bottom of stack
3424#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3428#    move $s2,$zero

    #set up the "five" register
3432#    li $s5,5

3436#    la $s3,seg0_start
3440#    la $s4,seg0_end
3441##...lui $s4,16
3445##...addiu $s4,$s4,4288
    
    # return
3448#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3452:divide:
    # get parameters; abort if divisor zero
3452#    lw $t0,($sp)
3456#    lw $t1,8($sp)
3460#    beq $t0,$zero,divByZeroError
    
    # perform division
3464#    div $t1,$t0
3468#    mflo $t0

    # store result, adjust stack and return
3472#    addu $sp,$sp,8 # adjust stack
3476#    sw $t0,($sp) # store result
3480#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3484:remainder:
    # get parameters; abort if divisor zero
3484#    lw $t0,($sp)
3488#    lw $t1,8($sp)
3492#    beq $t0,$zero,divByZeroError
    
    # perform division
3496#    div $t1,$t0
3500#    mfhi $t0

    # store result, adjust stack and return
3504#    addu $sp,$sp,8 # adjust stack
3508#    sw $t0,($sp) # store result
3512#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3516:checkCast:
    # get object, allow immediately if null
3516#    lw $t2,($sp)
3520#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3524#    lw $t2,-12($t2) # vtable address
3528#    bge $t2,$t1,castException
3529##...slt $at,$t2,$t1
3533##...beq $at,$zero,3668
3536#    blt $t2,$t0,castException
3537##...slt $at,$t2,$t0
3541##...bne $at,$zero,3668
    
    # return, leaving object unchanged on stack
3544:  checkCastReturn:    
3544#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3548:instanceOf:
    # get object, go return false if null
3548#    lw $t2,($sp)
3552#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3556#    lw $t2,-12($t2) # vtable address
3560#    sge $t0,$t2,$t0 # are we >= the lower limit?
3561##...slt $t0,$t2,$t0
3565##...xori $t0,$t0,0x1
3568#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3572#    and $t2,$t0,$t1
3576#    sw $t2,($sp)
3580:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3580#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3584:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3584#    li $v0,4 # syscall-code for print-string
3588#    syscall
3592:exit:
    # print termination message
3592#    li $v0,4 # syscall-code for print-string
3596#    la $a0,exitString
3600#    syscall

    # terminate execution
3604#    li $v0,10 #syscall-code for "exit"
3608#    syscall

3612:outOfHeapMemory:
3612#    la $a0,heapMemoryMsg
3616#    j exitError
3620:divByZeroError:
3620#    la $a0,divByZeroMsg
3624#    j exitError
3628:strIndexOutOfBounds:
3628#    la $a0,strIndexOutOfBoundsMsg
3632#    j exitError
3636:arrayIndexOutOfBounds:
3636#    la $a0,arrayIndexOutOfBoundsMsg
3640#    j exitError
3644:arraySizeOutOfBounds:
3644#    la $a0,arraySizeOutOfBoundsMsg
3648#    j exitError
3652:nullPtrException:
3652#    la $a0,nullPtrExceptionMsg
3656#    j exitError
3660:badIntegerFormat:
3660#    la $a0,badIntegerFormatMsg
3664#    j exitError
3668:castException:
3668#    la $a0,castExceptionMsg
3672#    j exitError
############## data section ################
    .data
3924:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3940:cur_seg:
    .word 0

3944:lastCharRead:
    .word -2 # -2 => no buffered character
3948:prevHashConstant:
    .word 0x2785173c
3952:gcCount:
    .word 0

3956:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3983:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4006:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4041:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4075:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4108:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4139:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4187:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4208:gcMsg: 
      .asciiz "\nGC!\n"
4214:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4246:nullStr:
    .asciiz "null"
4251:trueString:
    .asciiz "true"
4256:falseString:
    .asciiz "false"
4262:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4281:newlineString:
    .asciiz "\n"
    
    .align 2
4284:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4288:seg0_start:
    .space 0x100000
1052864:seg0_end:
1052864:seg1_start:
    .space 0x100000
2101440:seg1_end:

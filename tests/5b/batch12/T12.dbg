1545##...bne $at,$zero,1564
1548#    and $t1,0xff # mask out all but low byte
1549##...lui $at,0
1553##...ori $at,$at,0xff
1557##...and $t1,$t1,$at
1560#    b skipPrintStr2
1564:skipPrintStr1:
1564#    and $t1,0x7ffffff
1565##...lui $at,2047
1569##...ori $at,$at,0xffff
1573##...and $t1,$t1,$at
1576:skipPrintStr2:    

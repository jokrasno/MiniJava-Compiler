2420#    sw $t4,-8($s7) # ... and store back into -8 header-word
2424:  skipMask_intToChar:

    # store data in string
2424#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
2428#    li $t0,-1
2432#    sw $t0,-4($s7)

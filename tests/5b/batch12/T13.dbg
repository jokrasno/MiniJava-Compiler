########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
1620:mth_substring_String:

    # save $ra by pushing onto stack
1620#    subu $sp,$sp,4
1624#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
1628#    move $t0,$s2
1632#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
1636#    lw $t0,-4($t0) # negative of string length
1640#    subu $t0,$zero,$t0 # string length
1644#    lw $t1,4($sp) # k
1648#    lw $t2,12($sp) # n
1652#    bgt $zero,$t2,strIndexOutOfBounds
1653##...slt $at,$t2,$zero
1657##...bne $at,$zero,3580
1660#    bgt $t2,$t1,strIndexOutOfBounds
1661##...slt $at,$t1,$t2
1665##...bne $at,$zero,3580
1668#    bgt $t1,$t0,strIndexOutOfBounds
1669##...slt $at,$t0,$t1
1673##...bne $at,$zero,3580

    # allocate memory
1676#    subu $s6,$t1,$t2 # # chars in target-string
1680#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1684#    srl $s6,$s6,2 # convert bytes-count to word-count
1688#    move $s7,$zero # (no object-bytes in string)
1692#    jal newObject

    # store "String" tag in object-type field
1696#    la $t0,CLASS_String
1700#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
1704#    lw $t4,-8($s7) # data words in source string
1708#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
1709##...slt $at,$t4,$zero
1713##...beq $at,$zero,1732
1716#    and $t4,0xff # mask off object's hash value ...
1717##...lui $at,0
1721##...ori $at,$at,0xff
1725##...and $t4,$t4,$at
1728#    sw $t4,-8($s7) # ... and store back into -8 header-word
1732:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1732#    lw $t1,8($sp) # k
1736#    lw $t2,16($sp) # n
1740#    subu $t0,$t2,$t1 # value to store
1744#    sw $t0,-4($s7) # store value
    
1748#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
1752#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
1756#    lw $t4,-8($t3) # data words in source string
1760#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
1764#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
1768#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
1772#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
1776#    lw $t2,-8($s7)   # data words in target string
1780#    sll $t2,$t2,2    # data bytes in target string
1784#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

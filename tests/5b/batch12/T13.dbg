##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
524:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
524#    lw $t0,-8($s2) # get word with hash bits from this
528#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
532#    addu $t0,$t1

536#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
540:mth_equals_Object:
540#    move $t0,$s2 # first pointer (this)
544#    lw $t1,($sp) # second pointer
548#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
549##...subu $at,$t0,$t1
553##...sltiu $t0,$at,1

556#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
560:mth_hashCode_String:
560#    move $t0,$s2 # put this pointer in t0

564#    li $t2,0 # current hash value
568#    lw $t1,-4($t0) # negative of number of characters in string
572#    beq $t1,$zero,done_hashCode_String # if zero length => done
576#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
580#    and $t0,0xfffffffc # adjust for padding
581##...lui $at,65535
585##...ori $at,$at,0xfffc
589##...and $t0,$t0,$at
592#    subu $t1,$t0,$t1 # address at end of string +12
596:loop_hashCode_String:    
596#    sll $t4,$t2,5 # multiply by 32
600#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
604#    lbu $t3,-12($t0) # current character
608#    addu $t2,$t3 # add in current character
612#    addu $t0,1 # go to next character's address
616#    bne $t0,$t1,loop_hashCode_String # loop back if more
620:done_hashCode_String:    

    # push int on stack
620#    move $t0, $t2 # put $t2 in return slot
624#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
628:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
628#    subu $sp,4
632#    sw $ra,($sp)
    
    # get hash value
636#    lw $t2,-12($s2) # vtable address
640#    lw $t0,($t2) # method address
644#    jalr $t0
648#    subu $sp,8 # push result (int in $t0) on stack
652#    sw $s5,4($sp)
656#    sw $t0,($sp)

    # compute print-size of hash value
660#    li $t0, 1
664#    lw $t1, ($sp)
668#    srl $t1,$t1,4
672#    beq $t1,$zero,toString_skip_loop
676:toString_loop_top:
676#    addu $t0,1
680#    srl $t1,$t1,4
684#    bne $t1,$zero,toString_loop_top
688:toString_skip_loop:
688#    subu $sp,8
692#    sw $s5,4($sp)
696#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
700#    lw $t2,-12($s2) # vtable address
704#    move $t0,$t2
708:toString_checkTagBit:
708#    subu $t0,1
712#    lb $t1,($t0)
716#    and $t1,0x80
717##...lui $at,0
721##...ori $at,$at,0x80
725##...and $t1,$t1,$at
728#    beq $t1,$zero,toString_checkTagBit
732#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
736#    subu $sp,8
740#    sw $t1,($sp)
744#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
748#    move $s7,$zero # -4 offset header word
752#    lw $t4,8($sp) # bytes for hash value
756#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
760#    addu $t4,8
764#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
768#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

772#    li $t0,CLASS_String # store string vtable address into ...
776#    sw $t0,-12($s7) # ... -12 offset in object header
780#    lw $t2,-12($s2) # our object's vtable address
784#    lw $t5,4($sp) # number characters in prefix
788#    lw $t1,12($sp) # number of characters in hashcode
792#    addu $t3,$t1,$t5 # number of characters in string ...
796#    addu $t3,1 # ... including the '@' character
800#    subu $t0,$zero,$t3 # store negated length into ...
804#    sw $t0,-4($s7) # ... -4 offset header word
808#    lw $t0,-8($s7) # get -8 offset header-word
812#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
813##...slt $at,$t0,$zero
817##...beq $at,$zero,836
820#    and $t0,0xff # mask off object's hash value ...
821##...lui $at,0
825##...ori $at,$at,0xff
829##...and $t0,$t0,$at
832#    sw $t0,-8($s7) # ... and store back into -8 header-word
836:skipMask_toString:
836#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
840#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
844#    subu $t4,$t2,$t5
848:toString_copyLoop:    
848#    lb $t3,($t4)
852#    and $t3,0x7f # mask off sign bit (in case first word)
853##...lui $at,0
857##...ori $at,$at,0x7f
861##...and $t3,$t3,$at
864#    sb $t3,-8($t0)
868#    addu $t4,1
872#    addu $t0,1
876#    blt $t4,$t2,toString_copyLoop
877##...slt $at,$t4,$t2
881##...bne $at,$zero,848

    # copy the '@' sign
884#    li $t3,'@'
888#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
892#    addu $t2,$t0,$t1 # address of last byte in string to store +8
896#    lw $t3,20($sp) # hash code to print
900:toString_hashCopyLoop:
900#    and $t4,$t3,0xf
904#    srl $t3,4
908#    lb $t4,hexChars($t4)
912#    sb $t4,-8($t2)
916#    subu $t2,$t2,1
920#    bgt $t2,$t0,toString_hashCopyLoop
921##...slt $at,$t0,$t2
925##...bne $at,$zero,900

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
928#    addu $sp,28
932#    lw $ra,($sp)
936#    addu $sp,4
940#    move $t0, $s7 # return string we created
944#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
948:mth_equals_String:
    
    # quick test for obvious false
948#    lw $t0,($sp) # second parameter
952#    beq $t0,$zero,goEsFalse # go return false if null
956#    lw $t1,-12($t0) # vtable pointer
960#    la $t2,CLASS_String # string vtable pointer
964#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
968#    subu $sp,12
972#    sw $ra,8($sp)
976#    sw $s2,4($sp)
980#    sw $t0,($sp)
984#    jal mth_compareTo_String
988#    lw $s2, 4($sp) #restore this pointer and pop parameters
992#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
996#    seq $t0,$t0,$zero
997##...subu $at,$t0,$zero
1001##...sltiu $t0,$at,1

    # pop return address and return $t0
1004#    lw $ra,($sp)
1008#    addu $sp,4

1012#    jr $ra # return
    
1016:goEsFalse:
    # put 0 in $t0 and return
1016#    li $t0, 0
1020#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object

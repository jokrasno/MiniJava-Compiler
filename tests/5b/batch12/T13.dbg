3308#    sw $s0,($s3)
3312#    addu $t4,$t4,4
3316#    addu $s3,$s3,4
3320#    bltu $t4,$t3,gCinnerCopy2
3321##...sltu $at,$t4,$t3
3325##...bne $at,$zero,3304

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3328#    sw $zero,-8($t1) # 0 in first header-slot
3332#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3336#    sw $t8,($t0)

3340:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3340#    addu $t0,$t0,4
3344#    bltu $t0,$s1,gcNextPointerInObject
3345##...sltu $at,$t0,$s1
3349##...bne $at,$zero,3188

3352:  gcTestIterDone2:
3352#    bltu $t0,$s3,gcHeapCopyLoop
3353##...sltu $at,$t0,$s3
3357##...bne $at,$zero,3072

    ###### end outer loop to copy all non-stack-direct objects ######

3360:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3360#    lw $s2,($sp)
3364#    addu $sp,$sp,4

    # mark us as having already GC'd
3368#    move $t5,$s5

    # go try and allocate again
3372#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3376:vm_init:

    # mark bottom of stack
3376#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3380#    move $s2,$zero

    #set up the "five" register
3384#    li $s5,5

3388#    la $s3,seg0_start
3392#    la $s4,seg0_end
3393##...lui $s4,16
3397##...addiu $s4,$s4,4248
    
    # return
3400#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3404:divide:
    # get parameters; abort if divisor zero
3404#    lw $t0,($sp)
3408#    lw $t1,8($sp)
3412#    beq $t0,$zero,divByZeroError
    
    # perform division
3416#    div $t1,$t0
3420#    mflo $t0

    # store result, adjust stack and return
3424#    addu $sp,$sp,8 # adjust stack
3428#    sw $t0,($sp) # store result
3432#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3436:remainder:
    # get parameters; abort if divisor zero
3436#    lw $t0,($sp)
3440#    lw $t1,8($sp)
3444#    beq $t0,$zero,divByZeroError
    
    # perform division
3448#    div $t1,$t0
3452#    mfhi $t0

    # store result, adjust stack and return
3456#    addu $sp,$sp,8 # adjust stack
3460#    sw $t0,($sp) # store result
3464#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3468:checkCast:
    # get object, allow immediately if null
3468#    lw $t2,($sp)
3472#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3476#    lw $t2,-12($t2) # vtable address
3480#    bge $t2,$t1,castException
3481##...slt $at,$t2,$t1
3485##...beq $at,$zero,3620
3488#    blt $t2,$t0,castException
3489##...slt $at,$t2,$t0
3493##...bne $at,$zero,3620
    
    # return, leaving object unchanged on stack
3496:  checkCastReturn:    
3496#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3500:instanceOf:
    # get object, go return false if null
3500#    lw $t2,($sp)
3504#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3508#    lw $t2,-12($t2) # vtable address
3512#    sge $t0,$t2,$t0 # are we >= the lower limit?
3513##...slt $t0,$t2,$t0
3517##...xori $t0,$t0,0x1
3520#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3524#    and $t2,$t0,$t1
3528#    sw $t2,($sp)
3532:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3532#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3536:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3536#    li $v0,4 # syscall-code for print-string
3540#    syscall
3544:exit:
    # print termination message
3544#    li $v0,4 # syscall-code for print-string
3548#    la $a0,exitString
3552#    syscall

    # terminate execution
3556#    li $v0,10 #syscall-code for "exit"
3560#    syscall

3564:outOfHeapMemory:
3564#    la $a0,heapMemoryMsg
3568#    j exitError
3572:divByZeroError:
3572#    la $a0,divByZeroMsg
3576#    j exitError
3580:strIndexOutOfBounds:
3580#    la $a0,strIndexOutOfBoundsMsg
3584#    j exitError
3588:arrayIndexOutOfBounds:
3588#    la $a0,arrayIndexOutOfBoundsMsg
3592#    j exitError
3596:arraySizeOutOfBounds:
3596#    la $a0,arraySizeOutOfBoundsMsg
3600#    j exitError
3604:nullPtrException:
3604#    la $a0,nullPtrExceptionMsg
3608#    j exitError
3612:badIntegerFormat:
3612#    la $a0,badIntegerFormatMsg
3616#    j exitError
3620:castException:
3620#    la $a0,castExceptionMsg
3624#    j exitError
############## data section ################
    .data
3884:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3900:cur_seg:
    .word 0

3904:lastCharRead:
    .word -2 # -2 => no buffered character
3908:prevHashConstant:
    .word 0x2785173c
3912:gcCount:
    .word 0

3916:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3943:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3966:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4001:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4035:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4068:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4099:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4147:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4168:gcMsg: 
      .asciiz "\nGC!\n"
4174:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4206:nullStr:
    .asciiz "null"
4211:trueString:
    .asciiz "true"
4216:falseString:
    .asciiz "false"
4222:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4241:newlineString:
    .asciiz "\n"
    
    .align 2
4244:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4248:seg0_start:
    .space 0x100000
1052824:seg0_end:
1052824:seg1_start:
    .space 0x100000
2101400:seg1_end:

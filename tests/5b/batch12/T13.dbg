###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1032:mth_readLine_Lib:
    
1032#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1036#    sw $ra, 4($sp) # save $ra
1040#    move $t1,$sp # save "original" sp

1044:  doRead:

    # read the character
1044#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1048#    subu $t2,$v0,13
1052#    bne $t2,$zero,notReturnRL
1056#    jal readLogicalChar
1060#    subu $t2,$v0,10 # check for newline
1064#    beq $t2,$zero,foundNewLine
1068#    sw $v0,lastCharRead # push back character into queue
1072#    j foundNewLine # go process the line

1076:  notReturnRL:

    # at this point, $v0 has our character

1076#    subu $t0,$v0,10
1080#    beq $t0,$zero,foundNewLine
1084#    blt $v0,$zero,foundEof
1085##...slt $at,$v0,$zero
1089##...bne $at,$zero,1104

    # we have a character, so push it onto stack
1092#    subu $sp,$sp,4
1096#    sw $v0,($sp)

    # loop back up to get next character
1100#    j doRead

1104:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1104#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1108#    li $s7, 0 # return-value: null
1112#    j rlReturn # return

1116:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1116#    subu $t0,$t1,$sp # number of chars we read (times 4)
1120#    srl $s6,$t0,2 # number of words on stack with chars
1124#    subu $sp,$sp,4 # push char-count ...
1128#    sw $s6,($sp) # ... onto stack
1132#    addu $t2,$t0,5 # GC tag, incl. for count-word
1136#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1140#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1144#    srl $s6,$s6,2  # data words in object
1148#    move $s7,$zero # object words in object
1152#    jal newObject  # allocate space
    
    # store header words
1156#    la $t0,CLASS_String
1160#    sw $t0,-12($s7)# store class tag (String) into object
1164#    lw $t2,4($sp) # char-count
1168#    sll $t1,$t2,2 # 4 times number of chars
1172#    subu $t2,$zero,$t2 # negative of char-count
1176#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1180#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1184#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1185##...slt $at,$t0,$zero
1189##...beq $at,$zero,1208
1192#    and $t0,0xff # mask off object's hash value ...
1193##...lui $at,0
1197##...ori $at,$at,0xff
1201##...and $t0,$t0,$at
1204#    sw $t0,-8($s7) # ... and store back into -8 header-word
1208:  skipMask_readLine:

1208#    sll $t0,$t0,2 # data bytes in object
1212#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1216#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1220#    addu $sp,$sp,8 # pop redundant object-pointer and count
1224#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1228#    beq $sp,$t1,rlReturn
1232:  charCopyLoop:
1232#    lw $t2,($sp)
1236#    sb $t2,-9($t0)
1240#    addu $sp,$sp,4
1244#    subu $t0,$t0,1
1248#    bne $sp,$t1,charCopyLoop
1252:  rlReturn:

1252#    lw $ra, 4($sp)
1256#    addu $sp, 8   # pop $ra and pointless word off stack
1260#    move $t0, $s7 # return string we allocated in $s7
1264#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1268:mth_readInt_Lib:

    # save $ra by pushing onto stack
1268#    subu $sp,$sp,4
1272#    sw $ra,($sp)

1276:  riSkipWhiteLoop:
    # read a character
1276#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1280#    subu $t0,$v0,32
1284#    bgt $t0,$zero,nonWhite
1285##...slt $at,$zero,$t0
1289##...bne $at,$zero,1332
1292#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1296#    subu $t0,$v0,10
1300#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1304#    subu $t0,$v0,9
1308#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1312#    subu $t0,$v0,13
1316#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1320#    subu $t0,$v0,12
1324#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1328#    j badIntegerFormat # illegal integer char: abort program

1332:  nonWhite:
1332#    subu $t0,$v0,'-'
1336#    li $t4,1 # final multiplier
1340#    bne $t0,$zero,helpReadInt # go read
1344#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1348#    jal readLogicalChar

1352:  helpReadInt:
1352#    li $t2,10
1356#    subu $t1,$v0,'0' # convert digit to 0-9 value
1360#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1361##...sltu $at,$t1,$t2
1365##...beq $at,$zero,3612
1368#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1372:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1372#    jal readLogicalChar # read next character
1376#    subu $t1,$v0,'0' # convert digit to 0-9 value
1380#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1381##...sltu $at,$t1,$t2
1385##...beq $at,$zero,1404

1388#    mul $t3,$t3,$t2 # multiply old value by 10
1389##...mult $t3,$t2
1393##...mflo $t3
1396#    addu $t3,$t3,$t1 # add in value of new digit
1400#    j digitLoop

1404:  doneDigitLoop:

    # "push back" unused character into queue
1404#    sw $v0,lastCharRead

    # restore return address
1408#    lw $ra,($sp)
1412#    addu $sp, 4

    # multiply by sign and put return value in $t0
1416#    mult $t3,$t4 # multiply to account for poss. minus sign
1420#    mflo $t3
1424#    move $t0, $t3
    
    # return
1428#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1432:mth_readChar_Lib:

    # save $ra by pushing onto stack
1432#    subu $sp,$sp,4
1436#    sw $ra,($sp)

      # read the character
1440#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1444#    lw $ra,($sp)
1448#    addu $sp, 4
1452#    move $t0, $v0

    # return
1456#    jr $ra

########################################################

    
    # return
3188#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3192:divide:
    # get parameters; abort if divisor zero
3192#    lw $t0,($sp)
3196#    lw $t1,8($sp)
3200#    beq $t0,$zero,divByZeroError
    
    # perform division
3204#    div $t1,$t0
3208#    mflo $t0

    # store result, adjust stack and return
3212#    addu $sp,$sp,8 # adjust stack
3216#    sw $t0,($sp) # store result
3220#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3224:remainder:
    # get parameters; abort if divisor zero
3224#    lw $t0,($sp)
3228#    lw $t1,8($sp)
3232#    beq $t0,$zero,divByZeroError
    
    # perform division
3236#    div $t1,$t0
3240#    mfhi $t0

    # store result, adjust stack and return
3244#    addu $sp,$sp,8 # adjust stack
3248#    sw $t0,($sp) # store result
3252#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3256:checkCast:
    # get object, allow immediately if null
3256#    lw $t2,($sp)
3260#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3264#    lw $t2,-12($t2) # vtable address
3268#    bge $t2,$t1,castException
3269##...slt $at,$t2,$t1
3273##...beq $at,$zero,3408
3276#    blt $t2,$t0,castException
3277##...slt $at,$t2,$t0
3281##...bne $at,$zero,3408
    
    # return, leaving object unchanged on stack
3284:  checkCastReturn:    
3284#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3288:instanceOf:
    # get object, go return false if null
3288#    lw $t2,($sp)
3292#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3296#    lw $t2,-12($t2) # vtable address
3300#    sge $t0,$t2,$t0 # are we >= the lower limit?
3301##...slt $t0,$t2,$t0
3305##...xori $t0,$t0,0x1
3308#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3312#    and $t2,$t0,$t1
3316#    sw $t2,($sp)
3320:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3320#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3324:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3324#    li $v0,4 # syscall-code for print-string
3328#    syscall
3332:exit:
    # print termination message
3332#    li $v0,4 # syscall-code for print-string
3336#    la $a0,exitString
3340#    syscall

    # terminate execution
3344#    li $v0,10 #syscall-code for "exit"
3348#    syscall

3352:outOfHeapMemory:
3352#    la $a0,heapMemoryMsg
3356#    j exitError
3360:divByZeroError:
3360#    la $a0,divByZeroMsg
3364#    j exitError
3368:strIndexOutOfBounds:
3368#    la $a0,strIndexOutOfBoundsMsg
3372#    j exitError
3376:arrayIndexOutOfBounds:
3376#    la $a0,arrayIndexOutOfBoundsMsg
3380#    j exitError
3384:arraySizeOutOfBounds:
3384#    la $a0,arraySizeOutOfBoundsMsg
3388#    j exitError
3392:nullPtrException:
3392#    la $a0,nullPtrExceptionMsg
3396#    j exitError
3400:badIntegerFormat:
3400#    la $a0,badIntegerFormatMsg
3404#    j exitError
3408:castException:
3408#    la $a0,castExceptionMsg
3412#    j exitError
############## data section ################
    .data
3648:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3664:cur_seg:
    .word 0

3668:lastCharRead:
    .word -2 # -2 => no buffered character
3672:prevHashConstant:
    .word 0x2785173c
3676:gcCount:
    .word 0

3680:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3707:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3730:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3765:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3799:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3832:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3863:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3911:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3932:gcMsg: 
      .asciiz "\nGC!\n"
3938:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3970:nullStr:
    .asciiz "null"
3975:trueString:
    .asciiz "true"
3980:falseString:
    .asciiz "false"
3986:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4005:newlineString:
    .asciiz "\n"
    
    .align 2
4008:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4012:seg0_start:
    .space 0x100000
1052588:seg0_end:
1052588:seg1_start:
    .space 0x100000
2101164:seg1_end:

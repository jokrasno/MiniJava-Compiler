2272#    lw $t2,-8($t0) # # data words in second string
2276#    lw $t3,-8($t1) # # data words in first string
2280#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
2284#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
2288#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
2292#    subu $t1,$t1,$t3 # beginning of str2 address (+8)

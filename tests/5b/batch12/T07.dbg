##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
312:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
312#    lw $t0,-8($s2) # get word with hash bits from this
316#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
320#    addu $t0,$t1

324#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
328:mth_equals_Object:
328#    move $t0,$s2 # first pointer (this)
332#    lw $t1,($sp) # second pointer
336#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
337##...subu $at,$t0,$t1
341##...sltiu $t0,$at,1

344#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
348:mth_hashCode_String:
348#    move $t0,$s2 # put this pointer in t0

352#    li $t2,0 # current hash value
356#    lw $t1,-4($t0) # negative of number of characters in string
360#    beq $t1,$zero,done_hashCode_String # if zero length => done
364#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
368#    and $t0,0xfffffffc # adjust for padding
369##...lui $at,65535
373##...ori $at,$at,0xfffc
377##...and $t0,$t0,$at
380#    subu $t1,$t0,$t1 # address at end of string +12
384:loop_hashCode_String:    
384#    sll $t4,$t2,5 # multiply by 32
388#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
392#    lbu $t3,-12($t0) # current character
396#    addu $t2,$t3 # add in current character
400#    addu $t0,1 # go to next character's address
404#    bne $t0,$t1,loop_hashCode_String # loop back if more
408:done_hashCode_String:    

    # push int on stack
408#    move $t0, $t2 # put $t2 in return slot
412#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
416:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
416#    subu $sp,4
420#    sw $ra,($sp)
    
    # get hash value
424#    lw $t2,-12($s2) # vtable address
428#    lw $t0,($t2) # method address
432#    jalr $t0
436#    subu $sp,8 # push result (int in $t0) on stack
440#    sw $s5,4($sp)
444#    sw $t0,($sp)

    # compute print-size of hash value
448#    li $t0, 1
452#    lw $t1, ($sp)
456#    srl $t1,$t1,4
460#    beq $t1,$zero,toString_skip_loop
464:toString_loop_top:
464#    addu $t0,1
468#    srl $t1,$t1,4
472#    bne $t1,$zero,toString_loop_top
476:toString_skip_loop:
476#    subu $sp,8
480#    sw $s5,4($sp)
484#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
488#    lw $t2,-12($s2) # vtable address
492#    move $t0,$t2
496:toString_checkTagBit:
496#    subu $t0,1
500#    lb $t1,($t0)
504#    and $t1,0x80
505##...lui $at,0
509##...ori $at,$at,0x80
513##...and $t1,$t1,$at
516#    beq $t1,$zero,toString_checkTagBit
520#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
524#    subu $sp,8
528#    sw $t1,($sp)
532#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
536#    move $s7,$zero # -4 offset header word
540#    lw $t4,8($sp) # bytes for hash value
544#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
548#    addu $t4,8
552#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
556#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

560#    li $t0,CLASS_String # store string vtable address into ...
564#    sw $t0,-12($s7) # ... -12 offset in object header
568#    lw $t2,-12($s2) # our object's vtable address
572#    lw $t5,4($sp) # number characters in prefix
576#    lw $t1,12($sp) # number of characters in hashcode
580#    addu $t3,$t1,$t5 # number of characters in string ...
584#    addu $t3,1 # ... including the '@' character
588#    subu $t0,$zero,$t3 # store negated length into ...
592#    sw $t0,-4($s7) # ... -4 offset header word
596#    lw $t0,-8($s7) # get -8 offset header-word
600#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
601##...slt $at,$t0,$zero
605##...beq $at,$zero,624
608#    and $t0,0xff # mask off object's hash value ...
609##...lui $at,0
613##...ori $at,$at,0xff
617##...and $t0,$t0,$at
620#    sw $t0,-8($s7) # ... and store back into -8 header-word
624:skipMask_toString:
624#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
628#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
632#    subu $t4,$t2,$t5
636:toString_copyLoop:    
636#    lb $t3,($t4)
640#    and $t3,0x7f # mask off sign bit (in case first word)
641##...lui $at,0
645##...ori $at,$at,0x7f
649##...and $t3,$t3,$at
652#    sb $t3,-8($t0)
656#    addu $t4,1
660#    addu $t0,1
664#    blt $t4,$t2,toString_copyLoop
665##...slt $at,$t4,$t2
669##...bne $at,$zero,636

    # copy the '@' sign
672#    li $t3,'@'
676#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
680#    addu $t2,$t0,$t1 # address of last byte in string to store +8
684#    lw $t3,20($sp) # hash code to print
688:toString_hashCopyLoop:
688#    and $t4,$t3,0xf
692#    srl $t3,4
696#    lb $t4,hexChars($t4)
700#    sb $t4,-8($t2)
704#    subu $t2,$t2,1
708#    bgt $t2,$t0,toString_hashCopyLoop
709##...slt $at,$t0,$t2
713##...bne $at,$zero,688

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
716#    addu $sp,28
720#    lw $ra,($sp)
724#    addu $sp,4
728#    move $t0, $s7 # return string we created
732#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
736:mth_equals_String:
    
    # quick test for obvious false
736#    lw $t0,($sp) # second parameter
740#    beq $t0,$zero,goEsFalse # go return false if null
744#    lw $t1,-12($t0) # vtable pointer
748#    la $t2,CLASS_String # string vtable pointer
752#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
756#    subu $sp,12
760#    sw $ra,8($sp)
764#    sw $s2,4($sp)
768#    sw $t0,($sp)
772#    jal mth_compareTo_String
776#    lw $s2, 4($sp) #restore this pointer and pop parameters
780#    addu $sp, 8 # pop parameters


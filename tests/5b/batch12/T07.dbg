###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
820:mth_readLine_Lib:
    
820#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
824#    sw $ra, 4($sp) # save $ra
828#    move $t1,$sp # save "original" sp

832:  doRead:

    # read the character
832#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
836#    subu $t2,$v0,13
840#    bne $t2,$zero,notReturnRL
844#    jal readLogicalChar
848#    subu $t2,$v0,10 # check for newline
852#    beq $t2,$zero,foundNewLine
856#    sw $v0,lastCharRead # push back character into queue
860#    j foundNewLine # go process the line

864:  notReturnRL:

    # at this point, $v0 has our character

864#    subu $t0,$v0,10
868#    beq $t0,$zero,foundNewLine
872#    blt $v0,$zero,foundEof
873##...slt $at,$v0,$zero
877##...bne $at,$zero,892

    # we have a character, so push it onto stack
880#    subu $sp,$sp,4
884#    sw $v0,($sp)

    # loop back up to get next character
888#    j doRead

892:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
892#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
896#    li $s7, 0 # return-value: null
900#    j rlReturn # return

904:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
904#    subu $t0,$t1,$sp # number of chars we read (times 4)
908#    srl $s6,$t0,2 # number of words on stack with chars
912#    subu $sp,$sp,4 # push char-count ...
916#    sw $s6,($sp) # ... onto stack
920#    addu $t2,$t0,5 # GC tag, incl. for count-word
924#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
928#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
932#    srl $s6,$s6,2  # data words in object
936#    move $s7,$zero # object words in object
940#    jal newObject  # allocate space
    
    # store header words
944#    la $t0,CLASS_String
948#    sw $t0,-12($s7)# store class tag (String) into object
952#    lw $t2,4($sp) # char-count
956#    sll $t1,$t2,2 # 4 times number of chars
960#    subu $t2,$zero,$t2 # negative of char-count
964#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
968#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
972#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
973##...slt $at,$t0,$zero
977##...beq $at,$zero,996
980#    and $t0,0xff # mask off object's hash value ...
981##...lui $at,0
985##...ori $at,$at,0xff
989##...and $t0,$t0,$at
992#    sw $t0,-8($s7) # ... and store back into -8 header-word
996:  skipMask_readLine:

996#    sll $t0,$t0,2 # data bytes in object
1000#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1004#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1008#    addu $sp,$sp,8 # pop redundant object-pointer and count
1012#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1016#    beq $sp,$t1,rlReturn
1020:  charCopyLoop:
1020#    lw $t2,($sp)
1024#    sb $t2,-9($t0)
1028#    addu $sp,$sp,4
1032#    subu $t0,$t0,1
1036#    bne $sp,$t1,charCopyLoop
1040:  rlReturn:

1040#    lw $ra, 4($sp)
1044#    addu $sp, 8   # pop $ra and pointless word off stack
1048#    move $t0, $s7 # return string we allocated in $s7
1052#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1056:mth_readInt_Lib:

    # save $ra by pushing onto stack
1056#    subu $sp,$sp,4
1060#    sw $ra,($sp)

1064:  riSkipWhiteLoop:
    # read a character
1064#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1068#    subu $t0,$v0,32
1072#    bgt $t0,$zero,nonWhite
1073##...slt $at,$zero,$t0
1077##...bne $at,$zero,1120
1080#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1084#    subu $t0,$v0,10
1088#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1092#    subu $t0,$v0,9
1096#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1100#    subu $t0,$v0,13
1104#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1108#    subu $t0,$v0,12
1112#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1116#    j badIntegerFormat # illegal integer char: abort program

1120:  nonWhite:
1120#    subu $t0,$v0,'-'
1124#    li $t4,1 # final multiplier
1128#    bne $t0,$zero,helpReadInt # go read
1132#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1136#    jal readLogicalChar

1140:  helpReadInt:
1140#    li $t2,10
1144#    subu $t1,$v0,'0' # convert digit to 0-9 value
1148#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1149##...sltu $at,$t1,$t2
1153##...beq $at,$zero,3400
1156#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1160:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1160#    jal readLogicalChar # read next character
1164#    subu $t1,$v0,'0' # convert digit to 0-9 value
1168#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1169##...sltu $at,$t1,$t2
1173##...beq $at,$zero,1192

1176#    mul $t3,$t3,$t2 # multiply old value by 10
1177##...mult $t3,$t2
1181##...mflo $t3
1184#    addu $t3,$t3,$t1 # add in value of new digit
1188#    j digitLoop

1192:  doneDigitLoop:

    # "push back" unused character into queue
1192#    sw $v0,lastCharRead

    # restore return address
1196#    lw $ra,($sp)
1200#    addu $sp, 4

    # multiply by sign and put return value in $t0
1204#    mult $t3,$t4 # multiply to account for poss. minus sign
1208#    mflo $t3
1212#    move $t0, $t3
    
    # return
1216#    jr $ra

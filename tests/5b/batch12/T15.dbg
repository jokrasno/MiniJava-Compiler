#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3236:vm_init:

    # mark bottom of stack
3236#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3240#    move $s2,$zero

    #set up the "five" register
3244#    li $s5,5

3248#    la $s3,seg0_start
3252#    la $s4,seg0_end
3253##...lui $s4,16
3257##...addiu $s4,$s4,4096
    
    # return
3260#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3264:divide:
    # get parameters; abort if divisor zero
3264#    lw $t0,($sp)
3268#    lw $t1,8($sp)
3272#    beq $t0,$zero,divByZeroError
    
    # perform division
3276#    div $t1,$t0
3280#    mflo $t0

    # store result, adjust stack and return
3284#    addu $sp,$sp,8 # adjust stack
3288#    sw $t0,($sp) # store result
3292#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3296:remainder:
    # get parameters; abort if divisor zero
3296#    lw $t0,($sp)
3300#    lw $t1,8($sp)
3304#    beq $t0,$zero,divByZeroError
    
    # perform division
3308#    div $t1,$t0
3312#    mfhi $t0

    # store result, adjust stack and return
3316#    addu $sp,$sp,8 # adjust stack
3320#    sw $t0,($sp) # store result
3324#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3328:checkCast:
    # get object, allow immediately if null
3328#    lw $t2,($sp)
3332#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3336#    lw $t2,-12($t2) # vtable address
3340#    bge $t2,$t1,castException
3341##...slt $at,$t2,$t1
3345##...beq $at,$zero,3480
3348#    blt $t2,$t0,castException
3349##...slt $at,$t2,$t0
3353##...bne $at,$zero,3480
    
    # return, leaving object unchanged on stack
3356:  checkCastReturn:    
3356#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3360:instanceOf:
    # get object, go return false if null
3360#    lw $t2,($sp)
3364#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3368#    lw $t2,-12($t2) # vtable address
3372#    sge $t0,$t2,$t0 # are we >= the lower limit?
3373##...slt $t0,$t2,$t0
3377##...xori $t0,$t0,0x1
3380#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3384#    and $t2,$t0,$t1
3388#    sw $t2,($sp)
3392:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3392#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3396:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3396#    li $v0,4 # syscall-code for print-string
3400#    syscall
3404:exit:
    # print termination message
3404#    li $v0,4 # syscall-code for print-string
3408#    la $a0,exitString
3412#    syscall

    # terminate execution
3416#    li $v0,10 #syscall-code for "exit"
3420#    syscall

3424:outOfHeapMemory:
3424#    la $a0,heapMemoryMsg
3428#    j exitError
3432:divByZeroError:
3432#    la $a0,divByZeroMsg
3436#    j exitError
3440:strIndexOutOfBounds:
3440#    la $a0,strIndexOutOfBoundsMsg
3444#    j exitError
3448:arrayIndexOutOfBounds:
3448#    la $a0,arrayIndexOutOfBoundsMsg
3452#    j exitError
3456:arraySizeOutOfBounds:
3456#    la $a0,arraySizeOutOfBoundsMsg
3460#    j exitError
3464:nullPtrException:
3464#    la $a0,nullPtrExceptionMsg
3468#    j exitError
3472:badIntegerFormat:
3472#    la $a0,badIntegerFormatMsg
3476#    j exitError
3480:castException:
3480#    la $a0,castExceptionMsg
3484#    j exitError
############## data section ################
    .data
3732:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3748:cur_seg:
    .word 0

3752:lastCharRead:
    .word -2 # -2 => no buffered character
3756:prevHashConstant:
    .word 0x2785173c
3760:gcCount:
    .word 0

3764:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3791:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3814:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3849:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3883:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3916:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3947:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3995:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4016:gcMsg: 
      .asciiz "\nGC!\n"
4022:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4054:nullStr:
    .asciiz "null"
4059:trueString:
    .asciiz "true"
4064:falseString:
    .asciiz "false"
4070:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4089:newlineString:
    .asciiz "\n"
    
    .align 2
4092:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4096:seg0_start:
    .space 0x100000
1052672:seg0_end:
1052672:seg1_start:
    .space 0x100000
2101248:seg1_end:

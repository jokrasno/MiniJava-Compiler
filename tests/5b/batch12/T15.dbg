##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
384:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
384#    lw $t0,-8($s2) # get word with hash bits from this
388#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
392#    addu $t0,$t1

396#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
400:mth_equals_Object:
400#    move $t0,$s2 # first pointer (this)
404#    lw $t1,($sp) # second pointer
408#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
409##...subu $at,$t0,$t1
413##...sltiu $t0,$at,1

416#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
420:mth_hashCode_String:
420#    move $t0,$s2 # put this pointer in t0

424#    li $t2,0 # current hash value
428#    lw $t1,-4($t0) # negative of number of characters in string
432#    beq $t1,$zero,done_hashCode_String # if zero length => done
436#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
440#    and $t0,0xfffffffc # adjust for padding
441##...lui $at,65535
445##...ori $at,$at,0xfffc
449##...and $t0,$t0,$at
452#    subu $t1,$t0,$t1 # address at end of string +12
456:loop_hashCode_String:    
456#    sll $t4,$t2,5 # multiply by 32
460#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
464#    lbu $t3,-12($t0) # current character
468#    addu $t2,$t3 # add in current character
472#    addu $t0,1 # go to next character's address
476#    bne $t0,$t1,loop_hashCode_String # loop back if more
480:done_hashCode_String:    

    # push int on stack
480#    move $t0, $t2 # put $t2 in return slot
484#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
488:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
488#    subu $sp,4
492#    sw $ra,($sp)
    
    # get hash value
496#    lw $t2,-12($s2) # vtable address
500#    lw $t0,($t2) # method address
504#    jalr $t0
508#    subu $sp,8 # push result (int in $t0) on stack
512#    sw $s5,4($sp)
516#    sw $t0,($sp)

    # compute print-size of hash value
520#    li $t0, 1
524#    lw $t1, ($sp)
528#    srl $t1,$t1,4
532#    beq $t1,$zero,toString_skip_loop
536:toString_loop_top:
536#    addu $t0,1
540#    srl $t1,$t1,4
544#    bne $t1,$zero,toString_loop_top
548:toString_skip_loop:
548#    subu $sp,8
552#    sw $s5,4($sp)
556#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
560#    lw $t2,-12($s2) # vtable address
564#    move $t0,$t2
568:toString_checkTagBit:
568#    subu $t0,1
572#    lb $t1,($t0)
576#    and $t1,0x80
577##...lui $at,0
581##...ori $at,$at,0x80
585##...and $t1,$t1,$at
588#    beq $t1,$zero,toString_checkTagBit
592#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
596#    subu $sp,8
600#    sw $t1,($sp)
604#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
608#    move $s7,$zero # -4 offset header word
612#    lw $t4,8($sp) # bytes for hash value
616#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
620#    addu $t4,8
624#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
628#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

632#    li $t0,CLASS_String # store string vtable address into ...
636#    sw $t0,-12($s7) # ... -12 offset in object header
640#    lw $t2,-12($s2) # our object's vtable address
644#    lw $t5,4($sp) # number characters in prefix
648#    lw $t1,12($sp) # number of characters in hashcode
652#    addu $t3,$t1,$t5 # number of characters in string ...
656#    addu $t3,1 # ... including the '@' character
660#    subu $t0,$zero,$t3 # store negated length into ...
664#    sw $t0,-4($s7) # ... -4 offset header word
668#    lw $t0,-8($s7) # get -8 offset header-word
672#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
673##...slt $at,$t0,$zero
677##...beq $at,$zero,696
680#    and $t0,0xff # mask off object's hash value ...
681##...lui $at,0
685##...ori $at,$at,0xff
689##...and $t0,$t0,$at
692#    sw $t0,-8($s7) # ... and store back into -8 header-word
696:skipMask_toString:
696#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
700#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
704#    subu $t4,$t2,$t5
708:toString_copyLoop:    
708#    lb $t3,($t4)
712#    and $t3,0x7f # mask off sign bit (in case first word)
713##...lui $at,0
717##...ori $at,$at,0x7f
721##...and $t3,$t3,$at
724#    sb $t3,-8($t0)
728#    addu $t4,1
732#    addu $t0,1
736#    blt $t4,$t2,toString_copyLoop
737##...slt $at,$t4,$t2
741##...bne $at,$zero,708

    # copy the '@' sign
744#    li $t3,'@'
748#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
752#    addu $t2,$t0,$t1 # address of last byte in string to store +8
756#    lw $t3,20($sp) # hash code to print
760:toString_hashCopyLoop:
760#    and $t4,$t3,0xf
764#    srl $t3,4
768#    lb $t4,hexChars($t4)
772#    sb $t4,-8($t2)
776#    subu $t2,$t2,1
780#    bgt $t2,$t0,toString_hashCopyLoop
781##...slt $at,$t0,$t2
785##...bne $at,$zero,760

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
788#    addu $sp,28
792#    lw $ra,($sp)
796#    addu $sp,4
800#    move $t0, $s7 # return string we created
804#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
808:mth_equals_String:
    
    # quick test for obvious false
808#    lw $t0,($sp) # second parameter
812#    beq $t0,$zero,goEsFalse # go return false if null
816#    lw $t1,-12($t0) # vtable pointer
820#    la $t2,CLASS_String # string vtable pointer
824#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter

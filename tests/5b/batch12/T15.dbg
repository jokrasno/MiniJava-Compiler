1569##...slt $at,$t4,$zero
1573##...beq $at,$zero,1592
1576#    and $t4,0xff # mask off object's hash value ...
1577##...lui $at,0
1581##...ori $at,$at,0xff
1585##...and $t4,$t4,$at
1588#    sw $t4,-8($s7) # ... and store back into -8 header-word
1592:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1592#    lw $t1,8($sp) # k
1596#    lw $t2,16($sp) # n
1600#    subu $t0,$t2,$t1 # value to store

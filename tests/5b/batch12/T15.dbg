###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
892:mth_readLine_Lib:
    
892#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
896#    sw $ra, 4($sp) # save $ra
900#    move $t1,$sp # save "original" sp

904:  doRead:

    # read the character
904#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
908#    subu $t2,$v0,13
912#    bne $t2,$zero,notReturnRL
916#    jal readLogicalChar
920#    subu $t2,$v0,10 # check for newline
924#    beq $t2,$zero,foundNewLine
928#    sw $v0,lastCharRead # push back character into queue
932#    j foundNewLine # go process the line

936:  notReturnRL:

    # at this point, $v0 has our character

936#    subu $t0,$v0,10
940#    beq $t0,$zero,foundNewLine
944#    blt $v0,$zero,foundEof
945##...slt $at,$v0,$zero
949##...bne $at,$zero,964

    # we have a character, so push it onto stack
952#    subu $sp,$sp,4
956#    sw $v0,($sp)

    # loop back up to get next character
960#    j doRead

964:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
964#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
968#    li $s7, 0 # return-value: null
972#    j rlReturn # return

976:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
976#    subu $t0,$t1,$sp # number of chars we read (times 4)
980#    srl $s6,$t0,2 # number of words on stack with chars
984#    subu $sp,$sp,4 # push char-count ...
988#    sw $s6,($sp) # ... onto stack
992#    addu $t2,$t0,5 # GC tag, incl. for count-word
996#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1000#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1004#    srl $s6,$s6,2  # data words in object
1008#    move $s7,$zero # object words in object
1012#    jal newObject  # allocate space
    
    # store header words
1016#    la $t0,CLASS_String
1020#    sw $t0,-12($s7)# store class tag (String) into object
1024#    lw $t2,4($sp) # char-count
1028#    sll $t1,$t2,2 # 4 times number of chars
1032#    subu $t2,$zero,$t2 # negative of char-count
1036#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1040#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1044#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1045##...slt $at,$t0,$zero
1049##...beq $at,$zero,1068
1052#    and $t0,0xff # mask off object's hash value ...
1053##...lui $at,0
1057##...ori $at,$at,0xff
1061##...and $t0,$t0,$at
1064#    sw $t0,-8($s7) # ... and store back into -8 header-word
1068:  skipMask_readLine:

1068#    sll $t0,$t0,2 # data bytes in object
1072#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1076#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1080#    addu $sp,$sp,8 # pop redundant object-pointer and count
1084#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1088#    beq $sp,$t1,rlReturn
1092:  charCopyLoop:
1092#    lw $t2,($sp)
1096#    sb $t2,-9($t0)
1100#    addu $sp,$sp,4
1104#    subu $t0,$t0,1
1108#    bne $sp,$t1,charCopyLoop
1112:  rlReturn:

1112#    lw $ra, 4($sp)
1116#    addu $sp, 8   # pop $ra and pointless word off stack
1120#    move $t0, $s7 # return string we allocated in $s7
1124#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1128:mth_readInt_Lib:

    # save $ra by pushing onto stack
1128#    subu $sp,$sp,4
1132#    sw $ra,($sp)

1136:  riSkipWhiteLoop:
    # read a character
1136#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1140#    subu $t0,$v0,32
1144#    bgt $t0,$zero,nonWhite
1145##...slt $at,$zero,$t0
1149##...bne $at,$zero,1192
1152#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1156#    subu $t0,$v0,10
1160#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1164#    subu $t0,$v0,9
1168#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1172#    subu $t0,$v0,13
1176#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1180#    subu $t0,$v0,12
1184#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1188#    j badIntegerFormat # illegal integer char: abort program

1192:  nonWhite:
1192#    subu $t0,$v0,'-'
1196#    li $t4,1 # final multiplier
1200#    bne $t0,$zero,helpReadInt # go read
1204#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1208#    jal readLogicalChar

1212:  helpReadInt:
1212#    li $t2,10
1216#    subu $t1,$v0,'0' # convert digit to 0-9 value
1220#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1221##...sltu $at,$t1,$t2
1225##...beq $at,$zero,3472
1228#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1232:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1232#    jal readLogicalChar # read next character
1236#    subu $t1,$v0,'0' # convert digit to 0-9 value
1240#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1241##...sltu $at,$t1,$t2
1245##...beq $at,$zero,1264

1248#    mul $t3,$t3,$t2 # multiply old value by 10
1249##...mult $t3,$t2
1253##...mflo $t3
1256#    addu $t3,$t3,$t1 # add in value of new digit
1260#    j digitLoop

1264:  doneDigitLoop:

    # "push back" unused character into queue
1264#    sw $v0,lastCharRead

    # restore return address
1268#    lw $ra,($sp)
1272#    addu $sp, 4

    # multiply by sign and put return value in $t0
1276#    mult $t3,$t4 # multiply to account for poss. minus sign
1280#    mflo $t3
1284#    move $t0, $t3
    
    # return
1288#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer

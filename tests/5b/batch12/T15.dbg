856#    seq $t0,$t0,$zero
857##...subu $at,$t0,$zero
861##...sltiu $t0,$at,1

    # pop return address and return $t0
864#    lw $ra,($sp)
868#    addu $sp,4

872#    jr $ra # return
    
876:goEsFalse:
    # put 0 in $t0 and return
876#    li $t0, 0
880#    jr $ra # return

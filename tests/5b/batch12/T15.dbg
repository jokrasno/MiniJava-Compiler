    # because it's still in the string class.
828#    subu $sp,12
832#    sw $ra,8($sp)
836#    sw $s2,4($sp)
840#    sw $t0,($sp)
844#    jal mth_compareTo_String
848#    lw $s2, 4($sp) #restore this pointer and pop parameters
852#    addu $sp, 8 # pop parameters

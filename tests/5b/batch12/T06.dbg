##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
300:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
300#    lw $t0,-8($s2) # get word with hash bits from this
304#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
308#    addu $t0,$t1

312#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
316:mth_equals_Object:
316#    move $t0,$s2 # first pointer (this)
320#    lw $t1,($sp) # second pointer
324#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
325##...subu $at,$t0,$t1
329##...sltiu $t0,$at,1

332#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
336:mth_hashCode_String:
336#    move $t0,$s2 # put this pointer in t0

340#    li $t2,0 # current hash value
344#    lw $t1,-4($t0) # negative of number of characters in string
348#    beq $t1,$zero,done_hashCode_String # if zero length => done
352#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
356#    and $t0,0xfffffffc # adjust for padding
357##...lui $at,65535
361##...ori $at,$at,0xfffc
365##...and $t0,$t0,$at
368#    subu $t1,$t0,$t1 # address at end of string +12
372:loop_hashCode_String:    
372#    sll $t4,$t2,5 # multiply by 32
376#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
380#    lbu $t3,-12($t0) # current character
384#    addu $t2,$t3 # add in current character
388#    addu $t0,1 # go to next character's address
392#    bne $t0,$t1,loop_hashCode_String # loop back if more
396:done_hashCode_String:    

    # push int on stack
396#    move $t0, $t2 # put $t2 in return slot
400#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
404:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
404#    subu $sp,4
408#    sw $ra,($sp)
    
    # get hash value
412#    lw $t2,-12($s2) # vtable address
416#    lw $t0,($t2) # method address
420#    jalr $t0
424#    subu $sp,8 # push result (int in $t0) on stack
428#    sw $s5,4($sp)
432#    sw $t0,($sp)

    # compute print-size of hash value
436#    li $t0, 1
440#    lw $t1, ($sp)
444#    srl $t1,$t1,4
448#    beq $t1,$zero,toString_skip_loop
452:toString_loop_top:
452#    addu $t0,1
456#    srl $t1,$t1,4
460#    bne $t1,$zero,toString_loop_top
464:toString_skip_loop:
464#    subu $sp,8
468#    sw $s5,4($sp)
472#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
476#    lw $t2,-12($s2) # vtable address
480#    move $t0,$t2
484:toString_checkTagBit:
484#    subu $t0,1
488#    lb $t1,($t0)
492#    and $t1,0x80
493##...lui $at,0
497##...ori $at,$at,0x80
501##...and $t1,$t1,$at
504#    beq $t1,$zero,toString_checkTagBit
508#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
512#    subu $sp,8
516#    sw $t1,($sp)
520#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
524#    move $s7,$zero # -4 offset header word
528#    lw $t4,8($sp) # bytes for hash value
532#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
536#    addu $t4,8
540#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
544#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

548#    li $t0,CLASS_String # store string vtable address into ...
552#    sw $t0,-12($s7) # ... -12 offset in object header
556#    lw $t2,-12($s2) # our object's vtable address
560#    lw $t5,4($sp) # number characters in prefix
564#    lw $t1,12($sp) # number of characters in hashcode
568#    addu $t3,$t1,$t5 # number of characters in string ...
572#    addu $t3,1 # ... including the '@' character
576#    subu $t0,$zero,$t3 # store negated length into ...
580#    sw $t0,-4($s7) # ... -4 offset header word
584#    lw $t0,-8($s7) # get -8 offset header-word
588#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
589##...slt $at,$t0,$zero
593##...beq $at,$zero,612
596#    and $t0,0xff # mask off object's hash value ...
597##...lui $at,0
601##...ori $at,$at,0xff
605##...and $t0,$t0,$at
608#    sw $t0,-8($s7) # ... and store back into -8 header-word
612:skipMask_toString:
612#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
616#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
620#    subu $t4,$t2,$t5
624:toString_copyLoop:    
624#    lb $t3,($t4)
628#    and $t3,0x7f # mask off sign bit (in case first word)
629##...lui $at,0
633##...ori $at,$at,0x7f
637##...and $t3,$t3,$at
640#    sb $t3,-8($t0)
644#    addu $t4,1
648#    addu $t0,1
652#    blt $t4,$t2,toString_copyLoop
653##...slt $at,$t4,$t2
657##...bne $at,$zero,624

    # copy the '@' sign
660#    li $t3,'@'
664#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
668#    addu $t2,$t0,$t1 # address of last byte in string to store +8
672#    lw $t3,20($sp) # hash code to print
676:toString_hashCopyLoop:
676#    and $t4,$t3,0xf
680#    srl $t3,4
684#    lb $t4,hexChars($t4)
688#    sb $t4,-8($t2)
692#    subu $t2,$t2,1
696#    bgt $t2,$t0,toString_hashCopyLoop
697##...slt $at,$t0,$t2
701##...bne $at,$zero,676

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
704#    addu $sp,28
708#    lw $ra,($sp)
712#    addu $sp,4
716#    move $t0, $s7 # return string we created
720#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
724:mth_equals_String:
    
    # quick test for obvious false
724#    lw $t0,($sp) # second parameter
728#    beq $t0,$zero,goEsFalse # go return false if null
732#    lw $t1,-12($t0) # vtable pointer
736#    la $t2,CLASS_String # string vtable pointer
740#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
744#    subu $sp,12
748#    sw $ra,8($sp)
752#    sw $s2,4($sp)
756#    sw $t0,($sp)
760#    jal mth_compareTo_String
764#    lw $s2, 4($sp) #restore this pointer and pop parameters
768#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
772#    seq $t0,$t0,$zero
773##...subu $at,$t0,$zero

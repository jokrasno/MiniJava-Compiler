###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
808:mth_readLine_Lib:
    
808#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
812#    sw $ra, 4($sp) # save $ra
816#    move $t1,$sp # save "original" sp

820:  doRead:

    # read the character
820#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
824#    subu $t2,$v0,13
828#    bne $t2,$zero,notReturnRL
832#    jal readLogicalChar
836#    subu $t2,$v0,10 # check for newline
840#    beq $t2,$zero,foundNewLine
844#    sw $v0,lastCharRead # push back character into queue
848#    j foundNewLine # go process the line

852:  notReturnRL:

    # at this point, $v0 has our character

852#    subu $t0,$v0,10
856#    beq $t0,$zero,foundNewLine
860#    blt $v0,$zero,foundEof
861##...slt $at,$v0,$zero
865##...bne $at,$zero,880

    # we have a character, so push it onto stack
868#    subu $sp,$sp,4
872#    sw $v0,($sp)

    # loop back up to get next character
876#    j doRead

880:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
880#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
884#    li $s7, 0 # return-value: null
888#    j rlReturn # return

892:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
892#    subu $t0,$t1,$sp # number of chars we read (times 4)
896#    srl $s6,$t0,2 # number of words on stack with chars
900#    subu $sp,$sp,4 # push char-count ...
904#    sw $s6,($sp) # ... onto stack
908#    addu $t2,$t0,5 # GC tag, incl. for count-word
912#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
916#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
920#    srl $s6,$s6,2  # data words in object
924#    move $s7,$zero # object words in object
928#    jal newObject  # allocate space
    
    # store header words
932#    la $t0,CLASS_String
936#    sw $t0,-12($s7)# store class tag (String) into object
940#    lw $t2,4($sp) # char-count
944#    sll $t1,$t2,2 # 4 times number of chars
948#    subu $t2,$zero,$t2 # negative of char-count
952#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
956#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
960#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
961##...slt $at,$t0,$zero
965##...beq $at,$zero,984
968#    and $t0,0xff # mask off object's hash value ...
969##...lui $at,0
973##...ori $at,$at,0xff
977##...and $t0,$t0,$at
980#    sw $t0,-8($s7) # ... and store back into -8 header-word
984:  skipMask_readLine:

984#    sll $t0,$t0,2 # data bytes in object
988#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
992#    subu $t0,$t0,$t2 # place to store last character (plus 9)
996#    addu $sp,$sp,8 # pop redundant object-pointer and count
1000#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1004#    beq $sp,$t1,rlReturn
1008:  charCopyLoop:
1008#    lw $t2,($sp)
1012#    sb $t2,-9($t0)
1016#    addu $sp,$sp,4
1020#    subu $t0,$t0,1
1024#    bne $sp,$t1,charCopyLoop
1028:  rlReturn:

1028#    lw $ra, 4($sp)
1032#    addu $sp, 8   # pop $ra and pointless word off stack
1036#    move $t0, $s7 # return string we allocated in $s7
1040#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1044:mth_readInt_Lib:

    # save $ra by pushing onto stack
1044#    subu $sp,$sp,4
1048#    sw $ra,($sp)

1052:  riSkipWhiteLoop:
    # read a character
1052#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1056#    subu $t0,$v0,32
1060#    bgt $t0,$zero,nonWhite
1061##...slt $at,$zero,$t0
1065##...bne $at,$zero,1108
1068#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1072#    subu $t0,$v0,10
1076#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1080#    subu $t0,$v0,9
1084#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1088#    subu $t0,$v0,13
1092#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1096#    subu $t0,$v0,12
1100#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1104#    j badIntegerFormat # illegal integer char: abort program

1108:  nonWhite:
1108#    subu $t0,$v0,'-'
1112#    li $t4,1 # final multiplier
1116#    bne $t0,$zero,helpReadInt # go read
1120#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1124#    jal readLogicalChar

1128:  helpReadInt:
1128#    li $t2,10
1132#    subu $t1,$v0,'0' # convert digit to 0-9 value
1136#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1137##...sltu $at,$t1,$t2
1141##...beq $at,$zero,3388
1144#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1148:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1148#    jal readLogicalChar # read next character
1152#    subu $t1,$v0,'0' # convert digit to 0-9 value
1156#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1157##...sltu $at,$t1,$t2
1161##...beq $at,$zero,1180

1164#    mul $t3,$t3,$t2 # multiply old value by 10
1165##...mult $t3,$t2
1169##...mflo $t3
1172#    addu $t3,$t3,$t1 # add in value of new digit
1176#    j digitLoop

1180:  doneDigitLoop:

    # "push back" unused character into queue
1180#    sw $v0,lastCharRead

    # restore return address
1184#    lw $ra,($sp)
1188#    addu $sp, 4


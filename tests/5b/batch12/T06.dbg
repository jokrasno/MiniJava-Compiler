########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3152:vm_init:

    # mark bottom of stack
3152#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3156#    move $s2,$zero

    #set up the "five" register
3160#    li $s5,5

3164#    la $s3,seg0_start
3168#    la $s4,seg0_end
3169##...lui $s4,16
3173##...addiu $s4,$s4,4000
    
    # return
3176#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3180:divide:
    # get parameters; abort if divisor zero
3180#    lw $t0,($sp)
3184#    lw $t1,8($sp)
3188#    beq $t0,$zero,divByZeroError
    
    # perform division
3192#    div $t1,$t0
3196#    mflo $t0

    # store result, adjust stack and return
3200#    addu $sp,$sp,8 # adjust stack
3204#    sw $t0,($sp) # store result
3208#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3212:remainder:
    # get parameters; abort if divisor zero
3212#    lw $t0,($sp)
3216#    lw $t1,8($sp)
3220#    beq $t0,$zero,divByZeroError
    
    # perform division
3224#    div $t1,$t0
3228#    mfhi $t0

    # store result, adjust stack and return
3232#    addu $sp,$sp,8 # adjust stack
3236#    sw $t0,($sp) # store result
3240#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3244:checkCast:
    # get object, allow immediately if null
3244#    lw $t2,($sp)
3248#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3252#    lw $t2,-12($t2) # vtable address
3256#    bge $t2,$t1,castException
3257##...slt $at,$t2,$t1
3261##...beq $at,$zero,3396
3264#    blt $t2,$t0,castException
3265##...slt $at,$t2,$t0
3269##...bne $at,$zero,3396
    
    # return, leaving object unchanged on stack
3272:  checkCastReturn:    
3272#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3276:instanceOf:
    # get object, go return false if null
3276#    lw $t2,($sp)
3280#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3284#    lw $t2,-12($t2) # vtable address
3288#    sge $t0,$t2,$t0 # are we >= the lower limit?
3289##...slt $t0,$t2,$t0
3293##...xori $t0,$t0,0x1
3296#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3300#    and $t2,$t0,$t1
3304#    sw $t2,($sp)
3308:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3308#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3312:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3312#    li $v0,4 # syscall-code for print-string
3316#    syscall
3320:exit:
    # print termination message
3320#    li $v0,4 # syscall-code for print-string
3324#    la $a0,exitString
3328#    syscall

    # terminate execution
3332#    li $v0,10 #syscall-code for "exit"
3336#    syscall

3340:outOfHeapMemory:
3340#    la $a0,heapMemoryMsg
3344#    j exitError
3348:divByZeroError:
3348#    la $a0,divByZeroMsg
3352#    j exitError
3356:strIndexOutOfBounds:
3356#    la $a0,strIndexOutOfBoundsMsg
3360#    j exitError
3364:arrayIndexOutOfBounds:
3364#    la $a0,arrayIndexOutOfBoundsMsg
3368#    j exitError
3372:arraySizeOutOfBounds:
3372#    la $a0,arraySizeOutOfBoundsMsg
3376#    j exitError
3380:nullPtrException:
3380#    la $a0,nullPtrExceptionMsg
3384#    j exitError
3388:badIntegerFormat:
3388#    la $a0,badIntegerFormatMsg
3392#    j exitError
3396:castException:
3396#    la $a0,castExceptionMsg
3400#    j exitError
############## data section ################
    .data
3636:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3652:cur_seg:
    .word 0

3656:lastCharRead:
    .word -2 # -2 => no buffered character
3660:prevHashConstant:
    .word 0x2785173c
3664:gcCount:
    .word 0

3668:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3695:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3718:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3753:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3787:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3820:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3851:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3899:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3920:gcMsg: 
      .asciiz "\nGC!\n"
3926:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3958:nullStr:
    .asciiz "null"
3963:trueString:
    .asciiz "true"
3968:falseString:
    .asciiz "false"
3974:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3993:newlineString:
    .asciiz "\n"
    
    .align 2
3996:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4000:seg0_start:
    .space 0x100000
1052576:seg0_end:
1052576:seg1_start:
    .space 0x100000
2101152:seg1_end:

########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
1468:mth_substring_String:

    # save $ra by pushing onto stack
1468#    subu $sp,$sp,4
1472#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
1476#    move $t0,$s2
1480#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
1484#    lw $t0,-4($t0) # negative of string length
1488#    subu $t0,$zero,$t0 # string length
1492#    lw $t1,4($sp) # k
1496#    lw $t2,12($sp) # n
1500#    bgt $zero,$t2,strIndexOutOfBounds
1501##...slt $at,$t2,$zero
1505##...bne $at,$zero,3428
1508#    bgt $t2,$t1,strIndexOutOfBounds
1509##...slt $at,$t1,$t2
1513##...bne $at,$zero,3428
1516#    bgt $t1,$t0,strIndexOutOfBounds
1517##...slt $at,$t0,$t1
1521##...bne $at,$zero,3428

    # allocate memory
1524#    subu $s6,$t1,$t2 # # chars in target-string
1528#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1532#    srl $s6,$s6,2 # convert bytes-count to word-count
1536#    move $s7,$zero # (no object-bytes in string)
1540#    jal newObject

    # store "String" tag in object-type field
1544#    la $t0,CLASS_String
1548#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
1552#    lw $t4,-8($s7) # data words in source string
1556#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
1557##...slt $at,$t4,$zero
1561##...beq $at,$zero,1580
1564#    and $t4,0xff # mask off object's hash value ...
1565##...lui $at,0
1569##...ori $at,$at,0xff
1573##...and $t4,$t4,$at
1576#    sw $t4,-8($s7) # ... and store back into -8 header-word
1580:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1580#    lw $t1,8($sp) # k
1584#    lw $t2,16($sp) # n
1588#    subu $t0,$t2,$t1 # value to store
1592#    sw $t0,-4($s7) # store value
    
1596#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
1600#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
1604#    lw $t4,-8($t3) # data words in source string
1608#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
1612#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
1616#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
1620#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
1624#    lw $t2,-8($s7)   # data words in target string
1628#    sll $t2,$t2,2    # data bytes in target string
1632#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target
1636:  subCopyLoopzz:
1636#    lb $t4,-8($t3)
1640#    sb $t4,-8($t2)
1644#    addu $t2,$t2,1
1648#    addu $t3,$t3,1
1652#    blt $t3,$t1,subCopyLoopzz
1653##...slt $at,$t3,$t1
1657##...bne $at,$zero,1636
    
1660:  doneSubCopyzz:
    # restore return address, store return value, pop stack
1660#    lw $ra,4($sp) # restore $ra
1664#    addu $sp,$sp,8 # pop ra, and allocated newObject
1668#    move $t0, $s7 # we're returning the string we got back
                  # from newObject
    
    # return
1672#    jr $ra

########################################################
# length() - library method (class String)
# returns length of a string: Java: str.length()
# - parameters:
#   - ($sp) - old this pointer
# - return-value:
#   - $t0 - length of string
########################################################
1676:mth_length_String:

    # the length is the negative of 4($s2)
1676#    lw $t0,-4($s2) # -length
1680#    subu $t0,$zero,$t0

    # return
1684#    jr $ra


########################################################
# str1.concat(str2) - library method (class String)
# (as in Java)
# - parameters:
#   - ($sp) - the second string
#   - 4($sp) - old this pointer
#   - $s2 - the first string (this)
# - returns:
#   - $t0 - pointer to concatenated string
########################################################
1688:mth_concat_String:
    # save $ra by pushing onto stack
1688#    subu $sp,$sp,4
1692#    sw $ra, ($sp)

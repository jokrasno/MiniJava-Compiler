##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
372:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
372#    lw $t0,-8($s2) # get word with hash bits from this
376#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
380#    addu $t0,$t1

384#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
388:mth_equals_Object:
388#    move $t0,$s2 # first pointer (this)
392#    lw $t1,($sp) # second pointer
396#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
397##...subu $at,$t0,$t1
401##...sltiu $t0,$at,1

404#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
408:mth_hashCode_String:
408#    move $t0,$s2 # put this pointer in t0

412#    li $t2,0 # current hash value
416#    lw $t1,-4($t0) # negative of number of characters in string
420#    beq $t1,$zero,done_hashCode_String # if zero length => done
424#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
428#    and $t0,0xfffffffc # adjust for padding
429##...lui $at,65535
433##...ori $at,$at,0xfffc
437##...and $t0,$t0,$at
440#    subu $t1,$t0,$t1 # address at end of string +12
444:loop_hashCode_String:    
444#    sll $t4,$t2,5 # multiply by 32
448#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
452#    lbu $t3,-12($t0) # current character
456#    addu $t2,$t3 # add in current character
460#    addu $t0,1 # go to next character's address
464#    bne $t0,$t1,loop_hashCode_String # loop back if more
468:done_hashCode_String:    

    # push int on stack
468#    move $t0, $t2 # put $t2 in return slot
472#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
476:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
476#    subu $sp,4
480#    sw $ra,($sp)
    
    # get hash value
484#    lw $t2,-12($s2) # vtable address
488#    lw $t0,($t2) # method address
492#    jalr $t0
496#    subu $sp,8 # push result (int in $t0) on stack
500#    sw $s5,4($sp)
504#    sw $t0,($sp)

    # compute print-size of hash value
508#    li $t0, 1
512#    lw $t1, ($sp)
516#    srl $t1,$t1,4
520#    beq $t1,$zero,toString_skip_loop
524:toString_loop_top:
524#    addu $t0,1
528#    srl $t1,$t1,4
532#    bne $t1,$zero,toString_loop_top
536:toString_skip_loop:
536#    subu $sp,8
540#    sw $s5,4($sp)
544#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
548#    lw $t2,-12($s2) # vtable address
552#    move $t0,$t2
556:toString_checkTagBit:
556#    subu $t0,1
560#    lb $t1,($t0)
564#    and $t1,0x80
565##...lui $at,0
569##...ori $at,$at,0x80
573##...and $t1,$t1,$at
576#    beq $t1,$zero,toString_checkTagBit
580#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
584#    subu $sp,8
588#    sw $t1,($sp)
592#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
596#    move $s7,$zero # -4 offset header word
600#    lw $t4,8($sp) # bytes for hash value
604#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
608#    addu $t4,8
612#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
616#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

620#    li $t0,CLASS_String # store string vtable address into ...
624#    sw $t0,-12($s7) # ... -12 offset in object header
628#    lw $t2,-12($s2) # our object's vtable address
632#    lw $t5,4($sp) # number characters in prefix
636#    lw $t1,12($sp) # number of characters in hashcode
640#    addu $t3,$t1,$t5 # number of characters in string ...
644#    addu $t3,1 # ... including the '@' character
648#    subu $t0,$zero,$t3 # store negated length into ...
652#    sw $t0,-4($s7) # ... -4 offset header word
656#    lw $t0,-8($s7) # get -8 offset header-word
660#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
661##...slt $at,$t0,$zero
665##...beq $at,$zero,684
668#    and $t0,0xff # mask off object's hash value ...
669##...lui $at,0
673##...ori $at,$at,0xff
677##...and $t0,$t0,$at
680#    sw $t0,-8($s7) # ... and store back into -8 header-word
684:skipMask_toString:
684#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
688#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
692#    subu $t4,$t2,$t5
696:toString_copyLoop:    
696#    lb $t3,($t4)
700#    and $t3,0x7f # mask off sign bit (in case first word)
701##...lui $at,0
705##...ori $at,$at,0x7f
709##...and $t3,$t3,$at
712#    sb $t3,-8($t0)
716#    addu $t4,1
720#    addu $t0,1
724#    blt $t4,$t2,toString_copyLoop
725##...slt $at,$t4,$t2
729##...bne $at,$zero,696

    # copy the '@' sign
732#    li $t3,'@'
736#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
740#    addu $t2,$t0,$t1 # address of last byte in string to store +8
744#    lw $t3,20($sp) # hash code to print
748:toString_hashCopyLoop:
748#    and $t4,$t3,0xf
752#    srl $t3,4
756#    lb $t4,hexChars($t4)
760#    sb $t4,-8($t2)
764#    subu $t2,$t2,1
768#    bgt $t2,$t0,toString_hashCopyLoop
769##...slt $at,$t0,$t2
773##...bne $at,$zero,748

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
776#    addu $sp,28
780#    lw $ra,($sp)
784#    addu $sp,4
788#    move $t0, $s7 # return string we created
792#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
796:mth_equals_String:
    
    # quick test for obvious false
796#    lw $t0,($sp) # second parameter
800#    beq $t0,$zero,goEsFalse # go return false if null
804#    lw $t1,-12($t0) # vtable pointer
808#    la $t2,CLASS_String # string vtable pointer
812#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
816#    subu $sp,12
820#    sw $ra,8($sp)
824#    sw $s2,4($sp)
828#    sw $t0,($sp)
832#    jal mth_compareTo_String
836#    lw $s2, 4($sp) #restore this pointer and pop parameters
840#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
844#    seq $t0,$t0,$zero
845##...subu $at,$t0,$zero
849##...sltiu $t0,$at,1

    # pop return address and return $t0
852#    lw $ra,($sp)
856#    addu $sp,4

860#    jr $ra # return
    
864:goEsFalse:
    # put 0 in $t0 and return
864#    li $t0, 0
868#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
872:mth_toString_String:
    #we are a string, so return this.
872#    move $t0, $s2
876#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
880:mth_readLine_Lib:
    
880#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
884#    sw $ra, 4($sp) # save $ra
888#    move $t1,$sp # save "original" sp

892:  doRead:

    # read the character
892#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
896#    subu $t2,$v0,13
900#    bne $t2,$zero,notReturnRL
904#    jal readLogicalChar
908#    subu $t2,$v0,10 # check for newline
912#    beq $t2,$zero,foundNewLine
916#    sw $v0,lastCharRead # push back character into queue
920#    j foundNewLine # go process the line

924:  notReturnRL:

    # at this point, $v0 has our character

924#    subu $t0,$v0,10
928#    beq $t0,$zero,foundNewLine
932#    blt $v0,$zero,foundEof
933##...slt $at,$v0,$zero
937##...bne $at,$zero,952

    # we have a character, so push it onto stack
940#    subu $sp,$sp,4
944#    sw $v0,($sp)

    # loop back up to get next character
948#    j doRead

952:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
952#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
956#    li $s7, 0 # return-value: null
960#    j rlReturn # return

964:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
964#    subu $t0,$t1,$sp # number of chars we read (times 4)
968#    srl $s6,$t0,2 # number of words on stack with chars
972#    subu $sp,$sp,4 # push char-count ...
976#    sw $s6,($sp) # ... onto stack
980#    addu $t2,$t0,5 # GC tag, incl. for count-word
984#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
988#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
992#    srl $s6,$s6,2  # data words in object
996#    move $s7,$zero # object words in object
1000#    jal newObject  # allocate space
    
    # store header words
1004#    la $t0,CLASS_String
1008#    sw $t0,-12($s7)# store class tag (String) into object
1012#    lw $t2,4($sp) # char-count
1016#    sll $t1,$t2,2 # 4 times number of chars
1020#    subu $t2,$zero,$t2 # negative of char-count
1024#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1028#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1032#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1033##...slt $at,$t0,$zero
1037##...beq $at,$zero,1056
1040#    and $t0,0xff # mask off object's hash value ...
1041##...lui $at,0
1045##...ori $at,$at,0xff
1049##...and $t0,$t0,$at
1052#    sw $t0,-8($s7) # ... and store back into -8 header-word
1056:  skipMask_readLine:

1056#    sll $t0,$t0,2 # data bytes in object
1060#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1064#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1068#    addu $sp,$sp,8 # pop redundant object-pointer and count
1072#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1076#    beq $sp,$t1,rlReturn
1080:  charCopyLoop:
1080#    lw $t2,($sp)
1084#    sb $t2,-9($t0)
1088#    addu $sp,$sp,4
1092#    subu $t0,$t0,1
1096#    bne $sp,$t1,charCopyLoop
1100:  rlReturn:

1100#    lw $ra, 4($sp)
1104#    addu $sp, 8   # pop $ra and pointless word off stack
1108#    move $t0, $s7 # return string we allocated in $s7
1112#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1116:mth_readInt_Lib:

    # save $ra by pushing onto stack
1116#    subu $sp,$sp,4
1120#    sw $ra,($sp)

1124:  riSkipWhiteLoop:
    # read a character
1124#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1128#    subu $t0,$v0,32
1132#    bgt $t0,$zero,nonWhite
1133##...slt $at,$zero,$t0
1137##...bne $at,$zero,1180
1140#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1144#    subu $t0,$v0,10
1148#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1152#    subu $t0,$v0,9
1156#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1160#    subu $t0,$v0,13
1164#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1168#    subu $t0,$v0,12
1172#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1176#    j badIntegerFormat # illegal integer char: abort program

1180:  nonWhite:
1180#    subu $t0,$v0,'-'
1184#    li $t4,1 # final multiplier
1188#    bne $t0,$zero,helpReadInt # go read
1192#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1196#    jal readLogicalChar

1200:  helpReadInt:
1200#    li $t2,10
1204#    subu $t1,$v0,'0' # convert digit to 0-9 value
1208#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1209##...sltu $at,$t1,$t2
1213##...beq $at,$zero,3460
1216#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1220:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1220#    jal readLogicalChar # read next character
1224#    subu $t1,$v0,'0' # convert digit to 0-9 value
1228#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1229##...sltu $at,$t1,$t2
1233##...beq $at,$zero,1252

1236#    mul $t3,$t3,$t2 # multiply old value by 10
1237##...mult $t3,$t2
1241##...mflo $t3
1244#    addu $t3,$t3,$t1 # add in value of new digit
1248#    j digitLoop

1252:  doneDigitLoop:

    # "push back" unused character into queue
1252#    sw $v0,lastCharRead

    # restore return address
1256#    lw $ra,($sp)
1260#    addu $sp, 4

    # multiply by sign and put return value in $t0
1264#    mult $t3,$t4 # multiply to account for poss. minus sign
1268#    mflo $t3
1272#    move $t0, $t3
    
    # return
1276#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1280:mth_readChar_Lib:

    # save $ra by pushing onto stack
1280#    subu $sp,$sp,4
1284#    sw $ra,($sp)

      # read the character
1288#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1292#    lw $ra,($sp)
1296#    addu $sp, 4
1300#    move $t0, $v0

    # return
1304#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
1308:mth_printStr_Lib:
    # check for null, printing "(null)", if so
1308#    lw $t0,($sp)
1312#    bne $t0,$zero,psNotNull

    # print "(null)"
1316#    la $a0,nullStr
1320#    li $v0,4
1324#    syscall
1328#    j donePrintStr
    
1332:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
1332#    subu $t0,$t0,8
1336#    lw $t1,($t0) # number of data words, but needs modification
1340#    blt $t1,$zero,skipPrintStr1
1341##...slt $at,$t1,$zero
1345##...bne $at,$zero,1364
1348#    and $t1,0xff # mask out all but low byte
1349##...lui $at,0
1353##...ori $at,$at,0xff
1357##...and $t1,$t1,$at
1360#    b skipPrintStr2
1364:skipPrintStr1:
1364#    and $t1,0x7ffffff
1365##...lui $at,2047
1369##...ori $at,$at,0xffff
1373##...and $t1,$t1,$at
1376:skipPrintStr2:    
1376#    sll $t1,$t1,2
1380#    subu $t1,$t0,$t1 # first word in string
1384#    lw $t0,4($t0) # negative of string-length
1388#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
1392#    beq $t0,$t1,donePrintStr
1396:  psLoop:
1396#    lb $a0,($t1) # next byte
1400#    li $v0,11 # code for printing char
1404#        syscall # print the char
1408#    addu $t1,$t1,1 # go to next char
1412#    blt $t1,$t0,psLoop
1413##...slt $at,$t1,$t0
1417##...bne $at,$zero,1396

1420:  donePrintStr:
1420#    jr $ra

########################################################
# printInt(n) - library method (class Lib)
# - prints integer in decimal format to standard output
# - parameters:
#   - ($sp) - the integer to print
#   - 4($sp) - GC tag
#   - ($sp) - old-this-pointer
########################################################
1424:mth_printInt_Lib:
1424#    lw $a0,($sp)

    # print it
1428#    li $v0,1 # code for print-int
1432#    syscall

    # return
1436#    jr $ra

########################################################
# printBool(n) - library method (class Lib)
# - prints boolean to standard output
# - parameters:
#   - ($sp) - the boolean to print
#   - 4($sp) - old-this-pointer
########################################################
1440:mth_printBool_Lib:
    # pop value off stack, along with 'this'
1440#    lw $t0,($sp)

    # print either 'true' or 'false', depending on the value
1444#    la $a0,falseString
1448#    beq $t0,$zero,skipPB
1452#    la $a0,trueString
1456:  skipPB:
1456#    li $v0,4 # code for print-string
1460#    syscall

    # return
1464#    jr $ra

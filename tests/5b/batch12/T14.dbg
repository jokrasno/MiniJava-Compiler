########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3224:vm_init:

    # mark bottom of stack
3224#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3228#    move $s2,$zero

    #set up the "five" register
3232#    li $s5,5

3236#    la $s3,seg0_start
3240#    la $s4,seg0_end
3241##...lui $s4,16
3245##...addiu $s4,$s4,4096
    
    # return
3248#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3252:divide:
    # get parameters; abort if divisor zero
3252#    lw $t0,($sp)
3256#    lw $t1,8($sp)
3260#    beq $t0,$zero,divByZeroError
    
    # perform division
3264#    div $t1,$t0
3268#    mflo $t0

    # store result, adjust stack and return
3272#    addu $sp,$sp,8 # adjust stack
3276#    sw $t0,($sp) # store result
3280#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3284:remainder:
    # get parameters; abort if divisor zero
3284#    lw $t0,($sp)
3288#    lw $t1,8($sp)
3292#    beq $t0,$zero,divByZeroError
    
    # perform division
3296#    div $t1,$t0
3300#    mfhi $t0

    # store result, adjust stack and return
3304#    addu $sp,$sp,8 # adjust stack
3308#    sw $t0,($sp) # store result
3312#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3316:checkCast:
    # get object, allow immediately if null
3316#    lw $t2,($sp)
3320#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3324#    lw $t2,-12($t2) # vtable address
3328#    bge $t2,$t1,castException
3329##...slt $at,$t2,$t1
3333##...beq $at,$zero,3468
3336#    blt $t2,$t0,castException
3337##...slt $at,$t2,$t0
3341##...bne $at,$zero,3468
    
    # return, leaving object unchanged on stack
3344:  checkCastReturn:    
3344#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3348:instanceOf:
    # get object, go return false if null
3348#    lw $t2,($sp)
3352#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3356#    lw $t2,-12($t2) # vtable address
3360#    sge $t0,$t2,$t0 # are we >= the lower limit?
3361##...slt $t0,$t2,$t0
3365##...xori $t0,$t0,0x1
3368#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3372#    and $t2,$t0,$t1
3376#    sw $t2,($sp)
3380:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3380#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3384:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3384#    li $v0,4 # syscall-code for print-string
3388#    syscall
3392:exit:
    # print termination message
3392#    li $v0,4 # syscall-code for print-string
3396#    la $a0,exitString
3400#    syscall

    # terminate execution
3404#    li $v0,10 #syscall-code for "exit"
3408#    syscall

3412:outOfHeapMemory:
3412#    la $a0,heapMemoryMsg
3416#    j exitError
3420:divByZeroError:
3420#    la $a0,divByZeroMsg
3424#    j exitError
3428:strIndexOutOfBounds:
3428#    la $a0,strIndexOutOfBoundsMsg
3432#    j exitError
3436:arrayIndexOutOfBounds:
3436#    la $a0,arrayIndexOutOfBoundsMsg
3440#    j exitError
3444:arraySizeOutOfBounds:
3444#    la $a0,arraySizeOutOfBoundsMsg
3448#    j exitError
3452:nullPtrException:
3452#    la $a0,nullPtrExceptionMsg
3456#    j exitError
3460:badIntegerFormat:
3460#    la $a0,badIntegerFormatMsg
3464#    j exitError
3468:castException:
3468#    la $a0,castExceptionMsg
3472#    j exitError
############## data section ################
    .data
3732:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3748:cur_seg:
    .word 0

3752:lastCharRead:
    .word -2 # -2 => no buffered character
3756:prevHashConstant:
    .word 0x2785173c
3760:gcCount:
    .word 0

3764:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3791:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3814:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3849:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3883:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3916:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3947:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3995:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4016:gcMsg: 
      .asciiz "\nGC!\n"
4022:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4054:nullStr:
    .asciiz "null"
4059:trueString:
    .asciiz "true"
4064:falseString:
    .asciiz "false"
4070:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4089:newlineString:
    .asciiz "\n"
    
    .align 2
4092:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4096:seg0_start:
    .space 0x100000
1052672:seg0_end:
1052672:seg1_start:
    .space 0x100000
2101248:seg1_end:

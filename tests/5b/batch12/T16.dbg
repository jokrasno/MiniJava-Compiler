###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
760:mth_readLine_Lib:
    
760#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
764#    sw $ra, 4($sp) # save $ra
768#    move $t1,$sp # save "original" sp

772:  doRead:

    # read the character
772#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
776#    subu $t2,$v0,13
780#    bne $t2,$zero,notReturnRL
784#    jal readLogicalChar
788#    subu $t2,$v0,10 # check for newline
792#    beq $t2,$zero,foundNewLine
796#    sw $v0,lastCharRead # push back character into queue
800#    j foundNewLine # go process the line

804:  notReturnRL:

    # at this point, $v0 has our character

804#    subu $t0,$v0,10
808#    beq $t0,$zero,foundNewLine
812#    blt $v0,$zero,foundEof
813##...slt $at,$v0,$zero
817##...bne $at,$zero,832

    # we have a character, so push it onto stack
820#    subu $sp,$sp,4
824#    sw $v0,($sp)

    # loop back up to get next character
828#    j doRead

832:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
832#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
836#    li $s7, 0 # return-value: null
840#    j rlReturn # return

844:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
844#    subu $t0,$t1,$sp # number of chars we read (times 4)
848#    srl $s6,$t0,2 # number of words on stack with chars
852#    subu $sp,$sp,4 # push char-count ...
856#    sw $s6,($sp) # ... onto stack
860#    addu $t2,$t0,5 # GC tag, incl. for count-word
864#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
868#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
872#    srl $s6,$s6,2  # data words in object
876#    move $s7,$zero # object words in object
880#    jal newObject  # allocate space
    
    # store header words
884#    la $t0,CLASS_String
888#    sw $t0,-12($s7)# store class tag (String) into object
892#    lw $t2,4($sp) # char-count
896#    sll $t1,$t2,2 # 4 times number of chars
900#    subu $t2,$zero,$t2 # negative of char-count
904#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
908#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
912#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
913##...slt $at,$t0,$zero
917##...beq $at,$zero,936
920#    and $t0,0xff # mask off object's hash value ...
921##...lui $at,0
925##...ori $at,$at,0xff
929##...and $t0,$t0,$at
932#    sw $t0,-8($s7) # ... and store back into -8 header-word
936:  skipMask_readLine:

936#    sll $t0,$t0,2 # data bytes in object
940#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
944#    subu $t0,$t0,$t2 # place to store last character (plus 9)
948#    addu $sp,$sp,8 # pop redundant object-pointer and count
952#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

956#    beq $sp,$t1,rlReturn
960:  charCopyLoop:
960#    lw $t2,($sp)
964#    sb $t2,-9($t0)
968#    addu $sp,$sp,4
972#    subu $t0,$t0,1
976#    bne $sp,$t1,charCopyLoop
980:  rlReturn:

980#    lw $ra, 4($sp)
984#    addu $sp, 8   # pop $ra and pointless word off stack
988#    move $t0, $s7 # return string we allocated in $s7
992#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
996:mth_readInt_Lib:

    # save $ra by pushing onto stack
996#    subu $sp,$sp,4
1000#    sw $ra,($sp)

1004:  riSkipWhiteLoop:
    # read a character
1004#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1008#    subu $t0,$v0,32
1012#    bgt $t0,$zero,nonWhite
1013##...slt $at,$zero,$t0
1017##...bne $at,$zero,1060
1020#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1024#    subu $t0,$v0,10
1028#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1032#    subu $t0,$v0,9
1036#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1040#    subu $t0,$v0,13
1044#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1048#    subu $t0,$v0,12
1052#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1056#    j badIntegerFormat # illegal integer char: abort program

1060:  nonWhite:
1060#    subu $t0,$v0,'-'
1064#    li $t4,1 # final multiplier
1068#    bne $t0,$zero,helpReadInt # go read
1072#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1076#    jal readLogicalChar

1080:  helpReadInt:
1080#    li $t2,10
1084#    subu $t1,$v0,'0' # convert digit to 0-9 value
1088#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1089##...sltu $at,$t1,$t2
1093##...beq $at,$zero,3340
1096#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1100:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1100#    jal readLogicalChar # read next character
1104#    subu $t1,$v0,'0' # convert digit to 0-9 value
1108#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1109##...sltu $at,$t1,$t2
1113##...beq $at,$zero,1132

1116#    mul $t3,$t3,$t2 # multiply old value by 10
1117##...mult $t3,$t2
1121##...mflo $t3
1124#    addu $t3,$t3,$t1 # add in value of new digit
1128#    j digitLoop

1132:  doneDigitLoop:

    # "push back" unused character into queue
1132#    sw $v0,lastCharRead

    # restore return address
1136#    lw $ra,($sp)
1140#    addu $sp, 4

    # multiply by sign and put return value in $t0
1144#    mult $t3,$t4 # multiply to account for poss. minus sign
1148#    mflo $t3
1152#    move $t0, $t3
    
    # return
1156#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1160:mth_readChar_Lib:

    # save $ra by pushing onto stack
1160#    subu $sp,$sp,4
1164#    sw $ra,($sp)

      # read the character
1168#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1172#    lw $ra,($sp)
1176#    addu $sp, 4
1180#    move $t0, $v0

    # return
1184#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
1188:mth_printStr_Lib:
    # check for null, printing "(null)", if so
1188#    lw $t0,($sp)
1192#    bne $t0,$zero,psNotNull

    # print "(null)"
1196#    la $a0,nullStr
1200#    li $v0,4
1204#    syscall
1208#    j donePrintStr
    
1212:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
1212#    subu $t0,$t0,8
1216#    lw $t1,($t0) # number of data words, but needs modification
1220#    blt $t1,$zero,skipPrintStr1
1221##...slt $at,$t1,$zero
1225##...bne $at,$zero,1244
1228#    and $t1,0xff # mask out all but low byte
1229##...lui $at,0
1233##...ori $at,$at,0xff
1237##...and $t1,$t1,$at
1240#    b skipPrintStr2
1244:skipPrintStr1:
1244#    and $t1,0x7ffffff
1245##...lui $at,2047
1249##...ori $at,$at,0xffff
1253##...and $t1,$t1,$at
1256:skipPrintStr2:    
1256#    sll $t1,$t1,2
1260#    subu $t1,$t0,$t1 # first word in string
1264#    lw $t0,4($t0) # negative of string-length
1268#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
1272#    beq $t0,$t1,donePrintStr
1276:  psLoop:
1276#    lb $a0,($t1) # next byte
1280#    li $v0,11 # code for printing char
1284#        syscall # print the char
1288#    addu $t1,$t1,1 # go to next char
1292#    blt $t1,$t0,psLoop
1293##...slt $at,$t1,$t0
1297##...bne $at,$zero,1276

1300:  donePrintStr:
1300#    jr $ra

2533##...addiu $s4,$s4,3964
2536#    sw $zero,cur_seg
2540#    bne $t0,$zero,skipGc1
2544#    la $t6,seg0_start
2548#    la $s3,seg1_start
2549##...lui $s3,16
2553##...addiu $s3,$s3,3964

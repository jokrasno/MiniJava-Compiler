##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
252:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
252#    lw $t0,-8($s2) # get word with hash bits from this
256#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
260#    addu $t0,$t1

264#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
268:mth_equals_Object:
268#    move $t0,$s2 # first pointer (this)
272#    lw $t1,($sp) # second pointer
276#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
277##...subu $at,$t0,$t1
281##...sltiu $t0,$at,1

284#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
288:mth_hashCode_String:
288#    move $t0,$s2 # put this pointer in t0

292#    li $t2,0 # current hash value
296#    lw $t1,-4($t0) # negative of number of characters in string
300#    beq $t1,$zero,done_hashCode_String # if zero length => done
304#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
308#    and $t0,0xfffffffc # adjust for padding
309##...lui $at,65535
313##...ori $at,$at,0xfffc
317##...and $t0,$t0,$at
320#    subu $t1,$t0,$t1 # address at end of string +12
324:loop_hashCode_String:    
324#    sll $t4,$t2,5 # multiply by 32
328#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
332#    lbu $t3,-12($t0) # current character
336#    addu $t2,$t3 # add in current character
340#    addu $t0,1 # go to next character's address
344#    bne $t0,$t1,loop_hashCode_String # loop back if more
348:done_hashCode_String:    

    # push int on stack
348#    move $t0, $t2 # put $t2 in return slot
352#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
356:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
356#    subu $sp,4
360#    sw $ra,($sp)
    
    # get hash value
364#    lw $t2,-12($s2) # vtable address
368#    lw $t0,($t2) # method address
372#    jalr $t0
376#    subu $sp,8 # push result (int in $t0) on stack
380#    sw $s5,4($sp)
384#    sw $t0,($sp)

    # compute print-size of hash value
388#    li $t0, 1
392#    lw $t1, ($sp)
396#    srl $t1,$t1,4
400#    beq $t1,$zero,toString_skip_loop
404:toString_loop_top:
404#    addu $t0,1
408#    srl $t1,$t1,4
412#    bne $t1,$zero,toString_loop_top
416:toString_skip_loop:
416#    subu $sp,8
420#    sw $s5,4($sp)
424#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
428#    lw $t2,-12($s2) # vtable address
432#    move $t0,$t2
436:toString_checkTagBit:
436#    subu $t0,1
440#    lb $t1,($t0)
444#    and $t1,0x80
445##...lui $at,0
449##...ori $at,$at,0x80
453##...and $t1,$t1,$at
456#    beq $t1,$zero,toString_checkTagBit
460#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
464#    subu $sp,8
468#    sw $t1,($sp)
472#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
476#    move $s7,$zero # -4 offset header word
480#    lw $t4,8($sp) # bytes for hash value
484#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
488#    addu $t4,8
492#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
496#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

500#    li $t0,CLASS_String # store string vtable address into ...
504#    sw $t0,-12($s7) # ... -12 offset in object header
508#    lw $t2,-12($s2) # our object's vtable address
512#    lw $t5,4($sp) # number characters in prefix
516#    lw $t1,12($sp) # number of characters in hashcode
520#    addu $t3,$t1,$t5 # number of characters in string ...
524#    addu $t3,1 # ... including the '@' character
528#    subu $t0,$zero,$t3 # store negated length into ...
532#    sw $t0,-4($s7) # ... -4 offset header word
536#    lw $t0,-8($s7) # get -8 offset header-word
540#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
541##...slt $at,$t0,$zero
545##...beq $at,$zero,564
548#    and $t0,0xff # mask off object's hash value ...
549##...lui $at,0
553##...ori $at,$at,0xff
557##...and $t0,$t0,$at
560#    sw $t0,-8($s7) # ... and store back into -8 header-word
564:skipMask_toString:
564#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
568#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
572#    subu $t4,$t2,$t5
576:toString_copyLoop:    
576#    lb $t3,($t4)
580#    and $t3,0x7f # mask off sign bit (in case first word)
581##...lui $at,0
585##...ori $at,$at,0x7f
589##...and $t3,$t3,$at
592#    sb $t3,-8($t0)
596#    addu $t4,1
600#    addu $t0,1
604#    blt $t4,$t2,toString_copyLoop
605##...slt $at,$t4,$t2
609##...bne $at,$zero,576

    # copy the '@' sign
612#    li $t3,'@'
616#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
620#    addu $t2,$t0,$t1 # address of last byte in string to store +8
624#    lw $t3,20($sp) # hash code to print
628:toString_hashCopyLoop:
628#    and $t4,$t3,0xf
632#    srl $t3,4
636#    lb $t4,hexChars($t4)
640#    sb $t4,-8($t2)
644#    subu $t2,$t2,1
648#    bgt $t2,$t0,toString_hashCopyLoop
649##...slt $at,$t0,$t2
653##...bne $at,$zero,628

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
656#    addu $sp,28
660#    lw $ra,($sp)
664#    addu $sp,4
668#    move $t0, $s7 # return string we created
672#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
676:mth_equals_String:
    
    # quick test for obvious false
676#    lw $t0,($sp) # second parameter
680#    beq $t0,$zero,goEsFalse # go return false if null
684#    lw $t1,-12($t0) # vtable pointer
688#    la $t2,CLASS_String # string vtable pointer
692#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
696#    subu $sp,12
700#    sw $ra,8($sp)
704#    sw $s2,4($sp)
708#    sw $t0,($sp)
712#    jal mth_compareTo_String
716#    lw $s2, 4($sp) #restore this pointer and pop parameters
720#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
724#    seq $t0,$t0,$zero
725##...subu $at,$t0,$zero
729##...sltiu $t0,$at,1

    # pop return address and return $t0
732#    lw $ra,($sp)
736#    addu $sp,4

740#    jr $ra # return
    

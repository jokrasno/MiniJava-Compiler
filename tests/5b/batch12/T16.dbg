    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
1588#    lw $t0,-4($t0) # negative size of second object
1592#    lw $t1,-4($t1) # negative size of first object
1596#    addu $s6,$t0,$t1 # sum of negative sizes
1600#    sra $s6,$s6,2 # negative word-size of char part
1604#    subu $s6,$zero,$s6 # word size of char part
1608#    addu $s6,$s6,1 # data word size, including v-table word
1612#    move $s7,$zero
1616#    jal newObject

    # store String vtable address in vtable address field
1620#    la $t0,CLASS_String
1624#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
1628#    lw $t4,-8($s7) # # data words in source string
1632#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
1633##...slt $at,$t4,$zero
1637##...beq $at,$zero,1656
1640#    and $t4,0xff # mask off object's hash value ...
1641##...lui $at,0
1645##...ori $at,$at,0xff
1649##...and $t4,$t4,$at
1652#    sw $t4,-8($s7) # ... and store back into -8 header-word
1656:skipMask_concat:


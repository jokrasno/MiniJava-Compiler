########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3104:vm_init:

    # mark bottom of stack
3104#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3108#    move $s2,$zero

    #set up the "five" register
3112#    li $s5,5

3116#    la $s3,seg0_start
3120#    la $s4,seg0_end
3121##...lui $s4,16
3125##...addiu $s4,$s4,3964
    
    # return
3128#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3132:divide:
    # get parameters; abort if divisor zero
3132#    lw $t0,($sp)
3136#    lw $t1,8($sp)
3140#    beq $t0,$zero,divByZeroError
    
    # perform division
3144#    div $t1,$t0
3148#    mflo $t0

    # store result, adjust stack and return
3152#    addu $sp,$sp,8 # adjust stack
3156#    sw $t0,($sp) # store result
3160#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3164:remainder:
    # get parameters; abort if divisor zero
3164#    lw $t0,($sp)
3168#    lw $t1,8($sp)
3172#    beq $t0,$zero,divByZeroError
    
    # perform division
3176#    div $t1,$t0
3180#    mfhi $t0

    # store result, adjust stack and return
3184#    addu $sp,$sp,8 # adjust stack
3188#    sw $t0,($sp) # store result
3192#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3196:checkCast:
    # get object, allow immediately if null
3196#    lw $t2,($sp)
3200#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3204#    lw $t2,-12($t2) # vtable address
3208#    bge $t2,$t1,castException
3209##...slt $at,$t2,$t1
3213##...beq $at,$zero,3348
3216#    blt $t2,$t0,castException
3217##...slt $at,$t2,$t0
3221##...bne $at,$zero,3348
    
    # return, leaving object unchanged on stack
3224:  checkCastReturn:    
3224#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3228:instanceOf:
    # get object, go return false if null
3228#    lw $t2,($sp)
3232#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3236#    lw $t2,-12($t2) # vtable address
3240#    sge $t0,$t2,$t0 # are we >= the lower limit?
3241##...slt $t0,$t2,$t0
3245##...xori $t0,$t0,0x1
3248#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3252#    and $t2,$t0,$t1
3256#    sw $t2,($sp)
3260:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3260#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3264:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3264#    li $v0,4 # syscall-code for print-string
3268#    syscall
3272:exit:
    # print termination message
3272#    li $v0,4 # syscall-code for print-string
3276#    la $a0,exitString
3280#    syscall

    # terminate execution
3284#    li $v0,10 #syscall-code for "exit"
3288#    syscall

3292:outOfHeapMemory:
3292#    la $a0,heapMemoryMsg
3296#    j exitError
3300:divByZeroError:
3300#    la $a0,divByZeroMsg
3304#    j exitError
3308:strIndexOutOfBounds:
3308#    la $a0,strIndexOutOfBoundsMsg
3312#    j exitError
3316:arrayIndexOutOfBounds:
3316#    la $a0,arrayIndexOutOfBoundsMsg
3320#    j exitError
3324:arraySizeOutOfBounds:
3324#    la $a0,arraySizeOutOfBoundsMsg
3328#    j exitError
3332:nullPtrException:
3332#    la $a0,nullPtrExceptionMsg
3336#    j exitError
3340:badIntegerFormat:
3340#    la $a0,badIntegerFormatMsg
3344#    j exitError
3348:castException:
3348#    la $a0,castExceptionMsg
3352#    j exitError
############## data section ################
    .data
3600:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3616:cur_seg:
    .word 0

3620:lastCharRead:
    .word -2 # -2 => no buffered character
3624:prevHashConstant:
    .word 0x2785173c
3628:gcCount:
    .word 0

3632:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3659:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3682:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3717:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3751:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3784:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3815:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3863:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3884:gcMsg: 
      .asciiz "\nGC!\n"
3890:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3922:nullStr:
    .asciiz "null"
3927:trueString:
    .asciiz "true"
3932:falseString:
    .asciiz "false"
3938:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3957:newlineString:
    .asciiz "\n"
    
    .align 2
3960:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3964:seg0_start:
    .space 0x100000
1052540:seg0_end:
1052540:seg1_start:
    .space 0x100000
2101116:seg1_end:

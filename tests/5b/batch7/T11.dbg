    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1480#    jal readLogicalChar # read next character
1484#    subu $t1,$v0,'0' # convert digit to 0-9 value
1488#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1489##...sltu $at,$t1,$t2
1493##...beq $at,$zero,1512

1496#    mul $t3,$t3,$t2 # multiply old value by 10
1497##...mult $t3,$t2
1501##...mflo $t3
1504#    addu $t3,$t3,$t1 # add in value of new digit

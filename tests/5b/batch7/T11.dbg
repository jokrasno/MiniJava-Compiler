1104#    seq $t0,$t0,$zero
1105##...subu $at,$t0,$zero
1109##...sltiu $t0,$at,1

    # pop return address and return $t0
1112#    lw $ra,($sp)
1116#    addu $sp,4

1120#    jr $ra # return
    
1124:goEsFalse:
    # put 0 in $t0 and return
1124#    li $t0, 0
1128#    jr $ra # return

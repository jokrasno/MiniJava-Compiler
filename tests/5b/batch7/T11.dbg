1336#    beq $sp,$t1,rlReturn
1340:  charCopyLoop:
1340#    lw $t2,($sp)
1344#    sb $t2,-9($t0)
1348#    addu $sp,$sp,4
1352#    subu $t0,$t0,1
1356#    bne $sp,$t1,charCopyLoop
1360:  rlReturn:

1360#    lw $ra, 4($sp)
1364#    addu $sp, 8   # pop $ra and pointless word off stack
1368#    move $t0, $s7 # return string we allocated in $s7
1372#    jr $ra

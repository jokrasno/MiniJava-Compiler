2532:  skipMask_intToChar:

    # store data in string
2532#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
2536#    li $t0,-1
2540#    sw $t0,-4($s7)

    # we're returning $s7
2544#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
2548#    lw $ra,4($sp)
2552#    addu $sp,$sp,8

    # return
2556#    jr $ra

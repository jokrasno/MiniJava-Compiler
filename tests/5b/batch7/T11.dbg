1404#    subu $t0,$v0,10
1408#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1412#    subu $t0,$v0,9
1416#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1420#    subu $t0,$v0,13
1424#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1428#    subu $t0,$v0,12
1432#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1436#    j badIntegerFormat # illegal integer char: abort program

1440:  nonWhite:
1440#    subu $t0,$v0,'-'
1444#    li $t4,1 # final multiplier
1448#    bne $t0,$zero,helpReadInt # go read
1452#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'

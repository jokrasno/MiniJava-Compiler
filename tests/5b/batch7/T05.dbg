3032#    addu $t1,0x12b68fd2
3033##...lui $at,4791
3037##...addiu $at,$at,-28718
3041##...addu $t1,$at,$t1
3044#    sw $t1,prevHashConstant # update hash constant
3048#    or $t1,0x80000000 # set top bit
3049##...lui $at,32768
3053##...or $t1,$at,$t1
3056#    and $t1,0xffffff00 # clear low bit
3057##...lui $at,65535
3061##...ori $at,$at,0xff00
3065##...and $t1,$t1,$at
3068#    or $s6,$t1
3072:firstHeaderLarge:
3072#    sw $s6,-8($t0) # store header-1 value
3076#    lw $zero,-8($t0)

    # store second header-value
3080#    sw $s7,-4($t0)   # second header-word
3084#    lw $zero,-4($t0)

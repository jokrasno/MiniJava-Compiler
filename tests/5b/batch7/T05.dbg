1344#    seq $t0,$t0,$zero
1345##...subu $at,$t0,$zero
1349##...sltiu $t0,$at,1

    # pop return address and return $t0
1352#    lw $ra,($sp)
1356#    addu $sp,4

1360#    jr $ra # return
    
1364:goEsFalse:
    # put 0 in $t0 and return
1364#    li $t0, 0
1368#    jr $ra # return

3148#    la $s4,seg0_end
3149##...lui $s4,16
3153##...addiu $s4,$s4,4560
3156#    sw $zero,cur_seg
3160#    bne $t0,$zero,skipGc1
3164#    la $t6,seg0_start
3168#    la $s3,seg1_start
3169##...lui $s3,16
3173##...addiu $s3,$s3,4560
3176#    la $s4,seg1_end
3177##...lui $s4,32
3181##...addiu $s4,$s4,4560
3184#    sw $s5,cur_seg

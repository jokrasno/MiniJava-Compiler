3940#    j exitError
3944:arraySizeOutOfBounds:
3944#    la $a0,arraySizeOutOfBoundsMsg
3948#    j exitError
3952:nullPtrException:
3952#    la $a0,nullPtrExceptionMsg
3956#    j exitError
3960:badIntegerFormat:
3960#    la $a0,badIntegerFormatMsg
3964#    j exitError
3968:castException:
3968#    la $a0,castExceptionMsg
3972#    j exitError
############## data section ################
    .data
4196:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4212:cur_seg:
    .word 0

4216:lastCharRead:
    .word -2 # -2 => no buffered character
4220:prevHashConstant:
    .word 0x2785173c
4224:gcCount:
    .word 0

4228:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4255:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4278:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4313:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4347:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4380:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4411:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4459:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4480:gcMsg: 
      .asciiz "\nGC!\n"
4486:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4518:nullStr:
    .asciiz "null"
4523:trueString:
    .asciiz "true"
4528:falseString:
    .asciiz "false"

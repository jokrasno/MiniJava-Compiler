1161##...slt $at,$t0,$zero
1165##...beq $at,$zero,1184
1168#    and $t0,0xff # mask off object's hash value ...
1169##...lui $at,0
1173##...ori $at,$at,0xff
1177##...and $t0,$t0,$at
1180#    sw $t0,-8($s7) # ... and store back into -8 header-word
1184:skipMask_toString:
1184#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1188#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1192#    subu $t4,$t2,$t5
1196:toString_copyLoop:    
1196#    lb $t3,($t4)
1200#    and $t3,0x7f # mask off sign bit (in case first word)
1201##...lui $at,0
1205##...ori $at,$at,0x7f
1209##...and $t3,$t3,$at
1212#    sb $t3,-8($t0)

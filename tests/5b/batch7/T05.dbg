1644#    subu $t0,$v0,10
1648#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1652#    subu $t0,$v0,9
1656#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1660#    subu $t0,$v0,13
1664#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1668#    subu $t0,$v0,12

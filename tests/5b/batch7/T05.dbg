3584#    and $t8,0xff # mask off hash bits
3585##...lui $at,0
3589##...ori $at,$at,0xff
3593##...and $t8,$t8,$at

3596:  gcSkip5:
3596#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3600#    addu $t8,$t8,8 # ... add in bytes for header-words
3604#    subu $t4,$t1,$t8 # address of first word of source object
3608#    lw $t3,-4($t1) # # words in positive-offset portion
3612#    bge $t3,$zero,gcNoNeg
3613##...slt $at,$t3,$zero
3617##...beq $at,$zero,3624
3620#    move $t3,$zero # negative treated as zero
3624:  gcNoNeg:
3624#    sll $t3,$t3,2 # bytes in negative-offset portion
3628#    addu $t3,$t3,$t1 # address one word past last word of source

3632#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3636#    lw $s0,($t4)
3640#    lw $t9,-8($t1)
3644#    sw $t9,($t4)
3648#    sw $s0,-8($t1)

    # copy all source bytes to the target
3652:  gCinnerCopy2:
3652#    lw $s0,($t4)
3656#    sw $s0,($s3)
3660#    addu $t4,$t4,4
3664#    addu $s3,$s3,4
3668#    bltu $t4,$t3,gCinnerCopy2
3669##...sltu $at,$t4,$t3
3673##...bne $at,$zero,3652

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3676#    sw $zero,-8($t1) # 0 in first header-slot
3680#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3684#    sw $t8,($t0)

3688:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3688#    addu $t0,$t0,4
3692#    bltu $t0,$s1,gcNextPointerInObject
3693##...sltu $at,$t0,$s1
3697##...bne $at,$zero,3536

3700:  gcTestIterDone2:
3700#    bltu $t0,$s3,gcHeapCopyLoop
3701##...sltu $at,$t0,$s3
3705##...bne $at,$zero,3420

    ###### end outer loop to copy all non-stack-direct objects ######

3708:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3708#    lw $s2,($sp)
3712#    addu $sp,$sp,4

    # mark us as having already GC'd
3716#    move $t5,$s5

    # go try and allocate again
3720#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3724:vm_init:

    # mark bottom of stack
3724#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3728#    move $s2,$zero

    #set up the "five" register
3732#    li $s5,5

3736#    la $s3,seg0_start
3740#    la $s4,seg0_end
3741##...lui $s4,16
3745##...addiu $s4,$s4,4560
    
    # return
3748#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3752:divide:
    # get parameters; abort if divisor zero
3752#    lw $t0,($sp)
3756#    lw $t1,8($sp)
3760#    beq $t0,$zero,divByZeroError
    
    # perform division
3764#    div $t1,$t0
3768#    mflo $t0

    # store result, adjust stack and return
3772#    addu $sp,$sp,8 # adjust stack
3776#    sw $t0,($sp) # store result
3780#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3784:remainder:
    # get parameters; abort if divisor zero
3784#    lw $t0,($sp)
3788#    lw $t1,8($sp)
3792#    beq $t0,$zero,divByZeroError
    
    # perform division
3796#    div $t1,$t0
3800#    mfhi $t0

    # store result, adjust stack and return
3804#    addu $sp,$sp,8 # adjust stack
3808#    sw $t0,($sp) # store result
3812#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3816:checkCast:
    # get object, allow immediately if null
3816#    lw $t2,($sp)
3820#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3824#    lw $t2,-12($t2) # vtable address
3828#    bge $t2,$t1,castException
3829##...slt $at,$t2,$t1
3833##...beq $at,$zero,3968
3836#    blt $t2,$t0,castException
3837##...slt $at,$t2,$t0
3841##...bne $at,$zero,3968
    
    # return, leaving object unchanged on stack
3844:  checkCastReturn:    
3844#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3848:instanceOf:
    # get object, go return false if null
3848#    lw $t2,($sp)
3852#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3856#    lw $t2,-12($t2) # vtable address
3860#    sge $t0,$t2,$t0 # are we >= the lower limit?
3861##...slt $t0,$t2,$t0
3865##...xori $t0,$t0,0x1
3868#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3872#    and $t2,$t0,$t1
3876#    sw $t2,($sp)
3880:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3880#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3884:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3884#    li $v0,4 # syscall-code for print-string
3888#    syscall
3892:exit:
    # print termination message
3892#    li $v0,4 # syscall-code for print-string
3896#    la $a0,exitString
3900#    syscall

    # terminate execution
3904#    li $v0,10 #syscall-code for "exit"
3908#    syscall

3912:outOfHeapMemory:
3912#    la $a0,heapMemoryMsg
3916#    j exitError
3920:divByZeroError:
3920#    la $a0,divByZeroMsg
3924#    j exitError
3928:strIndexOutOfBounds:
3928#    la $a0,strIndexOutOfBoundsMsg
3932#    j exitError
3936:arrayIndexOutOfBounds:

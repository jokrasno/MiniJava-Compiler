########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
2916:readLogicalChar:

    # check if we already have a character
2916#    lw $v0,lastCharRead
2920#    li $t0,-2
2924#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
2928#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2932#    jr $ra # return
    
2936:  doReadCh:
    # we need to actually read a character: read and return
2936#    li $v0,12 # use system call to read a character
2940#    syscall
2944#    jr $ra # return

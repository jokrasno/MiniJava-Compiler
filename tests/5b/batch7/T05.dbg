
    # determine if we have enough memory available
2960#    addu $t0,$s6,$s7
2964#    sll $t0,$t0,2
2968#    addu $t0,$t0,8 # amount of memory needed
2972#    addu $t1,$t0,$s3
2976#    bgtu $t1,$s4,doGC
2977##...sltu $at,$s4,$t1
2981##...bne $at,$zero,3104

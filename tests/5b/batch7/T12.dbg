##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1316:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1316#    lw $t0,-8($s2) # get word with hash bits from this
1320#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1324#    addu $t0,$t1

1328#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1332:mth_equals_Object:
1332#    move $t0,$s2 # first pointer (this)
1336#    lw $t1,($sp) # second pointer
1340#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1341##...subu $at,$t0,$t1
1345##...sltiu $t0,$at,1

1348#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1352:mth_hashCode_String:
1352#    move $t0,$s2 # put this pointer in t0

1356#    li $t2,0 # current hash value
1360#    lw $t1,-4($t0) # negative of number of characters in string
1364#    beq $t1,$zero,done_hashCode_String # if zero length => done
1368#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1372#    and $t0,0xfffffffc # adjust for padding
1373##...lui $at,65535
1377##...ori $at,$at,0xfffc
1381##...and $t0,$t0,$at
1384#    subu $t1,$t0,$t1 # address at end of string +12
1388:loop_hashCode_String:    
1388#    sll $t4,$t2,5 # multiply by 32
1392#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1396#    lbu $t3,-12($t0) # current character
1400#    addu $t2,$t3 # add in current character
1404#    addu $t0,1 # go to next character's address
1408#    bne $t0,$t1,loop_hashCode_String # loop back if more
1412:done_hashCode_String:    

    # push int on stack
1412#    move $t0, $t2 # put $t2 in return slot
1416#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1420:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1420#    subu $sp,4
1424#    sw $ra,($sp)
    
    # get hash value
1428#    lw $t2,-12($s2) # vtable address
1432#    lw $t0,($t2) # method address
1436#    jalr $t0
1440#    subu $sp,8 # push result (int in $t0) on stack
1444#    sw $s5,4($sp)
1448#    sw $t0,($sp)

    # compute print-size of hash value
1452#    li $t0, 1
1456#    lw $t1, ($sp)
1460#    srl $t1,$t1,4
1464#    beq $t1,$zero,toString_skip_loop
1468:toString_loop_top:
1468#    addu $t0,1
1472#    srl $t1,$t1,4
1476#    bne $t1,$zero,toString_loop_top
1480:toString_skip_loop:
1480#    subu $sp,8
1484#    sw $s5,4($sp)
1488#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1492#    lw $t2,-12($s2) # vtable address
1496#    move $t0,$t2
1500:toString_checkTagBit:
1500#    subu $t0,1
1504#    lb $t1,($t0)
1508#    and $t1,0x80
1509##...lui $at,0
1513##...ori $at,$at,0x80
1517##...and $t1,$t1,$at
1520#    beq $t1,$zero,toString_checkTagBit
1524#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1528#    subu $sp,8
1532#    sw $t1,($sp)
1536#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1540#    move $s7,$zero # -4 offset header word
1544#    lw $t4,8($sp) # bytes for hash value
1548#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1552#    addu $t4,8
1556#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1560#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1564#    li $t0,CLASS_String # store string vtable address into ...
1568#    sw $t0,-12($s7) # ... -12 offset in object header
1572#    lw $t2,-12($s2) # our object's vtable address
1576#    lw $t5,4($sp) # number characters in prefix
1580#    lw $t1,12($sp) # number of characters in hashcode
1584#    addu $t3,$t1,$t5 # number of characters in string ...
1588#    addu $t3,1 # ... including the '@' character
1592#    subu $t0,$zero,$t3 # store negated length into ...
1596#    sw $t0,-4($s7) # ... -4 offset header word
1600#    lw $t0,-8($s7) # get -8 offset header-word
1604#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1605##...slt $at,$t0,$zero
1609##...beq $at,$zero,1628
1612#    and $t0,0xff # mask off object's hash value ...
1613##...lui $at,0
1617##...ori $at,$at,0xff
1621##...and $t0,$t0,$at
1624#    sw $t0,-8($s7) # ... and store back into -8 header-word
1628:skipMask_toString:
1628#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1632#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1636#    subu $t4,$t2,$t5
1640:toString_copyLoop:    
1640#    lb $t3,($t4)
1644#    and $t3,0x7f # mask off sign bit (in case first word)
1645##...lui $at,0
1649##...ori $at,$at,0x7f
1653##...and $t3,$t3,$at
1656#    sb $t3,-8($t0)
1660#    addu $t4,1
1664#    addu $t0,1
1668#    blt $t4,$t2,toString_copyLoop
1669##...slt $at,$t4,$t2
1673##...bne $at,$zero,1640

    # copy the '@' sign
1676#    li $t3,'@'
1680#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1684#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1688#    lw $t3,20($sp) # hash code to print
1692:toString_hashCopyLoop:
1692#    and $t4,$t3,0xf
1696#    srl $t3,4
1700#    lb $t4,hexChars($t4)
1704#    sb $t4,-8($t2)
1708#    subu $t2,$t2,1
1712#    bgt $t2,$t0,toString_hashCopyLoop
1713##...slt $at,$t0,$t2
1717##...bne $at,$zero,1692

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1720#    addu $sp,28
1724#    lw $ra,($sp)
1728#    addu $sp,4
1732#    move $t0, $s7 # return string we created
1736#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1740:mth_equals_String:
    
    # quick test for obvious false
1740#    lw $t0,($sp) # second parameter
1744#    beq $t0,$zero,goEsFalse # go return false if null
1748#    lw $t1,-12($t0) # vtable pointer
1752#    la $t2,CLASS_String # string vtable pointer
1756#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1760#    subu $sp,12
1764#    sw $ra,8($sp)
1768#    sw $s2,4($sp)
1772#    sw $t0,($sp)
1776#    jal mth_compareTo_String
1780#    lw $s2, 4($sp) #restore this pointer and pop parameters
1784#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1788#    seq $t0,$t0,$zero
1789##...subu $at,$t0,$zero
1793##...sltiu $t0,$at,1

    # pop return address and return $t0
1796#    lw $ra,($sp)
1800#    addu $sp,4

1804#    jr $ra # return
    
1808:goEsFalse:
    # put 0 in $t0 and return
1808#    li $t0, 0
1812#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1816:mth_toString_String:
    #we are a string, so return this.
1816#    move $t0, $s2
1820#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1824:mth_readLine_Lib:
    
1824#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1828#    sw $ra, 4($sp) # save $ra
1832#    move $t1,$sp # save "original" sp

1836:  doRead:

    # read the character
1836#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1840#    subu $t2,$v0,13
1844#    bne $t2,$zero,notReturnRL
1848#    jal readLogicalChar
1852#    subu $t2,$v0,10 # check for newline
1856#    beq $t2,$zero,foundNewLine
1860#    sw $v0,lastCharRead # push back character into queue
1864#    j foundNewLine # go process the line

1868:  notReturnRL:

    # at this point, $v0 has our character

1868#    subu $t0,$v0,10
1872#    beq $t0,$zero,foundNewLine
1876#    blt $v0,$zero,foundEof
1877##...slt $at,$v0,$zero
1881##...bne $at,$zero,1896

    # we have a character, so push it onto stack
1884#    subu $sp,$sp,4
1888#    sw $v0,($sp)

    # loop back up to get next character
1892#    j doRead

1896:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1896#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1900#    li $s7, 0 # return-value: null
1904#    j rlReturn # return

1908:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1908#    subu $t0,$t1,$sp # number of chars we read (times 4)
1912#    srl $s6,$t0,2 # number of words on stack with chars
1916#    subu $sp,$sp,4 # push char-count ...
1920#    sw $s6,($sp) # ... onto stack
1924#    addu $t2,$t0,5 # GC tag, incl. for count-word
1928#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1932#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1936#    srl $s6,$s6,2  # data words in object
1940#    move $s7,$zero # object words in object
1944#    jal newObject  # allocate space
    
    # store header words
1948#    la $t0,CLASS_String
1952#    sw $t0,-12($s7)# store class tag (String) into object
1956#    lw $t2,4($sp) # char-count
1960#    sll $t1,$t2,2 # 4 times number of chars
1964#    subu $t2,$zero,$t2 # negative of char-count
1968#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1972#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1976#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1977##...slt $at,$t0,$zero
1981##...beq $at,$zero,2000
1984#    and $t0,0xff # mask off object's hash value ...
1985##...lui $at,0
1989##...ori $at,$at,0xff
1993##...and $t0,$t0,$at
1996#    sw $t0,-8($s7) # ... and store back into -8 header-word
2000:  skipMask_readLine:

2000#    sll $t0,$t0,2 # data bytes in object
2004#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2008#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2012#    addu $sp,$sp,8 # pop redundant object-pointer and count
2016#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2020#    beq $sp,$t1,rlReturn
2024:  charCopyLoop:
2024#    lw $t2,($sp)
2028#    sb $t2,-9($t0)
2032#    addu $sp,$sp,4
2036#    subu $t0,$t0,1
2040#    bne $sp,$t1,charCopyLoop
2044:  rlReturn:

2044#    lw $ra, 4($sp)
2048#    addu $sp, 8   # pop $ra and pointless word off stack
2052#    move $t0, $s7 # return string we allocated in $s7
2056#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2060:mth_readInt_Lib:

    # save $ra by pushing onto stack
2060#    subu $sp,$sp,4
2064#    sw $ra,($sp)

2068:  riSkipWhiteLoop:
    # read a character
2068#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2072#    subu $t0,$v0,32
2076#    bgt $t0,$zero,nonWhite
2077##...slt $at,$zero,$t0
2081##...bne $at,$zero,2124
2084#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2088#    subu $t0,$v0,10
2092#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2096#    subu $t0,$v0,9
2100#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2104#    subu $t0,$v0,13
2108#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2112#    subu $t0,$v0,12
2116#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2120#    j badIntegerFormat # illegal integer char: abort program

2124:  nonWhite:
2124#    subu $t0,$v0,'-'
2128#    li $t4,1 # final multiplier
2132#    bne $t0,$zero,helpReadInt # go read
2136#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2140#    jal readLogicalChar

2144:  helpReadInt:
2144#    li $t2,10
2148#    subu $t1,$v0,'0' # convert digit to 0-9 value
2152#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2153##...sltu $at,$t1,$t2
2157##...beq $at,$zero,4404
2160#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2164:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2164#    jal readLogicalChar # read next character
2168#    subu $t1,$v0,'0' # convert digit to 0-9 value
2172#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2173##...sltu $at,$t1,$t2
2177##...beq $at,$zero,2196

2180#    mul $t3,$t3,$t2 # multiply old value by 10
2181##...mult $t3,$t2
2185##...mflo $t3
2188#    addu $t3,$t3,$t1 # add in value of new digit
2192#    j digitLoop

2196:  doneDigitLoop:

    # "push back" unused character into queue
2196#    sw $v0,lastCharRead

    # restore return address
2200#    lw $ra,($sp)
2204#    addu $sp, 4

    # multiply by sign and put return value in $t0


    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
3836#    lw $t1,cur_seg
3840#    la $t0,seg0_start
3844#    beq $t1,$zero,gcSkip4
3848#    la $t0,seg1_start
3849##...lui $t0,16
3853##...addiu $t0,$t0,5060


3856:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
3856#    bgeu $t0,$s3,gcFinishUp
3857##...sltu $at,$t0,$s3
3861##...beq $at,$zero,4152

    ###### begin outer loop to copy all non-stack-direct objects ######

3864:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
3864#    lw $t1,($t0) # (what will be) first header word for current object
3868#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
3872#    bge $t2,$zero,gcSkip4a # are there hash bits?
3873##...slt $at,$t2,$zero
3877##...beq $at,$zero,3892
3880#    and $t2,0xff # mask off hash bits
3881##...lui $at,0
3885##...ori $at,$at,0xff
3889##...and $t2,$t2,$at
3892:gcSkip4a:    
3892#    sll $t2,$t2,2 # # data bytes
3896#    addu $t2,$t2,8 # to skip header words
3900#    addu $t2,$t0,$t2 # pointer to new object
3904#    lw $t3,-8($t2) # word to swap
3908#    sw $t1,-8($t2) # store header word
3912#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3916#    lw $t1,-12($t2) # vtable pointer
3920#    li $t0,dataArrayVTableStart # address of vtable for first data array
3924#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3925##...slt $at,$t1,$t0
3929##...bne $at,$zero,3948

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3932:  skipToNextObj:
3932#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3936#    sll $t1,$t1,2 # convert to byte-count
3940#    addu $t0,$t2,$t1 # skip over object
3944#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3948:  gcNotDataArray:
3948#    lw $t3,-4($t2) # # object words (negative treated as zero)
3952#    bge $t3,$zero,gcH2Neg2
3953##...slt $at,$t3,$zero
3957##...beq $at,$zero,3964
3960#    move $t3,$zero
3964:  gcH2Neg2:
3964#    sll $t3,$t3,2 # # object bytes
3968#    move $t0,$t2 # address of first pointer in object
3972#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3976#    beq $t0,$s1,gcTestIterDone2
    
3980:  gcNextPointerInObject:
    # get pointer from object
3980#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3984#    bleu $t1,$t6,gcGoNextPointerSlot
3985##...sltu $at,$t6,$t1
3989##...beq $at,$zero,4132
3992#    bgtu $t1,$t7,gcGoNextPointerSlot
3993##...sltu $at,$t7,$t1
3997##...bne $at,$zero,4132

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4000#    lw $t8,-8($t1) # possible forwarding tag
4004#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
4008#    lw $t8,-4($t1) # forwarding pointer: object's new address
4012#    sw $t8,($t0) # update pointer in object
4016#    j gcGoNextPointerSlot # do next iteration

4020:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
4020#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
4021##...slt $at,$t8,$zero
4025##...beq $at,$zero,4040
4028#    and $t8,0xff # mask off hash bits
4029##...lui $at,0
4033##...ori $at,$at,0xff
4037##...and $t8,$t8,$at

4040:  gcSkip5:
4040#    sll $t8,$t8,2 # bytes in negative-offset portion ...
4044#    addu $t8,$t8,8 # ... add in bytes for header-words
4048#    subu $t4,$t1,$t8 # address of first word of source object
4052#    lw $t3,-4($t1) # # words in positive-offset portion
4056#    bge $t3,$zero,gcNoNeg
4057##...slt $at,$t3,$zero
4061##...beq $at,$zero,4068
4064#    move $t3,$zero # negative treated as zero
4068:  gcNoNeg:
4068#    sll $t3,$t3,2 # bytes in negative-offset portion
4072#    addu $t3,$t3,$t1 # address one word past last word of source

4076#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4080#    lw $s0,($t4)
4084#    lw $t9,-8($t1)
4088#    sw $t9,($t4)
4092#    sw $s0,-8($t1)

    # copy all source bytes to the target
4096:  gCinnerCopy2:
4096#    lw $s0,($t4)
4100#    sw $s0,($s3)
4104#    addu $t4,$t4,4
4108#    addu $s3,$s3,4
4112#    bltu $t4,$t3,gCinnerCopy2
4113##...sltu $at,$t4,$t3
4117##...bne $at,$zero,4096

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4120#    sw $zero,-8($t1) # 0 in first header-slot
4124#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4128#    sw $t8,($t0)

4132:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4132#    addu $t0,$t0,4
4136#    bltu $t0,$s1,gcNextPointerInObject
4137##...sltu $at,$t0,$s1
4141##...bne $at,$zero,3980

4144:  gcTestIterDone2:
4144#    bltu $t0,$s3,gcHeapCopyLoop
4145##...sltu $at,$t0,$s3
4149##...bne $at,$zero,3864

    ###### end outer loop to copy all non-stack-direct objects ######

4152:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4152#    lw $s2,($sp)
4156#    addu $sp,$sp,4

    # mark us as having already GC'd
4160#    move $t5,$s5

    # go try and allocate again
4164#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4168:vm_init:

    # mark bottom of stack
4168#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4172#    move $s2,$zero

    #set up the "five" register
4176#    li $s5,5

4180#    la $s3,seg0_start
4184#    la $s4,seg0_end
4185##...lui $s4,16
4189##...addiu $s4,$s4,5060
    
    # return
4192#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4196:divide:
    # get parameters; abort if divisor zero
4196#    lw $t0,($sp)
4200#    lw $t1,8($sp)
4204#    beq $t0,$zero,divByZeroError
    
    # perform division
4208#    div $t1,$t0
4212#    mflo $t0

    # store result, adjust stack and return
4216#    addu $sp,$sp,8 # adjust stack
4220#    sw $t0,($sp) # store result
4224#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4228:remainder:
    # get parameters; abort if divisor zero
4228#    lw $t0,($sp)
4232#    lw $t1,8($sp)
4236#    beq $t0,$zero,divByZeroError
    
    # perform division
4240#    div $t1,$t0
4244#    mfhi $t0

    # store result, adjust stack and return
4248#    addu $sp,$sp,8 # adjust stack
4252#    sw $t0,($sp) # store result
4256#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4260:checkCast:
    # get object, allow immediately if null
4260#    lw $t2,($sp)
4264#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4268#    lw $t2,-12($t2) # vtable address
4272#    bge $t2,$t1,castException
4273##...slt $at,$t2,$t1
4277##...beq $at,$zero,4412
4280#    blt $t2,$t0,castException
4281##...slt $at,$t2,$t0
4285##...bne $at,$zero,4412
    
    # return, leaving object unchanged on stack
4288:  checkCastReturn:    
4288#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4292:instanceOf:
    # get object, go return false if null
4292#    lw $t2,($sp)
4296#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4300#    lw $t2,-12($t2) # vtable address
4304#    sge $t0,$t2,$t0 # are we >= the lower limit?
4305##...slt $t0,$t2,$t0
4309##...xori $t0,$t0,0x1
4312#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4316#    and $t2,$t0,$t1
4320#    sw $t2,($sp)
4324:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4324#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4328:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4328#    li $v0,4 # syscall-code for print-string
4332#    syscall
4336:exit:
    # print termination message
4336#    li $v0,4 # syscall-code for print-string
4340#    la $a0,exitString
4344#    syscall

    # terminate execution
4348#    li $v0,10 #syscall-code for "exit"
4352#    syscall

4356:outOfHeapMemory:
4356#    la $a0,heapMemoryMsg
4360#    j exitError
4364:divByZeroError:
4364#    la $a0,divByZeroMsg
4368#    j exitError
4372:strIndexOutOfBounds:
4372#    la $a0,strIndexOutOfBoundsMsg
4376#    j exitError
4380:arrayIndexOutOfBounds:
4380#    la $a0,arrayIndexOutOfBoundsMsg
4384#    j exitError
4388:arraySizeOutOfBounds:
4388#    la $a0,arraySizeOutOfBoundsMsg
4392#    j exitError
4396:nullPtrException:
4396#    la $a0,nullPtrExceptionMsg
4400#    j exitError
4404:badIntegerFormat:
4404#    la $a0,badIntegerFormatMsg
4408#    j exitError
4412:castException:
4412#    la $a0,castExceptionMsg
4416#    j exitError
############## data section ################
    .data
4696:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4712:cur_seg:
    .word 0

4716:lastCharRead:
    .word -2 # -2 => no buffered character
4720:prevHashConstant:
    .word 0x2785173c
4724:gcCount:
    .word 0

4728:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4755:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4778:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4813:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4847:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4880:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4911:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4959:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4980:gcMsg: 
      .asciiz "\nGC!\n"
4986:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5018:nullStr:
    .asciiz "null"
5023:trueString:
    .asciiz "true"
5028:falseString:
    .asciiz "false"
5034:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5053:newlineString:
    .asciiz "\n"
    
    .align 2
5056:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5060:seg0_start:
    .space 0x100000
1053636:seg0_end:
1053636:seg1_start:
    .space 0x100000
2102212:seg1_end:

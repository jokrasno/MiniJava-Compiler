###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
992:mth_readLine_Lib:
    
992#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
996#    sw $ra, 4($sp) # save $ra
1000#    move $t1,$sp # save "original" sp

1004:  doRead:

    # read the character
1004#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1008#    subu $t2,$v0,13
1012#    bne $t2,$zero,notReturnRL
1016#    jal readLogicalChar
1020#    subu $t2,$v0,10 # check for newline
1024#    beq $t2,$zero,foundNewLine
1028#    sw $v0,lastCharRead # push back character into queue
1032#    j foundNewLine # go process the line

1036:  notReturnRL:

    # at this point, $v0 has our character

1036#    subu $t0,$v0,10
1040#    beq $t0,$zero,foundNewLine
1044#    blt $v0,$zero,foundEof
1045##...slt $at,$v0,$zero
1049##...bne $at,$zero,1064

    # we have a character, so push it onto stack
1052#    subu $sp,$sp,4
1056#    sw $v0,($sp)

    # loop back up to get next character
1060#    j doRead

1064:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1064#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1068#    li $s7, 0 # return-value: null
1072#    j rlReturn # return

1076:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1076#    subu $t0,$t1,$sp # number of chars we read (times 4)
1080#    srl $s6,$t0,2 # number of words on stack with chars
1084#    subu $sp,$sp,4 # push char-count ...
1088#    sw $s6,($sp) # ... onto stack
1092#    addu $t2,$t0,5 # GC tag, incl. for count-word
1096#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1100#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1104#    srl $s6,$s6,2  # data words in object
1108#    move $s7,$zero # object words in object
1112#    jal newObject  # allocate space
    
    # store header words
1116#    la $t0,CLASS_String
1120#    sw $t0,-12($s7)# store class tag (String) into object
1124#    lw $t2,4($sp) # char-count
1128#    sll $t1,$t2,2 # 4 times number of chars
1132#    subu $t2,$zero,$t2 # negative of char-count
1136#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1140#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1144#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1145##...slt $at,$t0,$zero
1149##...beq $at,$zero,1168
1152#    and $t0,0xff # mask off object's hash value ...
1153##...lui $at,0
1157##...ori $at,$at,0xff
1161##...and $t0,$t0,$at
1164#    sw $t0,-8($s7) # ... and store back into -8 header-word
1168:  skipMask_readLine:

1168#    sll $t0,$t0,2 # data bytes in object
1172#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1176#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1180#    addu $sp,$sp,8 # pop redundant object-pointer and count
1184#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1188#    beq $sp,$t1,rlReturn
1192:  charCopyLoop:
1192#    lw $t2,($sp)
1196#    sb $t2,-9($t0)
1200#    addu $sp,$sp,4
1204#    subu $t0,$t0,1
1208#    bne $sp,$t1,charCopyLoop
1212:  rlReturn:

1212#    lw $ra, 4($sp)
1216#    addu $sp, 8   # pop $ra and pointless word off stack
1220#    move $t0, $s7 # return string we allocated in $s7
1224#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1228:mth_readInt_Lib:

    # save $ra by pushing onto stack
1228#    subu $sp,$sp,4
1232#    sw $ra,($sp)

1236:  riSkipWhiteLoop:
    # read a character
1236#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1240#    subu $t0,$v0,32
1244#    bgt $t0,$zero,nonWhite
1245##...slt $at,$zero,$t0
1249##...bne $at,$zero,1292
1252#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1256#    subu $t0,$v0,10
1260#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1264#    subu $t0,$v0,9
1268#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1272#    subu $t0,$v0,13
1276#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1280#    subu $t0,$v0,12
1284#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1288#    j badIntegerFormat # illegal integer char: abort program

1292:  nonWhite:
1292#    subu $t0,$v0,'-'
1296#    li $t4,1 # final multiplier
1300#    bne $t0,$zero,helpReadInt # go read
1304#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1308#    jal readLogicalChar

1312:  helpReadInt:
1312#    li $t2,10
1316#    subu $t1,$v0,'0' # convert digit to 0-9 value
1320#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1321##...sltu $at,$t1,$t2
1325##...beq $at,$zero,3572
1328#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1332:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1332#    jal readLogicalChar # read next character
1336#    subu $t1,$v0,'0' # convert digit to 0-9 value
1340#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1341##...sltu $at,$t1,$t2
1345##...beq $at,$zero,1364

1348#    mul $t3,$t3,$t2 # multiply old value by 10
1349##...mult $t3,$t2
1353##...mflo $t3
1356#    addu $t3,$t3,$t1 # add in value of new digit
1360#    j digitLoop

1364:  doneDigitLoop:

    # "push back" unused character into queue
1364#    sw $v0,lastCharRead

    # restore return address
1368#    lw $ra,($sp)
1372#    addu $sp, 4

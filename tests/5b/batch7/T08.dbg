1669##...slt $at,$t4,$zero
1673##...beq $at,$zero,1692
1676#    and $t4,0xff # mask off object's hash value ...
1677##...lui $at,0
1681##...ori $at,$at,0xff
1685##...and $t4,$t4,$at
1688#    sw $t4,-8($s7) # ... and store back into -8 header-word
1692:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1692#    lw $t1,8($sp) # k
1696#    lw $t2,16($sp) # n
1700#    subu $t0,$t2,$t1 # value to store
1704#    sw $t0,-4($s7) # store value

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
484:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
484#    lw $t0,-8($s2) # get word with hash bits from this
488#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
492#    addu $t0,$t1

496#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
500:mth_equals_Object:
500#    move $t0,$s2 # first pointer (this)
504#    lw $t1,($sp) # second pointer
508#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
509##...subu $at,$t0,$t1
513##...sltiu $t0,$at,1

516#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
520:mth_hashCode_String:
520#    move $t0,$s2 # put this pointer in t0

524#    li $t2,0 # current hash value
528#    lw $t1,-4($t0) # negative of number of characters in string
532#    beq $t1,$zero,done_hashCode_String # if zero length => done
536#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
540#    and $t0,0xfffffffc # adjust for padding
541##...lui $at,65535
545##...ori $at,$at,0xfffc
549##...and $t0,$t0,$at
552#    subu $t1,$t0,$t1 # address at end of string +12
556:loop_hashCode_String:    
556#    sll $t4,$t2,5 # multiply by 32
560#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
564#    lbu $t3,-12($t0) # current character
568#    addu $t2,$t3 # add in current character
572#    addu $t0,1 # go to next character's address
576#    bne $t0,$t1,loop_hashCode_String # loop back if more
580:done_hashCode_String:    

    # push int on stack
580#    move $t0, $t2 # put $t2 in return slot
584#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
588:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
588#    subu $sp,4
592#    sw $ra,($sp)
    
    # get hash value
596#    lw $t2,-12($s2) # vtable address
600#    lw $t0,($t2) # method address
604#    jalr $t0
608#    subu $sp,8 # push result (int in $t0) on stack
612#    sw $s5,4($sp)
616#    sw $t0,($sp)

    # compute print-size of hash value
620#    li $t0, 1
624#    lw $t1, ($sp)
628#    srl $t1,$t1,4
632#    beq $t1,$zero,toString_skip_loop
636:toString_loop_top:
636#    addu $t0,1
640#    srl $t1,$t1,4
644#    bne $t1,$zero,toString_loop_top
648:toString_skip_loop:
648#    subu $sp,8
652#    sw $s5,4($sp)
656#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
660#    lw $t2,-12($s2) # vtable address
664#    move $t0,$t2
668:toString_checkTagBit:
668#    subu $t0,1
672#    lb $t1,($t0)
676#    and $t1,0x80
677##...lui $at,0
681##...ori $at,$at,0x80
685##...and $t1,$t1,$at
688#    beq $t1,$zero,toString_checkTagBit
692#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
696#    subu $sp,8
700#    sw $t1,($sp)
704#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
708#    move $s7,$zero # -4 offset header word
712#    lw $t4,8($sp) # bytes for hash value
716#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
720#    addu $t4,8
724#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
728#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

732#    li $t0,CLASS_String # store string vtable address into ...
736#    sw $t0,-12($s7) # ... -12 offset in object header
740#    lw $t2,-12($s2) # our object's vtable address
744#    lw $t5,4($sp) # number characters in prefix
748#    lw $t1,12($sp) # number of characters in hashcode
752#    addu $t3,$t1,$t5 # number of characters in string ...
756#    addu $t3,1 # ... including the '@' character
760#    subu $t0,$zero,$t3 # store negated length into ...
764#    sw $t0,-4($s7) # ... -4 offset header word
768#    lw $t0,-8($s7) # get -8 offset header-word
772#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
773##...slt $at,$t0,$zero
777##...beq $at,$zero,796
780#    and $t0,0xff # mask off object's hash value ...
781##...lui $at,0
785##...ori $at,$at,0xff
789##...and $t0,$t0,$at
792#    sw $t0,-8($s7) # ... and store back into -8 header-word
796:skipMask_toString:
796#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
800#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
804#    subu $t4,$t2,$t5
808:toString_copyLoop:    
808#    lb $t3,($t4)
812#    and $t3,0x7f # mask off sign bit (in case first word)
813##...lui $at,0
817##...ori $at,$at,0x7f
821##...and $t3,$t3,$at
824#    sb $t3,-8($t0)

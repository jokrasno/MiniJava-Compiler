    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3248#    lw $s0,($t4)
3252#    lw $t9,-8($t1)
3256#    sw $t9,($t4)
3260#    sw $s0,-8($t1)

    # copy all source bytes to the target
3264:  gCinnerCopy2:
3264#    lw $s0,($t4)
3268#    sw $s0,($s3)
3272#    addu $t4,$t4,4
3276#    addu $s3,$s3,4
3280#    bltu $t4,$t3,gCinnerCopy2
3281##...sltu $at,$t4,$t3
3285##...bne $at,$zero,3264

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3288#    sw $zero,-8($t1) # 0 in first header-slot
3292#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3296#    sw $t8,($t0)

3300:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3300#    addu $t0,$t0,4
3304#    bltu $t0,$s1,gcNextPointerInObject
3305##...sltu $at,$t0,$s1
3309##...bne $at,$zero,3148

3312:  gcTestIterDone2:
3312#    bltu $t0,$s3,gcHeapCopyLoop
3313##...sltu $at,$t0,$s3
3317##...bne $at,$zero,3032

    ###### end outer loop to copy all non-stack-direct objects ######

3320:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3320#    lw $s2,($sp)
3324#    addu $sp,$sp,4

    # mark us as having already GC'd
3328#    move $t5,$s5

    # go try and allocate again
3332#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3336:vm_init:

    # mark bottom of stack
3336#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3340#    move $s2,$zero

    #set up the "five" register
3344#    li $s5,5

3348#    la $s3,seg0_start
3352#    la $s4,seg0_end
3353##...lui $s4,16
3357##...addiu $s4,$s4,4252
    
    # return
3360#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3364:divide:
    # get parameters; abort if divisor zero
3364#    lw $t0,($sp)
3368#    lw $t1,8($sp)
3372#    beq $t0,$zero,divByZeroError
    
    # perform division
3376#    div $t1,$t0
3380#    mflo $t0

    # store result, adjust stack and return
3384#    addu $sp,$sp,8 # adjust stack
3388#    sw $t0,($sp) # store result
3392#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3396:remainder:
    # get parameters; abort if divisor zero
3396#    lw $t0,($sp)
3400#    lw $t1,8($sp)
3404#    beq $t0,$zero,divByZeroError
    
    # perform division
3408#    div $t1,$t0
3412#    mfhi $t0

    # store result, adjust stack and return
3416#    addu $sp,$sp,8 # adjust stack
3420#    sw $t0,($sp) # store result
3424#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3428:checkCast:
    # get object, allow immediately if null
3428#    lw $t2,($sp)
3432#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3436#    lw $t2,-12($t2) # vtable address
3440#    bge $t2,$t1,castException
3441##...slt $at,$t2,$t1
3445##...beq $at,$zero,3580
3448#    blt $t2,$t0,castException
3449##...slt $at,$t2,$t0
3453##...bne $at,$zero,3580
    
    # return, leaving object unchanged on stack
3456:  checkCastReturn:    
3456#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3460:instanceOf:
    # get object, go return false if null
3460#    lw $t2,($sp)
3464#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3468#    lw $t2,-12($t2) # vtable address
3472#    sge $t0,$t2,$t0 # are we >= the lower limit?
3473##...slt $t0,$t2,$t0
3477##...xori $t0,$t0,0x1
3480#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3484#    and $t2,$t0,$t1
3488#    sw $t2,($sp)
3492:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3492#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3496:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3496#    li $v0,4 # syscall-code for print-string
3500#    syscall
3504:exit:
    # print termination message
3504#    li $v0,4 # syscall-code for print-string
3508#    la $a0,exitString
3512#    syscall

    # terminate execution
3516#    li $v0,10 #syscall-code for "exit"
3520#    syscall

3524:outOfHeapMemory:
3524#    la $a0,heapMemoryMsg
3528#    j exitError
3532:divByZeroError:
3532#    la $a0,divByZeroMsg
3536#    j exitError
3540:strIndexOutOfBounds:
3540#    la $a0,strIndexOutOfBoundsMsg
3544#    j exitError
3548:arrayIndexOutOfBounds:
3548#    la $a0,arrayIndexOutOfBoundsMsg
3552#    j exitError
3556:arraySizeOutOfBounds:
3556#    la $a0,arraySizeOutOfBoundsMsg
3560#    j exitError
3564:nullPtrException:
3564#    la $a0,nullPtrExceptionMsg
3568#    j exitError
3572:badIntegerFormat:
3572#    la $a0,badIntegerFormatMsg
3576#    j exitError
3580:castException:
3580#    la $a0,castExceptionMsg
3584#    j exitError
############## data section ################
    .data
3888:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3904:cur_seg:
    .word 0

3908:lastCharRead:
    .word -2 # -2 => no buffered character
3912:prevHashConstant:
    .word 0x2785173c
3916:gcCount:
    .word 0

3920:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3947:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3970:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4005:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4039:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4072:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4103:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4151:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4172:gcMsg: 
      .asciiz "\nGC!\n"
4178:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4210:nullStr:
    .asciiz "null"
4215:trueString:
    .asciiz "true"
4220:falseString:
    .asciiz "false"
4226:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4245:newlineString:
    .asciiz "\n"
    
    .align 2
4248:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4252:seg0_start:
    .space 0x100000
1052828:seg0_end:
1052828:seg1_start:
    .space 0x100000
2101404:seg1_end:

1636#    subu $s6,$t1,$t2 # # chars in target-string
1640#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1644#    srl $s6,$s6,2 # convert bytes-count to word-count
1648#    move $s7,$zero # (no object-bytes in string)
1652#    jal newObject

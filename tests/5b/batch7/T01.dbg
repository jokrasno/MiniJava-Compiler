2772#    beq $sp,$t1,rlReturn
2776:  charCopyLoop:
2776#    lw $t2,($sp)
2780#    sb $t2,-9($t0)
2784#    addu $sp,$sp,4
2788#    subu $t0,$t0,1
2792#    bne $sp,$t1,charCopyLoop

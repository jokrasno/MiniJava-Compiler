2836#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2840#    subu $t0,$v0,10
2844#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2848#    subu $t0,$v0,9
2852#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2856#    subu $t0,$v0,13
2860#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2864#    subu $t0,$v0,12
2868#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2872#    j badIntegerFormat # illegal integer char: abort program

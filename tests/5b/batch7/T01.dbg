        
    # mask off hash bits, if needed
3444#    lw $t4,-8($s7) # # data words in source string
3448#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
3449##...slt $at,$t4,$zero
3453##...beq $at,$zero,3472
3456#    and $t4,0xff # mask off object's hash value ...
3457##...lui $at,0
3461##...ori $at,$at,0xff

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2068:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
2068#    lw $t0,-8($s2) # get word with hash bits from this
2072#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
2076#    addu $t0,$t1

2080#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2084:mth_equals_Object:
2084#    move $t0,$s2 # first pointer (this)
2088#    lw $t1,($sp) # second pointer
2092#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
2093##...subu $at,$t0,$t1
2097##...sltiu $t0,$at,1

2100#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2104:mth_hashCode_String:
2104#    move $t0,$s2 # put this pointer in t0

2108#    li $t2,0 # current hash value
2112#    lw $t1,-4($t0) # negative of number of characters in string
2116#    beq $t1,$zero,done_hashCode_String # if zero length => done
2120#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
2124#    and $t0,0xfffffffc # adjust for padding
2125##...lui $at,65535
2129##...ori $at,$at,0xfffc
2133##...and $t0,$t0,$at
2136#    subu $t1,$t0,$t1 # address at end of string +12
2140:loop_hashCode_String:    
2140#    sll $t4,$t2,5 # multiply by 32
2144#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
2148#    lbu $t3,-12($t0) # current character
2152#    addu $t2,$t3 # add in current character
2156#    addu $t0,1 # go to next character's address
2160#    bne $t0,$t1,loop_hashCode_String # loop back if more
2164:done_hashCode_String:    

    # push int on stack
2164#    move $t0, $t2 # put $t2 in return slot
2168#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
2172:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
2172#    subu $sp,4
2176#    sw $ra,($sp)
    
    # get hash value
2180#    lw $t2,-12($s2) # vtable address
2184#    lw $t0,($t2) # method address
2188#    jalr $t0
2192#    subu $sp,8 # push result (int in $t0) on stack
2196#    sw $s5,4($sp)
2200#    sw $t0,($sp)

    # compute print-size of hash value
2204#    li $t0, 1
2208#    lw $t1, ($sp)
2212#    srl $t1,$t1,4
2216#    beq $t1,$zero,toString_skip_loop
2220:toString_loop_top:
2220#    addu $t0,1
2224#    srl $t1,$t1,4
2228#    bne $t1,$zero,toString_loop_top
2232:toString_skip_loop:
2232#    subu $sp,8
2236#    sw $s5,4($sp)
2240#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
2244#    lw $t2,-12($s2) # vtable address
2248#    move $t0,$t2
2252:toString_checkTagBit:
2252#    subu $t0,1
2256#    lb $t1,($t0)
2260#    and $t1,0x80
2261##...lui $at,0
2265##...ori $at,$at,0x80
2269##...and $t1,$t1,$at
2272#    beq $t1,$zero,toString_checkTagBit
2276#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
2280#    subu $sp,8
2284#    sw $t1,($sp)
2288#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
2292#    move $s7,$zero # -4 offset header word
2296#    lw $t4,8($sp) # bytes for hash value
2300#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
2304#    addu $t4,8
2308#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
2312#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

2316#    li $t0,CLASS_String # store string vtable address into ...
2320#    sw $t0,-12($s7) # ... -12 offset in object header
2324#    lw $t2,-12($s2) # our object's vtable address
2328#    lw $t5,4($sp) # number characters in prefix
2332#    lw $t1,12($sp) # number of characters in hashcode
2336#    addu $t3,$t1,$t5 # number of characters in string ...
2340#    addu $t3,1 # ... including the '@' character
2344#    subu $t0,$zero,$t3 # store negated length into ...
2348#    sw $t0,-4($s7) # ... -4 offset header word
2352#    lw $t0,-8($s7) # get -8 offset header-word
2356#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2357##...slt $at,$t0,$zero
2361##...beq $at,$zero,2380
2364#    and $t0,0xff # mask off object's hash value ...
2365##...lui $at,0
2369##...ori $at,$at,0xff
2373##...and $t0,$t0,$at
2376#    sw $t0,-8($s7) # ... and store back into -8 header-word
2380:skipMask_toString:
2380#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2384#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2388#    subu $t4,$t2,$t5
2392:toString_copyLoop:    
2392#    lb $t3,($t4)
2396#    and $t3,0x7f # mask off sign bit (in case first word)
2397##...lui $at,0
2401##...ori $at,$at,0x7f
2405##...and $t3,$t3,$at
2408#    sb $t3,-8($t0)
2412#    addu $t4,1
2416#    addu $t0,1
2420#    blt $t4,$t2,toString_copyLoop
2421##...slt $at,$t4,$t2
2425##...bne $at,$zero,2392

    # copy the '@' sign
2428#    li $t3,'@'
2432#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2436#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2440#    lw $t3,20($sp) # hash code to print
2444:toString_hashCopyLoop:
2444#    and $t4,$t3,0xf
2448#    srl $t3,4
2452#    lb $t4,hexChars($t4)
2456#    sb $t4,-8($t2)
2460#    subu $t2,$t2,1
2464#    bgt $t2,$t0,toString_hashCopyLoop
2465##...slt $at,$t0,$t2
2469##...bne $at,$zero,2444

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2472#    addu $sp,28
2476#    lw $ra,($sp)
2480#    addu $sp,4
2484#    move $t0, $s7 # return string we created
2488#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2492:mth_equals_String:
    
    # quick test for obvious false
2492#    lw $t0,($sp) # second parameter
2496#    beq $t0,$zero,goEsFalse # go return false if null
2500#    lw $t1,-12($t0) # vtable pointer
2504#    la $t2,CLASS_String # string vtable pointer
2508#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2512#    subu $sp,12
2516#    sw $ra,8($sp)
2520#    sw $s2,4($sp)
2524#    sw $t0,($sp)
2528#    jal mth_compareTo_String
2532#    lw $s2, 4($sp) #restore this pointer and pop parameters
2536#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2540#    seq $t0,$t0,$zero
2541##...subu $at,$t0,$zero
2545##...sltiu $t0,$at,1

    # pop return address and return $t0
2548#    lw $ra,($sp)
2552#    addu $sp,4

2556#    jr $ra # return
    
2560:goEsFalse:
    # put 0 in $t0 and return
2560#    li $t0, 0
2564#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2568:mth_toString_String:
    #we are a string, so return this.
2568#    move $t0, $s2
2572#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2576:mth_readLine_Lib:
    
2576#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2580#    sw $ra, 4($sp) # save $ra
2584#    move $t1,$sp # save "original" sp

2588:  doRead:

    # read the character
2588#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2592#    subu $t2,$v0,13
2596#    bne $t2,$zero,notReturnRL
2600#    jal readLogicalChar
2604#    subu $t2,$v0,10 # check for newline
2608#    beq $t2,$zero,foundNewLine
2612#    sw $v0,lastCharRead # push back character into queue
2616#    j foundNewLine # go process the line

2620:  notReturnRL:

    # at this point, $v0 has our character

2620#    subu $t0,$v0,10
2624#    beq $t0,$zero,foundNewLine
2628#    blt $v0,$zero,foundEof
2629##...slt $at,$v0,$zero
2633##...bne $at,$zero,2648

    # we have a character, so push it onto stack
2636#    subu $sp,$sp,4
2640#    sw $v0,($sp)

    # loop back up to get next character
2644#    j doRead

2648:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2648#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2652#    li $s7, 0 # return-value: null
2656#    j rlReturn # return

2660:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2660#    subu $t0,$t1,$sp # number of chars we read (times 4)
2664#    srl $s6,$t0,2 # number of words on stack with chars
2668#    subu $sp,$sp,4 # push char-count ...
2672#    sw $s6,($sp) # ... onto stack
2676#    addu $t2,$t0,5 # GC tag, incl. for count-word
2680#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2684#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2688#    srl $s6,$s6,2  # data words in object
2692#    move $s7,$zero # object words in object
2696#    jal newObject  # allocate space
    
    # store header words
2700#    la $t0,CLASS_String
2704#    sw $t0,-12($s7)# store class tag (String) into object
2708#    lw $t2,4($sp) # char-count
2712#    sll $t1,$t2,2 # 4 times number of chars
2716#    subu $t2,$zero,$t2 # negative of char-count
2720#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2724#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2728#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2729##...slt $at,$t0,$zero
2733##...beq $at,$zero,2752
2736#    and $t0,0xff # mask off object's hash value ...
2737##...lui $at,0
2741##...ori $at,$at,0xff
2745##...and $t0,$t0,$at
2748#    sw $t0,-8($s7) # ... and store back into -8 header-word
2752:  skipMask_readLine:

2752#    sll $t0,$t0,2 # data bytes in object
2756#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2760#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2764#    addu $sp,$sp,8 # pop redundant object-pointer and count
2768#    addu $t1,$t1,$sp # first non-char spot on stack

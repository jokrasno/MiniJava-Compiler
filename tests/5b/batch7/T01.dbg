########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4920:vm_init:

    # mark bottom of stack
4920#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4924#    move $s2,$zero

    #set up the "five" register
4928#    li $s5,5

4932#    la $s3,seg0_start
4936#    la $s4,seg0_end
4937##...lui $s4,16
4941##...addiu $s4,$s4,5784
    
    # return
4944#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4948:divide:
    # get parameters; abort if divisor zero
4948#    lw $t0,($sp)
4952#    lw $t1,8($sp)
4956#    beq $t0,$zero,divByZeroError
    
    # perform division
4960#    div $t1,$t0
4964#    mflo $t0

    # store result, adjust stack and return
4968#    addu $sp,$sp,8 # adjust stack
4972#    sw $t0,($sp) # store result
4976#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4980:remainder:
    # get parameters; abort if divisor zero
4980#    lw $t0,($sp)
4984#    lw $t1,8($sp)
4988#    beq $t0,$zero,divByZeroError
    
    # perform division
4992#    div $t1,$t0
4996#    mfhi $t0

    # store result, adjust stack and return
5000#    addu $sp,$sp,8 # adjust stack
5004#    sw $t0,($sp) # store result
5008#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
5012:checkCast:
    # get object, allow immediately if null
5012#    lw $t2,($sp)
5016#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
5020#    lw $t2,-12($t2) # vtable address
5024#    bge $t2,$t1,castException
5025##...slt $at,$t2,$t1
5029##...beq $at,$zero,5164
5032#    blt $t2,$t0,castException
5033##...slt $at,$t2,$t0
5037##...bne $at,$zero,5164
    
    # return, leaving object unchanged on stack
5040:  checkCastReturn:    
5040#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
5044:instanceOf:
    # get object, go return false if null
5044#    lw $t2,($sp)
5048#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
5052#    lw $t2,-12($t2) # vtable address
5056#    sge $t0,$t2,$t0 # are we >= the lower limit?
5057##...slt $t0,$t2,$t0
5061##...xori $t0,$t0,0x1
5064#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
5068#    and $t2,$t0,$t1
5072#    sw $t2,($sp)
5076:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
5076#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

5080:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
5080#    li $v0,4 # syscall-code for print-string
5084#    syscall
5088:exit:
    # print termination message
5088#    li $v0,4 # syscall-code for print-string
5092#    la $a0,exitString
5096#    syscall

    # terminate execution
5100#    li $v0,10 #syscall-code for "exit"
5104#    syscall

5108:outOfHeapMemory:
5108#    la $a0,heapMemoryMsg
5112#    j exitError
5116:divByZeroError:
5116#    la $a0,divByZeroMsg
5120#    j exitError
5124:strIndexOutOfBounds:
5124#    la $a0,strIndexOutOfBoundsMsg
5128#    j exitError
5132:arrayIndexOutOfBounds:
5132#    la $a0,arrayIndexOutOfBoundsMsg
5136#    j exitError
5140:arraySizeOutOfBounds:
5140#    la $a0,arraySizeOutOfBoundsMsg
5144#    j exitError
5148:nullPtrException:
5148#    la $a0,nullPtrExceptionMsg
5152#    j exitError
5156:badIntegerFormat:
5156#    la $a0,badIntegerFormatMsg
5160#    j exitError
5164:castException:
5164#    la $a0,castExceptionMsg
5168#    j exitError
############## data section ################
    .data
5420:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5436:cur_seg:
    .word 0

5440:lastCharRead:
    .word -2 # -2 => no buffered character
5444:prevHashConstant:
    .word 0x2785173c
5448:gcCount:
    .word 0

5452:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5479:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5502:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5537:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5571:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5604:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5635:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5683:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5704:gcMsg: 
      .asciiz "\nGC!\n"
5710:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5742:nullStr:
    .asciiz "null"
5747:trueString:
    .asciiz "true"
5752:falseString:
    .asciiz "false"
5758:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5777:newlineString:
    .asciiz "\n"
    
    .align 2
5780:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5784:seg0_start:
    .space 0x100000
1054360:seg0_end:
1054360:seg1_start:
    .space 0x100000
2102936:seg1_end:

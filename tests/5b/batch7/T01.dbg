    #### and $t2 contains the value 10

2916:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2916#    jal readLogicalChar # read next character
2920#    subu $t1,$v0,'0' # convert digit to 0-9 value
2924#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2925##...sltu $at,$t1,$t2
2929##...beq $at,$zero,2948

2932#    mul $t3,$t3,$t2 # multiply old value by 10
2933##...mult $t3,$t2
2937##...mflo $t3
2940#    addu $t3,$t3,$t1 # add in value of new digit
2944#    j digitLoop

2948:  doneDigitLoop:

    # "push back" unused character into queue

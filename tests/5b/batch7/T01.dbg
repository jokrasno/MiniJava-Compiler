3468#    sw $t4,-8($s7) # ... and store back into -8 header-word
3472:skipMask_concat:

3472#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
3476#    move $t1,$s2   # first object
3480#    lw $t0,8($sp) # second object

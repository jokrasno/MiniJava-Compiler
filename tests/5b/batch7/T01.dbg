########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
4112:readLogicalChar:

    # check if we already have a character
4112#    lw $v0,lastCharRead
4116#    li $t0,-2
4120#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
4124#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
4128#    jr $ra # return
    
4132:  doReadCh:
    # we need to actually read a character: read and return
4132#    li $v0,12 # use system call to read a character
4136#    syscall
4140#    jr $ra # return

    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3752:  gcNotDataArray:
3752#    lw $t3,-4($t2) # # object words (negative treated as zero)
3756#    bge $t3,$zero,gcH2Neg2
3757##...slt $at,$t3,$zero
3761##...beq $at,$zero,3768
3764#    move $t3,$zero
3768:  gcH2Neg2:
3768#    sll $t3,$t3,2 # # object bytes
3772#    move $t0,$t2 # address of first pointer in object
3776#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3780#    beq $t0,$s1,gcTestIterDone2
    
3784:  gcNextPointerInObject:
    # get pointer from object
3784#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3788#    bleu $t1,$t6,gcGoNextPointerSlot
3789##...sltu $at,$t6,$t1
3793##...beq $at,$zero,3936
3796#    bgtu $t1,$t7,gcGoNextPointerSlot
3797##...sltu $at,$t7,$t1
3801##...bne $at,$zero,3936

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3804#    lw $t8,-8($t1) # possible forwarding tag
3808#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3812#    lw $t8,-4($t1) # forwarding pointer: object's new address
3816#    sw $t8,($t0) # update pointer in object
3820#    j gcGoNextPointerSlot # do next iteration

3824:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3824#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3825##...slt $at,$t8,$zero
3829##...beq $at,$zero,3844
3832#    and $t8,0xff # mask off hash bits
3833##...lui $at,0
3837##...ori $at,$at,0xff
3841##...and $t8,$t8,$at

3844:  gcSkip5:
3844#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3848#    addu $t8,$t8,8 # ... add in bytes for header-words
3852#    subu $t4,$t1,$t8 # address of first word of source object
3856#    lw $t3,-4($t1) # # words in positive-offset portion
3860#    bge $t3,$zero,gcNoNeg
3861##...slt $at,$t3,$zero
3865##...beq $at,$zero,3872
3868#    move $t3,$zero # negative treated as zero
3872:  gcNoNeg:
3872#    sll $t3,$t3,2 # bytes in negative-offset portion
3876#    addu $t3,$t3,$t1 # address one word past last word of source

3880#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3884#    lw $s0,($t4)
3888#    lw $t9,-8($t1)
3892#    sw $t9,($t4)
3896#    sw $s0,-8($t1)

    # copy all source bytes to the target
3900:  gCinnerCopy2:
3900#    lw $s0,($t4)
3904#    sw $s0,($s3)
3908#    addu $t4,$t4,4
3912#    addu $s3,$s3,4
3916#    bltu $t4,$t3,gCinnerCopy2
3917##...sltu $at,$t4,$t3
3921##...bne $at,$zero,3900

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3924#    sw $zero,-8($t1) # 0 in first header-slot
3928#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3932#    sw $t8,($t0)

3936:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3936#    addu $t0,$t0,4
3940#    bltu $t0,$s1,gcNextPointerInObject
3941##...sltu $at,$t0,$s1
3945##...bne $at,$zero,3784

3948:  gcTestIterDone2:
3948#    bltu $t0,$s3,gcHeapCopyLoop
3949##...sltu $at,$t0,$s3
3953##...bne $at,$zero,3668

    ###### end outer loop to copy all non-stack-direct objects ######

3956:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3956#    lw $s2,($sp)
3960#    addu $sp,$sp,4

    # mark us as having already GC'd
3964#    move $t5,$s5

    # go try and allocate again
3968#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3972:vm_init:

    # mark bottom of stack
3972#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3976#    move $s2,$zero

    #set up the "five" register
3980#    li $s5,5

3984#    la $s3,seg0_start
3988#    la $s4,seg0_end
3989##...lui $s4,16
3993##...addiu $s4,$s4,4828
    
    # return
3996#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4000:divide:
    # get parameters; abort if divisor zero
4000#    lw $t0,($sp)
4004#    lw $t1,8($sp)
4008#    beq $t0,$zero,divByZeroError
    
    # perform division
4012#    div $t1,$t0
4016#    mflo $t0

    # store result, adjust stack and return
4020#    addu $sp,$sp,8 # adjust stack
4024#    sw $t0,($sp) # store result
4028#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4032:remainder:
    # get parameters; abort if divisor zero
4032#    lw $t0,($sp)
4036#    lw $t1,8($sp)
4040#    beq $t0,$zero,divByZeroError
    
    # perform division
4044#    div $t1,$t0
4048#    mfhi $t0

    # store result, adjust stack and return
4052#    addu $sp,$sp,8 # adjust stack
4056#    sw $t0,($sp) # store result
4060#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4064:checkCast:
    # get object, allow immediately if null
4064#    lw $t2,($sp)
4068#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4072#    lw $t2,-12($t2) # vtable address
4076#    bge $t2,$t1,castException
4077##...slt $at,$t2,$t1
4081##...beq $at,$zero,4216
4084#    blt $t2,$t0,castException
4085##...slt $at,$t2,$t0
4089##...bne $at,$zero,4216
    
    # return, leaving object unchanged on stack
4092:  checkCastReturn:    
4092#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4096:instanceOf:
    # get object, go return false if null
4096#    lw $t2,($sp)
4100#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4104#    lw $t2,-12($t2) # vtable address
4108#    sge $t0,$t2,$t0 # are we >= the lower limit?
4109##...slt $t0,$t2,$t0
4113##...xori $t0,$t0,0x1
4116#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4120#    and $t2,$t0,$t1
4124#    sw $t2,($sp)
4128:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4128#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4132:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4132#    li $v0,4 # syscall-code for print-string
4136#    syscall
4140:exit:
    # print termination message
4140#    li $v0,4 # syscall-code for print-string
4144#    la $a0,exitString
4148#    syscall

    # terminate execution
4152#    li $v0,10 #syscall-code for "exit"
4156#    syscall

4160:outOfHeapMemory:
4160#    la $a0,heapMemoryMsg
4164#    j exitError
4168:divByZeroError:
4168#    la $a0,divByZeroMsg
4172#    j exitError
4176:strIndexOutOfBounds:
4176#    la $a0,strIndexOutOfBoundsMsg
4180#    j exitError
4184:arrayIndexOutOfBounds:
4184#    la $a0,arrayIndexOutOfBoundsMsg
4188#    j exitError
4192:arraySizeOutOfBounds:
4192#    la $a0,arraySizeOutOfBoundsMsg
4196#    j exitError
4200:nullPtrException:
4200#    la $a0,nullPtrExceptionMsg
4204#    j exitError
4208:badIntegerFormat:
4208#    la $a0,badIntegerFormatMsg
4212#    j exitError
4216:castException:
4216#    la $a0,castExceptionMsg
4220#    j exitError
############## data section ################
    .data
4464:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4480:cur_seg:
    .word 0

4484:lastCharRead:
    .word -2 # -2 => no buffered character
4488:prevHashConstant:
    .word 0x2785173c
4492:gcCount:
    .word 0

4496:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4523:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4546:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4581:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4615:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4648:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4679:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4727:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4748:gcMsg: 
      .asciiz "\nGC!\n"
4754:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4786:nullStr:
    .asciiz "null"
4791:trueString:
    .asciiz "true"
4796:falseString:
    .asciiz "false"
4802:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4821:newlineString:
    .asciiz "\n"
    
    .align 2
4824:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4828:seg0_start:
    .space 0x100000
1053404:seg0_end:
1053404:seg1_start:
    .space 0x100000
2101980:seg1_end:

1888#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1892#    subu $t0,$v0,10
1896#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1900#    subu $t0,$v0,9
1904#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1908#    subu $t0,$v0,13
1912#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1916#    subu $t0,$v0,12
1920#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1924#    j badIntegerFormat # illegal integer char: abort program

1928:  nonWhite:
1928#    subu $t0,$v0,'-'
1932#    li $t4,1 # final multiplier
1936#    bne $t0,$zero,helpReadInt # go read
1940#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1944#    jal readLogicalChar

1948:  helpReadInt:
1948#    li $t2,10
1952#    subu $t1,$v0,'0' # convert digit to 0-9 value
1956#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1957##...sltu $at,$t1,$t2
1961##...beq $at,$zero,4208
1964#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1968:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1968#    jal readLogicalChar # read next character
1972#    subu $t1,$v0,'0' # convert digit to 0-9 value
1976#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1977##...sltu $at,$t1,$t2
1981##...beq $at,$zero,2000

1984#    mul $t3,$t3,$t2 # multiply old value by 10
1985##...mult $t3,$t2
1989##...mflo $t3
1992#    addu $t3,$t3,$t1 # add in value of new digit
1996#    j digitLoop

2000:  doneDigitLoop:

    # "push back" unused character into queue
2000#    sw $v0,lastCharRead

    # restore return address
2004#    lw $ra,($sp)
2008#    addu $sp, 4

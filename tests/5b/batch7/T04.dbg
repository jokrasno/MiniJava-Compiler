3140#    j cmpHitLimitzz

3144:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
3144#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
3148#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
3152#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
3156:  cmpHitLimitzz:
3156#    move $t0, $t5 # store return value
3160#    jr $ra # return

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1628:mth_readLine_Lib:
    
1628#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1632#    sw $ra, 4($sp) # save $ra
1636#    move $t1,$sp # save "original" sp

1640:  doRead:

    # read the character
1640#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1644#    subu $t2,$v0,13
1648#    bne $t2,$zero,notReturnRL
1652#    jal readLogicalChar
1656#    subu $t2,$v0,10 # check for newline
1660#    beq $t2,$zero,foundNewLine
1664#    sw $v0,lastCharRead # push back character into queue
1668#    j foundNewLine # go process the line

1672:  notReturnRL:

    # at this point, $v0 has our character

1672#    subu $t0,$v0,10
1676#    beq $t0,$zero,foundNewLine
1680#    blt $v0,$zero,foundEof
1681##...slt $at,$v0,$zero
1685##...bne $at,$zero,1700

    # we have a character, so push it onto stack
1688#    subu $sp,$sp,4
1692#    sw $v0,($sp)

    # loop back up to get next character
1696#    j doRead

1700:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1700#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1704#    li $s7, 0 # return-value: null
1708#    j rlReturn # return

1712:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1712#    subu $t0,$t1,$sp # number of chars we read (times 4)
1716#    srl $s6,$t0,2 # number of words on stack with chars
1720#    subu $sp,$sp,4 # push char-count ...
1724#    sw $s6,($sp) # ... onto stack
1728#    addu $t2,$t0,5 # GC tag, incl. for count-word
1732#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1736#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1740#    srl $s6,$s6,2  # data words in object
1744#    move $s7,$zero # object words in object
1748#    jal newObject  # allocate space
    
    # store header words
1752#    la $t0,CLASS_String
1756#    sw $t0,-12($s7)# store class tag (String) into object
1760#    lw $t2,4($sp) # char-count
1764#    sll $t1,$t2,2 # 4 times number of chars
1768#    subu $t2,$zero,$t2 # negative of char-count
1772#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1776#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1780#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1781##...slt $at,$t0,$zero
1785##...beq $at,$zero,1804
1788#    and $t0,0xff # mask off object's hash value ...
1789##...lui $at,0
1793##...ori $at,$at,0xff
1797##...and $t0,$t0,$at
1800#    sw $t0,-8($s7) # ... and store back into -8 header-word
1804:  skipMask_readLine:

1804#    sll $t0,$t0,2 # data bytes in object
1808#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1812#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1816#    addu $sp,$sp,8 # pop redundant object-pointer and count
1820#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1824#    beq $sp,$t1,rlReturn
1828:  charCopyLoop:
1828#    lw $t2,($sp)
1832#    sb $t2,-9($t0)
1836#    addu $sp,$sp,4
1840#    subu $t0,$t0,1
1844#    bne $sp,$t1,charCopyLoop
1848:  rlReturn:

1848#    lw $ra, 4($sp)
1852#    addu $sp, 8   # pop $ra and pointless word off stack
1856#    move $t0, $s7 # return string we allocated in $s7
1860#    jr $ra

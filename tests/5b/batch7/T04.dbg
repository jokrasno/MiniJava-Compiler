    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1564#    subu $sp,12
1568#    sw $ra,8($sp)
1572#    sw $s2,4($sp)
1576#    sw $t0,($sp)
1580#    jal mth_compareTo_String
1584#    lw $s2, 4($sp) #restore this pointer and pop parameters
1588#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1592#    seq $t0,$t0,$zero
1593##...subu $at,$t0,$zero
1597##...sltiu $t0,$at,1

    # pop return address and return $t0
1600#    lw $ra,($sp)
1604#    addu $sp,4

1608#    jr $ra # return
    
1612:goEsFalse:
    # put 0 in $t0 and return
1612#    li $t0, 0
1616#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1224:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1224#    subu $sp,4
1228#    sw $ra,($sp)
    
    # get hash value
1232#    lw $t2,-12($s2) # vtable address
1236#    lw $t0,($t2) # method address
1240#    jalr $t0
1244#    subu $sp,8 # push result (int in $t0) on stack
1248#    sw $s5,4($sp)
1252#    sw $t0,($sp)

    # compute print-size of hash value
1256#    li $t0, 1
1260#    lw $t1, ($sp)
1264#    srl $t1,$t1,4
1268#    beq $t1,$zero,toString_skip_loop
1272:toString_loop_top:
1272#    addu $t0,1
1276#    srl $t1,$t1,4
1280#    bne $t1,$zero,toString_loop_top
1284:toString_skip_loop:
1284#    subu $sp,8
1288#    sw $s5,4($sp)
1292#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1296#    lw $t2,-12($s2) # vtable address
1300#    move $t0,$t2
1304:toString_checkTagBit:
1304#    subu $t0,1
1308#    lb $t1,($t0)
1312#    and $t1,0x80
1313##...lui $at,0
1317##...ori $at,$at,0x80
1321##...and $t1,$t1,$at
1324#    beq $t1,$zero,toString_checkTagBit
1328#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1332#    subu $sp,8
1336#    sw $t1,($sp)
1340#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1344#    move $s7,$zero # -4 offset header word
1348#    lw $t4,8($sp) # bytes for hash value
1352#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1356#    addu $t4,8
1360#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1364#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1368#    li $t0,CLASS_String # store string vtable address into ...
1372#    sw $t0,-12($s7) # ... -12 offset in object header
1376#    lw $t2,-12($s2) # our object's vtable address
1380#    lw $t5,4($sp) # number characters in prefix
1384#    lw $t1,12($sp) # number of characters in hashcode
1388#    addu $t3,$t1,$t5 # number of characters in string ...
1392#    addu $t3,1 # ... including the '@' character
1396#    subu $t0,$zero,$t3 # store negated length into ...
1400#    sw $t0,-4($s7) # ... -4 offset header word
1404#    lw $t0,-8($s7) # get -8 offset header-word
1408#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1409##...slt $at,$t0,$zero
1413##...beq $at,$zero,1432
1416#    and $t0,0xff # mask off object's hash value ...
1417##...lui $at,0
1421##...ori $at,$at,0xff
1425##...and $t0,$t0,$at
1428#    sw $t0,-8($s7) # ... and store back into -8 header-word
1432:skipMask_toString:
1432#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1436#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1440#    subu $t4,$t2,$t5
1444:toString_copyLoop:    
1444#    lb $t3,($t4)
1448#    and $t3,0x7f # mask off sign bit (in case first word)
1449##...lui $at,0
1453##...ori $at,$at,0x7f
1457##...and $t3,$t3,$at
1460#    sb $t3,-8($t0)
1464#    addu $t4,1
1468#    addu $t0,1
1472#    blt $t4,$t2,toString_copyLoop
1473##...slt $at,$t4,$t2
1477##...bne $at,$zero,1444

    # copy the '@' sign
1480#    li $t3,'@'
1484#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1488#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1492#    lw $t3,20($sp) # hash code to print
1496:toString_hashCopyLoop:
1496#    and $t4,$t3,0xf
1500#    srl $t3,4
1504#    lb $t4,hexChars($t4)
1508#    sb $t4,-8($t2)
1512#    subu $t2,$t2,1
1516#    bgt $t2,$t0,toString_hashCopyLoop
1517##...slt $at,$t0,$t2
1521##...bne $at,$zero,1496

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1524#    addu $sp,28
1528#    lw $ra,($sp)
1532#    addu $sp,4
1536#    move $t0, $s7 # return string we created
1540#    jr $ra

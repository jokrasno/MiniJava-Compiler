##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1120:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1120#    lw $t0,-8($s2) # get word with hash bits from this
1124#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1128#    addu $t0,$t1

1132#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1136:mth_equals_Object:
1136#    move $t0,$s2 # first pointer (this)
1140#    lw $t1,($sp) # second pointer
1144#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1145##...subu $at,$t0,$t1
1149##...sltiu $t0,$at,1

1152#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1156:mth_hashCode_String:
1156#    move $t0,$s2 # put this pointer in t0

1160#    li $t2,0 # current hash value
1164#    lw $t1,-4($t0) # negative of number of characters in string
1168#    beq $t1,$zero,done_hashCode_String # if zero length => done
1172#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1176#    and $t0,0xfffffffc # adjust for padding
1177##...lui $at,65535
1181##...ori $at,$at,0xfffc
1185##...and $t0,$t0,$at
1188#    subu $t1,$t0,$t1 # address at end of string +12
1192:loop_hashCode_String:    
1192#    sll $t4,$t2,5 # multiply by 32
1196#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1200#    lbu $t3,-12($t0) # current character
1204#    addu $t2,$t3 # add in current character
1208#    addu $t0,1 # go to next character's address
1212#    bne $t0,$t1,loop_hashCode_String # loop back if more
1216:done_hashCode_String:    

    # push int on stack
1216#    move $t0, $t2 # put $t2 in return slot
1220#    jr $ra # return

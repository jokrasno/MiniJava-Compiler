    # buffer and return
3176#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
3180#    jr $ra # return
    
3184:  doReadCh:
    # we need to actually read a character: read and return
3184#    li $v0,12 # use system call to read a character
3188#    syscall
3192#    jr $ra # return

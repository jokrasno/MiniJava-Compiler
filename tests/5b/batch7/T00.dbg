    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
3932#    lw $t1,cur_seg
3936#    la $t0,seg0_start
3940#    beq $t1,$zero,gcSkip4
3944#    la $t0,seg1_start
3945##...lui $t0,16
3949##...addiu $t0,$t0,5112


3952:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
3952#    bgeu $t0,$s3,gcFinishUp
3953##...sltu $at,$t0,$s3
3957##...beq $at,$zero,4248

    ###### begin outer loop to copy all non-stack-direct objects ######

3960:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
3960#    lw $t1,($t0) # (what will be) first header word for current object
3964#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
3968#    bge $t2,$zero,gcSkip4a # are there hash bits?
3969##...slt $at,$t2,$zero
3973##...beq $at,$zero,3988
3976#    and $t2,0xff # mask off hash bits
3977##...lui $at,0
3981##...ori $at,$at,0xff
3985##...and $t2,$t2,$at
3988:gcSkip4a:    
3988#    sll $t2,$t2,2 # # data bytes
3992#    addu $t2,$t2,8 # to skip header words
3996#    addu $t2,$t0,$t2 # pointer to new object
4000#    lw $t3,-8($t2) # word to swap
4004#    sw $t1,-8($t2) # store header word
4008#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
4012#    lw $t1,-12($t2) # vtable pointer
4016#    li $t0,dataArrayVTableStart # address of vtable for first data array
4020#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
4021##...slt $at,$t1,$t0
4025##...bne $at,$zero,4044

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
4028:  skipToNextObj:
4028#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
4032#    sll $t1,$t1,2 # convert to byte-count
4036#    addu $t0,$t2,$t1 # skip over object
4040#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
4044:  gcNotDataArray:
4044#    lw $t3,-4($t2) # # object words (negative treated as zero)
4048#    bge $t3,$zero,gcH2Neg2
4049##...slt $at,$t3,$zero
4053##...beq $at,$zero,4060
4056#    move $t3,$zero
4060:  gcH2Neg2:
4060#    sll $t3,$t3,2 # # object bytes
4064#    move $t0,$t2 # address of first pointer in object
4068#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
4072#    beq $t0,$s1,gcTestIterDone2
    
4076:  gcNextPointerInObject:
    # get pointer from object
4076#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
4080#    bleu $t1,$t6,gcGoNextPointerSlot
4081##...sltu $at,$t6,$t1
4085##...beq $at,$zero,4228
4088#    bgtu $t1,$t7,gcGoNextPointerSlot
4089##...sltu $at,$t7,$t1
4093##...bne $at,$zero,4228

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4096#    lw $t8,-8($t1) # possible forwarding tag
4100#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
4104#    lw $t8,-4($t1) # forwarding pointer: object's new address
4108#    sw $t8,($t0) # update pointer in object
4112#    j gcGoNextPointerSlot # do next iteration

4116:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
4116#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
4117##...slt $at,$t8,$zero
4121##...beq $at,$zero,4136
4124#    and $t8,0xff # mask off hash bits
4125##...lui $at,0
4129##...ori $at,$at,0xff
4133##...and $t8,$t8,$at

4136:  gcSkip5:
4136#    sll $t8,$t8,2 # bytes in negative-offset portion ...
4140#    addu $t8,$t8,8 # ... add in bytes for header-words
4144#    subu $t4,$t1,$t8 # address of first word of source object
4148#    lw $t3,-4($t1) # # words in positive-offset portion
4152#    bge $t3,$zero,gcNoNeg
4153##...slt $at,$t3,$zero
4157##...beq $at,$zero,4164
4160#    move $t3,$zero # negative treated as zero
4164:  gcNoNeg:
4164#    sll $t3,$t3,2 # bytes in negative-offset portion
4168#    addu $t3,$t3,$t1 # address one word past last word of source

4172#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4176#    lw $s0,($t4)
4180#    lw $t9,-8($t1)
4184#    sw $t9,($t4)
4188#    sw $s0,-8($t1)

    # copy all source bytes to the target
4192:  gCinnerCopy2:
4192#    lw $s0,($t4)
4196#    sw $s0,($s3)
4200#    addu $t4,$t4,4
4204#    addu $s3,$s3,4
4208#    bltu $t4,$t3,gCinnerCopy2
4209##...sltu $at,$t4,$t3
4213##...bne $at,$zero,4192

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4216#    sw $zero,-8($t1) # 0 in first header-slot
4220#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4224#    sw $t8,($t0)

4228:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4228#    addu $t0,$t0,4
4232#    bltu $t0,$s1,gcNextPointerInObject
4233##...sltu $at,$t0,$s1
4237##...bne $at,$zero,4076

4240:  gcTestIterDone2:
4240#    bltu $t0,$s3,gcHeapCopyLoop
4241##...sltu $at,$t0,$s3
4245##...bne $at,$zero,3960

    ###### end outer loop to copy all non-stack-direct objects ######

4248:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4248#    lw $s2,($sp)
4252#    addu $sp,$sp,4

    # mark us as having already GC'd
4256#    move $t5,$s5

    # go try and allocate again
4260#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4264:vm_init:

    # mark bottom of stack
4264#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4268#    move $s2,$zero

    #set up the "five" register
4272#    li $s5,5

4276#    la $s3,seg0_start
4280#    la $s4,seg0_end
4281##...lui $s4,16
4285##...addiu $s4,$s4,5112
    
    # return
4288#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4292:divide:
    # get parameters; abort if divisor zero
4292#    lw $t0,($sp)
4296#    lw $t1,8($sp)
4300#    beq $t0,$zero,divByZeroError
    
    # perform division
4304#    div $t1,$t0
4308#    mflo $t0

    # store result, adjust stack and return
4312#    addu $sp,$sp,8 # adjust stack
4316#    sw $t0,($sp) # store result
4320#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4324:remainder:
    # get parameters; abort if divisor zero
4324#    lw $t0,($sp)
4328#    lw $t1,8($sp)
4332#    beq $t0,$zero,divByZeroError
    
    # perform division
4336#    div $t1,$t0
4340#    mfhi $t0

    # store result, adjust stack and return
4344#    addu $sp,$sp,8 # adjust stack
4348#    sw $t0,($sp) # store result
4352#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4356:checkCast:
    # get object, allow immediately if null
4356#    lw $t2,($sp)
4360#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4364#    lw $t2,-12($t2) # vtable address
4368#    bge $t2,$t1,castException
4369##...slt $at,$t2,$t1
4373##...beq $at,$zero,4508
4376#    blt $t2,$t0,castException
4377##...slt $at,$t2,$t0
4381##...bne $at,$zero,4508
    
    # return, leaving object unchanged on stack
4384:  checkCastReturn:    
4384#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4388:instanceOf:
    # get object, go return false if null
4388#    lw $t2,($sp)
4392#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4396#    lw $t2,-12($t2) # vtable address
4400#    sge $t0,$t2,$t0 # are we >= the lower limit?
4401##...slt $t0,$t2,$t0
4405##...xori $t0,$t0,0x1
4408#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4412#    and $t2,$t0,$t1
4416#    sw $t2,($sp)
4420:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4420#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4424:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4424#    li $v0,4 # syscall-code for print-string
4428#    syscall
4432:exit:
    # print termination message
4432#    li $v0,4 # syscall-code for print-string
4436#    la $a0,exitString
4440#    syscall

    # terminate execution
4444#    li $v0,10 #syscall-code for "exit"
4448#    syscall

4452:outOfHeapMemory:
4452#    la $a0,heapMemoryMsg
4456#    j exitError
4460:divByZeroError:
4460#    la $a0,divByZeroMsg
4464#    j exitError
4468:strIndexOutOfBounds:
4468#    la $a0,strIndexOutOfBoundsMsg
4472#    j exitError
4476:arrayIndexOutOfBounds:
4476#    la $a0,arrayIndexOutOfBoundsMsg
4480#    j exitError
4484:arraySizeOutOfBounds:
4484#    la $a0,arraySizeOutOfBoundsMsg
4488#    j exitError
4492:nullPtrException:
4492#    la $a0,nullPtrExceptionMsg
4496#    j exitError
4500:badIntegerFormat:
4500#    la $a0,badIntegerFormatMsg
4504#    j exitError
4508:castException:
4508#    la $a0,castExceptionMsg
4512#    j exitError
############## data section ################
    .data
4748:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4764:cur_seg:
    .word 0

4768:lastCharRead:
    .word -2 # -2 => no buffered character
4772:prevHashConstant:
    .word 0x2785173c
4776:gcCount:
    .word 0

4780:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4807:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4830:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4865:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4899:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4932:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4963:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5011:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5032:gcMsg: 
      .asciiz "\nGC!\n"
5038:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5070:nullStr:
    .asciiz "null"
5075:trueString:
    .asciiz "true"
5080:falseString:
    .asciiz "false"
5086:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5105:newlineString:
    .asciiz "\n"
    
    .align 2
5108:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5112:seg0_start:
    .space 0x100000
1053688:seg0_end:
1053688:seg1_start:
    .space 0x100000
2102264:seg1_end:

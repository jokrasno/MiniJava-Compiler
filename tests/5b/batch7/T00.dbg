3033##...beq $at,$zero,3040
3036#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
3040:  itsNonNegLoop:
3040#    divu $t1,$t3
3044#    mflo $t1 # quotient
3048#    mfhi $t4 # remainder
3052#    addu $t4,$t4,'0' # turn remainder into digit
3056#    subu $sp,$sp,4

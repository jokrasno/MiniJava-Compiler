# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1412:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1412#    lw $t0,-8($s2) # get word with hash bits from this
1416#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1420#    addu $t0,$t1

1424#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1428:mth_equals_Object:
1428#    move $t0,$s2 # first pointer (this)
1432#    lw $t1,($sp) # second pointer
1436#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1437##...subu $at,$t0,$t1
1441##...sltiu $t0,$at,1

1444#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1448:mth_hashCode_String:
1448#    move $t0,$s2 # put this pointer in t0

1452#    li $t2,0 # current hash value
1456#    lw $t1,-4($t0) # negative of number of characters in string
1460#    beq $t1,$zero,done_hashCode_String # if zero length => done
1464#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1468#    and $t0,0xfffffffc # adjust for padding
1469##...lui $at,65535
1473##...ori $at,$at,0xfffc
1477##...and $t0,$t0,$at
1480#    subu $t1,$t0,$t1 # address at end of string +12
1484:loop_hashCode_String:    
1484#    sll $t4,$t2,5 # multiply by 32
1488#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1492#    lbu $t3,-12($t0) # current character
1496#    addu $t2,$t3 # add in current character
1500#    addu $t0,1 # go to next character's address
1504#    bne $t0,$t1,loop_hashCode_String # loop back if more
1508:done_hashCode_String:    

    # push int on stack
1508#    move $t0, $t2 # put $t2 in return slot
1512#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1516:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1516#    subu $sp,4
1520#    sw $ra,($sp)
    
    # get hash value
1524#    lw $t2,-12($s2) # vtable address
1528#    lw $t0,($t2) # method address
1532#    jalr $t0
1536#    subu $sp,8 # push result (int in $t0) on stack
1540#    sw $s5,4($sp)
1544#    sw $t0,($sp)

    # compute print-size of hash value
1548#    li $t0, 1
1552#    lw $t1, ($sp)
1556#    srl $t1,$t1,4
1560#    beq $t1,$zero,toString_skip_loop
1564:toString_loop_top:
1564#    addu $t0,1
1568#    srl $t1,$t1,4
1572#    bne $t1,$zero,toString_loop_top
1576:toString_skip_loop:
1576#    subu $sp,8
1580#    sw $s5,4($sp)
1584#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1588#    lw $t2,-12($s2) # vtable address
1592#    move $t0,$t2
1596:toString_checkTagBit:
1596#    subu $t0,1
1600#    lb $t1,($t0)
1604#    and $t1,0x80
1605##...lui $at,0
1609##...ori $at,$at,0x80
1613##...and $t1,$t1,$at
1616#    beq $t1,$zero,toString_checkTagBit
1620#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1624#    subu $sp,8
1628#    sw $t1,($sp)
1632#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1636#    move $s7,$zero # -4 offset header word
1640#    lw $t4,8($sp) # bytes for hash value
1644#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1648#    addu $t4,8
1652#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1656#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1660#    li $t0,CLASS_String # store string vtable address into ...
1664#    sw $t0,-12($s7) # ... -12 offset in object header
1668#    lw $t2,-12($s2) # our object's vtable address
1672#    lw $t5,4($sp) # number characters in prefix
1676#    lw $t1,12($sp) # number of characters in hashcode
1680#    addu $t3,$t1,$t5 # number of characters in string ...
1684#    addu $t3,1 # ... including the '@' character
1688#    subu $t0,$zero,$t3 # store negated length into ...
1692#    sw $t0,-4($s7) # ... -4 offset header word
1696#    lw $t0,-8($s7) # get -8 offset header-word
1700#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1701##...slt $at,$t0,$zero
1705##...beq $at,$zero,1724
1708#    and $t0,0xff # mask off object's hash value ...
1709##...lui $at,0
1713##...ori $at,$at,0xff
1717##...and $t0,$t0,$at
1720#    sw $t0,-8($s7) # ... and store back into -8 header-word
1724:skipMask_toString:
1724#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1728#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1732#    subu $t4,$t2,$t5
1736:toString_copyLoop:    
1736#    lb $t3,($t4)
1740#    and $t3,0x7f # mask off sign bit (in case first word)
1741##...lui $at,0
1745##...ori $at,$at,0x7f
1749##...and $t3,$t3,$at
1752#    sb $t3,-8($t0)
1756#    addu $t4,1
1760#    addu $t0,1
1764#    blt $t4,$t2,toString_copyLoop
1765##...slt $at,$t4,$t2
1769##...bne $at,$zero,1736

    # copy the '@' sign
1772#    li $t3,'@'
1776#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1780#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1784#    lw $t3,20($sp) # hash code to print
1788:toString_hashCopyLoop:
1788#    and $t4,$t3,0xf
1792#    srl $t3,4
1796#    lb $t4,hexChars($t4)
1800#    sb $t4,-8($t2)
1804#    subu $t2,$t2,1
1808#    bgt $t2,$t0,toString_hashCopyLoop
1809##...slt $at,$t0,$t2
1813##...bne $at,$zero,1788

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1816#    addu $sp,28
1820#    lw $ra,($sp)
1824#    addu $sp,4
1828#    move $t0, $s7 # return string we created
1832#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1836:mth_equals_String:
    
    # quick test for obvious false
1836#    lw $t0,($sp) # second parameter
1840#    beq $t0,$zero,goEsFalse # go return false if null
1844#    lw $t1,-12($t0) # vtable pointer
1848#    la $t2,CLASS_String # string vtable pointer
1852#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1856#    subu $sp,12
1860#    sw $ra,8($sp)
1864#    sw $s2,4($sp)
1868#    sw $t0,($sp)
1872#    jal mth_compareTo_String
1876#    lw $s2, 4($sp) #restore this pointer and pop parameters
1880#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1884#    seq $t0,$t0,$zero
1885##...subu $at,$t0,$zero
1889##...sltiu $t0,$at,1

    # pop return address and return $t0
1892#    lw $ra,($sp)
1896#    addu $sp,4

1900#    jr $ra # return
    
1904:goEsFalse:
    # put 0 in $t0 and return
1904#    li $t0, 0
1908#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1912:mth_toString_String:
    #we are a string, so return this.
1912#    move $t0, $s2
1916#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1920:mth_readLine_Lib:
    
1920#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1924#    sw $ra, 4($sp) # save $ra
1928#    move $t1,$sp # save "original" sp

1932:  doRead:

    # read the character
1932#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1936#    subu $t2,$v0,13
1940#    bne $t2,$zero,notReturnRL
1944#    jal readLogicalChar
1948#    subu $t2,$v0,10 # check for newline
1952#    beq $t2,$zero,foundNewLine
1956#    sw $v0,lastCharRead # push back character into queue
1960#    j foundNewLine # go process the line

1964:  notReturnRL:

    # at this point, $v0 has our character

1964#    subu $t0,$v0,10
1968#    beq $t0,$zero,foundNewLine
1972#    blt $v0,$zero,foundEof
1973##...slt $at,$v0,$zero
1977##...bne $at,$zero,1992

    # we have a character, so push it onto stack
1980#    subu $sp,$sp,4
1984#    sw $v0,($sp)

    # loop back up to get next character
1988#    j doRead

1992:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1992#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1996#    li $s7, 0 # return-value: null
2000#    j rlReturn # return

2004:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2004#    subu $t0,$t1,$sp # number of chars we read (times 4)
2008#    srl $s6,$t0,2 # number of words on stack with chars
2012#    subu $sp,$sp,4 # push char-count ...
2016#    sw $s6,($sp) # ... onto stack
2020#    addu $t2,$t0,5 # GC tag, incl. for count-word
2024#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2028#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2032#    srl $s6,$s6,2  # data words in object
2036#    move $s7,$zero # object words in object
2040#    jal newObject  # allocate space
    
    # store header words
2044#    la $t0,CLASS_String
2048#    sw $t0,-12($s7)# store class tag (String) into object
2052#    lw $t2,4($sp) # char-count
2056#    sll $t1,$t2,2 # 4 times number of chars
2060#    subu $t2,$zero,$t2 # negative of char-count
2064#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2068#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2072#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2073##...slt $at,$t0,$zero
2077##...beq $at,$zero,2096
2080#    and $t0,0xff # mask off object's hash value ...
2081##...lui $at,0
2085##...ori $at,$at,0xff
2089##...and $t0,$t0,$at
2092#    sw $t0,-8($s7) # ... and store back into -8 header-word
2096:  skipMask_readLine:

2096#    sll $t0,$t0,2 # data bytes in object
2100#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2104#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2108#    addu $sp,$sp,8 # pop redundant object-pointer and count
2112#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2116#    beq $sp,$t1,rlReturn
2120:  charCopyLoop:
2120#    lw $t2,($sp)
2124#    sb $t2,-9($t0)
2128#    addu $sp,$sp,4
2132#    subu $t0,$t0,1
2136#    bne $sp,$t1,charCopyLoop
2140:  rlReturn:

2140#    lw $ra, 4($sp)
2144#    addu $sp, 8   # pop $ra and pointless word off stack
2148#    move $t0, $s7 # return string we allocated in $s7
2152#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2156:mth_readInt_Lib:

    # save $ra by pushing onto stack
2156#    subu $sp,$sp,4
2160#    sw $ra,($sp)

2164:  riSkipWhiteLoop:
    # read a character
2164#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2168#    subu $t0,$v0,32
2172#    bgt $t0,$zero,nonWhite
2173##...slt $at,$zero,$t0
2177##...bne $at,$zero,2220
2180#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2184#    subu $t0,$v0,10
2188#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2192#    subu $t0,$v0,9
2196#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2200#    subu $t0,$v0,13
2204#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2208#    subu $t0,$v0,12
2212#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2216#    j badIntegerFormat # illegal integer char: abort program

2220:  nonWhite:
2220#    subu $t0,$v0,'-'
2224#    li $t4,1 # final multiplier
2228#    bne $t0,$zero,helpReadInt # go read
2232#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2236#    jal readLogicalChar

2240:  helpReadInt:
2240#    li $t2,10
2244#    subu $t1,$v0,'0' # convert digit to 0-9 value
2248#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2249##...sltu $at,$t1,$t2
2253##...beq $at,$zero,4500
2256#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2260:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2260#    jal readLogicalChar # read next character
2264#    subu $t1,$v0,'0' # convert digit to 0-9 value
2268#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2269##...sltu $at,$t1,$t2
2273##...beq $at,$zero,2292

2276#    mul $t3,$t3,$t2 # multiply old value by 10
2277##...mult $t3,$t2
2281##...mflo $t3
2284#    addu $t3,$t3,$t1 # add in value of new digit

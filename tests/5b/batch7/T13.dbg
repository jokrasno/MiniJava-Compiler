
########################################################
# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
2892:mth_compareTo_String:
    # get string pointers and check parameter for null
2892#    lw $t0,($sp) # second string
2896#    beq $t0,$zero,nullPtrException
2900#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
2904#    lw $t2,-4($t0) # negative length of second string
2908#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
2912#    slt $t4,$t3,$t2
2916#    slt $t5,$t2,$t3
2920#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
2924#    lw $t2,-8($t0) # # data words in second string
2928#    lw $t3,-8($t1) # # data words in first string
2932#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
2936#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
2940#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
2944#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
2948#    beq $zero,$t5,skipStrCmpLenzz
2952#    move $t2,$t3
2956:  skipStrCmpLenzz:
2956#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
2960:  cmpLoopzz:
2960#    lw $t3,-8($t1) # word from str2
2964#    lw $t4,-8($t0) # word from str1
2968#    bne $t3,$t4,cmpNotEqualzz
2972#    addu $t1,$t1,4
2976#    addu $t0,$t0,4
2980#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
2984#    j cmpHitLimitzz

2988:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
2988#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
2992#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
2996#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
3000:  cmpHitLimitzz:
3000#    move $t0, $t5 # store return value
3004#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
3008:readLogicalChar:

    # check if we already have a character
3008#    lw $v0,lastCharRead
3012#    li $t0,-2
3016#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
3020#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
3024#    jr $ra # return
    
3028:  doReadCh:
    # we need to actually read a character: read and return
3028#    li $v0,12 # use system call to read a character
3032#    syscall
3036#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
3040:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
3040#    blt $s7,$zero arraySizeOutOfBounds
3041##...slt $at,$s7,$zero
3045##...bne $at,$zero,4036

    # mark the fact that we have not yet GC'd for this allocation
3048#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

3052:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
3052#    addu $t0,$s6,$s7
3056#    sll $t0,$t0,2
3060#    addu $t0,$t0,8 # amount of memory needed
3064#    addu $t1,$t0,$s3
3068#    bgtu $t1,$s4,doGC
3069##...sltu $at,$s4,$t1
3073##...bne $at,$zero,3196

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
3076#    move $t2,$s3
3080:  zeroObjLoop:
3080#    sw $zero,($s3)
3084#    lw $zero,($s3)

3088#    addu $s3,4
3092#    bltu $s3,$t1,zeroObjLoop
3093##...sltu $at,$s3,$t1
3097##...bne $at,$zero,3080

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
3100#    sll $t0,$s7,2    # number of post-header bytes
3104#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
3108#    li $t2,255
3112#    bgeu $s6,$t2 firstHeaderLarge
3113##...sltu $at,$s6,$t2
3117##...beq $at,$zero,3164
3120#    lw $t1,prevHashConstant
3124#    addu $t1,0x12b68fd2
3125##...lui $at,4791
3129##...addiu $at,$at,-28718
3133##...addu $t1,$at,$t1
3136#    sw $t1,prevHashConstant # update hash constant
3140#    or $t1,0x80000000 # set top bit
3141##...lui $at,32768
3145##...or $t1,$at,$t1
3148#    and $t1,0xffffff00 # clear low bit
3149##...lui $at,65535
3153##...ori $at,$at,0xff00
3157##...and $t1,$t1,$at
3160#    or $s6,$t1
3164:firstHeaderLarge:
3164#    sw $s6,-8($t0) # store header-1 value
3168#    lw $zero,-8($t0)

    # store second header-value
3172#    sw $s7,-4($t0)   # second header-word
3176#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
3180#    move $s7,$t0
3184#    subu $sp,$sp,4
3188#    sw $t0,($sp)

3192#    jr $ra
    
3196:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
3196#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
3200#    lw $t5,gcCount
3204#    addu $t5,1
3208#    sw $t5,gcCount

    # save $s2 (our only rooted register) on the stack
    # so that the garbage collector processes it
3212#    subu $sp,$sp,4
3216#    sw $s2,($sp)

    # set $s3 to the address of the new segment and the
    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
3220#    lw $t0,cur_seg
3224#    move $t7,$s4
3228#    la $t6,seg1_start
3229##...lui $t6,16
3233##...addiu $t6,$t6,4744
3236#    la $s3,seg0_start
3240#    la $s4,seg0_end
3241##...lui $s4,16
3245##...addiu $s4,$s4,4744
3248#    sw $zero,cur_seg
3252#    bne $t0,$zero,skipGc1
3256#    la $t6,seg0_start
3260#    la $s3,seg1_start
3261##...lui $s3,16
3265##...addiu $s3,$s3,4744
3268#    la $s4,seg1_end
3269##...lui $s4,32
3273##...addiu $s4,$s4,4744
3276#    sw $s5,cur_seg
3280:  skipGc1:
3280#    li $t5,0x80000000
3284#    lw $t0,stack_bottom
3288#    subu $t0,4


    ###############################################################
    # at this point:
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first address of the target space
    # - $s4 contains the limit address of the target space
    # - cur_seg has been updated to refer to the target space
    # - $t0 contains the address of the deepest stack element
    # - $sp contains the address of the top stack element
    # - $s2 is available for use, having been pushed onto the stack
    # - $t5 contains the value 0x80000000
    ###############################################################

    ###### begin outer loop to copy all stack-direct objects ######

3292:  gcStackCopyLoop:
3292#    lw $t1,($t0) # current stack element

    # test if we have a GC tag
3296#    sll $t2,$t1,31 # zero iff low bit was zero
3300#    bne $t2,$zero,gcBump # go skip data values if low bit not zero

    # bump stack-address pointer
3304#    subu $t0,$t0,4

    # if value is out of range (which includes null=0), and is
    # therefore does not refer to an object on the heap, just go
    # loop back and do the next one
3308#    bleu $t1,$t6,gcTestIterDone1
3309##...sltu $at,$t6,$t1
3313##...beq $at,$zero,3476
3316#    bgtu $t1,$t7,gcTestIterDone1
3317##...sltu $at,$t7,$t1
3321##...bne $at,$zero,3476

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3324#    lw $t2,-8($t1) # possible forwarding tag
3328#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
3332#    lw $t2,-4($t1) # forwarding pointer: object's new address
3336#    sw $t2,4($t0) # update stack value
3340#    j gcTestIterDone1 # do next iteration

3344:  gcNoForward1:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    # compute the amount of space that is needed
3344#    bge $t2,$zero,gcSkip2
3345##...slt $at,$t2,$zero
3349##...beq $at,$zero,3364
3352#    and $t2,0xff #### mask off hash value
3353##...lui $at,0
3357##...ori $at,$at,0xff
3361##...and $t2,$t2,$at
    #### OLD
    #### subu $t2,$zero,$t2 # set to 1 if -1 (number of data words)

3364:  gcSkip2:
3364#    sll $t2,$t2,2
3368#    addu $t2,$t2,8
3372#    subu $t4,$t1,$t2 # address of first word of source
3376#    lw $t3,-4($t1) # number of object words (negative means zero)
3380#    bge $t3,$zero,gcH2Neg1
3381##...slt $at,$t3,$zero
3385##...beq $at,$zero,3392
3388#    move $t3,$zero
3392:  gcH2Neg1:
3392#    sll $t3,$t3,2
3396#    addu $t3,$t3,$t1 # address one word past last word of source

3400#    addu $t2,$s3,$t2 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object (i.e., the address just beyond the object's header)
    # - $t2 contains the pointer to the target object
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0-2
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger" in the target space
3404#    lw $s0,($t4)
3408#    lw $s1,-8($t1)
3412#    sw $s1,($t4)
3416#    sw $s0,-8($t1)
    
    # copy all source bytes to the target
3420:  gCinnerCopy1:
3420#    lw $s0,($t4)
3424#    sw $s0,($s3)
3428#    addu $t4,$t4,4
3432#    addu $s3,$s3,4
3436#    bltu $t4,$t3,gCinnerCopy1
3437##...sltu $at,$t4,$t3
3441##...bne $at,$zero,3420

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3444#    sw $zero,-8($t1) # 0 in first header-slot
3448#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
3452#    sw $t2,4($t0)
3456#    lw $zero,-8($t2)
3460#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
3464#    j gcTestIterDone1

3468:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
3468#    subu $t0,$t0,$t1
3472#    subu $t0,$t0,3

3476:  gcTestIterDone1:
3476#    bgeu $t0,$sp,gcStackCopyLoop
3477##...sltu $at,$t0,$sp
3481##...beq $at,$zero,3292

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
3484#    lw $t1,cur_seg
3488#    la $t0,seg0_start
3492#    beq $t1,$zero,gcSkip4
3496#    la $t0,seg1_start
3497##...lui $t0,16
3501##...addiu $t0,$t0,4744


3504:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
3504#    bgeu $t0,$s3,gcFinishUp
3505##...sltu $at,$t0,$s3
3509##...beq $at,$zero,3800

    ###### begin outer loop to copy all non-stack-direct objects ######

3512:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
3512#    lw $t1,($t0) # (what will be) first header word for current object
3516#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
3520#    bge $t2,$zero,gcSkip4a # are there hash bits?
3521##...slt $at,$t2,$zero
3525##...beq $at,$zero,3540
3528#    and $t2,0xff # mask off hash bits
3529##...lui $at,0
3533##...ori $at,$at,0xff
3537##...and $t2,$t2,$at
3540:gcSkip4a:    
3540#    sll $t2,$t2,2 # # data bytes
3544#    addu $t2,$t2,8 # to skip header words
3548#    addu $t2,$t0,$t2 # pointer to new object
3552#    lw $t3,-8($t2) # word to swap
3556#    sw $t1,-8($t2) # store header word
3560#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3564#    lw $t1,-12($t2) # vtable pointer
3568#    li $t0,dataArrayVTableStart # address of vtable for first data array
3572#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3573##...slt $at,$t1,$t0
3577##...bne $at,$zero,3596

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3580:  skipToNextObj:
3580#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3584#    sll $t1,$t1,2 # convert to byte-count
3588#    addu $t0,$t2,$t1 # skip over object
3592#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3596:  gcNotDataArray:
3596#    lw $t3,-4($t2) # # object words (negative treated as zero)
3600#    bge $t3,$zero,gcH2Neg2
3601##...slt $at,$t3,$zero
3605##...beq $at,$zero,3612
3608#    move $t3,$zero
3612:  gcH2Neg2:
3612#    sll $t3,$t3,2 # # object bytes
3616#    move $t0,$t2 # address of first pointer in object
3620#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3624#    beq $t0,$s1,gcTestIterDone2
    
3628:  gcNextPointerInObject:
    # get pointer from object
3628#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3632#    bleu $t1,$t6,gcGoNextPointerSlot
3633##...sltu $at,$t6,$t1
3637##...beq $at,$zero,3780
3640#    bgtu $t1,$t7,gcGoNextPointerSlot
3641##...sltu $at,$t7,$t1
3645##...bne $at,$zero,3780

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3648#    lw $t8,-8($t1) # possible forwarding tag
3652#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3656#    lw $t8,-4($t1) # forwarding pointer: object's new address
3660#    sw $t8,($t0) # update pointer in object
3664#    j gcGoNextPointerSlot # do next iteration

3668:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3668#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3669##...slt $at,$t8,$zero
3673##...beq $at,$zero,3688
3676#    and $t8,0xff # mask off hash bits
3677##...lui $at,0
3681##...ori $at,$at,0xff
3685##...and $t8,$t8,$at

3688:  gcSkip5:
3688#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3692#    addu $t8,$t8,8 # ... add in bytes for header-words
3696#    subu $t4,$t1,$t8 # address of first word of source object
3700#    lw $t3,-4($t1) # # words in positive-offset portion
3704#    bge $t3,$zero,gcNoNeg
3705##...slt $at,$t3,$zero
3709##...beq $at,$zero,3716
3712#    move $t3,$zero # negative treated as zero
3716:  gcNoNeg:
3716#    sll $t3,$t3,2 # bytes in negative-offset portion
3720#    addu $t3,$t3,$t1 # address one word past last word of source

3724#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3728#    lw $s0,($t4)
3732#    lw $t9,-8($t1)
3736#    sw $t9,($t4)
3740#    sw $s0,-8($t1)

    # copy all source bytes to the target
3744:  gCinnerCopy2:
3744#    lw $s0,($t4)
3748#    sw $s0,($s3)
3752#    addu $t4,$t4,4
3756#    addu $s3,$s3,4
3760#    bltu $t4,$t3,gCinnerCopy2
3761##...sltu $at,$t4,$t3
3765##...bne $at,$zero,3744

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3768#    sw $zero,-8($t1) # 0 in first header-slot
3772#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3776#    sw $t8,($t0)

3780:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3780#    addu $t0,$t0,4
3784#    bltu $t0,$s1,gcNextPointerInObject
3785##...sltu $at,$t0,$s1
3789##...bne $at,$zero,3628

3792:  gcTestIterDone2:
3792#    bltu $t0,$s3,gcHeapCopyLoop
3793##...sltu $at,$t0,$s3
3797##...bne $at,$zero,3512

    ###### end outer loop to copy all non-stack-direct objects ######

3800:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3800#    lw $s2,($sp)
3804#    addu $sp,$sp,4

    # mark us as having already GC'd
3808#    move $t5,$s5

    # go try and allocate again
3812#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3816:vm_init:

    # mark bottom of stack
3816#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3820#    move $s2,$zero

    #set up the "five" register
3824#    li $s5,5

3828#    la $s3,seg0_start
3832#    la $s4,seg0_end
3833##...lui $s4,16
3837##...addiu $s4,$s4,4744
    
    # return
3840#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3844:divide:
    # get parameters; abort if divisor zero
3844#    lw $t0,($sp)
3848#    lw $t1,8($sp)
3852#    beq $t0,$zero,divByZeroError
    
    # perform division
3856#    div $t1,$t0
3860#    mflo $t0

    # store result, adjust stack and return
3864#    addu $sp,$sp,8 # adjust stack
3868#    sw $t0,($sp) # store result
3872#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3876:remainder:
    # get parameters; abort if divisor zero
3876#    lw $t0,($sp)
3880#    lw $t1,8($sp)
3884#    beq $t0,$zero,divByZeroError
    
    # perform division
3888#    div $t1,$t0
3892#    mfhi $t0

    # store result, adjust stack and return
3896#    addu $sp,$sp,8 # adjust stack
3900#    sw $t0,($sp) # store result
3904#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3908:checkCast:
    # get object, allow immediately if null
3908#    lw $t2,($sp)
3912#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3916#    lw $t2,-12($t2) # vtable address
3920#    bge $t2,$t1,castException
3921##...slt $at,$t2,$t1
3925##...beq $at,$zero,4060
3928#    blt $t2,$t0,castException
3929##...slt $at,$t2,$t0
3933##...bne $at,$zero,4060
    
    # return, leaving object unchanged on stack
3936:  checkCastReturn:    
3936#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3940:instanceOf:
    # get object, go return false if null
3940#    lw $t2,($sp)
3944#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3948#    lw $t2,-12($t2) # vtable address
3952#    sge $t0,$t2,$t0 # are we >= the lower limit?
3953##...slt $t0,$t2,$t0
3957##...xori $t0,$t0,0x1
3960#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3964#    and $t2,$t0,$t1
3968#    sw $t2,($sp)
3972:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3972#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3976:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3976#    li $v0,4 # syscall-code for print-string
3980#    syscall
3984:exit:
    # print termination message
3984#    li $v0,4 # syscall-code for print-string
3988#    la $a0,exitString
3992#    syscall

    # terminate execution
3996#    li $v0,10 #syscall-code for "exit"
4000#    syscall

4004:outOfHeapMemory:
4004#    la $a0,heapMemoryMsg
4008#    j exitError
4012:divByZeroError:
4012#    la $a0,divByZeroMsg
4016#    j exitError
4020:strIndexOutOfBounds:
4020#    la $a0,strIndexOutOfBoundsMsg
4024#    j exitError
4028:arrayIndexOutOfBounds:
4028#    la $a0,arrayIndexOutOfBoundsMsg
4032#    j exitError
4036:arraySizeOutOfBounds:
4036#    la $a0,arraySizeOutOfBoundsMsg
4040#    j exitError
4044:nullPtrException:
4044#    la $a0,nullPtrExceptionMsg
4048#    j exitError
4052:badIntegerFormat:
4052#    la $a0,badIntegerFormatMsg
4056#    j exitError
4060:castException:
4060#    la $a0,castExceptionMsg
4064#    j exitError
############## data section ################
    .data
4380:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4396:cur_seg:
    .word 0

4400:lastCharRead:
    .word -2 # -2 => no buffered character
4404:prevHashConstant:
    .word 0x2785173c
4408:gcCount:
    .word 0

4412:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4439:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4462:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4497:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4531:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4564:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4595:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4643:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4664:gcMsg: 
      .asciiz "\nGC!\n"
4670:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4702:nullStr:
    .asciiz "null"
4707:trueString:
    .asciiz "true"
4712:falseString:
    .asciiz "false"
4718:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4737:newlineString:
    .asciiz "\n"
    
    .align 2
4740:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4744:seg0_start:
    .space 0x100000
1053320:seg0_end:
1053320:seg1_start:
    .space 0x100000
2101896:seg1_end:

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
964:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
964#    lw $t0,-8($s2) # get word with hash bits from this
968#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
972#    addu $t0,$t1

976#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
980:mth_equals_Object:
980#    move $t0,$s2 # first pointer (this)
984#    lw $t1,($sp) # second pointer
988#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
989##...subu $at,$t0,$t1
993##...sltiu $t0,$at,1

996#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1000:mth_hashCode_String:
1000#    move $t0,$s2 # put this pointer in t0

1004#    li $t2,0 # current hash value
1008#    lw $t1,-4($t0) # negative of number of characters in string
1012#    beq $t1,$zero,done_hashCode_String # if zero length => done
1016#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1020#    and $t0,0xfffffffc # adjust for padding
1021##...lui $at,65535
1025##...ori $at,$at,0xfffc
1029##...and $t0,$t0,$at
1032#    subu $t1,$t0,$t1 # address at end of string +12
1036:loop_hashCode_String:    
1036#    sll $t4,$t2,5 # multiply by 32
1040#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1044#    lbu $t3,-12($t0) # current character
1048#    addu $t2,$t3 # add in current character
1052#    addu $t0,1 # go to next character's address
1056#    bne $t0,$t1,loop_hashCode_String # loop back if more
1060:done_hashCode_String:    

    # push int on stack
1060#    move $t0, $t2 # put $t2 in return slot
1064#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1068:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1068#    subu $sp,4
1072#    sw $ra,($sp)
    
    # get hash value
1076#    lw $t2,-12($s2) # vtable address
1080#    lw $t0,($t2) # method address
1084#    jalr $t0
1088#    subu $sp,8 # push result (int in $t0) on stack
1092#    sw $s5,4($sp)
1096#    sw $t0,($sp)

    # compute print-size of hash value
1100#    li $t0, 1
1104#    lw $t1, ($sp)
1108#    srl $t1,$t1,4
1112#    beq $t1,$zero,toString_skip_loop
1116:toString_loop_top:
1116#    addu $t0,1
1120#    srl $t1,$t1,4
1124#    bne $t1,$zero,toString_loop_top
1128:toString_skip_loop:
1128#    subu $sp,8
1132#    sw $s5,4($sp)
1136#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1140#    lw $t2,-12($s2) # vtable address
1144#    move $t0,$t2
1148:toString_checkTagBit:
1148#    subu $t0,1
1152#    lb $t1,($t0)
1156#    and $t1,0x80
1157##...lui $at,0
1161##...ori $at,$at,0x80
1165##...and $t1,$t1,$at
1168#    beq $t1,$zero,toString_checkTagBit
1172#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1176#    subu $sp,8
1180#    sw $t1,($sp)
1184#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1188#    move $s7,$zero # -4 offset header word
1192#    lw $t4,8($sp) # bytes for hash value
1196#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1200#    addu $t4,8
1204#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1208#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1212#    li $t0,CLASS_String # store string vtable address into ...
1216#    sw $t0,-12($s7) # ... -12 offset in object header
1220#    lw $t2,-12($s2) # our object's vtable address
1224#    lw $t5,4($sp) # number characters in prefix
1228#    lw $t1,12($sp) # number of characters in hashcode
1232#    addu $t3,$t1,$t5 # number of characters in string ...
1236#    addu $t3,1 # ... including the '@' character
1240#    subu $t0,$zero,$t3 # store negated length into ...
1244#    sw $t0,-4($s7) # ... -4 offset header word
1248#    lw $t0,-8($s7) # get -8 offset header-word
1252#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1253##...slt $at,$t0,$zero
1257##...beq $at,$zero,1276
1260#    and $t0,0xff # mask off object's hash value ...
1261##...lui $at,0
1265##...ori $at,$at,0xff
1269##...and $t0,$t0,$at
1272#    sw $t0,-8($s7) # ... and store back into -8 header-word
1276:skipMask_toString:
1276#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1280#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1284#    subu $t4,$t2,$t5
1288:toString_copyLoop:    
1288#    lb $t3,($t4)
1292#    and $t3,0x7f # mask off sign bit (in case first word)
1293##...lui $at,0
1297##...ori $at,$at,0x7f
1301##...and $t3,$t3,$at
1304#    sb $t3,-8($t0)
1308#    addu $t4,1
1312#    addu $t0,1
1316#    blt $t4,$t2,toString_copyLoop
1317##...slt $at,$t4,$t2
1321##...bne $at,$zero,1288

    # copy the '@' sign
1324#    li $t3,'@'
1328#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1332#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1336#    lw $t3,20($sp) # hash code to print
1340:toString_hashCopyLoop:
1340#    and $t4,$t3,0xf
1344#    srl $t3,4
1348#    lb $t4,hexChars($t4)
1352#    sb $t4,-8($t2)
1356#    subu $t2,$t2,1
1360#    bgt $t2,$t0,toString_hashCopyLoop
1361##...slt $at,$t0,$t2
1365##...bne $at,$zero,1340

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1368#    addu $sp,28
1372#    lw $ra,($sp)
1376#    addu $sp,4
1380#    move $t0, $s7 # return string we created
1384#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1388:mth_equals_String:
    
    # quick test for obvious false
1388#    lw $t0,($sp) # second parameter
1392#    beq $t0,$zero,goEsFalse # go return false if null
1396#    lw $t1,-12($t0) # vtable pointer
1400#    la $t2,CLASS_String # string vtable pointer
1404#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1408#    subu $sp,12
1412#    sw $ra,8($sp)
1416#    sw $s2,4($sp)
1420#    sw $t0,($sp)
1424#    jal mth_compareTo_String
1428#    lw $s2, 4($sp) #restore this pointer and pop parameters
1432#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1436#    seq $t0,$t0,$zero
1437##...subu $at,$t0,$zero
1441##...sltiu $t0,$at,1

    # pop return address and return $t0
1444#    lw $ra,($sp)
1448#    addu $sp,4

1452#    jr $ra # return
    
1456:goEsFalse:
    # put 0 in $t0 and return
1456#    li $t0, 0
1460#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1464:mth_toString_String:
    #we are a string, so return this.
1464#    move $t0, $s2
1468#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1472:mth_readLine_Lib:
    
1472#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1476#    sw $ra, 4($sp) # save $ra
1480#    move $t1,$sp # save "original" sp

1484:  doRead:

    # read the character
1484#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1488#    subu $t2,$v0,13
1492#    bne $t2,$zero,notReturnRL
1496#    jal readLogicalChar
1500#    subu $t2,$v0,10 # check for newline
1504#    beq $t2,$zero,foundNewLine
1508#    sw $v0,lastCharRead # push back character into queue
1512#    j foundNewLine # go process the line

1516:  notReturnRL:

    # at this point, $v0 has our character

1516#    subu $t0,$v0,10
1520#    beq $t0,$zero,foundNewLine
1524#    blt $v0,$zero,foundEof
1525##...slt $at,$v0,$zero
1529##...bne $at,$zero,1544

    # we have a character, so push it onto stack
1532#    subu $sp,$sp,4
1536#    sw $v0,($sp)

    # loop back up to get next character
1540#    j doRead

1544:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1544#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1548#    li $s7, 0 # return-value: null
1552#    j rlReturn # return

1556:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1556#    subu $t0,$t1,$sp # number of chars we read (times 4)
1560#    srl $s6,$t0,2 # number of words on stack with chars
1564#    subu $sp,$sp,4 # push char-count ...
1568#    sw $s6,($sp) # ... onto stack
1572#    addu $t2,$t0,5 # GC tag, incl. for count-word
1576#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1580#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1584#    srl $s6,$s6,2  # data words in object
1588#    move $s7,$zero # object words in object
1592#    jal newObject  # allocate space
    
    # store header words
1596#    la $t0,CLASS_String
1600#    sw $t0,-12($s7)# store class tag (String) into object
1604#    lw $t2,4($sp) # char-count
1608#    sll $t1,$t2,2 # 4 times number of chars
1612#    subu $t2,$zero,$t2 # negative of char-count
1616#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1620#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1624#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1625##...slt $at,$t0,$zero
1629##...beq $at,$zero,1648
1632#    and $t0,0xff # mask off object's hash value ...
1633##...lui $at,0
1637##...ori $at,$at,0xff
1641##...and $t0,$t0,$at
1644#    sw $t0,-8($s7) # ... and store back into -8 header-word
1648:  skipMask_readLine:

1648#    sll $t0,$t0,2 # data bytes in object
1652#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1656#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1660#    addu $sp,$sp,8 # pop redundant object-pointer and count
1664#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1668#    beq $sp,$t1,rlReturn
1672:  charCopyLoop:
1672#    lw $t2,($sp)
1676#    sb $t2,-9($t0)
1680#    addu $sp,$sp,4
1684#    subu $t0,$t0,1
1688#    bne $sp,$t1,charCopyLoop
1692:  rlReturn:

1692#    lw $ra, 4($sp)
1696#    addu $sp, 8   # pop $ra and pointless word off stack
1700#    move $t0, $s7 # return string we allocated in $s7
1704#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1708:mth_readInt_Lib:

    # save $ra by pushing onto stack
1708#    subu $sp,$sp,4
1712#    sw $ra,($sp)

1716:  riSkipWhiteLoop:
    # read a character
1716#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1720#    subu $t0,$v0,32
1724#    bgt $t0,$zero,nonWhite
1725##...slt $at,$zero,$t0
1729##...bne $at,$zero,1772
1732#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1736#    subu $t0,$v0,10
1740#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1744#    subu $t0,$v0,9
1748#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1752#    subu $t0,$v0,13
1756#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1760#    subu $t0,$v0,12
1764#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1768#    j badIntegerFormat # illegal integer char: abort program

1772:  nonWhite:
1772#    subu $t0,$v0,'-'
1776#    li $t4,1 # final multiplier
1780#    bne $t0,$zero,helpReadInt # go read
1784#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1788#    jal readLogicalChar

1792:  helpReadInt:
1792#    li $t2,10
1796#    subu $t1,$v0,'0' # convert digit to 0-9 value
1800#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1801##...sltu $at,$t1,$t2
1805##...beq $at,$zero,4052
1808#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1812:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1812#    jal readLogicalChar # read next character
1816#    subu $t1,$v0,'0' # convert digit to 0-9 value
1820#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1821##...sltu $at,$t1,$t2
1825##...beq $at,$zero,1844

1828#    mul $t3,$t3,$t2 # multiply old value by 10
1829##...mult $t3,$t2
1833##...mflo $t3
1836#    addu $t3,$t3,$t1 # add in value of new digit
1840#    j digitLoop

1844:  doneDigitLoop:

    # "push back" unused character into queue
1844#    sw $v0,lastCharRead

    # restore return address
1848#    lw $ra,($sp)
1852#    addu $sp, 4

    # multiply by sign and put return value in $t0
1856#    mult $t3,$t4 # multiply to account for poss. minus sign
1860#    mflo $t3
1864#    move $t0, $t3
    
    # return
1868#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1872:mth_readChar_Lib:

    # save $ra by pushing onto stack
1872#    subu $sp,$sp,4
1876#    sw $ra,($sp)

      # read the character
1880#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1884#    lw $ra,($sp)
1888#    addu $sp, 4
1892#    move $t0, $v0

    # return
1896#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
1900:mth_printStr_Lib:
    # check for null, printing "(null)", if so
1900#    lw $t0,($sp)
1904#    bne $t0,$zero,psNotNull

    # print "(null)"
1908#    la $a0,nullStr
1912#    li $v0,4
1916#    syscall
1920#    j donePrintStr
    
1924:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
1924#    subu $t0,$t0,8
1928#    lw $t1,($t0) # number of data words, but needs modification
1932#    blt $t1,$zero,skipPrintStr1
1933##...slt $at,$t1,$zero
1937##...bne $at,$zero,1956
1940#    and $t1,0xff # mask out all but low byte
1941##...lui $at,0
1945##...ori $at,$at,0xff
1949##...and $t1,$t1,$at
1952#    b skipPrintStr2
1956:skipPrintStr1:
1956#    and $t1,0x7ffffff
1957##...lui $at,2047
1961##...ori $at,$at,0xffff
1965##...and $t1,$t1,$at
1968:skipPrintStr2:    
1968#    sll $t1,$t1,2
1972#    subu $t1,$t0,$t1 # first word in string
1976#    lw $t0,4($t0) # negative of string-length
1980#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
1984#    beq $t0,$t1,donePrintStr
1988:  psLoop:
1988#    lb $a0,($t1) # next byte
1992#    li $v0,11 # code for printing char

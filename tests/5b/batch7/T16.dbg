993##...lui $at,0
997##...ori $at,$at,0x80
1001##...and $t1,$t1,$at
1004#    beq $t1,$zero,toString_checkTagBit
1008#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1012#    subu $sp,8
1016#    sw $t1,($sp)
1020#    sw $s5,4($sp) # push size onto stack

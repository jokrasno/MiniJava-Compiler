3468#    bleu $t1,$t6,gcGoNextPointerSlot
3469##...sltu $at,$t6,$t1
3473##...beq $at,$zero,3616
3476#    bgtu $t1,$t7,gcGoNextPointerSlot
3477##...sltu $at,$t7,$t1
3481##...bne $at,$zero,3616

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3484#    lw $t8,-8($t1) # possible forwarding tag
3488#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3492#    lw $t8,-4($t1) # forwarding pointer: object's new address
3496#    sw $t8,($t0) # update pointer in object
3500#    j gcGoNextPointerSlot # do next iteration

3504:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3504#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3505##...slt $at,$t8,$zero
3509##...beq $at,$zero,3524
3512#    and $t8,0xff # mask off hash bits
3513##...lui $at,0
3517##...ori $at,$at,0xff
3521##...and $t8,$t8,$at

3524:  gcSkip5:
3524#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3528#    addu $t8,$t8,8 # ... add in bytes for header-words
3532#    subu $t4,$t1,$t8 # address of first word of source object
3536#    lw $t3,-4($t1) # # words in positive-offset portion
3540#    bge $t3,$zero,gcNoNeg
3541##...slt $at,$t3,$zero
3545##...beq $at,$zero,3552
3548#    move $t3,$zero # negative treated as zero
3552:  gcNoNeg:
3552#    sll $t3,$t3,2 # bytes in negative-offset portion
3556#    addu $t3,$t3,$t1 # address one word past last word of source

3560#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3564#    lw $s0,($t4)
3568#    lw $t9,-8($t1)
3572#    sw $t9,($t4)
3576#    sw $s0,-8($t1)

    # copy all source bytes to the target
3580:  gCinnerCopy2:
3580#    lw $s0,($t4)
3584#    sw $s0,($s3)
3588#    addu $t4,$t4,4
3592#    addu $s3,$s3,4
3596#    bltu $t4,$t3,gCinnerCopy2
3597##...sltu $at,$t4,$t3
3601##...bne $at,$zero,3580

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3604#    sw $zero,-8($t1) # 0 in first header-slot
3608#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3612#    sw $t8,($t0)

3616:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3616#    addu $t0,$t0,4
3620#    bltu $t0,$s1,gcNextPointerInObject
3621##...sltu $at,$t0,$s1
3625##...bne $at,$zero,3464

3628:  gcTestIterDone2:
3628#    bltu $t0,$s3,gcHeapCopyLoop
3629##...sltu $at,$t0,$s3
3633##...bne $at,$zero,3348

    ###### end outer loop to copy all non-stack-direct objects ######

3636:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3636#    lw $s2,($sp)
3640#    addu $sp,$sp,4

    # mark us as having already GC'd
3644#    move $t5,$s5

    # go try and allocate again
3648#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3652:vm_init:

    # mark bottom of stack
3652#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3656#    move $s2,$zero

    #set up the "five" register
3660#    li $s5,5

3664#    la $s3,seg0_start
3668#    la $s4,seg0_end
3669##...lui $s4,16
3673##...addiu $s4,$s4,4604
    
    # return
3676#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3680:divide:
    # get parameters; abort if divisor zero
3680#    lw $t0,($sp)
3684#    lw $t1,8($sp)
3688#    beq $t0,$zero,divByZeroError
    
    # perform division
3692#    div $t1,$t0
3696#    mflo $t0

    # store result, adjust stack and return
3700#    addu $sp,$sp,8 # adjust stack
3704#    sw $t0,($sp) # store result
3708#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3712:remainder:
    # get parameters; abort if divisor zero
3712#    lw $t0,($sp)
3716#    lw $t1,8($sp)
3720#    beq $t0,$zero,divByZeroError
    
    # perform division
3724#    div $t1,$t0
3728#    mfhi $t0

    # store result, adjust stack and return
3732#    addu $sp,$sp,8 # adjust stack
3736#    sw $t0,($sp) # store result
3740#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3744:checkCast:
    # get object, allow immediately if null
3744#    lw $t2,($sp)
3748#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3752#    lw $t2,-12($t2) # vtable address
3756#    bge $t2,$t1,castException
3757##...slt $at,$t2,$t1
3761##...beq $at,$zero,3896
3764#    blt $t2,$t0,castException
3765##...slt $at,$t2,$t0
3769##...bne $at,$zero,3896
    
    # return, leaving object unchanged on stack
3772:  checkCastReturn:    
3772#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3776:instanceOf:
    # get object, go return false if null
3776#    lw $t2,($sp)
3780#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3784#    lw $t2,-12($t2) # vtable address
3788#    sge $t0,$t2,$t0 # are we >= the lower limit?
3789##...slt $t0,$t2,$t0
3793##...xori $t0,$t0,0x1
3796#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3800#    and $t2,$t0,$t1
3804#    sw $t2,($sp)
3808:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3808#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3812:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3812#    li $v0,4 # syscall-code for print-string
3816#    syscall
3820:exit:
    # print termination message
3820#    li $v0,4 # syscall-code for print-string
3824#    la $a0,exitString
3828#    syscall

    # terminate execution
3832#    li $v0,10 #syscall-code for "exit"
3836#    syscall

3840:outOfHeapMemory:
3840#    la $a0,heapMemoryMsg
3844#    j exitError
3848:divByZeroError:
3848#    la $a0,divByZeroMsg
3852#    j exitError
3856:strIndexOutOfBounds:
3856#    la $a0,strIndexOutOfBoundsMsg
3860#    j exitError
3864:arrayIndexOutOfBounds:
3864#    la $a0,arrayIndexOutOfBoundsMsg
3868#    j exitError
3872:arraySizeOutOfBounds:
3872#    la $a0,arraySizeOutOfBoundsMsg
3876#    j exitError
3880:nullPtrException:
3880#    la $a0,nullPtrExceptionMsg
3884#    j exitError
3888:badIntegerFormat:
3888#    la $a0,badIntegerFormatMsg
3892#    j exitError
3896:castException:
3896#    la $a0,castExceptionMsg
3900#    j exitError
############## data section ################
    .data
4240:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4256:cur_seg:
    .word 0

4260:lastCharRead:
    .word -2 # -2 => no buffered character
4264:prevHashConstant:
    .word 0x2785173c
4268:gcCount:
    .word 0

4272:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4299:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4322:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4357:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4391:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4424:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4455:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4503:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4524:gcMsg: 
      .asciiz "\nGC!\n"
4530:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4562:nullStr:
    .asciiz "null"
4567:trueString:
    .asciiz "true"
4572:falseString:
    .asciiz "false"
4578:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4597:newlineString:
    .asciiz "\n"
    
    .align 2
4600:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4604:seg0_start:
    .space 0x100000
1053180:seg0_end:
1053180:seg1_start:
    .space 0x100000
2101756:seg1_end:

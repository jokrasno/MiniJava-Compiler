    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1168#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1172#    lw $t3,20($sp) # hash code to print
1176:toString_hashCopyLoop:

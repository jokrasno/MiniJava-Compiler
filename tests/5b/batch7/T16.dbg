1264#    lw $s2, 4($sp) #restore this pointer and pop parameters
1268#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1272#    seq $t0,$t0,$zero
1273##...subu $at,$t0,$zero
1277##...sltiu $t0,$at,1

    # pop return address and return $t0
1280#    lw $ra,($sp)
1284#    addu $sp,4

1288#    jr $ra # return
    
1292:goEsFalse:
    # put 0 in $t0 and return
1292#    li $t0, 0
1296#    jr $ra # return

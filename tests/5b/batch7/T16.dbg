###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1308:mth_readLine_Lib:
    
1308#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1312#    sw $ra, 4($sp) # save $ra
1316#    move $t1,$sp # save "original" sp

1320:  doRead:

    # read the character
1320#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1324#    subu $t2,$v0,13
1328#    bne $t2,$zero,notReturnRL
1332#    jal readLogicalChar
1336#    subu $t2,$v0,10 # check for newline
1340#    beq $t2,$zero,foundNewLine
1344#    sw $v0,lastCharRead # push back character into queue
1348#    j foundNewLine # go process the line

1352:  notReturnRL:

    # at this point, $v0 has our character

1352#    subu $t0,$v0,10
1356#    beq $t0,$zero,foundNewLine
1360#    blt $v0,$zero,foundEof
1361##...slt $at,$v0,$zero
1365##...bne $at,$zero,1380

    # we have a character, so push it onto stack
1368#    subu $sp,$sp,4
1372#    sw $v0,($sp)

    # loop back up to get next character
1376#    j doRead

1380:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1380#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1384#    li $s7, 0 # return-value: null
1388#    j rlReturn # return

1392:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1392#    subu $t0,$t1,$sp # number of chars we read (times 4)
1396#    srl $s6,$t0,2 # number of words on stack with chars
1400#    subu $sp,$sp,4 # push char-count ...
1404#    sw $s6,($sp) # ... onto stack
1408#    addu $t2,$t0,5 # GC tag, incl. for count-word
1412#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1416#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1420#    srl $s6,$s6,2  # data words in object
1424#    move $s7,$zero # object words in object
1428#    jal newObject  # allocate space
    
    # store header words
1432#    la $t0,CLASS_String
1436#    sw $t0,-12($s7)# store class tag (String) into object
1440#    lw $t2,4($sp) # char-count
1444#    sll $t1,$t2,2 # 4 times number of chars
1448#    subu $t2,$zero,$t2 # negative of char-count
1452#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1456#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1460#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1461##...slt $at,$t0,$zero
1465##...beq $at,$zero,1484
1468#    and $t0,0xff # mask off object's hash value ...
1469##...lui $at,0
1473##...ori $at,$at,0xff
1477##...and $t0,$t0,$at
1480#    sw $t0,-8($s7) # ... and store back into -8 header-word
1484:  skipMask_readLine:

1484#    sll $t0,$t0,2 # data bytes in object
1488#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1492#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1496#    addu $sp,$sp,8 # pop redundant object-pointer and count
1500#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1504#    beq $sp,$t1,rlReturn
1508:  charCopyLoop:
1508#    lw $t2,($sp)
1512#    sb $t2,-9($t0)
1516#    addu $sp,$sp,4
1520#    subu $t0,$t0,1
1524#    bne $sp,$t1,charCopyLoop
1528:  rlReturn:

1528#    lw $ra, 4($sp)
1532#    addu $sp, 8   # pop $ra and pointless word off stack
1536#    move $t0, $s7 # return string we allocated in $s7
1540#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1544:mth_readInt_Lib:

    # save $ra by pushing onto stack
1544#    subu $sp,$sp,4
1548#    sw $ra,($sp)

1552:  riSkipWhiteLoop:
    # read a character
1552#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1556#    subu $t0,$v0,32
1560#    bgt $t0,$zero,nonWhite
1561##...slt $at,$zero,$t0
1565##...bne $at,$zero,1608
1568#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1572#    subu $t0,$v0,10
1576#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1580#    subu $t0,$v0,9
1584#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1588#    subu $t0,$v0,13
1592#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1596#    subu $t0,$v0,12
1600#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1604#    j badIntegerFormat # illegal integer char: abort program

1608:  nonWhite:
1608#    subu $t0,$v0,'-'
1612#    li $t4,1 # final multiplier
1616#    bne $t0,$zero,helpReadInt # go read
1620#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1624#    jal readLogicalChar

1628:  helpReadInt:
1628#    li $t2,10
1632#    subu $t1,$v0,'0' # convert digit to 0-9 value
1636#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1637##...sltu $at,$t1,$t2
1641##...beq $at,$zero,3888
1644#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1648:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1648#    jal readLogicalChar # read next character
1652#    subu $t1,$v0,'0' # convert digit to 0-9 value
1656#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1657##...sltu $at,$t1,$t2
1661##...beq $at,$zero,1680

1664#    mul $t3,$t3,$t2 # multiply old value by 10
1665##...mult $t3,$t2
1669##...mflo $t3
1672#    addu $t3,$t3,$t1 # add in value of new digit
1676#    j digitLoop

1680:  doneDigitLoop:

    # "push back" unused character into queue

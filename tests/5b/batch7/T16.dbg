    # buffer and return
2856#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2860#    jr $ra # return
    
2864:  doReadCh:
    # we need to actually read a character: read and return
2864#    li $v0,12 # use system call to read a character
2868#    syscall
2872#    jr $ra # return

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
800:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
800#    lw $t0,-8($s2) # get word with hash bits from this
804#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
808#    addu $t0,$t1

812#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
816:mth_equals_Object:
816#    move $t0,$s2 # first pointer (this)
820#    lw $t1,($sp) # second pointer
824#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
825##...subu $at,$t0,$t1
829##...sltiu $t0,$at,1

832#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
836:mth_hashCode_String:
836#    move $t0,$s2 # put this pointer in t0

840#    li $t2,0 # current hash value
844#    lw $t1,-4($t0) # negative of number of characters in string
848#    beq $t1,$zero,done_hashCode_String # if zero length => done
852#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
856#    and $t0,0xfffffffc # adjust for padding
857##...lui $at,65535
861##...ori $at,$at,0xfffc
865##...and $t0,$t0,$at
868#    subu $t1,$t0,$t1 # address at end of string +12
872:loop_hashCode_String:    
872#    sll $t4,$t2,5 # multiply by 32
876#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
880#    lbu $t3,-12($t0) # current character
884#    addu $t2,$t3 # add in current character
888#    addu $t0,1 # go to next character's address
892#    bne $t0,$t1,loop_hashCode_String # loop back if more
896:done_hashCode_String:    

    # push int on stack
896#    move $t0, $t2 # put $t2 in return slot
900#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
904:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
904#    subu $sp,4
908#    sw $ra,($sp)
    
    # get hash value
912#    lw $t2,-12($s2) # vtable address
916#    lw $t0,($t2) # method address
920#    jalr $t0
924#    subu $sp,8 # push result (int in $t0) on stack
928#    sw $s5,4($sp)
932#    sw $t0,($sp)



########################################################
# str1.concat(str2) - library method (class String)
# (as in Java)
# - parameters:
#   - ($sp) - the second string
#   - 4($sp) - old this pointer
#   - $s2 - the first string (this)
# - returns:
#   - $t0 - pointer to concatenated string
########################################################
1596:mth_concat_String:
    # save $ra by pushing onto stack
1596#    subu $sp,$sp,4
1600#    sw $ra, ($sp)

    # get string pointers and check parameter for null
1604#    lw $t0,4($sp)
1608#    beq $t0,$zero,nullPtrException
1612#    move $t1,$s2
    
    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
1616#    lw $t0,-4($t0) # negative size of second object
1620#    lw $t1,-4($t1) # negative size of first object
1624#    addu $s6,$t0,$t1 # sum of negative sizes
1628#    sra $s6,$s6,2 # negative word-size of char part

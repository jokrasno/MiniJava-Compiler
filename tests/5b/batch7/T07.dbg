3148#    la $s4,seg0_end
3149##...lui $s4,16
3153##...addiu $s4,$s4,4020
    
    # return
3156#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3160:divide:
    # get parameters; abort if divisor zero
3160#    lw $t0,($sp)
3164#    lw $t1,8($sp)
3168#    beq $t0,$zero,divByZeroError
    
    # perform division
3172#    div $t1,$t0
3176#    mflo $t0

    # store result, adjust stack and return
3180#    addu $sp,$sp,8 # adjust stack
3184#    sw $t0,($sp) # store result
3188#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3192:remainder:
    # get parameters; abort if divisor zero
3192#    lw $t0,($sp)
3196#    lw $t1,8($sp)
3200#    beq $t0,$zero,divByZeroError
    
    # perform division
3204#    div $t1,$t0
3208#    mfhi $t0

    # store result, adjust stack and return
3212#    addu $sp,$sp,8 # adjust stack
3216#    sw $t0,($sp) # store result
3220#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3224:checkCast:
    # get object, allow immediately if null
3224#    lw $t2,($sp)
3228#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3232#    lw $t2,-12($t2) # vtable address
3236#    bge $t2,$t1,castException
3237##...slt $at,$t2,$t1
3241##...beq $at,$zero,3376
3244#    blt $t2,$t0,castException
3245##...slt $at,$t2,$t0
3249##...bne $at,$zero,3376
    
    # return, leaving object unchanged on stack
3252:  checkCastReturn:    
3252#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3256:instanceOf:
    # get object, go return false if null
3256#    lw $t2,($sp)
3260#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3264#    lw $t2,-12($t2) # vtable address
3268#    sge $t0,$t2,$t0 # are we >= the lower limit?
3269##...slt $t0,$t2,$t0
3273##...xori $t0,$t0,0x1
3276#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3280#    and $t2,$t0,$t1
3284#    sw $t2,($sp)
3288:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3288#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3292:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3292#    li $v0,4 # syscall-code for print-string
3296#    syscall
3300:exit:
    # print termination message
3300#    li $v0,4 # syscall-code for print-string
3304#    la $a0,exitString
3308#    syscall

    # terminate execution
3312#    li $v0,10 #syscall-code for "exit"
3316#    syscall

3320:outOfHeapMemory:
3320#    la $a0,heapMemoryMsg
3324#    j exitError
3328:divByZeroError:
3328#    la $a0,divByZeroMsg
3332#    j exitError
3336:strIndexOutOfBounds:
3336#    la $a0,strIndexOutOfBoundsMsg
3340#    j exitError
3344:arrayIndexOutOfBounds:
3344#    la $a0,arrayIndexOutOfBoundsMsg
3348#    j exitError
3352:arraySizeOutOfBounds:
3352#    la $a0,arraySizeOutOfBoundsMsg
3356#    j exitError
3360:nullPtrException:
3360#    la $a0,nullPtrExceptionMsg
3364#    j exitError
3368:badIntegerFormat:
3368#    la $a0,badIntegerFormatMsg
3372#    j exitError
3376:castException:
3376#    la $a0,castExceptionMsg
3380#    j exitError
############## data section ################
    .data
3656:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3672:cur_seg:
    .word 0

3676:lastCharRead:
    .word -2 # -2 => no buffered character
3680:prevHashConstant:
    .word 0x2785173c
3684:gcCount:
    .word 0

3688:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3715:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3738:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3773:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3807:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3840:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3871:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3919:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3940:gcMsg: 
      .asciiz "\nGC!\n"
3946:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3978:nullStr:
    .asciiz "null"
3983:trueString:
    .asciiz "true"
3988:falseString:
    .asciiz "false"
3994:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4013:newlineString:
    .asciiz "\n"
    
    .align 2
4016:stack_bottom:

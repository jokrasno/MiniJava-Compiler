##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
280:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
280#    lw $t0,-8($s2) # get word with hash bits from this
284#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
288#    addu $t0,$t1

292#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
296:mth_equals_Object:
296#    move $t0,$s2 # first pointer (this)
300#    lw $t1,($sp) # second pointer
304#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
305##...subu $at,$t0,$t1
309##...sltiu $t0,$at,1

312#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
316:mth_hashCode_String:
316#    move $t0,$s2 # put this pointer in t0

320#    li $t2,0 # current hash value
324#    lw $t1,-4($t0) # negative of number of characters in string
328#    beq $t1,$zero,done_hashCode_String # if zero length => done
332#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
336#    and $t0,0xfffffffc # adjust for padding
337##...lui $at,65535
341##...ori $at,$at,0xfffc
345##...and $t0,$t0,$at
348#    subu $t1,$t0,$t1 # address at end of string +12
352:loop_hashCode_String:    
352#    sll $t4,$t2,5 # multiply by 32
356#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
360#    lbu $t3,-12($t0) # current character
364#    addu $t2,$t3 # add in current character
368#    addu $t0,1 # go to next character's address
372#    bne $t0,$t1,loop_hashCode_String # loop back if more
376:done_hashCode_String:    

    # push int on stack
376#    move $t0, $t2 # put $t2 in return slot
380#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
384:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
384#    subu $sp,4
388#    sw $ra,($sp)
    
    # get hash value
392#    lw $t2,-12($s2) # vtable address
396#    lw $t0,($t2) # method address
400#    jalr $t0
404#    subu $sp,8 # push result (int in $t0) on stack
408#    sw $s5,4($sp)
412#    sw $t0,($sp)

    # compute print-size of hash value
416#    li $t0, 1
420#    lw $t1, ($sp)
424#    srl $t1,$t1,4
428#    beq $t1,$zero,toString_skip_loop
432:toString_loop_top:
432#    addu $t0,1
436#    srl $t1,$t1,4
440#    bne $t1,$zero,toString_loop_top
444:toString_skip_loop:
444#    subu $sp,8
448#    sw $s5,4($sp)
452#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
456#    lw $t2,-12($s2) # vtable address
460#    move $t0,$t2
464:toString_checkTagBit:
464#    subu $t0,1
468#    lb $t1,($t0)
472#    and $t1,0x80
473##...lui $at,0
477##...ori $at,$at,0x80
481##...and $t1,$t1,$at
484#    beq $t1,$zero,toString_checkTagBit
488#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
492#    subu $sp,8
496#    sw $t1,($sp)
500#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
504#    move $s7,$zero # -4 offset header word
508#    lw $t4,8($sp) # bytes for hash value
512#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
516#    addu $t4,8
520#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
524#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

528#    li $t0,CLASS_String # store string vtable address into ...
532#    sw $t0,-12($s7) # ... -12 offset in object header
536#    lw $t2,-12($s2) # our object's vtable address
540#    lw $t5,4($sp) # number characters in prefix
544#    lw $t1,12($sp) # number of characters in hashcode
548#    addu $t3,$t1,$t5 # number of characters in string ...
552#    addu $t3,1 # ... including the '@' character
556#    subu $t0,$zero,$t3 # store negated length into ...
560#    sw $t0,-4($s7) # ... -4 offset header word
564#    lw $t0,-8($s7) # get -8 offset header-word
568#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
569##...slt $at,$t0,$zero
573##...beq $at,$zero,592
576#    and $t0,0xff # mask off object's hash value ...
577##...lui $at,0
581##...ori $at,$at,0xff
585##...and $t0,$t0,$at
588#    sw $t0,-8($s7) # ... and store back into -8 header-word
592:skipMask_toString:
592#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
596#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
600#    subu $t4,$t2,$t5
604:toString_copyLoop:    
604#    lb $t3,($t4)
608#    and $t3,0x7f # mask off sign bit (in case first word)
609##...lui $at,0
613##...ori $at,$at,0x7f
617##...and $t3,$t3,$at
620#    sb $t3,-8($t0)
624#    addu $t4,1
628#    addu $t0,1
632#    blt $t4,$t2,toString_copyLoop
633##...slt $at,$t4,$t2
637##...bne $at,$zero,604

    # copy the '@' sign
640#    li $t3,'@'
644#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
648#    addu $t2,$t0,$t1 # address of last byte in string to store +8
652#    lw $t3,20($sp) # hash code to print
656:toString_hashCopyLoop:
656#    and $t4,$t3,0xf
660#    srl $t3,4
664#    lb $t4,hexChars($t4)
668#    sb $t4,-8($t2)
672#    subu $t2,$t2,1
676#    bgt $t2,$t0,toString_hashCopyLoop
677##...slt $at,$t0,$t2
681##...bne $at,$zero,656

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
684#    addu $sp,28
688#    lw $ra,($sp)
692#    addu $sp,4
696#    move $t0, $s7 # return string we created
700#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
704:mth_equals_String:
    
    # quick test for obvious false
704#    lw $t0,($sp) # second parameter
708#    beq $t0,$zero,goEsFalse # go return false if null
712#    lw $t1,-12($t0) # vtable pointer
716#    la $t2,CLASS_String # string vtable pointer

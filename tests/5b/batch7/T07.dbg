###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
788:mth_readLine_Lib:
    
788#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
792#    sw $ra, 4($sp) # save $ra
796#    move $t1,$sp # save "original" sp

800:  doRead:

    # read the character
800#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
804#    subu $t2,$v0,13
808#    bne $t2,$zero,notReturnRL
812#    jal readLogicalChar
816#    subu $t2,$v0,10 # check for newline
820#    beq $t2,$zero,foundNewLine
824#    sw $v0,lastCharRead # push back character into queue
828#    j foundNewLine # go process the line

832:  notReturnRL:

    # at this point, $v0 has our character

832#    subu $t0,$v0,10
836#    beq $t0,$zero,foundNewLine
840#    blt $v0,$zero,foundEof
841##...slt $at,$v0,$zero
845##...bne $at,$zero,860

    # we have a character, so push it onto stack
848#    subu $sp,$sp,4
852#    sw $v0,($sp)

    # loop back up to get next character
856#    j doRead

860:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
860#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
864#    li $s7, 0 # return-value: null
868#    j rlReturn # return

872:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
872#    subu $t0,$t1,$sp # number of chars we read (times 4)
876#    srl $s6,$t0,2 # number of words on stack with chars
880#    subu $sp,$sp,4 # push char-count ...
884#    sw $s6,($sp) # ... onto stack
888#    addu $t2,$t0,5 # GC tag, incl. for count-word
892#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
896#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
900#    srl $s6,$s6,2  # data words in object
904#    move $s7,$zero # object words in object
908#    jal newObject  # allocate space
    
    # store header words
912#    la $t0,CLASS_String
916#    sw $t0,-12($s7)# store class tag (String) into object
920#    lw $t2,4($sp) # char-count
924#    sll $t1,$t2,2 # 4 times number of chars
928#    subu $t2,$zero,$t2 # negative of char-count
932#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
936#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
940#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
941##...slt $at,$t0,$zero
945##...beq $at,$zero,964
948#    and $t0,0xff # mask off object's hash value ...
949##...lui $at,0
953##...ori $at,$at,0xff
957##...and $t0,$t0,$at
960#    sw $t0,-8($s7) # ... and store back into -8 header-word
964:  skipMask_readLine:

964#    sll $t0,$t0,2 # data bytes in object
968#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
972#    subu $t0,$t0,$t2 # place to store last character (plus 9)
976#    addu $sp,$sp,8 # pop redundant object-pointer and count
980#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

984#    beq $sp,$t1,rlReturn
988:  charCopyLoop:
988#    lw $t2,($sp)
992#    sb $t2,-9($t0)
996#    addu $sp,$sp,4
1000#    subu $t0,$t0,1
1004#    bne $sp,$t1,charCopyLoop
1008:  rlReturn:

1008#    lw $ra, 4($sp)
1012#    addu $sp, 8   # pop $ra and pointless word off stack
1016#    move $t0, $s7 # return string we allocated in $s7
1020#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1024:mth_readInt_Lib:

    # save $ra by pushing onto stack
1024#    subu $sp,$sp,4
1028#    sw $ra,($sp)

1032:  riSkipWhiteLoop:
    # read a character
1032#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1036#    subu $t0,$v0,32
1040#    bgt $t0,$zero,nonWhite
1041##...slt $at,$zero,$t0
1045##...bne $at,$zero,1088
1048#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1052#    subu $t0,$v0,10
1056#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1060#    subu $t0,$v0,9
1064#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1068#    subu $t0,$v0,13
1072#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1076#    subu $t0,$v0,12
1080#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1084#    j badIntegerFormat # illegal integer char: abort program

1088:  nonWhite:
1088#    subu $t0,$v0,'-'
1092#    li $t4,1 # final multiplier
1096#    bne $t0,$zero,helpReadInt # go read
1100#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1104#    jal readLogicalChar

1108:  helpReadInt:
1108#    li $t2,10
1112#    subu $t1,$v0,'0' # convert digit to 0-9 value
1116#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1117##...sltu $at,$t1,$t2
1121##...beq $at,$zero,3368
1124#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1128:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1128#    jal readLogicalChar # read next character
1132#    subu $t1,$v0,'0' # convert digit to 0-9 value
1136#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1137##...sltu $at,$t1,$t2
1141##...beq $at,$zero,1160

1144#    mul $t3,$t3,$t2 # multiply old value by 10
1145##...mult $t3,$t2
1149##...mflo $t3
1152#    addu $t3,$t3,$t1 # add in value of new digit
1156#    j digitLoop

1160:  doneDigitLoop:

    # "push back" unused character into queue
1160#    sw $v0,lastCharRead

    # restore return address
1164#    lw $ra,($sp)
1168#    addu $sp, 4

    # multiply by sign and put return value in $t0
1172#    mult $t3,$t4 # multiply to account for poss. minus sign
1176#    mflo $t3
1180#    move $t0, $t3
    
    # return
1184#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1188:mth_readChar_Lib:

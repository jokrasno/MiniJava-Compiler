
11032:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
11032#    lw $s2,($sp)
11036#    addu $sp,$sp,4

    # mark us as having already GC'd
11040#    move $t5,$s5

    # go try and allocate again
11044#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
11048:vm_init:

    # mark bottom of stack
11048#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
11052#    move $s2,$zero

    #set up the "five" register
11056#    li $s5,5

11060#    la $s3,seg0_start
11064#    la $s4,seg0_end
11065##...lui $s4,16
11069##...addiu $s4,$s4,12000
    
    # return
11072#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
11076:divide:
    # get parameters; abort if divisor zero
11076#    lw $t0,($sp)
11080#    lw $t1,8($sp)
11084#    beq $t0,$zero,divByZeroError
    
    # perform division
11088#    div $t1,$t0
11092#    mflo $t0

    # store result, adjust stack and return
11096#    addu $sp,$sp,8 # adjust stack
11100#    sw $t0,($sp) # store result
11104#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
11108:remainder:
    # get parameters; abort if divisor zero
11108#    lw $t0,($sp)
11112#    lw $t1,8($sp)
11116#    beq $t0,$zero,divByZeroError
    
    # perform division
11120#    div $t1,$t0
11124#    mfhi $t0

    # store result, adjust stack and return
11128#    addu $sp,$sp,8 # adjust stack
11132#    sw $t0,($sp) # store result
11136#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
11140:checkCast:
    # get object, allow immediately if null
11140#    lw $t2,($sp)
11144#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
11148#    lw $t2,-12($t2) # vtable address
11152#    bge $t2,$t1,castException
11153##...slt $at,$t2,$t1
11157##...beq $at,$zero,11292
11160#    blt $t2,$t0,castException
11161##...slt $at,$t2,$t0
11165##...bne $at,$zero,11292
    
    # return, leaving object unchanged on stack
11168:  checkCastReturn:    
11168#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
11172:instanceOf:
    # get object, go return false if null
11172#    lw $t2,($sp)
11176#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
11180#    lw $t2,-12($t2) # vtable address
11184#    sge $t0,$t2,$t0 # are we >= the lower limit?
11185##...slt $t0,$t2,$t0
11189##...xori $t0,$t0,0x1
11192#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
11196#    and $t2,$t0,$t1
11200#    sw $t2,($sp)
11204:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
11204#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

11208:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
11208#    li $v0,4 # syscall-code for print-string
11212#    syscall
11216:exit:
    # print termination message
11216#    li $v0,4 # syscall-code for print-string
11220#    la $a0,exitString
11224#    syscall

    # terminate execution
11228#    li $v0,10 #syscall-code for "exit"
11232#    syscall

11236:outOfHeapMemory:
11236#    la $a0,heapMemoryMsg
11240#    j exitError
11244:divByZeroError:
11244#    la $a0,divByZeroMsg
11248#    j exitError
11252:strIndexOutOfBounds:
11252#    la $a0,strIndexOutOfBoundsMsg
11256#    j exitError
11260:arrayIndexOutOfBounds:
11260#    la $a0,arrayIndexOutOfBoundsMsg
11264#    j exitError
11268:arraySizeOutOfBounds:
11268#    la $a0,arraySizeOutOfBoundsMsg
11272#    j exitError
11276:nullPtrException:
11276#    la $a0,nullPtrExceptionMsg
11280#    j exitError
11284:badIntegerFormat:
11284#    la $a0,badIntegerFormatMsg
11288#    j exitError
11292:castException:
11292#    la $a0,castExceptionMsg
11296#    j exitError
############## data section ################
    .data
11636:hexChars:
    .ascii "0123456789abcdef"
    .align 2
11652:cur_seg:
    .word 0

11656:lastCharRead:
    .word -2 # -2 => no buffered character
11660:prevHashConstant:
    .word 0x2785173c
11664:gcCount:
    .word 0

11668:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
11695:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
11718:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
11753:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
11787:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
11820:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
11851:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
11899:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
11920:gcMsg: 
      .asciiz "\nGC!\n"
11926:gcCountMsg: 
      .asciiz "Number of garbage collections: "

11958:nullStr:
    .asciiz "null"
11963:trueString:
    .asciiz "true"
11968:falseString:
    .asciiz "false"
11974:exitString:
    .ascii "Program terminated."
    #### "falls through" here
11993:newlineString:
    .asciiz "\n"
    
    .align 2
11996:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

12000:seg0_start:
    .space 0x100000
1060576:seg0_end:
1060576:seg1_start:
    .space 0x100000
2109152:seg1_end:

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
8196:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
8196#    lw $t0,-8($s2) # get word with hash bits from this
8200#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
8204#    addu $t0,$t1

8208#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
8212:mth_equals_Object:
8212#    move $t0,$s2 # first pointer (this)
8216#    lw $t1,($sp) # second pointer
8220#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
8221##...subu $at,$t0,$t1
8225##...sltiu $t0,$at,1

8228#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
8232:mth_hashCode_String:
8232#    move $t0,$s2 # put this pointer in t0

8236#    li $t2,0 # current hash value
8240#    lw $t1,-4($t0) # negative of number of characters in string
8244#    beq $t1,$zero,done_hashCode_String # if zero length => done
8248#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
8252#    and $t0,0xfffffffc # adjust for padding
8253##...lui $at,65535
8257##...ori $at,$at,0xfffc
8261##...and $t0,$t0,$at
8264#    subu $t1,$t0,$t1 # address at end of string +12
8268:loop_hashCode_String:    
8268#    sll $t4,$t2,5 # multiply by 32
8272#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
8276#    lbu $t3,-12($t0) # current character
8280#    addu $t2,$t3 # add in current character
8284#    addu $t0,1 # go to next character's address
8288#    bne $t0,$t1,loop_hashCode_String # loop back if more
8292:done_hashCode_String:    

    # push int on stack
8292#    move $t0, $t2 # put $t2 in return slot
8296#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
8300:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
8300#    subu $sp,4
8304#    sw $ra,($sp)
    
    # get hash value
8308#    lw $t2,-12($s2) # vtable address
8312#    lw $t0,($t2) # method address
8316#    jalr $t0
8320#    subu $sp,8 # push result (int in $t0) on stack
8324#    sw $s5,4($sp)
8328#    sw $t0,($sp)

    # compute print-size of hash value
8332#    li $t0, 1
8336#    lw $t1, ($sp)
8340#    srl $t1,$t1,4
8344#    beq $t1,$zero,toString_skip_loop
8348:toString_loop_top:
8348#    addu $t0,1
8352#    srl $t1,$t1,4
8356#    bne $t1,$zero,toString_loop_top
8360:toString_skip_loop:
8360#    subu $sp,8
8364#    sw $s5,4($sp)
8368#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
8372#    lw $t2,-12($s2) # vtable address
8376#    move $t0,$t2
8380:toString_checkTagBit:
8380#    subu $t0,1
8384#    lb $t1,($t0)
8388#    and $t1,0x80
8389##...lui $at,0
8393##...ori $at,$at,0x80
8397##...and $t1,$t1,$at
8400#    beq $t1,$zero,toString_checkTagBit
8404#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
8408#    subu $sp,8
8412#    sw $t1,($sp)
8416#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
8420#    move $s7,$zero # -4 offset header word
8424#    lw $t4,8($sp) # bytes for hash value
8428#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
8432#    addu $t4,8
8436#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
8440#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

8444#    li $t0,CLASS_String # store string vtable address into ...
8448#    sw $t0,-12($s7) # ... -12 offset in object header
8452#    lw $t2,-12($s2) # our object's vtable address
8456#    lw $t5,4($sp) # number characters in prefix
8460#    lw $t1,12($sp) # number of characters in hashcode
8464#    addu $t3,$t1,$t5 # number of characters in string ...
8468#    addu $t3,1 # ... including the '@' character
8472#    subu $t0,$zero,$t3 # store negated length into ...
8476#    sw $t0,-4($s7) # ... -4 offset header word
8480#    lw $t0,-8($s7) # get -8 offset header-word
8484#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
8485##...slt $at,$t0,$zero
8489##...beq $at,$zero,8508
8492#    and $t0,0xff # mask off object's hash value ...
8493##...lui $at,0
8497##...ori $at,$at,0xff
8501##...and $t0,$t0,$at
8504#    sw $t0,-8($s7) # ... and store back into -8 header-word
8508:skipMask_toString:
8508#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
8512#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
8516#    subu $t4,$t2,$t5
8520:toString_copyLoop:    
8520#    lb $t3,($t4)
8524#    and $t3,0x7f # mask off sign bit (in case first word)
8525##...lui $at,0
8529##...ori $at,$at,0x7f
8533##...and $t3,$t3,$at
8536#    sb $t3,-8($t0)
8540#    addu $t4,1
8544#    addu $t0,1
8548#    blt $t4,$t2,toString_copyLoop
8549##...slt $at,$t4,$t2
8553##...bne $at,$zero,8520

    # copy the '@' sign
8556#    li $t3,'@'
8560#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
8564#    addu $t2,$t0,$t1 # address of last byte in string to store +8
8568#    lw $t3,20($sp) # hash code to print
8572:toString_hashCopyLoop:
8572#    and $t4,$t3,0xf
8576#    srl $t3,4
8580#    lb $t4,hexChars($t4)
8584#    sb $t4,-8($t2)
8588#    subu $t2,$t2,1
8592#    bgt $t2,$t0,toString_hashCopyLoop
8593##...slt $at,$t0,$t2
8597##...bne $at,$zero,8572

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
8600#    addu $sp,28
8604#    lw $ra,($sp)
8608#    addu $sp,4
8612#    move $t0, $s7 # return string we created
8616#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
8620:mth_equals_String:
    
    # quick test for obvious false
8620#    lw $t0,($sp) # second parameter
8624#    beq $t0,$zero,goEsFalse # go return false if null
8628#    lw $t1,-12($t0) # vtable pointer
8632#    la $t2,CLASS_String # string vtable pointer
8636#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
8640#    subu $sp,12
8644#    sw $ra,8($sp)
8648#    sw $s2,4($sp)
8652#    sw $t0,($sp)
8656#    jal mth_compareTo_String
8660#    lw $s2, 4($sp) #restore this pointer and pop parameters
8664#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
8668#    seq $t0,$t0,$zero
8669##...subu $at,$t0,$zero
8673##...sltiu $t0,$at,1

    # pop return address and return $t0
8676#    lw $ra,($sp)
8680#    addu $sp,4

8684#    jr $ra # return
    
8688:goEsFalse:
    # put 0 in $t0 and return
8688#    li $t0, 0
8692#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
8696:mth_toString_String:
    #we are a string, so return this.
8696#    move $t0, $s2
8700#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
8704:mth_readLine_Lib:
    
8704#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
8708#    sw $ra, 4($sp) # save $ra
8712#    move $t1,$sp # save "original" sp

8716:  doRead:

    # read the character
8716#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
8720#    subu $t2,$v0,13
8724#    bne $t2,$zero,notReturnRL
8728#    jal readLogicalChar
8732#    subu $t2,$v0,10 # check for newline
8736#    beq $t2,$zero,foundNewLine
8740#    sw $v0,lastCharRead # push back character into queue
8744#    j foundNewLine # go process the line

8748:  notReturnRL:

    # at this point, $v0 has our character

8748#    subu $t0,$v0,10
8752#    beq $t0,$zero,foundNewLine
8756#    blt $v0,$zero,foundEof
8757##...slt $at,$v0,$zero
8761##...bne $at,$zero,8776

    # we have a character, so push it onto stack
8764#    subu $sp,$sp,4
8768#    sw $v0,($sp)

    # loop back up to get next character
8772#    j doRead

8776:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
8776#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
8780#    li $s7, 0 # return-value: null
8784#    j rlReturn # return

8788:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
8788#    subu $t0,$t1,$sp # number of chars we read (times 4)
8792#    srl $s6,$t0,2 # number of words on stack with chars
8796#    subu $sp,$sp,4 # push char-count ...
8800#    sw $s6,($sp) # ... onto stack
8804#    addu $t2,$t0,5 # GC tag, incl. for count-word
8808#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
8812#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
8816#    srl $s6,$s6,2  # data words in object
8820#    move $s7,$zero # object words in object
8824#    jal newObject  # allocate space
    
    # store header words
8828#    la $t0,CLASS_String
8832#    sw $t0,-12($s7)# store class tag (String) into object
8836#    lw $t2,4($sp) # char-count
8840#    sll $t1,$t2,2 # 4 times number of chars
8844#    subu $t2,$zero,$t2 # negative of char-count
8848#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
8852#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
8856#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
8857##...slt $at,$t0,$zero
8861##...beq $at,$zero,8880
8864#    and $t0,0xff # mask off object's hash value ...
8865##...lui $at,0
8869##...ori $at,$at,0xff
8873##...and $t0,$t0,$at
8876#    sw $t0,-8($s7) # ... and store back into -8 header-word
8880:  skipMask_readLine:

8880#    sll $t0,$t0,2 # data bytes in object
8884#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
8888#    subu $t0,$t0,$t2 # place to store last character (plus 9)
8892#    addu $sp,$sp,8 # pop redundant object-pointer and count
8896#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

8900#    beq $sp,$t1,rlReturn
8904:  charCopyLoop:
8904#    lw $t2,($sp)
8908#    sb $t2,-9($t0)
8912#    addu $sp,$sp,4
8916#    subu $t0,$t0,1
8920#    bne $sp,$t1,charCopyLoop
8924:  rlReturn:

8924#    lw $ra, 4($sp)
8928#    addu $sp, 8   # pop $ra and pointless word off stack
8932#    move $t0, $s7 # return string we allocated in $s7
8936#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
8940:mth_readInt_Lib:

    # save $ra by pushing onto stack
8940#    subu $sp,$sp,4
8944#    sw $ra,($sp)

8948:  riSkipWhiteLoop:
    # read a character
8948#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
8952#    subu $t0,$v0,32
8956#    bgt $t0,$zero,nonWhite
8957##...slt $at,$zero,$t0
8961##...bne $at,$zero,9004
8964#    beq $t0,$zero,riSkipWhiteLoop # start over if space
8968#    subu $t0,$v0,10
8972#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
8976#    subu $t0,$v0,9
8980#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
8984#    subu $t0,$v0,13
8988#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
8992#    subu $t0,$v0,12
8996#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
9000#    j badIntegerFormat # illegal integer char: abort program

9004:  nonWhite:
9004#    subu $t0,$v0,'-'
9008#    li $t4,1 # final multiplier
9012#    bne $t0,$zero,helpReadInt # go read
9016#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
9020#    jal readLogicalChar

9024:  helpReadInt:
9024#    li $t2,10
9028#    subu $t1,$v0,'0' # convert digit to 0-9 value
9032#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
9033##...sltu $at,$t1,$t2
9037##...beq $at,$zero,11284
9040#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

9044:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

9044#    jal readLogicalChar # read next character
9048#    subu $t1,$v0,'0' # convert digit to 0-9 value
9052#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
9053##...sltu $at,$t1,$t2
9057##...beq $at,$zero,9076

9060#    mul $t3,$t3,$t2 # multiply old value by 10
9061##...mult $t3,$t2
9065##...mflo $t3
9068#    addu $t3,$t3,$t1 # add in value of new digit
9072#    j digitLoop

9076:  doneDigitLoop:

    # "push back" unused character into queue
9076#    sw $v0,lastCharRead

    # restore return address
9080#    lw $ra,($sp)
9084#    addu $sp, 4

    # multiply by sign and put return value in $t0
9088#    mult $t3,$t4 # multiply to account for poss. minus sign
9092#    mflo $t3
9096#    move $t0, $t3
    
    # return
9100#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
9104:mth_readChar_Lib:

    # save $ra by pushing onto stack
9104#    subu $sp,$sp,4
9108#    sw $ra,($sp)

      # read the character
9112#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
9116#    lw $ra,($sp)
9120#    addu $sp, 4
9124#    move $t0, $v0

    # return
9128#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
9132:mth_printStr_Lib:
    # check for null, printing "(null)", if so
9132#    lw $t0,($sp)
9136#    bne $t0,$zero,psNotNull

    # print "(null)"
9140#    la $a0,nullStr
9144#    li $v0,4
9148#    syscall
9152#    j donePrintStr
    
9156:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
9156#    subu $t0,$t0,8
9160#    lw $t1,($t0) # number of data words, but needs modification
9164#    blt $t1,$zero,skipPrintStr1
9165##...slt $at,$t1,$zero
9169##...bne $at,$zero,9188
9172#    and $t1,0xff # mask out all but low byte
9173##...lui $at,0
9177##...ori $at,$at,0xff
9181##...and $t1,$t1,$at
9184#    b skipPrintStr2
9188:skipPrintStr1:
9188#    and $t1,0x7ffffff
9189##...lui $at,2047
9193##...ori $at,$at,0xffff
9197##...and $t1,$t1,$at
9200:skipPrintStr2:    
9200#    sll $t1,$t1,2
9204#    subu $t1,$t0,$t1 # first word in string
9208#    lw $t0,4($t0) # negative of string-length
9212#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
9216#    beq $t0,$t1,donePrintStr
9220:  psLoop:
9220#    lb $a0,($t1) # next byte
9224#    li $v0,11 # code for printing char
9228#        syscall # print the char
9232#    addu $t1,$t1,1 # go to next char
9236#    blt $t1,$t0,psLoop
9237##...slt $at,$t1,$t0
9241##...bne $at,$zero,9220

9244:  donePrintStr:
9244#    jr $ra

########################################################
# printInt(n) - library method (class Lib)
# - prints integer in decimal format to standard output
# - parameters:
#   - ($sp) - the integer to print
#   - 4($sp) - GC tag
#   - ($sp) - old-this-pointer
########################################################
9248:mth_printInt_Lib:
9248#    lw $a0,($sp)

    # print it
9252#    li $v0,1 # code for print-int
9256#    syscall

    # return
9260#    jr $ra

########################################################
# printBool(n) - library method (class Lib)
# - prints boolean to standard output
# - parameters:
#   - ($sp) - the boolean to print
#   - 4($sp) - old-this-pointer
########################################################
9264:mth_printBool_Lib:
    # pop value off stack, along with 'this'
9264#    lw $t0,($sp)

    # print either 'true' or 'false', depending on the value
9268#    la $a0,falseString
9272#    beq $t0,$zero,skipPB
9276#    la $a0,trueString
9280:  skipPB:
9280#    li $v0,4 # code for print-string
9284#    syscall

    # return
9288#    jr $ra

########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
9292:mth_substring_String:

    # save $ra by pushing onto stack
9292#    subu $sp,$sp,4
9296#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
9300#    move $t0,$s2
9304#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
9308#    lw $t0,-4($t0) # negative of string length
9312#    subu $t0,$zero,$t0 # string length
9316#    lw $t1,4($sp) # k
9320#    lw $t2,12($sp) # n
9324#    bgt $zero,$t2,strIndexOutOfBounds
9325##...slt $at,$t2,$zero
9329##...bne $at,$zero,11252
9332#    bgt $t2,$t1,strIndexOutOfBounds
9333##...slt $at,$t1,$t2
9337##...bne $at,$zero,11252
9340#    bgt $t1,$t0,strIndexOutOfBounds
9341##...slt $at,$t0,$t1
9345##...bne $at,$zero,11252

    # allocate memory
9348#    subu $s6,$t1,$t2 # # chars in target-string
9352#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
9356#    srl $s6,$s6,2 # convert bytes-count to word-count
9360#    move $s7,$zero # (no object-bytes in string)
9364#    jal newObject

    # store "String" tag in object-type field
9368#    la $t0,CLASS_String
9372#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
9376#    lw $t4,-8($s7) # data words in source string
9380#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
9381##...slt $at,$t4,$zero
9385##...beq $at,$zero,9404
9388#    and $t4,0xff # mask off object's hash value ...
9389##...lui $at,0
9393##...ori $at,$at,0xff
9397##...and $t4,$t4,$at
9400#    sw $t4,-8($s7) # ... and store back into -8 header-word
9404:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
9404#    lw $t1,8($sp) # k
9408#    lw $t2,16($sp) # n
9412#    subu $t0,$t2,$t1 # value to store
9416#    sw $t0,-4($s7) # store value
    
9420#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
9424#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
9428#    lw $t4,-8($t3) # data words in source string
9432#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
9436#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
9440#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
9444#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
9448#    lw $t2,-8($s7)   # data words in target string
9452#    sll $t2,$t2,2    # data bytes in target string
9456#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target
9460:  subCopyLoopzz:
9460#    lb $t4,-8($t3)
9464#    sb $t4,-8($t2)
9468#    addu $t2,$t2,1
9472#    addu $t3,$t3,1
9476#    blt $t3,$t1,subCopyLoopzz
9477##...slt $at,$t3,$t1
9481##...bne $at,$zero,9460
    
9484:  doneSubCopyzz:
    # restore return address, store return value, pop stack
9484#    lw $ra,4($sp) # restore $ra
9488#    addu $sp,$sp,8 # pop ra, and allocated newObject
9492#    move $t0, $s7 # we're returning the string we got back
                  # from newObject
    
    # return
9496#    jr $ra

########################################################
# length() - library method (class String)
# returns length of a string: Java: str.length()
# - parameters:
#   - ($sp) - old this pointer
# - return-value:
#   - $t0 - length of string
########################################################
9500:mth_length_String:

    # the length is the negative of 4($s2)
9500#    lw $t0,-4($s2) # -length
9504#    subu $t0,$zero,$t0

    # return
9508#    jr $ra


########################################################
# str1.concat(str2) - library method (class String)
# (as in Java)
# - parameters:
#   - ($sp) - the second string
#   - 4($sp) - old this pointer
#   - $s2 - the first string (this)
# - returns:
#   - $t0 - pointer to concatenated string
########################################################
9512:mth_concat_String:
    # save $ra by pushing onto stack
9512#    subu $sp,$sp,4
9516#    sw $ra, ($sp)

    # get string pointers and check parameter for null
9520#    lw $t0,4($sp)
9524#    beq $t0,$zero,nullPtrException
9528#    move $t1,$s2
    
    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
9532#    lw $t0,-4($t0) # negative size of second object
9536#    lw $t1,-4($t1) # negative size of first object
9540#    addu $s6,$t0,$t1 # sum of negative sizes
9544#    sra $s6,$s6,2 # negative word-size of char part
9548#    subu $s6,$zero,$s6 # word size of char part
9552#    addu $s6,$s6,1 # data word size, including v-table word
9556#    move $s7,$zero
9560#    jal newObject

    # store String vtable address in vtable address field
9564#    la $t0,CLASS_String
9568#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
9572#    lw $t4,-8($s7) # # data words in source string
9576#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
9577##...slt $at,$t4,$zero
9581##...beq $at,$zero,9600
9584#    and $t4,0xff # mask off object's hash value ...
9585##...lui $at,0
9589##...ori $at,$at,0xff
9593##...and $t4,$t4,$at
9596#    sw $t4,-8($s7) # ... and store back into -8 header-word
9600:skipMask_concat:

9600#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
9604#    move $t1,$s2   # first object
9608#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
9612#    lw $t2,-4($t0) # negative length of second object
9616#    lw $t3,-4($t1) # negative length of first object
9620#    addu $t4,$t2,$t3 # sum of negative lengths
9624#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################

    # compute addresses for moving data from first string
9628#    lw $t4,-8($t1) # # data words in first string
9632#    sll $t4,$t4,2 # # data bytes in first string
9636#    subu $t1,$t1,$t4 # addr. (+8) of first byte in first string
9640#    lw $t4,-8($s7) # # data words in new string
9644#    sll $t4,$t4,2 # # data bytes in new string
9648#    subu $s7,$s7,$t4 # addr. (+8) of first byte in new string
9652#    beq $zero,$t3,doneConcatLoop1zz # skip first loop is no bytes to copy
9656#    subu $t3,$t1,$t3 # limit (+8) address for first string

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is address (+8) of first byte in first object
    # - $t2 is negated length of second object
    # - $t3 is limit-address (+8) of data in first object
    # - $s7 is address (+8) of first byte in new object
    # - note: if data-length of first object is zero, then
    #   we skip over this part, and go to 'doneConcatLoop1'
    #########################################################

    # copy the bytes from first source to target
9660:  concatLoop1zz:
9660#    lb $t4,-8($t1)
9664#    sb $t4,-8($s7)
9668#    addu $s7,$s7,1
9672#    addu $t1,$t1,1
9676#    blt $t1,$t3,concatLoop1zz
9677##...slt $at,$t1,$t3
9681##...bne $at,$zero,9660
9684:  doneConcatLoop1zz:
  
    # if second string is empty, skip rest of copy
9684#    beq $zero,$t2,doneConcatLoop2zz

      # compute addresses for moving data from second string
9688#    lw $t4,-8($t0) # # data words in second string
9692#    sll $t4,$t4,2 # # data bytes in second string
9696#    subu $t1,$t0,$t4 # addr. (+8) of first byte in second string
9700#    subu $t3,$t1,$t2 # limit (+8) address for second string

    #########################################################
    # at this point:
    # - $t1 is address (+8) of first byte in second object
    # - $t3 is limit-address (+8) of data in second object
    # - $s7 is address (+8) of next byte to write new object
    # - note: if data-length of second object is zero, then
    #   we skip over this part, and go to 'doneConcatLoop2'
    #########################################################

    # copy the bytes from first source to target
9704:  concatLoop2zz:
9704#    lb $t4,-8($t1)
9708#    sb $t4,-8($s7)
9712#    addu $s7,$s7,1
9716#    addu $t1,$t1,1
9720#    blt $t1,$t3,concatLoop2zz
9721##...slt $at,$t1,$t3
9725##...bne $at,$zero,9704
9728:  doneConcatLoop2zz:
 
9728:  concatRtnzz:
    # return
9728#    move $t0, $t9 # put saved return string in $t0
9732#    lw $ra, 4($sp)
9736#    addu $sp, 8 # pop ra and allocated newObject
9740#    jr $ra

########################################################
# str.charAt(n) - library method (class String)
# accesses a character in a string, as in Java
# - parameters:
#   - ($sp) - the index, n
#   - 4($sp) - GC tag
#   - 8($sp) - old this pointer
#   - $s2    - this pointer
# - returns:
#   - $t0 - the character found.
########################################################
9744:mth_charAt_String:
    # get string
9744#    move $t0,$s2

    # check that index is in bounds
9748#    lw $t1,-4($t0) # negative of # data words in string
9752#    subu $t3,$zero,$t1 # # chars in string
9756#    lw $t2,($sp) # index
9760#    bgeu $t2,$t3,strIndexOutOfBounds
9761##...sltu $at,$t2,$t3
9765##...beq $at,$zero,11252

    # access element
9768#    lw $t1,-8($t0) # # data words in object
9772#    sll $t1,$t1,2 # - byte-offset from end of chars
9776#    subu $t1,$t2,$t1 # - address of first char in string, offset by 8
9780#    addu $t0,$t0,$t1 # - address of our char, offset by 8
9784#    lb $t0,-8($t0) # our char

    # return
9788#    jr $ra

########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
9792:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
9792#    subu $sp,$sp,8
9796#    sw $ra,4($sp)

    # save current sp
9800#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
9804#    li $t3,10

    # get argument, negate if negative
9808#    lw $t1,8($sp)
9812#    bge $t1,$zero,itsNonNegLoop
9813##...slt $at,$t1,$zero
9817##...beq $at,$zero,9824
9820#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
9824:  itsNonNegLoop:
9824#    divu $t1,$t3
9828#    mflo $t1 # quotient
9832#    mfhi $t4 # remainder
9836#    addu $t4,$t4,'0' # turn remainder into digit
9840#    subu $sp,$sp,4
9844#    sw $t4,($sp) # push digit onto stack
9848#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
9852#    lw $t4,8($t0)
9856#    bge $t4,$zero,itsSkipNeg
9857##...slt $at,$t4,$zero
9861##...beq $at,$zero,9876
9864#    li $t4,'-'
9868#    subu $sp,$sp,4
9872#    sw $t4,($sp)
9876:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
9876#    subu $s6,$t0,$sp
9880#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
9884#    sw $t3,($t0)
9888#    srl $s6,$s6,2
9892#    subu $sp,$sp,4
9896#    sw $s6,($sp)
    
    # allocate memory
9900#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
9904#    srl $s6,$s6,2
9908#    move $s7,$zero # no "object" words in object
9912#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
9916#    lw $t0,4($sp)
9920#    addu $sp,$sp,8

    # store "String" tag into class field
9924#    subu $s7,$s7,8 # address of header-1 word
9928#    la $t1,CLASS_String
9932#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
9936#    lw $t4,($s7) # # data words in source string
9940#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
9941##...slt $at,$t4,$zero
9945##...beq $at,$zero,9964
9948#    and $t4,0xff # mask off object's hash value ...
9949##...lui $at,0
9953##...ori $at,$at,0xff
9957##...and $t4,$t4,$at
9960#    sw $t4,($s7) # ... and store back into -8 header-word
9964:skipMask_intToString:
    
    # store negative of char-count into header-2 word
9964#    subu $t0,$zero,$t0
9968#    sw $t0,4($s7)

9972#    lw $t1,($s7) # number of data words in string
9976#    sll $t1,$t1,2 # number data bytes in string
9980#    subu $t1,$s7,$t1 # first location to store chars in string
9984#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
9988:  itsLoop:
9988#    lw $t2,($sp)
9992#    addu $sp,$sp,4
9996#    sb $t2,($t1)
10000#    addu $t1,$t1,1
10004#    bne $t1,$t0,itsLoop

    ####################################################
    # At this point
    # - ($t0+15)&0xfffffffe is our return value
    # - ($sp) contains garbage (old GC tag)
    # - 4($sp) contains return address
    ####################################################

    # adjust stack, restore return address; return
10008#    lw $ra,4($sp)
10012#    addu $sp,$sp,8
10016#    addu $t0,$t0,15
10020#    and $t0,$t0,0xfffffffc
10021##...lui $at,65535
10025##...ori $at,$at,0xfffc
10029##...and $t0,$t0,$at
10032#    jr $ra

########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
10036:mth_intToChar_Lib:
    # save return address
10036#    subu $sp,$sp,4
10040#    sw $ra,($sp)

    # allocate object
10044#    li $s6,2
10048#    move $s7,$zero
10052#    jal newObject

    # get n from string.
10056#    lw $t1,8($sp)

    # store "String" tag into class field
10060#    la $t0,CLASS_String
10064#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
10068#    lw $t4,-8($s7) # # data words in source string
10072#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
10073##...slt $at,$t4,$zero
10077##...beq $at,$zero,10096
10080#    and $t4,0xff # mask off object's hash value ...
10081##...lui $at,0
10085##...ori $at,$at,0xff
10089##...and $t4,$t4,$at
10092#    sw $t4,-8($s7) # ... and store back into -8 header-word
10096:  skipMask_intToChar:

    # store data in string
10096#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
10100#    li $t0,-1
10104#    sw $t0,-4($s7)

    # we're returning $s7
10108#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
10112#    lw $ra,4($sp)
10116#    addu $sp,$sp,8

    # return
10120#    jr $ra

########################################################
# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
10124:mth_compareTo_String:
    # get string pointers and check parameter for null
10124#    lw $t0,($sp) # second string
10128#    beq $t0,$zero,nullPtrException
10132#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
10136#    lw $t2,-4($t0) # negative length of second string
10140#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
10144#    slt $t4,$t3,$t2
10148#    slt $t5,$t2,$t3
10152#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
10156#    lw $t2,-8($t0) # # data words in second string
10160#    lw $t3,-8($t1) # # data words in first string
10164#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
10168#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
10172#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
10176#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
10180#    beq $zero,$t5,skipStrCmpLenzz
10184#    move $t2,$t3
10188:  skipStrCmpLenzz:
10188#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
10192:  cmpLoopzz:
10192#    lw $t3,-8($t1) # word from str2
10196#    lw $t4,-8($t0) # word from str1
10200#    bne $t3,$t4,cmpNotEqualzz
10204#    addu $t1,$t1,4
10208#    addu $t0,$t0,4
10212#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
10216#    j cmpHitLimitzz

10220:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
10220#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
10224#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
10228#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
10232:  cmpHitLimitzz:
10232#    move $t0, $t5 # store return value
10236#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
10240:readLogicalChar:

    # check if we already have a character
10240#    lw $v0,lastCharRead
10244#    li $t0,-2
10248#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
10252#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
10256#    jr $ra # return
    
10260:  doReadCh:
    # we need to actually read a character: read and return
10260#    li $v0,12 # use system call to read a character
10264#    syscall
10268#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
10272:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
10272#    blt $s7,$zero arraySizeOutOfBounds
10273##...slt $at,$s7,$zero
10277##...bne $at,$zero,11268

    # mark the fact that we have not yet GC'd for this allocation
10280#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

10284:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
10284#    addu $t0,$s6,$s7
10288#    sll $t0,$t0,2
10292#    addu $t0,$t0,8 # amount of memory needed
10296#    addu $t1,$t0,$s3
10300#    bgtu $t1,$s4,doGC
10301##...sltu $at,$s4,$t1
10305##...bne $at,$zero,10428

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
10308#    move $t2,$s3

10349##...beq $at,$zero,10396
10352#    lw $t1,prevHashConstant
10356#    addu $t1,0x12b68fd2
10357##...lui $at,4791
10361##...addiu $at,$at,-28718
10365##...addu $t1,$at,$t1
10368#    sw $t1,prevHashConstant # update hash constant

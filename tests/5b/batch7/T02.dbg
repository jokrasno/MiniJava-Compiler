10461##...lui $t6,16
10465##...addiu $t6,$t6,12000
10468#    la $s3,seg0_start
10472#    la $s4,seg0_end
10473##...lui $s4,16
10477##...addiu $s4,$s4,12000
10480#    sw $zero,cur_seg
10484#    bne $t0,$zero,skipGc1
10488#    la $t6,seg0_start
10492#    la $s3,seg1_start
10493##...lui $s3,16
10497##...addiu $s3,$s3,12000
10500#    la $s4,seg1_end
10501##...lui $s4,32
10505##...addiu $s4,$s4,12000
10508#    sw $s5,cur_seg
10512:  skipGc1:
10512#    li $t5,0x80000000
10516#    lw $t0,stack_bottom
10520#    subu $t0,4

1601##...bne $at,$zero,1644
1604#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1608#    subu $t0,$v0,10
1612#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1616#    subu $t0,$v0,9
1620#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1624#    subu $t0,$v0,13
1628#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1632#    subu $t0,$v0,12
1636#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1640#    j badIntegerFormat # illegal integer char: abort program

1644:  nonWhite:
1644#    subu $t0,$v0,'-'
1648#    li $t4,1 # final multiplier
1652#    bne $t0,$zero,helpReadInt # go read
1656#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1660#    jal readLogicalChar

1664:  helpReadInt:
1664#    li $t2,10
1668#    subu $t1,$v0,'0' # convert digit to 0-9 value
1672#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1673##...sltu $at,$t1,$t2
1677##...beq $at,$zero,3924
1680#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1684:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1684#    jal readLogicalChar # read next character
1688#    subu $t1,$v0,'0' # convert digit to 0-9 value
1692#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1693##...sltu $at,$t1,$t2
1697##...beq $at,$zero,1716

1700#    mul $t3,$t3,$t2 # multiply old value by 10
1701##...mult $t3,$t2
1705##...mflo $t3
1708#    addu $t3,$t3,$t1 # add in value of new digit
1712#    j digitLoop

1716:  doneDigitLoop:

    # "push back" unused character into queue

1308#    seq $t0,$t0,$zero
1309##...subu $at,$t0,$zero
1313##...sltiu $t0,$at,1

    # pop return address and return $t0
1316#    lw $ra,($sp)
1320#    addu $sp,4

1324#    jr $ra # return
    
1328:goEsFalse:
    # put 0 in $t0 and return
1328#    li $t0, 0
1332#    jr $ra # return

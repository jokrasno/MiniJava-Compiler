3132#    la $s3,seg1_start
3133##...lui $s3,16
3137##...addiu $s3,$s3,4524
3140#    la $s4,seg1_end
3141##...lui $s4,32
3145##...addiu $s4,$s4,4524
3148#    sw $s5,cur_seg
3152:  skipGc1:
3152#    li $t5,0x80000000
3156#    lw $t0,stack_bottom
3160#    subu $t0,4

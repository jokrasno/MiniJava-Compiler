1125##...slt $at,$t0,$zero
1129##...beq $at,$zero,1148
1132#    and $t0,0xff # mask off object's hash value ...
1133##...lui $at,0
1137##...ori $at,$at,0xff
1141##...and $t0,$t0,$at
1144#    sw $t0,-8($s7) # ... and store back into -8 header-word
1148:skipMask_toString:
1148#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1152#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1156#    subu $t4,$t2,$t5
1160:toString_copyLoop:    
1160#    lb $t3,($t4)
1164#    and $t3,0x7f # mask off sign bit (in case first word)
1165##...lui $at,0
1169##...ori $at,$at,0x7f
1173##...and $t3,$t3,$at
1176#    sb $t3,-8($t0)

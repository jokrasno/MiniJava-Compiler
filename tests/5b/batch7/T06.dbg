###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1344:mth_readLine_Lib:
    
1344#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1348#    sw $ra, 4($sp) # save $ra
1352#    move $t1,$sp # save "original" sp

1356:  doRead:

    # read the character
1356#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1360#    subu $t2,$v0,13
1364#    bne $t2,$zero,notReturnRL
1368#    jal readLogicalChar
1372#    subu $t2,$v0,10 # check for newline
1376#    beq $t2,$zero,foundNewLine
1380#    sw $v0,lastCharRead # push back character into queue
1384#    j foundNewLine # go process the line

1388:  notReturnRL:

    # at this point, $v0 has our character

1388#    subu $t0,$v0,10
1392#    beq $t0,$zero,foundNewLine
1396#    blt $v0,$zero,foundEof
1397##...slt $at,$v0,$zero
1401##...bne $at,$zero,1416

    # we have a character, so push it onto stack
1404#    subu $sp,$sp,4
1408#    sw $v0,($sp)

    # loop back up to get next character
1412#    j doRead

1416:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1416#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1420#    li $s7, 0 # return-value: null
1424#    j rlReturn # return

1428:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1428#    subu $t0,$t1,$sp # number of chars we read (times 4)
1432#    srl $s6,$t0,2 # number of words on stack with chars
1436#    subu $sp,$sp,4 # push char-count ...
1440#    sw $s6,($sp) # ... onto stack
1444#    addu $t2,$t0,5 # GC tag, incl. for count-word
1448#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1452#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1456#    srl $s6,$s6,2  # data words in object
1460#    move $s7,$zero # object words in object
1464#    jal newObject  # allocate space
    
    # store header words
1468#    la $t0,CLASS_String
1472#    sw $t0,-12($s7)# store class tag (String) into object
1476#    lw $t2,4($sp) # char-count
1480#    sll $t1,$t2,2 # 4 times number of chars
1484#    subu $t2,$zero,$t2 # negative of char-count
1488#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1492#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1496#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1497##...slt $at,$t0,$zero
1501##...beq $at,$zero,1520
1504#    and $t0,0xff # mask off object's hash value ...
1505##...lui $at,0
1509##...ori $at,$at,0xff
1513##...and $t0,$t0,$at
1516#    sw $t0,-8($s7) # ... and store back into -8 header-word
1520:  skipMask_readLine:

1520#    sll $t0,$t0,2 # data bytes in object
1524#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1528#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1532#    addu $sp,$sp,8 # pop redundant object-pointer and count
1536#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1540#    beq $sp,$t1,rlReturn
1544:  charCopyLoop:
1544#    lw $t2,($sp)
1548#    sb $t2,-9($t0)
1552#    addu $sp,$sp,4
1556#    subu $t0,$t0,1
1560#    bne $sp,$t1,charCopyLoop
1564:  rlReturn:

1564#    lw $ra, 4($sp)
1568#    addu $sp, 8   # pop $ra and pointless word off stack
1572#    move $t0, $s7 # return string we allocated in $s7
1576#    jr $ra

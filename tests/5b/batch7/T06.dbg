    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1280#    subu $sp,12
1284#    sw $ra,8($sp)
1288#    sw $s2,4($sp)
1292#    sw $t0,($sp)
1296#    jal mth_compareTo_String
1300#    lw $s2, 4($sp) #restore this pointer and pop parameters
1304#    addu $sp, 8 # pop parameters

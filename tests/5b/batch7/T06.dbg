2985##...sltu $at,$s6,$t2
2989##...beq $at,$zero,3036
2992#    lw $t1,prevHashConstant
2996#    addu $t1,0x12b68fd2
2997##...lui $at,4791
3001##...addiu $at,$at,-28718
3005##...addu $t1,$at,$t1
3008#    sw $t1,prevHashConstant # update hash constant
3012#    or $t1,0x80000000 # set top bit
3013##...lui $at,32768
3017##...or $t1,$at,$t1
3020#    and $t1,0xffffff00 # clear low bit
3021##...lui $at,65535
3025##...ori $at,$at,0xff00
3029##...and $t1,$t1,$at
3032#    or $s6,$t1
3036:firstHeaderLarge:
3036#    sw $s6,-8($t0) # store header-1 value
3040#    lw $zero,-8($t0)

    # store second header-value
3044#    sw $s7,-4($t0)   # second header-word
3048#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
3052#    move $s7,$t0
3056#    subu $sp,$sp,4
3060#    sw $t0,($sp)

3064#    jr $ra

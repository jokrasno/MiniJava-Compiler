##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2164:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
2164#    lw $t0,-8($s2) # get word with hash bits from this
2168#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
2172#    addu $t0,$t1

2176#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2180:mth_equals_Object:
2180#    move $t0,$s2 # first pointer (this)
2184#    lw $t1,($sp) # second pointer
2188#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
2189##...subu $at,$t0,$t1
2193##...sltiu $t0,$at,1

2196#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2200:mth_hashCode_String:
2200#    move $t0,$s2 # put this pointer in t0

2204#    li $t2,0 # current hash value
2208#    lw $t1,-4($t0) # negative of number of characters in string
2212#    beq $t1,$zero,done_hashCode_String # if zero length => done
2216#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
2220#    and $t0,0xfffffffc # adjust for padding
2221##...lui $at,65535
2225##...ori $at,$at,0xfffc
2229##...and $t0,$t0,$at
2232#    subu $t1,$t0,$t1 # address at end of string +12
2236:loop_hashCode_String:    
2236#    sll $t4,$t2,5 # multiply by 32
2240#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
2244#    lbu $t3,-12($t0) # current character
2248#    addu $t2,$t3 # add in current character
2252#    addu $t0,1 # go to next character's address
2256#    bne $t0,$t1,loop_hashCode_String # loop back if more
2260:done_hashCode_String:    

    # push int on stack
2260#    move $t0, $t2 # put $t2 in return slot
2264#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
2268:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
2268#    subu $sp,4
2272#    sw $ra,($sp)
    
    # get hash value
2276#    lw $t2,-12($s2) # vtable address
2280#    lw $t0,($t2) # method address
2284#    jalr $t0
2288#    subu $sp,8 # push result (int in $t0) on stack
2292#    sw $s5,4($sp)
2296#    sw $t0,($sp)

    # compute print-size of hash value
2300#    li $t0, 1
2304#    lw $t1, ($sp)
2308#    srl $t1,$t1,4
2312#    beq $t1,$zero,toString_skip_loop
2316:toString_loop_top:
2316#    addu $t0,1
2320#    srl $t1,$t1,4
2324#    bne $t1,$zero,toString_loop_top
2328:toString_skip_loop:
2328#    subu $sp,8
2332#    sw $s5,4($sp)
2336#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
2340#    lw $t2,-12($s2) # vtable address
2344#    move $t0,$t2
2348:toString_checkTagBit:
2348#    subu $t0,1
2352#    lb $t1,($t0)
2356#    and $t1,0x80
2357##...lui $at,0
2361##...ori $at,$at,0x80
2365##...and $t1,$t1,$at
2368#    beq $t1,$zero,toString_checkTagBit
2372#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
2376#    subu $sp,8
2380#    sw $t1,($sp)
2384#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
2388#    move $s7,$zero # -4 offset header word
2392#    lw $t4,8($sp) # bytes for hash value
2396#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
2400#    addu $t4,8
2404#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
2408#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

2412#    li $t0,CLASS_String # store string vtable address into ...
2416#    sw $t0,-12($s7) # ... -12 offset in object header
2420#    lw $t2,-12($s2) # our object's vtable address
2424#    lw $t5,4($sp) # number characters in prefix
2428#    lw $t1,12($sp) # number of characters in hashcode
2432#    addu $t3,$t1,$t5 # number of characters in string ...
2436#    addu $t3,1 # ... including the '@' character
2440#    subu $t0,$zero,$t3 # store negated length into ...
2444#    sw $t0,-4($s7) # ... -4 offset header word
2448#    lw $t0,-8($s7) # get -8 offset header-word
2452#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2453##...slt $at,$t0,$zero
2457##...beq $at,$zero,2476
2460#    and $t0,0xff # mask off object's hash value ...
2461##...lui $at,0
2465##...ori $at,$at,0xff
2469##...and $t0,$t0,$at
2472#    sw $t0,-8($s7) # ... and store back into -8 header-word
2476:skipMask_toString:
2476#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2480#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2484#    subu $t4,$t2,$t5
2488:toString_copyLoop:    
2488#    lb $t3,($t4)
2492#    and $t3,0x7f # mask off sign bit (in case first word)
2493##...lui $at,0
2497##...ori $at,$at,0x7f
2501##...and $t3,$t3,$at
2504#    sb $t3,-8($t0)
2508#    addu $t4,1
2512#    addu $t0,1
2516#    blt $t4,$t2,toString_copyLoop
2517##...slt $at,$t4,$t2
2521##...bne $at,$zero,2488

    # copy the '@' sign
2524#    li $t3,'@'
2528#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2532#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2536#    lw $t3,20($sp) # hash code to print
2540:toString_hashCopyLoop:
2540#    and $t4,$t3,0xf
2544#    srl $t3,4
2548#    lb $t4,hexChars($t4)
2552#    sb $t4,-8($t2)
2556#    subu $t2,$t2,1
2560#    bgt $t2,$t0,toString_hashCopyLoop
2561##...slt $at,$t0,$t2
2565##...bne $at,$zero,2540

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2568#    addu $sp,28
2572#    lw $ra,($sp)
2576#    addu $sp,4
2580#    move $t0, $s7 # return string we created
2584#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2588:mth_equals_String:
    
    # quick test for obvious false
2588#    lw $t0,($sp) # second parameter
2592#    beq $t0,$zero,goEsFalse # go return false if null
2596#    lw $t1,-12($t0) # vtable pointer
2600#    la $t2,CLASS_String # string vtable pointer
2604#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2608#    subu $sp,12
2612#    sw $ra,8($sp)
2616#    sw $s2,4($sp)
2620#    sw $t0,($sp)
2624#    jal mth_compareTo_String
2628#    lw $s2, 4($sp) #restore this pointer and pop parameters
2632#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2636#    seq $t0,$t0,$zero
2637##...subu $at,$t0,$zero
2641##...sltiu $t0,$at,1

    # pop return address and return $t0
2644#    lw $ra,($sp)
2648#    addu $sp,4

2652#    jr $ra # return
    
2656:goEsFalse:
    # put 0 in $t0 and return
2656#    li $t0, 0
2660#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2664:mth_toString_String:
    #we are a string, so return this.
2664#    move $t0, $s2
2668#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2672:mth_readLine_Lib:
    
2672#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2676#    sw $ra, 4($sp) # save $ra
2680#    move $t1,$sp # save "original" sp

2684:  doRead:

    # read the character
2684#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2688#    subu $t2,$v0,13
2692#    bne $t2,$zero,notReturnRL
2696#    jal readLogicalChar
2700#    subu $t2,$v0,10 # check for newline
2704#    beq $t2,$zero,foundNewLine
2708#    sw $v0,lastCharRead # push back character into queue
2712#    j foundNewLine # go process the line

2716:  notReturnRL:

    # at this point, $v0 has our character

2716#    subu $t0,$v0,10
2720#    beq $t0,$zero,foundNewLine
2724#    blt $v0,$zero,foundEof
2725##...slt $at,$v0,$zero
2729##...bne $at,$zero,2744

    # we have a character, so push it onto stack
2732#    subu $sp,$sp,4
2736#    sw $v0,($sp)

    # loop back up to get next character
2740#    j doRead

2744:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2744#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2748#    li $s7, 0 # return-value: null
2752#    j rlReturn # return

2756:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2756#    subu $t0,$t1,$sp # number of chars we read (times 4)
2760#    srl $s6,$t0,2 # number of words on stack with chars
2764#    subu $sp,$sp,4 # push char-count ...
2768#    sw $s6,($sp) # ... onto stack
2772#    addu $t2,$t0,5 # GC tag, incl. for count-word
2776#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2780#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2784#    srl $s6,$s6,2  # data words in object
2788#    move $s7,$zero # object words in object
2792#    jal newObject  # allocate space
    
    # store header words
2796#    la $t0,CLASS_String
2800#    sw $t0,-12($s7)# store class tag (String) into object
2804#    lw $t2,4($sp) # char-count
2808#    sll $t1,$t2,2 # 4 times number of chars
2812#    subu $t2,$zero,$t2 # negative of char-count
2816#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2820#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2824#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2825##...slt $at,$t0,$zero
2829##...beq $at,$zero,2848
2832#    and $t0,0xff # mask off object's hash value ...
2833##...lui $at,0
2837##...ori $at,$at,0xff
2841##...and $t0,$t0,$at
2844#    sw $t0,-8($s7) # ... and store back into -8 header-word
2848:  skipMask_readLine:

2848#    sll $t0,$t0,2 # data bytes in object
2852#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2856#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2860#    addu $sp,$sp,8 # pop redundant object-pointer and count
2864#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2868#    beq $sp,$t1,rlReturn
2872:  charCopyLoop:
2872#    lw $t2,($sp)
2876#    sb $t2,-9($t0)
2880#    addu $sp,$sp,4
2884#    subu $t0,$t0,1
2888#    bne $sp,$t1,charCopyLoop
2892:  rlReturn:

2892#    lw $ra, 4($sp)
2896#    addu $sp, 8   # pop $ra and pointless word off stack
2900#    move $t0, $s7 # return string we allocated in $s7
2904#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2908:mth_readInt_Lib:

    # save $ra by pushing onto stack
2908#    subu $sp,$sp,4
2912#    sw $ra,($sp)

2916:  riSkipWhiteLoop:
    # read a character
2916#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2920#    subu $t0,$v0,32
2924#    bgt $t0,$zero,nonWhite
2925##...slt $at,$zero,$t0
2929##...bne $at,$zero,2972
2932#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2936#    subu $t0,$v0,10
2940#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2944#    subu $t0,$v0,9
2948#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2952#    subu $t0,$v0,13
2956#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2960#    subu $t0,$v0,12
2964#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2968#    j badIntegerFormat # illegal integer char: abort program

2972:  nonWhite:
2972#    subu $t0,$v0,'-'
2976#    li $t4,1 # final multiplier
2980#    bne $t0,$zero,helpReadInt # go read
2984#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2988#    jal readLogicalChar

2992:  helpReadInt:
2992#    li $t2,10
2996#    subu $t1,$v0,'0' # convert digit to 0-9 value
3000#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
3001##...sltu $at,$t1,$t2
3005##...beq $at,$zero,5252
3008#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

3012:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

3012#    jal readLogicalChar # read next character
3016#    subu $t1,$v0,'0' # convert digit to 0-9 value
3020#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
3021##...sltu $at,$t1,$t2
3025##...beq $at,$zero,3044

3028#    mul $t3,$t3,$t2 # multiply old value by 10
3029##...mult $t3,$t2
3033##...mflo $t3
3036#    addu $t3,$t3,$t1 # add in value of new digit
3040#    j digitLoop

3044:  doneDigitLoop:

    # "push back" unused character into queue
3044#    sw $v0,lastCharRead

    # restore return address
3048#    lw $ra,($sp)
3052#    addu $sp, 4

    # multiply by sign and put return value in $t0
3056#    mult $t3,$t4 # multiply to account for poss. minus sign
3060#    mflo $t3
3064#    move $t0, $t3
    
    # return
3068#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3072:mth_readChar_Lib:

    # save $ra by pushing onto stack
3072#    subu $sp,$sp,4
3076#    sw $ra,($sp)

      # read the character
3080#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
3084#    lw $ra,($sp)
3088#    addu $sp, 4
3092#    move $t0, $v0

    # return
3096#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
3100:mth_printStr_Lib:
    # check for null, printing "(null)", if so
3100#    lw $t0,($sp)
3104#    bne $t0,$zero,psNotNull

    # print "(null)"
3108#    la $a0,nullStr
3112#    li $v0,4
3116#    syscall
3120#    j donePrintStr
    
3124:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
3124#    subu $t0,$t0,8
3128#    lw $t1,($t0) # number of data words, but needs modification
3132#    blt $t1,$zero,skipPrintStr1
3133##...slt $at,$t1,$zero
3137##...bne $at,$zero,3156
3140#    and $t1,0xff # mask out all but low byte
3141##...lui $at,0
3145##...ori $at,$at,0xff
3149##...and $t1,$t1,$at
3152#    b skipPrintStr2
3156:skipPrintStr1:
3156#    and $t1,0x7ffffff
3157##...lui $at,2047
3161##...ori $at,$at,0xffff
3165##...and $t1,$t1,$at
3168:skipPrintStr2:    
3168#    sll $t1,$t1,2
3172#    subu $t1,$t0,$t1 # first word in string
3176#    lw $t0,4($t0) # negative of string-length
3180#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
3184#    beq $t0,$t1,donePrintStr
3188:  psLoop:
3188#    lb $a0,($t1) # next byte
3192#    li $v0,11 # code for printing char
3196#        syscall # print the char
3200#    addu $t1,$t1,1 # go to next char
3204#    blt $t1,$t0,psLoop
3205##...slt $at,$t1,$t0
3209##...bne $at,$zero,3188

3212:  donePrintStr:
3212#    jr $ra

########################################################
# printInt(n) - library method (class Lib)
# - prints integer in decimal format to standard output
# - parameters:
#   - ($sp) - the integer to print
#   - 4($sp) - GC tag
#   - ($sp) - old-this-pointer
########################################################
3216:mth_printInt_Lib:
3216#    lw $a0,($sp)

    # print it
3220#    li $v0,1 # code for print-int

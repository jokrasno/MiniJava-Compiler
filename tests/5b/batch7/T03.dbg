    # return
3228#    jr $ra

########################################################
# printBool(n) - library method (class Lib)
# - prints boolean to standard output
# - parameters:
#   - ($sp) - the boolean to print
#   - 4($sp) - old-this-pointer
########################################################
3232:mth_printBool_Lib:
    # pop value off stack, along with 'this'
3232#    lw $t0,($sp)

    # print either 'true' or 'false', depending on the value
3236#    la $a0,falseString
3240#    beq $t0,$zero,skipPB
3244#    la $a0,trueString
3248:  skipPB:
3248#    li $v0,4 # code for print-string
3252#    syscall

    # return
3256#    jr $ra

########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
3260:mth_substring_String:

    # save $ra by pushing onto stack
3260#    subu $sp,$sp,4
3264#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
3268#    move $t0,$s2
3272#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
3276#    lw $t0,-4($t0) # negative of string length
3280#    subu $t0,$zero,$t0 # string length
3284#    lw $t1,4($sp) # k
3288#    lw $t2,12($sp) # n
3292#    bgt $zero,$t2,strIndexOutOfBounds
3293##...slt $at,$t2,$zero
3297##...bne $at,$zero,5220
3300#    bgt $t2,$t1,strIndexOutOfBounds
3301##...slt $at,$t1,$t2
3305##...bne $at,$zero,5220
3308#    bgt $t1,$t0,strIndexOutOfBounds
3309##...slt $at,$t0,$t1
3313##...bne $at,$zero,5220

    # allocate memory
3316#    subu $s6,$t1,$t2 # # chars in target-string
3320#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
3324#    srl $s6,$s6,2 # convert bytes-count to word-count
3328#    move $s7,$zero # (no object-bytes in string)
3332#    jal newObject

    # store "String" tag in object-type field
3336#    la $t0,CLASS_String
3340#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
3344#    lw $t4,-8($s7) # data words in source string
3348#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
3349##...slt $at,$t4,$zero
3353##...beq $at,$zero,3372
3356#    and $t4,0xff # mask off object's hash value ...
3357##...lui $at,0
3361##...ori $at,$at,0xff
3365##...and $t4,$t4,$at
3368#    sw $t4,-8($s7) # ... and store back into -8 header-word
3372:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
3372#    lw $t1,8($sp) # k
3376#    lw $t2,16($sp) # n
3380#    subu $t0,$t2,$t1 # value to store
3384#    sw $t0,-4($s7) # store value
    
3388#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
3392#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
3396#    lw $t4,-8($t3) # data words in source string
3400#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
3404#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
3408#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
3412#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
3416#    lw $t2,-8($s7)   # data words in target string
3420#    sll $t2,$t2,2    # data bytes in target string
3424#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target
3428:  subCopyLoopzz:
3428#    lb $t4,-8($t3)
3432#    sb $t4,-8($t2)
3436#    addu $t2,$t2,1
3440#    addu $t3,$t3,1
3444#    blt $t3,$t1,subCopyLoopzz
3445##...slt $at,$t3,$t1
3449##...bne $at,$zero,3428
    
3452:  doneSubCopyzz:
    # restore return address, store return value, pop stack
3452#    lw $ra,4($sp) # restore $ra
3456#    addu $sp,$sp,8 # pop ra, and allocated newObject
3460#    move $t0, $s7 # we're returning the string we got back
                  # from newObject
    
    # return
3464#    jr $ra

########################################################
# length() - library method (class String)
# returns length of a string: Java: str.length()
# - parameters:
#   - ($sp) - old this pointer
# - return-value:
#   - $t0 - length of string
########################################################
3468:mth_length_String:

    # the length is the negative of 4($s2)
3468#    lw $t0,-4($s2) # -length
3472#    subu $t0,$zero,$t0

    # return
3476#    jr $ra


########################################################
# str1.concat(str2) - library method (class String)
# (as in Java)
# - parameters:
#   - ($sp) - the second string
#   - 4($sp) - old this pointer
#   - $s2 - the first string (this)
# - returns:
#   - $t0 - pointer to concatenated string
########################################################
3480:mth_concat_String:
    # save $ra by pushing onto stack
3480#    subu $sp,$sp,4
3484#    sw $ra, ($sp)

    # get string pointers and check parameter for null
3488#    lw $t0,4($sp)
3492#    beq $t0,$zero,nullPtrException
3496#    move $t1,$s2
    
    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
3500#    lw $t0,-4($t0) # negative size of second object
3504#    lw $t1,-4($t1) # negative size of first object
3508#    addu $s6,$t0,$t1 # sum of negative sizes
3512#    sra $s6,$s6,2 # negative word-size of char part
3516#    subu $s6,$zero,$s6 # word size of char part
3520#    addu $s6,$s6,1 # data word size, including v-table word
3524#    move $s7,$zero
3528#    jal newObject

    # store String vtable address in vtable address field
3532#    la $t0,CLASS_String
3536#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
3540#    lw $t4,-8($s7) # # data words in source string
3544#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
3545##...slt $at,$t4,$zero
3549##...beq $at,$zero,3568
3552#    and $t4,0xff # mask off object's hash value ...
3553##...lui $at,0
3557##...ori $at,$at,0xff
3561##...and $t4,$t4,$at
3564#    sw $t4,-8($s7) # ... and store back into -8 header-word
3568:skipMask_concat:

3568#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
3572#    move $t1,$s2   # first object
3576#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
3580#    lw $t2,-4($t0) # negative length of second object
3584#    lw $t3,-4($t1) # negative length of first object
3588#    addu $t4,$t2,$t3 # sum of negative lengths
3592#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################


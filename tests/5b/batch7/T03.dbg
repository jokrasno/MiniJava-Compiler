5084#    beq $t0,$zero,divByZeroError
    
    # perform division
5088#    div $t1,$t0
5092#    mfhi $t0

    # store result, adjust stack and return
5096#    addu $sp,$sp,8 # adjust stack
5100#    sw $t0,($sp) # store result
5104#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
5108:checkCast:
    # get object, allow immediately if null
5108#    lw $t2,($sp)
5112#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
5116#    lw $t2,-12($t2) # vtable address
5120#    bge $t2,$t1,castException
5121##...slt $at,$t2,$t1
5125##...beq $at,$zero,5260
5128#    blt $t2,$t0,castException
5129##...slt $at,$t2,$t0
5133##...bne $at,$zero,5260
    
    # return, leaving object unchanged on stack
5136:  checkCastReturn:    
5136#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
5140:instanceOf:
    # get object, go return false if null
5140#    lw $t2,($sp)
5144#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
5148#    lw $t2,-12($t2) # vtable address
5152#    sge $t0,$t2,$t0 # are we >= the lower limit?
5153##...slt $t0,$t2,$t0
5157##...xori $t0,$t0,0x1
5160#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
5164#    and $t2,$t0,$t1
5168#    sw $t2,($sp)
5172:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
5172#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

5176:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
5176#    li $v0,4 # syscall-code for print-string
5180#    syscall
5184:exit:
    # print termination message
5184#    li $v0,4 # syscall-code for print-string
5188#    la $a0,exitString
5192#    syscall

    # terminate execution
5196#    li $v0,10 #syscall-code for "exit"
5200#    syscall

5204:outOfHeapMemory:
5204#    la $a0,heapMemoryMsg
5208#    j exitError
5212:divByZeroError:
5212#    la $a0,divByZeroMsg
5216#    j exitError
5220:strIndexOutOfBounds:
5220#    la $a0,strIndexOutOfBoundsMsg
5224#    j exitError
5228:arrayIndexOutOfBounds:
5228#    la $a0,arrayIndexOutOfBoundsMsg
5232#    j exitError
5236:arraySizeOutOfBounds:
5236#    la $a0,arraySizeOutOfBoundsMsg
5240#    j exitError
5244:nullPtrException:
5244#    la $a0,nullPtrExceptionMsg
5248#    j exitError
5252:badIntegerFormat:
5252#    la $a0,badIntegerFormatMsg
5256#    j exitError
5260:castException:
5260#    la $a0,castExceptionMsg
5264#    j exitError
############## data section ################
    .data
5500:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5516:cur_seg:
    .word 0

5520:lastCharRead:
    .word -2 # -2 => no buffered character
5524:prevHashConstant:
    .word 0x2785173c
5528:gcCount:
    .word 0

5532:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5559:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5582:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5617:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5651:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5684:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5715:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5763:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5784:gcMsg: 
      .asciiz "\nGC!\n"
5790:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5822:nullStr:
    .asciiz "null"
5827:trueString:
    .asciiz "true"
5832:falseString:
    .asciiz "false"
5838:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5857:newlineString:
    .asciiz "\n"
    
    .align 2
5860:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5864:seg0_start:
    .space 0x100000
1054440:seg0_end:
1054440:seg1_start:
    .space 0x100000
2103016:seg1_end:

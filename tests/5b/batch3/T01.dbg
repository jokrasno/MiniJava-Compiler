3248#    subu $t0,$zero,$t0 # string length
3252#    lw $t1,4($sp) # k
3256#    lw $t2,12($sp) # n
3260#    bgt $zero,$t2,strIndexOutOfBounds
3261##...slt $at,$t2,$zero
3265##...bne $at,$zero,5188
3268#    bgt $t2,$t1,strIndexOutOfBounds
3269##...slt $at,$t1,$t2
3273##...bne $at,$zero,5188

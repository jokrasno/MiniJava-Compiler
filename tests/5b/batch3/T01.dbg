3277##...slt $at,$t0,$t1
3281##...bne $at,$zero,5188

    # allocate memory
3284#    subu $s6,$t1,$t2 # # chars in target-string
3288#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
3292#    srl $s6,$s6,2 # convert bytes-count to word-count
3296#    move $s7,$zero # (no object-bytes in string)
3300#    jal newObject

    # store "String" tag in object-type field
3304#    la $t0,CLASS_String
3308#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
3312#    lw $t4,-8($s7) # data words in source string

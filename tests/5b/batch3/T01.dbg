##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2132:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
2132#    lw $t0,-8($s2) # get word with hash bits from this
2136#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
2140#    addu $t0,$t1

2144#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2148:mth_equals_Object:
2148#    move $t0,$s2 # first pointer (this)
2152#    lw $t1,($sp) # second pointer
2156#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
2157##...subu $at,$t0,$t1
2161##...sltiu $t0,$at,1

2164#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2168:mth_hashCode_String:
2168#    move $t0,$s2 # put this pointer in t0

2172#    li $t2,0 # current hash value
2176#    lw $t1,-4($t0) # negative of number of characters in string
2180#    beq $t1,$zero,done_hashCode_String # if zero length => done
2184#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
2188#    and $t0,0xfffffffc # adjust for padding
2189##...lui $at,65535
2193##...ori $at,$at,0xfffc
2197##...and $t0,$t0,$at
2200#    subu $t1,$t0,$t1 # address at end of string +12
2204:loop_hashCode_String:    
2204#    sll $t4,$t2,5 # multiply by 32
2208#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
2212#    lbu $t3,-12($t0) # current character
2216#    addu $t2,$t3 # add in current character
2220#    addu $t0,1 # go to next character's address
2224#    bne $t0,$t1,loop_hashCode_String # loop back if more
2228:done_hashCode_String:    

    # push int on stack
2228#    move $t0, $t2 # put $t2 in return slot
2232#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
2236:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
2236#    subu $sp,4
2240#    sw $ra,($sp)
    
    # get hash value
2244#    lw $t2,-12($s2) # vtable address
2248#    lw $t0,($t2) # method address
2252#    jalr $t0
2256#    subu $sp,8 # push result (int in $t0) on stack
2260#    sw $s5,4($sp)
2264#    sw $t0,($sp)

    # compute print-size of hash value
2268#    li $t0, 1
2272#    lw $t1, ($sp)
2276#    srl $t1,$t1,4
2280#    beq $t1,$zero,toString_skip_loop
2284:toString_loop_top:
2284#    addu $t0,1
2288#    srl $t1,$t1,4
2292#    bne $t1,$zero,toString_loop_top
2296:toString_skip_loop:
2296#    subu $sp,8
2300#    sw $s5,4($sp)
2304#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
2308#    lw $t2,-12($s2) # vtable address
2312#    move $t0,$t2
2316:toString_checkTagBit:
2316#    subu $t0,1
2320#    lb $t1,($t0)
2324#    and $t1,0x80
2325##...lui $at,0
2329##...ori $at,$at,0x80
2333##...and $t1,$t1,$at
2336#    beq $t1,$zero,toString_checkTagBit
2340#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
2344#    subu $sp,8
2348#    sw $t1,($sp)
2352#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
2356#    move $s7,$zero # -4 offset header word
2360#    lw $t4,8($sp) # bytes for hash value
2364#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
2368#    addu $t4,8
2372#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
2376#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

2380#    li $t0,CLASS_String # store string vtable address into ...
2384#    sw $t0,-12($s7) # ... -12 offset in object header
2388#    lw $t2,-12($s2) # our object's vtable address
2392#    lw $t5,4($sp) # number characters in prefix
2396#    lw $t1,12($sp) # number of characters in hashcode
2400#    addu $t3,$t1,$t5 # number of characters in string ...
2404#    addu $t3,1 # ... including the '@' character
2408#    subu $t0,$zero,$t3 # store negated length into ...
2412#    sw $t0,-4($s7) # ... -4 offset header word
2416#    lw $t0,-8($s7) # get -8 offset header-word
2420#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2421##...slt $at,$t0,$zero
2425##...beq $at,$zero,2444
2428#    and $t0,0xff # mask off object's hash value ...
2429##...lui $at,0
2433##...ori $at,$at,0xff
2437##...and $t0,$t0,$at
2440#    sw $t0,-8($s7) # ... and store back into -8 header-word
2444:skipMask_toString:
2444#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2448#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2452#    subu $t4,$t2,$t5
2456:toString_copyLoop:    
2456#    lb $t3,($t4)
2460#    and $t3,0x7f # mask off sign bit (in case first word)
2461##...lui $at,0
2465##...ori $at,$at,0x7f
2469##...and $t3,$t3,$at
2472#    sb $t3,-8($t0)
2476#    addu $t4,1
2480#    addu $t0,1
2484#    blt $t4,$t2,toString_copyLoop
2485##...slt $at,$t4,$t2
2489##...bne $at,$zero,2456

    # copy the '@' sign
2492#    li $t3,'@'
2496#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2500#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2504#    lw $t3,20($sp) # hash code to print
2508:toString_hashCopyLoop:
2508#    and $t4,$t3,0xf
2512#    srl $t3,4
2516#    lb $t4,hexChars($t4)
2520#    sb $t4,-8($t2)
2524#    subu $t2,$t2,1
2528#    bgt $t2,$t0,toString_hashCopyLoop
2529##...slt $at,$t0,$t2
2533##...bne $at,$zero,2508

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2536#    addu $sp,28
2540#    lw $ra,($sp)
2544#    addu $sp,4
2548#    move $t0, $s7 # return string we created
2552#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2556:mth_equals_String:
    
    # quick test for obvious false
2556#    lw $t0,($sp) # second parameter
2560#    beq $t0,$zero,goEsFalse # go return false if null
2564#    lw $t1,-12($t0) # vtable pointer
2568#    la $t2,CLASS_String # string vtable pointer
2572#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2576#    subu $sp,12
2580#    sw $ra,8($sp)
2584#    sw $s2,4($sp)
2588#    sw $t0,($sp)
2592#    jal mth_compareTo_String
2596#    lw $s2, 4($sp) #restore this pointer and pop parameters
2600#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2604#    seq $t0,$t0,$zero
2605##...subu $at,$t0,$zero
2609##...sltiu $t0,$at,1

    # pop return address and return $t0
2612#    lw $ra,($sp)
2616#    addu $sp,4

2620#    jr $ra # return
    
2624:goEsFalse:
    # put 0 in $t0 and return
2624#    li $t0, 0
2628#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2632:mth_toString_String:
    #we are a string, so return this.
2632#    move $t0, $s2
2636#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2640:mth_readLine_Lib:
    
2640#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2644#    sw $ra, 4($sp) # save $ra
2648#    move $t1,$sp # save "original" sp

2652:  doRead:

    # read the character
2652#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2656#    subu $t2,$v0,13
2660#    bne $t2,$zero,notReturnRL
2664#    jal readLogicalChar
2668#    subu $t2,$v0,10 # check for newline
2672#    beq $t2,$zero,foundNewLine
2676#    sw $v0,lastCharRead # push back character into queue
2680#    j foundNewLine # go process the line

2684:  notReturnRL:

    # at this point, $v0 has our character

2684#    subu $t0,$v0,10
2688#    beq $t0,$zero,foundNewLine
2692#    blt $v0,$zero,foundEof
2693##...slt $at,$v0,$zero
2697##...bne $at,$zero,2712

    # we have a character, so push it onto stack
2700#    subu $sp,$sp,4
2704#    sw $v0,($sp)

    # loop back up to get next character
2708#    j doRead

2712:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2712#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2716#    li $s7, 0 # return-value: null
2720#    j rlReturn # return

2724:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2724#    subu $t0,$t1,$sp # number of chars we read (times 4)
2728#    srl $s6,$t0,2 # number of words on stack with chars
2732#    subu $sp,$sp,4 # push char-count ...
2736#    sw $s6,($sp) # ... onto stack
2740#    addu $t2,$t0,5 # GC tag, incl. for count-word
2744#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2748#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2752#    srl $s6,$s6,2  # data words in object
2756#    move $s7,$zero # object words in object
2760#    jal newObject  # allocate space
    
    # store header words
2764#    la $t0,CLASS_String
2768#    sw $t0,-12($s7)# store class tag (String) into object
2772#    lw $t2,4($sp) # char-count
2776#    sll $t1,$t2,2 # 4 times number of chars
2780#    subu $t2,$zero,$t2 # negative of char-count
2784#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2788#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2792#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2793##...slt $at,$t0,$zero
2797##...beq $at,$zero,2816
2800#    and $t0,0xff # mask off object's hash value ...
2801##...lui $at,0
2805##...ori $at,$at,0xff
2809##...and $t0,$t0,$at
2812#    sw $t0,-8($s7) # ... and store back into -8 header-word
2816:  skipMask_readLine:

2816#    sll $t0,$t0,2 # data bytes in object
2820#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2824#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2828#    addu $sp,$sp,8 # pop redundant object-pointer and count
2832#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2836#    beq $sp,$t1,rlReturn
2840:  charCopyLoop:
2840#    lw $t2,($sp)
2844#    sb $t2,-9($t0)
2848#    addu $sp,$sp,4
2852#    subu $t0,$t0,1
2856#    bne $sp,$t1,charCopyLoop
2860:  rlReturn:

2860#    lw $ra, 4($sp)
2864#    addu $sp, 8   # pop $ra and pointless word off stack
2868#    move $t0, $s7 # return string we allocated in $s7
2872#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2876:mth_readInt_Lib:

    # save $ra by pushing onto stack
2876#    subu $sp,$sp,4
2880#    sw $ra,($sp)

2884:  riSkipWhiteLoop:
    # read a character
2884#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2888#    subu $t0,$v0,32
2892#    bgt $t0,$zero,nonWhite
2893##...slt $at,$zero,$t0
2897##...bne $at,$zero,2940
2900#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2904#    subu $t0,$v0,10
2908#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2912#    subu $t0,$v0,9
2916#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2920#    subu $t0,$v0,13
2924#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2928#    subu $t0,$v0,12
2932#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2936#    j badIntegerFormat # illegal integer char: abort program

2940:  nonWhite:
2940#    subu $t0,$v0,'-'
2944#    li $t4,1 # final multiplier
2948#    bne $t0,$zero,helpReadInt # go read
2952#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2956#    jal readLogicalChar

2960:  helpReadInt:
2960#    li $t2,10
2964#    subu $t1,$v0,'0' # convert digit to 0-9 value
2968#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2969##...sltu $at,$t1,$t2
2973##...beq $at,$zero,5220
2976#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2980:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2980#    jal readLogicalChar # read next character
2984#    subu $t1,$v0,'0' # convert digit to 0-9 value
2988#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2989##...sltu $at,$t1,$t2
2993##...beq $at,$zero,3012

2996#    mul $t3,$t3,$t2 # multiply old value by 10
2997##...mult $t3,$t2
3001##...mflo $t3
3004#    addu $t3,$t3,$t1 # add in value of new digit
3008#    j digitLoop

3012:  doneDigitLoop:

    # "push back" unused character into queue
3012#    sw $v0,lastCharRead

    # restore return address
3016#    lw $ra,($sp)
3020#    addu $sp, 4

    # multiply by sign and put return value in $t0
3024#    mult $t3,$t4 # multiply to account for poss. minus sign
3028#    mflo $t3
3032#    move $t0, $t3
    
    # return
3036#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3040:mth_readChar_Lib:

    # save $ra by pushing onto stack
3040#    subu $sp,$sp,4
3044#    sw $ra,($sp)

      # read the character
3048#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
3052#    lw $ra,($sp)
3056#    addu $sp, 4
3060#    move $t0, $v0

    # return
3064#    jr $ra


4248#    sw $zero,($s3)
4252#    lw $zero,($s3)

4256#    addu $s3,4
4260#    bltu $s3,$t1,zeroObjLoop
4261##...sltu $at,$s3,$t1
4265##...bne $at,$zero,4248

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
4268#    sll $t0,$s7,2    # number of post-header bytes
4272#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
4276#    li $t2,255
4280#    bgeu $s6,$t2 firstHeaderLarge
4281##...sltu $at,$s6,$t2
4285##...beq $at,$zero,4332
4288#    lw $t1,prevHashConstant
4292#    addu $t1,0x12b68fd2
4293##...lui $at,4791
4297##...addiu $at,$at,-28718
4301##...addu $t1,$at,$t1
4304#    sw $t1,prevHashConstant # update hash constant
4308#    or $t1,0x80000000 # set top bit
4309##...lui $at,32768
4313##...or $t1,$at,$t1
4316#    and $t1,0xffffff00 # clear low bit
4317##...lui $at,65535
4321##...ori $at,$at,0xff00
4325##...and $t1,$t1,$at
4328#    or $s6,$t1
4332:firstHeaderLarge:
4332#    sw $s6,-8($t0) # store header-1 value
4336#    lw $zero,-8($t0)

    # store second header-value
4340#    sw $s7,-4($t0)   # second header-word
4344#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
4348#    move $s7,$t0
4352#    subu $sp,$sp,4
4356#    sw $t0,($sp)

4360#    jr $ra

3317##...slt $at,$t4,$zero
3321##...beq $at,$zero,3340
3324#    and $t4,0xff # mask off object's hash value ...
3325##...lui $at,0
3329##...ori $at,$at,0xff
3333##...and $t4,$t4,$at
3336#    sw $t4,-8($s7) # ... and store back into -8 header-word
3340:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
3340#    lw $t1,8($sp) # k
3344#    lw $t2,16($sp) # n
3348#    subu $t0,$t2,$t1 # value to store
3352#    sw $t0,-4($s7) # store value
    
3356#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
3360#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
3364#    lw $t4,-8($t3) # data words in source string
3368#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
3372#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
3376#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
3380#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
3384#    lw $t2,-8($s7)   # data words in target string
3388#    sll $t2,$t2,2    # data bytes in target string
3392#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target

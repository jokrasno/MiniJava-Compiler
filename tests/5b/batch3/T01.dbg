########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4984:vm_init:

    # mark bottom of stack
4984#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4988#    move $s2,$zero

    #set up the "five" register
4992#    li $s5,5

4996#    la $s3,seg0_start
5000#    la $s4,seg0_end
5001##...lui $s4,16
5005##...addiu $s4,$s4,5820
    
    # return
5008#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5012:divide:
    # get parameters; abort if divisor zero
5012#    lw $t0,($sp)
5016#    lw $t1,8($sp)
5020#    beq $t0,$zero,divByZeroError
    
    # perform division
5024#    div $t1,$t0
5028#    mflo $t0

    # store result, adjust stack and return
5032#    addu $sp,$sp,8 # adjust stack
5036#    sw $t0,($sp) # store result
5040#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5044:remainder:
    # get parameters; abort if divisor zero
5044#    lw $t0,($sp)
5048#    lw $t1,8($sp)
5052#    beq $t0,$zero,divByZeroError
    
    # perform division
5056#    div $t1,$t0
5060#    mfhi $t0

    # store result, adjust stack and return
5064#    addu $sp,$sp,8 # adjust stack
5068#    sw $t0,($sp) # store result
5072#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
5076:checkCast:
    # get object, allow immediately if null
5076#    lw $t2,($sp)
5080#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
5084#    lw $t2,-12($t2) # vtable address
5088#    bge $t2,$t1,castException
5089##...slt $at,$t2,$t1
5093##...beq $at,$zero,5228
5096#    blt $t2,$t0,castException
5097##...slt $at,$t2,$t0
5101##...bne $at,$zero,5228
    
    # return, leaving object unchanged on stack
5104:  checkCastReturn:    
5104#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
5108:instanceOf:
    # get object, go return false if null
5108#    lw $t2,($sp)
5112#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
5116#    lw $t2,-12($t2) # vtable address
5120#    sge $t0,$t2,$t0 # are we >= the lower limit?
5121##...slt $t0,$t2,$t0
5125##...xori $t0,$t0,0x1
5128#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
5132#    and $t2,$t0,$t1
5136#    sw $t2,($sp)
5140:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
5140#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

5144:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
5144#    li $v0,4 # syscall-code for print-string
5148#    syscall
5152:exit:
    # print termination message
5152#    li $v0,4 # syscall-code for print-string
5156#    la $a0,exitString
5160#    syscall

    # terminate execution
5164#    li $v0,10 #syscall-code for "exit"
5168#    syscall

5172:outOfHeapMemory:
5172#    la $a0,heapMemoryMsg
5176#    j exitError
5180:divByZeroError:
5180#    la $a0,divByZeroMsg
5184#    j exitError
5188:strIndexOutOfBounds:
5188#    la $a0,strIndexOutOfBoundsMsg
5192#    j exitError
5196:arrayIndexOutOfBounds:
5196#    la $a0,arrayIndexOutOfBoundsMsg
5200#    j exitError
5204:arraySizeOutOfBounds:
5204#    la $a0,arraySizeOutOfBoundsMsg
5208#    j exitError
5212:nullPtrException:
5212#    la $a0,nullPtrExceptionMsg
5216#    j exitError
5220:badIntegerFormat:
5220#    la $a0,badIntegerFormatMsg
5224#    j exitError
5228:castException:
5228#    la $a0,castExceptionMsg
5232#    j exitError
############## data section ################
    .data
5456:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5472:cur_seg:
    .word 0

5476:lastCharRead:
    .word -2 # -2 => no buffered character
5480:prevHashConstant:
    .word 0x2785173c
5484:gcCount:
    .word 0

5488:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5515:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5538:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5573:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5607:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5640:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5671:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5719:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5740:gcMsg: 
      .asciiz "\nGC!\n"
5746:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5778:nullStr:
    .asciiz "null"
5783:trueString:
    .asciiz "true"
5788:falseString:
    .asciiz "false"
5794:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5813:newlineString:
    .asciiz "\n"
    
    .align 2
5816:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5820:seg0_start:
    .space 0x100000
1054396:seg0_end:
1054396:seg1_start:
    .space 0x100000
2102972:seg1_end:


########################################################
# str1.concat(str2) - library method (class String)
# (as in Java)
# - parameters:
#   - ($sp) - the second string
#   - 4($sp) - old this pointer
#   - $s2 - the first string (this)
# - returns:
#   - $t0 - pointer to concatenated string
########################################################
3448:mth_concat_String:
    # save $ra by pushing onto stack
3448#    subu $sp,$sp,4
3452#    sw $ra, ($sp)

    # get string pointers and check parameter for null
3456#    lw $t0,4($sp)
3460#    beq $t0,$zero,nullPtrException
3464#    move $t1,$s2
    
    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
3468#    lw $t0,-4($t0) # negative size of second object
3472#    lw $t1,-4($t1) # negative size of first object
3476#    addu $s6,$t0,$t1 # sum of negative sizes
3480#    sra $s6,$s6,2 # negative word-size of char part
3484#    subu $s6,$zero,$s6 # word size of char part
3488#    addu $s6,$s6,1 # data word size, including v-table word
3492#    move $s7,$zero
3496#    jal newObject

    # store String vtable address in vtable address field
3500#    la $t0,CLASS_String
3504#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
3508#    lw $t4,-8($s7) # # data words in source string
3512#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
3513##...slt $at,$t4,$zero
3517##...beq $at,$zero,3536
3520#    and $t4,0xff # mask off object's hash value ...
3521##...lui $at,0
3525##...ori $at,$at,0xff
3529##...and $t4,$t4,$at
3532#    sw $t4,-8($s7) # ... and store back into -8 header-word
3536:skipMask_concat:

3536#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
3540#    move $t1,$s2   # first object
3544#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
3548#    lw $t2,-4($t0) # negative length of second object
3552#    lw $t3,-4($t1) # negative length of first object
3556#    addu $t4,$t2,$t3 # sum of negative lengths
3560#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################

    # compute addresses for moving data from first string
3564#    lw $t4,-8($t1) # # data words in first string
3568#    sll $t4,$t4,2 # # data bytes in first string
3572#    subu $t1,$t1,$t4 # addr. (+8) of first byte in first string
3576#    lw $t4,-8($s7) # # data words in new string
3580#    sll $t4,$t4,2 # # data bytes in new string
3584#    subu $s7,$s7,$t4 # addr. (+8) of first byte in new string
3588#    beq $zero,$t3,doneConcatLoop1zz # skip first loop is no bytes to copy
3592#    subu $t3,$t1,$t3 # limit (+8) address for first string

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is address (+8) of first byte in first object

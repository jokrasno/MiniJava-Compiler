2696#    and $t0,0xff # mask off object's hash value ...
2697##...lui $at,0
2701##...ori $at,$at,0xff
2705##...and $t0,$t0,$at
2708#    sw $t0,-8($s7) # ... and store back into -8 header-word
2712:skipMask_toString:
2712#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2716#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2720#    subu $t4,$t2,$t5
2724:toString_copyLoop:    
2724#    lb $t3,($t4)
2728#    and $t3,0x7f # mask off sign bit (in case first word)
2729##...lui $at,0
2733##...ori $at,$at,0x7f
2737##...and $t3,$t3,$at
2740#    sb $t3,-8($t0)

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
4444:readLogicalChar:

    # check if we already have a character
4444#    lw $v0,lastCharRead
4448#    li $t0,-2
4452#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
4456#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
4460#    jr $ra # return
    
4464:  doReadCh:
    # we need to actually read a character: read and return
4464#    li $v0,12 # use system call to read a character
4468#    syscall
4472#    jr $ra # return

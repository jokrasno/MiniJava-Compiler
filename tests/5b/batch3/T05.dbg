###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2908:mth_readLine_Lib:
    
2908#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2912#    sw $ra, 4($sp) # save $ra
2916#    move $t1,$sp # save "original" sp

2920:  doRead:

    # read the character
2920#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2924#    subu $t2,$v0,13
2928#    bne $t2,$zero,notReturnRL
2932#    jal readLogicalChar
2936#    subu $t2,$v0,10 # check for newline
2940#    beq $t2,$zero,foundNewLine
2944#    sw $v0,lastCharRead # push back character into queue
2948#    j foundNewLine # go process the line

2952:  notReturnRL:

    # at this point, $v0 has our character

2952#    subu $t0,$v0,10
2956#    beq $t0,$zero,foundNewLine
2960#    blt $v0,$zero,foundEof
2961##...slt $at,$v0,$zero
2965##...bne $at,$zero,2980

    # we have a character, so push it onto stack
2968#    subu $sp,$sp,4
2972#    sw $v0,($sp)

    # loop back up to get next character
2976#    j doRead

2980:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2980#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2984#    li $s7, 0 # return-value: null
2988#    j rlReturn # return

2992:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2992#    subu $t0,$t1,$sp # number of chars we read (times 4)
2996#    srl $s6,$t0,2 # number of words on stack with chars
3000#    subu $sp,$sp,4 # push char-count ...
3004#    sw $s6,($sp) # ... onto stack
3008#    addu $t2,$t0,5 # GC tag, incl. for count-word
3012#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
3016#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
3020#    srl $s6,$s6,2  # data words in object
3024#    move $s7,$zero # object words in object
3028#    jal newObject  # allocate space
    
    # store header words
3032#    la $t0,CLASS_String
3036#    sw $t0,-12($s7)# store class tag (String) into object
3040#    lw $t2,4($sp) # char-count
3044#    sll $t1,$t2,2 # 4 times number of chars
3048#    subu $t2,$zero,$t2 # negative of char-count
3052#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3056#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3060#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3061##...slt $at,$t0,$zero
3065##...beq $at,$zero,3084
3068#    and $t0,0xff # mask off object's hash value ...
3069##...lui $at,0
3073##...ori $at,$at,0xff
3077##...and $t0,$t0,$at
3080#    sw $t0,-8($s7) # ... and store back into -8 header-word
3084:  skipMask_readLine:

3084#    sll $t0,$t0,2 # data bytes in object
3088#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
3092#    subu $t0,$t0,$t2 # place to store last character (plus 9)
3096#    addu $sp,$sp,8 # pop redundant object-pointer and count
3100#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

3104#    beq $sp,$t1,rlReturn
3108:  charCopyLoop:
3108#    lw $t2,($sp)
3112#    sb $t2,-9($t0)
3116#    addu $sp,$sp,4
3120#    subu $t0,$t0,1
3124#    bne $sp,$t1,charCopyLoop
3128:  rlReturn:

3128#    lw $ra, 4($sp)
3132#    addu $sp, 8   # pop $ra and pointless word off stack
3136#    move $t0, $s7 # return string we allocated in $s7
3140#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3144:mth_readInt_Lib:

    # save $ra by pushing onto stack
3144#    subu $sp,$sp,4
3148#    sw $ra,($sp)

3152:  riSkipWhiteLoop:
    # read a character
3152#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
3156#    subu $t0,$v0,32
3160#    bgt $t0,$zero,nonWhite
3161##...slt $at,$zero,$t0
3165##...bne $at,$zero,3208
3168#    beq $t0,$zero,riSkipWhiteLoop # start over if space
3172#    subu $t0,$v0,10
3176#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
3180#    subu $t0,$v0,9
3184#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
3188#    subu $t0,$v0,13
3192#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
3196#    subu $t0,$v0,12
3200#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
3204#    j badIntegerFormat # illegal integer char: abort program

3208:  nonWhite:
3208#    subu $t0,$v0,'-'
3212#    li $t4,1 # final multiplier
3216#    bne $t0,$zero,helpReadInt # go read
3220#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
3224#    jal readLogicalChar

3228:  helpReadInt:
3228#    li $t2,10
3232#    subu $t1,$v0,'0' # convert digit to 0-9 value
3236#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
3237##...sltu $at,$t1,$t2
3241##...beq $at,$zero,5488
3244#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

3248:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

3248#    jal readLogicalChar # read next character
3252#    subu $t1,$v0,'0' # convert digit to 0-9 value
3256#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
3257##...sltu $at,$t1,$t2
3261##...beq $at,$zero,3280

3264#    mul $t3,$t3,$t2 # multiply old value by 10
3265##...mult $t3,$t2
3269##...mflo $t3
3272#    addu $t3,$t3,$t1 # add in value of new digit
3276#    j digitLoop

3280:  doneDigitLoop:

    # "push back" unused character into queue
3280#    sw $v0,lastCharRead

    # restore return address
3284#    lw $ra,($sp)
3288#    addu $sp, 4

    # multiply by sign and put return value in $t0
3292#    mult $t3,$t4 # multiply to account for poss. minus sign
3296#    mflo $t3
3300#    move $t0, $t3
    
    # return
3304#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3308:mth_readChar_Lib:

    # save $ra by pushing onto stack
3308#    subu $sp,$sp,4
3312#    sw $ra,($sp)

      # read the character
3316#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
3320#    lw $ra,($sp)
3324#    addu $sp, 4
3328#    move $t0, $v0

    # return
3332#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output

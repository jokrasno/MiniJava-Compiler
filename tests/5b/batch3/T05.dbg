    # allocate memory
3552#    subu $s6,$t1,$t2 # # chars in target-string
3556#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
3560#    srl $s6,$s6,2 # convert bytes-count to word-count
3564#    move $s7,$zero # (no object-bytes in string)
3568#    jal newObject

    # store "String" tag in object-type field
3572#    la $t0,CLASS_String

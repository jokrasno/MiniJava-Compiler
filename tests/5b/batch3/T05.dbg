4676#    la $s4,seg0_end
4677##...lui $s4,16
4681##...addiu $s4,$s4,6256
4684#    sw $zero,cur_seg
4688#    bne $t0,$zero,skipGc1
4692#    la $t6,seg0_start
4696#    la $s3,seg1_start
4697##...lui $s3,16
4701##...addiu $s3,$s3,6256
4704#    la $s4,seg1_end
4705##...lui $s4,32
4709##...addiu $s4,$s4,6256
4712#    sw $s5,cur_seg
4716:  skipGc1:
4716#    li $t5,0x80000000

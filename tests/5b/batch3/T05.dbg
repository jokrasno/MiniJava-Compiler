##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2400:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
2400#    lw $t0,-8($s2) # get word with hash bits from this
2404#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
2408#    addu $t0,$t1

2412#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2416:mth_equals_Object:
2416#    move $t0,$s2 # first pointer (this)
2420#    lw $t1,($sp) # second pointer
2424#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
2425##...subu $at,$t0,$t1
2429##...sltiu $t0,$at,1

2432#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2436:mth_hashCode_String:
2436#    move $t0,$s2 # put this pointer in t0

2440#    li $t2,0 # current hash value
2444#    lw $t1,-4($t0) # negative of number of characters in string
2448#    beq $t1,$zero,done_hashCode_String # if zero length => done
2452#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
2456#    and $t0,0xfffffffc # adjust for padding
2457##...lui $at,65535
2461##...ori $at,$at,0xfffc
2465##...and $t0,$t0,$at
2468#    subu $t1,$t0,$t1 # address at end of string +12
2472:loop_hashCode_String:    
2472#    sll $t4,$t2,5 # multiply by 32
2476#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
2480#    lbu $t3,-12($t0) # current character
2484#    addu $t2,$t3 # add in current character
2488#    addu $t0,1 # go to next character's address
2492#    bne $t0,$t1,loop_hashCode_String # loop back if more
2496:done_hashCode_String:    

    # push int on stack
2496#    move $t0, $t2 # put $t2 in return slot
2500#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
2504:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
2504#    subu $sp,4
2508#    sw $ra,($sp)
    
    # get hash value
2512#    lw $t2,-12($s2) # vtable address
2516#    lw $t0,($t2) # method address
2520#    jalr $t0
2524#    subu $sp,8 # push result (int in $t0) on stack
2528#    sw $s5,4($sp)
2532#    sw $t0,($sp)

    # compute print-size of hash value
2536#    li $t0, 1
2540#    lw $t1, ($sp)
2544#    srl $t1,$t1,4
2548#    beq $t1,$zero,toString_skip_loop
2552:toString_loop_top:
2552#    addu $t0,1
2556#    srl $t1,$t1,4
2560#    bne $t1,$zero,toString_loop_top
2564:toString_skip_loop:
2564#    subu $sp,8
2568#    sw $s5,4($sp)
2572#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
2576#    lw $t2,-12($s2) # vtable address
2580#    move $t0,$t2
2584:toString_checkTagBit:
2584#    subu $t0,1
2588#    lb $t1,($t0)
2592#    and $t1,0x80
2593##...lui $at,0
2597##...ori $at,$at,0x80
2601##...and $t1,$t1,$at
2604#    beq $t1,$zero,toString_checkTagBit
2608#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
2612#    subu $sp,8
2616#    sw $t1,($sp)
2620#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
2624#    move $s7,$zero # -4 offset header word
2628#    lw $t4,8($sp) # bytes for hash value
2632#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
2636#    addu $t4,8
2640#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
2644#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

2648#    li $t0,CLASS_String # store string vtable address into ...
2652#    sw $t0,-12($s7) # ... -12 offset in object header
2656#    lw $t2,-12($s2) # our object's vtable address
2660#    lw $t5,4($sp) # number characters in prefix
2664#    lw $t1,12($sp) # number of characters in hashcode
2668#    addu $t3,$t1,$t5 # number of characters in string ...
2672#    addu $t3,1 # ... including the '@' character
2676#    subu $t0,$zero,$t3 # store negated length into ...
2680#    sw $t0,-4($s7) # ... -4 offset header word
2684#    lw $t0,-8($s7) # get -8 offset header-word
2688#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2689##...slt $at,$t0,$zero

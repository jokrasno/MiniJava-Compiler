###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2824:mth_equals_String:
    
    # quick test for obvious false
2824#    lw $t0,($sp) # second parameter
2828#    beq $t0,$zero,goEsFalse # go return false if null
2832#    lw $t1,-12($t0) # vtable pointer
2836#    la $t2,CLASS_String # string vtable pointer
2840#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2844#    subu $sp,12
2848#    sw $ra,8($sp)
2852#    sw $s2,4($sp)
2856#    sw $t0,($sp)
2860#    jal mth_compareTo_String
2864#    lw $s2, 4($sp) #restore this pointer and pop parameters
2868#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2872#    seq $t0,$t0,$zero
2873##...subu $at,$t0,$zero
2877##...sltiu $t0,$at,1

    # pop return address and return $t0
2880#    lw $ra,($sp)
2884#    addu $sp,4

2888#    jr $ra # return
    
2892:goEsFalse:
    # put 0 in $t0 and return
2892#    li $t0, 0
2896#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object

5124#    sll $t8,$t8,2 # bytes in negative-offset portion ...
5128#    addu $t8,$t8,8 # ... add in bytes for header-words
5132#    subu $t4,$t1,$t8 # address of first word of source object
5136#    lw $t3,-4($t1) # # words in positive-offset portion
5140#    bge $t3,$zero,gcNoNeg
5141##...slt $at,$t3,$zero
5145##...beq $at,$zero,5152
5148#    move $t3,$zero # negative treated as zero
5152:  gcNoNeg:
5152#    sll $t3,$t3,2 # bytes in negative-offset portion
5156#    addu $t3,$t3,$t1 # address one word past last word of source

5160#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
5164#    lw $s0,($t4)
5168#    lw $t9,-8($t1)
5172#    sw $t9,($t4)
5176#    sw $s0,-8($t1)

    # copy all source bytes to the target
5180:  gCinnerCopy2:
5180#    lw $s0,($t4)
5184#    sw $s0,($s3)
5188#    addu $t4,$t4,4
5192#    addu $s3,$s3,4
5196#    bltu $t4,$t3,gCinnerCopy2
5197##...sltu $at,$t4,$t3
5201##...bne $at,$zero,5180

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
5204#    sw $zero,-8($t1) # 0 in first header-slot
5208#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
5212#    sw $t8,($t0)

5216:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
5216#    addu $t0,$t0,4
5220#    bltu $t0,$s1,gcNextPointerInObject
5221##...sltu $at,$t0,$s1
5225##...bne $at,$zero,5064

5228:  gcTestIterDone2:
5228#    bltu $t0,$s3,gcHeapCopyLoop
5229##...sltu $at,$t0,$s3
5233##...bne $at,$zero,4948

    ###### end outer loop to copy all non-stack-direct objects ######

5236:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
5236#    lw $s2,($sp)
5240#    addu $sp,$sp,4

    # mark us as having already GC'd
5244#    move $t5,$s5

    # go try and allocate again
5248#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
5252:vm_init:

    # mark bottom of stack
5252#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
5256#    move $s2,$zero

    #set up the "five" register
5260#    li $s5,5

5264#    la $s3,seg0_start
5268#    la $s4,seg0_end
5269##...lui $s4,16
5273##...addiu $s4,$s4,6256
    
    # return
5276#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5280:divide:
    # get parameters; abort if divisor zero
5280#    lw $t0,($sp)
5284#    lw $t1,8($sp)
5288#    beq $t0,$zero,divByZeroError
    
    # perform division
5292#    div $t1,$t0
5296#    mflo $t0

    # store result, adjust stack and return
5300#    addu $sp,$sp,8 # adjust stack
5304#    sw $t0,($sp) # store result
5308#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5312:remainder:
    # get parameters; abort if divisor zero
5312#    lw $t0,($sp)
5316#    lw $t1,8($sp)
5320#    beq $t0,$zero,divByZeroError
    
    # perform division
5324#    div $t1,$t0
5328#    mfhi $t0

    # store result, adjust stack and return
5332#    addu $sp,$sp,8 # adjust stack
5336#    sw $t0,($sp) # store result
5340#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
5344:checkCast:
    # get object, allow immediately if null
5344#    lw $t2,($sp)
5348#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
5352#    lw $t2,-12($t2) # vtable address
5356#    bge $t2,$t1,castException
5357##...slt $at,$t2,$t1
5361##...beq $at,$zero,5496
5364#    blt $t2,$t0,castException
5365##...slt $at,$t2,$t0
5369##...bne $at,$zero,5496
    
    # return, leaving object unchanged on stack
5372:  checkCastReturn:    
5372#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
5376:instanceOf:
    # get object, go return false if null
5376#    lw $t2,($sp)
5380#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
5384#    lw $t2,-12($t2) # vtable address
5388#    sge $t0,$t2,$t0 # are we >= the lower limit?
5389##...slt $t0,$t2,$t0
5393##...xori $t0,$t0,0x1
5396#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
5400#    and $t2,$t0,$t1
5404#    sw $t2,($sp)
5408:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
5408#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

5412:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
5412#    li $v0,4 # syscall-code for print-string
5416#    syscall
5420:exit:
    # print termination message
5420#    li $v0,4 # syscall-code for print-string
5424#    la $a0,exitString
5428#    syscall

    # terminate execution
5432#    li $v0,10 #syscall-code for "exit"
5436#    syscall

5440:outOfHeapMemory:
5440#    la $a0,heapMemoryMsg
5444#    j exitError
5448:divByZeroError:
5448#    la $a0,divByZeroMsg
5452#    j exitError
5456:strIndexOutOfBounds:
5456#    la $a0,strIndexOutOfBoundsMsg
5460#    j exitError
5464:arrayIndexOutOfBounds:
5464#    la $a0,arrayIndexOutOfBoundsMsg
5468#    j exitError
5472:arraySizeOutOfBounds:
5472#    la $a0,arraySizeOutOfBoundsMsg
5476#    j exitError
5480:nullPtrException:
5480#    la $a0,nullPtrExceptionMsg
5484#    j exitError
5488:badIntegerFormat:
5488#    la $a0,badIntegerFormatMsg
5492#    j exitError
5496:castException:
5496#    la $a0,castExceptionMsg
5500#    j exitError
############## data section ################
    .data
5892:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5908:cur_seg:
    .word 0

5912:lastCharRead:
    .word -2 # -2 => no buffered character
5916:prevHashConstant:
    .word 0x2785173c
5920:gcCount:
    .word 0

5924:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5951:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5974:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
6009:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
6043:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
6076:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
6107:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
6155:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
6176:gcMsg: 
      .asciiz "\nGC!\n"
6182:gcCountMsg: 
      .asciiz "Number of garbage collections: "

6214:nullStr:
    .asciiz "null"
6219:trueString:
    .asciiz "true"
6224:falseString:
    .asciiz "false"
6230:exitString:
    .ascii "Program terminated."
    #### "falls through" here
6249:newlineString:
    .asciiz "\n"
    
    .align 2
6252:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

6256:seg0_start:
    .space 0x100000
1054832:seg0_end:
1054832:seg1_start:
    .space 0x100000
2103408:seg1_end:

4516#    sw $zero,($s3)
4520#    lw $zero,($s3)

4524#    addu $s3,4
4528#    bltu $s3,$t1,zeroObjLoop
4529##...sltu $at,$s3,$t1
4533##...bne $at,$zero,4516

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
4536#    sll $t0,$s7,2    # number of post-header bytes
4540#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
4544#    li $t2,255
4548#    bgeu $s6,$t2 firstHeaderLarge
4549##...sltu $at,$s6,$t2
4553##...beq $at,$zero,4600
4556#    lw $t1,prevHashConstant
4560#    addu $t1,0x12b68fd2
4561##...lui $at,4791
4565##...addiu $at,$at,-28718
4569##...addu $t1,$at,$t1
4572#    sw $t1,prevHashConstant # update hash constant
4576#    or $t1,0x80000000 # set top bit
4577##...lui $at,32768
4581##...or $t1,$at,$t1
4584#    and $t1,0xffffff00 # clear low bit
4585##...lui $at,65535
4589##...ori $at,$at,0xff00
4593##...and $t1,$t1,$at
4596#    or $s6,$t1
4600:firstHeaderLarge:
4600#    sw $s6,-8($t0) # store header-1 value
4604#    lw $zero,-8($t0)

    # store second header-value
4608#    sw $s7,-4($t0)   # second header-word
4612#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
4616#    move $s7,$t0
4620#    subu $sp,$sp,4
4624#    sw $t0,($sp)

4628#    jr $ra

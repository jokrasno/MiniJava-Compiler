3412#    lw $t0,4($t0) # negative of string-length
3416#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
3420#    beq $t0,$t1,donePrintStr
3424:  psLoop:
3424#    lb $a0,($t1) # next byte
3428#    li $v0,11 # code for printing char
3432#        syscall # print the char

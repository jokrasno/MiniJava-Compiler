3640:gcSkip4a:    
3640#    sll $t2,$t2,2 # # data bytes
3644#    addu $t2,$t2,8 # to skip header words
3648#    addu $t2,$t0,$t2 # pointer to new object
3652#    lw $t3,-8($t2) # word to swap
3656#    sw $t1,-8($t2) # store header word
3660#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3664#    lw $t1,-12($t2) # vtable pointer
3668#    li $t0,dataArrayVTableStart # address of vtable for first data array
3672#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3673##...slt $at,$t1,$t0
3677##...bne $at,$zero,3696

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3680:  skipToNextObj:
3680#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3684#    sll $t1,$t1,2 # convert to byte-count
3688#    addu $t0,$t2,$t1 # skip over object
3692#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3696:  gcNotDataArray:
3696#    lw $t3,-4($t2) # # object words (negative treated as zero)
3700#    bge $t3,$zero,gcH2Neg2
3701##...slt $at,$t3,$zero
3705##...beq $at,$zero,3712
3708#    move $t3,$zero
3712:  gcH2Neg2:
3712#    sll $t3,$t3,2 # # object bytes
3716#    move $t0,$t2 # address of first pointer in object
3720#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3724#    beq $t0,$s1,gcTestIterDone2
    
3728:  gcNextPointerInObject:
    # get pointer from object
3728#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3732#    bleu $t1,$t6,gcGoNextPointerSlot
3733##...sltu $at,$t6,$t1
3737##...beq $at,$zero,3880
3740#    bgtu $t1,$t7,gcGoNextPointerSlot
3741##...sltu $at,$t7,$t1
3745##...bne $at,$zero,3880

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3748#    lw $t8,-8($t1) # possible forwarding tag
3752#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3756#    lw $t8,-4($t1) # forwarding pointer: object's new address
3760#    sw $t8,($t0) # update pointer in object
3764#    j gcGoNextPointerSlot # do next iteration

3768:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3768#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3769##...slt $at,$t8,$zero
3773##...beq $at,$zero,3788
3776#    and $t8,0xff # mask off hash bits
3777##...lui $at,0
3781##...ori $at,$at,0xff
3785##...and $t8,$t8,$at

3788:  gcSkip5:
3788#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3792#    addu $t8,$t8,8 # ... add in bytes for header-words
3796#    subu $t4,$t1,$t8 # address of first word of source object
3800#    lw $t3,-4($t1) # # words in positive-offset portion
3804#    bge $t3,$zero,gcNoNeg
3805##...slt $at,$t3,$zero
3809##...beq $at,$zero,3816
3812#    move $t3,$zero # negative treated as zero
3816:  gcNoNeg:
3816#    sll $t3,$t3,2 # bytes in negative-offset portion
3820#    addu $t3,$t3,$t1 # address one word past last word of source

3824#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3828#    lw $s0,($t4)
3832#    lw $t9,-8($t1)
3836#    sw $t9,($t4)
3840#    sw $s0,-8($t1)

    # copy all source bytes to the target
3844:  gCinnerCopy2:
3844#    lw $s0,($t4)
3848#    sw $s0,($s3)
3852#    addu $t4,$t4,4
3856#    addu $s3,$s3,4
3860#    bltu $t4,$t3,gCinnerCopy2
3861##...sltu $at,$t4,$t3
3865##...bne $at,$zero,3844

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3868#    sw $zero,-8($t1) # 0 in first header-slot
3872#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3876#    sw $t8,($t0)

3880:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3880#    addu $t0,$t0,4
3884#    bltu $t0,$s1,gcNextPointerInObject
3885##...sltu $at,$t0,$s1
3889##...bne $at,$zero,3728

3892:  gcTestIterDone2:
3892#    bltu $t0,$s3,gcHeapCopyLoop
3893##...sltu $at,$t0,$s3
3897##...bne $at,$zero,3612

    ###### end outer loop to copy all non-stack-direct objects ######

3900:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3900#    lw $s2,($sp)
3904#    addu $sp,$sp,4

    # mark us as having already GC'd
3908#    move $t5,$s5

    # go try and allocate again
3912#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3916:vm_init:

    # mark bottom of stack
3916#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3920#    move $s2,$zero

    #set up the "five" register
3924#    li $s5,5

3928#    la $s3,seg0_start
3932#    la $s4,seg0_end
3933##...lui $s4,16
3937##...addiu $s4,$s4,4840
    
    # return
3940#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3944:divide:
    # get parameters; abort if divisor zero
3944#    lw $t0,($sp)
3948#    lw $t1,8($sp)
3952#    beq $t0,$zero,divByZeroError
    
    # perform division
3956#    div $t1,$t0
3960#    mflo $t0

    # store result, adjust stack and return
3964#    addu $sp,$sp,8 # adjust stack
3968#    sw $t0,($sp) # store result
3972#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3976:remainder:
    # get parameters; abort if divisor zero
3976#    lw $t0,($sp)
3980#    lw $t1,8($sp)
3984#    beq $t0,$zero,divByZeroError
    
    # perform division
3988#    div $t1,$t0
3992#    mfhi $t0

    # store result, adjust stack and return
3996#    addu $sp,$sp,8 # adjust stack
4000#    sw $t0,($sp) # store result
4004#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4008:checkCast:
    # get object, allow immediately if null
4008#    lw $t2,($sp)
4012#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4016#    lw $t2,-12($t2) # vtable address
4020#    bge $t2,$t1,castException
4021##...slt $at,$t2,$t1
4025##...beq $at,$zero,4160
4028#    blt $t2,$t0,castException
4029##...slt $at,$t2,$t0
4033##...bne $at,$zero,4160
    
    # return, leaving object unchanged on stack
4036:  checkCastReturn:    
4036#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4040:instanceOf:
    # get object, go return false if null
4040#    lw $t2,($sp)
4044#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4048#    lw $t2,-12($t2) # vtable address
4052#    sge $t0,$t2,$t0 # are we >= the lower limit?
4053##...slt $t0,$t2,$t0
4057##...xori $t0,$t0,0x1
4060#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4064#    and $t2,$t0,$t1
4068#    sw $t2,($sp)
4072:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4072#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4076:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4076#    li $v0,4 # syscall-code for print-string
4080#    syscall
4084:exit:
    # print termination message
4084#    li $v0,4 # syscall-code for print-string
4088#    la $a0,exitString
4092#    syscall

    # terminate execution
4096#    li $v0,10 #syscall-code for "exit"
4100#    syscall

4104:outOfHeapMemory:
4104#    la $a0,heapMemoryMsg
4108#    j exitError
4112:divByZeroError:
4112#    la $a0,divByZeroMsg
4116#    j exitError
4120:strIndexOutOfBounds:
4120#    la $a0,strIndexOutOfBoundsMsg
4124#    j exitError
4128:arrayIndexOutOfBounds:
4128#    la $a0,arrayIndexOutOfBoundsMsg
4132#    j exitError
4136:arraySizeOutOfBounds:
4136#    la $a0,arraySizeOutOfBoundsMsg
4140#    j exitError
4144:nullPtrException:
4144#    la $a0,nullPtrExceptionMsg
4148#    j exitError
4152:badIntegerFormat:
4152#    la $a0,badIntegerFormatMsg
4156#    j exitError
4160:castException:
4160#    la $a0,castExceptionMsg
4164#    j exitError
############## data section ################
    .data
4476:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4492:cur_seg:
    .word 0

4496:lastCharRead:
    .word -2 # -2 => no buffered character
4500:prevHashConstant:
    .word 0x2785173c
4504:gcCount:
    .word 0

4508:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4535:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4558:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4593:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4627:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4660:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4691:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4739:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4760:gcMsg: 
      .asciiz "\nGC!\n"
4766:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4798:nullStr:
    .asciiz "null"
4803:trueString:
    .asciiz "true"
4808:falseString:
    .asciiz "false"
4814:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4833:newlineString:
    .asciiz "\n"
    
    .align 2
4836:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4840:seg0_start:
    .space 0x100000
1053416:seg0_end:
1053416:seg1_start:
    .space 0x100000
2101992:seg1_end:

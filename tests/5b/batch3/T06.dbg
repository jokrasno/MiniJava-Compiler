3424#    lw $t2,-8($t1) # possible forwarding tag
3428#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
3432#    lw $t2,-4($t1) # forwarding pointer: object's new address
3436#    sw $t2,4($t0) # update stack value
3440#    j gcTestIterDone1 # do next iteration

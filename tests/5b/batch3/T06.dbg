3408#    bleu $t1,$t6,gcTestIterDone1
3409##...sltu $at,$t6,$t1
3413##...beq $at,$zero,3576
3416#    bgtu $t1,$t7,gcTestIterDone1
3417##...sltu $at,$t7,$t1
3421##...bne $at,$zero,3576

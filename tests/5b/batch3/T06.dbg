##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1064:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1064#    lw $t0,-8($s2) # get word with hash bits from this
1068#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1072#    addu $t0,$t1

1076#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1080:mth_equals_Object:
1080#    move $t0,$s2 # first pointer (this)
1084#    lw $t1,($sp) # second pointer
1088#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1089##...subu $at,$t0,$t1
1093##...sltiu $t0,$at,1

1096#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1100:mth_hashCode_String:
1100#    move $t0,$s2 # put this pointer in t0

1104#    li $t2,0 # current hash value
1108#    lw $t1,-4($t0) # negative of number of characters in string
1112#    beq $t1,$zero,done_hashCode_String # if zero length => done
1116#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1120#    and $t0,0xfffffffc # adjust for padding
1121##...lui $at,65535
1125##...ori $at,$at,0xfffc
1129##...and $t0,$t0,$at
1132#    subu $t1,$t0,$t1 # address at end of string +12
1136:loop_hashCode_String:    
1136#    sll $t4,$t2,5 # multiply by 32
1140#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1144#    lbu $t3,-12($t0) # current character
1148#    addu $t2,$t3 # add in current character
1152#    addu $t0,1 # go to next character's address
1156#    bne $t0,$t1,loop_hashCode_String # loop back if more
1160:done_hashCode_String:    

    # push int on stack
1160#    move $t0, $t2 # put $t2 in return slot
1164#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1168:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1168#    subu $sp,4
1172#    sw $ra,($sp)
    
    # get hash value
1176#    lw $t2,-12($s2) # vtable address
1180#    lw $t0,($t2) # method address
1184#    jalr $t0
1188#    subu $sp,8 # push result (int in $t0) on stack
1192#    sw $s5,4($sp)
1196#    sw $t0,($sp)

    # compute print-size of hash value
1200#    li $t0, 1
1204#    lw $t1, ($sp)
1208#    srl $t1,$t1,4
1212#    beq $t1,$zero,toString_skip_loop
1216:toString_loop_top:
1216#    addu $t0,1
1220#    srl $t1,$t1,4
1224#    bne $t1,$zero,toString_loop_top
1228:toString_skip_loop:
1228#    subu $sp,8
1232#    sw $s5,4($sp)
1236#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1240#    lw $t2,-12($s2) # vtable address
1244#    move $t0,$t2
1248:toString_checkTagBit:
1248#    subu $t0,1
1252#    lb $t1,($t0)
1256#    and $t1,0x80
1257##...lui $at,0
1261##...ori $at,$at,0x80
1265##...and $t1,$t1,$at
1268#    beq $t1,$zero,toString_checkTagBit
1272#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1276#    subu $sp,8
1280#    sw $t1,($sp)
1284#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1288#    move $s7,$zero # -4 offset header word
1292#    lw $t4,8($sp) # bytes for hash value
1296#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1300#    addu $t4,8
1304#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1308#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1312#    li $t0,CLASS_String # store string vtable address into ...
1316#    sw $t0,-12($s7) # ... -12 offset in object header
1320#    lw $t2,-12($s2) # our object's vtable address
1324#    lw $t5,4($sp) # number characters in prefix
1328#    lw $t1,12($sp) # number of characters in hashcode
1332#    addu $t3,$t1,$t5 # number of characters in string ...
1336#    addu $t3,1 # ... including the '@' character
1340#    subu $t0,$zero,$t3 # store negated length into ...
1344#    sw $t0,-4($s7) # ... -4 offset header word
1348#    lw $t0,-8($s7) # get -8 offset header-word
1352#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1353##...slt $at,$t0,$zero
1357##...beq $at,$zero,1376
1360#    and $t0,0xff # mask off object's hash value ...
1361##...lui $at,0
1365##...ori $at,$at,0xff
1369##...and $t0,$t0,$at
1372#    sw $t0,-8($s7) # ... and store back into -8 header-word
1376:skipMask_toString:
1376#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1380#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1384#    subu $t4,$t2,$t5
1388:toString_copyLoop:    
1388#    lb $t3,($t4)
1392#    and $t3,0x7f # mask off sign bit (in case first word)
1393##...lui $at,0
1397##...ori $at,$at,0x7f
1401##...and $t3,$t3,$at
1404#    sb $t3,-8($t0)
1408#    addu $t4,1
1412#    addu $t0,1
1416#    blt $t4,$t2,toString_copyLoop
1417##...slt $at,$t4,$t2
1421##...bne $at,$zero,1388

    # copy the '@' sign
1424#    li $t3,'@'
1428#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1432#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1436#    lw $t3,20($sp) # hash code to print
1440:toString_hashCopyLoop:
1440#    and $t4,$t3,0xf
1444#    srl $t3,4
1448#    lb $t4,hexChars($t4)
1452#    sb $t4,-8($t2)
1456#    subu $t2,$t2,1
1460#    bgt $t2,$t0,toString_hashCopyLoop
1461##...slt $at,$t0,$t2
1465##...bne $at,$zero,1440

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1468#    addu $sp,28
1472#    lw $ra,($sp)
1476#    addu $sp,4
1480#    move $t0, $s7 # return string we created
1484#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1488:mth_equals_String:
    
    # quick test for obvious false
1488#    lw $t0,($sp) # second parameter
1492#    beq $t0,$zero,goEsFalse # go return false if null
1496#    lw $t1,-12($t0) # vtable pointer
1500#    la $t2,CLASS_String # string vtable pointer
1504#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1508#    subu $sp,12
1512#    sw $ra,8($sp)
1516#    sw $s2,4($sp)
1520#    sw $t0,($sp)
1524#    jal mth_compareTo_String
1528#    lw $s2, 4($sp) #restore this pointer and pop parameters
1532#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1536#    seq $t0,$t0,$zero
1537##...subu $at,$t0,$zero
1541##...sltiu $t0,$at,1

    # pop return address and return $t0
1544#    lw $ra,($sp)
1548#    addu $sp,4

1552#    jr $ra # return
    
1556:goEsFalse:
    # put 0 in $t0 and return
1556#    li $t0, 0
1560#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1564:mth_toString_String:
    #we are a string, so return this.
1564#    move $t0, $s2
1568#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1572:mth_readLine_Lib:
    
1572#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1576#    sw $ra, 4($sp) # save $ra
1580#    move $t1,$sp # save "original" sp

1584:  doRead:

    # read the character
1584#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1588#    subu $t2,$v0,13
1592#    bne $t2,$zero,notReturnRL
1596#    jal readLogicalChar
1600#    subu $t2,$v0,10 # check for newline
1604#    beq $t2,$zero,foundNewLine
1608#    sw $v0,lastCharRead # push back character into queue
1612#    j foundNewLine # go process the line

1616:  notReturnRL:

    # at this point, $v0 has our character

1616#    subu $t0,$v0,10
1620#    beq $t0,$zero,foundNewLine
1624#    blt $v0,$zero,foundEof
1625##...slt $at,$v0,$zero
1629##...bne $at,$zero,1644

    # we have a character, so push it onto stack
1632#    subu $sp,$sp,4
1636#    sw $v0,($sp)

    # loop back up to get next character
1640#    j doRead

1644:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1644#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1648#    li $s7, 0 # return-value: null
1652#    j rlReturn # return

1656:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1656#    subu $t0,$t1,$sp # number of chars we read (times 4)
1660#    srl $s6,$t0,2 # number of words on stack with chars
1664#    subu $sp,$sp,4 # push char-count ...
1668#    sw $s6,($sp) # ... onto stack
1672#    addu $t2,$t0,5 # GC tag, incl. for count-word
1676#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1680#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1684#    srl $s6,$s6,2  # data words in object
1688#    move $s7,$zero # object words in object
1692#    jal newObject  # allocate space
    
    # store header words
1696#    la $t0,CLASS_String
1700#    sw $t0,-12($s7)# store class tag (String) into object
1704#    lw $t2,4($sp) # char-count
1708#    sll $t1,$t2,2 # 4 times number of chars
1712#    subu $t2,$zero,$t2 # negative of char-count
1716#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1720#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1724#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1725##...slt $at,$t0,$zero
1729##...beq $at,$zero,1748
1732#    and $t0,0xff # mask off object's hash value ...
1733##...lui $at,0
1737##...ori $at,$at,0xff
1741##...and $t0,$t0,$at
1744#    sw $t0,-8($s7) # ... and store back into -8 header-word
1748:  skipMask_readLine:

1748#    sll $t0,$t0,2 # data bytes in object
1752#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1756#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1760#    addu $sp,$sp,8 # pop redundant object-pointer and count
1764#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1768#    beq $sp,$t1,rlReturn
1772:  charCopyLoop:
1772#    lw $t2,($sp)
1776#    sb $t2,-9($t0)
1780#    addu $sp,$sp,4
1784#    subu $t0,$t0,1
1788#    bne $sp,$t1,charCopyLoop
1792:  rlReturn:

1792#    lw $ra, 4($sp)
1796#    addu $sp, 8   # pop $ra and pointless word off stack
1800#    move $t0, $s7 # return string we allocated in $s7
1804#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1808:mth_readInt_Lib:

    # save $ra by pushing onto stack
1808#    subu $sp,$sp,4
1812#    sw $ra,($sp)

1816:  riSkipWhiteLoop:
    # read a character
1816#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1820#    subu $t0,$v0,32
1824#    bgt $t0,$zero,nonWhite
1825##...slt $at,$zero,$t0
1829##...bne $at,$zero,1872
1832#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1836#    subu $t0,$v0,10
1840#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1844#    subu $t0,$v0,9
1848#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1852#    subu $t0,$v0,13
1856#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1860#    subu $t0,$v0,12
1864#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1868#    j badIntegerFormat # illegal integer char: abort program

1872:  nonWhite:
1872#    subu $t0,$v0,'-'
1876#    li $t4,1 # final multiplier
1880#    bne $t0,$zero,helpReadInt # go read
1884#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1888#    jal readLogicalChar

1892:  helpReadInt:
1892#    li $t2,10
1896#    subu $t1,$v0,'0' # convert digit to 0-9 value
1900#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1901##...sltu $at,$t1,$t2
1905##...beq $at,$zero,4152
1908#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1912:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1912#    jal readLogicalChar # read next character
1916#    subu $t1,$v0,'0' # convert digit to 0-9 value
1920#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1921##...sltu $at,$t1,$t2
1925##...beq $at,$zero,1944

1928#    mul $t3,$t3,$t2 # multiply old value by 10
1929##...mult $t3,$t2
1933##...mflo $t3
1936#    addu $t3,$t3,$t1 # add in value of new digit
1940#    j digitLoop

1944:  doneDigitLoop:

    # "push back" unused character into queue
1944#    sw $v0,lastCharRead

    # restore return address
1948#    lw $ra,($sp)
1952#    addu $sp, 4

    # multiply by sign and put return value in $t0
1956#    mult $t3,$t4 # multiply to account for poss. minus sign
1960#    mflo $t3
1964#    move $t0, $t3
    
    # return
1968#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1972:mth_readChar_Lib:

    # save $ra by pushing onto stack
1972#    subu $sp,$sp,4
1976#    sw $ra,($sp)

      # read the character
1980#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1984#    lw $ra,($sp)
1988#    addu $sp, 4
1992#    move $t0, $v0

    # return
1996#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
2000:mth_printStr_Lib:
    # check for null, printing "(null)", if so
2000#    lw $t0,($sp)
2004#    bne $t0,$zero,psNotNull

    # print "(null)"
2008#    la $a0,nullStr

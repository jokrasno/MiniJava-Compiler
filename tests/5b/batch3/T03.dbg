9996:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
9996#    subu $t0,$t1,$sp # number of chars we read (times 4)
10000#    srl $s6,$t0,2 # number of words on stack with chars
10004#    subu $sp,$sp,4 # push char-count ...
10008#    sw $s6,($sp) # ... onto stack
10012#    addu $t2,$t0,5 # GC tag, incl. for count-word
10016#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
10020#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
10024#    srl $s6,$s6,2  # data words in object
10028#    move $s7,$zero # object words in object
10032#    jal newObject  # allocate space
    
    # store header words
10036#    la $t0,CLASS_String
10040#    sw $t0,-12($s7)# store class tag (String) into object
10044#    lw $t2,4($sp) # char-count
10048#    sll $t1,$t2,2 # 4 times number of chars
10052#    subu $t2,$zero,$t2 # negative of char-count
10056#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
10060#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
10064#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
10065##...slt $at,$t0,$zero
10069##...beq $at,$zero,10088
10072#    and $t0,0xff # mask off object's hash value ...
10073##...lui $at,0
10077##...ori $at,$at,0xff
10081##...and $t0,$t0,$at
10084#    sw $t0,-8($s7) # ... and store back into -8 header-word
10088:  skipMask_readLine:

10088#    sll $t0,$t0,2 # data bytes in object
10092#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
10096#    subu $t0,$t0,$t2 # place to store last character (plus 9)
10100#    addu $sp,$sp,8 # pop redundant object-pointer and count
10104#    addu $t1,$t1,$sp # first non-char spot on stack

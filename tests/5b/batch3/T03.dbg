11448#    lw $v0,lastCharRead
11452#    li $t0,-2
11456#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
11460#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
11464#    jr $ra # return
    
11468:  doReadCh:
    # we need to actually read a character: read and return
11468#    li $v0,12 # use system call to read a character
11472#    syscall
11476#    jr $ra # return

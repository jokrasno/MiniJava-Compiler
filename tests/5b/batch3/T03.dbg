###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
9404:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
9404#    lw $t0,-8($s2) # get word with hash bits from this
9408#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
9412#    addu $t0,$t1

9416#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
9420:mth_equals_Object:
9420#    move $t0,$s2 # first pointer (this)
9424#    lw $t1,($sp) # second pointer
9428#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
9429##...subu $at,$t0,$t1
9433##...sltiu $t0,$at,1

9436#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
9440:mth_hashCode_String:
9440#    move $t0,$s2 # put this pointer in t0

9444#    li $t2,0 # current hash value
9448#    lw $t1,-4($t0) # negative of number of characters in string
9452#    beq $t1,$zero,done_hashCode_String # if zero length => done
9456#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
9460#    and $t0,0xfffffffc # adjust for padding
9461##...lui $at,65535
9465##...ori $at,$at,0xfffc
9469##...and $t0,$t0,$at
9472#    subu $t1,$t0,$t1 # address at end of string +12
9476:loop_hashCode_String:    
9476#    sll $t4,$t2,5 # multiply by 32
9480#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
9484#    lbu $t3,-12($t0) # current character
9488#    addu $t2,$t3 # add in current character
9492#    addu $t0,1 # go to next character's address
9496#    bne $t0,$t1,loop_hashCode_String # loop back if more
9500:done_hashCode_String:    

    # push int on stack
9500#    move $t0, $t2 # put $t2 in return slot
9504#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
9508:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
9508#    subu $sp,4
9512#    sw $ra,($sp)
    
    # get hash value
9516#    lw $t2,-12($s2) # vtable address
9520#    lw $t0,($t2) # method address
9524#    jalr $t0
9528#    subu $sp,8 # push result (int in $t0) on stack
9532#    sw $s5,4($sp)
9536#    sw $t0,($sp)

    # compute print-size of hash value
9540#    li $t0, 1
9544#    lw $t1, ($sp)
9548#    srl $t1,$t1,4
9552#    beq $t1,$zero,toString_skip_loop
9556:toString_loop_top:
9556#    addu $t0,1
9560#    srl $t1,$t1,4
9564#    bne $t1,$zero,toString_loop_top
9568:toString_skip_loop:
9568#    subu $sp,8
9572#    sw $s5,4($sp)
9576#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
9580#    lw $t2,-12($s2) # vtable address
9584#    move $t0,$t2
9588:toString_checkTagBit:
9588#    subu $t0,1
9592#    lb $t1,($t0)
9596#    and $t1,0x80
9597##...lui $at,0
9601##...ori $at,$at,0x80
9605##...and $t1,$t1,$at
9608#    beq $t1,$zero,toString_checkTagBit
9612#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
9616#    subu $sp,8
9620#    sw $t1,($sp)
9624#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
9628#    move $s7,$zero # -4 offset header word
9632#    lw $t4,8($sp) # bytes for hash value
9636#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
9640#    addu $t4,8
9644#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
9648#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

9652#    li $t0,CLASS_String # store string vtable address into ...
9656#    sw $t0,-12($s7) # ... -12 offset in object header
9660#    lw $t2,-12($s2) # our object's vtable address
9664#    lw $t5,4($sp) # number characters in prefix
9668#    lw $t1,12($sp) # number of characters in hashcode
9672#    addu $t3,$t1,$t5 # number of characters in string ...
9676#    addu $t3,1 # ... including the '@' character
9680#    subu $t0,$zero,$t3 # store negated length into ...
9684#    sw $t0,-4($s7) # ... -4 offset header word
9688#    lw $t0,-8($s7) # get -8 offset header-word
9692#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
9693##...slt $at,$t0,$zero
9697##...beq $at,$zero,9716
9700#    and $t0,0xff # mask off object's hash value ...
9701##...lui $at,0
9705##...ori $at,$at,0xff
9709##...and $t0,$t0,$at
9712#    sw $t0,-8($s7) # ... and store back into -8 header-word
9716:skipMask_toString:
9716#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
9720#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
9724#    subu $t4,$t2,$t5
9728:toString_copyLoop:    
9728#    lb $t3,($t4)
9732#    and $t3,0x7f # mask off sign bit (in case first word)
9733##...lui $at,0
9737##...ori $at,$at,0x7f
9741##...and $t3,$t3,$at
9744#    sb $t3,-8($t0)
9748#    addu $t4,1
9752#    addu $t0,1
9756#    blt $t4,$t2,toString_copyLoop
9757##...slt $at,$t4,$t2
9761##...bne $at,$zero,9728

    # copy the '@' sign
9764#    li $t3,'@'
9768#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
9772#    addu $t2,$t0,$t1 # address of last byte in string to store +8
9776#    lw $t3,20($sp) # hash code to print
9780:toString_hashCopyLoop:
9780#    and $t4,$t3,0xf
9784#    srl $t3,4
9788#    lb $t4,hexChars($t4)
9792#    sb $t4,-8($t2)
9796#    subu $t2,$t2,1
9800#    bgt $t2,$t0,toString_hashCopyLoop
9801##...slt $at,$t0,$t2
9805##...bne $at,$zero,9780

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
9808#    addu $sp,28
9812#    lw $ra,($sp)
9816#    addu $sp,4
9820#    move $t0, $s7 # return string we created
9824#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
9828:mth_equals_String:
    
    # quick test for obvious false
9828#    lw $t0,($sp) # second parameter
9832#    beq $t0,$zero,goEsFalse # go return false if null
9836#    lw $t1,-12($t0) # vtable pointer
9840#    la $t2,CLASS_String # string vtable pointer
9844#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
9848#    subu $sp,12
9852#    sw $ra,8($sp)
9856#    sw $s2,4($sp)
9860#    sw $t0,($sp)
9864#    jal mth_compareTo_String
9868#    lw $s2, 4($sp) #restore this pointer and pop parameters
9872#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
9876#    seq $t0,$t0,$zero
9877##...subu $at,$t0,$zero
9881##...sltiu $t0,$at,1

    # pop return address and return $t0
9884#    lw $ra,($sp)
9888#    addu $sp,4

9892#    jr $ra # return
    
9896:goEsFalse:
    # put 0 in $t0 and return
9896#    li $t0, 0
9900#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
9904:mth_toString_String:
    #we are a string, so return this.
9904#    move $t0, $s2
9908#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
9912:mth_readLine_Lib:
    
9912#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
9916#    sw $ra, 4($sp) # save $ra
9920#    move $t1,$sp # save "original" sp

9924:  doRead:

    # read the character
9924#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
9928#    subu $t2,$v0,13
9932#    bne $t2,$zero,notReturnRL
9936#    jal readLogicalChar
9940#    subu $t2,$v0,10 # check for newline
9944#    beq $t2,$zero,foundNewLine
9948#    sw $v0,lastCharRead # push back character into queue
9952#    j foundNewLine # go process the line

9956:  notReturnRL:

    # at this point, $v0 has our character

9956#    subu $t0,$v0,10
9960#    beq $t0,$zero,foundNewLine
9964#    blt $v0,$zero,foundEof
9965##...slt $at,$v0,$zero
9969##...bne $at,$zero,9984

    # we have a character, so push it onto stack
9972#    subu $sp,$sp,4
9976#    sw $v0,($sp)

    # loop back up to get next character
9980#    j doRead

9984:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
9984#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any

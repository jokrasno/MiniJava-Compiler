#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
12380:instanceOf:
    # get object, go return false if null
12380#    lw $t2,($sp)
12384#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
12388#    lw $t2,-12($t2) # vtable address
12392#    sge $t0,$t2,$t0 # are we >= the lower limit?
12393##...slt $t0,$t2,$t0
12397##...xori $t0,$t0,0x1
12400#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
12404#    and $t2,$t0,$t1
12408#    sw $t2,($sp)
12412:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
12412#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

12416:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
12416#    li $v0,4 # syscall-code for print-string
12420#    syscall
12424:exit:
    # print termination message
12424#    li $v0,4 # syscall-code for print-string
12428#    la $a0,exitString
12432#    syscall

    # terminate execution
12436#    li $v0,10 #syscall-code for "exit"
12440#    syscall

12444:outOfHeapMemory:
12444#    la $a0,heapMemoryMsg
12448#    j exitError
12452:divByZeroError:
12452#    la $a0,divByZeroMsg
12456#    j exitError
12460:strIndexOutOfBounds:
12460#    la $a0,strIndexOutOfBoundsMsg
12464#    j exitError
12468:arrayIndexOutOfBounds:
12468#    la $a0,arrayIndexOutOfBoundsMsg
12472#    j exitError
12476:arraySizeOutOfBounds:
12476#    la $a0,arraySizeOutOfBoundsMsg
12480#    j exitError
12484:nullPtrException:
12484#    la $a0,nullPtrExceptionMsg
12488#    j exitError
12492:badIntegerFormat:
12492#    la $a0,badIntegerFormatMsg
12496#    j exitError
12500:castException:
12500#    la $a0,castExceptionMsg
12504#    j exitError
############## data section ################
    .data
12752:hexChars:
    .ascii "0123456789abcdef"
    .align 2
12768:cur_seg:
    .word 0

12772:lastCharRead:
    .word -2 # -2 => no buffered character
12776:prevHashConstant:
    .word 0x2785173c
12780:gcCount:
    .word 0

12784:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
12811:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
12834:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
12869:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
12903:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
12936:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
12967:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
13015:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
13036:gcMsg: 
      .asciiz "\nGC!\n"
13042:gcCountMsg: 
      .asciiz "Number of garbage collections: "

13074:nullStr:
    .asciiz "null"
13079:trueString:
    .asciiz "true"
13084:falseString:
    .asciiz "false"
13090:exitString:
    .ascii "Program terminated."
    #### "falls through" here
13109:newlineString:
    .asciiz "\n"
    
    .align 2
13112:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

13116:seg0_start:
    .space 0x100000
1061692:seg0_end:
1061692:seg1_start:
    .space 0x100000
2110268:seg1_end:

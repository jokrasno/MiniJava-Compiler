    # greater
11428#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
11432#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
11436#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
11440:  cmpHitLimitzz:
11440#    move $t0, $t5 # store return value
11444#    jr $ra # return

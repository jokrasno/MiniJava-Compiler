    # allocate memory
3660#    subu $s6,$t1,$t2 # # chars in target-string
3664#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
3668#    srl $s6,$s6,2 # convert bytes-count to word-count


5232:  gcSkip5:
5232#    sll $t8,$t8,2 # bytes in negative-offset portion ...
5236#    addu $t8,$t8,8 # ... add in bytes for header-words
5240#    subu $t4,$t1,$t8 # address of first word of source object
5244#    lw $t3,-4($t1) # # words in positive-offset portion
5248#    bge $t3,$zero,gcNoNeg
5249##...slt $at,$t3,$zero
5253##...beq $at,$zero,5260
5256#    move $t3,$zero # negative treated as zero
5260:  gcNoNeg:
5260#    sll $t3,$t3,2 # bytes in negative-offset portion
5264#    addu $t3,$t3,$t1 # address one word past last word of source

5268#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
5272#    lw $s0,($t4)
5276#    lw $t9,-8($t1)
5280#    sw $t9,($t4)
5284#    sw $s0,-8($t1)

    # copy all source bytes to the target
5288:  gCinnerCopy2:
5288#    lw $s0,($t4)
5292#    sw $s0,($s3)
5296#    addu $t4,$t4,4
5300#    addu $s3,$s3,4
5304#    bltu $t4,$t3,gCinnerCopy2
5305##...sltu $at,$t4,$t3
5309##...bne $at,$zero,5288

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
5312#    sw $zero,-8($t1) # 0 in first header-slot
5316#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
5320#    sw $t8,($t0)

5324:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
5324#    addu $t0,$t0,4
5328#    bltu $t0,$s1,gcNextPointerInObject
5329##...sltu $at,$t0,$s1
5333##...bne $at,$zero,5172

5336:  gcTestIterDone2:
5336#    bltu $t0,$s3,gcHeapCopyLoop
5337##...sltu $at,$t0,$s3
5341##...bne $at,$zero,5056

    ###### end outer loop to copy all non-stack-direct objects ######

5344:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
5344#    lw $s2,($sp)
5348#    addu $sp,$sp,4

    # mark us as having already GC'd
5352#    move $t5,$s5

    # go try and allocate again
5356#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
5360:vm_init:

    # mark bottom of stack
5360#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
5364#    move $s2,$zero

    #set up the "five" register
5368#    li $s5,5

5372#    la $s3,seg0_start
5376#    la $s4,seg0_end
5377##...lui $s4,16
5381##...addiu $s4,$s4,6300
    
    # return
5384#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5388:divide:
    # get parameters; abort if divisor zero
5388#    lw $t0,($sp)
5392#    lw $t1,8($sp)
5396#    beq $t0,$zero,divByZeroError
    
    # perform division
5400#    div $t1,$t0
5404#    mflo $t0

    # store result, adjust stack and return
5408#    addu $sp,$sp,8 # adjust stack
5412#    sw $t0,($sp) # store result
5416#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5420:remainder:
    # get parameters; abort if divisor zero
5420#    lw $t0,($sp)
5424#    lw $t1,8($sp)
5428#    beq $t0,$zero,divByZeroError
    
    # perform division
5432#    div $t1,$t0
5436#    mfhi $t0

    # store result, adjust stack and return
5440#    addu $sp,$sp,8 # adjust stack
5444#    sw $t0,($sp) # store result
5448#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
5452:checkCast:
    # get object, allow immediately if null
5452#    lw $t2,($sp)
5456#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
5460#    lw $t2,-12($t2) # vtable address
5464#    bge $t2,$t1,castException
5465##...slt $at,$t2,$t1
5469##...beq $at,$zero,5604
5472#    blt $t2,$t0,castException
5473##...slt $at,$t2,$t0
5477##...bne $at,$zero,5604
    
    # return, leaving object unchanged on stack
5480:  checkCastReturn:    
5480#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
5484:instanceOf:
    # get object, go return false if null
5484#    lw $t2,($sp)
5488#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
5492#    lw $t2,-12($t2) # vtable address
5496#    sge $t0,$t2,$t0 # are we >= the lower limit?
5497##...slt $t0,$t2,$t0
5501##...xori $t0,$t0,0x1
5504#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
5508#    and $t2,$t0,$t1
5512#    sw $t2,($sp)
5516:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
5516#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

5520:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
5520#    li $v0,4 # syscall-code for print-string
5524#    syscall
5528:exit:
    # print termination message
5528#    li $v0,4 # syscall-code for print-string
5532#    la $a0,exitString
5536#    syscall

    # terminate execution
5540#    li $v0,10 #syscall-code for "exit"
5544#    syscall

5548:outOfHeapMemory:
5548#    la $a0,heapMemoryMsg
5552#    j exitError
5556:divByZeroError:
5556#    la $a0,divByZeroMsg
5560#    j exitError
5564:strIndexOutOfBounds:
5564#    la $a0,strIndexOutOfBoundsMsg
5568#    j exitError
5572:arrayIndexOutOfBounds:
5572#    la $a0,arrayIndexOutOfBoundsMsg
5576#    j exitError
5580:arraySizeOutOfBounds:
5580#    la $a0,arraySizeOutOfBoundsMsg
5584#    j exitError
5588:nullPtrException:
5588#    la $a0,nullPtrExceptionMsg
5592#    j exitError
5596:badIntegerFormat:
5596#    la $a0,badIntegerFormatMsg
5600#    j exitError
5604:castException:
5604#    la $a0,castExceptionMsg
5608#    j exitError
############## data section ################
    .data
5936:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5952:cur_seg:
    .word 0

5956:lastCharRead:
    .word -2 # -2 => no buffered character
5960:prevHashConstant:
    .word 0x2785173c
5964:gcCount:
    .word 0

5968:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5995:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
6018:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
6053:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
6087:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
6120:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
6151:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
6199:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
6220:gcMsg: 
      .asciiz "\nGC!\n"
6226:gcCountMsg: 
      .asciiz "Number of garbage collections: "

6258:nullStr:
    .asciiz "null"
6263:trueString:
    .asciiz "true"
6268:falseString:
    .asciiz "false"
6274:exitString:
    .ascii "Program terminated."
    #### "falls through" here
6293:newlineString:
    .asciiz "\n"
    
    .align 2
6296:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

6300:seg0_start:
    .space 0x100000
1054876:seg0_end:
1054876:seg1_start:
    .space 0x100000
2103452:seg1_end:

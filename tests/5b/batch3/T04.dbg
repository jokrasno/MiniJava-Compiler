########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
3604:mth_substring_String:

    # save $ra by pushing onto stack
3604#    subu $sp,$sp,4
3608#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
3612#    move $t0,$s2
3616#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
3620#    lw $t0,-4($t0) # negative of string length
3624#    subu $t0,$zero,$t0 # string length
3628#    lw $t1,4($sp) # k
3632#    lw $t2,12($sp) # n
3636#    bgt $zero,$t2,strIndexOutOfBounds
3637##...slt $at,$t2,$zero
3641##...bne $at,$zero,5564
3644#    bgt $t2,$t1,strIndexOutOfBounds
3645##...slt $at,$t1,$t2
3649##...bne $at,$zero,5564
3652#    bgt $t1,$t0,strIndexOutOfBounds
3653##...slt $at,$t0,$t1
3657##...bne $at,$zero,5564

3481##...bne $at,$zero,3500
3484#    and $t1,0xff # mask out all but low byte
3485##...lui $at,0
3489##...ori $at,$at,0xff
3493##...and $t1,$t1,$at
3496#    b skipPrintStr2
3500:skipPrintStr1:
3500#    and $t1,0x7ffffff
3501##...lui $at,2047
3505##...ori $at,$at,0xffff
3509##...and $t1,$t1,$at
3512:skipPrintStr2:    
3512#    sll $t1,$t1,2
3516#    subu $t1,$t0,$t1 # first word in string
3520#    lw $t0,4($t0) # negative of string-length
3524#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
3528#    beq $t0,$t1,donePrintStr
3532:  psLoop:
3532#    lb $a0,($t1) # next byte
3536#    li $v0,11 # code for printing char
3540#        syscall # print the char
3544#    addu $t1,$t1,1 # go to next char
3548#    blt $t1,$t0,psLoop
3549##...slt $at,$t1,$t0
3553##...bne $at,$zero,3532

3556:  donePrintStr:
3556#    jr $ra

########################################################
# printInt(n) - library method (class Lib)
# - prints integer in decimal format to standard output
# - parameters:
#   - ($sp) - the integer to print
#   - 4($sp) - GC tag
#   - ($sp) - old-this-pointer
########################################################
3560:mth_printInt_Lib:

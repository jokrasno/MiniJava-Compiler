##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2508:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
2508#    lw $t0,-8($s2) # get word with hash bits from this
2512#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
2516#    addu $t0,$t1

2520#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2524:mth_equals_Object:
2524#    move $t0,$s2 # first pointer (this)
2528#    lw $t1,($sp) # second pointer
2532#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
2533##...subu $at,$t0,$t1
2537##...sltiu $t0,$at,1

2540#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2544:mth_hashCode_String:
2544#    move $t0,$s2 # put this pointer in t0

2548#    li $t2,0 # current hash value
2552#    lw $t1,-4($t0) # negative of number of characters in string
2556#    beq $t1,$zero,done_hashCode_String # if zero length => done
2560#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
2564#    and $t0,0xfffffffc # adjust for padding
2565##...lui $at,65535
2569##...ori $at,$at,0xfffc
2573##...and $t0,$t0,$at
2576#    subu $t1,$t0,$t1 # address at end of string +12
2580:loop_hashCode_String:    
2580#    sll $t4,$t2,5 # multiply by 32
2584#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
2588#    lbu $t3,-12($t0) # current character
2592#    addu $t2,$t3 # add in current character
2596#    addu $t0,1 # go to next character's address
2600#    bne $t0,$t1,loop_hashCode_String # loop back if more
2604:done_hashCode_String:    

    # push int on stack
2604#    move $t0, $t2 # put $t2 in return slot
2608#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
2612:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
2612#    subu $sp,4
2616#    sw $ra,($sp)
    
    # get hash value
2620#    lw $t2,-12($s2) # vtable address
2624#    lw $t0,($t2) # method address
2628#    jalr $t0
2632#    subu $sp,8 # push result (int in $t0) on stack
2636#    sw $s5,4($sp)
2640#    sw $t0,($sp)

    # compute print-size of hash value
2644#    li $t0, 1
2648#    lw $t1, ($sp)
2652#    srl $t1,$t1,4
2656#    beq $t1,$zero,toString_skip_loop
2660:toString_loop_top:
2660#    addu $t0,1
2664#    srl $t1,$t1,4
2668#    bne $t1,$zero,toString_loop_top
2672:toString_skip_loop:
2672#    subu $sp,8
2676#    sw $s5,4($sp)
2680#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
2684#    lw $t2,-12($s2) # vtable address
2688#    move $t0,$t2
2692:toString_checkTagBit:
2692#    subu $t0,1
2696#    lb $t1,($t0)
2700#    and $t1,0x80
2701##...lui $at,0
2705##...ori $at,$at,0x80
2709##...and $t1,$t1,$at
2712#    beq $t1,$zero,toString_checkTagBit
2716#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
2720#    subu $sp,8
2724#    sw $t1,($sp)
2728#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
2732#    move $s7,$zero # -4 offset header word
2736#    lw $t4,8($sp) # bytes for hash value
2740#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
2744#    addu $t4,8
2748#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
2752#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

2756#    li $t0,CLASS_String # store string vtable address into ...
2760#    sw $t0,-12($s7) # ... -12 offset in object header
2764#    lw $t2,-12($s2) # our object's vtable address
2768#    lw $t5,4($sp) # number characters in prefix
2772#    lw $t1,12($sp) # number of characters in hashcode
2776#    addu $t3,$t1,$t5 # number of characters in string ...
2780#    addu $t3,1 # ... including the '@' character
2784#    subu $t0,$zero,$t3 # store negated length into ...
2788#    sw $t0,-4($s7) # ... -4 offset header word
2792#    lw $t0,-8($s7) # get -8 offset header-word
2796#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2797##...slt $at,$t0,$zero
2801##...beq $at,$zero,2820
2804#    and $t0,0xff # mask off object's hash value ...
2805##...lui $at,0
2809##...ori $at,$at,0xff
2813##...and $t0,$t0,$at
2816#    sw $t0,-8($s7) # ... and store back into -8 header-word
2820:skipMask_toString:
2820#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2824#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2828#    subu $t4,$t2,$t5
2832:toString_copyLoop:    
2832#    lb $t3,($t4)
2836#    and $t3,0x7f # mask off sign bit (in case first word)
2837##...lui $at,0
2841##...ori $at,$at,0x7f
2845##...and $t3,$t3,$at
2848#    sb $t3,-8($t0)
2852#    addu $t4,1
2856#    addu $t0,1
2860#    blt $t4,$t2,toString_copyLoop
2861##...slt $at,$t4,$t2
2865##...bne $at,$zero,2832

    # copy the '@' sign
2868#    li $t3,'@'
2872#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2876#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2880#    lw $t3,20($sp) # hash code to print
2884:toString_hashCopyLoop:
2884#    and $t4,$t3,0xf
2888#    srl $t3,4
2892#    lb $t4,hexChars($t4)
2896#    sb $t4,-8($t2)
2900#    subu $t2,$t2,1
2904#    bgt $t2,$t0,toString_hashCopyLoop
2905##...slt $at,$t0,$t2
2909##...bne $at,$zero,2884

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2912#    addu $sp,28
2916#    lw $ra,($sp)
2920#    addu $sp,4
2924#    move $t0, $s7 # return string we created
2928#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2932:mth_equals_String:
    
    # quick test for obvious false
2932#    lw $t0,($sp) # second parameter
2936#    beq $t0,$zero,goEsFalse # go return false if null
2940#    lw $t1,-12($t0) # vtable pointer
2944#    la $t2,CLASS_String # string vtable pointer
2948#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2952#    subu $sp,12
2956#    sw $ra,8($sp)
2960#    sw $s2,4($sp)
2964#    sw $t0,($sp)
2968#    jal mth_compareTo_String
2972#    lw $s2, 4($sp) #restore this pointer and pop parameters
2976#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2980#    seq $t0,$t0,$zero
2981##...subu $at,$t0,$zero
2985##...sltiu $t0,$at,1

    # pop return address and return $t0
2988#    lw $ra,($sp)
2992#    addu $sp,4

2996#    jr $ra # return
    
3000:goEsFalse:
    # put 0 in $t0 and return
3000#    li $t0, 0
3004#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
3008:mth_toString_String:
    #we are a string, so return this.
3008#    move $t0, $s2
3012#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
3016:mth_readLine_Lib:
    
3016#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
3020#    sw $ra, 4($sp) # save $ra
3024#    move $t1,$sp # save "original" sp

3028:  doRead:

    # read the character
3028#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
3032#    subu $t2,$v0,13
3036#    bne $t2,$zero,notReturnRL
3040#    jal readLogicalChar
3044#    subu $t2,$v0,10 # check for newline
3048#    beq $t2,$zero,foundNewLine
3052#    sw $v0,lastCharRead # push back character into queue
3056#    j foundNewLine # go process the line

3060:  notReturnRL:

    # at this point, $v0 has our character

3060#    subu $t0,$v0,10
3064#    beq $t0,$zero,foundNewLine
3068#    blt $v0,$zero,foundEof
3069##...slt $at,$v0,$zero
3073##...bne $at,$zero,3088

    # we have a character, so push it onto stack
3076#    subu $sp,$sp,4
3080#    sw $v0,($sp)

    # loop back up to get next character
3084#    j doRead

3088:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
3088#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
3092#    li $s7, 0 # return-value: null
3096#    j rlReturn # return

3100:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
3100#    subu $t0,$t1,$sp # number of chars we read (times 4)
3104#    srl $s6,$t0,2 # number of words on stack with chars
3108#    subu $sp,$sp,4 # push char-count ...
3112#    sw $s6,($sp) # ... onto stack
3116#    addu $t2,$t0,5 # GC tag, incl. for count-word
3120#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
3124#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
3128#    srl $s6,$s6,2  # data words in object
3132#    move $s7,$zero # object words in object
3136#    jal newObject  # allocate space
    
    # store header words
3140#    la $t0,CLASS_String
3144#    sw $t0,-12($s7)# store class tag (String) into object
3148#    lw $t2,4($sp) # char-count
3152#    sll $t1,$t2,2 # 4 times number of chars
3156#    subu $t2,$zero,$t2 # negative of char-count
3160#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3164#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3168#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3169##...slt $at,$t0,$zero
3173##...beq $at,$zero,3192
3176#    and $t0,0xff # mask off object's hash value ...
3177##...lui $at,0
3181##...ori $at,$at,0xff
3185##...and $t0,$t0,$at
3188#    sw $t0,-8($s7) # ... and store back into -8 header-word
3192:  skipMask_readLine:

3192#    sll $t0,$t0,2 # data bytes in object
3196#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
3200#    subu $t0,$t0,$t2 # place to store last character (plus 9)
3204#    addu $sp,$sp,8 # pop redundant object-pointer and count
3208#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

3212#    beq $sp,$t1,rlReturn
3216:  charCopyLoop:
3216#    lw $t2,($sp)
3220#    sb $t2,-9($t0)
3224#    addu $sp,$sp,4
3228#    subu $t0,$t0,1
3232#    bne $sp,$t1,charCopyLoop
3236:  rlReturn:

3236#    lw $ra, 4($sp)
3240#    addu $sp, 8   # pop $ra and pointless word off stack
3244#    move $t0, $s7 # return string we allocated in $s7
3248#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3252:mth_readInt_Lib:

    # save $ra by pushing onto stack
3252#    subu $sp,$sp,4
3256#    sw $ra,($sp)

3260:  riSkipWhiteLoop:
    # read a character
3260#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
3264#    subu $t0,$v0,32
3268#    bgt $t0,$zero,nonWhite
3269##...slt $at,$zero,$t0
3273##...bne $at,$zero,3316
3276#    beq $t0,$zero,riSkipWhiteLoop # start over if space
3280#    subu $t0,$v0,10
3284#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
3288#    subu $t0,$v0,9
3292#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
3296#    subu $t0,$v0,13
3300#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
3304#    subu $t0,$v0,12
3308#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
3312#    j badIntegerFormat # illegal integer char: abort program

3316:  nonWhite:
3316#    subu $t0,$v0,'-'
3320#    li $t4,1 # final multiplier
3324#    bne $t0,$zero,helpReadInt # go read
3328#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
3332#    jal readLogicalChar

3336:  helpReadInt:
3336#    li $t2,10
3340#    subu $t1,$v0,'0' # convert digit to 0-9 value
3344#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
3345##...sltu $at,$t1,$t2
3349##...beq $at,$zero,5596
3352#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

3356:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

3356#    jal readLogicalChar # read next character
3360#    subu $t1,$v0,'0' # convert digit to 0-9 value
3364#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
3365##...sltu $at,$t1,$t2
3369##...beq $at,$zero,3388

3372#    mul $t3,$t3,$t2 # multiply old value by 10
3373##...mult $t3,$t2
3377##...mflo $t3
3380#    addu $t3,$t3,$t1 # add in value of new digit
3384#    j digitLoop

3388:  doneDigitLoop:

    # "push back" unused character into queue
3388#    sw $v0,lastCharRead

    # restore return address
3392#    lw $ra,($sp)
3396#    addu $sp, 4

    # multiply by sign and put return value in $t0
3400#    mult $t3,$t4 # multiply to account for poss. minus sign
3404#    mflo $t3
3408#    move $t0, $t3
    
    # return
3412#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3416:mth_readChar_Lib:

    # save $ra by pushing onto stack
3416#    subu $sp,$sp,4
3420#    sw $ra,($sp)

      # read the character
3424#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
3428#    lw $ra,($sp)
3432#    addu $sp, 4
3436#    move $t0, $v0

    # return
3440#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
3444:mth_printStr_Lib:
    # check for null, printing "(null)", if so
3444#    lw $t0,($sp)
3448#    bne $t0,$zero,psNotNull

    # print "(null)"
3452#    la $a0,nullStr
3456#    li $v0,4
3460#    syscall
3464#    j donePrintStr
    
3468:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
3468#    subu $t0,$t0,8
3472#    lw $t1,($t0) # number of data words, but needs modification
3476#    blt $t1,$zero,skipPrintStr1

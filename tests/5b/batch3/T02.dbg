###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
8412:mth_readInt_Lib:

    # save $ra by pushing onto stack
8412#    subu $sp,$sp,4
8416#    sw $ra,($sp)

8420:  riSkipWhiteLoop:
    # read a character
8420#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
8424#    subu $t0,$v0,32
8428#    bgt $t0,$zero,nonWhite
8429##...slt $at,$zero,$t0
8433##...bne $at,$zero,8476
8436#    beq $t0,$zero,riSkipWhiteLoop # start over if space
8440#    subu $t0,$v0,10
8444#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
8448#    subu $t0,$v0,9
8452#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
8456#    subu $t0,$v0,13
8460#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
8464#    subu $t0,$v0,12
8468#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
8472#    j badIntegerFormat # illegal integer char: abort program

8476:  nonWhite:
8476#    subu $t0,$v0,'-'
8480#    li $t4,1 # final multiplier
8484#    bne $t0,$zero,helpReadInt # go read
8488#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
8492#    jal readLogicalChar

8496:  helpReadInt:
8496#    li $t2,10
8500#    subu $t1,$v0,'0' # convert digit to 0-9 value

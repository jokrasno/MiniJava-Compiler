##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
7668:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
7668#    lw $t0,-8($s2) # get word with hash bits from this
7672#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
7676#    addu $t0,$t1

7680#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
7684:mth_equals_Object:
7684#    move $t0,$s2 # first pointer (this)
7688#    lw $t1,($sp) # second pointer
7692#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
7693##...subu $at,$t0,$t1
7697##...sltiu $t0,$at,1

7700#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
7704:mth_hashCode_String:
7704#    move $t0,$s2 # put this pointer in t0

7708#    li $t2,0 # current hash value
7712#    lw $t1,-4($t0) # negative of number of characters in string
7716#    beq $t1,$zero,done_hashCode_String # if zero length => done
7720#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
7724#    and $t0,0xfffffffc # adjust for padding
7725##...lui $at,65535
7729##...ori $at,$at,0xfffc
7733##...and $t0,$t0,$at
7736#    subu $t1,$t0,$t1 # address at end of string +12
7740:loop_hashCode_String:    
7740#    sll $t4,$t2,5 # multiply by 32
7744#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
7748#    lbu $t3,-12($t0) # current character
7752#    addu $t2,$t3 # add in current character
7756#    addu $t0,1 # go to next character's address
7760#    bne $t0,$t1,loop_hashCode_String # loop back if more
7764:done_hashCode_String:    

    # push int on stack
7764#    move $t0, $t2 # put $t2 in return slot
7768#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
7772:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
7772#    subu $sp,4
7776#    sw $ra,($sp)
    
    # get hash value
7780#    lw $t2,-12($s2) # vtable address
7784#    lw $t0,($t2) # method address
7788#    jalr $t0
7792#    subu $sp,8 # push result (int in $t0) on stack
7796#    sw $s5,4($sp)
7800#    sw $t0,($sp)

    # compute print-size of hash value
7804#    li $t0, 1
7808#    lw $t1, ($sp)
7812#    srl $t1,$t1,4
7816#    beq $t1,$zero,toString_skip_loop
7820:toString_loop_top:
7820#    addu $t0,1
7824#    srl $t1,$t1,4
7828#    bne $t1,$zero,toString_loop_top
7832:toString_skip_loop:
7832#    subu $sp,8
7836#    sw $s5,4($sp)
7840#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
7844#    lw $t2,-12($s2) # vtable address
7848#    move $t0,$t2
7852:toString_checkTagBit:
7852#    subu $t0,1
7856#    lb $t1,($t0)
7860#    and $t1,0x80
7861##...lui $at,0
7865##...ori $at,$at,0x80
7869##...and $t1,$t1,$at
7872#    beq $t1,$zero,toString_checkTagBit
7876#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
7880#    subu $sp,8
7884#    sw $t1,($sp)
7888#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
7892#    move $s7,$zero # -4 offset header word
7896#    lw $t4,8($sp) # bytes for hash value
7900#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
7904#    addu $t4,8
7908#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
7912#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

7916#    li $t0,CLASS_String # store string vtable address into ...
7920#    sw $t0,-12($s7) # ... -12 offset in object header
7924#    lw $t2,-12($s2) # our object's vtable address
7928#    lw $t5,4($sp) # number characters in prefix
7932#    lw $t1,12($sp) # number of characters in hashcode
7936#    addu $t3,$t1,$t5 # number of characters in string ...
7940#    addu $t3,1 # ... including the '@' character
7944#    subu $t0,$zero,$t3 # store negated length into ...
7948#    sw $t0,-4($s7) # ... -4 offset header word
7952#    lw $t0,-8($s7) # get -8 offset header-word
7956#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
7957##...slt $at,$t0,$zero
7961##...beq $at,$zero,7980
7964#    and $t0,0xff # mask off object's hash value ...
7965##...lui $at,0
7969##...ori $at,$at,0xff
7973##...and $t0,$t0,$at
7976#    sw $t0,-8($s7) # ... and store back into -8 header-word
7980:skipMask_toString:
7980#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
7984#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
7988#    subu $t4,$t2,$t5
7992:toString_copyLoop:    
7992#    lb $t3,($t4)
7996#    and $t3,0x7f # mask off sign bit (in case first word)
7997##...lui $at,0
8001##...ori $at,$at,0x7f
8005##...and $t3,$t3,$at
8008#    sb $t3,-8($t0)
8012#    addu $t4,1
8016#    addu $t0,1
8020#    blt $t4,$t2,toString_copyLoop
8021##...slt $at,$t4,$t2
8025##...bne $at,$zero,7992

    # copy the '@' sign
8028#    li $t3,'@'
8032#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
8036#    addu $t2,$t0,$t1 # address of last byte in string to store +8
8040#    lw $t3,20($sp) # hash code to print
8044:toString_hashCopyLoop:
8044#    and $t4,$t3,0xf
8048#    srl $t3,4
8052#    lb $t4,hexChars($t4)
8056#    sb $t4,-8($t2)
8060#    subu $t2,$t2,1
8064#    bgt $t2,$t0,toString_hashCopyLoop
8065##...slt $at,$t0,$t2
8069##...bne $at,$zero,8044

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
8072#    addu $sp,28
8076#    lw $ra,($sp)
8080#    addu $sp,4
8084#    move $t0, $s7 # return string we created
8088#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
8092:mth_equals_String:
    
    # quick test for obvious false
8092#    lw $t0,($sp) # second parameter
8096#    beq $t0,$zero,goEsFalse # go return false if null
8100#    lw $t1,-12($t0) # vtable pointer
8104#    la $t2,CLASS_String # string vtable pointer
8108#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
8112#    subu $sp,12
8116#    sw $ra,8($sp)
8120#    sw $s2,4($sp)
8124#    sw $t0,($sp)
8128#    jal mth_compareTo_String
8132#    lw $s2, 4($sp) #restore this pointer and pop parameters
8136#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
8140#    seq $t0,$t0,$zero
8141##...subu $at,$t0,$zero
8145##...sltiu $t0,$at,1

    # pop return address and return $t0
8148#    lw $ra,($sp)
8152#    addu $sp,4

8156#    jr $ra # return
    
8160:goEsFalse:
    # put 0 in $t0 and return
8160#    li $t0, 0
8164#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
8168:mth_toString_String:
    #we are a string, so return this.
8168#    move $t0, $s2
8172#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
8176:mth_readLine_Lib:
    
8176#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
8180#    sw $ra, 4($sp) # save $ra
8184#    move $t1,$sp # save "original" sp

8188:  doRead:

    # read the character
8188#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
8192#    subu $t2,$v0,13
8196#    bne $t2,$zero,notReturnRL
8200#    jal readLogicalChar
8204#    subu $t2,$v0,10 # check for newline
8208#    beq $t2,$zero,foundNewLine
8212#    sw $v0,lastCharRead # push back character into queue
8216#    j foundNewLine # go process the line

8220:  notReturnRL:

    # at this point, $v0 has our character

8220#    subu $t0,$v0,10
8224#    beq $t0,$zero,foundNewLine
8228#    blt $v0,$zero,foundEof
8229##...slt $at,$v0,$zero
8233##...bne $at,$zero,8248

    # we have a character, so push it onto stack
8236#    subu $sp,$sp,4
8240#    sw $v0,($sp)

    # loop back up to get next character
8244#    j doRead

8248:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
8248#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
8252#    li $s7, 0 # return-value: null
8256#    j rlReturn # return

8260:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
8260#    subu $t0,$t1,$sp # number of chars we read (times 4)
8264#    srl $s6,$t0,2 # number of words on stack with chars
8268#    subu $sp,$sp,4 # push char-count ...
8272#    sw $s6,($sp) # ... onto stack

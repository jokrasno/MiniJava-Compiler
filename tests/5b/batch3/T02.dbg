    # storing digits on stack until we reach 0
9296:  itsNonNegLoop:
9296#    divu $t1,$t3
9300#    mflo $t1 # quotient
9304#    mfhi $t4 # remainder
9308#    addu $t4,$t4,'0' # turn remainder into digit
9312#    subu $sp,$sp,4

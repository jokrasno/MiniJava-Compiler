
8516:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

8516#    jal readLogicalChar # read next character
8520#    subu $t1,$v0,'0' # convert digit to 0-9 value
8524#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
8525##...sltu $at,$t1,$t2
8529##...beq $at,$zero,8548

8532#    mul $t3,$t3,$t2 # multiply old value by 10
8533##...mult $t3,$t2
8537##...mflo $t3
8540#    addu $t3,$t3,$t1 # add in value of new digit
8544#    j digitLoop

8548:  doneDigitLoop:

    # "push back" unused character into queue

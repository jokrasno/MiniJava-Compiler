########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
10520:vm_init:

    # mark bottom of stack
10520#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
10524#    move $s2,$zero

    #set up the "five" register
10528#    li $s5,5

10532#    la $s3,seg0_start
10536#    la $s4,seg0_end
10537##...lui $s4,16
10541##...addiu $s4,$s4,11364
    
    # return
10544#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
10548:divide:
    # get parameters; abort if divisor zero
10548#    lw $t0,($sp)
10552#    lw $t1,8($sp)
10556#    beq $t0,$zero,divByZeroError
    
    # perform division
10560#    div $t1,$t0
10564#    mflo $t0

    # store result, adjust stack and return
10568#    addu $sp,$sp,8 # adjust stack
10572#    sw $t0,($sp) # store result
10576#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
10580:remainder:
    # get parameters; abort if divisor zero
10580#    lw $t0,($sp)
10584#    lw $t1,8($sp)
10588#    beq $t0,$zero,divByZeroError
    
    # perform division
10592#    div $t1,$t0
10596#    mfhi $t0

    # store result, adjust stack and return
10600#    addu $sp,$sp,8 # adjust stack
10604#    sw $t0,($sp) # store result
10608#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
10612:checkCast:
    # get object, allow immediately if null
10612#    lw $t2,($sp)
10616#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
10620#    lw $t2,-12($t2) # vtable address
10624#    bge $t2,$t1,castException
10625##...slt $at,$t2,$t1
10629##...beq $at,$zero,10764
10632#    blt $t2,$t0,castException
10633##...slt $at,$t2,$t0
10637##...bne $at,$zero,10764
    
    # return, leaving object unchanged on stack
10640:  checkCastReturn:    
10640#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
10644:instanceOf:
    # get object, go return false if null
10644#    lw $t2,($sp)
10648#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
10652#    lw $t2,-12($t2) # vtable address
10656#    sge $t0,$t2,$t0 # are we >= the lower limit?
10657##...slt $t0,$t2,$t0
10661##...xori $t0,$t0,0x1
10664#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
10668#    and $t2,$t0,$t1
10672#    sw $t2,($sp)
10676:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
10676#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

10680:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
10680#    li $v0,4 # syscall-code for print-string
10684#    syscall
10688:exit:
    # print termination message
10688#    li $v0,4 # syscall-code for print-string
10692#    la $a0,exitString
10696#    syscall

    # terminate execution
10700#    li $v0,10 #syscall-code for "exit"
10704#    syscall

10708:outOfHeapMemory:
10708#    la $a0,heapMemoryMsg
10712#    j exitError
10716:divByZeroError:
10716#    la $a0,divByZeroMsg
10720#    j exitError
10724:strIndexOutOfBounds:
10724#    la $a0,strIndexOutOfBoundsMsg
10728#    j exitError
10732:arrayIndexOutOfBounds:
10732#    la $a0,arrayIndexOutOfBoundsMsg
10736#    j exitError
10740:arraySizeOutOfBounds:
10740#    la $a0,arraySizeOutOfBoundsMsg
10744#    j exitError
10748:nullPtrException:
10748#    la $a0,nullPtrExceptionMsg
10752#    j exitError
10756:badIntegerFormat:
10756#    la $a0,badIntegerFormatMsg
10760#    j exitError
10764:castException:
10764#    la $a0,castExceptionMsg
10768#    j exitError
############## data section ################
    .data
11000:hexChars:
    .ascii "0123456789abcdef"
    .align 2
11016:cur_seg:
    .word 0

11020:lastCharRead:
    .word -2 # -2 => no buffered character
11024:prevHashConstant:
    .word 0x2785173c
11028:gcCount:
    .word 0

11032:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
11059:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
11082:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
11117:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
11151:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
11184:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
11215:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
11263:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
11284:gcMsg: 
      .asciiz "\nGC!\n"
11290:gcCountMsg: 
      .asciiz "Number of garbage collections: "

11322:nullStr:
    .asciiz "null"
11327:trueString:
    .asciiz "true"
11332:falseString:
    .asciiz "false"
11338:exitString:
    .ascii "Program terminated."
    #### "falls through" here
11357:newlineString:
    .asciiz "\n"
    
    .align 2
11360:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

11364:seg0_start:
    .space 0x100000
1059940:seg0_end:
1059940:seg1_start:
    .space 0x100000
2108516:seg1_end:

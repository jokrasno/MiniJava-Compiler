    # buffer and return
2720#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2724#    jr $ra # return
    
2728:  doReadCh:
    # we need to actually read a character: read and return
2728#    li $v0,12 # use system call to read a character
2732#    syscall
2736#    jr $ra # return

1137##...subu $at,$t0,$zero
1141##...sltiu $t0,$at,1

    # pop return address and return $t0
1144#    lw $ra,($sp)
1148#    addu $sp,4

1152#    jr $ra # return
    
1156:goEsFalse:
    # put 0 in $t0 and return
1156#    li $t0, 0
1160#    jr $ra # return

2817##...beq $at,$zero,2864
2820#    lw $t1,prevHashConstant
2824#    addu $t1,0x12b68fd2
2825##...lui $at,4791
2829##...addiu $at,$at,-28718
2833##...addu $t1,$at,$t1
2836#    sw $t1,prevHashConstant # update hash constant
2840#    or $t1,0x80000000 # set top bit
2841##...lui $at,32768
2845##...or $t1,$at,$t1
2848#    and $t1,0xffffff00 # clear low bit
2849##...lui $at,65535
2853##...ori $at,$at,0xff00
2857##...and $t1,$t1,$at
2860#    or $s6,$t1
2864:firstHeaderLarge:
2864#    sw $s6,-8($t0) # store header-1 value
2868#    lw $zero,-8($t0)

    # store second header-value
2872#    sw $s7,-4($t0)   # second header-word
2876#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
2880#    move $s7,$t0
2884#    subu $sp,$sp,4
2888#    sw $t0,($sp)

2892#    jr $ra

1432#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1436#    subu $t0,$v0,10
1440#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1444#    subu $t0,$v0,9
1448#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1452#    subu $t0,$v0,13
1456#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1460#    subu $t0,$v0,12
1464#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1468#    j badIntegerFormat # illegal integer char: abort program

1472:  nonWhite:
1472#    subu $t0,$v0,'-'
1476#    li $t4,1 # final multiplier
1480#    bne $t0,$zero,helpReadInt # go read
1484#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'

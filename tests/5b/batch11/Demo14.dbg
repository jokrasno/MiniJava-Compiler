##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
664:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
664#    lw $t0,-8($s2) # get word with hash bits from this
668#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
672#    addu $t0,$t1

676#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
680:mth_equals_Object:
680#    move $t0,$s2 # first pointer (this)
684#    lw $t1,($sp) # second pointer
688#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
689##...subu $at,$t0,$t1
693##...sltiu $t0,$at,1

696#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
700:mth_hashCode_String:
700#    move $t0,$s2 # put this pointer in t0

704#    li $t2,0 # current hash value
708#    lw $t1,-4($t0) # negative of number of characters in string
712#    beq $t1,$zero,done_hashCode_String # if zero length => done
716#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
720#    and $t0,0xfffffffc # adjust for padding
721##...lui $at,65535
725##...ori $at,$at,0xfffc
729##...and $t0,$t0,$at
732#    subu $t1,$t0,$t1 # address at end of string +12
736:loop_hashCode_String:    
736#    sll $t4,$t2,5 # multiply by 32
740#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
744#    lbu $t3,-12($t0) # current character
748#    addu $t2,$t3 # add in current character
752#    addu $t0,1 # go to next character's address
756#    bne $t0,$t1,loop_hashCode_String # loop back if more
760:done_hashCode_String:    

    # push int on stack
760#    move $t0, $t2 # put $t2 in return slot
764#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
768:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
768#    subu $sp,4
772#    sw $ra,($sp)
    
    # get hash value
776#    lw $t2,-12($s2) # vtable address
780#    lw $t0,($t2) # method address
784#    jalr $t0
788#    subu $sp,8 # push result (int in $t0) on stack
792#    sw $s5,4($sp)
796#    sw $t0,($sp)

    # compute print-size of hash value
800#    li $t0, 1
804#    lw $t1, ($sp)
808#    srl $t1,$t1,4
812#    beq $t1,$zero,toString_skip_loop
816:toString_loop_top:
816#    addu $t0,1
820#    srl $t1,$t1,4
824#    bne $t1,$zero,toString_loop_top
828:toString_skip_loop:
828#    subu $sp,8
832#    sw $s5,4($sp)
836#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
840#    lw $t2,-12($s2) # vtable address
844#    move $t0,$t2
848:toString_checkTagBit:
848#    subu $t0,1
852#    lb $t1,($t0)
856#    and $t1,0x80
857##...lui $at,0
861##...ori $at,$at,0x80
865##...and $t1,$t1,$at
868#    beq $t1,$zero,toString_checkTagBit
872#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
876#    subu $sp,8
880#    sw $t1,($sp)
884#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
888#    move $s7,$zero # -4 offset header word
892#    lw $t4,8($sp) # bytes for hash value
896#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
900#    addu $t4,8
904#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
908#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address

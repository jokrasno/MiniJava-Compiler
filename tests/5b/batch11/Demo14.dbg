3385##...and $t8,$t8,$at

3388:  gcSkip5:
3388#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3392#    addu $t8,$t8,8 # ... add in bytes for header-words
3396#    subu $t4,$t1,$t8 # address of first word of source object
3400#    lw $t3,-4($t1) # # words in positive-offset portion
3404#    bge $t3,$zero,gcNoNeg
3405##...slt $at,$t3,$zero
3409##...beq $at,$zero,3416
3412#    move $t3,$zero # negative treated as zero
3416:  gcNoNeg:
3416#    sll $t3,$t3,2 # bytes in negative-offset portion
3420#    addu $t3,$t3,$t1 # address one word past last word of source

3424#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3428#    lw $s0,($t4)
3432#    lw $t9,-8($t1)
3436#    sw $t9,($t4)
3440#    sw $s0,-8($t1)

    # copy all source bytes to the target
3444:  gCinnerCopy2:
3444#    lw $s0,($t4)
3448#    sw $s0,($s3)
3452#    addu $t4,$t4,4
3456#    addu $s3,$s3,4
3460#    bltu $t4,$t3,gCinnerCopy2
3461##...sltu $at,$t4,$t3
3465##...bne $at,$zero,3444

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3468#    sw $zero,-8($t1) # 0 in first header-slot
3472#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3476#    sw $t8,($t0)

3480:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3480#    addu $t0,$t0,4
3484#    bltu $t0,$s1,gcNextPointerInObject
3485##...sltu $at,$t0,$s1
3489##...bne $at,$zero,3328

3492:  gcTestIterDone2:
3492#    bltu $t0,$s3,gcHeapCopyLoop
3493##...sltu $at,$t0,$s3
3497##...bne $at,$zero,3212

    ###### end outer loop to copy all non-stack-direct objects ######

3500:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3500#    lw $s2,($sp)
3504#    addu $sp,$sp,4

    # mark us as having already GC'd
3508#    move $t5,$s5

    # go try and allocate again
3512#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3516:vm_init:

    # mark bottom of stack
3516#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3520#    move $s2,$zero

    #set up the "five" register
3524#    li $s5,5

3528#    la $s3,seg0_start
3532#    la $s4,seg0_end
3533##...lui $s4,16
3537##...addiu $s4,$s4,4436
    
    # return
3540#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3544:divide:
    # get parameters; abort if divisor zero
3544#    lw $t0,($sp)
3548#    lw $t1,8($sp)
3552#    beq $t0,$zero,divByZeroError
    
    # perform division
3556#    div $t1,$t0
3560#    mflo $t0

    # store result, adjust stack and return
3564#    addu $sp,$sp,8 # adjust stack
3568#    sw $t0,($sp) # store result
3572#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3576:remainder:
    # get parameters; abort if divisor zero
3576#    lw $t0,($sp)
3580#    lw $t1,8($sp)
3584#    beq $t0,$zero,divByZeroError
    
    # perform division
3588#    div $t1,$t0
3592#    mfhi $t0

    # store result, adjust stack and return
3596#    addu $sp,$sp,8 # adjust stack
3600#    sw $t0,($sp) # store result
3604#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3608:checkCast:
    # get object, allow immediately if null
3608#    lw $t2,($sp)
3612#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3616#    lw $t2,-12($t2) # vtable address
3620#    bge $t2,$t1,castException
3621##...slt $at,$t2,$t1
3625##...beq $at,$zero,3760
3628#    blt $t2,$t0,castException
3629##...slt $at,$t2,$t0
3633##...bne $at,$zero,3760
    
    # return, leaving object unchanged on stack
3636:  checkCastReturn:    
3636#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3640:instanceOf:
    # get object, go return false if null
3640#    lw $t2,($sp)
3644#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3648#    lw $t2,-12($t2) # vtable address
3652#    sge $t0,$t2,$t0 # are we >= the lower limit?
3653##...slt $t0,$t2,$t0
3657##...xori $t0,$t0,0x1
3660#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3664#    and $t2,$t0,$t1
3668#    sw $t2,($sp)
3672:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3672#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3676:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3676#    li $v0,4 # syscall-code for print-string
3680#    syscall
3684:exit:
    # print termination message
3684#    li $v0,4 # syscall-code for print-string
3688#    la $a0,exitString
3692#    syscall

    # terminate execution
3696#    li $v0,10 #syscall-code for "exit"
3700#    syscall

3704:outOfHeapMemory:
3704#    la $a0,heapMemoryMsg
3708#    j exitError
3712:divByZeroError:
3712#    la $a0,divByZeroMsg
3716#    j exitError
3720:strIndexOutOfBounds:
3720#    la $a0,strIndexOutOfBoundsMsg
3724#    j exitError
3728:arrayIndexOutOfBounds:
3728#    la $a0,arrayIndexOutOfBoundsMsg
3732#    j exitError
3736:arraySizeOutOfBounds:
3736#    la $a0,arraySizeOutOfBoundsMsg
3740#    j exitError
3744:nullPtrException:
3744#    la $a0,nullPtrExceptionMsg
3748#    j exitError
3752:badIntegerFormat:
3752#    la $a0,badIntegerFormatMsg
3756#    j exitError
3760:castException:
3760#    la $a0,castExceptionMsg
3764#    j exitError
############## data section ################
    .data
4072:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4088:cur_seg:
    .word 0

4092:lastCharRead:
    .word -2 # -2 => no buffered character
4096:prevHashConstant:
    .word 0x2785173c
4100:gcCount:
    .word 0

4104:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4131:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4154:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4189:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4223:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4256:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4287:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4335:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4356:gcMsg: 
      .asciiz "\nGC!\n"
4362:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4394:nullStr:
    .asciiz "null"
4399:trueString:
    .asciiz "true"
4404:falseString:
    .asciiz "false"
4410:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4429:newlineString:
    .asciiz "\n"
    
    .align 2
4432:stack_bottom:
    .word 0

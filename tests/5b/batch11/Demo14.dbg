2752#    addu $t0,$s6,$s7
2756#    sll $t0,$t0,2
2760#    addu $t0,$t0,8 # amount of memory needed
2764#    addu $t1,$t0,$s3
2768#    bgtu $t1,$s4,doGC
2769##...sltu $at,$s4,$t1
2773##...bne $at,$zero,2896

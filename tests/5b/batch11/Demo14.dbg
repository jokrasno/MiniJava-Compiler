
912#    li $t0,CLASS_String # store string vtable address into ...
916#    sw $t0,-12($s7) # ... -12 offset in object header
920#    lw $t2,-12($s2) # our object's vtable address
924#    lw $t5,4($sp) # number characters in prefix

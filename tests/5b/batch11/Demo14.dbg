
1492:  helpReadInt:
1492#    li $t2,10
1496#    subu $t1,$v0,'0' # convert digit to 0-9 value
1500#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1501##...sltu $at,$t1,$t2
1505##...beq $at,$zero,3752
1508#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1512:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1512#    jal readLogicalChar # read next character
1516#    subu $t1,$v0,'0' # convert digit to 0-9 value
1520#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1521##...sltu $at,$t1,$t2
1525##...beq $at,$zero,1544

1528#    mul $t3,$t3,$t2 # multiply old value by 10
1529##...mult $t3,$t2
1533##...mflo $t3
1536#    addu $t3,$t3,$t1 # add in value of new digit
1540#    j digitLoop

1544:  doneDigitLoop:

    # perform division
8500#    div $t1,$t0
8504#    mflo $t0

    # store result, adjust stack and return
8508#    addu $sp,$sp,8 # adjust stack
8512#    sw $t0,($sp) # store result
8516#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
5608:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
5608#    lw $t0,-8($s2) # get word with hash bits from this
5612#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
5616#    addu $t0,$t1

5620#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
5624:mth_equals_Object:
5624#    move $t0,$s2 # first pointer (this)
5628#    lw $t1,($sp) # second pointer
5632#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
5633##...subu $at,$t0,$t1
5637##...sltiu $t0,$at,1

5640#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
5644:mth_hashCode_String:
5644#    move $t0,$s2 # put this pointer in t0

5648#    li $t2,0 # current hash value
5652#    lw $t1,-4($t0) # negative of number of characters in string
5656#    beq $t1,$zero,done_hashCode_String # if zero length => done
5660#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
5664#    and $t0,0xfffffffc # adjust for padding
5665##...lui $at,65535
5669##...ori $at,$at,0xfffc
5673##...and $t0,$t0,$at
5676#    subu $t1,$t0,$t1 # address at end of string +12
5680:loop_hashCode_String:    
5680#    sll $t4,$t2,5 # multiply by 32
5684#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
5688#    lbu $t3,-12($t0) # current character
5692#    addu $t2,$t3 # add in current character
5696#    addu $t0,1 # go to next character's address
5700#    bne $t0,$t1,loop_hashCode_String # loop back if more
5704:done_hashCode_String:    

    # push int on stack
5704#    move $t0, $t2 # put $t2 in return slot
5708#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
5712:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
5712#    subu $sp,4
5716#    sw $ra,($sp)
    
    # get hash value
5720#    lw $t2,-12($s2) # vtable address
5724#    lw $t0,($t2) # method address
5728#    jalr $t0
5732#    subu $sp,8 # push result (int in $t0) on stack
5736#    sw $s5,4($sp)
5740#    sw $t0,($sp)

    # compute print-size of hash value
5744#    li $t0, 1
5748#    lw $t1, ($sp)
5752#    srl $t1,$t1,4
5756#    beq $t1,$zero,toString_skip_loop
5760:toString_loop_top:
5760#    addu $t0,1
5764#    srl $t1,$t1,4
5768#    bne $t1,$zero,toString_loop_top
5772:toString_skip_loop:
5772#    subu $sp,8
5776#    sw $s5,4($sp)
5780#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
5784#    lw $t2,-12($s2) # vtable address
5788#    move $t0,$t2
5792:toString_checkTagBit:
5792#    subu $t0,1
5796#    lb $t1,($t0)
5800#    and $t1,0x80
5801##...lui $at,0
5805##...ori $at,$at,0x80
5809##...and $t1,$t1,$at
5812#    beq $t1,$zero,toString_checkTagBit
5816#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
5820#    subu $sp,8
5824#    sw $t1,($sp)
5828#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
5832#    move $s7,$zero # -4 offset header word
5836#    lw $t4,8($sp) # bytes for hash value
5840#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
5844#    addu $t4,8
5848#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
5852#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

5856#    li $t0,CLASS_String # store string vtable address into ...
5860#    sw $t0,-12($s7) # ... -12 offset in object header
5864#    lw $t2,-12($s2) # our object's vtable address
5868#    lw $t5,4($sp) # number characters in prefix
5872#    lw $t1,12($sp) # number of characters in hashcode
5876#    addu $t3,$t1,$t5 # number of characters in string ...
5880#    addu $t3,1 # ... including the '@' character
5884#    subu $t0,$zero,$t3 # store negated length into ...
5888#    sw $t0,-4($s7) # ... -4 offset header word
5892#    lw $t0,-8($s7) # get -8 offset header-word
5896#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
5897##...slt $at,$t0,$zero
5901##...beq $at,$zero,5920
5904#    and $t0,0xff # mask off object's hash value ...
5905##...lui $at,0
5909##...ori $at,$at,0xff
5913##...and $t0,$t0,$at
5916#    sw $t0,-8($s7) # ... and store back into -8 header-word
5920:skipMask_toString:
5920#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
5924#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
5928#    subu $t4,$t2,$t5
5932:toString_copyLoop:    
5932#    lb $t3,($t4)
5936#    and $t3,0x7f # mask off sign bit (in case first word)
5937##...lui $at,0
5941##...ori $at,$at,0x7f
5945##...and $t3,$t3,$at
5948#    sb $t3,-8($t0)
5952#    addu $t4,1
5956#    addu $t0,1
5960#    blt $t4,$t2,toString_copyLoop
5961##...slt $at,$t4,$t2
5965##...bne $at,$zero,5932

    # copy the '@' sign
5968#    li $t3,'@'
5972#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
5976#    addu $t2,$t0,$t1 # address of last byte in string to store +8
5980#    lw $t3,20($sp) # hash code to print
5984:toString_hashCopyLoop:
5984#    and $t4,$t3,0xf
5988#    srl $t3,4
5992#    lb $t4,hexChars($t4)
5996#    sb $t4,-8($t2)
6000#    subu $t2,$t2,1
6004#    bgt $t2,$t0,toString_hashCopyLoop
6005##...slt $at,$t0,$t2
6009##...bne $at,$zero,5984

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
6012#    addu $sp,28
6016#    lw $ra,($sp)
6020#    addu $sp,4
6024#    move $t0, $s7 # return string we created
6028#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
6032:mth_equals_String:
    
    # quick test for obvious false
6032#    lw $t0,($sp) # second parameter
6036#    beq $t0,$zero,goEsFalse # go return false if null
6040#    lw $t1,-12($t0) # vtable pointer
6044#    la $t2,CLASS_String # string vtable pointer
6048#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
6052#    subu $sp,12
6056#    sw $ra,8($sp)
6060#    sw $s2,4($sp)
6064#    sw $t0,($sp)
6068#    jal mth_compareTo_String
6072#    lw $s2, 4($sp) #restore this pointer and pop parameters
6076#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
6080#    seq $t0,$t0,$zero
6081##...subu $at,$t0,$zero
6085##...sltiu $t0,$at,1

    # pop return address and return $t0
6088#    lw $ra,($sp)
6092#    addu $sp,4

6096#    jr $ra # return
    
6100:goEsFalse:
    # put 0 in $t0 and return
6100#    li $t0, 0
6104#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
6108:mth_toString_String:
    #we are a string, so return this.
6108#    move $t0, $s2
6112#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
6116:mth_readLine_Lib:
    
6116#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
6120#    sw $ra, 4($sp) # save $ra
6124#    move $t1,$sp # save "original" sp

6128:  doRead:

    # read the character
6128#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
6132#    subu $t2,$v0,13
6136#    bne $t2,$zero,notReturnRL
6140#    jal readLogicalChar
6144#    subu $t2,$v0,10 # check for newline
6148#    beq $t2,$zero,foundNewLine
6152#    sw $v0,lastCharRead # push back character into queue
6156#    j foundNewLine # go process the line

6160:  notReturnRL:

    # at this point, $v0 has our character

6160#    subu $t0,$v0,10
6164#    beq $t0,$zero,foundNewLine
6168#    blt $v0,$zero,foundEof
6169##...slt $at,$v0,$zero
6173##...bne $at,$zero,6188

    # we have a character, so push it onto stack
6176#    subu $sp,$sp,4
6180#    sw $v0,($sp)

    # loop back up to get next character
6184#    j doRead

6188:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
6188#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
6192#    li $s7, 0 # return-value: null
6196#    j rlReturn # return

6200:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
6200#    subu $t0,$t1,$sp # number of chars we read (times 4)
6204#    srl $s6,$t0,2 # number of words on stack with chars
6208#    subu $sp,$sp,4 # push char-count ...
6212#    sw $s6,($sp) # ... onto stack
6216#    addu $t2,$t0,5 # GC tag, incl. for count-word
6220#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
6224#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
6228#    srl $s6,$s6,2  # data words in object
6232#    move $s7,$zero # object words in object
6236#    jal newObject  # allocate space
    
    # store header words
6240#    la $t0,CLASS_String
6244#    sw $t0,-12($s7)# store class tag (String) into object
6248#    lw $t2,4($sp) # char-count
6252#    sll $t1,$t2,2 # 4 times number of chars
6256#    subu $t2,$zero,$t2 # negative of char-count
6260#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
6264#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
6268#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there

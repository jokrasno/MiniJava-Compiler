########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
7448:mth_intToChar_Lib:
    # save return address
7448#    subu $sp,$sp,4
7452#    sw $ra,($sp)

    # allocate object
7456#    li $s6,2
7460#    move $s7,$zero
7464#    jal newObject

    # get n from string.
7468#    lw $t1,8($sp)

    # store "String" tag into class field
7472#    la $t0,CLASS_String
7476#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
7480#    lw $t4,-8($s7) # # data words in source string
7484#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
7485##...slt $at,$t4,$zero
7489##...beq $at,$zero,7508
7492#    and $t4,0xff # mask off object's hash value ...
7493##...lui $at,0
7497##...ori $at,$at,0xff
7501##...and $t4,$t4,$at
7504#    sw $t4,-8($s7) # ... and store back into -8 header-word
7508:  skipMask_intToChar:

    # store data in string
7508#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
7512#    li $t0,-1
7516#    sw $t0,-4($s7)

    # we're returning $s7
7520#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
7524#    lw $ra,4($sp)
7528#    addu $sp,$sp,8

    # return
7532#    jr $ra

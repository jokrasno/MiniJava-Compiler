########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
7204:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
7204#    subu $sp,$sp,8
7208#    sw $ra,4($sp)

    # save current sp
7212#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
7216#    li $t3,10

    # get argument, negate if negative
7220#    lw $t1,8($sp)
7224#    bge $t1,$zero,itsNonNegLoop
7225##...slt $at,$t1,$zero
7229##...beq $at,$zero,7236
7232#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
7236:  itsNonNegLoop:
7236#    divu $t1,$t3
7240#    mflo $t1 # quotient
7244#    mfhi $t4 # remainder
7248#    addu $t4,$t4,'0' # turn remainder into digit
7252#    subu $sp,$sp,4
7256#    sw $t4,($sp) # push digit onto stack
7260#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
7264#    lw $t4,8($t0)
7268#    bge $t4,$zero,itsSkipNeg
7269##...slt $at,$t4,$zero
7273##...beq $at,$zero,7288
7276#    li $t4,'-'
7280#    subu $sp,$sp,4
7284#    sw $t4,($sp)
7288:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
7288#    subu $s6,$t0,$sp
7292#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
7296#    sw $t3,($t0)
7300#    srl $s6,$s6,2
7304#    subu $sp,$sp,4
7308#    sw $s6,($sp)
    
    # allocate memory
7312#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
7316#    srl $s6,$s6,2
7320#    move $s7,$zero # no "object" words in object
7324#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
7328#    lw $t0,4($sp)
7332#    addu $sp,$sp,8

    # store "String" tag into class field
7336#    subu $s7,$s7,8 # address of header-1 word
7340#    la $t1,CLASS_String
7344#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
7348#    lw $t4,($s7) # # data words in source string
7352#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
7353##...slt $at,$t4,$zero
7357##...beq $at,$zero,7376
7360#    and $t4,0xff # mask off object's hash value ...
7361##...lui $at,0
7365##...ori $at,$at,0xff
7369##...and $t4,$t4,$at
7372#    sw $t4,($s7) # ... and store back into -8 header-word
7376:skipMask_intToString:
    
    # store negative of char-count into header-2 word
7376#    subu $t0,$zero,$t0
7380#    sw $t0,4($s7)

7384#    lw $t1,($s7) # number of data words in string
7388#    sll $t1,$t1,2 # number data bytes in string
7392#    subu $t1,$s7,$t1 # first location to store chars in string
7396#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
7400:  itsLoop:
7400#    lw $t2,($sp)
7404#    addu $sp,$sp,4
7408#    sb $t2,($t1)
7412#    addu $t1,$t1,1
7416#    bne $t1,$t0,itsLoop

    ####################################################
    # At this point
    # - ($t0+15)&0xfffffffe is our return value
    # - ($sp) contains garbage (old GC tag)
    # - 4($sp) contains return address
    ####################################################

    # adjust stack, restore return address; return
7420#    lw $ra,4($sp)
7424#    addu $sp,$sp,8
7428#    addu $t0,$t0,15
7432#    and $t0,$t0,0xfffffffc
7433##...lui $at,65535
7437##...ori $at,$at,0xfffc
7441##...and $t0,$t0,$at
7444#    jr $ra

6380#    subu $t0,$v0,10
6384#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
6388#    subu $t0,$v0,9
6392#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
6396#    subu $t0,$v0,13
6400#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
6404#    subu $t0,$v0,12
6408#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
6412#    j badIntegerFormat # illegal integer char: abort program

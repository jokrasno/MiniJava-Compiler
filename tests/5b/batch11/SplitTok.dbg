8616:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
8616#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

8620:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
8620#    li $v0,4 # syscall-code for print-string
8624#    syscall
8628:exit:
    # print termination message
8628#    li $v0,4 # syscall-code for print-string
8632#    la $a0,exitString
8636#    syscall

    # terminate execution
8640#    li $v0,10 #syscall-code for "exit"
8644#    syscall

8648:outOfHeapMemory:
8648#    la $a0,heapMemoryMsg
8652#    j exitError
8656:divByZeroError:
8656#    la $a0,divByZeroMsg
8660#    j exitError
8664:strIndexOutOfBounds:
8664#    la $a0,strIndexOutOfBoundsMsg
8668#    j exitError
8672:arrayIndexOutOfBounds:
8672#    la $a0,arrayIndexOutOfBoundsMsg
8676#    j exitError
8680:arraySizeOutOfBounds:
8680#    la $a0,arraySizeOutOfBoundsMsg
8684#    j exitError
8688:nullPtrException:
8688#    la $a0,nullPtrExceptionMsg
8692#    j exitError
8696:badIntegerFormat:
8696#    la $a0,badIntegerFormatMsg
8700#    j exitError
8704:castException:
8704#    la $a0,castExceptionMsg
8708#    j exitError
############## data section ################
    .data
8992:hexChars:
    .ascii "0123456789abcdef"
    .align 2
9008:cur_seg:
    .word 0

9012:lastCharRead:
    .word -2 # -2 => no buffered character
9016:prevHashConstant:
    .word 0x2785173c
9020:gcCount:
    .word 0

9024:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
9051:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
9074:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
9109:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
9143:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
9176:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
9207:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
9255:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
9276:gcMsg: 
      .asciiz "\nGC!\n"
9282:gcCountMsg: 
      .asciiz "Number of garbage collections: "

9314:nullStr:
    .asciiz "null"
9319:trueString:
    .asciiz "true"
9324:falseString:
    .asciiz "false"
9330:exitString:
    .ascii "Program terminated."
    #### "falls through" here
9349:newlineString:
    .asciiz "\n"
    
    .align 2
9352:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

9356:seg0_start:
    .space 0x100000
1057932:seg0_end:
1057932:seg1_start:
    .space 0x100000
2106508:seg1_end:

    # access element
7180#    lw $t1,-8($t0) # # data words in object
7184#    sll $t1,$t1,2 # - byte-offset from end of chars
7188#    subu $t1,$t2,$t1 # - address of first char in string, offset by 8
7192#    addu $t0,$t0,$t1 # - address of our char, offset by 8
7196#    lb $t0,-8($t0) # our char

    # return
7200#    jr $ra

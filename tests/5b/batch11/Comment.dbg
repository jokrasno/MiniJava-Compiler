    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
5296#    lw $t1,cur_seg
5300#    la $t0,seg0_start
5304#    beq $t1,$zero,gcSkip4
5308#    la $t0,seg1_start
5309##...lui $t0,16
5313##...addiu $t0,$t0,6628


5316:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
5316#    bgeu $t0,$s3,gcFinishUp
5317##...sltu $at,$t0,$s3
5321##...beq $at,$zero,5612

    ###### begin outer loop to copy all non-stack-direct objects ######

5324:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
5324#    lw $t1,($t0) # (what will be) first header word for current object
5328#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
5332#    bge $t2,$zero,gcSkip4a # are there hash bits?
5333##...slt $at,$t2,$zero
5337##...beq $at,$zero,5352
5340#    and $t2,0xff # mask off hash bits
5341##...lui $at,0
5345##...ori $at,$at,0xff
5349##...and $t2,$t2,$at
5352:gcSkip4a:    
5352#    sll $t2,$t2,2 # # data bytes
5356#    addu $t2,$t2,8 # to skip header words
5360#    addu $t2,$t0,$t2 # pointer to new object
5364#    lw $t3,-8($t2) # word to swap
5368#    sw $t1,-8($t2) # store header word
5372#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
5376#    lw $t1,-12($t2) # vtable pointer
5380#    li $t0,dataArrayVTableStart # address of vtable for first data array
5384#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
5385##...slt $at,$t1,$t0
5389##...bne $at,$zero,5408

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
5392:  skipToNextObj:
5392#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
5396#    sll $t1,$t1,2 # convert to byte-count
5400#    addu $t0,$t2,$t1 # skip over object
5404#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
5408:  gcNotDataArray:
5408#    lw $t3,-4($t2) # # object words (negative treated as zero)
5412#    bge $t3,$zero,gcH2Neg2
5413##...slt $at,$t3,$zero
5417##...beq $at,$zero,5424
5420#    move $t3,$zero
5424:  gcH2Neg2:
5424#    sll $t3,$t3,2 # # object bytes
5428#    move $t0,$t2 # address of first pointer in object
5432#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
5436#    beq $t0,$s1,gcTestIterDone2
    
5440:  gcNextPointerInObject:
    # get pointer from object
5440#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
5444#    bleu $t1,$t6,gcGoNextPointerSlot
5445##...sltu $at,$t6,$t1
5449##...beq $at,$zero,5592
5452#    bgtu $t1,$t7,gcGoNextPointerSlot
5453##...sltu $at,$t7,$t1
5457##...bne $at,$zero,5592

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
5460#    lw $t8,-8($t1) # possible forwarding tag
5464#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
5468#    lw $t8,-4($t1) # forwarding pointer: object's new address
5472#    sw $t8,($t0) # update pointer in object
5476#    j gcGoNextPointerSlot # do next iteration

5480:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
5480#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
5481##...slt $at,$t8,$zero
5485##...beq $at,$zero,5500
5488#    and $t8,0xff # mask off hash bits
5489##...lui $at,0
5493##...ori $at,$at,0xff
5497##...and $t8,$t8,$at

5500:  gcSkip5:
5500#    sll $t8,$t8,2 # bytes in negative-offset portion ...
5504#    addu $t8,$t8,8 # ... add in bytes for header-words
5508#    subu $t4,$t1,$t8 # address of first word of source object
5512#    lw $t3,-4($t1) # # words in positive-offset portion
5516#    bge $t3,$zero,gcNoNeg
5517##...slt $at,$t3,$zero
5521##...beq $at,$zero,5528
5524#    move $t3,$zero # negative treated as zero
5528:  gcNoNeg:
5528#    sll $t3,$t3,2 # bytes in negative-offset portion
5532#    addu $t3,$t3,$t1 # address one word past last word of source

5536#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
5540#    lw $s0,($t4)
5544#    lw $t9,-8($t1)
5548#    sw $t9,($t4)
5552#    sw $s0,-8($t1)

    # copy all source bytes to the target
5556:  gCinnerCopy2:
5556#    lw $s0,($t4)
5560#    sw $s0,($s3)
5564#    addu $t4,$t4,4
5568#    addu $s3,$s3,4
5572#    bltu $t4,$t3,gCinnerCopy2
5573##...sltu $at,$t4,$t3
5577##...bne $at,$zero,5556

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
5580#    sw $zero,-8($t1) # 0 in first header-slot
5584#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
5588#    sw $t8,($t0)

5592:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
5592#    addu $t0,$t0,4
5596#    bltu $t0,$s1,gcNextPointerInObject
5597##...sltu $at,$t0,$s1
5601##...bne $at,$zero,5440

5604:  gcTestIterDone2:
5604#    bltu $t0,$s3,gcHeapCopyLoop
5605##...sltu $at,$t0,$s3
5609##...bne $at,$zero,5324

    ###### end outer loop to copy all non-stack-direct objects ######

5612:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
5612#    lw $s2,($sp)
5616#    addu $sp,$sp,4

    # mark us as having already GC'd
5620#    move $t5,$s5

    # go try and allocate again
5624#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
5628:vm_init:

    # mark bottom of stack
5628#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
5632#    move $s2,$zero

    #set up the "five" register
5636#    li $s5,5

5640#    la $s3,seg0_start
5644#    la $s4,seg0_end
5645##...lui $s4,16
5649##...addiu $s4,$s4,6628
    
    # return
5652#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5656:divide:
    # get parameters; abort if divisor zero
5656#    lw $t0,($sp)
5660#    lw $t1,8($sp)
5664#    beq $t0,$zero,divByZeroError
    
    # perform division
5668#    div $t1,$t0
5672#    mflo $t0

    # store result, adjust stack and return
5676#    addu $sp,$sp,8 # adjust stack
5680#    sw $t0,($sp) # store result
5684#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5688:remainder:
    # get parameters; abort if divisor zero
5688#    lw $t0,($sp)
5692#    lw $t1,8($sp)
5696#    beq $t0,$zero,divByZeroError
    
    # perform division
5700#    div $t1,$t0
5704#    mfhi $t0

    # store result, adjust stack and return
5708#    addu $sp,$sp,8 # adjust stack
5712#    sw $t0,($sp) # store result
5716#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
5720:checkCast:
    # get object, allow immediately if null
5720#    lw $t2,($sp)
5724#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
5728#    lw $t2,-12($t2) # vtable address
5732#    bge $t2,$t1,castException
5733##...slt $at,$t2,$t1
5737##...beq $at,$zero,5872
5740#    blt $t2,$t0,castException
5741##...slt $at,$t2,$t0
5745##...bne $at,$zero,5872
    
    # return, leaving object unchanged on stack
5748:  checkCastReturn:    
5748#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
5752:instanceOf:
    # get object, go return false if null
5752#    lw $t2,($sp)
5756#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
5760#    lw $t2,-12($t2) # vtable address
5764#    sge $t0,$t2,$t0 # are we >= the lower limit?
5765##...slt $t0,$t2,$t0
5769##...xori $t0,$t0,0x1
5772#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
5776#    and $t2,$t0,$t1
5780#    sw $t2,($sp)
5784:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
5784#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

5788:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
5788#    li $v0,4 # syscall-code for print-string
5792#    syscall
5796:exit:
    # print termination message
5796#    li $v0,4 # syscall-code for print-string
5800#    la $a0,exitString
5804#    syscall

    # terminate execution
5808#    li $v0,10 #syscall-code for "exit"
5812#    syscall

5816:outOfHeapMemory:
5816#    la $a0,heapMemoryMsg
5820#    j exitError
5824:divByZeroError:
5824#    la $a0,divByZeroMsg
5828#    j exitError
5832:strIndexOutOfBounds:
5832#    la $a0,strIndexOutOfBoundsMsg
5836#    j exitError
5840:arrayIndexOutOfBounds:
5840#    la $a0,arrayIndexOutOfBoundsMsg
5844#    j exitError
5848:arraySizeOutOfBounds:
5848#    la $a0,arraySizeOutOfBoundsMsg
5852#    j exitError
5856:nullPtrException:
5856#    la $a0,nullPtrExceptionMsg
5860#    j exitError
5864:badIntegerFormat:
5864#    la $a0,badIntegerFormatMsg
5868#    j exitError
5872:castException:
5872#    la $a0,castExceptionMsg
5876#    j exitError
############## data section ################
    .data
6264:hexChars:
    .ascii "0123456789abcdef"
    .align 2
6280:cur_seg:
    .word 0

6284:lastCharRead:
    .word -2 # -2 => no buffered character
6288:prevHashConstant:
    .word 0x2785173c
6292:gcCount:
    .word 0

6296:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
6323:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
6346:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
6381:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
6415:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
6448:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
6479:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
6527:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
6548:gcMsg: 
      .asciiz "\nGC!\n"
6554:gcCountMsg: 
      .asciiz "Number of garbage collections: "

6586:nullStr:
    .asciiz "null"
6591:trueString:
    .asciiz "true"
6596:falseString:
    .asciiz "false"
6602:exitString:
    .ascii "Program terminated."
    #### "falls through" here
6621:newlineString:
    .asciiz "\n"
    
    .align 2
6624:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

6628:seg0_start:
    .space 0x100000
1055204:seg0_end:
1055204:seg1_start:
    .space 0x100000
2103780:seg1_end:

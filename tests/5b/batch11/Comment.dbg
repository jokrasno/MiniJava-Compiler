    # get begin-of-string addresses
4736#    lw $t2,-8($t0) # # data words in second string
4740#    lw $t3,-8($t1) # # data words in first string
4744#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
4748#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
4752#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
4756#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2

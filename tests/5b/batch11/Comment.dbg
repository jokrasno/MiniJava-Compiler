##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2776:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
2776#    lw $t0,-8($s2) # get word with hash bits from this
2780#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
2784#    addu $t0,$t1

2788#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2792:mth_equals_Object:
2792#    move $t0,$s2 # first pointer (this)
2796#    lw $t1,($sp) # second pointer
2800#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
2801##...subu $at,$t0,$t1
2805##...sltiu $t0,$at,1

2808#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2812:mth_hashCode_String:
2812#    move $t0,$s2 # put this pointer in t0

2816#    li $t2,0 # current hash value
2820#    lw $t1,-4($t0) # negative of number of characters in string
2824#    beq $t1,$zero,done_hashCode_String # if zero length => done
2828#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
2832#    and $t0,0xfffffffc # adjust for padding
2833##...lui $at,65535
2837##...ori $at,$at,0xfffc
2841##...and $t0,$t0,$at
2844#    subu $t1,$t0,$t1 # address at end of string +12
2848:loop_hashCode_String:    
2848#    sll $t4,$t2,5 # multiply by 32
2852#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
2856#    lbu $t3,-12($t0) # current character
2860#    addu $t2,$t3 # add in current character
2864#    addu $t0,1 # go to next character's address
2868#    bne $t0,$t1,loop_hashCode_String # loop back if more
2872:done_hashCode_String:    

    # push int on stack
2872#    move $t0, $t2 # put $t2 in return slot
2876#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
2880:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
2880#    subu $sp,4
2884#    sw $ra,($sp)
    
    # get hash value
2888#    lw $t2,-12($s2) # vtable address
2892#    lw $t0,($t2) # method address
2896#    jalr $t0
2900#    subu $sp,8 # push result (int in $t0) on stack
2904#    sw $s5,4($sp)
2908#    sw $t0,($sp)

    # compute print-size of hash value
2912#    li $t0, 1
2916#    lw $t1, ($sp)
2920#    srl $t1,$t1,4
2924#    beq $t1,$zero,toString_skip_loop
2928:toString_loop_top:
2928#    addu $t0,1
2932#    srl $t1,$t1,4
2936#    bne $t1,$zero,toString_loop_top
2940:toString_skip_loop:
2940#    subu $sp,8
2944#    sw $s5,4($sp)
2948#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
2952#    lw $t2,-12($s2) # vtable address
2956#    move $t0,$t2
2960:toString_checkTagBit:
2960#    subu $t0,1
2964#    lb $t1,($t0)
2968#    and $t1,0x80
2969##...lui $at,0
2973##...ori $at,$at,0x80
2977##...and $t1,$t1,$at
2980#    beq $t1,$zero,toString_checkTagBit
2984#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
2988#    subu $sp,8
2992#    sw $t1,($sp)
2996#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
3000#    move $s7,$zero # -4 offset header word
3004#    lw $t4,8($sp) # bytes for hash value
3008#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
3012#    addu $t4,8
3016#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
3020#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

3024#    li $t0,CLASS_String # store string vtable address into ...
3028#    sw $t0,-12($s7) # ... -12 offset in object header
3032#    lw $t2,-12($s2) # our object's vtable address
3036#    lw $t5,4($sp) # number characters in prefix
3040#    lw $t1,12($sp) # number of characters in hashcode
3044#    addu $t3,$t1,$t5 # number of characters in string ...
3048#    addu $t3,1 # ... including the '@' character
3052#    subu $t0,$zero,$t3 # store negated length into ...
3056#    sw $t0,-4($s7) # ... -4 offset header word
3060#    lw $t0,-8($s7) # get -8 offset header-word
3064#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
3065##...slt $at,$t0,$zero
3069##...beq $at,$zero,3088
3072#    and $t0,0xff # mask off object's hash value ...
3073##...lui $at,0
3077##...ori $at,$at,0xff
3081##...and $t0,$t0,$at
3084#    sw $t0,-8($s7) # ... and store back into -8 header-word
3088:skipMask_toString:
3088#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
3092#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
3096#    subu $t4,$t2,$t5
3100:toString_copyLoop:    
3100#    lb $t3,($t4)
3104#    and $t3,0x7f # mask off sign bit (in case first word)
3105##...lui $at,0
3109##...ori $at,$at,0x7f
3113##...and $t3,$t3,$at
3116#    sb $t3,-8($t0)
3120#    addu $t4,1
3124#    addu $t0,1
3128#    blt $t4,$t2,toString_copyLoop
3129##...slt $at,$t4,$t2
3133##...bne $at,$zero,3100

    # copy the '@' sign
3136#    li $t3,'@'
3140#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
3144#    addu $t2,$t0,$t1 # address of last byte in string to store +8
3148#    lw $t3,20($sp) # hash code to print
3152:toString_hashCopyLoop:
3152#    and $t4,$t3,0xf
3156#    srl $t3,4
3160#    lb $t4,hexChars($t4)
3164#    sb $t4,-8($t2)
3168#    subu $t2,$t2,1
3172#    bgt $t2,$t0,toString_hashCopyLoop
3173##...slt $at,$t0,$t2
3177##...bne $at,$zero,3152

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
3180#    addu $sp,28
3184#    lw $ra,($sp)
3188#    addu $sp,4
3192#    move $t0, $s7 # return string we created
3196#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
3200:mth_equals_String:
    
    # quick test for obvious false
3200#    lw $t0,($sp) # second parameter
3204#    beq $t0,$zero,goEsFalse # go return false if null
3208#    lw $t1,-12($t0) # vtable pointer
3212#    la $t2,CLASS_String # string vtable pointer
3216#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
3220#    subu $sp,12
3224#    sw $ra,8($sp)
3228#    sw $s2,4($sp)
3232#    sw $t0,($sp)
3236#    jal mth_compareTo_String
3240#    lw $s2, 4($sp) #restore this pointer and pop parameters
3244#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
3248#    seq $t0,$t0,$zero
3249##...subu $at,$t0,$zero
3253##...sltiu $t0,$at,1

    # pop return address and return $t0
3256#    lw $ra,($sp)
3260#    addu $sp,4

3264#    jr $ra # return
    
3268:goEsFalse:
    # put 0 in $t0 and return
3268#    li $t0, 0
3272#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
3276:mth_toString_String:
    #we are a string, so return this.
3276#    move $t0, $s2
3280#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
3284:mth_readLine_Lib:
    
3284#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
3288#    sw $ra, 4($sp) # save $ra
3292#    move $t1,$sp # save "original" sp

3296:  doRead:

    # read the character
3296#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
3300#    subu $t2,$v0,13
3304#    bne $t2,$zero,notReturnRL
3308#    jal readLogicalChar
3312#    subu $t2,$v0,10 # check for newline
3316#    beq $t2,$zero,foundNewLine
3320#    sw $v0,lastCharRead # push back character into queue
3324#    j foundNewLine # go process the line

3328:  notReturnRL:

    # at this point, $v0 has our character

3328#    subu $t0,$v0,10
3332#    beq $t0,$zero,foundNewLine
3336#    blt $v0,$zero,foundEof
3337##...slt $at,$v0,$zero
3341##...bne $at,$zero,3356

    # we have a character, so push it onto stack
3344#    subu $sp,$sp,4
3348#    sw $v0,($sp)

    # loop back up to get next character
3352#    j doRead

3356:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
3356#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
3360#    li $s7, 0 # return-value: null
3364#    j rlReturn # return

3368:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
3368#    subu $t0,$t1,$sp # number of chars we read (times 4)
3372#    srl $s6,$t0,2 # number of words on stack with chars
3376#    subu $sp,$sp,4 # push char-count ...
3380#    sw $s6,($sp) # ... onto stack
3384#    addu $t2,$t0,5 # GC tag, incl. for count-word
3388#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
3392#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
3396#    srl $s6,$s6,2  # data words in object
3400#    move $s7,$zero # object words in object
3404#    jal newObject  # allocate space
    
    # store header words
3408#    la $t0,CLASS_String
3412#    sw $t0,-12($s7)# store class tag (String) into object
3416#    lw $t2,4($sp) # char-count
3420#    sll $t1,$t2,2 # 4 times number of chars
3424#    subu $t2,$zero,$t2 # negative of char-count
3428#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3432#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3436#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3437##...slt $at,$t0,$zero
3441##...beq $at,$zero,3460
3444#    and $t0,0xff # mask off object's hash value ...
3445##...lui $at,0
3449##...ori $at,$at,0xff
3453##...and $t0,$t0,$at
3456#    sw $t0,-8($s7) # ... and store back into -8 header-word
3460:  skipMask_readLine:

3460#    sll $t0,$t0,2 # data bytes in object
3464#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
3468#    subu $t0,$t0,$t2 # place to store last character (plus 9)
3472#    addu $sp,$sp,8 # pop redundant object-pointer and count
3476#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

3480#    beq $sp,$t1,rlReturn
3484:  charCopyLoop:
3484#    lw $t2,($sp)
3488#    sb $t2,-9($t0)
3492#    addu $sp,$sp,4
3496#    subu $t0,$t0,1
3500#    bne $sp,$t1,charCopyLoop
3504:  rlReturn:

3504#    lw $ra, 4($sp)
3508#    addu $sp, 8   # pop $ra and pointless word off stack
3512#    move $t0, $s7 # return string we allocated in $s7
3516#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3520:mth_readInt_Lib:

    # save $ra by pushing onto stack
3520#    subu $sp,$sp,4
3524#    sw $ra,($sp)

3528:  riSkipWhiteLoop:
    # read a character
3528#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
3532#    subu $t0,$v0,32
3536#    bgt $t0,$zero,nonWhite
3537##...slt $at,$zero,$t0
3541##...bne $at,$zero,3584
3544#    beq $t0,$zero,riSkipWhiteLoop # start over if space
3548#    subu $t0,$v0,10
3552#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
3556#    subu $t0,$v0,9
3560#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
3564#    subu $t0,$v0,13
3568#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
3572#    subu $t0,$v0,12
3576#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
3580#    j badIntegerFormat # illegal integer char: abort program

3584:  nonWhite:
3584#    subu $t0,$v0,'-'
3588#    li $t4,1 # final multiplier
3592#    bne $t0,$zero,helpReadInt # go read
3596#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
3600#    jal readLogicalChar

3604:  helpReadInt:
3604#    li $t2,10
3608#    subu $t1,$v0,'0' # convert digit to 0-9 value
3612#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
3613##...sltu $at,$t1,$t2
3617##...beq $at,$zero,5864
3620#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

3624:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

3624#    jal readLogicalChar # read next character
3628#    subu $t1,$v0,'0' # convert digit to 0-9 value
3632#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
3633##...sltu $at,$t1,$t2
3637##...beq $at,$zero,3656

3640#    mul $t3,$t3,$t2 # multiply old value by 10
3641##...mult $t3,$t2
3645##...mflo $t3
3648#    addu $t3,$t3,$t1 # add in value of new digit
3652#    j digitLoop

3656:  doneDigitLoop:

    # "push back" unused character into queue
3656#    sw $v0,lastCharRead

    # restore return address
3660#    lw $ra,($sp)
3664#    addu $sp, 4

    # multiply by sign and put return value in $t0
3668#    mult $t3,$t4 # multiply to account for poss. minus sign
3672#    mflo $t3
3676#    move $t0, $t3
    
    # return
3680#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3684:mth_readChar_Lib:

    # save $ra by pushing onto stack
3684#    subu $sp,$sp,4

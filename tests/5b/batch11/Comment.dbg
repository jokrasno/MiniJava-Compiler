    # store data in string
4676#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
4680#    li $t0,-1
4684#    sw $t0,-4($s7)

    # we're returning $s7
4688#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
4692#    lw $ra,4($sp)
4696#    addu $sp,$sp,8

    # return
4700#    jr $ra

########################################################
# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
18528:mth_compareTo_String:
    # get string pointers and check parameter for null
18528#    lw $t0,($sp) # second string
18532#    beq $t0,$zero,nullPtrException
18536#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
18540#    lw $t2,-4($t0) # negative length of second string
18544#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
18548#    slt $t4,$t3,$t2
18552#    slt $t5,$t2,$t3
18556#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
18560#    lw $t2,-8($t0) # # data words in second string
18564#    lw $t3,-8($t1) # # data words in first string
18568#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
18572#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
18576#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
18580#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
18584#    beq $zero,$t5,skipStrCmpLenzz
18588#    move $t2,$t3
18592:  skipStrCmpLenzz:
18592#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
18596:  cmpLoopzz:
18596#    lw $t3,-8($t1) # word from str2
18600#    lw $t4,-8($t0) # word from str1
18604#    bne $t3,$t4,cmpNotEqualzz
18608#    addu $t1,$t1,4
18612#    addu $t0,$t0,4
18616#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
18620#    j cmpHitLimitzz

18624:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
18624#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
18628#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
18632#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
18636:  cmpHitLimitzz:
18636#    move $t0, $t5 # store return value
18640#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
18644:readLogicalChar:

    # check if we already have a character
18644#    lw $v0,lastCharRead
18648#    li $t0,-2
18652#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
18656#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
18660#    jr $ra # return
    
18664:  doReadCh:
    # we need to actually read a character: read and return
18664#    li $v0,12 # use system call to read a character
18668#    syscall
18672#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
18676:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
18676#    blt $s7,$zero arraySizeOutOfBounds
18677##...slt $at,$s7,$zero
18681##...bne $at,$zero,19672

    # mark the fact that we have not yet GC'd for this allocation
18684#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

18688:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
18688#    addu $t0,$s6,$s7
18692#    sll $t0,$t0,2
18696#    addu $t0,$t0,8 # amount of memory needed
18700#    addu $t1,$t0,$s3
18704#    bgtu $t1,$s4,doGC
18705##...sltu $at,$s4,$t1
18709##...bne $at,$zero,18832

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
18712#    move $t2,$s3
18716:  zeroObjLoop:
18716#    sw $zero,($s3)
18720#    lw $zero,($s3)

18724#    addu $s3,4
18728#    bltu $s3,$t1,zeroObjLoop
18729##...sltu $at,$s3,$t1
18733##...bne $at,$zero,18716

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
18736#    sll $t0,$s7,2    # number of post-header bytes
18740#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
18744#    li $t2,255
18748#    bgeu $s6,$t2 firstHeaderLarge
18749##...sltu $at,$s6,$t2
18753##...beq $at,$zero,18800
18756#    lw $t1,prevHashConstant
18760#    addu $t1,0x12b68fd2
18761##...lui $at,4791
18765##...addiu $at,$at,-28718
18769##...addu $t1,$at,$t1
18772#    sw $t1,prevHashConstant # update hash constant
18776#    or $t1,0x80000000 # set top bit
18777##...lui $at,32768
18781##...or $t1,$at,$t1
18784#    and $t1,0xffffff00 # clear low bit
18785##...lui $at,65535
18789##...ori $at,$at,0xff00
18793##...and $t1,$t1,$at
18796#    or $s6,$t1
18800:firstHeaderLarge:
18800#    sw $s6,-8($t0) # store header-1 value
18804#    lw $zero,-8($t0)

    # store second header-value
18808#    sw $s7,-4($t0)   # second header-word
18812#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
18816#    move $s7,$t0
18820#    subu $sp,$sp,4
18824#    sw $t0,($sp)

18828#    jr $ra
    
18832:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
18832#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
18836#    lw $t5,gcCount
18840#    addu $t5,1
18844#    sw $t5,gcCount

    # save $s2 (our only rooted register) on the stack
    # so that the garbage collector processes it
18848#    subu $sp,$sp,4
18852#    sw $s2,($sp)

    # set $s3 to the address of the new segment and the
    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
18856#    lw $t0,cur_seg
18860#    move $t7,$s4
18864#    la $t6,seg1_start
18865##...lui $t6,16
18869##...addiu $t6,$t6,20400
18872#    la $s3,seg0_start
18876#    la $s4,seg0_end
18877##...lui $s4,16
18881##...addiu $s4,$s4,20400
18884#    sw $zero,cur_seg
18888#    bne $t0,$zero,skipGc1
18892#    la $t6,seg0_start
18896#    la $s3,seg1_start
18897##...lui $s3,16
18901##...addiu $s3,$s3,20400
18904#    la $s4,seg1_end
18905##...lui $s4,32
18909##...addiu $s4,$s4,20400
18912#    sw $s5,cur_seg
18916:  skipGc1:
18916#    li $t5,0x80000000
18920#    lw $t0,stack_bottom
18924#    subu $t0,4


    ###############################################################
    # at this point:
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first address of the target space
    # - $s4 contains the limit address of the target space
    # - cur_seg has been updated to refer to the target space
    # - $t0 contains the address of the deepest stack element
    # - $sp contains the address of the top stack element
    # - $s2 is available for use, having been pushed onto the stack
    # - $t5 contains the value 0x80000000
    ###############################################################

    ###### begin outer loop to copy all stack-direct objects ######

18928:  gcStackCopyLoop:
18928#    lw $t1,($t0) # current stack element

    # test if we have a GC tag
18932#    sll $t2,$t1,31 # zero iff low bit was zero
18936#    bne $t2,$zero,gcBump # go skip data values if low bit not zero

    # bump stack-address pointer
18940#    subu $t0,$t0,4

    # if value is out of range (which includes null=0), and is
    # therefore does not refer to an object on the heap, just go
    # loop back and do the next one
18944#    bleu $t1,$t6,gcTestIterDone1
18945##...sltu $at,$t6,$t1
18949##...beq $at,$zero,19112
18952#    bgtu $t1,$t7,gcTestIterDone1
18953##...sltu $at,$t7,$t1
18957##...bne $at,$zero,19112

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
18960#    lw $t2,-8($t1) # possible forwarding tag
18964#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
18968#    lw $t2,-4($t1) # forwarding pointer: object's new address
18972#    sw $t2,4($t0) # update stack value
18976#    j gcTestIterDone1 # do next iteration

18980:  gcNoForward1:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    # compute the amount of space that is needed
18980#    bge $t2,$zero,gcSkip2
18981##...slt $at,$t2,$zero
18985##...beq $at,$zero,19000
18988#    and $t2,0xff #### mask off hash value
18989##...lui $at,0
18993##...ori $at,$at,0xff
18997##...and $t2,$t2,$at
    #### OLD
    #### subu $t2,$zero,$t2 # set to 1 if -1 (number of data words)

19000:  gcSkip2:
19000#    sll $t2,$t2,2
19004#    addu $t2,$t2,8
19008#    subu $t4,$t1,$t2 # address of first word of source
19012#    lw $t3,-4($t1) # number of object words (negative means zero)
19016#    bge $t3,$zero,gcH2Neg1
19017##...slt $at,$t3,$zero
19021##...beq $at,$zero,19028
19024#    move $t3,$zero
19028:  gcH2Neg1:
19028#    sll $t3,$t3,2
19032#    addu $t3,$t3,$t1 # address one word past last word of source

19036#    addu $t2,$s3,$t2 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object (i.e., the address just beyond the object's header)
    # - $t2 contains the pointer to the target object
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0-2
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger" in the target space
19040#    lw $s0,($t4)
19044#    lw $s1,-8($t1)
19048#    sw $s1,($t4)
19052#    sw $s0,-8($t1)
    
    # copy all source bytes to the target
19056:  gCinnerCopy1:
19056#    lw $s0,($t4)
19060#    sw $s0,($s3)
19064#    addu $t4,$t4,4
19068#    addu $s3,$s3,4
19072#    bltu $t4,$t3,gCinnerCopy1
19073##...sltu $at,$t4,$t3
19077##...bne $at,$zero,19056

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
19080#    sw $zero,-8($t1) # 0 in first header-slot
19084#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
19088#    sw $t2,4($t0)
19092#    lw $zero,-8($t2)
19096#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
19100#    j gcTestIterDone1

19104:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
19104#    subu $t0,$t0,$t1
19108#    subu $t0,$t0,3

19112:  gcTestIterDone1:
19112#    bgeu $t0,$sp,gcStackCopyLoop
19113##...sltu $at,$t0,$sp
19117##...beq $at,$zero,18928

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
19120#    lw $t1,cur_seg
19124#    la $t0,seg0_start
19128#    beq $t1,$zero,gcSkip4
19132#    la $t0,seg1_start
19133##...lui $t0,16
19137##...addiu $t0,$t0,20400


19140:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
19140#    bgeu $t0,$s3,gcFinishUp
19141##...sltu $at,$t0,$s3
19145##...beq $at,$zero,19436

    ###### begin outer loop to copy all non-stack-direct objects ######

19148:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
19148#    lw $t1,($t0) # (what will be) first header word for current object
19152#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
19156#    bge $t2,$zero,gcSkip4a # are there hash bits?
19157##...slt $at,$t2,$zero
19161##...beq $at,$zero,19176
19164#    and $t2,0xff # mask off hash bits
19165##...lui $at,0
19169##...ori $at,$at,0xff
19173##...and $t2,$t2,$at
19176:gcSkip4a:    
19176#    sll $t2,$t2,2 # # data bytes
19180#    addu $t2,$t2,8 # to skip header words
19184#    addu $t2,$t0,$t2 # pointer to new object
19188#    lw $t3,-8($t2) # word to swap
19192#    sw $t1,-8($t2) # store header word
19196#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
19200#    lw $t1,-12($t2) # vtable pointer
19204#    li $t0,dataArrayVTableStart # address of vtable for first data array
19208#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
19209##...slt $at,$t1,$t0
19213##...bne $at,$zero,19232

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
19216:  skipToNextObj:
19216#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
19220#    sll $t1,$t1,2 # convert to byte-count
19224#    addu $t0,$t2,$t1 # skip over object
19228#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
19232:  gcNotDataArray:
19232#    lw $t3,-4($t2) # # object words (negative treated as zero)
19236#    bge $t3,$zero,gcH2Neg2
19237##...slt $at,$t3,$zero
19241##...beq $at,$zero,19248
19244#    move $t3,$zero
19248:  gcH2Neg2:
19248#    sll $t3,$t3,2 # # object bytes
19252#    move $t0,$t2 # address of first pointer in object
19256#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
19260#    beq $t0,$s1,gcTestIterDone2
    
19264:  gcNextPointerInObject:
    # get pointer from object
19264#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
19268#    bleu $t1,$t6,gcGoNextPointerSlot
19269##...sltu $at,$t6,$t1
19273##...beq $at,$zero,19416
19276#    bgtu $t1,$t7,gcGoNextPointerSlot
19277##...sltu $at,$t7,$t1
19281##...bne $at,$zero,19416

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
19284#    lw $t8,-8($t1) # possible forwarding tag
19288#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
19292#    lw $t8,-4($t1) # forwarding pointer: object's new address
19296#    sw $t8,($t0) # update pointer in object
19300#    j gcGoNextPointerSlot # do next iteration

19304:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
19304#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
19305##...slt $at,$t8,$zero
19309##...beq $at,$zero,19324
19312#    and $t8,0xff # mask off hash bits
19313##...lui $at,0
19317##...ori $at,$at,0xff
19321##...and $t8,$t8,$at

19324:  gcSkip5:
19324#    sll $t8,$t8,2 # bytes in negative-offset portion ...
19328#    addu $t8,$t8,8 # ... add in bytes for header-words
19332#    subu $t4,$t1,$t8 # address of first word of source object
19336#    lw $t3,-4($t1) # # words in positive-offset portion
19340#    bge $t3,$zero,gcNoNeg
19341##...slt $at,$t3,$zero
19345##...beq $at,$zero,19352
19348#    move $t3,$zero # negative treated as zero
19352:  gcNoNeg:
19352#    sll $t3,$t3,2 # bytes in negative-offset portion
19356#    addu $t3,$t3,$t1 # address one word past last word of source

19360#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
19364#    lw $s0,($t4)
19368#    lw $t9,-8($t1)
19372#    sw $t9,($t4)
19376#    sw $s0,-8($t1)

    # copy all source bytes to the target
19380:  gCinnerCopy2:
19380#    lw $s0,($t4)
19384#    sw $s0,($s3)
19388#    addu $t4,$t4,4
19392#    addu $s3,$s3,4
19396#    bltu $t4,$t3,gCinnerCopy2
19397##...sltu $at,$t4,$t3
19401##...bne $at,$zero,19380

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
19404#    sw $zero,-8($t1) # 0 in first header-slot
19408#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
19412#    sw $t8,($t0)

19416:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
19416#    addu $t0,$t0,4
19420#    bltu $t0,$s1,gcNextPointerInObject
19421##...sltu $at,$t0,$s1
19425##...bne $at,$zero,19264

19428:  gcTestIterDone2:
19428#    bltu $t0,$s3,gcHeapCopyLoop
19429##...sltu $at,$t0,$s3
19433##...bne $at,$zero,19148

    ###### end outer loop to copy all non-stack-direct objects ######

19436:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
19436#    lw $s2,($sp)
19440#    addu $sp,$sp,4

    # mark us as having already GC'd
19444#    move $t5,$s5

    # go try and allocate again
19448#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
19452:vm_init:

    # mark bottom of stack
19452#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
19456#    move $s2,$zero

    #set up the "five" register
19460#    li $s5,5

19464#    la $s3,seg0_start
19468#    la $s4,seg0_end
19469##...lui $s4,16
19473##...addiu $s4,$s4,20400
    
    # return
19476#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
19480:divide:
    # get parameters; abort if divisor zero
19480#    lw $t0,($sp)
19484#    lw $t1,8($sp)
19488#    beq $t0,$zero,divByZeroError
    
    # perform division
19492#    div $t1,$t0
19496#    mflo $t0

    # store result, adjust stack and return
19500#    addu $sp,$sp,8 # adjust stack
19504#    sw $t0,($sp) # store result
19508#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
19512:remainder:
    # get parameters; abort if divisor zero
19512#    lw $t0,($sp)
19516#    lw $t1,8($sp)
19520#    beq $t0,$zero,divByZeroError
    
    # perform division
19524#    div $t1,$t0
19528#    mfhi $t0

    # store result, adjust stack and return
19532#    addu $sp,$sp,8 # adjust stack
19536#    sw $t0,($sp) # store result
19540#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
19544:checkCast:
    # get object, allow immediately if null
19544#    lw $t2,($sp)
19548#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
19552#    lw $t2,-12($t2) # vtable address
19556#    bge $t2,$t1,castException
19557##...slt $at,$t2,$t1
19561##...beq $at,$zero,19696
19564#    blt $t2,$t0,castException
19565##...slt $at,$t2,$t0
19569##...bne $at,$zero,19696
    
    # return, leaving object unchanged on stack
19572:  checkCastReturn:    
19572#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
19576:instanceOf:
    # get object, go return false if null
19576#    lw $t2,($sp)
19580#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
19584#    lw $t2,-12($t2) # vtable address
19588#    sge $t0,$t2,$t0 # are we >= the lower limit?
19589##...slt $t0,$t2,$t0
19593##...xori $t0,$t0,0x1
19596#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
19600#    and $t2,$t0,$t1
19604#    sw $t2,($sp)
19608:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
19608#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

19612:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
19612#    li $v0,4 # syscall-code for print-string
19616#    syscall
19620:exit:
    # print termination message
19620#    li $v0,4 # syscall-code for print-string
19624#    la $a0,exitString
19628#    syscall

    # terminate execution
19632#    li $v0,10 #syscall-code for "exit"
19636#    syscall

19640:outOfHeapMemory:
19640#    la $a0,heapMemoryMsg
19644#    j exitError
19648:divByZeroError:
19648#    la $a0,divByZeroMsg
19652#    j exitError
19656:strIndexOutOfBounds:
19656#    la $a0,strIndexOutOfBoundsMsg
19660#    j exitError
19664:arrayIndexOutOfBounds:
19664#    la $a0,arrayIndexOutOfBoundsMsg
19668#    j exitError
19672:arraySizeOutOfBounds:
19672#    la $a0,arraySizeOutOfBoundsMsg
19676#    j exitError
19680:nullPtrException:
19680#    la $a0,nullPtrExceptionMsg
19684#    j exitError
19688:badIntegerFormat:
19688#    la $a0,badIntegerFormatMsg
19692#    j exitError
19696:castException:
19696#    la $a0,castExceptionMsg
19700#    j exitError
############## data section ################
    .data
20036:hexChars:
    .ascii "0123456789abcdef"
    .align 2
20052:cur_seg:
    .word 0

20056:lastCharRead:
    .word -2 # -2 => no buffered character
20060:prevHashConstant:
    .word 0x2785173c
20064:gcCount:
    .word 0

20068:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
20095:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
20118:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
20153:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
20187:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
20220:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
20251:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
20299:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
20320:gcMsg: 
      .asciiz "\nGC!\n"
20326:gcCountMsg: 
      .asciiz "Number of garbage collections: "

20358:nullStr:
    .asciiz "null"
20363:trueString:
    .asciiz "true"
20368:falseString:
    .asciiz "false"
20374:exitString:
    .ascii "Program terminated."
    #### "falls through" here
20393:newlineString:
    .asciiz "\n"
    
    .align 2
20396:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

20400:seg0_start:
    .space 0x100000
1068976:seg0_end:
1068976:seg1_start:
    .space 0x100000
2117552:seg1_end:

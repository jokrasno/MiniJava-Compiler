##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
16600:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
16600#    lw $t0,-8($s2) # get word with hash bits from this
16604#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
16608#    addu $t0,$t1

16612#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
16616:mth_equals_Object:
16616#    move $t0,$s2 # first pointer (this)
16620#    lw $t1,($sp) # second pointer
16624#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
16625##...subu $at,$t0,$t1
16629##...sltiu $t0,$at,1

16632#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
16636:mth_hashCode_String:
16636#    move $t0,$s2 # put this pointer in t0

16640#    li $t2,0 # current hash value
16644#    lw $t1,-4($t0) # negative of number of characters in string
16648#    beq $t1,$zero,done_hashCode_String # if zero length => done
16652#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
16656#    and $t0,0xfffffffc # adjust for padding
16657##...lui $at,65535
16661##...ori $at,$at,0xfffc
16665##...and $t0,$t0,$at
16668#    subu $t1,$t0,$t1 # address at end of string +12
16672:loop_hashCode_String:    
16672#    sll $t4,$t2,5 # multiply by 32
16676#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
16680#    lbu $t3,-12($t0) # current character
16684#    addu $t2,$t3 # add in current character
16688#    addu $t0,1 # go to next character's address
16692#    bne $t0,$t1,loop_hashCode_String # loop back if more
16696:done_hashCode_String:    

    # push int on stack
16696#    move $t0, $t2 # put $t2 in return slot
16700#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
16704:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
16704#    subu $sp,4
16708#    sw $ra,($sp)
    
    # get hash value
16712#    lw $t2,-12($s2) # vtable address
16716#    lw $t0,($t2) # method address
16720#    jalr $t0
16724#    subu $sp,8 # push result (int in $t0) on stack
16728#    sw $s5,4($sp)
16732#    sw $t0,($sp)

    # compute print-size of hash value
16736#    li $t0, 1
16740#    lw $t1, ($sp)
16744#    srl $t1,$t1,4
16748#    beq $t1,$zero,toString_skip_loop
16752:toString_loop_top:
16752#    addu $t0,1
16756#    srl $t1,$t1,4
16760#    bne $t1,$zero,toString_loop_top
16764:toString_skip_loop:
16764#    subu $sp,8
16768#    sw $s5,4($sp)
16772#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
16776#    lw $t2,-12($s2) # vtable address
16780#    move $t0,$t2
16784:toString_checkTagBit:
16784#    subu $t0,1
16788#    lb $t1,($t0)
16792#    and $t1,0x80
16793##...lui $at,0
16797##...ori $at,$at,0x80
16801##...and $t1,$t1,$at
16804#    beq $t1,$zero,toString_checkTagBit
16808#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
16812#    subu $sp,8
16816#    sw $t1,($sp)
16820#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
16824#    move $s7,$zero # -4 offset header word
16828#    lw $t4,8($sp) # bytes for hash value
16832#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
16836#    addu $t4,8
16840#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
16844#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

16848#    li $t0,CLASS_String # store string vtable address into ...
16852#    sw $t0,-12($s7) # ... -12 offset in object header
16856#    lw $t2,-12($s2) # our object's vtable address
16860#    lw $t5,4($sp) # number characters in prefix
16864#    lw $t1,12($sp) # number of characters in hashcode
16868#    addu $t3,$t1,$t5 # number of characters in string ...
16872#    addu $t3,1 # ... including the '@' character
16876#    subu $t0,$zero,$t3 # store negated length into ...
16880#    sw $t0,-4($s7) # ... -4 offset header word
16884#    lw $t0,-8($s7) # get -8 offset header-word
16888#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
16889##...slt $at,$t0,$zero
16893##...beq $at,$zero,16912
16896#    and $t0,0xff # mask off object's hash value ...
16897##...lui $at,0
16901##...ori $at,$at,0xff
16905##...and $t0,$t0,$at
16908#    sw $t0,-8($s7) # ... and store back into -8 header-word
16912:skipMask_toString:
16912#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
16916#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
16920#    subu $t4,$t2,$t5
16924:toString_copyLoop:    
16924#    lb $t3,($t4)
16928#    and $t3,0x7f # mask off sign bit (in case first word)
16929##...lui $at,0
16933##...ori $at,$at,0x7f
16937##...and $t3,$t3,$at
16940#    sb $t3,-8($t0)
16944#    addu $t4,1
16948#    addu $t0,1
16952#    blt $t4,$t2,toString_copyLoop
16953##...slt $at,$t4,$t2
16957##...bne $at,$zero,16924

    # copy the '@' sign
16960#    li $t3,'@'
16964#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
16968#    addu $t2,$t0,$t1 # address of last byte in string to store +8
16972#    lw $t3,20($sp) # hash code to print
16976:toString_hashCopyLoop:
16976#    and $t4,$t3,0xf
16980#    srl $t3,4
16984#    lb $t4,hexChars($t4)
16988#    sb $t4,-8($t2)
16992#    subu $t2,$t2,1
16996#    bgt $t2,$t0,toString_hashCopyLoop
16997##...slt $at,$t0,$t2
17001##...bne $at,$zero,16976

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
17004#    addu $sp,28
17008#    lw $ra,($sp)
17012#    addu $sp,4
17016#    move $t0, $s7 # return string we created
17020#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
17024:mth_equals_String:
    
    # quick test for obvious false
17024#    lw $t0,($sp) # second parameter
17028#    beq $t0,$zero,goEsFalse # go return false if null
17032#    lw $t1,-12($t0) # vtable pointer
17036#    la $t2,CLASS_String # string vtable pointer
17040#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
17044#    subu $sp,12
17048#    sw $ra,8($sp)
17052#    sw $s2,4($sp)
17056#    sw $t0,($sp)
17060#    jal mth_compareTo_String
17064#    lw $s2, 4($sp) #restore this pointer and pop parameters
17068#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
17072#    seq $t0,$t0,$zero
17073##...subu $at,$t0,$zero
17077##...sltiu $t0,$at,1

    # pop return address and return $t0
17080#    lw $ra,($sp)
17084#    addu $sp,4

17088#    jr $ra # return
    
17092:goEsFalse:
    # put 0 in $t0 and return
17092#    li $t0, 0
17096#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
17100:mth_toString_String:

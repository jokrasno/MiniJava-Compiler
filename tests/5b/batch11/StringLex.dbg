###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
17108:mth_readLine_Lib:
    
17108#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
17112#    sw $ra, 4($sp) # save $ra
17116#    move $t1,$sp # save "original" sp

17120:  doRead:

    # read the character
17120#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
17124#    subu $t2,$v0,13
17128#    bne $t2,$zero,notReturnRL
17132#    jal readLogicalChar
17136#    subu $t2,$v0,10 # check for newline
17140#    beq $t2,$zero,foundNewLine
17144#    sw $v0,lastCharRead # push back character into queue
17148#    j foundNewLine # go process the line

17152:  notReturnRL:

    # at this point, $v0 has our character

17152#    subu $t0,$v0,10
17156#    beq $t0,$zero,foundNewLine
17160#    blt $v0,$zero,foundEof
17161##...slt $at,$v0,$zero
17165##...bne $at,$zero,17180

    # we have a character, so push it onto stack
17168#    subu $sp,$sp,4
17172#    sw $v0,($sp)

    # loop back up to get next character
17176#    j doRead

17180:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
17180#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
17184#    li $s7, 0 # return-value: null
17188#    j rlReturn # return

17192:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
17192#    subu $t0,$t1,$sp # number of chars we read (times 4)
17196#    srl $s6,$t0,2 # number of words on stack with chars
17200#    subu $sp,$sp,4 # push char-count ...
17204#    sw $s6,($sp) # ... onto stack
17208#    addu $t2,$t0,5 # GC tag, incl. for count-word
17212#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
17216#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
17220#    srl $s6,$s6,2  # data words in object
17224#    move $s7,$zero # object words in object
17228#    jal newObject  # allocate space
    
    # store header words
17232#    la $t0,CLASS_String
17236#    sw $t0,-12($s7)# store class tag (String) into object
17240#    lw $t2,4($sp) # char-count
17244#    sll $t1,$t2,2 # 4 times number of chars
17248#    subu $t2,$zero,$t2 # negative of char-count
17252#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
17256#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
17260#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
17261##...slt $at,$t0,$zero
17265##...beq $at,$zero,17284
17268#    and $t0,0xff # mask off object's hash value ...
17269##...lui $at,0
17273##...ori $at,$at,0xff
17277##...and $t0,$t0,$at
17280#    sw $t0,-8($s7) # ... and store back into -8 header-word
17284:  skipMask_readLine:

17284#    sll $t0,$t0,2 # data bytes in object
17288#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
17292#    subu $t0,$t0,$t2 # place to store last character (plus 9)
17296#    addu $sp,$sp,8 # pop redundant object-pointer and count
17300#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

17304#    beq $sp,$t1,rlReturn
17308:  charCopyLoop:
17308#    lw $t2,($sp)
17312#    sb $t2,-9($t0)
17316#    addu $sp,$sp,4
17320#    subu $t0,$t0,1
17324#    bne $sp,$t1,charCopyLoop
17328:  rlReturn:

17328#    lw $ra, 4($sp)
17332#    addu $sp, 8   # pop $ra and pointless word off stack
17336#    move $t0, $s7 # return string we allocated in $s7
17340#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
17344:mth_readInt_Lib:

    # save $ra by pushing onto stack
17344#    subu $sp,$sp,4
17348#    sw $ra,($sp)

17352:  riSkipWhiteLoop:
    # read a character
17352#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
17356#    subu $t0,$v0,32
17360#    bgt $t0,$zero,nonWhite
17361##...slt $at,$zero,$t0
17365##...bne $at,$zero,17408
17368#    beq $t0,$zero,riSkipWhiteLoop # start over if space
17372#    subu $t0,$v0,10
17376#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
17380#    subu $t0,$v0,9
17384#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
17388#    subu $t0,$v0,13
17392#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
17396#    subu $t0,$v0,12
17400#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
17404#    j badIntegerFormat # illegal integer char: abort program

17408:  nonWhite:
17408#    subu $t0,$v0,'-'
17412#    li $t4,1 # final multiplier
17416#    bne $t0,$zero,helpReadInt # go read
17420#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
17424#    jal readLogicalChar

17428:  helpReadInt:
17428#    li $t2,10
17432#    subu $t1,$v0,'0' # convert digit to 0-9 value
17436#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
17437##...sltu $at,$t1,$t2
17441##...beq $at,$zero,19688
17444#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

17448:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

17448#    jal readLogicalChar # read next character
17452#    subu $t1,$v0,'0' # convert digit to 0-9 value
17456#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
17457##...sltu $at,$t1,$t2
17461##...beq $at,$zero,17480

17464#    mul $t3,$t3,$t2 # multiply old value by 10
17465##...mult $t3,$t2
17469##...mflo $t3
17472#    addu $t3,$t3,$t1 # add in value of new digit
17476#    j digitLoop

17480:  doneDigitLoop:

    # "push back" unused character into queue
17480#    sw $v0,lastCharRead

    # restore return address
17484#    lw $ra,($sp)
17488#    addu $sp, 4

    # multiply by sign and put return value in $t0
17492#    mult $t3,$t4 # multiply to account for poss. minus sign
17496#    mflo $t3
17500#    move $t0, $t3
    
    # return
17504#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
17508:mth_readChar_Lib:

    # save $ra by pushing onto stack
17508#    subu $sp,$sp,4
17512#    sw $ra,($sp)

      # read the character
17516#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
17520#    lw $ra,($sp)
17524#    addu $sp, 4
17528#    move $t0, $v0

    # return
17532#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
17536:mth_printStr_Lib:
    # check for null, printing "(null)", if so
17536#    lw $t0,($sp)
17540#    bne $t0,$zero,psNotNull

    # print "(null)"
17544#    la $a0,nullStr
17548#    li $v0,4
17552#    syscall
17556#    j donePrintStr
    
17560:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
17560#    subu $t0,$t0,8
17564#    lw $t1,($t0) # number of data words, but needs modification
17568#    blt $t1,$zero,skipPrintStr1
17569##...slt $at,$t1,$zero
17573##...bne $at,$zero,17592
17576#    and $t1,0xff # mask out all but low byte
17577##...lui $at,0
17581##...ori $at,$at,0xff
17585##...and $t1,$t1,$at
17588#    b skipPrintStr2
17592:skipPrintStr1:
17592#    and $t1,0x7ffffff
17593##...lui $at,2047
17597##...ori $at,$at,0xffff
17601##...and $t1,$t1,$at
17604:skipPrintStr2:    
17604#    sll $t1,$t1,2
17608#    subu $t1,$t0,$t1 # first word in string
17612#    lw $t0,4($t0) # negative of string-length
17616#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
17620#    beq $t0,$t1,donePrintStr
17624:  psLoop:
17624#    lb $a0,($t1) # next byte
17628#    li $v0,11 # code for printing char

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1216:mth_equals_String:
    
    # quick test for obvious false
1216#    lw $t0,($sp) # second parameter
1220#    beq $t0,$zero,goEsFalse # go return false if null
1224#    lw $t1,-12($t0) # vtable pointer
1228#    la $t2,CLASS_String # string vtable pointer
1232#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1236#    subu $sp,12
1240#    sw $ra,8($sp)
1244#    sw $s2,4($sp)
1248#    sw $t0,($sp)
1252#    jal mth_compareTo_String
1256#    lw $s2, 4($sp) #restore this pointer and pop parameters
1260#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1264#    seq $t0,$t0,$zero
1265##...subu $at,$t0,$zero
1269##...sltiu $t0,$at,1

    # pop return address and return $t0
1272#    lw $ra,($sp)
1276#    addu $sp,4

1280#    jr $ra # return
    
1284:goEsFalse:
    # put 0 in $t0 and return
1284#    li $t0, 0
1288#    jr $ra # return

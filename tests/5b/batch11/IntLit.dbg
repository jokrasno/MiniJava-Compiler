##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
792:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
792#    lw $t0,-8($s2) # get word with hash bits from this
796#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
800#    addu $t0,$t1

804#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
808:mth_equals_Object:
808#    move $t0,$s2 # first pointer (this)
812#    lw $t1,($sp) # second pointer
816#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
817##...subu $at,$t0,$t1
821##...sltiu $t0,$at,1

824#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
828:mth_hashCode_String:
828#    move $t0,$s2 # put this pointer in t0

832#    li $t2,0 # current hash value
836#    lw $t1,-4($t0) # negative of number of characters in string
840#    beq $t1,$zero,done_hashCode_String # if zero length => done
844#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
848#    and $t0,0xfffffffc # adjust for padding
849##...lui $at,65535
853##...ori $at,$at,0xfffc
857##...and $t0,$t0,$at
860#    subu $t1,$t0,$t1 # address at end of string +12
864:loop_hashCode_String:    
864#    sll $t4,$t2,5 # multiply by 32
868#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
872#    lbu $t3,-12($t0) # current character
876#    addu $t2,$t3 # add in current character
880#    addu $t0,1 # go to next character's address
884#    bne $t0,$t1,loop_hashCode_String # loop back if more
888:done_hashCode_String:    

    # push int on stack
888#    move $t0, $t2 # put $t2 in return slot
892#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
896:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
896#    subu $sp,4
900#    sw $ra,($sp)
    
    # get hash value
904#    lw $t2,-12($s2) # vtable address
908#    lw $t0,($t2) # method address
912#    jalr $t0
916#    subu $sp,8 # push result (int in $t0) on stack
920#    sw $s5,4($sp)
924#    sw $t0,($sp)

    # compute print-size of hash value
928#    li $t0, 1
932#    lw $t1, ($sp)
936#    srl $t1,$t1,4
940#    beq $t1,$zero,toString_skip_loop
944:toString_loop_top:
944#    addu $t0,1
948#    srl $t1,$t1,4
952#    bne $t1,$zero,toString_loop_top
956:toString_skip_loop:
956#    subu $sp,8
960#    sw $s5,4($sp)
964#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
968#    lw $t2,-12($s2) # vtable address
972#    move $t0,$t2
976:toString_checkTagBit:
976#    subu $t0,1
980#    lb $t1,($t0)
984#    and $t1,0x80
985##...lui $at,0
989##...ori $at,$at,0x80
993##...and $t1,$t1,$at
996#    beq $t1,$zero,toString_checkTagBit
1000#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1004#    subu $sp,8
1008#    sw $t1,($sp)
1012#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1016#    move $s7,$zero # -4 offset header word
1020#    lw $t4,8($sp) # bytes for hash value
1024#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1028#    addu $t4,8
1032#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1036#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1040#    li $t0,CLASS_String # store string vtable address into ...
1044#    sw $t0,-12($s7) # ... -12 offset in object header
1048#    lw $t2,-12($s2) # our object's vtable address
1052#    lw $t5,4($sp) # number characters in prefix
1056#    lw $t1,12($sp) # number of characters in hashcode
1060#    addu $t3,$t1,$t5 # number of characters in string ...
1064#    addu $t3,1 # ... including the '@' character
1068#    subu $t0,$zero,$t3 # store negated length into ...
1072#    sw $t0,-4($s7) # ... -4 offset header word
1076#    lw $t0,-8($s7) # get -8 offset header-word
1080#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1081##...slt $at,$t0,$zero
1085##...beq $at,$zero,1104
1088#    and $t0,0xff # mask off object's hash value ...
1089##...lui $at,0
1093##...ori $at,$at,0xff
1097##...and $t0,$t0,$at
1100#    sw $t0,-8($s7) # ... and store back into -8 header-word
1104:skipMask_toString:
1104#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1108#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1112#    subu $t4,$t2,$t5
1116:toString_copyLoop:    
1116#    lb $t3,($t4)

1996#    sw $t4,-8($s7) # ... and store back into -8 header-word
2000:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
2000#    lw $t1,8($sp) # k
2004#    lw $t2,16($sp) # n
2008#    subu $t0,$t2,$t1 # value to store
2012#    sw $t0,-4($s7) # store value

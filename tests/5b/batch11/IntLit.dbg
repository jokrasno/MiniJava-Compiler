    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3556#    lw $s0,($t4)
3560#    lw $t9,-8($t1)
3564#    sw $t9,($t4)
3568#    sw $s0,-8($t1)

    # copy all source bytes to the target
3572:  gCinnerCopy2:
3572#    lw $s0,($t4)
3576#    sw $s0,($s3)
3580#    addu $t4,$t4,4
3584#    addu $s3,$s3,4
3588#    bltu $t4,$t3,gCinnerCopy2
3589##...sltu $at,$t4,$t3
3593##...bne $at,$zero,3572

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3596#    sw $zero,-8($t1) # 0 in first header-slot
3600#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3604#    sw $t8,($t0)

3608:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3608#    addu $t0,$t0,4
3612#    bltu $t0,$s1,gcNextPointerInObject
3613##...sltu $at,$t0,$s1
3617##...bne $at,$zero,3456

3620:  gcTestIterDone2:
3620#    bltu $t0,$s3,gcHeapCopyLoop
3621##...sltu $at,$t0,$s3
3625##...bne $at,$zero,3340

    ###### end outer loop to copy all non-stack-direct objects ######

3628:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3628#    lw $s2,($sp)
3632#    addu $sp,$sp,4

    # mark us as having already GC'd
3636#    move $t5,$s5

    # go try and allocate again
3640#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3644:vm_init:

    # mark bottom of stack
3644#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3648#    move $s2,$zero

    #set up the "five" register
3652#    li $s5,5

3656#    la $s3,seg0_start
3660#    la $s4,seg0_end
3661##...lui $s4,16
3665##...addiu $s4,$s4,4424
    
    # return
3668#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3672:divide:
    # get parameters; abort if divisor zero
3672#    lw $t0,($sp)
3676#    lw $t1,8($sp)
3680#    beq $t0,$zero,divByZeroError
    
    # perform division
3684#    div $t1,$t0
3688#    mflo $t0

    # store result, adjust stack and return
3692#    addu $sp,$sp,8 # adjust stack
3696#    sw $t0,($sp) # store result
3700#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3704:remainder:
    # get parameters; abort if divisor zero
3704#    lw $t0,($sp)
3708#    lw $t1,8($sp)
3712#    beq $t0,$zero,divByZeroError
    
    # perform division
3716#    div $t1,$t0
3720#    mfhi $t0

    # store result, adjust stack and return
3724#    addu $sp,$sp,8 # adjust stack
3728#    sw $t0,($sp) # store result
3732#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3736:checkCast:
    # get object, allow immediately if null
3736#    lw $t2,($sp)
3740#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3744#    lw $t2,-12($t2) # vtable address
3748#    bge $t2,$t1,castException
3749##...slt $at,$t2,$t1
3753##...beq $at,$zero,3888
3756#    blt $t2,$t0,castException
3757##...slt $at,$t2,$t0
3761##...bne $at,$zero,3888
    
    # return, leaving object unchanged on stack
3764:  checkCastReturn:    
3764#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3768:instanceOf:
    # get object, go return false if null
3768#    lw $t2,($sp)
3772#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3776#    lw $t2,-12($t2) # vtable address
3780#    sge $t0,$t2,$t0 # are we >= the lower limit?
3781##...slt $t0,$t2,$t0
3785##...xori $t0,$t0,0x1
3788#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3792#    and $t2,$t0,$t1
3796#    sw $t2,($sp)
3800:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3800#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3804:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3804#    li $v0,4 # syscall-code for print-string
3808#    syscall
3812:exit:
    # print termination message
3812#    li $v0,4 # syscall-code for print-string
3816#    la $a0,exitString
3820#    syscall

    # terminate execution
3824#    li $v0,10 #syscall-code for "exit"
3828#    syscall

3832:outOfHeapMemory:
3832#    la $a0,heapMemoryMsg
3836#    j exitError
3840:divByZeroError:
3840#    la $a0,divByZeroMsg
3844#    j exitError
3848:strIndexOutOfBounds:
3848#    la $a0,strIndexOutOfBoundsMsg
3852#    j exitError
3856:arrayIndexOutOfBounds:
3856#    la $a0,arrayIndexOutOfBoundsMsg
3860#    j exitError
3864:arraySizeOutOfBounds:
3864#    la $a0,arraySizeOutOfBoundsMsg
3868#    j exitError
3872:nullPtrException:
3872#    la $a0,nullPtrExceptionMsg
3876#    j exitError
3880:badIntegerFormat:
3880#    la $a0,badIntegerFormatMsg
3884#    j exitError
3888:castException:
3888#    la $a0,castExceptionMsg
3892#    j exitError
############## data section ################
    .data
4060:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4076:cur_seg:
    .word 0

4080:lastCharRead:
    .word -2 # -2 => no buffered character
4084:prevHashConstant:
    .word 0x2785173c
4088:gcCount:
    .word 0

4092:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4119:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4142:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4177:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4211:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4244:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4275:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4323:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4344:gcMsg: 
      .asciiz "\nGC!\n"
4350:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4382:nullStr:
    .asciiz "null"
4387:trueString:
    .asciiz "true"
4392:falseString:
    .asciiz "false"
4398:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4417:newlineString:
    .asciiz "\n"
    
    .align 2
4420:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4424:seg0_start:
    .space 0x100000
1053000:seg0_end:
1053000:seg1_start:
    .space 0x100000
2101576:seg1_end:

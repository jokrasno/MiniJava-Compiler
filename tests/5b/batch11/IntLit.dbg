###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1300:mth_readLine_Lib:
    
1300#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1304#    sw $ra, 4($sp) # save $ra
1308#    move $t1,$sp # save "original" sp

1312:  doRead:

    # read the character
1312#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1316#    subu $t2,$v0,13
1320#    bne $t2,$zero,notReturnRL
1324#    jal readLogicalChar
1328#    subu $t2,$v0,10 # check for newline
1332#    beq $t2,$zero,foundNewLine
1336#    sw $v0,lastCharRead # push back character into queue
1340#    j foundNewLine # go process the line

1344:  notReturnRL:

    # at this point, $v0 has our character

1344#    subu $t0,$v0,10
1348#    beq $t0,$zero,foundNewLine
1352#    blt $v0,$zero,foundEof
1353##...slt $at,$v0,$zero
1357##...bne $at,$zero,1372

    # we have a character, so push it onto stack
1360#    subu $sp,$sp,4
1364#    sw $v0,($sp)

    # loop back up to get next character
1368#    j doRead

1372:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1372#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1376#    li $s7, 0 # return-value: null
1380#    j rlReturn # return

1384:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1384#    subu $t0,$t1,$sp # number of chars we read (times 4)
1388#    srl $s6,$t0,2 # number of words on stack with chars
1392#    subu $sp,$sp,4 # push char-count ...
1396#    sw $s6,($sp) # ... onto stack
1400#    addu $t2,$t0,5 # GC tag, incl. for count-word
1404#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1408#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1412#    srl $s6,$s6,2  # data words in object
1416#    move $s7,$zero # object words in object
1420#    jal newObject  # allocate space
    
    # store header words
1424#    la $t0,CLASS_String
1428#    sw $t0,-12($s7)# store class tag (String) into object
1432#    lw $t2,4($sp) # char-count
1436#    sll $t1,$t2,2 # 4 times number of chars
1440#    subu $t2,$zero,$t2 # negative of char-count
1444#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1448#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1452#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1453##...slt $at,$t0,$zero
1457##...beq $at,$zero,1476
1460#    and $t0,0xff # mask off object's hash value ...
1461##...lui $at,0
1465##...ori $at,$at,0xff
1469##...and $t0,$t0,$at
1472#    sw $t0,-8($s7) # ... and store back into -8 header-word
1476:  skipMask_readLine:

1476#    sll $t0,$t0,2 # data bytes in object
1480#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1484#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1488#    addu $sp,$sp,8 # pop redundant object-pointer and count
1492#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1496#    beq $sp,$t1,rlReturn
1500:  charCopyLoop:
1500#    lw $t2,($sp)
1504#    sb $t2,-9($t0)
1508#    addu $sp,$sp,4
1512#    subu $t0,$t0,1
1516#    bne $sp,$t1,charCopyLoop
1520:  rlReturn:

1520#    lw $ra, 4($sp)
1524#    addu $sp, 8   # pop $ra and pointless word off stack
1528#    move $t0, $s7 # return string we allocated in $s7
1532#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1536:mth_readInt_Lib:

    # save $ra by pushing onto stack
1536#    subu $sp,$sp,4
1540#    sw $ra,($sp)

1544:  riSkipWhiteLoop:
    # read a character
1544#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1548#    subu $t0,$v0,32
1552#    bgt $t0,$zero,nonWhite
1553##...slt $at,$zero,$t0
1557##...bne $at,$zero,1600
1560#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1564#    subu $t0,$v0,10
1568#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1572#    subu $t0,$v0,9
1576#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1580#    subu $t0,$v0,13
1584#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1588#    subu $t0,$v0,12
1592#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1596#    j badIntegerFormat # illegal integer char: abort program

1600:  nonWhite:
1600#    subu $t0,$v0,'-'
1604#    li $t4,1 # final multiplier
1608#    bne $t0,$zero,helpReadInt # go read
1612#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1616#    jal readLogicalChar

1620:  helpReadInt:
1620#    li $t2,10
1624#    subu $t1,$v0,'0' # convert digit to 0-9 value
1628#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1629##...sltu $at,$t1,$t2
1633##...beq $at,$zero,3880
1636#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1640:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1640#    jal readLogicalChar # read next character
1644#    subu $t1,$v0,'0' # convert digit to 0-9 value
1648#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1649##...sltu $at,$t1,$t2
1653##...beq $at,$zero,1672

1656#    mul $t3,$t3,$t2 # multiply old value by 10
1657##...mult $t3,$t2
1661##...mflo $t3
1664#    addu $t3,$t3,$t1 # add in value of new digit
1668#    j digitLoop

1672:  doneDigitLoop:

    # "push back" unused character into queue
1672#    sw $v0,lastCharRead

    # restore return address
1676#    lw $ra,($sp)
1680#    addu $sp, 4

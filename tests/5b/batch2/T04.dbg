    
    # perform division
3336#    div $t1,$t0
3340#    mflo $t0

    # store result, adjust stack and return
3344#    addu $sp,$sp,8 # adjust stack
3348#    sw $t0,($sp) # store result
3352#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3356:remainder:
    # get parameters; abort if divisor zero
3356#    lw $t0,($sp)
3360#    lw $t1,8($sp)
3364#    beq $t0,$zero,divByZeroError
    
    # perform division
3368#    div $t1,$t0
3372#    mfhi $t0

    # store result, adjust stack and return
3376#    addu $sp,$sp,8 # adjust stack
3380#    sw $t0,($sp) # store result
3384#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3388:checkCast:
    # get object, allow immediately if null
3388#    lw $t2,($sp)
3392#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3396#    lw $t2,-12($t2) # vtable address
3400#    bge $t2,$t1,castException
3401##...slt $at,$t2,$t1
3405##...beq $at,$zero,3540
3408#    blt $t2,$t0,castException
3409##...slt $at,$t2,$t0
3413##...bne $at,$zero,3540
    
    # return, leaving object unchanged on stack
3416:  checkCastReturn:    
3416#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3420:instanceOf:
    # get object, go return false if null
3420#    lw $t2,($sp)
3424#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3428#    lw $t2,-12($t2) # vtable address
3432#    sge $t0,$t2,$t0 # are we >= the lower limit?
3433##...slt $t0,$t2,$t0
3437##...xori $t0,$t0,0x1
3440#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3444#    and $t2,$t0,$t1
3448#    sw $t2,($sp)
3452:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3452#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3456:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3456#    li $v0,4 # syscall-code for print-string
3460#    syscall
3464:exit:
    # print termination message
3464#    li $v0,4 # syscall-code for print-string
3468#    la $a0,exitString
3472#    syscall

    # terminate execution
3476#    li $v0,10 #syscall-code for "exit"
3480#    syscall

3484:outOfHeapMemory:
3484#    la $a0,heapMemoryMsg
3488#    j exitError
3492:divByZeroError:
3492#    la $a0,divByZeroMsg
3496#    j exitError
3500:strIndexOutOfBounds:
3500#    la $a0,strIndexOutOfBoundsMsg
3504#    j exitError
3508:arrayIndexOutOfBounds:
3508#    la $a0,arrayIndexOutOfBoundsMsg
3512#    j exitError
3516:arraySizeOutOfBounds:
3516#    la $a0,arraySizeOutOfBoundsMsg
3520#    j exitError
3524:nullPtrException:
3524#    la $a0,nullPtrExceptionMsg
3528#    j exitError
3532:badIntegerFormat:
3532#    la $a0,badIntegerFormatMsg
3536#    j exitError
3540:castException:
3540#    la $a0,castExceptionMsg
3544#    j exitError
############## data section ################
    .data
3728:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3744:cur_seg:
    .word 0

3748:lastCharRead:
    .word -2 # -2 => no buffered character
3752:prevHashConstant:
    .word 0x2785173c
3756:gcCount:
    .word 0

3760:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3787:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3810:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3845:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3879:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3912:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3943:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3991:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4012:gcMsg: 
      .asciiz "\nGC!\n"
4018:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4050:nullStr:
    .asciiz "null"
4055:trueString:
    .asciiz "true"
4060:falseString:
    .asciiz "false"
4066:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4085:newlineString:
    .asciiz "\n"
    
    .align 2
4088:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4092:seg0_start:
    .space 0x100000
1052668:seg0_end:
1052668:seg1_start:
    .space 0x100000
2101244:seg1_end:

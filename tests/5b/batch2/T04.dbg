##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
444:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
444#    lw $t0,-8($s2) # get word with hash bits from this
448#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
452#    addu $t0,$t1

456#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
460:mth_equals_Object:
460#    move $t0,$s2 # first pointer (this)
464#    lw $t1,($sp) # second pointer
468#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
469##...subu $at,$t0,$t1
473##...sltiu $t0,$at,1

476#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
480:mth_hashCode_String:
480#    move $t0,$s2 # put this pointer in t0

484#    li $t2,0 # current hash value
488#    lw $t1,-4($t0) # negative of number of characters in string
492#    beq $t1,$zero,done_hashCode_String # if zero length => done
496#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
500#    and $t0,0xfffffffc # adjust for padding
501##...lui $at,65535
505##...ori $at,$at,0xfffc
509##...and $t0,$t0,$at
512#    subu $t1,$t0,$t1 # address at end of string +12
516:loop_hashCode_String:    
516#    sll $t4,$t2,5 # multiply by 32
520#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
524#    lbu $t3,-12($t0) # current character
528#    addu $t2,$t3 # add in current character
532#    addu $t0,1 # go to next character's address
536#    bne $t0,$t1,loop_hashCode_String # loop back if more
540:done_hashCode_String:    

    # push int on stack
540#    move $t0, $t2 # put $t2 in return slot
544#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
548:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
548#    subu $sp,4
552#    sw $ra,($sp)
    
    # get hash value
556#    lw $t2,-12($s2) # vtable address
560#    lw $t0,($t2) # method address
564#    jalr $t0
568#    subu $sp,8 # push result (int in $t0) on stack
572#    sw $s5,4($sp)
576#    sw $t0,($sp)

    # compute print-size of hash value
580#    li $t0, 1
584#    lw $t1, ($sp)
588#    srl $t1,$t1,4
592#    beq $t1,$zero,toString_skip_loop
596:toString_loop_top:
596#    addu $t0,1
600#    srl $t1,$t1,4
604#    bne $t1,$zero,toString_loop_top
608:toString_skip_loop:
608#    subu $sp,8
612#    sw $s5,4($sp)
616#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
620#    lw $t2,-12($s2) # vtable address
624#    move $t0,$t2
628:toString_checkTagBit:
628#    subu $t0,1
632#    lb $t1,($t0)
636#    and $t1,0x80
637##...lui $at,0
641##...ori $at,$at,0x80
645##...and $t1,$t1,$at
648#    beq $t1,$zero,toString_checkTagBit
652#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
656#    subu $sp,8
660#    sw $t1,($sp)
664#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
668#    move $s7,$zero # -4 offset header word
672#    lw $t4,8($sp) # bytes for hash value
676#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
680#    addu $t4,8
684#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
688#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

692#    li $t0,CLASS_String # store string vtable address into ...
696#    sw $t0,-12($s7) # ... -12 offset in object header
700#    lw $t2,-12($s2) # our object's vtable address
704#    lw $t5,4($sp) # number characters in prefix
708#    lw $t1,12($sp) # number of characters in hashcode
712#    addu $t3,$t1,$t5 # number of characters in string ...
716#    addu $t3,1 # ... including the '@' character
720#    subu $t0,$zero,$t3 # store negated length into ...
724#    sw $t0,-4($s7) # ... -4 offset header word
728#    lw $t0,-8($s7) # get -8 offset header-word
732#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
733##...slt $at,$t0,$zero
737##...beq $at,$zero,756
740#    and $t0,0xff # mask off object's hash value ...
741##...lui $at,0
745##...ori $at,$at,0xff
749##...and $t0,$t0,$at
752#    sw $t0,-8($s7) # ... and store back into -8 header-word
756:skipMask_toString:
756#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
760#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
764#    subu $t4,$t2,$t5
768:toString_copyLoop:    
768#    lb $t3,($t4)
772#    and $t3,0x7f # mask off sign bit (in case first word)
773##...lui $at,0
777##...ori $at,$at,0x7f
781##...and $t3,$t3,$at
784#    sb $t3,-8($t0)
788#    addu $t4,1
792#    addu $t0,1
796#    blt $t4,$t2,toString_copyLoop
797##...slt $at,$t4,$t2
801##...bne $at,$zero,768

    # copy the '@' sign
804#    li $t3,'@'
808#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
812#    addu $t2,$t0,$t1 # address of last byte in string to store +8
816#    lw $t3,20($sp) # hash code to print
820:toString_hashCopyLoop:
820#    and $t4,$t3,0xf
824#    srl $t3,4
828#    lb $t4,hexChars($t4)
832#    sb $t4,-8($t2)
836#    subu $t2,$t2,1
840#    bgt $t2,$t0,toString_hashCopyLoop
841##...slt $at,$t0,$t2
845##...bne $at,$zero,820

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
848#    addu $sp,28
852#    lw $ra,($sp)
856#    addu $sp,4
860#    move $t0, $s7 # return string we created
864#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
868:mth_equals_String:
    
    # quick test for obvious false
868#    lw $t0,($sp) # second parameter
872#    beq $t0,$zero,goEsFalse # go return false if null
876#    lw $t1,-12($t0) # vtable pointer
880#    la $t2,CLASS_String # string vtable pointer
884#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
888#    subu $sp,12
892#    sw $ra,8($sp)
896#    sw $s2,4($sp)
900#    sw $t0,($sp)
904#    jal mth_compareTo_String
908#    lw $s2, 4($sp) #restore this pointer and pop parameters
912#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
916#    seq $t0,$t0,$zero
917##...subu $at,$t0,$zero
921##...sltiu $t0,$at,1

    # pop return address and return $t0
924#    lw $ra,($sp)
928#    addu $sp,4

932#    jr $ra # return
    
936:goEsFalse:
    # put 0 in $t0 and return

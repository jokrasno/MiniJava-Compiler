########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
2488:readLogicalChar:

    # check if we already have a character
2488#    lw $v0,lastCharRead
2492#    li $t0,-2
2496#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
2500#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2504#    jr $ra # return
    
2508:  doReadCh:
    # we need to actually read a character: read and return
2508#    li $v0,12 # use system call to read a character
2512#    syscall
2516#    jr $ra # return

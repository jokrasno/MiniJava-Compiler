###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
952:mth_readLine_Lib:
    
952#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
956#    sw $ra, 4($sp) # save $ra
960#    move $t1,$sp # save "original" sp

964:  doRead:

    # read the character
964#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
968#    subu $t2,$v0,13
972#    bne $t2,$zero,notReturnRL
976#    jal readLogicalChar
980#    subu $t2,$v0,10 # check for newline
984#    beq $t2,$zero,foundNewLine
988#    sw $v0,lastCharRead # push back character into queue
992#    j foundNewLine # go process the line

996:  notReturnRL:

    # at this point, $v0 has our character

996#    subu $t0,$v0,10
1000#    beq $t0,$zero,foundNewLine
1004#    blt $v0,$zero,foundEof
1005##...slt $at,$v0,$zero
1009##...bne $at,$zero,1024

    # we have a character, so push it onto stack
1012#    subu $sp,$sp,4
1016#    sw $v0,($sp)

    # loop back up to get next character
1020#    j doRead

1024:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1024#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1028#    li $s7, 0 # return-value: null
1032#    j rlReturn # return

1036:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1036#    subu $t0,$t1,$sp # number of chars we read (times 4)
1040#    srl $s6,$t0,2 # number of words on stack with chars
1044#    subu $sp,$sp,4 # push char-count ...
1048#    sw $s6,($sp) # ... onto stack
1052#    addu $t2,$t0,5 # GC tag, incl. for count-word
1056#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1060#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1064#    srl $s6,$s6,2  # data words in object
1068#    move $s7,$zero # object words in object
1072#    jal newObject  # allocate space
    
    # store header words
1076#    la $t0,CLASS_String
1080#    sw $t0,-12($s7)# store class tag (String) into object
1084#    lw $t2,4($sp) # char-count
1088#    sll $t1,$t2,2 # 4 times number of chars
1092#    subu $t2,$zero,$t2 # negative of char-count
1096#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1100#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1104#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1105##...slt $at,$t0,$zero
1109##...beq $at,$zero,1128
1112#    and $t0,0xff # mask off object's hash value ...
1113##...lui $at,0
1117##...ori $at,$at,0xff
1121##...and $t0,$t0,$at
1124#    sw $t0,-8($s7) # ... and store back into -8 header-word
1128:  skipMask_readLine:

1128#    sll $t0,$t0,2 # data bytes in object
1132#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1136#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1140#    addu $sp,$sp,8 # pop redundant object-pointer and count
1144#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1148#    beq $sp,$t1,rlReturn
1152:  charCopyLoop:
1152#    lw $t2,($sp)
1156#    sb $t2,-9($t0)
1160#    addu $sp,$sp,4
1164#    subu $t0,$t0,1
1168#    bne $sp,$t1,charCopyLoop
1172:  rlReturn:

1172#    lw $ra, 4($sp)
1176#    addu $sp, 8   # pop $ra and pointless word off stack
1180#    move $t0, $s7 # return string we allocated in $s7
1184#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1188:mth_readInt_Lib:

    # save $ra by pushing onto stack
1188#    subu $sp,$sp,4
1192#    sw $ra,($sp)

1196:  riSkipWhiteLoop:
    # read a character
1196#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1200#    subu $t0,$v0,32
1204#    bgt $t0,$zero,nonWhite
1205##...slt $at,$zero,$t0
1209##...bne $at,$zero,1252
1212#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1216#    subu $t0,$v0,10
1220#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1224#    subu $t0,$v0,9
1228#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1232#    subu $t0,$v0,13
1236#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1240#    subu $t0,$v0,12
1244#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1248#    j badIntegerFormat # illegal integer char: abort program

1252:  nonWhite:
1252#    subu $t0,$v0,'-'
1256#    li $t4,1 # final multiplier
1260#    bne $t0,$zero,helpReadInt # go read
1264#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1268#    jal readLogicalChar

1272:  helpReadInt:
1272#    li $t2,10
1276#    subu $t1,$v0,'0' # convert digit to 0-9 value
1280#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1281##...sltu $at,$t1,$t2
1285##...beq $at,$zero,3532
1288#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1292:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1292#    jal readLogicalChar # read next character
1296#    subu $t1,$v0,'0' # convert digit to 0-9 value
1300#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1301##...sltu $at,$t1,$t2
1305##...beq $at,$zero,1324

1308#    mul $t3,$t3,$t2 # multiply old value by 10
1309##...mult $t3,$t2
1313##...mflo $t3
1316#    addu $t3,$t3,$t1 # add in value of new digit
1320#    j digitLoop

1324:  doneDigitLoop:

    # "push back" unused character into queue
1324#    sw $v0,lastCharRead

    # restore return address
1328#    lw $ra,($sp)
1332#    addu $sp, 4

    # multiply by sign and put return value in $t0
1336#    mult $t3,$t4 # multiply to account for poss. minus sign
1340#    mflo $t3
1344#    move $t0, $t3
    
    # return
1348#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
956:mth_readLine_Lib:
    
956#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
960#    sw $ra, 4($sp) # save $ra
964#    move $t1,$sp # save "original" sp

968:  doRead:

    # read the character
968#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
972#    subu $t2,$v0,13
976#    bne $t2,$zero,notReturnRL
980#    jal readLogicalChar
984#    subu $t2,$v0,10 # check for newline
988#    beq $t2,$zero,foundNewLine
992#    sw $v0,lastCharRead # push back character into queue
996#    j foundNewLine # go process the line

1000:  notReturnRL:

    # at this point, $v0 has our character

1000#    subu $t0,$v0,10
1004#    beq $t0,$zero,foundNewLine
1008#    blt $v0,$zero,foundEof
1009##...slt $at,$v0,$zero
1013##...bne $at,$zero,1028

    # we have a character, so push it onto stack
1016#    subu $sp,$sp,4
1020#    sw $v0,($sp)

    # loop back up to get next character
1024#    j doRead

1028:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1028#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1032#    li $s7, 0 # return-value: null
1036#    j rlReturn # return

1040:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1040#    subu $t0,$t1,$sp # number of chars we read (times 4)
1044#    srl $s6,$t0,2 # number of words on stack with chars
1048#    subu $sp,$sp,4 # push char-count ...
1052#    sw $s6,($sp) # ... onto stack
1056#    addu $t2,$t0,5 # GC tag, incl. for count-word
1060#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1064#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1068#    srl $s6,$s6,2  # data words in object
1072#    move $s7,$zero # object words in object
1076#    jal newObject  # allocate space
    
    # store header words
1080#    la $t0,CLASS_String
1084#    sw $t0,-12($s7)# store class tag (String) into object
1088#    lw $t2,4($sp) # char-count
1092#    sll $t1,$t2,2 # 4 times number of chars
1096#    subu $t2,$zero,$t2 # negative of char-count
1100#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1104#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1108#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1109##...slt $at,$t0,$zero
1113##...beq $at,$zero,1132
1116#    and $t0,0xff # mask off object's hash value ...
1117##...lui $at,0
1121##...ori $at,$at,0xff
1125##...and $t0,$t0,$at
1128#    sw $t0,-8($s7) # ... and store back into -8 header-word
1132:  skipMask_readLine:

1132#    sll $t0,$t0,2 # data bytes in object
1136#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1140#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1144#    addu $sp,$sp,8 # pop redundant object-pointer and count
1148#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1152#    beq $sp,$t1,rlReturn
1156:  charCopyLoop:
1156#    lw $t2,($sp)
1160#    sb $t2,-9($t0)
1164#    addu $sp,$sp,4
1168#    subu $t0,$t0,1
1172#    bne $sp,$t1,charCopyLoop
1176:  rlReturn:

1176#    lw $ra, 4($sp)
1180#    addu $sp, 8   # pop $ra and pointless word off stack
1184#    move $t0, $s7 # return string we allocated in $s7
1188#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1192:mth_readInt_Lib:

    # save $ra by pushing onto stack
1192#    subu $sp,$sp,4
1196#    sw $ra,($sp)

1200:  riSkipWhiteLoop:
    # read a character
1200#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1204#    subu $t0,$v0,32
1208#    bgt $t0,$zero,nonWhite
1209##...slt $at,$zero,$t0
1213##...bne $at,$zero,1256
1216#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1220#    subu $t0,$v0,10
1224#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1228#    subu $t0,$v0,9
1232#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1236#    subu $t0,$v0,13
1240#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1244#    subu $t0,$v0,12
1248#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1252#    j badIntegerFormat # illegal integer char: abort program

1256:  nonWhite:
1256#    subu $t0,$v0,'-'
1260#    li $t4,1 # final multiplier
1264#    bne $t0,$zero,helpReadInt # go read
1268#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1272#    jal readLogicalChar

1276:  helpReadInt:
1276#    li $t2,10
1280#    subu $t1,$v0,'0' # convert digit to 0-9 value
1284#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1285##...sltu $at,$t1,$t2
1289##...beq $at,$zero,3536
1292#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1296:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1296#    jal readLogicalChar # read next character
1300#    subu $t1,$v0,'0' # convert digit to 0-9 value
1304#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1305##...sltu $at,$t1,$t2
1309##...beq $at,$zero,1328

1312#    mul $t3,$t3,$t2 # multiply old value by 10
1313##...mult $t3,$t2
1317##...mflo $t3
1320#    addu $t3,$t3,$t1 # add in value of new digit
1324#    j digitLoop

1328:  doneDigitLoop:

    # "push back" unused character into queue
1328#    sw $v0,lastCharRead

    # restore return address
1332#    lw $ra,($sp)
1336#    addu $sp, 4

    # multiply by sign and put return value in $t0
1340#    mult $t3,$t4 # multiply to account for poss. minus sign
1344#    mflo $t3
1348#    move $t0, $t3
    
    # return
1352#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input

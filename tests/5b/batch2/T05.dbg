##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
448:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
448#    lw $t0,-8($s2) # get word with hash bits from this
452#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
456#    addu $t0,$t1

460#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
464:mth_equals_Object:
464#    move $t0,$s2 # first pointer (this)
468#    lw $t1,($sp) # second pointer
472#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
473##...subu $at,$t0,$t1
477##...sltiu $t0,$at,1

480#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
484:mth_hashCode_String:
484#    move $t0,$s2 # put this pointer in t0

488#    li $t2,0 # current hash value
492#    lw $t1,-4($t0) # negative of number of characters in string
496#    beq $t1,$zero,done_hashCode_String # if zero length => done
500#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
504#    and $t0,0xfffffffc # adjust for padding
505##...lui $at,65535
509##...ori $at,$at,0xfffc
513##...and $t0,$t0,$at
516#    subu $t1,$t0,$t1 # address at end of string +12
520:loop_hashCode_String:    
520#    sll $t4,$t2,5 # multiply by 32
524#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
528#    lbu $t3,-12($t0) # current character
532#    addu $t2,$t3 # add in current character
536#    addu $t0,1 # go to next character's address
540#    bne $t0,$t1,loop_hashCode_String # loop back if more
544:done_hashCode_String:    

    # push int on stack
544#    move $t0, $t2 # put $t2 in return slot
548#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
552:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
552#    subu $sp,4
556#    sw $ra,($sp)
    
    # get hash value
560#    lw $t2,-12($s2) # vtable address
564#    lw $t0,($t2) # method address
568#    jalr $t0
572#    subu $sp,8 # push result (int in $t0) on stack
576#    sw $s5,4($sp)
580#    sw $t0,($sp)

    # compute print-size of hash value
584#    li $t0, 1
588#    lw $t1, ($sp)
592#    srl $t1,$t1,4
596#    beq $t1,$zero,toString_skip_loop
600:toString_loop_top:
600#    addu $t0,1
604#    srl $t1,$t1,4
608#    bne $t1,$zero,toString_loop_top
612:toString_skip_loop:
612#    subu $sp,8
616#    sw $s5,4($sp)
620#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
624#    lw $t2,-12($s2) # vtable address
628#    move $t0,$t2
632:toString_checkTagBit:
632#    subu $t0,1
636#    lb $t1,($t0)
640#    and $t1,0x80
641##...lui $at,0
645##...ori $at,$at,0x80
649##...and $t1,$t1,$at
652#    beq $t1,$zero,toString_checkTagBit
656#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
660#    subu $sp,8
664#    sw $t1,($sp)
668#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
672#    move $s7,$zero # -4 offset header word
676#    lw $t4,8($sp) # bytes for hash value
680#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
684#    addu $t4,8
688#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
692#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

696#    li $t0,CLASS_String # store string vtable address into ...
700#    sw $t0,-12($s7) # ... -12 offset in object header
704#    lw $t2,-12($s2) # our object's vtable address
708#    lw $t5,4($sp) # number characters in prefix
712#    lw $t1,12($sp) # number of characters in hashcode
716#    addu $t3,$t1,$t5 # number of characters in string ...
720#    addu $t3,1 # ... including the '@' character
724#    subu $t0,$zero,$t3 # store negated length into ...
728#    sw $t0,-4($s7) # ... -4 offset header word
732#    lw $t0,-8($s7) # get -8 offset header-word
736#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
737##...slt $at,$t0,$zero
741##...beq $at,$zero,760
744#    and $t0,0xff # mask off object's hash value ...
745##...lui $at,0
749##...ori $at,$at,0xff
753##...and $t0,$t0,$at
756#    sw $t0,-8($s7) # ... and store back into -8 header-word
760:skipMask_toString:
760#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
764#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
768#    subu $t4,$t2,$t5
772:toString_copyLoop:    
772#    lb $t3,($t4)
776#    and $t3,0x7f # mask off sign bit (in case first word)
777##...lui $at,0
781##...ori $at,$at,0x7f
785##...and $t3,$t3,$at
788#    sb $t3,-8($t0)
792#    addu $t4,1
796#    addu $t0,1
800#    blt $t4,$t2,toString_copyLoop
801##...slt $at,$t4,$t2
805##...bne $at,$zero,772

    # copy the '@' sign
808#    li $t3,'@'
812#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
816#    addu $t2,$t0,$t1 # address of last byte in string to store +8
820#    lw $t3,20($sp) # hash code to print
824:toString_hashCopyLoop:
824#    and $t4,$t3,0xf
828#    srl $t3,4
832#    lb $t4,hexChars($t4)
836#    sb $t4,-8($t2)
840#    subu $t2,$t2,1
844#    bgt $t2,$t0,toString_hashCopyLoop
845##...slt $at,$t0,$t2
849##...bne $at,$zero,824

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
852#    addu $sp,28
856#    lw $ra,($sp)
860#    addu $sp,4
864#    move $t0, $s7 # return string we created
868#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
872:mth_equals_String:
    
    # quick test for obvious false
872#    lw $t0,($sp) # second parameter
876#    beq $t0,$zero,goEsFalse # go return false if null
880#    lw $t1,-12($t0) # vtable pointer
884#    la $t2,CLASS_String # string vtable pointer
888#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
892#    subu $sp,12
896#    sw $ra,8($sp)
900#    sw $s2,4($sp)
904#    sw $t0,($sp)
908#    jal mth_compareTo_String

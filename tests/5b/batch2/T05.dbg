########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3300:vm_init:

    # mark bottom of stack
3300#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3304#    move $s2,$zero

    #set up the "five" register
3308#    li $s5,5

3312#    la $s3,seg0_start
3316#    la $s4,seg0_end
3317##...lui $s4,16
3321##...addiu $s4,$s4,4112
    
    # return
3324#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3328:divide:
    # get parameters; abort if divisor zero
3328#    lw $t0,($sp)
3332#    lw $t1,8($sp)
3336#    beq $t0,$zero,divByZeroError
    
    # perform division
3340#    div $t1,$t0
3344#    mflo $t0

    # store result, adjust stack and return
3348#    addu $sp,$sp,8 # adjust stack
3352#    sw $t0,($sp) # store result
3356#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3360:remainder:
    # get parameters; abort if divisor zero
3360#    lw $t0,($sp)
3364#    lw $t1,8($sp)
3368#    beq $t0,$zero,divByZeroError
    
    # perform division
3372#    div $t1,$t0
3376#    mfhi $t0

    # store result, adjust stack and return
3380#    addu $sp,$sp,8 # adjust stack
3384#    sw $t0,($sp) # store result
3388#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3392:checkCast:
    # get object, allow immediately if null
3392#    lw $t2,($sp)
3396#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3400#    lw $t2,-12($t2) # vtable address
3404#    bge $t2,$t1,castException
3405##...slt $at,$t2,$t1
3409##...beq $at,$zero,3544
3412#    blt $t2,$t0,castException
3413##...slt $at,$t2,$t0
3417##...bne $at,$zero,3544
    
    # return, leaving object unchanged on stack
3420:  checkCastReturn:    
3420#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3424:instanceOf:
    # get object, go return false if null
3424#    lw $t2,($sp)
3428#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3432#    lw $t2,-12($t2) # vtable address
3436#    sge $t0,$t2,$t0 # are we >= the lower limit?
3437##...slt $t0,$t2,$t0
3441##...xori $t0,$t0,0x1
3444#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3448#    and $t2,$t0,$t1
3452#    sw $t2,($sp)
3456:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3456#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3460:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3460#    li $v0,4 # syscall-code for print-string
3464#    syscall
3468:exit:
    # print termination message
3468#    li $v0,4 # syscall-code for print-string
3472#    la $a0,exitString
3476#    syscall

    # terminate execution
3480#    li $v0,10 #syscall-code for "exit"
3484#    syscall

3488:outOfHeapMemory:
3488#    la $a0,heapMemoryMsg
3492#    j exitError
3496:divByZeroError:
3496#    la $a0,divByZeroMsg
3500#    j exitError
3504:strIndexOutOfBounds:
3504#    la $a0,strIndexOutOfBoundsMsg
3508#    j exitError
3512:arrayIndexOutOfBounds:
3512#    la $a0,arrayIndexOutOfBoundsMsg
3516#    j exitError
3520:arraySizeOutOfBounds:
3520#    la $a0,arraySizeOutOfBoundsMsg
3524#    j exitError
3528:nullPtrException:
3528#    la $a0,nullPtrExceptionMsg
3532#    j exitError
3536:badIntegerFormat:
3536#    la $a0,badIntegerFormatMsg
3540#    j exitError
3544:castException:
3544#    la $a0,castExceptionMsg
3548#    j exitError
############## data section ################
    .data
3748:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3764:cur_seg:
    .word 0

3768:lastCharRead:
    .word -2 # -2 => no buffered character
3772:prevHashConstant:
    .word 0x2785173c
3776:gcCount:
    .word 0

3780:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3807:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3830:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3865:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3899:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3932:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3963:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4011:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4032:gcMsg: 
      .asciiz "\nGC!\n"
4038:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4070:nullStr:
    .asciiz "null"
4075:trueString:
    .asciiz "true"
4080:falseString:
    .asciiz "false"
4086:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4105:newlineString:
    .asciiz "\n"
    
    .align 2
4108:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4112:seg0_start:
    .space 0x100000
1052688:seg0_end:
1052688:seg1_start:
    .space 0x100000
2101264:seg1_end:

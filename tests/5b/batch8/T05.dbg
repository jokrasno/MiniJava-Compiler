#   - $t0 - value that was read
###################################################################
18596:mth_readInt_Lib:

    # save $ra by pushing onto stack
18596#    subu $sp,$sp,4
18600#    sw $ra,($sp)

18604:  riSkipWhiteLoop:
    # read a character
18604#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
18608#    subu $t0,$v0,32
18612#    bgt $t0,$zero,nonWhite
18613##...slt $at,$zero,$t0
18617##...bne $at,$zero,18660
18620#    beq $t0,$zero,riSkipWhiteLoop # start over if space
18624#    subu $t0,$v0,10
18628#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
18632#    subu $t0,$v0,9
18636#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
18640#    subu $t0,$v0,13
18644#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
18648#    subu $t0,$v0,12
18652#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
18656#    j badIntegerFormat # illegal integer char: abort program

18660:  nonWhite:
18660#    subu $t0,$v0,'-'
18664#    li $t4,1 # final multiplier
18668#    bne $t0,$zero,helpReadInt # go read
18672#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
18676#    jal readLogicalChar

18680:  helpReadInt:
18680#    li $t2,10
18684#    subu $t1,$v0,'0' # convert digit to 0-9 value
18688#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
18689##...sltu $at,$t1,$t2
18693##...beq $at,$zero,20940
18696#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

18700:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

18700#    jal readLogicalChar # read next character
18704#    subu $t1,$v0,'0' # convert digit to 0-9 value
18708#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
18709##...sltu $at,$t1,$t2
18713##...beq $at,$zero,18732

18716#    mul $t3,$t3,$t2 # multiply old value by 10
18717##...mult $t3,$t2
18721##...mflo $t3
18724#    addu $t3,$t3,$t1 # add in value of new digit
18728#    j digitLoop

18732:  doneDigitLoop:

    # "push back" unused character into queue
18732#    sw $v0,lastCharRead

    # restore return address
18736#    lw $ra,($sp)
18740#    addu $sp, 4

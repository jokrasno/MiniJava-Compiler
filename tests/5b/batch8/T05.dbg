########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
19896:readLogicalChar:

    # check if we already have a character
19896#    lw $v0,lastCharRead
19900#    li $t0,-2
19904#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
19908#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
19912#    jr $ra # return
    
19916:  doReadCh:
    # we need to actually read a character: read and return
19916#    li $v0,12 # use system call to read a character
19920#    syscall
19924#    jr $ra # return

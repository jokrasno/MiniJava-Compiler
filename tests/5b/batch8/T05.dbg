    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
20656#    sw $zero,-8($t1) # 0 in first header-slot
20660#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
20664#    sw $t8,($t0)

20668:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
20668#    addu $t0,$t0,4
20672#    bltu $t0,$s1,gcNextPointerInObject
20673##...sltu $at,$t0,$s1
20677##...bne $at,$zero,20516

20680:  gcTestIterDone2:
20680#    bltu $t0,$s3,gcHeapCopyLoop
20681##...sltu $at,$t0,$s3
20685##...bne $at,$zero,20400

    ###### end outer loop to copy all non-stack-direct objects ######

20688:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
20688#    lw $s2,($sp)
20692#    addu $sp,$sp,4

    # mark us as having already GC'd
20696#    move $t5,$s5

    # go try and allocate again
20700#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
20704:vm_init:

    # mark bottom of stack
20704#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
20708#    move $s2,$zero

    #set up the "five" register
20712#    li $s5,5

20716#    la $s3,seg0_start
20720#    la $s4,seg0_end
20721##...lui $s4,16
20725##...addiu $s4,$s4,21624
    
    # return
20728#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
20732:divide:
    # get parameters; abort if divisor zero
20732#    lw $t0,($sp)
20736#    lw $t1,8($sp)
20740#    beq $t0,$zero,divByZeroError
    
    # perform division
20744#    div $t1,$t0
20748#    mflo $t0

    # store result, adjust stack and return
20752#    addu $sp,$sp,8 # adjust stack
20756#    sw $t0,($sp) # store result
20760#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
20764:remainder:
    # get parameters; abort if divisor zero
20764#    lw $t0,($sp)
20768#    lw $t1,8($sp)
20772#    beq $t0,$zero,divByZeroError
    
    # perform division
20776#    div $t1,$t0
20780#    mfhi $t0

    # store result, adjust stack and return
20784#    addu $sp,$sp,8 # adjust stack
20788#    sw $t0,($sp) # store result
20792#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
20796:checkCast:
    # get object, allow immediately if null
20796#    lw $t2,($sp)
20800#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
20804#    lw $t2,-12($t2) # vtable address
20808#    bge $t2,$t1,castException
20809##...slt $at,$t2,$t1
20813##...beq $at,$zero,20948
20816#    blt $t2,$t0,castException
20817##...slt $at,$t2,$t0
20821##...bne $at,$zero,20948
    
    # return, leaving object unchanged on stack
20824:  checkCastReturn:    
20824#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
20828:instanceOf:
    # get object, go return false if null
20828#    lw $t2,($sp)
20832#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
20836#    lw $t2,-12($t2) # vtable address
20840#    sge $t0,$t2,$t0 # are we >= the lower limit?
20841##...slt $t0,$t2,$t0
20845##...xori $t0,$t0,0x1
20848#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
20852#    and $t2,$t0,$t1
20856#    sw $t2,($sp)
20860:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
20860#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

20864:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
20864#    li $v0,4 # syscall-code for print-string
20868#    syscall
20872:exit:
    # print termination message
20872#    li $v0,4 # syscall-code for print-string
20876#    la $a0,exitString
20880#    syscall

    # terminate execution
20884#    li $v0,10 #syscall-code for "exit"
20888#    syscall

20892:outOfHeapMemory:
20892#    la $a0,heapMemoryMsg
20896#    j exitError
20900:divByZeroError:
20900#    la $a0,divByZeroMsg
20904#    j exitError
20908:strIndexOutOfBounds:
20908#    la $a0,strIndexOutOfBoundsMsg
20912#    j exitError
20916:arrayIndexOutOfBounds:
20916#    la $a0,arrayIndexOutOfBoundsMsg
20920#    j exitError
20924:arraySizeOutOfBounds:
20924#    la $a0,arraySizeOutOfBoundsMsg
20928#    j exitError
20932:nullPtrException:
20932#    la $a0,nullPtrExceptionMsg
20936#    j exitError
20940:badIntegerFormat:
20940#    la $a0,badIntegerFormatMsg
20944#    j exitError
20948:castException:
20948#    la $a0,castExceptionMsg
20952#    j exitError
############## data section ################
    .data
21260:hexChars:
    .ascii "0123456789abcdef"
    .align 2
21276:cur_seg:
    .word 0

21280:lastCharRead:
    .word -2 # -2 => no buffered character
21284:prevHashConstant:
    .word 0x2785173c
21288:gcCount:
    .word 0

21292:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
21319:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
21342:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
21377:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
21411:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
21444:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
21475:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
21523:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
21544:gcMsg: 
      .asciiz "\nGC!\n"
21550:gcCountMsg: 
      .asciiz "Number of garbage collections: "

21582:nullStr:
    .asciiz "null"
21587:trueString:
    .asciiz "true"
21592:falseString:
    .asciiz "false"
21598:exitString:
    .ascii "Program terminated."
    #### "falls through" here
21617:newlineString:
    .asciiz "\n"
    
    .align 2
21620:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

21624:seg0_start:
    .space 0x100000
1070200:seg0_end:
1070200:seg1_start:
    .space 0x100000
2118776:seg1_end:

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
17852:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
17852#    lw $t0,-8($s2) # get word with hash bits from this
17856#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
17860#    addu $t0,$t1

17864#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
17868:mth_equals_Object:
17868#    move $t0,$s2 # first pointer (this)
17872#    lw $t1,($sp) # second pointer
17876#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
17877##...subu $at,$t0,$t1
17881##...sltiu $t0,$at,1

17884#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
17888:mth_hashCode_String:
17888#    move $t0,$s2 # put this pointer in t0

17892#    li $t2,0 # current hash value
17896#    lw $t1,-4($t0) # negative of number of characters in string
17900#    beq $t1,$zero,done_hashCode_String # if zero length => done
17904#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
17908#    and $t0,0xfffffffc # adjust for padding
17909##...lui $at,65535
17913##...ori $at,$at,0xfffc
17917##...and $t0,$t0,$at
17920#    subu $t1,$t0,$t1 # address at end of string +12
17924:loop_hashCode_String:    
17924#    sll $t4,$t2,5 # multiply by 32
17928#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
17932#    lbu $t3,-12($t0) # current character
17936#    addu $t2,$t3 # add in current character
17940#    addu $t0,1 # go to next character's address
17944#    bne $t0,$t1,loop_hashCode_String # loop back if more
17948:done_hashCode_String:    

    # push int on stack
17948#    move $t0, $t2 # put $t2 in return slot
17952#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
17956:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
17956#    subu $sp,4
17960#    sw $ra,($sp)
    
    # get hash value
17964#    lw $t2,-12($s2) # vtable address
17968#    lw $t0,($t2) # method address
17972#    jalr $t0
17976#    subu $sp,8 # push result (int in $t0) on stack
17980#    sw $s5,4($sp)
17984#    sw $t0,($sp)

    # compute print-size of hash value
17988#    li $t0, 1
17992#    lw $t1, ($sp)
17996#    srl $t1,$t1,4
18000#    beq $t1,$zero,toString_skip_loop
18004:toString_loop_top:
18004#    addu $t0,1
18008#    srl $t1,$t1,4
18012#    bne $t1,$zero,toString_loop_top
18016:toString_skip_loop:
18016#    subu $sp,8
18020#    sw $s5,4($sp)
18024#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
18028#    lw $t2,-12($s2) # vtable address
18032#    move $t0,$t2
18036:toString_checkTagBit:
18036#    subu $t0,1
18040#    lb $t1,($t0)
18044#    and $t1,0x80
18045##...lui $at,0
18049##...ori $at,$at,0x80
18053##...and $t1,$t1,$at
18056#    beq $t1,$zero,toString_checkTagBit
18060#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
18064#    subu $sp,8
18068#    sw $t1,($sp)
18072#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
18076#    move $s7,$zero # -4 offset header word
18080#    lw $t4,8($sp) # bytes for hash value
18084#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
18088#    addu $t4,8
18092#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
18096#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

18100#    li $t0,CLASS_String # store string vtable address into ...
18104#    sw $t0,-12($s7) # ... -12 offset in object header
18108#    lw $t2,-12($s2) # our object's vtable address
18112#    lw $t5,4($sp) # number characters in prefix
18116#    lw $t1,12($sp) # number of characters in hashcode
18120#    addu $t3,$t1,$t5 # number of characters in string ...
18124#    addu $t3,1 # ... including the '@' character
18128#    subu $t0,$zero,$t3 # store negated length into ...
18132#    sw $t0,-4($s7) # ... -4 offset header word
18136#    lw $t0,-8($s7) # get -8 offset header-word
18140#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
18141##...slt $at,$t0,$zero
18145##...beq $at,$zero,18164
18148#    and $t0,0xff # mask off object's hash value ...
18149##...lui $at,0
18153##...ori $at,$at,0xff
18157##...and $t0,$t0,$at
18160#    sw $t0,-8($s7) # ... and store back into -8 header-word
18164:skipMask_toString:
18164#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
18168#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
18172#    subu $t4,$t2,$t5
18176:toString_copyLoop:    
18176#    lb $t3,($t4)
18180#    and $t3,0x7f # mask off sign bit (in case first word)
18181##...lui $at,0
18185##...ori $at,$at,0x7f
18189##...and $t3,$t3,$at
18192#    sb $t3,-8($t0)
18196#    addu $t4,1
18200#    addu $t0,1
18204#    blt $t4,$t2,toString_copyLoop
18205##...slt $at,$t4,$t2
18209##...bne $at,$zero,18176

    # copy the '@' sign
18212#    li $t3,'@'
18216#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
18220#    addu $t2,$t0,$t1 # address of last byte in string to store +8
18224#    lw $t3,20($sp) # hash code to print
18228:toString_hashCopyLoop:
18228#    and $t4,$t3,0xf
18232#    srl $t3,4
18236#    lb $t4,hexChars($t4)
18240#    sb $t4,-8($t2)
18244#    subu $t2,$t2,1
18248#    bgt $t2,$t0,toString_hashCopyLoop
18249##...slt $at,$t0,$t2
18253##...bne $at,$zero,18228

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
18256#    addu $sp,28
18260#    lw $ra,($sp)
18264#    addu $sp,4

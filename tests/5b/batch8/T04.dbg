4025##...slt $at,$t3,$zero
4029##...beq $at,$zero,4036
4032#    move $t3,$zero
4036:  gcH2Neg1:
4036#    sll $t3,$t3,2
4040#    addu $t3,$t3,$t1 # address one word past last word of source

4044#    addu $t2,$s3,$t2 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object (i.e., the address just beyond the object's header)
    # - $t2 contains the pointer to the target object
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0-2
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger" in the target space
4048#    lw $s0,($t4)
4052#    lw $s1,-8($t1)
4056#    sw $s1,($t4)
4060#    sw $s0,-8($t1)
    
    # copy all source bytes to the target
4064:  gCinnerCopy1:
4064#    lw $s0,($t4)
4068#    sw $s0,($s3)
4072#    addu $t4,$t4,4
4076#    addu $s3,$s3,4
4080#    bltu $t4,$t3,gCinnerCopy1
4081##...sltu $at,$t4,$t3
4085##...bne $at,$zero,4064

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4088#    sw $zero,-8($t1) # 0 in first header-slot
4092#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
4096#    sw $t2,4($t0)
4100#    lw $zero,-8($t2)
4104#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
4108#    j gcTestIterDone1

4112:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
4112#    subu $t0,$t0,$t1
4116#    subu $t0,$t0,3

4120:  gcTestIterDone1:
4120#    bgeu $t0,$sp,gcStackCopyLoop
4121##...sltu $at,$t0,$sp
4125##...beq $at,$zero,3936

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
4128#    lw $t1,cur_seg
4132#    la $t0,seg0_start
4136#    beq $t1,$zero,gcSkip4
4140#    la $t0,seg1_start
4141##...lui $t0,16
4145##...addiu $t0,$t0,5312


4148:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
4148#    bgeu $t0,$s3,gcFinishUp
4149##...sltu $at,$t0,$s3
4153##...beq $at,$zero,4444

    ###### begin outer loop to copy all non-stack-direct objects ######

4156:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
4156#    lw $t1,($t0) # (what will be) first header word for current object
4160#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
4164#    bge $t2,$zero,gcSkip4a # are there hash bits?
4165##...slt $at,$t2,$zero
4169##...beq $at,$zero,4184
4172#    and $t2,0xff # mask off hash bits
4173##...lui $at,0
4177##...ori $at,$at,0xff
4181##...and $t2,$t2,$at
4184:gcSkip4a:    
4184#    sll $t2,$t2,2 # # data bytes
4188#    addu $t2,$t2,8 # to skip header words
4192#    addu $t2,$t0,$t2 # pointer to new object
4196#    lw $t3,-8($t2) # word to swap
4200#    sw $t1,-8($t2) # store header word
4204#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
4208#    lw $t1,-12($t2) # vtable pointer
4212#    li $t0,dataArrayVTableStart # address of vtable for first data array
4216#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
4217##...slt $at,$t1,$t0
4221##...bne $at,$zero,4240

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
4224:  skipToNextObj:
4224#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
4228#    sll $t1,$t1,2 # convert to byte-count
4232#    addu $t0,$t2,$t1 # skip over object
4236#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
4240:  gcNotDataArray:
4240#    lw $t3,-4($t2) # # object words (negative treated as zero)
4244#    bge $t3,$zero,gcH2Neg2
4245##...slt $at,$t3,$zero
4249##...beq $at,$zero,4256
4252#    move $t3,$zero
4256:  gcH2Neg2:
4256#    sll $t3,$t3,2 # # object bytes
4260#    move $t0,$t2 # address of first pointer in object
4264#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
4268#    beq $t0,$s1,gcTestIterDone2
    
4272:  gcNextPointerInObject:
    # get pointer from object
4272#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
4276#    bleu $t1,$t6,gcGoNextPointerSlot
4277##...sltu $at,$t6,$t1
4281##...beq $at,$zero,4424
4284#    bgtu $t1,$t7,gcGoNextPointerSlot
4285##...sltu $at,$t7,$t1
4289##...bne $at,$zero,4424

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4292#    lw $t8,-8($t1) # possible forwarding tag
4296#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
4300#    lw $t8,-4($t1) # forwarding pointer: object's new address
4304#    sw $t8,($t0) # update pointer in object
4308#    j gcGoNextPointerSlot # do next iteration

4312:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
4312#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
4313##...slt $at,$t8,$zero
4317##...beq $at,$zero,4332
4320#    and $t8,0xff # mask off hash bits
4321##...lui $at,0
4325##...ori $at,$at,0xff
4329##...and $t8,$t8,$at

4332:  gcSkip5:
4332#    sll $t8,$t8,2 # bytes in negative-offset portion ...
4336#    addu $t8,$t8,8 # ... add in bytes for header-words
4340#    subu $t4,$t1,$t8 # address of first word of source object
4344#    lw $t3,-4($t1) # # words in positive-offset portion
4348#    bge $t3,$zero,gcNoNeg
4349##...slt $at,$t3,$zero
4353##...beq $at,$zero,4360
4356#    move $t3,$zero # negative treated as zero
4360:  gcNoNeg:
4360#    sll $t3,$t3,2 # bytes in negative-offset portion
4364#    addu $t3,$t3,$t1 # address one word past last word of source

4368#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4372#    lw $s0,($t4)
4376#    lw $t9,-8($t1)
4380#    sw $t9,($t4)
4384#    sw $s0,-8($t1)

    # copy all source bytes to the target
4388:  gCinnerCopy2:
4388#    lw $s0,($t4)
4392#    sw $s0,($s3)
4396#    addu $t4,$t4,4
4400#    addu $s3,$s3,4
4404#    bltu $t4,$t3,gCinnerCopy2
4405##...sltu $at,$t4,$t3
4409##...bne $at,$zero,4388

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4412#    sw $zero,-8($t1) # 0 in first header-slot
4416#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4420#    sw $t8,($t0)

4424:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4424#    addu $t0,$t0,4
4428#    bltu $t0,$s1,gcNextPointerInObject
4429##...sltu $at,$t0,$s1
4433##...bne $at,$zero,4272

4436:  gcTestIterDone2:
4436#    bltu $t0,$s3,gcHeapCopyLoop
4437##...sltu $at,$t0,$s3
4441##...bne $at,$zero,4156

    ###### end outer loop to copy all non-stack-direct objects ######

4444:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4444#    lw $s2,($sp)
4448#    addu $sp,$sp,4

    # mark us as having already GC'd
4452#    move $t5,$s5

    # go try and allocate again
4456#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4460:vm_init:

    # mark bottom of stack
4460#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4464#    move $s2,$zero

    #set up the "five" register
4468#    li $s5,5

4472#    la $s3,seg0_start
4476#    la $s4,seg0_end
4477##...lui $s4,16
4481##...addiu $s4,$s4,5312
    
    # return
4484#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4488:divide:
    # get parameters; abort if divisor zero
4488#    lw $t0,($sp)
4492#    lw $t1,8($sp)
4496#    beq $t0,$zero,divByZeroError
    
    # perform division
4500#    div $t1,$t0
4504#    mflo $t0

    # store result, adjust stack and return
4508#    addu $sp,$sp,8 # adjust stack
4512#    sw $t0,($sp) # store result
4516#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4520:remainder:
    # get parameters; abort if divisor zero
4520#    lw $t0,($sp)
4524#    lw $t1,8($sp)
4528#    beq $t0,$zero,divByZeroError
    
    # perform division
4532#    div $t1,$t0
4536#    mfhi $t0

    # store result, adjust stack and return
4540#    addu $sp,$sp,8 # adjust stack
4544#    sw $t0,($sp) # store result
4548#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4552:checkCast:
    # get object, allow immediately if null
4552#    lw $t2,($sp)
4556#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4560#    lw $t2,-12($t2) # vtable address
4564#    bge $t2,$t1,castException
4565##...slt $at,$t2,$t1
4569##...beq $at,$zero,4704
4572#    blt $t2,$t0,castException
4573##...slt $at,$t2,$t0
4577##...bne $at,$zero,4704
    
    # return, leaving object unchanged on stack
4580:  checkCastReturn:    
4580#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4584:instanceOf:
    # get object, go return false if null
4584#    lw $t2,($sp)
4588#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4592#    lw $t2,-12($t2) # vtable address
4596#    sge $t0,$t2,$t0 # are we >= the lower limit?
4597##...slt $t0,$t2,$t0
4601##...xori $t0,$t0,0x1
4604#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4608#    and $t2,$t0,$t1
4612#    sw $t2,($sp)
4616:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4616#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4620:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4620#    li $v0,4 # syscall-code for print-string
4624#    syscall
4628:exit:
    # print termination message
4628#    li $v0,4 # syscall-code for print-string
4632#    la $a0,exitString
4636#    syscall

    # terminate execution
4640#    li $v0,10 #syscall-code for "exit"
4644#    syscall

4648:outOfHeapMemory:
4648#    la $a0,heapMemoryMsg
4652#    j exitError
4656:divByZeroError:
4656#    la $a0,divByZeroMsg
4660#    j exitError
4664:strIndexOutOfBounds:
4664#    la $a0,strIndexOutOfBoundsMsg
4668#    j exitError
4672:arrayIndexOutOfBounds:
4672#    la $a0,arrayIndexOutOfBoundsMsg
4676#    j exitError
4680:arraySizeOutOfBounds:
4680#    la $a0,arraySizeOutOfBoundsMsg
4684#    j exitError
4688:nullPtrException:
4688#    la $a0,nullPtrExceptionMsg
4692#    j exitError
4696:badIntegerFormat:
4696#    la $a0,badIntegerFormatMsg
4700#    j exitError
4704:castException:
4704#    la $a0,castExceptionMsg
4708#    j exitError
############## data section ################
    .data
4948:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4964:cur_seg:
    .word 0

4968:lastCharRead:
    .word -2 # -2 => no buffered character
4972:prevHashConstant:
    .word 0x2785173c
4976:gcCount:
    .word 0

4980:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5007:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5030:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5065:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5099:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5132:nullPtrExceptionMsg:


4008:  gcSkip2:
4008#    sll $t2,$t2,2
4012#    addu $t2,$t2,8
4016#    subu $t4,$t1,$t2 # address of first word of source
4020#    lw $t3,-4($t1) # number of object words (negative means zero)

# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1608:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1608#    lw $t0,-8($s2) # get word with hash bits from this
1612#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1616#    addu $t0,$t1

1620#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1624:mth_equals_Object:
1624#    move $t0,$s2 # first pointer (this)
1628#    lw $t1,($sp) # second pointer
1632#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1633##...subu $at,$t0,$t1
1637##...sltiu $t0,$at,1

1640#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1644:mth_hashCode_String:
1644#    move $t0,$s2 # put this pointer in t0

1648#    li $t2,0 # current hash value
1652#    lw $t1,-4($t0) # negative of number of characters in string
1656#    beq $t1,$zero,done_hashCode_String # if zero length => done
1660#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1664#    and $t0,0xfffffffc # adjust for padding
1665##...lui $at,65535
1669##...ori $at,$at,0xfffc
1673##...and $t0,$t0,$at
1676#    subu $t1,$t0,$t1 # address at end of string +12
1680:loop_hashCode_String:    
1680#    sll $t4,$t2,5 # multiply by 32
1684#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1688#    lbu $t3,-12($t0) # current character
1692#    addu $t2,$t3 # add in current character
1696#    addu $t0,1 # go to next character's address
1700#    bne $t0,$t1,loop_hashCode_String # loop back if more
1704:done_hashCode_String:    

    # push int on stack
1704#    move $t0, $t2 # put $t2 in return slot
1708#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1712:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1712#    subu $sp,4
1716#    sw $ra,($sp)
    
    # get hash value
1720#    lw $t2,-12($s2) # vtable address
1724#    lw $t0,($t2) # method address
1728#    jalr $t0
1732#    subu $sp,8 # push result (int in $t0) on stack
1736#    sw $s5,4($sp)
1740#    sw $t0,($sp)

    # compute print-size of hash value
1744#    li $t0, 1
1748#    lw $t1, ($sp)
1752#    srl $t1,$t1,4
1756#    beq $t1,$zero,toString_skip_loop
1760:toString_loop_top:
1760#    addu $t0,1
1764#    srl $t1,$t1,4
1768#    bne $t1,$zero,toString_loop_top
1772:toString_skip_loop:
1772#    subu $sp,8
1776#    sw $s5,4($sp)
1780#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1784#    lw $t2,-12($s2) # vtable address
1788#    move $t0,$t2
1792:toString_checkTagBit:
1792#    subu $t0,1
1796#    lb $t1,($t0)
1800#    and $t1,0x80
1801##...lui $at,0
1805##...ori $at,$at,0x80
1809##...and $t1,$t1,$at
1812#    beq $t1,$zero,toString_checkTagBit
1816#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1820#    subu $sp,8
1824#    sw $t1,($sp)
1828#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1832#    move $s7,$zero # -4 offset header word
1836#    lw $t4,8($sp) # bytes for hash value
1840#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1844#    addu $t4,8
1848#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1852#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1856#    li $t0,CLASS_String # store string vtable address into ...
1860#    sw $t0,-12($s7) # ... -12 offset in object header
1864#    lw $t2,-12($s2) # our object's vtable address
1868#    lw $t5,4($sp) # number characters in prefix
1872#    lw $t1,12($sp) # number of characters in hashcode
1876#    addu $t3,$t1,$t5 # number of characters in string ...
1880#    addu $t3,1 # ... including the '@' character
1884#    subu $t0,$zero,$t3 # store negated length into ...
1888#    sw $t0,-4($s7) # ... -4 offset header word
1892#    lw $t0,-8($s7) # get -8 offset header-word
1896#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1897##...slt $at,$t0,$zero
1901##...beq $at,$zero,1920
1904#    and $t0,0xff # mask off object's hash value ...
1905##...lui $at,0
1909##...ori $at,$at,0xff
1913##...and $t0,$t0,$at
1916#    sw $t0,-8($s7) # ... and store back into -8 header-word
1920:skipMask_toString:
1920#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1924#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1928#    subu $t4,$t2,$t5
1932:toString_copyLoop:    
1932#    lb $t3,($t4)
1936#    and $t3,0x7f # mask off sign bit (in case first word)
1937##...lui $at,0
1941##...ori $at,$at,0x7f
1945##...and $t3,$t3,$at
1948#    sb $t3,-8($t0)
1952#    addu $t4,1
1956#    addu $t0,1
1960#    blt $t4,$t2,toString_copyLoop
1961##...slt $at,$t4,$t2
1965##...bne $at,$zero,1932

    # copy the '@' sign
1968#    li $t3,'@'
1972#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1976#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1980#    lw $t3,20($sp) # hash code to print
1984:toString_hashCopyLoop:
1984#    and $t4,$t3,0xf
1988#    srl $t3,4
1992#    lb $t4,hexChars($t4)
1996#    sb $t4,-8($t2)
2000#    subu $t2,$t2,1
2004#    bgt $t2,$t0,toString_hashCopyLoop
2005##...slt $at,$t0,$t2
2009##...bne $at,$zero,1984

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2012#    addu $sp,28
2016#    lw $ra,($sp)
2020#    addu $sp,4
2024#    move $t0, $s7 # return string we created
2028#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2032:mth_equals_String:
    
    # quick test for obvious false
2032#    lw $t0,($sp) # second parameter
2036#    beq $t0,$zero,goEsFalse # go return false if null
2040#    lw $t1,-12($t0) # vtable pointer
2044#    la $t2,CLASS_String # string vtable pointer
2048#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2052#    subu $sp,12
2056#    sw $ra,8($sp)
2060#    sw $s2,4($sp)
2064#    sw $t0,($sp)
2068#    jal mth_compareTo_String
2072#    lw $s2, 4($sp) #restore this pointer and pop parameters
2076#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2080#    seq $t0,$t0,$zero
2081##...subu $at,$t0,$zero
2085##...sltiu $t0,$at,1

    # pop return address and return $t0
2088#    lw $ra,($sp)
2092#    addu $sp,4

2096#    jr $ra # return
    
2100:goEsFalse:
    # put 0 in $t0 and return
2100#    li $t0, 0
2104#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2108:mth_toString_String:
    #we are a string, so return this.
2108#    move $t0, $s2
2112#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2116:mth_readLine_Lib:
    
2116#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2120#    sw $ra, 4($sp) # save $ra
2124#    move $t1,$sp # save "original" sp

2128:  doRead:

    # read the character
2128#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2132#    subu $t2,$v0,13
2136#    bne $t2,$zero,notReturnRL
2140#    jal readLogicalChar
2144#    subu $t2,$v0,10 # check for newline
2148#    beq $t2,$zero,foundNewLine
2152#    sw $v0,lastCharRead # push back character into queue
2156#    j foundNewLine # go process the line

2160:  notReturnRL:

    # at this point, $v0 has our character

2160#    subu $t0,$v0,10
2164#    beq $t0,$zero,foundNewLine
2168#    blt $v0,$zero,foundEof
2169##...slt $at,$v0,$zero
2173##...bne $at,$zero,2188

    # we have a character, so push it onto stack
2176#    subu $sp,$sp,4
2180#    sw $v0,($sp)

    # loop back up to get next character
2184#    j doRead

2188:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2188#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2192#    li $s7, 0 # return-value: null
2196#    j rlReturn # return

2200:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2200#    subu $t0,$t1,$sp # number of chars we read (times 4)
2204#    srl $s6,$t0,2 # number of words on stack with chars
2208#    subu $sp,$sp,4 # push char-count ...
2212#    sw $s6,($sp) # ... onto stack
2216#    addu $t2,$t0,5 # GC tag, incl. for count-word
2220#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2224#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2228#    srl $s6,$s6,2  # data words in object
2232#    move $s7,$zero # object words in object
2236#    jal newObject  # allocate space
    
    # store header words
2240#    la $t0,CLASS_String
2244#    sw $t0,-12($s7)# store class tag (String) into object
2248#    lw $t2,4($sp) # char-count
2252#    sll $t1,$t2,2 # 4 times number of chars
2256#    subu $t2,$zero,$t2 # negative of char-count
2260#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2264#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2268#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2269##...slt $at,$t0,$zero
2273##...beq $at,$zero,2292
2276#    and $t0,0xff # mask off object's hash value ...
2277##...lui $at,0
2281##...ori $at,$at,0xff
2285##...and $t0,$t0,$at
2288#    sw $t0,-8($s7) # ... and store back into -8 header-word
2292:  skipMask_readLine:

2292#    sll $t0,$t0,2 # data bytes in object
2296#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2300#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2304#    addu $sp,$sp,8 # pop redundant object-pointer and count
2308#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2312#    beq $sp,$t1,rlReturn
2316:  charCopyLoop:
2316#    lw $t2,($sp)
2320#    sb $t2,-9($t0)
2324#    addu $sp,$sp,4
2328#    subu $t0,$t0,1
2332#    bne $sp,$t1,charCopyLoop
2336:  rlReturn:

2336#    lw $ra, 4($sp)
2340#    addu $sp, 8   # pop $ra and pointless word off stack
2344#    move $t0, $s7 # return string we allocated in $s7
2348#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2352:mth_readInt_Lib:

    # save $ra by pushing onto stack
2352#    subu $sp,$sp,4
2356#    sw $ra,($sp)

2360:  riSkipWhiteLoop:
    # read a character
2360#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2364#    subu $t0,$v0,32
2368#    bgt $t0,$zero,nonWhite

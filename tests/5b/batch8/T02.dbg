3568#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
3572#    lw $t4,-8($s7) # # data words in source string
3576#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
3577##...slt $at,$t4,$zero
3581##...beq $at,$zero,3600
3584#    and $t4,0xff # mask off object's hash value ...
3585##...lui $at,0
3589##...ori $at,$at,0xff
3593##...and $t4,$t4,$at
3596#    sw $t4,-8($s7) # ... and store back into -8 header-word
3600:  skipMask_intToChar:

    # store data in string
3600#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
3604#    li $t0,-1
3608#    sw $t0,-4($s7)

    # we're returning $s7
3612#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
3616#    lw $ra,4($sp)
3620#    addu $sp,$sp,8

    # return
3624#    jr $ra

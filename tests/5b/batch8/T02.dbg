    # greater
3724#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
3728#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
3732#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
3736:  cmpHitLimitzz:
3736#    move $t0, $t5 # store return value
3740#    jr $ra # return

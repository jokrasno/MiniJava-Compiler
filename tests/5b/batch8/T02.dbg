3457##...ori $at,$at,0xff
3461##...and $t4,$t4,$at
3464#    sw $t4,($s7) # ... and store back into -8 header-word
3468:skipMask_intToString:
    
    # store negative of char-count into header-2 word
3468#    subu $t0,$zero,$t0

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4552:vm_init:

    # mark bottom of stack
4552#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4556#    move $s2,$zero

    #set up the "five" register
4560#    li $s5,5

4564#    la $s3,seg0_start
4568#    la $s4,seg0_end
4569##...lui $s4,16
4573##...addiu $s4,$s4,5412
    
    # return
4576#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4580:divide:
    # get parameters; abort if divisor zero
4580#    lw $t0,($sp)
4584#    lw $t1,8($sp)
4588#    beq $t0,$zero,divByZeroError
    
    # perform division
4592#    div $t1,$t0
4596#    mflo $t0

    # store result, adjust stack and return
4600#    addu $sp,$sp,8 # adjust stack
4604#    sw $t0,($sp) # store result
4608#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4612:remainder:
    # get parameters; abort if divisor zero
4612#    lw $t0,($sp)
4616#    lw $t1,8($sp)
4620#    beq $t0,$zero,divByZeroError
    
    # perform division
4624#    div $t1,$t0
4628#    mfhi $t0

    # store result, adjust stack and return
4632#    addu $sp,$sp,8 # adjust stack
4636#    sw $t0,($sp) # store result
4640#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4644:checkCast:
    # get object, allow immediately if null
4644#    lw $t2,($sp)
4648#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4652#    lw $t2,-12($t2) # vtable address
4656#    bge $t2,$t1,castException
4657##...slt $at,$t2,$t1
4661##...beq $at,$zero,4796
4664#    blt $t2,$t0,castException
4665##...slt $at,$t2,$t0
4669##...bne $at,$zero,4796
    
    # return, leaving object unchanged on stack
4672:  checkCastReturn:    
4672#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4676:instanceOf:
    # get object, go return false if null
4676#    lw $t2,($sp)
4680#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4684#    lw $t2,-12($t2) # vtable address
4688#    sge $t0,$t2,$t0 # are we >= the lower limit?
4689##...slt $t0,$t2,$t0
4693##...xori $t0,$t0,0x1
4696#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4700#    and $t2,$t0,$t1
4704#    sw $t2,($sp)
4708:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4708#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4712:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4712#    li $v0,4 # syscall-code for print-string
4716#    syscall
4720:exit:
    # print termination message
4720#    li $v0,4 # syscall-code for print-string
4724#    la $a0,exitString
4728#    syscall

    # terminate execution
4732#    li $v0,10 #syscall-code for "exit"
4736#    syscall

4740:outOfHeapMemory:
4740#    la $a0,heapMemoryMsg
4744#    j exitError
4748:divByZeroError:
4748#    la $a0,divByZeroMsg
4752#    j exitError
4756:strIndexOutOfBounds:
4756#    la $a0,strIndexOutOfBoundsMsg
4760#    j exitError
4764:arrayIndexOutOfBounds:
4764#    la $a0,arrayIndexOutOfBoundsMsg
4768#    j exitError
4772:arraySizeOutOfBounds:
4772#    la $a0,arraySizeOutOfBoundsMsg
4776#    j exitError
4780:nullPtrException:
4780#    la $a0,nullPtrExceptionMsg

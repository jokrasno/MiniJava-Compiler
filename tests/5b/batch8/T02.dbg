
    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
3108#    move $t1,$s2   # first object
3112#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
3116#    lw $t2,-4($t0) # negative length of second object
3120#    lw $t3,-4($t1) # negative length of first object
3124#    addu $t4,$t2,$t3 # sum of negative lengths
3128#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object

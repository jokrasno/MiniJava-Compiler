###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2444:mth_readInt_Lib:

    # save $ra by pushing onto stack
2444#    subu $sp,$sp,4
2448#    sw $ra,($sp)

2452:  riSkipWhiteLoop:
    # read a character
2452#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2456#    subu $t0,$v0,32
2460#    bgt $t0,$zero,nonWhite
2461##...slt $at,$zero,$t0
2465##...bne $at,$zero,2508
2468#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2472#    subu $t0,$v0,10
2476#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2480#    subu $t0,$v0,9
2484#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2488#    subu $t0,$v0,13
2492#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2496#    subu $t0,$v0,12
2500#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2504#    j badIntegerFormat # illegal integer char: abort program

2508:  nonWhite:
2508#    subu $t0,$v0,'-'
2512#    li $t4,1 # final multiplier
2516#    bne $t0,$zero,helpReadInt # go read
2520#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2524#    jal readLogicalChar

2528:  helpReadInt:
2528#    li $t2,10

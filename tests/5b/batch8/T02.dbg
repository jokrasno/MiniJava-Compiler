##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1700:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1700#    lw $t0,-8($s2) # get word with hash bits from this
1704#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1708#    addu $t0,$t1

1712#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1716:mth_equals_Object:
1716#    move $t0,$s2 # first pointer (this)
1720#    lw $t1,($sp) # second pointer
1724#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1725##...subu $at,$t0,$t1
1729##...sltiu $t0,$at,1

1732#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1736:mth_hashCode_String:
1736#    move $t0,$s2 # put this pointer in t0

1740#    li $t2,0 # current hash value
1744#    lw $t1,-4($t0) # negative of number of characters in string
1748#    beq $t1,$zero,done_hashCode_String # if zero length => done
1752#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1756#    and $t0,0xfffffffc # adjust for padding
1757##...lui $at,65535
1761##...ori $at,$at,0xfffc
1765##...and $t0,$t0,$at
1768#    subu $t1,$t0,$t1 # address at end of string +12
1772:loop_hashCode_String:    
1772#    sll $t4,$t2,5 # multiply by 32
1776#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1780#    lbu $t3,-12($t0) # current character
1784#    addu $t2,$t3 # add in current character
1788#    addu $t0,1 # go to next character's address
1792#    bne $t0,$t1,loop_hashCode_String # loop back if more
1796:done_hashCode_String:    

    # push int on stack
1796#    move $t0, $t2 # put $t2 in return slot
1800#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1804:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1804#    subu $sp,4
1808#    sw $ra,($sp)
    
    # get hash value
1812#    lw $t2,-12($s2) # vtable address
1816#    lw $t0,($t2) # method address
1820#    jalr $t0
1824#    subu $sp,8 # push result (int in $t0) on stack
1828#    sw $s5,4($sp)
1832#    sw $t0,($sp)

    # compute print-size of hash value
1836#    li $t0, 1
1840#    lw $t1, ($sp)
1844#    srl $t1,$t1,4
1848#    beq $t1,$zero,toString_skip_loop
1852:toString_loop_top:
1852#    addu $t0,1
1856#    srl $t1,$t1,4
1860#    bne $t1,$zero,toString_loop_top
1864:toString_skip_loop:
1864#    subu $sp,8
1868#    sw $s5,4($sp)
1872#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1876#    lw $t2,-12($s2) # vtable address
1880#    move $t0,$t2
1884:toString_checkTagBit:
1884#    subu $t0,1
1888#    lb $t1,($t0)
1892#    and $t1,0x80
1893##...lui $at,0
1897##...ori $at,$at,0x80
1901##...and $t1,$t1,$at
1904#    beq $t1,$zero,toString_checkTagBit
1908#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1912#    subu $sp,8
1916#    sw $t1,($sp)
1920#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1924#    move $s7,$zero # -4 offset header word
1928#    lw $t4,8($sp) # bytes for hash value
1932#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1936#    addu $t4,8
1940#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1944#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1948#    li $t0,CLASS_String # store string vtable address into ...
1952#    sw $t0,-12($s7) # ... -12 offset in object header
1956#    lw $t2,-12($s2) # our object's vtable address
1960#    lw $t5,4($sp) # number characters in prefix
1964#    lw $t1,12($sp) # number of characters in hashcode
1968#    addu $t3,$t1,$t5 # number of characters in string ...
1972#    addu $t3,1 # ... including the '@' character
1976#    subu $t0,$zero,$t3 # store negated length into ...
1980#    sw $t0,-4($s7) # ... -4 offset header word
1984#    lw $t0,-8($s7) # get -8 offset header-word
1988#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1989##...slt $at,$t0,$zero
1993##...beq $at,$zero,2012
1996#    and $t0,0xff # mask off object's hash value ...
1997##...lui $at,0
2001##...ori $at,$at,0xff
2005##...and $t0,$t0,$at
2008#    sw $t0,-8($s7) # ... and store back into -8 header-word
2012:skipMask_toString:
2012#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2016#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2020#    subu $t4,$t2,$t5
2024:toString_copyLoop:    
2024#    lb $t3,($t4)
2028#    and $t3,0x7f # mask off sign bit (in case first word)
2029##...lui $at,0
2033##...ori $at,$at,0x7f
2037##...and $t3,$t3,$at
2040#    sb $t3,-8($t0)
2044#    addu $t4,1
2048#    addu $t0,1
2052#    blt $t4,$t2,toString_copyLoop
2053##...slt $at,$t4,$t2
2057##...bne $at,$zero,2024

    # copy the '@' sign
2060#    li $t3,'@'
2064#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2068#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2072#    lw $t3,20($sp) # hash code to print
2076:toString_hashCopyLoop:
2076#    and $t4,$t3,0xf
2080#    srl $t3,4
2084#    lb $t4,hexChars($t4)
2088#    sb $t4,-8($t2)
2092#    subu $t2,$t2,1
2096#    bgt $t2,$t0,toString_hashCopyLoop
2097##...slt $at,$t0,$t2
2101##...bne $at,$zero,2076

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2104#    addu $sp,28
2108#    lw $ra,($sp)
2112#    addu $sp,4
2116#    move $t0, $s7 # return string we created
2120#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2124:mth_equals_String:
    
    # quick test for obvious false
2124#    lw $t0,($sp) # second parameter
2128#    beq $t0,$zero,goEsFalse # go return false if null
2132#    lw $t1,-12($t0) # vtable pointer
2136#    la $t2,CLASS_String # string vtable pointer
2140#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2144#    subu $sp,12
2148#    sw $ra,8($sp)
2152#    sw $s2,4($sp)
2156#    sw $t0,($sp)
2160#    jal mth_compareTo_String
2164#    lw $s2, 4($sp) #restore this pointer and pop parameters
2168#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2172#    seq $t0,$t0,$zero
2173##...subu $at,$t0,$zero
2177##...sltiu $t0,$at,1

    # pop return address and return $t0
2180#    lw $ra,($sp)
2184#    addu $sp,4

2188#    jr $ra # return
    
2192:goEsFalse:
    # put 0 in $t0 and return
2192#    li $t0, 0
2196#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2200:mth_toString_String:
    #we are a string, so return this.
2200#    move $t0, $s2
2204#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2208:mth_readLine_Lib:
    
2208#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2212#    sw $ra, 4($sp) # save $ra
2216#    move $t1,$sp # save "original" sp

2220:  doRead:

    # read the character
2220#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2224#    subu $t2,$v0,13
2228#    bne $t2,$zero,notReturnRL
2232#    jal readLogicalChar
2236#    subu $t2,$v0,10 # check for newline
2240#    beq $t2,$zero,foundNewLine
2244#    sw $v0,lastCharRead # push back character into queue
2248#    j foundNewLine # go process the line

2252:  notReturnRL:

    # at this point, $v0 has our character

2252#    subu $t0,$v0,10
2256#    beq $t0,$zero,foundNewLine
2260#    blt $v0,$zero,foundEof
2261##...slt $at,$v0,$zero
2265##...bne $at,$zero,2280

    # we have a character, so push it onto stack
2268#    subu $sp,$sp,4
2272#    sw $v0,($sp)

    # loop back up to get next character
2276#    j doRead

2280:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2280#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2284#    li $s7, 0 # return-value: null
2288#    j rlReturn # return

2292:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2292#    subu $t0,$t1,$sp # number of chars we read (times 4)
2296#    srl $s6,$t0,2 # number of words on stack with chars
2300#    subu $sp,$sp,4 # push char-count ...
2304#    sw $s6,($sp) # ... onto stack
2308#    addu $t2,$t0,5 # GC tag, incl. for count-word
2312#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2316#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2320#    srl $s6,$s6,2  # data words in object
2324#    move $s7,$zero # object words in object
2328#    jal newObject  # allocate space
    
    # store header words
2332#    la $t0,CLASS_String
2336#    sw $t0,-12($s7)# store class tag (String) into object
2340#    lw $t2,4($sp) # char-count
2344#    sll $t1,$t2,2 # 4 times number of chars
2348#    subu $t2,$zero,$t2 # negative of char-count
2352#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2356#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2360#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2361##...slt $at,$t0,$zero
2365##...beq $at,$zero,2384
2368#    and $t0,0xff # mask off object's hash value ...
2369##...lui $at,0
2373##...ori $at,$at,0xff
2377##...and $t0,$t0,$at
2380#    sw $t0,-8($s7) # ... and store back into -8 header-word
2384:  skipMask_readLine:

2384#    sll $t0,$t0,2 # data bytes in object
2388#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2392#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2396#    addu $sp,$sp,8 # pop redundant object-pointer and count
2400#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2404#    beq $sp,$t1,rlReturn
2408:  charCopyLoop:
2408#    lw $t2,($sp)
2412#    sb $t2,-9($t0)
2416#    addu $sp,$sp,4
2420#    subu $t0,$t0,1
2424#    bne $sp,$t1,charCopyLoop
2428:  rlReturn:


4308#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
4309##...slt $at,$t1,$t0
4313##...bne $at,$zero,4332

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
4316:  skipToNextObj:
4316#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
4320#    sll $t1,$t1,2 # convert to byte-count
4324#    addu $t0,$t2,$t1 # skip over object

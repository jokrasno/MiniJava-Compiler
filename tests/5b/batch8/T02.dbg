
    # store second header-value
3908#    sw $s7,-4($t0)   # second header-word
3912#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
3916#    move $s7,$t0
3920#    subu $sp,$sp,4
3924#    sw $t0,($sp)

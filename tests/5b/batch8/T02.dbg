4468#    lw $t9,-8($t1)
4472#    sw $t9,($t4)
4476#    sw $s0,-8($t1)

    # copy all source bytes to the target
4480:  gCinnerCopy2:
4480#    lw $s0,($t4)
4484#    sw $s0,($s3)
4488#    addu $t4,$t4,4
4492#    addu $s3,$s3,4
4496#    bltu $t4,$t3,gCinnerCopy2
4497##...sltu $at,$t4,$t3
4501##...bne $at,$zero,4480

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4504#    sw $zero,-8($t1) # 0 in first header-slot
4508#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4512#    sw $t8,($t0)


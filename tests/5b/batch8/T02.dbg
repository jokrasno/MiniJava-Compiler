    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
4332:  gcNotDataArray:
4332#    lw $t3,-4($t2) # # object words (negative treated as zero)
4336#    bge $t3,$zero,gcH2Neg2
4337##...slt $at,$t3,$zero
4341##...beq $at,$zero,4348
4344#    move $t3,$zero
4348:  gcH2Neg2:
4348#    sll $t3,$t3,2 # # object bytes
4352#    move $t0,$t2 # address of first pointer in object

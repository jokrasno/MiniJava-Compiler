3853##...beq $at,$zero,3900
3856#    lw $t1,prevHashConstant
3860#    addu $t1,0x12b68fd2
3861##...lui $at,4791
3865##...addiu $at,$at,-28718
3869##...addu $t1,$at,$t1
3872#    sw $t1,prevHashConstant # update hash constant
3876#    or $t1,0x80000000 # set top bit
3877##...lui $at,32768
3881##...or $t1,$at,$t1

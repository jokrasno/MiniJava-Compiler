2552#    subu $t1,$v0,'0' # convert digit to 0-9 value
2556#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2557##...sltu $at,$t1,$t2
2561##...beq $at,$zero,2580

2564#    mul $t3,$t3,$t2 # multiply old value by 10
2565##...mult $t3,$t2
2569##...mflo $t3
2572#    addu $t3,$t3,$t1 # add in value of new digit
2576#    j digitLoop

    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
3908#    lw $t1,cur_seg
3912#    la $t0,seg0_start
3916#    beq $t1,$zero,gcSkip4
3920#    la $t0,seg1_start
3921##...lui $t0,16
3925##...addiu $t0,$t0,5100


3928:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
3928#    bgeu $t0,$s3,gcFinishUp
3929##...sltu $at,$t0,$s3
3933##...beq $at,$zero,4224

    ###### begin outer loop to copy all non-stack-direct objects ######

3936:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
3936#    lw $t1,($t0) # (what will be) first header word for current object
3940#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
3944#    bge $t2,$zero,gcSkip4a # are there hash bits?
3945##...slt $at,$t2,$zero
3949##...beq $at,$zero,3964
3952#    and $t2,0xff # mask off hash bits
3953##...lui $at,0
3957##...ori $at,$at,0xff
3961##...and $t2,$t2,$at
3964:gcSkip4a:    
3964#    sll $t2,$t2,2 # # data bytes
3968#    addu $t2,$t2,8 # to skip header words
3972#    addu $t2,$t0,$t2 # pointer to new object
3976#    lw $t3,-8($t2) # word to swap
3980#    sw $t1,-8($t2) # store header word
3984#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3988#    lw $t1,-12($t2) # vtable pointer
3992#    li $t0,dataArrayVTableStart # address of vtable for first data array
3996#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3997##...slt $at,$t1,$t0
4001##...bne $at,$zero,4020

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
4004:  skipToNextObj:
4004#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
4008#    sll $t1,$t1,2 # convert to byte-count
4012#    addu $t0,$t2,$t1 # skip over object
4016#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
4020:  gcNotDataArray:
4020#    lw $t3,-4($t2) # # object words (negative treated as zero)
4024#    bge $t3,$zero,gcH2Neg2
4025##...slt $at,$t3,$zero
4029##...beq $at,$zero,4036
4032#    move $t3,$zero
4036:  gcH2Neg2:
4036#    sll $t3,$t3,2 # # object bytes
4040#    move $t0,$t2 # address of first pointer in object
4044#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
4048#    beq $t0,$s1,gcTestIterDone2
    
4052:  gcNextPointerInObject:
    # get pointer from object
4052#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
4056#    bleu $t1,$t6,gcGoNextPointerSlot
4057##...sltu $at,$t6,$t1
4061##...beq $at,$zero,4204
4064#    bgtu $t1,$t7,gcGoNextPointerSlot
4065##...sltu $at,$t7,$t1
4069##...bne $at,$zero,4204

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4072#    lw $t8,-8($t1) # possible forwarding tag
4076#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
4080#    lw $t8,-4($t1) # forwarding pointer: object's new address
4084#    sw $t8,($t0) # update pointer in object
4088#    j gcGoNextPointerSlot # do next iteration

4092:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
4092#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
4093##...slt $at,$t8,$zero
4097##...beq $at,$zero,4112
4100#    and $t8,0xff # mask off hash bits
4101##...lui $at,0
4105##...ori $at,$at,0xff
4109##...and $t8,$t8,$at

4112:  gcSkip5:
4112#    sll $t8,$t8,2 # bytes in negative-offset portion ...
4116#    addu $t8,$t8,8 # ... add in bytes for header-words
4120#    subu $t4,$t1,$t8 # address of first word of source object
4124#    lw $t3,-4($t1) # # words in positive-offset portion
4128#    bge $t3,$zero,gcNoNeg
4129##...slt $at,$t3,$zero
4133##...beq $at,$zero,4140
4136#    move $t3,$zero # negative treated as zero
4140:  gcNoNeg:
4140#    sll $t3,$t3,2 # bytes in negative-offset portion
4144#    addu $t3,$t3,$t1 # address one word past last word of source

4148#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4152#    lw $s0,($t4)
4156#    lw $t9,-8($t1)
4160#    sw $t9,($t4)
4164#    sw $s0,-8($t1)

    # copy all source bytes to the target
4168:  gCinnerCopy2:
4168#    lw $s0,($t4)
4172#    sw $s0,($s3)
4176#    addu $t4,$t4,4
4180#    addu $s3,$s3,4
4184#    bltu $t4,$t3,gCinnerCopy2
4185##...sltu $at,$t4,$t3
4189##...bne $at,$zero,4168

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4192#    sw $zero,-8($t1) # 0 in first header-slot
4196#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4200#    sw $t8,($t0)

4204:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4204#    addu $t0,$t0,4
4208#    bltu $t0,$s1,gcNextPointerInObject
4209##...sltu $at,$t0,$s1
4213##...bne $at,$zero,4052

4216:  gcTestIterDone2:
4216#    bltu $t0,$s3,gcHeapCopyLoop
4217##...sltu $at,$t0,$s3
4221##...bne $at,$zero,3936

    ###### end outer loop to copy all non-stack-direct objects ######

4224:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4224#    lw $s2,($sp)
4228#    addu $sp,$sp,4

    # mark us as having already GC'd
4232#    move $t5,$s5

    # go try and allocate again
4236#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4240:vm_init:

    # mark bottom of stack
4240#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4244#    move $s2,$zero

    #set up the "five" register
4248#    li $s5,5

4252#    la $s3,seg0_start
4256#    la $s4,seg0_end
4257##...lui $s4,16
4261##...addiu $s4,$s4,5100
    
    # return
4264#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4268:divide:
    # get parameters; abort if divisor zero
4268#    lw $t0,($sp)
4272#    lw $t1,8($sp)
4276#    beq $t0,$zero,divByZeroError
    
    # perform division
4280#    div $t1,$t0
4284#    mflo $t0

    # store result, adjust stack and return
4288#    addu $sp,$sp,8 # adjust stack
4292#    sw $t0,($sp) # store result
4296#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4300:remainder:
    # get parameters; abort if divisor zero
4300#    lw $t0,($sp)
4304#    lw $t1,8($sp)
4308#    beq $t0,$zero,divByZeroError
    
    # perform division
4312#    div $t1,$t0
4316#    mfhi $t0

    # store result, adjust stack and return
4320#    addu $sp,$sp,8 # adjust stack
4324#    sw $t0,($sp) # store result
4328#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4332:checkCast:
    # get object, allow immediately if null
4332#    lw $t2,($sp)
4336#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4340#    lw $t2,-12($t2) # vtable address
4344#    bge $t2,$t1,castException
4345##...slt $at,$t2,$t1
4349##...beq $at,$zero,4484
4352#    blt $t2,$t0,castException
4353##...slt $at,$t2,$t0
4357##...bne $at,$zero,4484
    
    # return, leaving object unchanged on stack
4360:  checkCastReturn:    
4360#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4364:instanceOf:
    # get object, go return false if null
4364#    lw $t2,($sp)
4368#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4372#    lw $t2,-12($t2) # vtable address
4376#    sge $t0,$t2,$t0 # are we >= the lower limit?
4377##...slt $t0,$t2,$t0
4381##...xori $t0,$t0,0x1
4384#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4388#    and $t2,$t0,$t1
4392#    sw $t2,($sp)
4396:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4396#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4400:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4400#    li $v0,4 # syscall-code for print-string
4404#    syscall
4408:exit:
    # print termination message
4408#    li $v0,4 # syscall-code for print-string
4412#    la $a0,exitString
4416#    syscall

    # terminate execution
4420#    li $v0,10 #syscall-code for "exit"
4424#    syscall

4428:outOfHeapMemory:
4428#    la $a0,heapMemoryMsg
4432#    j exitError
4436:divByZeroError:
4436#    la $a0,divByZeroMsg
4440#    j exitError
4444:strIndexOutOfBounds:
4444#    la $a0,strIndexOutOfBoundsMsg
4448#    j exitError
4452:arrayIndexOutOfBounds:
4452#    la $a0,arrayIndexOutOfBoundsMsg
4456#    j exitError
4460:arraySizeOutOfBounds:
4460#    la $a0,arraySizeOutOfBoundsMsg
4464#    j exitError
4468:nullPtrException:
4468#    la $a0,nullPtrExceptionMsg
4472#    j exitError
4476:badIntegerFormat:
4476#    la $a0,badIntegerFormatMsg
4480#    j exitError
4484:castException:
4484#    la $a0,castExceptionMsg
4488#    j exitError
############## data section ################
    .data
4736:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4752:cur_seg:
    .word 0

4756:lastCharRead:
    .word -2 # -2 => no buffered character
4760:prevHashConstant:
    .word 0x2785173c
4764:gcCount:
    .word 0

4768:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4795:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4818:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4853:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4887:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4920:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4951:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4999:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5020:gcMsg: 
      .asciiz "\nGC!\n"
5026:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5058:nullStr:
    .asciiz "null"
5063:trueString:
    .asciiz "true"
5068:falseString:
    .asciiz "false"
5074:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5093:newlineString:
    .asciiz "\n"
    
    .align 2
5096:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5100:seg0_start:
    .space 0x100000
1053676:seg0_end:
1053676:seg1_start:
    .space 0x100000
2102252:seg1_end:

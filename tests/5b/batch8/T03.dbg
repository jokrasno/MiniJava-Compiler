
###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1388:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1388#    lw $t0,-8($s2) # get word with hash bits from this
1392#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1396#    addu $t0,$t1

1400#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1404:mth_equals_Object:
1404#    move $t0,$s2 # first pointer (this)
1408#    lw $t1,($sp) # second pointer
1412#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1413##...subu $at,$t0,$t1
1417##...sltiu $t0,$at,1

1420#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1424:mth_hashCode_String:
1424#    move $t0,$s2 # put this pointer in t0

1428#    li $t2,0 # current hash value
1432#    lw $t1,-4($t0) # negative of number of characters in string
1436#    beq $t1,$zero,done_hashCode_String # if zero length => done
1440#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1444#    and $t0,0xfffffffc # adjust for padding
1445##...lui $at,65535
1449##...ori $at,$at,0xfffc
1453##...and $t0,$t0,$at
1456#    subu $t1,$t0,$t1 # address at end of string +12
1460:loop_hashCode_String:    
1460#    sll $t4,$t2,5 # multiply by 32
1464#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1468#    lbu $t3,-12($t0) # current character
1472#    addu $t2,$t3 # add in current character
1476#    addu $t0,1 # go to next character's address
1480#    bne $t0,$t1,loop_hashCode_String # loop back if more
1484:done_hashCode_String:    

    # push int on stack
1484#    move $t0, $t2 # put $t2 in return slot
1488#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1492:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1492#    subu $sp,4
1496#    sw $ra,($sp)
    
    # get hash value
1500#    lw $t2,-12($s2) # vtable address
1504#    lw $t0,($t2) # method address
1508#    jalr $t0
1512#    subu $sp,8 # push result (int in $t0) on stack
1516#    sw $s5,4($sp)
1520#    sw $t0,($sp)

    # compute print-size of hash value
1524#    li $t0, 1
1528#    lw $t1, ($sp)
1532#    srl $t1,$t1,4
1536#    beq $t1,$zero,toString_skip_loop
1540:toString_loop_top:
1540#    addu $t0,1
1544#    srl $t1,$t1,4
1548#    bne $t1,$zero,toString_loop_top
1552:toString_skip_loop:
1552#    subu $sp,8
1556#    sw $s5,4($sp)
1560#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1564#    lw $t2,-12($s2) # vtable address
1568#    move $t0,$t2
1572:toString_checkTagBit:
1572#    subu $t0,1
1576#    lb $t1,($t0)
1580#    and $t1,0x80
1581##...lui $at,0
1585##...ori $at,$at,0x80
1589##...and $t1,$t1,$at
1592#    beq $t1,$zero,toString_checkTagBit
1596#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1600#    subu $sp,8
1604#    sw $t1,($sp)
1608#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1612#    move $s7,$zero # -4 offset header word
1616#    lw $t4,8($sp) # bytes for hash value
1620#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1624#    addu $t4,8
1628#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1632#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1636#    li $t0,CLASS_String # store string vtable address into ...
1640#    sw $t0,-12($s7) # ... -12 offset in object header
1644#    lw $t2,-12($s2) # our object's vtable address
1648#    lw $t5,4($sp) # number characters in prefix
1652#    lw $t1,12($sp) # number of characters in hashcode
1656#    addu $t3,$t1,$t5 # number of characters in string ...
1660#    addu $t3,1 # ... including the '@' character
1664#    subu $t0,$zero,$t3 # store negated length into ...
1668#    sw $t0,-4($s7) # ... -4 offset header word
1672#    lw $t0,-8($s7) # get -8 offset header-word
1676#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1677##...slt $at,$t0,$zero
1681##...beq $at,$zero,1700
1684#    and $t0,0xff # mask off object's hash value ...
1685##...lui $at,0
1689##...ori $at,$at,0xff
1693##...and $t0,$t0,$at
1696#    sw $t0,-8($s7) # ... and store back into -8 header-word
1700:skipMask_toString:
1700#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1704#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1708#    subu $t4,$t2,$t5
1712:toString_copyLoop:    
1712#    lb $t3,($t4)
1716#    and $t3,0x7f # mask off sign bit (in case first word)
1717##...lui $at,0
1721##...ori $at,$at,0x7f
1725##...and $t3,$t3,$at
1728#    sb $t3,-8($t0)
1732#    addu $t4,1
1736#    addu $t0,1
1740#    blt $t4,$t2,toString_copyLoop
1741##...slt $at,$t4,$t2
1745##...bne $at,$zero,1712

    # copy the '@' sign
1748#    li $t3,'@'
1752#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1756#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1760#    lw $t3,20($sp) # hash code to print
1764:toString_hashCopyLoop:
1764#    and $t4,$t3,0xf
1768#    srl $t3,4
1772#    lb $t4,hexChars($t4)
1776#    sb $t4,-8($t2)
1780#    subu $t2,$t2,1
1784#    bgt $t2,$t0,toString_hashCopyLoop
1785##...slt $at,$t0,$t2
1789##...bne $at,$zero,1764

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1792#    addu $sp,28
1796#    lw $ra,($sp)
1800#    addu $sp,4
1804#    move $t0, $s7 # return string we created
1808#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1812:mth_equals_String:
    
    # quick test for obvious false
1812#    lw $t0,($sp) # second parameter
1816#    beq $t0,$zero,goEsFalse # go return false if null
1820#    lw $t1,-12($t0) # vtable pointer
1824#    la $t2,CLASS_String # string vtable pointer
1828#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1832#    subu $sp,12
1836#    sw $ra,8($sp)
1840#    sw $s2,4($sp)
1844#    sw $t0,($sp)
1848#    jal mth_compareTo_String
1852#    lw $s2, 4($sp) #restore this pointer and pop parameters
1856#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1860#    seq $t0,$t0,$zero
1861##...subu $at,$t0,$zero
1865##...sltiu $t0,$at,1

    # pop return address and return $t0
1868#    lw $ra,($sp)
1872#    addu $sp,4

1876#    jr $ra # return
    
1880:goEsFalse:
    # put 0 in $t0 and return
1880#    li $t0, 0
1884#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1888:mth_toString_String:
    #we are a string, so return this.
1888#    move $t0, $s2
1892#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1896:mth_readLine_Lib:
    
1896#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1900#    sw $ra, 4($sp) # save $ra
1904#    move $t1,$sp # save "original" sp

1908:  doRead:

    # read the character
1908#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1912#    subu $t2,$v0,13
1916#    bne $t2,$zero,notReturnRL
1920#    jal readLogicalChar
1924#    subu $t2,$v0,10 # check for newline
1928#    beq $t2,$zero,foundNewLine
1932#    sw $v0,lastCharRead # push back character into queue
1936#    j foundNewLine # go process the line

1940:  notReturnRL:

    # at this point, $v0 has our character

1940#    subu $t0,$v0,10
1944#    beq $t0,$zero,foundNewLine
1948#    blt $v0,$zero,foundEof
1949##...slt $at,$v0,$zero
1953##...bne $at,$zero,1968

    # we have a character, so push it onto stack
1956#    subu $sp,$sp,4
1960#    sw $v0,($sp)

    # loop back up to get next character
1964#    j doRead

1968:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1968#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1972#    li $s7, 0 # return-value: null
1976#    j rlReturn # return

1980:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1980#    subu $t0,$t1,$sp # number of chars we read (times 4)
1984#    srl $s6,$t0,2 # number of words on stack with chars
1988#    subu $sp,$sp,4 # push char-count ...
1992#    sw $s6,($sp) # ... onto stack
1996#    addu $t2,$t0,5 # GC tag, incl. for count-word
2000#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2004#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2008#    srl $s6,$s6,2  # data words in object
2012#    move $s7,$zero # object words in object
2016#    jal newObject  # allocate space
    
    # store header words
2020#    la $t0,CLASS_String
2024#    sw $t0,-12($s7)# store class tag (String) into object
2028#    lw $t2,4($sp) # char-count
2032#    sll $t1,$t2,2 # 4 times number of chars
2036#    subu $t2,$zero,$t2 # negative of char-count
2040#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2044#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2048#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2049##...slt $at,$t0,$zero
2053##...beq $at,$zero,2072
2056#    and $t0,0xff # mask off object's hash value ...
2057##...lui $at,0
2061##...ori $at,$at,0xff
2065##...and $t0,$t0,$at
2068#    sw $t0,-8($s7) # ... and store back into -8 header-word
2072:  skipMask_readLine:

2072#    sll $t0,$t0,2 # data bytes in object
2076#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2080#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2084#    addu $sp,$sp,8 # pop redundant object-pointer and count
2088#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2092#    beq $sp,$t1,rlReturn
2096:  charCopyLoop:
2096#    lw $t2,($sp)
2100#    sb $t2,-9($t0)
2104#    addu $sp,$sp,4
2108#    subu $t0,$t0,1
2112#    bne $sp,$t1,charCopyLoop
2116:  rlReturn:

2116#    lw $ra, 4($sp)
2120#    addu $sp, 8   # pop $ra and pointless word off stack
2124#    move $t0, $s7 # return string we allocated in $s7
2128#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2132:mth_readInt_Lib:

    # save $ra by pushing onto stack
2132#    subu $sp,$sp,4
2136#    sw $ra,($sp)

2140:  riSkipWhiteLoop:
    # read a character
2140#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2144#    subu $t0,$v0,32
2148#    bgt $t0,$zero,nonWhite
2149##...slt $at,$zero,$t0
2153##...bne $at,$zero,2196
2156#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2160#    subu $t0,$v0,10
2164#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2168#    subu $t0,$v0,9
2172#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2176#    subu $t0,$v0,13
2180#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2184#    subu $t0,$v0,12
2188#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2192#    j badIntegerFormat # illegal integer char: abort program

2196:  nonWhite:
2196#    subu $t0,$v0,'-'
2200#    li $t4,1 # final multiplier
2204#    bne $t0,$zero,helpReadInt # go read
2208#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2212#    jal readLogicalChar

2216:  helpReadInt:
2216#    li $t2,10
2220#    subu $t1,$v0,'0' # convert digit to 0-9 value
2224#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2225##...sltu $at,$t1,$t2
2229##...beq $at,$zero,4476
2232#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2236:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2236#    jal readLogicalChar # read next character
2240#    subu $t1,$v0,'0' # convert digit to 0-9 value
2244#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2245##...sltu $at,$t1,$t2
2249##...beq $at,$zero,2268

2252#    mul $t3,$t3,$t2 # multiply old value by 10
2253##...mult $t3,$t2
2257##...mflo $t3
2260#    addu $t3,$t3,$t1 # add in value of new digit
2264#    j digitLoop

2268:  doneDigitLoop:

    # "push back" unused character into queue
2268#    sw $v0,lastCharRead

    # restore return address
2272#    lw $ra,($sp)

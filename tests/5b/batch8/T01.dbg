########################################################
# str.charAt(n) - library method (class String)
# accesses a character in a string, as in Java
# - parameters:
#   - ($sp) - the index, n
#   - 4($sp) - GC tag
#   - 8($sp) - old this pointer
#   - $s2    - this pointer
# - returns:
#   - $t0 - the character found.
########################################################
3980:mth_charAt_String:
    # get string
3980#    move $t0,$s2

    # check that index is in bounds
3984#    lw $t1,-4($t0) # negative of # data words in string
3988#    subu $t3,$zero,$t1 # # chars in string
3992#    lw $t2,($sp) # index
3996#    bgeu $t2,$t3,strIndexOutOfBounds
3997##...sltu $at,$t2,$t3
4001##...beq $at,$zero,5488

    # access element
4004#    lw $t1,-8($t0) # # data words in object
4008#    sll $t1,$t1,2 # - byte-offset from end of chars
4012#    subu $t1,$t2,$t1 # - address of first char in string, offset by 8
4016#    addu $t0,$t0,$t1 # - address of our char, offset by 8
4020#    lb $t0,-8($t0) # our char

    # return
4024#    jr $ra

########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
4028:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
4028#    subu $sp,$sp,8
4032#    sw $ra,4($sp)

    # save current sp
4036#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
4040#    li $t3,10

    # get argument, negate if negative
4044#    lw $t1,8($sp)
4048#    bge $t1,$zero,itsNonNegLoop
4049##...slt $at,$t1,$zero
4053##...beq $at,$zero,4060
4056#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
4060:  itsNonNegLoop:
4060#    divu $t1,$t3
4064#    mflo $t1 # quotient
4068#    mfhi $t4 # remainder
4072#    addu $t4,$t4,'0' # turn remainder into digit
4076#    subu $sp,$sp,4
4080#    sw $t4,($sp) # push digit onto stack
4084#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
4088#    lw $t4,8($t0)
4092#    bge $t4,$zero,itsSkipNeg
4093##...slt $at,$t4,$zero
4097##...beq $at,$zero,4112
4100#    li $t4,'-'
4104#    subu $sp,$sp,4
4108#    sw $t4,($sp)
4112:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
4112#    subu $s6,$t0,$sp
4116#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
4120#    sw $t3,($t0)
4124#    srl $s6,$s6,2
4128#    subu $sp,$sp,4
4132#    sw $s6,($sp)
    
    # allocate memory
4136#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
4140#    srl $s6,$s6,2
4144#    move $s7,$zero # no "object" words in object
4148#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
4152#    lw $t0,4($sp)
4156#    addu $sp,$sp,8

    # store "String" tag into class field
4160#    subu $s7,$s7,8 # address of header-1 word
4164#    la $t1,CLASS_String
4168#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
4172#    lw $t4,($s7) # # data words in source string
4176#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
4177##...slt $at,$t4,$zero
4181##...beq $at,$zero,4200
4184#    and $t4,0xff # mask off object's hash value ...
4185##...lui $at,0
4189##...ori $at,$at,0xff
4193##...and $t4,$t4,$at
4196#    sw $t4,($s7) # ... and store back into -8 header-word
4200:skipMask_intToString:
    
    # store negative of char-count into header-2 word
4200#    subu $t0,$zero,$t0
4204#    sw $t0,4($s7)

4208#    lw $t1,($s7) # number of data words in string
4212#    sll $t1,$t1,2 # number data bytes in string
4216#    subu $t1,$s7,$t1 # first location to store chars in string
4220#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
4224:  itsLoop:
4224#    lw $t2,($sp)
4228#    addu $sp,$sp,4
4232#    sb $t2,($t1)
4236#    addu $t1,$t1,1
4240#    bne $t1,$t0,itsLoop

    ####################################################
    # At this point
    # - ($t0+15)&0xfffffffe is our return value
    # - ($sp) contains garbage (old GC tag)
    # - 4($sp) contains return address
    ####################################################

    # adjust stack, restore return address; return
4244#    lw $ra,4($sp)
4248#    addu $sp,$sp,8
4252#    addu $t0,$t0,15
4256#    and $t0,$t0,0xfffffffc
4257##...lui $at,65535
4261##...ori $at,$at,0xfffc
4265##...and $t0,$t0,$at
4268#    jr $ra

########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
4272:mth_intToChar_Lib:
    # save return address
4272#    subu $sp,$sp,4
4276#    sw $ra,($sp)

    # allocate object
4280#    li $s6,2
4284#    move $s7,$zero
4288#    jal newObject

    # get n from string.
4292#    lw $t1,8($sp)

    # store "String" tag into class field
4296#    la $t0,CLASS_String
4300#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
4304#    lw $t4,-8($s7) # # data words in source string
4308#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
4309##...slt $at,$t4,$zero
4313##...beq $at,$zero,4332
4316#    and $t4,0xff # mask off object's hash value ...
4317##...lui $at,0
4321##...ori $at,$at,0xff
4325##...and $t4,$t4,$at
4328#    sw $t4,-8($s7) # ... and store back into -8 header-word
4332:  skipMask_intToChar:

    # store data in string
4332#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
4336#    li $t0,-1
4340#    sw $t0,-4($s7)

    # we're returning $s7
4344#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
4348#    lw $ra,4($sp)
4352#    addu $sp,$sp,8

    # return
4356#    jr $ra

########################################################
# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
4360:mth_compareTo_String:
    # get string pointers and check parameter for null
4360#    lw $t0,($sp) # second string
4364#    beq $t0,$zero,nullPtrException
4368#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
4372#    lw $t2,-4($t0) # negative length of second string
4376#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
4380#    slt $t4,$t3,$t2
4384#    slt $t5,$t2,$t3
4388#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
4392#    lw $t2,-8($t0) # # data words in second string
4396#    lw $t3,-8($t1) # # data words in first string
4400#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
4404#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
4408#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
4412#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
4416#    beq $zero,$t5,skipStrCmpLenzz
4420#    move $t2,$t3
4424:  skipStrCmpLenzz:
4424#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
4428:  cmpLoopzz:
4428#    lw $t3,-8($t1) # word from str2
4432#    lw $t4,-8($t0) # word from str1
4436#    bne $t3,$t4,cmpNotEqualzz
4440#    addu $t1,$t1,4
4444#    addu $t0,$t0,4
4448#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
4452#    j cmpHitLimitzz

4456:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
4456#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
4460#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
4464#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
4468:  cmpHitLimitzz:
4468#    move $t0, $t5 # store return value
4472#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
4476:readLogicalChar:

    # check if we already have a character
4476#    lw $v0,lastCharRead
4480#    li $t0,-2
4484#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
4488#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
4492#    jr $ra # return
    
4496:  doReadCh:
    # we need to actually read a character: read and return
4496#    li $v0,12 # use system call to read a character
4500#    syscall
4504#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
4508:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
4508#    blt $s7,$zero arraySizeOutOfBounds
4509##...slt $at,$s7,$zero
4513##...bne $at,$zero,5504

    # mark the fact that we have not yet GC'd for this allocation
4516#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

4520:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
4520#    addu $t0,$s6,$s7
4524#    sll $t0,$t0,2
4528#    addu $t0,$t0,8 # amount of memory needed
4532#    addu $t1,$t0,$s3
4536#    bgtu $t1,$s4,doGC
4537##...sltu $at,$s4,$t1
4541##...bne $at,$zero,4664

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
4544#    move $t2,$s3
4548:  zeroObjLoop:
4548#    sw $zero,($s3)
4552#    lw $zero,($s3)

4556#    addu $s3,4

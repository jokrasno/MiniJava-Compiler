
########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
5284:vm_init:

    # mark bottom of stack
5284#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
5288#    move $s2,$zero

    #set up the "five" register
5292#    li $s5,5

5296#    la $s3,seg0_start
5300#    la $s4,seg0_end
5301##...lui $s4,16
5305##...addiu $s4,$s4,6124
    
    # return
5308#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5312:divide:
    # get parameters; abort if divisor zero
5312#    lw $t0,($sp)
5316#    lw $t1,8($sp)
5320#    beq $t0,$zero,divByZeroError
    
    # perform division
5324#    div $t1,$t0
5328#    mflo $t0

    # store result, adjust stack and return
5332#    addu $sp,$sp,8 # adjust stack
5336#    sw $t0,($sp) # store result
5340#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5344:remainder:
    # get parameters; abort if divisor zero
5344#    lw $t0,($sp)
5348#    lw $t1,8($sp)
5352#    beq $t0,$zero,divByZeroError
    
    # perform division
5356#    div $t1,$t0
5360#    mfhi $t0

    # store result, adjust stack and return
5364#    addu $sp,$sp,8 # adjust stack
5368#    sw $t0,($sp) # store result
5372#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
5376:checkCast:
    # get object, allow immediately if null
5376#    lw $t2,($sp)
5380#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
5384#    lw $t2,-12($t2) # vtable address
5388#    bge $t2,$t1,castException
5389##...slt $at,$t2,$t1
5393##...beq $at,$zero,5528
5396#    blt $t2,$t0,castException
5397##...slt $at,$t2,$t0
5401##...bne $at,$zero,5528
    
    # return, leaving object unchanged on stack
5404:  checkCastReturn:    
5404#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
5408:instanceOf:
    # get object, go return false if null
5408#    lw $t2,($sp)
5412#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
5416#    lw $t2,-12($t2) # vtable address
5420#    sge $t0,$t2,$t0 # are we >= the lower limit?
5421##...slt $t0,$t2,$t0
5425##...xori $t0,$t0,0x1
5428#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
5432#    and $t2,$t0,$t1
5436#    sw $t2,($sp)
5440:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
5440#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

5444:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
5444#    li $v0,4 # syscall-code for print-string
5448#    syscall
5452:exit:
    # print termination message
5452#    li $v0,4 # syscall-code for print-string
5456#    la $a0,exitString
5460#    syscall

    # terminate execution
5464#    li $v0,10 #syscall-code for "exit"
5468#    syscall

5472:outOfHeapMemory:
5472#    la $a0,heapMemoryMsg
5476#    j exitError
5480:divByZeroError:
5480#    la $a0,divByZeroMsg
5484#    j exitError
5488:strIndexOutOfBounds:
5488#    la $a0,strIndexOutOfBoundsMsg
5492#    j exitError
5496:arrayIndexOutOfBounds:
5496#    la $a0,arrayIndexOutOfBoundsMsg
5500#    j exitError
5504:arraySizeOutOfBounds:
5504#    la $a0,arraySizeOutOfBoundsMsg
5508#    j exitError
5512:nullPtrException:
5512#    la $a0,nullPtrExceptionMsg
5516#    j exitError
5520:badIntegerFormat:
5520#    la $a0,badIntegerFormatMsg
5524#    j exitError
5528:castException:
5528#    la $a0,castExceptionMsg
5532#    j exitError
############## data section ################
    .data
5760:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5776:cur_seg:
    .word 0

5780:lastCharRead:
    .word -2 # -2 => no buffered character
5784:prevHashConstant:
    .word 0x2785173c
5788:gcCount:
    .word 0

5792:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5819:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5842:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5877:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5911:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5944:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5975:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
6023:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
6044:gcMsg: 
      .asciiz "\nGC!\n"
6050:gcCountMsg: 
      .asciiz "Number of garbage collections: "

6082:nullStr:
    .asciiz "null"
6087:trueString:
    .asciiz "true"
6092:falseString:
    .asciiz "false"
6098:exitString:
    .ascii "Program terminated."
    #### "falls through" here
6117:newlineString:
    .asciiz "\n"
    
    .align 2
6120:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

6124:seg0_start:
    .space 0x100000
1054700:seg0_end:
1054700:seg1_start:
    .space 0x100000
2103276:seg1_end:





###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2432:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
2432#    lw $t0,-8($s2) # get word with hash bits from this
2436#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
2440#    addu $t0,$t1

2444#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2448:mth_equals_Object:
2448#    move $t0,$s2 # first pointer (this)
2452#    lw $t1,($sp) # second pointer
2456#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
2457##...subu $at,$t0,$t1
2461##...sltiu $t0,$at,1

2464#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2468:mth_hashCode_String:
2468#    move $t0,$s2 # put this pointer in t0

2472#    li $t2,0 # current hash value
2476#    lw $t1,-4($t0) # negative of number of characters in string
2480#    beq $t1,$zero,done_hashCode_String # if zero length => done
2484#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
2488#    and $t0,0xfffffffc # adjust for padding
2489##...lui $at,65535
2493##...ori $at,$at,0xfffc
2497##...and $t0,$t0,$at
2500#    subu $t1,$t0,$t1 # address at end of string +12
2504:loop_hashCode_String:    
2504#    sll $t4,$t2,5 # multiply by 32
2508#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
2512#    lbu $t3,-12($t0) # current character
2516#    addu $t2,$t3 # add in current character
2520#    addu $t0,1 # go to next character's address
2524#    bne $t0,$t1,loop_hashCode_String # loop back if more
2528:done_hashCode_String:    

    # push int on stack
2528#    move $t0, $t2 # put $t2 in return slot
2532#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
2536:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
2536#    subu $sp,4
2540#    sw $ra,($sp)
    
    # get hash value
2544#    lw $t2,-12($s2) # vtable address
2548#    lw $t0,($t2) # method address
2552#    jalr $t0
2556#    subu $sp,8 # push result (int in $t0) on stack
2560#    sw $s5,4($sp)
2564#    sw $t0,($sp)

    # compute print-size of hash value
2568#    li $t0, 1
2572#    lw $t1, ($sp)
2576#    srl $t1,$t1,4
2580#    beq $t1,$zero,toString_skip_loop
2584:toString_loop_top:
2584#    addu $t0,1
2588#    srl $t1,$t1,4
2592#    bne $t1,$zero,toString_loop_top
2596:toString_skip_loop:
2596#    subu $sp,8
2600#    sw $s5,4($sp)
2604#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
2608#    lw $t2,-12($s2) # vtable address
2612#    move $t0,$t2
2616:toString_checkTagBit:
2616#    subu $t0,1
2620#    lb $t1,($t0)
2624#    and $t1,0x80
2625##...lui $at,0
2629##...ori $at,$at,0x80
2633##...and $t1,$t1,$at
2636#    beq $t1,$zero,toString_checkTagBit
2640#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
2644#    subu $sp,8
2648#    sw $t1,($sp)
2652#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
2656#    move $s7,$zero # -4 offset header word
2660#    lw $t4,8($sp) # bytes for hash value
2664#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
2668#    addu $t4,8
2672#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
2676#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

2680#    li $t0,CLASS_String # store string vtable address into ...
2684#    sw $t0,-12($s7) # ... -12 offset in object header
2688#    lw $t2,-12($s2) # our object's vtable address
2692#    lw $t5,4($sp) # number characters in prefix
2696#    lw $t1,12($sp) # number of characters in hashcode
2700#    addu $t3,$t1,$t5 # number of characters in string ...
2704#    addu $t3,1 # ... including the '@' character
2708#    subu $t0,$zero,$t3 # store negated length into ...
2712#    sw $t0,-4($s7) # ... -4 offset header word
2716#    lw $t0,-8($s7) # get -8 offset header-word
2720#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2721##...slt $at,$t0,$zero
2725##...beq $at,$zero,2744
2728#    and $t0,0xff # mask off object's hash value ...
2729##...lui $at,0
2733##...ori $at,$at,0xff
2737##...and $t0,$t0,$at
2740#    sw $t0,-8($s7) # ... and store back into -8 header-word
2744:skipMask_toString:
2744#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2748#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2752#    subu $t4,$t2,$t5
2756:toString_copyLoop:    
2756#    lb $t3,($t4)
2760#    and $t3,0x7f # mask off sign bit (in case first word)
2761##...lui $at,0
2765##...ori $at,$at,0x7f
2769##...and $t3,$t3,$at
2772#    sb $t3,-8($t0)
2776#    addu $t4,1
2780#    addu $t0,1
2784#    blt $t4,$t2,toString_copyLoop
2785##...slt $at,$t4,$t2
2789##...bne $at,$zero,2756

    # copy the '@' sign
2792#    li $t3,'@'
2796#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2800#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2804#    lw $t3,20($sp) # hash code to print
2808:toString_hashCopyLoop:
2808#    and $t4,$t3,0xf
2812#    srl $t3,4
2816#    lb $t4,hexChars($t4)
2820#    sb $t4,-8($t2)
2824#    subu $t2,$t2,1
2828#    bgt $t2,$t0,toString_hashCopyLoop
2829##...slt $at,$t0,$t2
2833##...bne $at,$zero,2808

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2836#    addu $sp,28
2840#    lw $ra,($sp)
2844#    addu $sp,4
2848#    move $t0, $s7 # return string we created
2852#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2856:mth_equals_String:
    
    # quick test for obvious false
2856#    lw $t0,($sp) # second parameter
2860#    beq $t0,$zero,goEsFalse # go return false if null
2864#    lw $t1,-12($t0) # vtable pointer
2868#    la $t2,CLASS_String # string vtable pointer
2872#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2876#    subu $sp,12
2880#    sw $ra,8($sp)
2884#    sw $s2,4($sp)
2888#    sw $t0,($sp)
2892#    jal mth_compareTo_String
2896#    lw $s2, 4($sp) #restore this pointer and pop parameters
2900#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2904#    seq $t0,$t0,$zero
2905##...subu $at,$t0,$zero
2909##...sltiu $t0,$at,1

    # pop return address and return $t0
2912#    lw $ra,($sp)
2916#    addu $sp,4

2920#    jr $ra # return
    
2924:goEsFalse:
    # put 0 in $t0 and return
2924#    li $t0, 0
2928#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2932:mth_toString_String:
    #we are a string, so return this.
2932#    move $t0, $s2
2936#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2940:mth_readLine_Lib:
    
2940#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2944#    sw $ra, 4($sp) # save $ra
2948#    move $t1,$sp # save "original" sp

2952:  doRead:

    # read the character
2952#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2956#    subu $t2,$v0,13
2960#    bne $t2,$zero,notReturnRL
2964#    jal readLogicalChar
2968#    subu $t2,$v0,10 # check for newline
2972#    beq $t2,$zero,foundNewLine
2976#    sw $v0,lastCharRead # push back character into queue
2980#    j foundNewLine # go process the line

2984:  notReturnRL:

    # at this point, $v0 has our character

2984#    subu $t0,$v0,10
2988#    beq $t0,$zero,foundNewLine
2992#    blt $v0,$zero,foundEof
2993##...slt $at,$v0,$zero
2997##...bne $at,$zero,3012

    # we have a character, so push it onto stack
3000#    subu $sp,$sp,4
3004#    sw $v0,($sp)

    # loop back up to get next character
3008#    j doRead

3012:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
3012#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
3016#    li $s7, 0 # return-value: null
3020#    j rlReturn # return

3024:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
3024#    subu $t0,$t1,$sp # number of chars we read (times 4)
3028#    srl $s6,$t0,2 # number of words on stack with chars
3032#    subu $sp,$sp,4 # push char-count ...
3036#    sw $s6,($sp) # ... onto stack
3040#    addu $t2,$t0,5 # GC tag, incl. for count-word
3044#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
3048#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
3052#    srl $s6,$s6,2  # data words in object
3056#    move $s7,$zero # object words in object
3060#    jal newObject  # allocate space
    
    # store header words
3064#    la $t0,CLASS_String
3068#    sw $t0,-12($s7)# store class tag (String) into object
3072#    lw $t2,4($sp) # char-count
3076#    sll $t1,$t2,2 # 4 times number of chars
3080#    subu $t2,$zero,$t2 # negative of char-count
3084#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3088#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3092#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3093##...slt $at,$t0,$zero
3097##...beq $at,$zero,3116
3100#    and $t0,0xff # mask off object's hash value ...
3101##...lui $at,0
3105##...ori $at,$at,0xff
3109##...and $t0,$t0,$at
3112#    sw $t0,-8($s7) # ... and store back into -8 header-word
3116:  skipMask_readLine:

3116#    sll $t0,$t0,2 # data bytes in object
3120#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
3124#    subu $t0,$t0,$t2 # place to store last character (plus 9)
3128#    addu $sp,$sp,8 # pop redundant object-pointer and count
3132#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

3136#    beq $sp,$t1,rlReturn
3140:  charCopyLoop:
3140#    lw $t2,($sp)
3144#    sb $t2,-9($t0)
3148#    addu $sp,$sp,4
3152#    subu $t0,$t0,1
3156#    bne $sp,$t1,charCopyLoop
3160:  rlReturn:

3160#    lw $ra, 4($sp)
3164#    addu $sp, 8   # pop $ra and pointless word off stack
3168#    move $t0, $s7 # return string we allocated in $s7
3172#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3176:mth_readInt_Lib:

    # save $ra by pushing onto stack
3176#    subu $sp,$sp,4
3180#    sw $ra,($sp)

3184:  riSkipWhiteLoop:
    # read a character
3184#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
3188#    subu $t0,$v0,32
3192#    bgt $t0,$zero,nonWhite
3193##...slt $at,$zero,$t0
3197##...bne $at,$zero,3240
3200#    beq $t0,$zero,riSkipWhiteLoop # start over if space
3204#    subu $t0,$v0,10
3208#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
3212#    subu $t0,$v0,9
3216#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
3220#    subu $t0,$v0,13
3224#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
3228#    subu $t0,$v0,12
3232#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
3236#    j badIntegerFormat # illegal integer char: abort program

3240:  nonWhite:
3240#    subu $t0,$v0,'-'
3244#    li $t4,1 # final multiplier
3248#    bne $t0,$zero,helpReadInt # go read
3252#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
3256#    jal readLogicalChar

3260:  helpReadInt:
3260#    li $t2,10
3264#    subu $t1,$v0,'0' # convert digit to 0-9 value
3268#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
3269##...sltu $at,$t1,$t2
3273##...beq $at,$zero,5520
3276#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

3280:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

3280#    jal readLogicalChar # read next character
3284#    subu $t1,$v0,'0' # convert digit to 0-9 value
3288#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
3289##...sltu $at,$t1,$t2
3293##...beq $at,$zero,3312

3296#    mul $t3,$t3,$t2 # multiply old value by 10
3297##...mult $t3,$t2
3301##...mflo $t3
3304#    addu $t3,$t3,$t1 # add in value of new digit
3308#    j digitLoop

3312:  doneDigitLoop:

    # "push back" unused character into queue
3312#    sw $v0,lastCharRead

    # restore return address
3316#    lw $ra,($sp)
3320#    addu $sp, 4

    # multiply by sign and put return value in $t0
3324#    mult $t3,$t4 # multiply to account for poss. minus sign
3328#    mflo $t3
3332#    move $t0, $t3
    
    # return
3336#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3340:mth_readChar_Lib:

    # save $ra by pushing onto stack
3340#    subu $sp,$sp,4
3344#    sw $ra,($sp)

      # read the character
3348#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
3352#    lw $ra,($sp)
3356#    addu $sp, 4
3360#    move $t0, $v0

    # return
3364#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
3368:mth_printStr_Lib:
    # check for null, printing "(null)", if so
3368#    lw $t0,($sp)
3372#    bne $t0,$zero,psNotNull

    # print "(null)"
3376#    la $a0,nullStr
3380#    li $v0,4
3384#    syscall
3388#    j donePrintStr
    
3392:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
3392#    subu $t0,$t0,8
3396#    lw $t1,($t0) # number of data words, but needs modification
3400#    blt $t1,$zero,skipPrintStr1
3401##...slt $at,$t1,$zero
3405##...bne $at,$zero,3424
3408#    and $t1,0xff # mask out all but low byte
3409##...lui $at,0
3413##...ori $at,$at,0xff
3417##...and $t1,$t1,$at
3420#    b skipPrintStr2
3424:skipPrintStr1:
3424#    and $t1,0x7ffffff
3425##...lui $at,2047
3429##...ori $at,$at,0xffff
3433##...and $t1,$t1,$at
3436:skipPrintStr2:    
3436#    sll $t1,$t1,2
3440#    subu $t1,$t0,$t1 # first word in string
3444#    lw $t0,4($t0) # negative of string-length
3448#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
3452#    beq $t0,$t1,donePrintStr
3456:  psLoop:
3456#    lb $a0,($t1) # next byte
3460#    li $v0,11 # code for printing char
3464#        syscall # print the char
3468#    addu $t1,$t1,1 # go to next char
3472#    blt $t1,$t0,psLoop
3473##...slt $at,$t1,$t0
3477##...bne $at,$zero,3456

3480:  donePrintStr:
3480#    jr $ra

########################################################
# printInt(n) - library method (class Lib)
# - prints integer in decimal format to standard output
# - parameters:
#   - ($sp) - the integer to print
#   - 4($sp) - GC tag
#   - ($sp) - old-this-pointer
########################################################
3484:mth_printInt_Lib:
3484#    lw $a0,($sp)

    # print it
3488#    li $v0,1 # code for print-int
3492#    syscall

    # return
3496#    jr $ra

########################################################
# printBool(n) - library method (class Lib)
# - prints boolean to standard output
# - parameters:
#   - ($sp) - the boolean to print
#   - 4($sp) - old-this-pointer
########################################################
3500:mth_printBool_Lib:
    # pop value off stack, along with 'this'
3500#    lw $t0,($sp)

    # print either 'true' or 'false', depending on the value
3504#    la $a0,falseString
3508#    beq $t0,$zero,skipPB
3512#    la $a0,trueString
3516:  skipPB:
3516#    li $v0,4 # code for print-string
3520#    syscall

    # return
3524#    jr $ra

########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
3528:mth_substring_String:

    # save $ra by pushing onto stack
3528#    subu $sp,$sp,4
3532#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
3536#    move $t0,$s2
3540#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
3544#    lw $t0,-4($t0) # negative of string length
3548#    subu $t0,$zero,$t0 # string length
3552#    lw $t1,4($sp) # k
3556#    lw $t2,12($sp) # n
3560#    bgt $zero,$t2,strIndexOutOfBounds
3561##...slt $at,$t2,$zero
3565##...bne $at,$zero,5488
3568#    bgt $t2,$t1,strIndexOutOfBounds
3569##...slt $at,$t1,$t2
3573##...bne $at,$zero,5488
3576#    bgt $t1,$t0,strIndexOutOfBounds
3577##...slt $at,$t0,$t1
3581##...bne $at,$zero,5488

    # allocate memory
3584#    subu $s6,$t1,$t2 # # chars in target-string
3588#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
3592#    srl $s6,$s6,2 # convert bytes-count to word-count
3596#    move $s7,$zero # (no object-bytes in string)
3600#    jal newObject

    # store "String" tag in object-type field
3604#    la $t0,CLASS_String
3608#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
3612#    lw $t4,-8($s7) # data words in source string
3616#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
3617##...slt $at,$t4,$zero
3621##...beq $at,$zero,3640
3624#    and $t4,0xff # mask off object's hash value ...
3625##...lui $at,0
3629##...ori $at,$at,0xff
3633##...and $t4,$t4,$at
3636#    sw $t4,-8($s7) # ... and store back into -8 header-word
3640:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
3640#    lw $t1,8($sp) # k
3644#    lw $t2,16($sp) # n
3648#    subu $t0,$t2,$t1 # value to store
3652#    sw $t0,-4($s7) # store value
    
3656#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
3660#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
3664#    lw $t4,-8($t3) # data words in source string
3668#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
3672#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
3676#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
3680#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
3684#    lw $t2,-8($s7)   # data words in target string
3688#    sll $t2,$t2,2    # data bytes in target string
3692#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target
3696:  subCopyLoopzz:
3696#    lb $t4,-8($t3)
3700#    sb $t4,-8($t2)
3704#    addu $t2,$t2,1
3708#    addu $t3,$t3,1
3712#    blt $t3,$t1,subCopyLoopzz
3713##...slt $at,$t3,$t1
3717##...bne $at,$zero,3696
    
3720:  doneSubCopyzz:
    # restore return address, store return value, pop stack
3720#    lw $ra,4($sp) # restore $ra
3724#    addu $sp,$sp,8 # pop ra, and allocated newObject
3728#    move $t0, $s7 # we're returning the string we got back
                  # from newObject
    
    # return
3732#    jr $ra

########################################################
# length() - library method (class String)
# returns length of a string: Java: str.length()
# - parameters:
#   - ($sp) - old this pointer
# - return-value:
#   - $t0 - length of string
########################################################
3736:mth_length_String:

    # the length is the negative of 4($s2)
3736#    lw $t0,-4($s2) # -length
3740#    subu $t0,$zero,$t0

    # return
3744#    jr $ra


########################################################
# str1.concat(str2) - library method (class String)
# (as in Java)
# - parameters:
#   - ($sp) - the second string
#   - 4($sp) - old this pointer
#   - $s2 - the first string (this)
# - returns:
#   - $t0 - pointer to concatenated string
########################################################
3748:mth_concat_String:
    # save $ra by pushing onto stack
3748#    subu $sp,$sp,4
3752#    sw $ra, ($sp)

    # get string pointers and check parameter for null
3756#    lw $t0,4($sp)
3760#    beq $t0,$zero,nullPtrException
3764#    move $t1,$s2
    
    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
3768#    lw $t0,-4($t0) # negative size of second object
3772#    lw $t1,-4($t1) # negative size of first object
3776#    addu $s6,$t0,$t1 # sum of negative sizes
3780#    sra $s6,$s6,2 # negative word-size of char part
3784#    subu $s6,$zero,$s6 # word size of char part
3788#    addu $s6,$s6,1 # data word size, including v-table word
3792#    move $s7,$zero
3796#    jal newObject

    # store String vtable address in vtable address field
3800#    la $t0,CLASS_String
3804#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
3808#    lw $t4,-8($s7) # # data words in source string
3812#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
3813##...slt $at,$t4,$zero
3817##...beq $at,$zero,3836
3820#    and $t4,0xff # mask off object's hash value ...
3821##...lui $at,0
3825##...ori $at,$at,0xff
3829##...and $t4,$t4,$at
3832#    sw $t4,-8($s7) # ... and store back into -8 header-word
3836:skipMask_concat:

3836#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
3840#    move $t1,$s2   # first object
3844#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
3848#    lw $t2,-4($t0) # negative length of second object
3852#    lw $t3,-4($t1) # negative length of first object
3856#    addu $t4,$t2,$t3 # sum of negative lengths
3860#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################

    # compute addresses for moving data from first string
3864#    lw $t4,-8($t1) # # data words in first string
3868#    sll $t4,$t4,2 # # data bytes in first string
3872#    subu $t1,$t1,$t4 # addr. (+8) of first byte in first string
3876#    lw $t4,-8($s7) # # data words in new string
3880#    sll $t4,$t4,2 # # data bytes in new string
3884#    subu $s7,$s7,$t4 # addr. (+8) of first byte in new string
3888#    beq $zero,$t3,doneConcatLoop1zz # skip first loop is no bytes to copy
3892#    subu $t3,$t1,$t3 # limit (+8) address for first string

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is address (+8) of first byte in first object
    # - $t2 is negated length of second object
    # - $t3 is limit-address (+8) of data in first object
    # - $s7 is address (+8) of first byte in new object
    # - note: if data-length of first object is zero, then
    #   we skip over this part, and go to 'doneConcatLoop1'
    #########################################################

    # copy the bytes from first source to target
3896:  concatLoop1zz:
3896#    lb $t4,-8($t1)
3900#    sb $t4,-8($s7)
3904#    addu $s7,$s7,1
3908#    addu $t1,$t1,1
3912#    blt $t1,$t3,concatLoop1zz
3913##...slt $at,$t1,$t3
3917##...bne $at,$zero,3896
3920:  doneConcatLoop1zz:
  
    # if second string is empty, skip rest of copy
3920#    beq $zero,$t2,doneConcatLoop2zz

      # compute addresses for moving data from second string
3924#    lw $t4,-8($t0) # # data words in second string
3928#    sll $t4,$t4,2 # # data bytes in second string
3932#    subu $t1,$t0,$t4 # addr. (+8) of first byte in second string
3936#    subu $t3,$t1,$t2 # limit (+8) address for second string

    #########################################################
    # at this point:
    # - $t1 is address (+8) of first byte in second object
    # - $t3 is limit-address (+8) of data in second object
    # - $s7 is address (+8) of next byte to write new object
    # - note: if data-length of second object is zero, then
    #   we skip over this part, and go to 'doneConcatLoop2'
    #########################################################

    # copy the bytes from first source to target
3940:  concatLoop2zz:

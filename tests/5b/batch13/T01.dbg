    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
4068#    lw $t1,cur_seg
4072#    la $t0,seg0_start
4076#    beq $t1,$zero,gcSkip4
4080#    la $t0,seg1_start
4081##...lui $t0,16
4085##...addiu $t0,$t0,5212


4088:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
4088#    bgeu $t0,$s3,gcFinishUp
4089##...sltu $at,$t0,$s3
4093##...beq $at,$zero,4384

    ###### begin outer loop to copy all non-stack-direct objects ######

4096:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
4096#    lw $t1,($t0) # (what will be) first header word for current object
4100#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
4104#    bge $t2,$zero,gcSkip4a # are there hash bits?
4105##...slt $at,$t2,$zero
4109##...beq $at,$zero,4124
4112#    and $t2,0xff # mask off hash bits
4113##...lui $at,0
4117##...ori $at,$at,0xff
4121##...and $t2,$t2,$at
4124:gcSkip4a:    
4124#    sll $t2,$t2,2 # # data bytes
4128#    addu $t2,$t2,8 # to skip header words
4132#    addu $t2,$t0,$t2 # pointer to new object
4136#    lw $t3,-8($t2) # word to swap
4140#    sw $t1,-8($t2) # store header word
4144#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
4148#    lw $t1,-12($t2) # vtable pointer
4152#    li $t0,dataArrayVTableStart # address of vtable for first data array
4156#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
4157##...slt $at,$t1,$t0
4161##...bne $at,$zero,4180

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
4164:  skipToNextObj:
4164#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
4168#    sll $t1,$t1,2 # convert to byte-count
4172#    addu $t0,$t2,$t1 # skip over object
4176#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
4180:  gcNotDataArray:
4180#    lw $t3,-4($t2) # # object words (negative treated as zero)
4184#    bge $t3,$zero,gcH2Neg2
4185##...slt $at,$t3,$zero
4189##...beq $at,$zero,4196
4192#    move $t3,$zero
4196:  gcH2Neg2:
4196#    sll $t3,$t3,2 # # object bytes
4200#    move $t0,$t2 # address of first pointer in object
4204#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
4208#    beq $t0,$s1,gcTestIterDone2
    
4212:  gcNextPointerInObject:
    # get pointer from object
4212#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
4216#    bleu $t1,$t6,gcGoNextPointerSlot
4217##...sltu $at,$t6,$t1
4221##...beq $at,$zero,4364
4224#    bgtu $t1,$t7,gcGoNextPointerSlot
4225##...sltu $at,$t7,$t1
4229##...bne $at,$zero,4364

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4232#    lw $t8,-8($t1) # possible forwarding tag
4236#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
4240#    lw $t8,-4($t1) # forwarding pointer: object's new address
4244#    sw $t8,($t0) # update pointer in object
4248#    j gcGoNextPointerSlot # do next iteration

4252:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
4252#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
4253##...slt $at,$t8,$zero
4257##...beq $at,$zero,4272
4260#    and $t8,0xff # mask off hash bits
4261##...lui $at,0
4265##...ori $at,$at,0xff
4269##...and $t8,$t8,$at

4272:  gcSkip5:
4272#    sll $t8,$t8,2 # bytes in negative-offset portion ...
4276#    addu $t8,$t8,8 # ... add in bytes for header-words
4280#    subu $t4,$t1,$t8 # address of first word of source object
4284#    lw $t3,-4($t1) # # words in positive-offset portion
4288#    bge $t3,$zero,gcNoNeg
4289##...slt $at,$t3,$zero
4293##...beq $at,$zero,4300
4296#    move $t3,$zero # negative treated as zero
4300:  gcNoNeg:
4300#    sll $t3,$t3,2 # bytes in negative-offset portion
4304#    addu $t3,$t3,$t1 # address one word past last word of source

4308#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4312#    lw $s0,($t4)
4316#    lw $t9,-8($t1)
4320#    sw $t9,($t4)
4324#    sw $s0,-8($t1)

    # copy all source bytes to the target
4328:  gCinnerCopy2:
4328#    lw $s0,($t4)
4332#    sw $s0,($s3)
4336#    addu $t4,$t4,4
4340#    addu $s3,$s3,4
4344#    bltu $t4,$t3,gCinnerCopy2
4345##...sltu $at,$t4,$t3
4349##...bne $at,$zero,4328

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4352#    sw $zero,-8($t1) # 0 in first header-slot
4356#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4360#    sw $t8,($t0)

4364:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4364#    addu $t0,$t0,4
4368#    bltu $t0,$s1,gcNextPointerInObject
4369##...sltu $at,$t0,$s1
4373##...bne $at,$zero,4212

4376:  gcTestIterDone2:
4376#    bltu $t0,$s3,gcHeapCopyLoop
4377##...sltu $at,$t0,$s3
4381##...bne $at,$zero,4096

    ###### end outer loop to copy all non-stack-direct objects ######

4384:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4384#    lw $s2,($sp)
4388#    addu $sp,$sp,4

    # mark us as having already GC'd
4392#    move $t5,$s5

    # go try and allocate again
4396#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4400:vm_init:

    # mark bottom of stack
4400#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4404#    move $s2,$zero

    #set up the "five" register
4408#    li $s5,5

4412#    la $s3,seg0_start
4416#    la $s4,seg0_end
4417##...lui $s4,16
4421##...addiu $s4,$s4,5212
    
    # return
4424#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4428:divide:
    # get parameters; abort if divisor zero
4428#    lw $t0,($sp)
4432#    lw $t1,8($sp)
4436#    beq $t0,$zero,divByZeroError
    
    # perform division
4440#    div $t1,$t0
4444#    mflo $t0

    # store result, adjust stack and return
4448#    addu $sp,$sp,8 # adjust stack
4452#    sw $t0,($sp) # store result
4456#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4460:remainder:
    # get parameters; abort if divisor zero
4460#    lw $t0,($sp)
4464#    lw $t1,8($sp)
4468#    beq $t0,$zero,divByZeroError
    
    # perform division
4472#    div $t1,$t0
4476#    mfhi $t0

    # store result, adjust stack and return
4480#    addu $sp,$sp,8 # adjust stack
4484#    sw $t0,($sp) # store result
4488#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4492:checkCast:
    # get object, allow immediately if null
4492#    lw $t2,($sp)
4496#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4500#    lw $t2,-12($t2) # vtable address
4504#    bge $t2,$t1,castException
4505##...slt $at,$t2,$t1
4509##...beq $at,$zero,4644
4512#    blt $t2,$t0,castException
4513##...slt $at,$t2,$t0
4517##...bne $at,$zero,4644
    
    # return, leaving object unchanged on stack
4520:  checkCastReturn:    
4520#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4524:instanceOf:
    # get object, go return false if null
4524#    lw $t2,($sp)
4528#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4532#    lw $t2,-12($t2) # vtable address
4536#    sge $t0,$t2,$t0 # are we >= the lower limit?
4537##...slt $t0,$t2,$t0
4541##...xori $t0,$t0,0x1
4544#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4548#    and $t2,$t0,$t1
4552#    sw $t2,($sp)
4556:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4556#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4560:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4560#    li $v0,4 # syscall-code for print-string
4564#    syscall
4568:exit:
    # print termination message
4568#    li $v0,4 # syscall-code for print-string
4572#    la $a0,exitString
4576#    syscall

    # terminate execution
4580#    li $v0,10 #syscall-code for "exit"
4584#    syscall

4588:outOfHeapMemory:
4588#    la $a0,heapMemoryMsg
4592#    j exitError
4596:divByZeroError:
4596#    la $a0,divByZeroMsg
4600#    j exitError
4604:strIndexOutOfBounds:
4604#    la $a0,strIndexOutOfBoundsMsg
4608#    j exitError
4612:arrayIndexOutOfBounds:
4612#    la $a0,arrayIndexOutOfBoundsMsg
4616#    j exitError
4620:arraySizeOutOfBounds:
4620#    la $a0,arraySizeOutOfBoundsMsg
4624#    j exitError
4628:nullPtrException:
4628#    la $a0,nullPtrExceptionMsg
4632#    j exitError
4636:badIntegerFormat:
4636#    la $a0,badIntegerFormatMsg
4640#    j exitError
4644:castException:
4644#    la $a0,castExceptionMsg
4648#    j exitError
############## data section ################
    .data
4848:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4864:cur_seg:
    .word 0

4868:lastCharRead:
    .word -2 # -2 => no buffered character
4872:prevHashConstant:
    .word 0x2785173c
4876:gcCount:
    .word 0

4880:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4907:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4930:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4965:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4999:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5032:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5063:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5111:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5132:gcMsg: 
      .asciiz "\nGC!\n"
5138:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5170:nullStr:
    .asciiz "null"
5175:trueString:
    .asciiz "true"
5180:falseString:
    .asciiz "false"
5186:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5205:newlineString:
    .asciiz "\n"
    
    .align 2
5208:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5212:seg0_start:
    .space 0x100000
1053788:seg0_end:
1053788:seg1_start:
    .space 0x100000
2102364:seg1_end:

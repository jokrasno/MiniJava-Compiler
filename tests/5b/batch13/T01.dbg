#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
3144:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
3144#    subu $sp,$sp,8
3148#    sw $ra,4($sp)

    # save current sp
3152#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
3156#    li $t3,10

    # get argument, negate if negative
3160#    lw $t1,8($sp)
3164#    bge $t1,$zero,itsNonNegLoop
3165##...slt $at,$t1,$zero
3169##...beq $at,$zero,3176
3172#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
3176:  itsNonNegLoop:
3176#    divu $t1,$t3
3180#    mflo $t1 # quotient
3184#    mfhi $t4 # remainder
3188#    addu $t4,$t4,'0' # turn remainder into digit
3192#    subu $sp,$sp,4

# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1548:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1548#    lw $t0,-8($s2) # get word with hash bits from this
1552#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1556#    addu $t0,$t1

1560#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1564:mth_equals_Object:
1564#    move $t0,$s2 # first pointer (this)
1568#    lw $t1,($sp) # second pointer
1572#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1573##...subu $at,$t0,$t1
1577##...sltiu $t0,$at,1

1580#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1584:mth_hashCode_String:
1584#    move $t0,$s2 # put this pointer in t0

1588#    li $t2,0 # current hash value
1592#    lw $t1,-4($t0) # negative of number of characters in string
1596#    beq $t1,$zero,done_hashCode_String # if zero length => done
1600#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1604#    and $t0,0xfffffffc # adjust for padding
1605##...lui $at,65535
1609##...ori $at,$at,0xfffc
1613##...and $t0,$t0,$at
1616#    subu $t1,$t0,$t1 # address at end of string +12
1620:loop_hashCode_String:    
1620#    sll $t4,$t2,5 # multiply by 32
1624#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1628#    lbu $t3,-12($t0) # current character
1632#    addu $t2,$t3 # add in current character
1636#    addu $t0,1 # go to next character's address
1640#    bne $t0,$t1,loop_hashCode_String # loop back if more
1644:done_hashCode_String:    

    # push int on stack
1644#    move $t0, $t2 # put $t2 in return slot
1648#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1652:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1652#    subu $sp,4
1656#    sw $ra,($sp)
    
    # get hash value
1660#    lw $t2,-12($s2) # vtable address
1664#    lw $t0,($t2) # method address
1668#    jalr $t0
1672#    subu $sp,8 # push result (int in $t0) on stack
1676#    sw $s5,4($sp)
1680#    sw $t0,($sp)

    # compute print-size of hash value
1684#    li $t0, 1
1688#    lw $t1, ($sp)
1692#    srl $t1,$t1,4
1696#    beq $t1,$zero,toString_skip_loop
1700:toString_loop_top:
1700#    addu $t0,1
1704#    srl $t1,$t1,4
1708#    bne $t1,$zero,toString_loop_top
1712:toString_skip_loop:
1712#    subu $sp,8
1716#    sw $s5,4($sp)
1720#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1724#    lw $t2,-12($s2) # vtable address
1728#    move $t0,$t2
1732:toString_checkTagBit:
1732#    subu $t0,1
1736#    lb $t1,($t0)
1740#    and $t1,0x80
1741##...lui $at,0
1745##...ori $at,$at,0x80
1749##...and $t1,$t1,$at
1752#    beq $t1,$zero,toString_checkTagBit
1756#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1760#    subu $sp,8
1764#    sw $t1,($sp)
1768#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1772#    move $s7,$zero # -4 offset header word
1776#    lw $t4,8($sp) # bytes for hash value
1780#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1784#    addu $t4,8
1788#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1792#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1796#    li $t0,CLASS_String # store string vtable address into ...
1800#    sw $t0,-12($s7) # ... -12 offset in object header
1804#    lw $t2,-12($s2) # our object's vtable address
1808#    lw $t5,4($sp) # number characters in prefix
1812#    lw $t1,12($sp) # number of characters in hashcode
1816#    addu $t3,$t1,$t5 # number of characters in string ...
1820#    addu $t3,1 # ... including the '@' character
1824#    subu $t0,$zero,$t3 # store negated length into ...
1828#    sw $t0,-4($s7) # ... -4 offset header word
1832#    lw $t0,-8($s7) # get -8 offset header-word
1836#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1837##...slt $at,$t0,$zero
1841##...beq $at,$zero,1860
1844#    and $t0,0xff # mask off object's hash value ...
1845##...lui $at,0
1849##...ori $at,$at,0xff
1853##...and $t0,$t0,$at
1856#    sw $t0,-8($s7) # ... and store back into -8 header-word
1860:skipMask_toString:
1860#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1864#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1868#    subu $t4,$t2,$t5
1872:toString_copyLoop:    
1872#    lb $t3,($t4)
1876#    and $t3,0x7f # mask off sign bit (in case first word)
1877##...lui $at,0
1881##...ori $at,$at,0x7f
1885##...and $t3,$t3,$at
1888#    sb $t3,-8($t0)
1892#    addu $t4,1
1896#    addu $t0,1
1900#    blt $t4,$t2,toString_copyLoop
1901##...slt $at,$t4,$t2
1905##...bne $at,$zero,1872

    # copy the '@' sign
1908#    li $t3,'@'
1912#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1916#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1920#    lw $t3,20($sp) # hash code to print
1924:toString_hashCopyLoop:
1924#    and $t4,$t3,0xf
1928#    srl $t3,4
1932#    lb $t4,hexChars($t4)
1936#    sb $t4,-8($t2)
1940#    subu $t2,$t2,1
1944#    bgt $t2,$t0,toString_hashCopyLoop
1945##...slt $at,$t0,$t2
1949##...bne $at,$zero,1924

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1952#    addu $sp,28
1956#    lw $ra,($sp)
1960#    addu $sp,4
1964#    move $t0, $s7 # return string we created
1968#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1972:mth_equals_String:
    
    # quick test for obvious false
1972#    lw $t0,($sp) # second parameter
1976#    beq $t0,$zero,goEsFalse # go return false if null
1980#    lw $t1,-12($t0) # vtable pointer
1984#    la $t2,CLASS_String # string vtable pointer
1988#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1992#    subu $sp,12
1996#    sw $ra,8($sp)
2000#    sw $s2,4($sp)
2004#    sw $t0,($sp)
2008#    jal mth_compareTo_String
2012#    lw $s2, 4($sp) #restore this pointer and pop parameters
2016#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2020#    seq $t0,$t0,$zero
2021##...subu $at,$t0,$zero
2025##...sltiu $t0,$at,1

    # pop return address and return $t0
2028#    lw $ra,($sp)
2032#    addu $sp,4

2036#    jr $ra # return
    
2040:goEsFalse:
    # put 0 in $t0 and return
2040#    li $t0, 0
2044#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2048:mth_toString_String:
    #we are a string, so return this.
2048#    move $t0, $s2
2052#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2056:mth_readLine_Lib:
    
2056#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2060#    sw $ra, 4($sp) # save $ra
2064#    move $t1,$sp # save "original" sp

2068:  doRead:

    # read the character
2068#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2072#    subu $t2,$v0,13
2076#    bne $t2,$zero,notReturnRL
2080#    jal readLogicalChar
2084#    subu $t2,$v0,10 # check for newline
2088#    beq $t2,$zero,foundNewLine
2092#    sw $v0,lastCharRead # push back character into queue
2096#    j foundNewLine # go process the line

2100:  notReturnRL:

    # at this point, $v0 has our character

2100#    subu $t0,$v0,10
2104#    beq $t0,$zero,foundNewLine
2108#    blt $v0,$zero,foundEof
2109##...slt $at,$v0,$zero
2113##...bne $at,$zero,2128

    # we have a character, so push it onto stack
2116#    subu $sp,$sp,4
2120#    sw $v0,($sp)

    # loop back up to get next character
2124#    j doRead

2128:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2128#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2132#    li $s7, 0 # return-value: null
2136#    j rlReturn # return

2140:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2140#    subu $t0,$t1,$sp # number of chars we read (times 4)
2144#    srl $s6,$t0,2 # number of words on stack with chars
2148#    subu $sp,$sp,4 # push char-count ...
2152#    sw $s6,($sp) # ... onto stack
2156#    addu $t2,$t0,5 # GC tag, incl. for count-word
2160#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2164#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2168#    srl $s6,$s6,2  # data words in object
2172#    move $s7,$zero # object words in object
2176#    jal newObject  # allocate space
    
    # store header words
2180#    la $t0,CLASS_String
2184#    sw $t0,-12($s7)# store class tag (String) into object
2188#    lw $t2,4($sp) # char-count
2192#    sll $t1,$t2,2 # 4 times number of chars
2196#    subu $t2,$zero,$t2 # negative of char-count
2200#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2204#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2208#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2209##...slt $at,$t0,$zero
2213##...beq $at,$zero,2232
2216#    and $t0,0xff # mask off object's hash value ...
2217##...lui $at,0
2221##...ori $at,$at,0xff
2225##...and $t0,$t0,$at
2228#    sw $t0,-8($s7) # ... and store back into -8 header-word
2232:  skipMask_readLine:

2232#    sll $t0,$t0,2 # data bytes in object
2236#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2240#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2244#    addu $sp,$sp,8 # pop redundant object-pointer and count
2248#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2252#    beq $sp,$t1,rlReturn
2256:  charCopyLoop:
2256#    lw $t2,($sp)
2260#    sb $t2,-9($t0)
2264#    addu $sp,$sp,4
2268#    subu $t0,$t0,1
2272#    bne $sp,$t1,charCopyLoop
2276:  rlReturn:

2276#    lw $ra, 4($sp)
2280#    addu $sp, 8   # pop $ra and pointless word off stack
2284#    move $t0, $s7 # return string we allocated in $s7
2288#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2292:mth_readInt_Lib:

    # save $ra by pushing onto stack
2292#    subu $sp,$sp,4
2296#    sw $ra,($sp)

2300:  riSkipWhiteLoop:
    # read a character
2300#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2304#    subu $t0,$v0,32
2308#    bgt $t0,$zero,nonWhite
2309##...slt $at,$zero,$t0
2313##...bne $at,$zero,2356
2316#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2320#    subu $t0,$v0,10
2324#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2328#    subu $t0,$v0,9
2332#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2336#    subu $t0,$v0,13
2340#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2344#    subu $t0,$v0,12
2348#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2352#    j badIntegerFormat # illegal integer char: abort program

2356:  nonWhite:
2356#    subu $t0,$v0,'-'
2360#    li $t4,1 # final multiplier
2364#    bne $t0,$zero,helpReadInt # go read
2368#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2372#    jal readLogicalChar

2376:  helpReadInt:
2376#    li $t2,10
2380#    subu $t1,$v0,'0' # convert digit to 0-9 value
2384#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2385##...sltu $at,$t1,$t2
2389##...beq $at,$zero,4636
2392#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2396:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2396#    jal readLogicalChar # read next character
2400#    subu $t1,$v0,'0' # convert digit to 0-9 value
2404#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2405##...sltu $at,$t1,$t2
2409##...beq $at,$zero,2428


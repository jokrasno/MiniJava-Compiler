3792#    bgeu $t0,$s3,gcFinishUp
3793##...sltu $at,$t0,$s3
3797##...beq $at,$zero,4088

    ###### begin outer loop to copy all non-stack-direct objects ######

3800:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
3800#    lw $t1,($t0) # (what will be) first header word for current object
3804#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
3808#    bge $t2,$zero,gcSkip4a # are there hash bits?
3809##...slt $at,$t2,$zero
3813##...beq $at,$zero,3828
3816#    and $t2,0xff # mask off hash bits
3817##...lui $at,0
3821##...ori $at,$at,0xff
3825##...and $t2,$t2,$at
3828:gcSkip4a:    
3828#    sll $t2,$t2,2 # # data bytes
3832#    addu $t2,$t2,8 # to skip header words
3836#    addu $t2,$t0,$t2 # pointer to new object
3840#    lw $t3,-8($t2) # word to swap
3844#    sw $t1,-8($t2) # store header word
3848#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3852#    lw $t1,-12($t2) # vtable pointer
3856#    li $t0,dataArrayVTableStart # address of vtable for first data array
3860#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3861##...slt $at,$t1,$t0
3865##...bne $at,$zero,3884

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3868:  skipToNextObj:
3868#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3872#    sll $t1,$t1,2 # convert to byte-count
3876#    addu $t0,$t2,$t1 # skip over object
3880#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3884:  gcNotDataArray:
3884#    lw $t3,-4($t2) # # object words (negative treated as zero)
3888#    bge $t3,$zero,gcH2Neg2
3889##...slt $at,$t3,$zero
3893##...beq $at,$zero,3900
3896#    move $t3,$zero
3900:  gcH2Neg2:
3900#    sll $t3,$t3,2 # # object bytes
3904#    move $t0,$t2 # address of first pointer in object
3908#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3912#    beq $t0,$s1,gcTestIterDone2
    
3916:  gcNextPointerInObject:
    # get pointer from object
3916#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3920#    bleu $t1,$t6,gcGoNextPointerSlot
3921##...sltu $at,$t6,$t1
3925##...beq $at,$zero,4068
3928#    bgtu $t1,$t7,gcGoNextPointerSlot
3929##...sltu $at,$t7,$t1
3933##...bne $at,$zero,4068

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3936#    lw $t8,-8($t1) # possible forwarding tag
3940#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3944#    lw $t8,-4($t1) # forwarding pointer: object's new address
3948#    sw $t8,($t0) # update pointer in object
3952#    j gcGoNextPointerSlot # do next iteration

3956:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3956#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3957##...slt $at,$t8,$zero
3961##...beq $at,$zero,3976
3964#    and $t8,0xff # mask off hash bits
3965##...lui $at,0
3969##...ori $at,$at,0xff
3973##...and $t8,$t8,$at

3976:  gcSkip5:
3976#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3980#    addu $t8,$t8,8 # ... add in bytes for header-words
3984#    subu $t4,$t1,$t8 # address of first word of source object
3988#    lw $t3,-4($t1) # # words in positive-offset portion
3992#    bge $t3,$zero,gcNoNeg
3993##...slt $at,$t3,$zero
3997##...beq $at,$zero,4004
4000#    move $t3,$zero # negative treated as zero
4004:  gcNoNeg:
4004#    sll $t3,$t3,2 # bytes in negative-offset portion
4008#    addu $t3,$t3,$t1 # address one word past last word of source

4012#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4016#    lw $s0,($t4)
4020#    lw $t9,-8($t1)
4024#    sw $t9,($t4)
4028#    sw $s0,-8($t1)

    # copy all source bytes to the target
4032:  gCinnerCopy2:
4032#    lw $s0,($t4)
4036#    sw $s0,($s3)
4040#    addu $t4,$t4,4
4044#    addu $s3,$s3,4
4048#    bltu $t4,$t3,gCinnerCopy2
4049##...sltu $at,$t4,$t3
4053##...bne $at,$zero,4032

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4056#    sw $zero,-8($t1) # 0 in first header-slot
4060#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4064#    sw $t8,($t0)

4068:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4068#    addu $t0,$t0,4
4072#    bltu $t0,$s1,gcNextPointerInObject
4073##...sltu $at,$t0,$s1
4077##...bne $at,$zero,3916

4080:  gcTestIterDone2:
4080#    bltu $t0,$s3,gcHeapCopyLoop
4081##...sltu $at,$t0,$s3
4085##...bne $at,$zero,3800

    ###### end outer loop to copy all non-stack-direct objects ######

4088:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4088#    lw $s2,($sp)
4092#    addu $sp,$sp,4

    # mark us as having already GC'd
4096#    move $t5,$s5

    # go try and allocate again
4100#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4104:vm_init:

    # mark bottom of stack
4104#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4108#    move $s2,$zero

    #set up the "five" register
4112#    li $s5,5

4116#    la $s3,seg0_start
4120#    la $s4,seg0_end
4121##...lui $s4,16
4125##...addiu $s4,$s4,4984
    
    # return
4128#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4132:divide:
    # get parameters; abort if divisor zero
4132#    lw $t0,($sp)
4136#    lw $t1,8($sp)
4140#    beq $t0,$zero,divByZeroError
    
    # perform division
4144#    div $t1,$t0
4148#    mflo $t0

    # store result, adjust stack and return
4152#    addu $sp,$sp,8 # adjust stack
4156#    sw $t0,($sp) # store result
4160#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4164:remainder:
    # get parameters; abort if divisor zero
4164#    lw $t0,($sp)
4168#    lw $t1,8($sp)
4172#    beq $t0,$zero,divByZeroError
    
    # perform division
4176#    div $t1,$t0
4180#    mfhi $t0

    # store result, adjust stack and return
4184#    addu $sp,$sp,8 # adjust stack
4188#    sw $t0,($sp) # store result
4192#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4196:checkCast:
    # get object, allow immediately if null
4196#    lw $t2,($sp)
4200#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4204#    lw $t2,-12($t2) # vtable address
4208#    bge $t2,$t1,castException
4209##...slt $at,$t2,$t1
4213##...beq $at,$zero,4348
4216#    blt $t2,$t0,castException
4217##...slt $at,$t2,$t0
4221##...bne $at,$zero,4348
    
    # return, leaving object unchanged on stack
4224:  checkCastReturn:    
4224#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4228:instanceOf:
    # get object, go return false if null
4228#    lw $t2,($sp)
4232#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4236#    lw $t2,-12($t2) # vtable address
4240#    sge $t0,$t2,$t0 # are we >= the lower limit?
4241##...slt $t0,$t2,$t0
4245##...xori $t0,$t0,0x1
4248#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4252#    and $t2,$t0,$t1
4256#    sw $t2,($sp)
4260:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4260#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4264:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4264#    li $v0,4 # syscall-code for print-string
4268#    syscall
4272:exit:
    # print termination message
4272#    li $v0,4 # syscall-code for print-string
4276#    la $a0,exitString
4280#    syscall

    # terminate execution
4284#    li $v0,10 #syscall-code for "exit"
4288#    syscall

4292:outOfHeapMemory:
4292#    la $a0,heapMemoryMsg
4296#    j exitError
4300:divByZeroError:
4300#    la $a0,divByZeroMsg
4304#    j exitError
4308:strIndexOutOfBounds:
4308#    la $a0,strIndexOutOfBoundsMsg
4312#    j exitError
4316:arrayIndexOutOfBounds:
4316#    la $a0,arrayIndexOutOfBoundsMsg
4320#    j exitError
4324:arraySizeOutOfBounds:
4324#    la $a0,arraySizeOutOfBoundsMsg
4328#    j exitError
4332:nullPtrException:
4332#    la $a0,nullPtrExceptionMsg
4336#    j exitError
4340:badIntegerFormat:
4340#    la $a0,badIntegerFormatMsg
4344#    j exitError
4348:castException:
4348#    la $a0,castExceptionMsg
4352#    j exitError
############## data section ################
    .data
4620:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4636:cur_seg:
    .word 0

4640:lastCharRead:
    .word -2 # -2 => no buffered character
4644:prevHashConstant:
    .word 0x2785173c
4648:gcCount:
    .word 0

4652:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4679:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4702:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4737:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4771:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4804:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4835:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4883:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4904:gcMsg: 
      .asciiz "\nGC!\n"
4910:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4942:nullStr:
    .asciiz "null"
4947:trueString:
    .asciiz "true"
4952:falseString:
    .asciiz "false"
4958:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4977:newlineString:
    .asciiz "\n"
    
    .align 2
4980:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4984:seg0_start:
    .space 0x100000
1053560:seg0_end:
1053560:seg1_start:
    .space 0x100000
2102136:seg1_end:

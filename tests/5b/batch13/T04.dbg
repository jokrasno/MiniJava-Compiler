    # store data in string
3152#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
3156#    li $t0,-1
3160#    sw $t0,-4($s7)

    # we're returning $s7
3164#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
3168#    lw $ra,4($sp)
3172#    addu $sp,$sp,8

    # return
3176#    jr $ra

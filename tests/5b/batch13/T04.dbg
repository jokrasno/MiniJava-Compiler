##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1252:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1252#    lw $t0,-8($s2) # get word with hash bits from this
1256#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1260#    addu $t0,$t1

1264#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1268:mth_equals_Object:
1268#    move $t0,$s2 # first pointer (this)
1272#    lw $t1,($sp) # second pointer
1276#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1277##...subu $at,$t0,$t1
1281##...sltiu $t0,$at,1

1284#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1288:mth_hashCode_String:
1288#    move $t0,$s2 # put this pointer in t0

1292#    li $t2,0 # current hash value
1296#    lw $t1,-4($t0) # negative of number of characters in string
1300#    beq $t1,$zero,done_hashCode_String # if zero length => done
1304#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1308#    and $t0,0xfffffffc # adjust for padding
1309##...lui $at,65535
1313##...ori $at,$at,0xfffc
1317##...and $t0,$t0,$at
1320#    subu $t1,$t0,$t1 # address at end of string +12
1324:loop_hashCode_String:    
1324#    sll $t4,$t2,5 # multiply by 32
1328#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1332#    lbu $t3,-12($t0) # current character
1336#    addu $t2,$t3 # add in current character
1340#    addu $t0,1 # go to next character's address
1344#    bne $t0,$t1,loop_hashCode_String # loop back if more
1348:done_hashCode_String:    

    # push int on stack
1348#    move $t0, $t2 # put $t2 in return slot
1352#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1356:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1356#    subu $sp,4
1360#    sw $ra,($sp)
    
    # get hash value
1364#    lw $t2,-12($s2) # vtable address
1368#    lw $t0,($t2) # method address
1372#    jalr $t0
1376#    subu $sp,8 # push result (int in $t0) on stack
1380#    sw $s5,4($sp)
1384#    sw $t0,($sp)

    # compute print-size of hash value
1388#    li $t0, 1
1392#    lw $t1, ($sp)
1396#    srl $t1,$t1,4
1400#    beq $t1,$zero,toString_skip_loop
1404:toString_loop_top:
1404#    addu $t0,1
1408#    srl $t1,$t1,4
1412#    bne $t1,$zero,toString_loop_top
1416:toString_skip_loop:
1416#    subu $sp,8
1420#    sw $s5,4($sp)
1424#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1428#    lw $t2,-12($s2) # vtable address
1432#    move $t0,$t2
1436:toString_checkTagBit:
1436#    subu $t0,1
1440#    lb $t1,($t0)
1444#    and $t1,0x80
1445##...lui $at,0
1449##...ori $at,$at,0x80
1453##...and $t1,$t1,$at
1456#    beq $t1,$zero,toString_checkTagBit
1460#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1464#    subu $sp,8
1468#    sw $t1,($sp)
1472#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1476#    move $s7,$zero # -4 offset header word
1480#    lw $t4,8($sp) # bytes for hash value
1484#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1488#    addu $t4,8
1492#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1496#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1500#    li $t0,CLASS_String # store string vtable address into ...
1504#    sw $t0,-12($s7) # ... -12 offset in object header
1508#    lw $t2,-12($s2) # our object's vtable address
1512#    lw $t5,4($sp) # number characters in prefix
1516#    lw $t1,12($sp) # number of characters in hashcode
1520#    addu $t3,$t1,$t5 # number of characters in string ...
1524#    addu $t3,1 # ... including the '@' character
1528#    subu $t0,$zero,$t3 # store negated length into ...
1532#    sw $t0,-4($s7) # ... -4 offset header word
1536#    lw $t0,-8($s7) # get -8 offset header-word
1540#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1541##...slt $at,$t0,$zero
1545##...beq $at,$zero,1564
1548#    and $t0,0xff # mask off object's hash value ...
1549##...lui $at,0
1553##...ori $at,$at,0xff
1557##...and $t0,$t0,$at
1560#    sw $t0,-8($s7) # ... and store back into -8 header-word
1564:skipMask_toString:
1564#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1568#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1572#    subu $t4,$t2,$t5
1576:toString_copyLoop:    
1576#    lb $t3,($t4)
1580#    and $t3,0x7f # mask off sign bit (in case first word)
1581##...lui $at,0
1585##...ori $at,$at,0x7f
1589##...and $t3,$t3,$at
1592#    sb $t3,-8($t0)
1596#    addu $t4,1
1600#    addu $t0,1
1604#    blt $t4,$t2,toString_copyLoop
1605##...slt $at,$t4,$t2
1609##...bne $at,$zero,1576

    # copy the '@' sign
1612#    li $t3,'@'
1616#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1620#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1624#    lw $t3,20($sp) # hash code to print
1628:toString_hashCopyLoop:
1628#    and $t4,$t3,0xf
1632#    srl $t3,4
1636#    lb $t4,hexChars($t4)
1640#    sb $t4,-8($t2)
1644#    subu $t2,$t2,1
1648#    bgt $t2,$t0,toString_hashCopyLoop
1649##...slt $at,$t0,$t2
1653##...bne $at,$zero,1628

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1656#    addu $sp,28
1660#    lw $ra,($sp)
1664#    addu $sp,4
1668#    move $t0, $s7 # return string we created
1672#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1676:mth_equals_String:
    
    # quick test for obvious false
1676#    lw $t0,($sp) # second parameter
1680#    beq $t0,$zero,goEsFalse # go return false if null
1684#    lw $t1,-12($t0) # vtable pointer
1688#    la $t2,CLASS_String # string vtable pointer
1692#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1696#    subu $sp,12
1700#    sw $ra,8($sp)
1704#    sw $s2,4($sp)
1708#    sw $t0,($sp)
1712#    jal mth_compareTo_String
1716#    lw $s2, 4($sp) #restore this pointer and pop parameters
1720#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1724#    seq $t0,$t0,$zero
1725##...subu $at,$t0,$zero
1729##...sltiu $t0,$at,1

    # pop return address and return $t0
1732#    lw $ra,($sp)
1736#    addu $sp,4

1740#    jr $ra # return
    
1744:goEsFalse:
    # put 0 in $t0 and return
1744#    li $t0, 0
1748#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1752:mth_toString_String:
    #we are a string, so return this.
1752#    move $t0, $s2
1756#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1760:mth_readLine_Lib:
    
1760#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1764#    sw $ra, 4($sp) # save $ra
1768#    move $t1,$sp # save "original" sp

1772:  doRead:

    # read the character
1772#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1776#    subu $t2,$v0,13
1780#    bne $t2,$zero,notReturnRL
1784#    jal readLogicalChar
1788#    subu $t2,$v0,10 # check for newline
1792#    beq $t2,$zero,foundNewLine
1796#    sw $v0,lastCharRead # push back character into queue
1800#    j foundNewLine # go process the line

1804:  notReturnRL:

    # at this point, $v0 has our character

1804#    subu $t0,$v0,10
1808#    beq $t0,$zero,foundNewLine
1812#    blt $v0,$zero,foundEof
1813##...slt $at,$v0,$zero
1817##...bne $at,$zero,1832

    # we have a character, so push it onto stack
1820#    subu $sp,$sp,4
1824#    sw $v0,($sp)

    # loop back up to get next character
1828#    j doRead

1832:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1832#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1836#    li $s7, 0 # return-value: null
1840#    j rlReturn # return

1844:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1844#    subu $t0,$t1,$sp # number of chars we read (times 4)
1848#    srl $s6,$t0,2 # number of words on stack with chars
1852#    subu $sp,$sp,4 # push char-count ...
1856#    sw $s6,($sp) # ... onto stack
1860#    addu $t2,$t0,5 # GC tag, incl. for count-word
1864#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1868#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1872#    srl $s6,$s6,2  # data words in object
1876#    move $s7,$zero # object words in object
1880#    jal newObject  # allocate space
    
    # store header words
1884#    la $t0,CLASS_String
1888#    sw $t0,-12($s7)# store class tag (String) into object
1892#    lw $t2,4($sp) # char-count
1896#    sll $t1,$t2,2 # 4 times number of chars
1900#    subu $t2,$zero,$t2 # negative of char-count
1904#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1908#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1912#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1913##...slt $at,$t0,$zero
1917##...beq $at,$zero,1936
1920#    and $t0,0xff # mask off object's hash value ...
1921##...lui $at,0
1925##...ori $at,$at,0xff
1929##...and $t0,$t0,$at
1932#    sw $t0,-8($s7) # ... and store back into -8 header-word
1936:  skipMask_readLine:

1936#    sll $t0,$t0,2 # data bytes in object
1940#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1944#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1948#    addu $sp,$sp,8 # pop redundant object-pointer and count
1952#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1956#    beq $sp,$t1,rlReturn
1960:  charCopyLoop:
1960#    lw $t2,($sp)
1964#    sb $t2,-9($t0)
1968#    addu $sp,$sp,4
1972#    subu $t0,$t0,1
1976#    bne $sp,$t1,charCopyLoop
1980:  rlReturn:

1980#    lw $ra, 4($sp)
1984#    addu $sp, 8   # pop $ra and pointless word off stack
1988#    move $t0, $s7 # return string we allocated in $s7
1992#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1996:mth_readInt_Lib:

    # save $ra by pushing onto stack
1996#    subu $sp,$sp,4
2000#    sw $ra,($sp)

2004:  riSkipWhiteLoop:
    # read a character
2004#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2008#    subu $t0,$v0,32
2012#    bgt $t0,$zero,nonWhite
2013##...slt $at,$zero,$t0
2017##...bne $at,$zero,2060
2020#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2024#    subu $t0,$v0,10
2028#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2032#    subu $t0,$v0,9
2036#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2040#    subu $t0,$v0,13
2044#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2048#    subu $t0,$v0,12
2052#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2056#    j badIntegerFormat # illegal integer char: abort program

2060:  nonWhite:
2060#    subu $t0,$v0,'-'
2064#    li $t4,1 # final multiplier
2068#    bne $t0,$zero,helpReadInt # go read
2072#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2076#    jal readLogicalChar

2080:  helpReadInt:
2080#    li $t2,10
2084#    subu $t1,$v0,'0' # convert digit to 0-9 value
2088#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2089##...sltu $at,$t1,$t2
2093##...beq $at,$zero,4340
2096#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2100:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2100#    jal readLogicalChar # read next character
2104#    subu $t1,$v0,'0' # convert digit to 0-9 value
2108#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2109##...sltu $at,$t1,$t2
2113##...beq $at,$zero,2132

2116#    mul $t3,$t3,$t2 # multiply old value by 10
2117##...mult $t3,$t2
2121##...mflo $t3
2124#    addu $t3,$t3,$t1 # add in value of new digit
2128#    j digitLoop

2132:  doneDigitLoop:

    # "push back" unused character into queue
2132#    sw $v0,lastCharRead

    # restore return address
2136#    lw $ra,($sp)
2140#    addu $sp, 4

    # multiply by sign and put return value in $t0
2144#    mult $t3,$t4 # multiply to account for poss. minus sign
2148#    mflo $t3
2152#    move $t0, $t3
    
    # return
2156#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2160:mth_readChar_Lib:

    # save $ra by pushing onto stack
2160#    subu $sp,$sp,4
2164#    sw $ra,($sp)

      # read the character
2168#    jal readLogicalChar


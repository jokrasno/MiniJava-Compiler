    # get begin-of-string addresses
3212#    lw $t2,-8($t0) # # data words in second string
3216#    lw $t3,-8($t1) # # data words in first string
3220#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
3224#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
3228#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
3232#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
3236#    beq $zero,$t5,skipStrCmpLenzz
3240#    move $t2,$t3
3244:  skipStrCmpLenzz:

    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3656#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3657##...slt $at,$t8,$zero
3661##...beq $at,$zero,3676
3664#    and $t8,0xff # mask off hash bits
3665##...lui $at,0
3669##...ori $at,$at,0xff
3673##...and $t8,$t8,$at

3676:  gcSkip5:
3676#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3680#    addu $t8,$t8,8 # ... add in bytes for header-words
3684#    subu $t4,$t1,$t8 # address of first word of source object
3688#    lw $t3,-4($t1) # # words in positive-offset portion
3692#    bge $t3,$zero,gcNoNeg
3693##...slt $at,$t3,$zero
3697##...beq $at,$zero,3704
3700#    move $t3,$zero # negative treated as zero
3704:  gcNoNeg:
3704#    sll $t3,$t3,2 # bytes in negative-offset portion
3708#    addu $t3,$t3,$t1 # address one word past last word of source

3712#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3716#    lw $s0,($t4)
3720#    lw $t9,-8($t1)
3724#    sw $t9,($t4)
3728#    sw $s0,-8($t1)

    # copy all source bytes to the target
3732:  gCinnerCopy2:
3732#    lw $s0,($t4)
3736#    sw $s0,($s3)
3740#    addu $t4,$t4,4
3744#    addu $s3,$s3,4
3748#    bltu $t4,$t3,gCinnerCopy2
3749##...sltu $at,$t4,$t3
3753##...bne $at,$zero,3732

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3756#    sw $zero,-8($t1) # 0 in first header-slot
3760#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3764#    sw $t8,($t0)

3768:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3768#    addu $t0,$t0,4
3772#    bltu $t0,$s1,gcNextPointerInObject
3773##...sltu $at,$t0,$s1
3777##...bne $at,$zero,3616

3780:  gcTestIterDone2:
3780#    bltu $t0,$s3,gcHeapCopyLoop
3781##...sltu $at,$t0,$s3
3785##...bne $at,$zero,3500

    ###### end outer loop to copy all non-stack-direct objects ######

3788:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3788#    lw $s2,($sp)
3792#    addu $sp,$sp,4

    # mark us as having already GC'd
3796#    move $t5,$s5

    # go try and allocate again
3800#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3804:vm_init:

    # mark bottom of stack
3804#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3808#    move $s2,$zero

    #set up the "five" register
3812#    li $s5,5

3816#    la $s3,seg0_start
3820#    la $s4,seg0_end
3821##...lui $s4,16
3825##...addiu $s4,$s4,4616
    
    # return
3828#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3832:divide:
    # get parameters; abort if divisor zero
3832#    lw $t0,($sp)
3836#    lw $t1,8($sp)
3840#    beq $t0,$zero,divByZeroError
    
    # perform division
3844#    div $t1,$t0
3848#    mflo $t0

    # store result, adjust stack and return
3852#    addu $sp,$sp,8 # adjust stack
3856#    sw $t0,($sp) # store result
3860#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3864:remainder:
    # get parameters; abort if divisor zero
3864#    lw $t0,($sp)
3868#    lw $t1,8($sp)
3872#    beq $t0,$zero,divByZeroError
    
    # perform division
3876#    div $t1,$t0
3880#    mfhi $t0

    # store result, adjust stack and return
3884#    addu $sp,$sp,8 # adjust stack
3888#    sw $t0,($sp) # store result
3892#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3896:checkCast:
    # get object, allow immediately if null
3896#    lw $t2,($sp)
3900#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3904#    lw $t2,-12($t2) # vtable address
3908#    bge $t2,$t1,castException
3909##...slt $at,$t2,$t1
3913##...beq $at,$zero,4048
3916#    blt $t2,$t0,castException
3917##...slt $at,$t2,$t0
3921##...bne $at,$zero,4048
    
    # return, leaving object unchanged on stack
3924:  checkCastReturn:    
3924#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3928:instanceOf:
    # get object, go return false if null
3928#    lw $t2,($sp)
3932#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3936#    lw $t2,-12($t2) # vtable address
3940#    sge $t0,$t2,$t0 # are we >= the lower limit?
3941##...slt $t0,$t2,$t0
3945##...xori $t0,$t0,0x1
3948#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3952#    and $t2,$t0,$t1
3956#    sw $t2,($sp)
3960:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3960#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3964:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3964#    li $v0,4 # syscall-code for print-string
3968#    syscall
3972:exit:
    # print termination message
3972#    li $v0,4 # syscall-code for print-string
3976#    la $a0,exitString
3980#    syscall

    # terminate execution
3984#    li $v0,10 #syscall-code for "exit"
3988#    syscall

3992:outOfHeapMemory:
3992#    la $a0,heapMemoryMsg
3996#    j exitError
4000:divByZeroError:
4000#    la $a0,divByZeroMsg
4004#    j exitError
4008:strIndexOutOfBounds:
4008#    la $a0,strIndexOutOfBoundsMsg
4012#    j exitError
4016:arrayIndexOutOfBounds:
4016#    la $a0,arrayIndexOutOfBoundsMsg
4020#    j exitError
4024:arraySizeOutOfBounds:
4024#    la $a0,arraySizeOutOfBoundsMsg
4028#    j exitError
4032:nullPtrException:
4032#    la $a0,nullPtrExceptionMsg
4036#    j exitError
4040:badIntegerFormat:
4040#    la $a0,badIntegerFormatMsg
4044#    j exitError
4048:castException:
4048#    la $a0,castExceptionMsg
4052#    j exitError
############## data section ################
    .data
4252:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4268:cur_seg:
    .word 0

4272:lastCharRead:
    .word -2 # -2 => no buffered character
4276:prevHashConstant:
    .word 0x2785173c
4280:gcCount:
    .word 0

4284:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4311:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4334:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4369:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4403:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4436:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4467:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4515:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4536:gcMsg: 
      .asciiz "\nGC!\n"
4542:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4574:nullStr:
    .asciiz "null"
4579:trueString:
    .asciiz "true"
4584:falseString:
    .asciiz "false"
4590:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4609:newlineString:
    .asciiz "\n"
    
    .align 2
4612:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4616:seg0_start:
    .space 0x100000
1053192:seg0_end:
1053192:seg1_start:
    .space 0x100000
2101768:seg1_end:

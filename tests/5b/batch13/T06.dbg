1720#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1724#    subu $t0,$v0,10
1728#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1732#    subu $t0,$v0,9
1736#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1740#    subu $t0,$v0,13
1744#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1748#    subu $t0,$v0,12
1752#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1756#    j badIntegerFormat # illegal integer char: abort program

1760:  nonWhite:
1760#    subu $t0,$v0,'-'
1764#    li $t4,1 # final multiplier
1768#    bne $t0,$zero,helpReadInt # go read
1772#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1776#    jal readLogicalChar

1780:  helpReadInt:
1780#    li $t2,10
1784#    subu $t1,$v0,'0' # convert digit to 0-9 value

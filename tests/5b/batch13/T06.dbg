##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
952:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
952#    lw $t0,-8($s2) # get word with hash bits from this
956#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
960#    addu $t0,$t1

964#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
968:mth_equals_Object:
968#    move $t0,$s2 # first pointer (this)
972#    lw $t1,($sp) # second pointer
976#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
977##...subu $at,$t0,$t1
981##...sltiu $t0,$at,1

984#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
988:mth_hashCode_String:
988#    move $t0,$s2 # put this pointer in t0

992#    li $t2,0 # current hash value
996#    lw $t1,-4($t0) # negative of number of characters in string
1000#    beq $t1,$zero,done_hashCode_String # if zero length => done
1004#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1008#    and $t0,0xfffffffc # adjust for padding
1009##...lui $at,65535
1013##...ori $at,$at,0xfffc
1017##...and $t0,$t0,$at
1020#    subu $t1,$t0,$t1 # address at end of string +12
1024:loop_hashCode_String:    
1024#    sll $t4,$t2,5 # multiply by 32
1028#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1032#    lbu $t3,-12($t0) # current character
1036#    addu $t2,$t3 # add in current character
1040#    addu $t0,1 # go to next character's address
1044#    bne $t0,$t1,loop_hashCode_String # loop back if more
1048:done_hashCode_String:    

    # push int on stack
1048#    move $t0, $t2 # put $t2 in return slot
1052#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1056:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1056#    subu $sp,4
1060#    sw $ra,($sp)
    
    # get hash value
1064#    lw $t2,-12($s2) # vtable address
1068#    lw $t0,($t2) # method address
1072#    jalr $t0
1076#    subu $sp,8 # push result (int in $t0) on stack
1080#    sw $s5,4($sp)
1084#    sw $t0,($sp)

    # compute print-size of hash value
1088#    li $t0, 1
1092#    lw $t1, ($sp)
1096#    srl $t1,$t1,4
1100#    beq $t1,$zero,toString_skip_loop
1104:toString_loop_top:
1104#    addu $t0,1
1108#    srl $t1,$t1,4
1112#    bne $t1,$zero,toString_loop_top
1116:toString_skip_loop:
1116#    subu $sp,8
1120#    sw $s5,4($sp)
1124#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1128#    lw $t2,-12($s2) # vtable address
1132#    move $t0,$t2
1136:toString_checkTagBit:
1136#    subu $t0,1
1140#    lb $t1,($t0)
1144#    and $t1,0x80
1145##...lui $at,0
1149##...ori $at,$at,0x80
1153##...and $t1,$t1,$at
1156#    beq $t1,$zero,toString_checkTagBit
1160#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1164#    subu $sp,8
1168#    sw $t1,($sp)
1172#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1176#    move $s7,$zero # -4 offset header word
1180#    lw $t4,8($sp) # bytes for hash value
1184#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1188#    addu $t4,8
1192#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1196#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1200#    li $t0,CLASS_String # store string vtable address into ...
1204#    sw $t0,-12($s7) # ... -12 offset in object header
1208#    lw $t2,-12($s2) # our object's vtable address
1212#    lw $t5,4($sp) # number characters in prefix
1216#    lw $t1,12($sp) # number of characters in hashcode
1220#    addu $t3,$t1,$t5 # number of characters in string ...
1224#    addu $t3,1 # ... including the '@' character
1228#    subu $t0,$zero,$t3 # store negated length into ...
1232#    sw $t0,-4($s7) # ... -4 offset header word
1236#    lw $t0,-8($s7) # get -8 offset header-word
1240#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1241##...slt $at,$t0,$zero
1245##...beq $at,$zero,1264
1248#    and $t0,0xff # mask off object's hash value ...
1249##...lui $at,0
1253##...ori $at,$at,0xff
1257##...and $t0,$t0,$at
1260#    sw $t0,-8($s7) # ... and store back into -8 header-word
1264:skipMask_toString:
1264#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1268#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1272#    subu $t4,$t2,$t5
1276:toString_copyLoop:    
1276#    lb $t3,($t4)
1280#    and $t3,0x7f # mask off sign bit (in case first word)
1281##...lui $at,0
1285##...ori $at,$at,0x7f
1289##...and $t3,$t3,$at
1292#    sb $t3,-8($t0)
1296#    addu $t4,1
1300#    addu $t0,1
1304#    blt $t4,$t2,toString_copyLoop
1305##...slt $at,$t4,$t2
1309##...bne $at,$zero,1276

    # copy the '@' sign
1312#    li $t3,'@'
1316#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1320#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1324#    lw $t3,20($sp) # hash code to print
1328:toString_hashCopyLoop:
1328#    and $t4,$t3,0xf
1332#    srl $t3,4
1336#    lb $t4,hexChars($t4)
1340#    sb $t4,-8($t2)
1344#    subu $t2,$t2,1
1348#    bgt $t2,$t0,toString_hashCopyLoop
1349##...slt $at,$t0,$t2
1353##...bne $at,$zero,1328

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1356#    addu $sp,28
1360#    lw $ra,($sp)
1364#    addu $sp,4
1368#    move $t0, $s7 # return string we created
1372#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1460:mth_readLine_Lib:
    
1460#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1464#    sw $ra, 4($sp) # save $ra
1468#    move $t1,$sp # save "original" sp

1472:  doRead:

    # read the character
1472#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1476#    subu $t2,$v0,13
1480#    bne $t2,$zero,notReturnRL
1484#    jal readLogicalChar
1488#    subu $t2,$v0,10 # check for newline
1492#    beq $t2,$zero,foundNewLine
1496#    sw $v0,lastCharRead # push back character into queue
1500#    j foundNewLine # go process the line

1504:  notReturnRL:

    # at this point, $v0 has our character

1504#    subu $t0,$v0,10
1508#    beq $t0,$zero,foundNewLine
1512#    blt $v0,$zero,foundEof
1513##...slt $at,$v0,$zero
1517##...bne $at,$zero,1532

    # we have a character, so push it onto stack
1520#    subu $sp,$sp,4
1524#    sw $v0,($sp)

    # loop back up to get next character
1528#    j doRead

1532:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1532#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1536#    li $s7, 0 # return-value: null
1540#    j rlReturn # return

1544:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1544#    subu $t0,$t1,$sp # number of chars we read (times 4)
1548#    srl $s6,$t0,2 # number of words on stack with chars
1552#    subu $sp,$sp,4 # push char-count ...
1556#    sw $s6,($sp) # ... onto stack
1560#    addu $t2,$t0,5 # GC tag, incl. for count-word
1564#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1568#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1572#    srl $s6,$s6,2  # data words in object
1576#    move $s7,$zero # object words in object
1580#    jal newObject  # allocate space
    
    # store header words
1584#    la $t0,CLASS_String
1588#    sw $t0,-12($s7)# store class tag (String) into object
1592#    lw $t2,4($sp) # char-count
1596#    sll $t1,$t2,2 # 4 times number of chars
1600#    subu $t2,$zero,$t2 # negative of char-count
1604#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1608#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1612#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1613##...slt $at,$t0,$zero
1617##...beq $at,$zero,1636
1620#    and $t0,0xff # mask off object's hash value ...
1621##...lui $at,0
1625##...ori $at,$at,0xff
1629##...and $t0,$t0,$at
1632#    sw $t0,-8($s7) # ... and store back into -8 header-word
1636:  skipMask_readLine:

1636#    sll $t0,$t0,2 # data bytes in object
1640#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1644#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1648#    addu $sp,$sp,8 # pop redundant object-pointer and count
1652#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1656#    beq $sp,$t1,rlReturn
1660:  charCopyLoop:
1660#    lw $t2,($sp)
1664#    sb $t2,-9($t0)
1668#    addu $sp,$sp,4
1672#    subu $t0,$t0,1
1676#    bne $sp,$t1,charCopyLoop
1680:  rlReturn:

1680#    lw $ra, 4($sp)
1684#    addu $sp, 8   # pop $ra and pointless word off stack
1688#    move $t0, $s7 # return string we allocated in $s7
1692#    jr $ra

1800:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1800#    jal readLogicalChar # read next character
1804#    subu $t1,$v0,'0' # convert digit to 0-9 value
1808#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1809##...sltu $at,$t1,$t2
1813##...beq $at,$zero,1832

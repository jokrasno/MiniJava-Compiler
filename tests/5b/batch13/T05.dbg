    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3496#    lw $s0,($t4)
3500#    lw $t9,-8($t1)
3504#    sw $t9,($t4)
3508#    sw $s0,-8($t1)

    # copy all source bytes to the target
3512:  gCinnerCopy2:
3512#    lw $s0,($t4)
3516#    sw $s0,($s3)
3520#    addu $t4,$t4,4
3524#    addu $s3,$s3,4
3528#    bltu $t4,$t3,gCinnerCopy2
3529##...sltu $at,$t4,$t3
3533##...bne $at,$zero,3512

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3536#    sw $zero,-8($t1) # 0 in first header-slot
3540#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3544#    sw $t8,($t0)

3548:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3548#    addu $t0,$t0,4
3552#    bltu $t0,$s1,gcNextPointerInObject
3553##...sltu $at,$t0,$s1
3557##...bne $at,$zero,3396

3560:  gcTestIterDone2:
3560#    bltu $t0,$s3,gcHeapCopyLoop
3561##...sltu $at,$t0,$s3
3565##...bne $at,$zero,3280

    ###### end outer loop to copy all non-stack-direct objects ######

3568:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3568#    lw $s2,($sp)
3572#    addu $sp,$sp,4

    # mark us as having already GC'd
3576#    move $t5,$s5

    # go try and allocate again
3580#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3584:vm_init:

    # mark bottom of stack
3584#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3588#    move $s2,$zero

    #set up the "five" register
3592#    li $s5,5

3596#    la $s3,seg0_start
3600#    la $s4,seg0_end
3601##...lui $s4,16
3605##...addiu $s4,$s4,4420
    
    # return
3608#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3612:divide:
    # get parameters; abort if divisor zero
3612#    lw $t0,($sp)
3616#    lw $t1,8($sp)
3620#    beq $t0,$zero,divByZeroError
    
    # perform division
3624#    div $t1,$t0
3628#    mflo $t0

    # store result, adjust stack and return
3632#    addu $sp,$sp,8 # adjust stack
3636#    sw $t0,($sp) # store result
3640#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3644:remainder:
    # get parameters; abort if divisor zero
3644#    lw $t0,($sp)
3648#    lw $t1,8($sp)
3652#    beq $t0,$zero,divByZeroError
    
    # perform division
3656#    div $t1,$t0
3660#    mfhi $t0

    # store result, adjust stack and return
3664#    addu $sp,$sp,8 # adjust stack
3668#    sw $t0,($sp) # store result
3672#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3676:checkCast:
    # get object, allow immediately if null
3676#    lw $t2,($sp)
3680#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3684#    lw $t2,-12($t2) # vtable address
3688#    bge $t2,$t1,castException
3689##...slt $at,$t2,$t1
3693##...beq $at,$zero,3828
3696#    blt $t2,$t0,castException
3697##...slt $at,$t2,$t0
3701##...bne $at,$zero,3828
    
    # return, leaving object unchanged on stack
3704:  checkCastReturn:    
3704#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3708:instanceOf:
    # get object, go return false if null
3708#    lw $t2,($sp)
3712#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3716#    lw $t2,-12($t2) # vtable address
3720#    sge $t0,$t2,$t0 # are we >= the lower limit?
3721##...slt $t0,$t2,$t0
3725##...xori $t0,$t0,0x1
3728#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3732#    and $t2,$t0,$t1
3736#    sw $t2,($sp)
3740:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3740#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3744:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3744#    li $v0,4 # syscall-code for print-string
3748#    syscall
3752:exit:
    # print termination message
3752#    li $v0,4 # syscall-code for print-string
3756#    la $a0,exitString
3760#    syscall

    # terminate execution
3764#    li $v0,10 #syscall-code for "exit"
3768#    syscall

3772:outOfHeapMemory:
3772#    la $a0,heapMemoryMsg
3776#    j exitError
3780:divByZeroError:
3780#    la $a0,divByZeroMsg
3784#    j exitError
3788:strIndexOutOfBounds:
3788#    la $a0,strIndexOutOfBoundsMsg
3792#    j exitError
3796:arrayIndexOutOfBounds:
3796#    la $a0,arrayIndexOutOfBoundsMsg
3800#    j exitError
3804:arraySizeOutOfBounds:
3804#    la $a0,arraySizeOutOfBoundsMsg
3808#    j exitError
3812:nullPtrException:
3812#    la $a0,nullPtrExceptionMsg
3816#    j exitError
3820:badIntegerFormat:
3820#    la $a0,badIntegerFormatMsg
3824#    j exitError
3828:castException:
3828#    la $a0,castExceptionMsg
3832#    j exitError
############## data section ################
    .data
4056:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4072:cur_seg:
    .word 0

4076:lastCharRead:
    .word -2 # -2 => no buffered character
4080:prevHashConstant:
    .word 0x2785173c
4084:gcCount:
    .word 0

4088:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4115:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4138:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4173:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4207:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4240:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4271:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4319:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4340:gcMsg: 
      .asciiz "\nGC!\n"
4346:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4378:nullStr:
    .asciiz "null"
4383:trueString:
    .asciiz "true"
4388:falseString:
    .asciiz "false"
4394:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4413:newlineString:
    .asciiz "\n"
    
    .align 2
4416:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4420:seg0_start:
    .space 0x100000
1052996:seg0_end:
1052996:seg1_start:
    .space 0x100000
2101572:seg1_end:

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
732:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
732#    lw $t0,-8($s2) # get word with hash bits from this
736#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
740#    addu $t0,$t1

744#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
748:mth_equals_Object:
748#    move $t0,$s2 # first pointer (this)
752#    lw $t1,($sp) # second pointer
756#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
757##...subu $at,$t0,$t1
761##...sltiu $t0,$at,1

764#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
768:mth_hashCode_String:
768#    move $t0,$s2 # put this pointer in t0

772#    li $t2,0 # current hash value
776#    lw $t1,-4($t0) # negative of number of characters in string
780#    beq $t1,$zero,done_hashCode_String # if zero length => done
784#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
788#    and $t0,0xfffffffc # adjust for padding
789##...lui $at,65535
793##...ori $at,$at,0xfffc
797##...and $t0,$t0,$at
800#    subu $t1,$t0,$t1 # address at end of string +12
804:loop_hashCode_String:    
804#    sll $t4,$t2,5 # multiply by 32
808#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
812#    lbu $t3,-12($t0) # current character
816#    addu $t2,$t3 # add in current character
820#    addu $t0,1 # go to next character's address
824#    bne $t0,$t1,loop_hashCode_String # loop back if more
828:done_hashCode_String:    

    # push int on stack
828#    move $t0, $t2 # put $t2 in return slot
832#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
836:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
836#    subu $sp,4
840#    sw $ra,($sp)
    
    # get hash value
844#    lw $t2,-12($s2) # vtable address
848#    lw $t0,($t2) # method address
852#    jalr $t0
856#    subu $sp,8 # push result (int in $t0) on stack
860#    sw $s5,4($sp)
864#    sw $t0,($sp)

    # compute print-size of hash value
868#    li $t0, 1
872#    lw $t1, ($sp)
876#    srl $t1,$t1,4
880#    beq $t1,$zero,toString_skip_loop
884:toString_loop_top:
884#    addu $t0,1
888#    srl $t1,$t1,4
892#    bne $t1,$zero,toString_loop_top
896:toString_skip_loop:
896#    subu $sp,8
900#    sw $s5,4($sp)
904#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
908#    lw $t2,-12($s2) # vtable address
912#    move $t0,$t2
916:toString_checkTagBit:
916#    subu $t0,1
920#    lb $t1,($t0)
924#    and $t1,0x80
925##...lui $at,0
929##...ori $at,$at,0x80
933##...and $t1,$t1,$at
936#    beq $t1,$zero,toString_checkTagBit
940#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
944#    subu $sp,8
948#    sw $t1,($sp)
952#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
956#    move $s7,$zero # -4 offset header word
960#    lw $t4,8($sp) # bytes for hash value
964#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
968#    addu $t4,8
972#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
976#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

980#    li $t0,CLASS_String # store string vtable address into ...
984#    sw $t0,-12($s7) # ... -12 offset in object header
988#    lw $t2,-12($s2) # our object's vtable address
992#    lw $t5,4($sp) # number characters in prefix
996#    lw $t1,12($sp) # number of characters in hashcode
1000#    addu $t3,$t1,$t5 # number of characters in string ...
1004#    addu $t3,1 # ... including the '@' character
1008#    subu $t0,$zero,$t3 # store negated length into ...
1012#    sw $t0,-4($s7) # ... -4 offset header word
1016#    lw $t0,-8($s7) # get -8 offset header-word
1020#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1021##...slt $at,$t0,$zero
1025##...beq $at,$zero,1044

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1240:mth_readLine_Lib:
    
1240#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1244#    sw $ra, 4($sp) # save $ra
1248#    move $t1,$sp # save "original" sp

1252:  doRead:

    # read the character
1252#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1256#    subu $t2,$v0,13
1260#    bne $t2,$zero,notReturnRL
1264#    jal readLogicalChar
1268#    subu $t2,$v0,10 # check for newline
1272#    beq $t2,$zero,foundNewLine
1276#    sw $v0,lastCharRead # push back character into queue
1280#    j foundNewLine # go process the line

1284:  notReturnRL:

    # at this point, $v0 has our character

1284#    subu $t0,$v0,10
1288#    beq $t0,$zero,foundNewLine
1292#    blt $v0,$zero,foundEof
1293##...slt $at,$v0,$zero
1297##...bne $at,$zero,1312

    # we have a character, so push it onto stack
1300#    subu $sp,$sp,4
1304#    sw $v0,($sp)

    # loop back up to get next character
1308#    j doRead

1312:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1312#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1316#    li $s7, 0 # return-value: null
1320#    j rlReturn # return

1324:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1324#    subu $t0,$t1,$sp # number of chars we read (times 4)
1328#    srl $s6,$t0,2 # number of words on stack with chars
1332#    subu $sp,$sp,4 # push char-count ...
1336#    sw $s6,($sp) # ... onto stack
1340#    addu $t2,$t0,5 # GC tag, incl. for count-word
1344#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1348#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1352#    srl $s6,$s6,2  # data words in object
1356#    move $s7,$zero # object words in object
1360#    jal newObject  # allocate space
    
    # store header words
1364#    la $t0,CLASS_String
1368#    sw $t0,-12($s7)# store class tag (String) into object
1372#    lw $t2,4($sp) # char-count
1376#    sll $t1,$t2,2 # 4 times number of chars
1380#    subu $t2,$zero,$t2 # negative of char-count
1384#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1388#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1392#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1393##...slt $at,$t0,$zero
1397##...beq $at,$zero,1416
1400#    and $t0,0xff # mask off object's hash value ...
1401##...lui $at,0
1405##...ori $at,$at,0xff
1409##...and $t0,$t0,$at
1412#    sw $t0,-8($s7) # ... and store back into -8 header-word
1416:  skipMask_readLine:

1416#    sll $t0,$t0,2 # data bytes in object
1420#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1424#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1428#    addu $sp,$sp,8 # pop redundant object-pointer and count
1432#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1436#    beq $sp,$t1,rlReturn
1440:  charCopyLoop:
1440#    lw $t2,($sp)
1444#    sb $t2,-9($t0)
1448#    addu $sp,$sp,4
1452#    subu $t0,$t0,1
1456#    bne $sp,$t1,charCopyLoop
1460:  rlReturn:

1460#    lw $ra, 4($sp)
1464#    addu $sp, 8   # pop $ra and pointless word off stack
1468#    move $t0, $s7 # return string we allocated in $s7
1472#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace

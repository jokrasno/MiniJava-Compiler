1500#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1504#    subu $t0,$v0,10
1508#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1512#    subu $t0,$v0,9
1516#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1520#    subu $t0,$v0,13
1524#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1528#    subu $t0,$v0,12

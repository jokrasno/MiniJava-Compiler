3008#    la $s4,seg0_end
3009##...lui $s4,16
3013##...addiu $s4,$s4,4420
3016#    sw $zero,cur_seg
3020#    bne $t0,$zero,skipGc1
3024#    la $t6,seg0_start
3028#    la $s3,seg1_start
3029##...lui $s3,16
3033##...addiu $s3,$s3,4420
3036#    la $s4,seg1_end

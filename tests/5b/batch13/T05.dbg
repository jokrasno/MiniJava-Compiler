1536#    j badIntegerFormat # illegal integer char: abort program

1540:  nonWhite:
1540#    subu $t0,$v0,'-'
1544#    li $t4,1 # final multiplier
1548#    bne $t0,$zero,helpReadInt # go read
1552#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1556#    jal readLogicalChar

1560:  helpReadInt:
1560#    li $t2,10

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1156:mth_equals_String:
    
    # quick test for obvious false
1156#    lw $t0,($sp) # second parameter
1160#    beq $t0,$zero,goEsFalse # go return false if null
1164#    lw $t1,-12($t0) # vtable pointer
1168#    la $t2,CLASS_String # string vtable pointer
1172#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1176#    subu $sp,12
1180#    sw $ra,8($sp)
1184#    sw $s2,4($sp)
1188#    sw $t0,($sp)
1192#    jal mth_compareTo_String
1196#    lw $s2, 4($sp) #restore this pointer and pop parameters
1200#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1204#    seq $t0,$t0,$zero
1205##...subu $at,$t0,$zero
1209##...sltiu $t0,$at,1

    # pop return address and return $t0
1212#    lw $ra,($sp)
1216#    addu $sp,4

1220#    jr $ra # return
    
1224:goEsFalse:
    # put 0 in $t0 and return
1224#    li $t0, 0
1228#    jr $ra # return

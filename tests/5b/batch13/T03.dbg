##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
948:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
948#    lw $t0,-8($s2) # get word with hash bits from this
952#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
956#    addu $t0,$t1

960#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
964:mth_equals_Object:
964#    move $t0,$s2 # first pointer (this)
968#    lw $t1,($sp) # second pointer
972#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
973##...subu $at,$t0,$t1
977##...sltiu $t0,$at,1

980#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
984:mth_hashCode_String:
984#    move $t0,$s2 # put this pointer in t0

988#    li $t2,0 # current hash value
992#    lw $t1,-4($t0) # negative of number of characters in string
996#    beq $t1,$zero,done_hashCode_String # if zero length => done
1000#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1004#    and $t0,0xfffffffc # adjust for padding
1005##...lui $at,65535
1009##...ori $at,$at,0xfffc
1013##...and $t0,$t0,$at
1016#    subu $t1,$t0,$t1 # address at end of string +12
1020:loop_hashCode_String:    
1020#    sll $t4,$t2,5 # multiply by 32
1024#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1028#    lbu $t3,-12($t0) # current character
1032#    addu $t2,$t3 # add in current character
1036#    addu $t0,1 # go to next character's address
1040#    bne $t0,$t1,loop_hashCode_String # loop back if more
1044:done_hashCode_String:    

    # push int on stack
1044#    move $t0, $t2 # put $t2 in return slot
1048#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1052:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1052#    subu $sp,4
1056#    sw $ra,($sp)
    
    # get hash value
1060#    lw $t2,-12($s2) # vtable address
1064#    lw $t0,($t2) # method address
1068#    jalr $t0
1072#    subu $sp,8 # push result (int in $t0) on stack
1076#    sw $s5,4($sp)
1080#    sw $t0,($sp)

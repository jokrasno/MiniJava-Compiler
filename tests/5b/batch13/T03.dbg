    # we have our character from the buffer. Wipe out
    # buffer and return
3004#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
3008#    jr $ra # return
    
3012:  doReadCh:
    # we need to actually read a character: read and return
3012#    li $v0,12 # use system call to read a character
3016#    syscall
3020#    jr $ra # return

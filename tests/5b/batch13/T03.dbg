###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1456:mth_readLine_Lib:
    
1456#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1460#    sw $ra, 4($sp) # save $ra
1464#    move $t1,$sp # save "original" sp

1468:  doRead:

    # read the character
1468#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1472#    subu $t2,$v0,13
1476#    bne $t2,$zero,notReturnRL
1480#    jal readLogicalChar
1484#    subu $t2,$v0,10 # check for newline
1488#    beq $t2,$zero,foundNewLine
1492#    sw $v0,lastCharRead # push back character into queue
1496#    j foundNewLine # go process the line

1500:  notReturnRL:

    # at this point, $v0 has our character

1500#    subu $t0,$v0,10
1504#    beq $t0,$zero,foundNewLine
1508#    blt $v0,$zero,foundEof
1509##...slt $at,$v0,$zero
1513##...bne $at,$zero,1528

    # we have a character, so push it onto stack
1516#    subu $sp,$sp,4
1520#    sw $v0,($sp)

    # loop back up to get next character
1524#    j doRead

1528:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1528#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1532#    li $s7, 0 # return-value: null
1536#    j rlReturn # return

1540:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1540#    subu $t0,$t1,$sp # number of chars we read (times 4)
1544#    srl $s6,$t0,2 # number of words on stack with chars
1548#    subu $sp,$sp,4 # push char-count ...
1552#    sw $s6,($sp) # ... onto stack
1556#    addu $t2,$t0,5 # GC tag, incl. for count-word
1560#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1564#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1568#    srl $s6,$s6,2  # data words in object
1572#    move $s7,$zero # object words in object
1576#    jal newObject  # allocate space
    
    # store header words
1580#    la $t0,CLASS_String
1584#    sw $t0,-12($s7)# store class tag (String) into object
1588#    lw $t2,4($sp) # char-count
1592#    sll $t1,$t2,2 # 4 times number of chars
1596#    subu $t2,$zero,$t2 # negative of char-count
1600#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1604#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1608#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1609##...slt $at,$t0,$zero
1613##...beq $at,$zero,1632
1616#    and $t0,0xff # mask off object's hash value ...
1617##...lui $at,0
1621##...ori $at,$at,0xff
1625##...and $t0,$t0,$at
1628#    sw $t0,-8($s7) # ... and store back into -8 header-word
1632:  skipMask_readLine:

1632#    sll $t0,$t0,2 # data bytes in object
1636#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1640#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1644#    addu $sp,$sp,8 # pop redundant object-pointer and count
1648#    addu $t1,$t1,$sp # first non-char spot on stack

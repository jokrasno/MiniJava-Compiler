    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3608#    beq $t0,$s1,gcTestIterDone2
    
3612:  gcNextPointerInObject:
    # get pointer from object
3612#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3616#    bleu $t1,$t6,gcGoNextPointerSlot
3617##...sltu $at,$t6,$t1
3621##...beq $at,$zero,3764
3624#    bgtu $t1,$t7,gcGoNextPointerSlot
3625##...sltu $at,$t7,$t1
3629##...bne $at,$zero,3764

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3632#    lw $t8,-8($t1) # possible forwarding tag
3636#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3640#    lw $t8,-4($t1) # forwarding pointer: object's new address
3644#    sw $t8,($t0) # update pointer in object
3648#    j gcGoNextPointerSlot # do next iteration

3652:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3652#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3653##...slt $at,$t8,$zero
3657##...beq $at,$zero,3672
3660#    and $t8,0xff # mask off hash bits
3661##...lui $at,0
3665##...ori $at,$at,0xff
3669##...and $t8,$t8,$at

3672:  gcSkip5:
3672#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3676#    addu $t8,$t8,8 # ... add in bytes for header-words
3680#    subu $t4,$t1,$t8 # address of first word of source object
3684#    lw $t3,-4($t1) # # words in positive-offset portion
3688#    bge $t3,$zero,gcNoNeg
3689##...slt $at,$t3,$zero
3693##...beq $at,$zero,3700
3696#    move $t3,$zero # negative treated as zero
3700:  gcNoNeg:
3700#    sll $t3,$t3,2 # bytes in negative-offset portion
3704#    addu $t3,$t3,$t1 # address one word past last word of source

3708#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3712#    lw $s0,($t4)
3716#    lw $t9,-8($t1)
3720#    sw $t9,($t4)
3724#    sw $s0,-8($t1)

    # copy all source bytes to the target
3728:  gCinnerCopy2:
3728#    lw $s0,($t4)
3732#    sw $s0,($s3)
3736#    addu $t4,$t4,4
3740#    addu $s3,$s3,4
3744#    bltu $t4,$t3,gCinnerCopy2
3745##...sltu $at,$t4,$t3
3749##...bne $at,$zero,3728

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3752#    sw $zero,-8($t1) # 0 in first header-slot
3756#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3760#    sw $t8,($t0)

3764:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3764#    addu $t0,$t0,4
3768#    bltu $t0,$s1,gcNextPointerInObject
3769##...sltu $at,$t0,$s1
3773##...bne $at,$zero,3612

3776:  gcTestIterDone2:
3776#    bltu $t0,$s3,gcHeapCopyLoop
3777##...sltu $at,$t0,$s3
3781##...bne $at,$zero,3496

    ###### end outer loop to copy all non-stack-direct objects ######

3784:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3784#    lw $s2,($sp)
3788#    addu $sp,$sp,4

    # mark us as having already GC'd
3792#    move $t5,$s5

    # go try and allocate again
3796#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3800:vm_init:

    # mark bottom of stack
3800#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3804#    move $s2,$zero

    #set up the "five" register
3808#    li $s5,5

3812#    la $s3,seg0_start
3816#    la $s4,seg0_end
3817##...lui $s4,16
3821##...addiu $s4,$s4,4680
    
    # return
3824#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3828:divide:
    # get parameters; abort if divisor zero
3828#    lw $t0,($sp)
3832#    lw $t1,8($sp)
3836#    beq $t0,$zero,divByZeroError
    
    # perform division
3840#    div $t1,$t0
3844#    mflo $t0

    # store result, adjust stack and return
3848#    addu $sp,$sp,8 # adjust stack
3852#    sw $t0,($sp) # store result
3856#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3860:remainder:
    # get parameters; abort if divisor zero
3860#    lw $t0,($sp)
3864#    lw $t1,8($sp)
3868#    beq $t0,$zero,divByZeroError
    
    # perform division
3872#    div $t1,$t0
3876#    mfhi $t0

    # store result, adjust stack and return
3880#    addu $sp,$sp,8 # adjust stack
3884#    sw $t0,($sp) # store result
3888#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3892:checkCast:
    # get object, allow immediately if null
3892#    lw $t2,($sp)
3896#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3900#    lw $t2,-12($t2) # vtable address
3904#    bge $t2,$t1,castException
3905##...slt $at,$t2,$t1
3909##...beq $at,$zero,4044
3912#    blt $t2,$t0,castException
3913##...slt $at,$t2,$t0
3917##...bne $at,$zero,4044
    
    # return, leaving object unchanged on stack
3920:  checkCastReturn:    
3920#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3924:instanceOf:
    # get object, go return false if null
3924#    lw $t2,($sp)
3928#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3932#    lw $t2,-12($t2) # vtable address
3936#    sge $t0,$t2,$t0 # are we >= the lower limit?
3937##...slt $t0,$t2,$t0
3941##...xori $t0,$t0,0x1
3944#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3948#    and $t2,$t0,$t1
3952#    sw $t2,($sp)
3956:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3956#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3960:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3960#    li $v0,4 # syscall-code for print-string
3964#    syscall
3968:exit:
    # print termination message
3968#    li $v0,4 # syscall-code for print-string
3972#    la $a0,exitString
3976#    syscall

    # terminate execution
3980#    li $v0,10 #syscall-code for "exit"
3984#    syscall

3988:outOfHeapMemory:
3988#    la $a0,heapMemoryMsg
3992#    j exitError
3996:divByZeroError:
3996#    la $a0,divByZeroMsg
4000#    j exitError
4004:strIndexOutOfBounds:
4004#    la $a0,strIndexOutOfBoundsMsg
4008#    j exitError
4012:arrayIndexOutOfBounds:
4012#    la $a0,arrayIndexOutOfBoundsMsg
4016#    j exitError
4020:arraySizeOutOfBounds:
4020#    la $a0,arraySizeOutOfBoundsMsg
4024#    j exitError
4028:nullPtrException:
4028#    la $a0,nullPtrExceptionMsg
4032#    j exitError
4036:badIntegerFormat:
4036#    la $a0,badIntegerFormatMsg
4040#    j exitError
4044:castException:
4044#    la $a0,castExceptionMsg
4048#    j exitError
############## data section ################
    .data
4316:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4332:cur_seg:
    .word 0

4336:lastCharRead:
    .word -2 # -2 => no buffered character
4340:prevHashConstant:
    .word 0x2785173c
4344:gcCount:
    .word 0

4348:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4375:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4398:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4433:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4467:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4500:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4531:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4579:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4600:gcMsg: 
      .asciiz "\nGC!\n"
4606:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4638:nullStr:
    .asciiz "null"
4643:trueString:
    .asciiz "true"
4648:falseString:
    .asciiz "false"
4654:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4673:newlineString:
    .asciiz "\n"
    
    .align 2
4676:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4680:seg0_start:
    .space 0x100000
1053256:seg0_end:
1053256:seg1_start:
    .space 0x100000
2101832:seg1_end:

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1652#    beq $sp,$t1,rlReturn
1656:  charCopyLoop:
1656#    lw $t2,($sp)
1660#    sb $t2,-9($t0)
1664#    addu $sp,$sp,4
1668#    subu $t0,$t0,1
1672#    bne $sp,$t1,charCopyLoop
1676:  rlReturn:

1676#    lw $ra, 4($sp)
1680#    addu $sp, 8   # pop $ra and pointless word off stack
1684#    move $t0, $s7 # return string we allocated in $s7
1688#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1692:mth_readInt_Lib:

    # save $ra by pushing onto stack
1692#    subu $sp,$sp,4
1696#    sw $ra,($sp)

1700:  riSkipWhiteLoop:
    # read a character
1700#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1704#    subu $t0,$v0,32
1708#    bgt $t0,$zero,nonWhite
1709##...slt $at,$zero,$t0
1713##...bne $at,$zero,1756
1716#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1720#    subu $t0,$v0,10
1724#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1728#    subu $t0,$v0,9
1732#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1736#    subu $t0,$v0,13
1740#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1744#    subu $t0,$v0,12
1748#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1752#    j badIntegerFormat # illegal integer char: abort program

1756:  nonWhite:
1756#    subu $t0,$v0,'-'
1760#    li $t4,1 # final multiplier
1764#    bne $t0,$zero,helpReadInt # go read
1768#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1772#    jal readLogicalChar

1776:  helpReadInt:
1776#    li $t2,10
1780#    subu $t1,$v0,'0' # convert digit to 0-9 value
1784#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1785##...sltu $at,$t1,$t2
1789##...beq $at,$zero,4036
1792#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1796:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1796#    jal readLogicalChar # read next character
1800#    subu $t1,$v0,'0' # convert digit to 0-9 value
1804#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1805##...sltu $at,$t1,$t2
1809##...beq $at,$zero,1828

1812#    mul $t3,$t3,$t2 # multiply old value by 10
1813##...mult $t3,$t2
1817##...mflo $t3
1820#    addu $t3,$t3,$t1 # add in value of new digit
1824#    j digitLoop

1828:  doneDigitLoop:

    # "push back" unused character into queue
1828#    sw $v0,lastCharRead

    # restore return address
1832#    lw $ra,($sp)
1836#    addu $sp, 4


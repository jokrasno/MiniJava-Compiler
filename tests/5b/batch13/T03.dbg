3036#    addu $t0,$s6,$s7
3040#    sll $t0,$t0,2
3044#    addu $t0,$t0,8 # amount of memory needed
3048#    addu $t1,$t0,$s3
3052#    bgtu $t1,$s4,doGC
3053##...sltu $at,$s4,$t1
3057##...bne $at,$zero,3180

3092#    li $t2,255
3096#    bgeu $s6,$t2 firstHeaderLarge
3097##...sltu $at,$s6,$t2
3101##...beq $at,$zero,3148
3104#    lw $t1,prevHashConstant
3108#    addu $t1,0x12b68fd2
3109##...lui $at,4791
3113##...addiu $at,$at,-28718
3117##...addu $t1,$at,$t1
3120#    sw $t1,prevHashConstant # update hash constant
3124#    or $t1,0x80000000 # set top bit
3125##...lui $at,32768
3129##...or $t1,$at,$t1
3132#    and $t1,0xffffff00 # clear low bit
3133##...lui $at,65535
3137##...ori $at,$at,0xff00
3141##...and $t1,$t1,$at
3144#    or $s6,$t1
3148:firstHeaderLarge:
3148#    sw $s6,-8($t0) # store header-1 value
3152#    lw $zero,-8($t0)

    # store second header-value
3156#    sw $s7,-4($t0)   # second header-word
3160#    lw $zero,-4($t0)

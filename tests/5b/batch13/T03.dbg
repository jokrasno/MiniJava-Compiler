1141##...lui $at,0
1145##...ori $at,$at,0x80
1149##...and $t1,$t1,$at
1152#    beq $t1,$zero,toString_checkTagBit
1156#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1160#    subu $sp,8
1164#    sw $t1,($sp)
1168#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1172#    move $s7,$zero # -4 offset header word
1176#    lw $t4,8($sp) # bytes for hash value
1180#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1184#    addu $t4,8
1188#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1192#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1196#    li $t0,CLASS_String # store string vtable address into ...
1200#    sw $t0,-12($s7) # ... -12 offset in object header
1204#    lw $t2,-12($s2) # our object's vtable address
1208#    lw $t5,4($sp) # number characters in prefix
1212#    lw $t1,12($sp) # number of characters in hashcode
1216#    addu $t3,$t1,$t5 # number of characters in string ...
1220#    addu $t3,1 # ... including the '@' character
1224#    subu $t0,$zero,$t3 # store negated length into ...
1228#    sw $t0,-4($s7) # ... -4 offset header word
1232#    lw $t0,-8($s7) # get -8 offset header-word
1236#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1237##...slt $at,$t0,$zero
1241##...beq $at,$zero,1260
1244#    and $t0,0xff # mask off object's hash value ...
1245##...lui $at,0
1249##...ori $at,$at,0xff
1253##...and $t0,$t0,$at
1256#    sw $t0,-8($s7) # ... and store back into -8 header-word
1260:skipMask_toString:
1260#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1264#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1268#    subu $t4,$t2,$t5
1272:toString_copyLoop:    
1272#    lb $t3,($t4)
1276#    and $t3,0x7f # mask off sign bit (in case first word)
1277##...lui $at,0
1281##...ori $at,$at,0x7f
1285##...and $t3,$t3,$at
1288#    sb $t3,-8($t0)
1292#    addu $t4,1

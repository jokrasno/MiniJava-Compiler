4020#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
4024#    j gcTestIterDone1

4028:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
4028#    subu $t0,$t0,$t1
4032#    subu $t0,$t0,3

4036:  gcTestIterDone1:
4036#    bgeu $t0,$sp,gcStackCopyLoop
4037##...sltu $at,$t0,$sp
4041##...beq $at,$zero,3852

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
4044#    lw $t1,cur_seg
4048#    la $t0,seg0_start
4052#    beq $t1,$zero,gcSkip4
4056#    la $t0,seg1_start
4057##...lui $t0,16
4061##...addiu $t0,$t0,5232


4064:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
4064#    bgeu $t0,$s3,gcFinishUp
4065##...sltu $at,$t0,$s3
4069##...beq $at,$zero,4360

    ###### begin outer loop to copy all non-stack-direct objects ######

4072:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
4072#    lw $t1,($t0) # (what will be) first header word for current object
4076#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
4080#    bge $t2,$zero,gcSkip4a # are there hash bits?
4081##...slt $at,$t2,$zero
4085##...beq $at,$zero,4100
4088#    and $t2,0xff # mask off hash bits
4089##...lui $at,0
4093##...ori $at,$at,0xff
4097##...and $t2,$t2,$at
4100:gcSkip4a:    
4100#    sll $t2,$t2,2 # # data bytes
4104#    addu $t2,$t2,8 # to skip header words
4108#    addu $t2,$t0,$t2 # pointer to new object
4112#    lw $t3,-8($t2) # word to swap
4116#    sw $t1,-8($t2) # store header word
4120#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
4124#    lw $t1,-12($t2) # vtable pointer
4128#    li $t0,dataArrayVTableStart # address of vtable for first data array
4132#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
4133##...slt $at,$t1,$t0
4137##...bne $at,$zero,4156

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
4140:  skipToNextObj:
4140#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
4144#    sll $t1,$t1,2 # convert to byte-count
4148#    addu $t0,$t2,$t1 # skip over object
4152#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
4156:  gcNotDataArray:
4156#    lw $t3,-4($t2) # # object words (negative treated as zero)
4160#    bge $t3,$zero,gcH2Neg2
4161##...slt $at,$t3,$zero
4165##...beq $at,$zero,4172
4168#    move $t3,$zero
4172:  gcH2Neg2:
4172#    sll $t3,$t3,2 # # object bytes
4176#    move $t0,$t2 # address of first pointer in object
4180#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
4184#    beq $t0,$s1,gcTestIterDone2
    
4188:  gcNextPointerInObject:
    # get pointer from object
4188#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
4192#    bleu $t1,$t6,gcGoNextPointerSlot
4193##...sltu $at,$t6,$t1
4197##...beq $at,$zero,4340
4200#    bgtu $t1,$t7,gcGoNextPointerSlot
4201##...sltu $at,$t7,$t1
4205##...bne $at,$zero,4340

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4208#    lw $t8,-8($t1) # possible forwarding tag
4212#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
4216#    lw $t8,-4($t1) # forwarding pointer: object's new address
4220#    sw $t8,($t0) # update pointer in object
4224#    j gcGoNextPointerSlot # do next iteration

4228:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
4228#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
4229##...slt $at,$t8,$zero
4233##...beq $at,$zero,4248
4236#    and $t8,0xff # mask off hash bits
4237##...lui $at,0
4241##...ori $at,$at,0xff
4245##...and $t8,$t8,$at

4248:  gcSkip5:
4248#    sll $t8,$t8,2 # bytes in negative-offset portion ...
4252#    addu $t8,$t8,8 # ... add in bytes for header-words
4256#    subu $t4,$t1,$t8 # address of first word of source object
4260#    lw $t3,-4($t1) # # words in positive-offset portion
4264#    bge $t3,$zero,gcNoNeg
4265##...slt $at,$t3,$zero
4269##...beq $at,$zero,4276
4272#    move $t3,$zero # negative treated as zero
4276:  gcNoNeg:
4276#    sll $t3,$t3,2 # bytes in negative-offset portion
4280#    addu $t3,$t3,$t1 # address one word past last word of source

4284#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4288#    lw $s0,($t4)
4292#    lw $t9,-8($t1)
4296#    sw $t9,($t4)
4300#    sw $s0,-8($t1)

    # copy all source bytes to the target
4304:  gCinnerCopy2:
4304#    lw $s0,($t4)
4308#    sw $s0,($s3)
4312#    addu $t4,$t4,4
4316#    addu $s3,$s3,4
4320#    bltu $t4,$t3,gCinnerCopy2
4321##...sltu $at,$t4,$t3
4325##...bne $at,$zero,4304

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4328#    sw $zero,-8($t1) # 0 in first header-slot
4332#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4336#    sw $t8,($t0)

4340:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4340#    addu $t0,$t0,4
4344#    bltu $t0,$s1,gcNextPointerInObject
4345##...sltu $at,$t0,$s1
4349##...bne $at,$zero,4188

4352:  gcTestIterDone2:
4352#    bltu $t0,$s3,gcHeapCopyLoop
4353##...sltu $at,$t0,$s3
4357##...bne $at,$zero,4072

    ###### end outer loop to copy all non-stack-direct objects ######

4360:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4360#    lw $s2,($sp)
4364#    addu $sp,$sp,4

    # mark us as having already GC'd
4368#    move $t5,$s5

    # go try and allocate again
4372#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4376:vm_init:

    # mark bottom of stack
4376#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4380#    move $s2,$zero

    #set up the "five" register
4384#    li $s5,5

4388#    la $s3,seg0_start
4392#    la $s4,seg0_end
4393##...lui $s4,16
4397##...addiu $s4,$s4,5232
    
    # return
4400#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4404:divide:
    # get parameters; abort if divisor zero
4404#    lw $t0,($sp)
4408#    lw $t1,8($sp)
4412#    beq $t0,$zero,divByZeroError
    
    # perform division
4416#    div $t1,$t0
4420#    mflo $t0

    # store result, adjust stack and return
4424#    addu $sp,$sp,8 # adjust stack
4428#    sw $t0,($sp) # store result
4432#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4436:remainder:
    # get parameters; abort if divisor zero
4436#    lw $t0,($sp)
4440#    lw $t1,8($sp)
4444#    beq $t0,$zero,divByZeroError
    
    # perform division
4448#    div $t1,$t0
4452#    mfhi $t0

    # store result, adjust stack and return
4456#    addu $sp,$sp,8 # adjust stack
4460#    sw $t0,($sp) # store result
4464#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4468:checkCast:
    # get object, allow immediately if null
4468#    lw $t2,($sp)
4472#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4476#    lw $t2,-12($t2) # vtable address
4480#    bge $t2,$t1,castException
4481##...slt $at,$t2,$t1
4485##...beq $at,$zero,4620
4488#    blt $t2,$t0,castException
4489##...slt $at,$t2,$t0
4493##...bne $at,$zero,4620
    
    # return, leaving object unchanged on stack
4496:  checkCastReturn:    
4496#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4500:instanceOf:
    # get object, go return false if null
4500#    lw $t2,($sp)
4504#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4508#    lw $t2,-12($t2) # vtable address
4512#    sge $t0,$t2,$t0 # are we >= the lower limit?
4513##...slt $t0,$t2,$t0
4517##...xori $t0,$t0,0x1
4520#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4524#    and $t2,$t0,$t1
4528#    sw $t2,($sp)
4532:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4532#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4536:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4536#    li $v0,4 # syscall-code for print-string
4540#    syscall
4544:exit:
    # print termination message
4544#    li $v0,4 # syscall-code for print-string
4548#    la $a0,exitString
4552#    syscall

    # terminate execution
4556#    li $v0,10 #syscall-code for "exit"
4560#    syscall

4564:outOfHeapMemory:
4564#    la $a0,heapMemoryMsg
4568#    j exitError
4572:divByZeroError:
4572#    la $a0,divByZeroMsg
4576#    j exitError
4580:strIndexOutOfBounds:
4580#    la $a0,strIndexOutOfBoundsMsg
4584#    j exitError
4588:arrayIndexOutOfBounds:
4588#    la $a0,arrayIndexOutOfBoundsMsg
4592#    j exitError
4596:arraySizeOutOfBounds:
4596#    la $a0,arraySizeOutOfBoundsMsg
4600#    j exitError
4604:nullPtrException:
4604#    la $a0,nullPtrExceptionMsg
4608#    j exitError
4612:badIntegerFormat:
4612#    la $a0,badIntegerFormatMsg
4616#    j exitError
4620:castException:
4620#    la $a0,castExceptionMsg
4624#    j exitError
############## data section ################
    .data
4868:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4884:cur_seg:
    .word 0

4888:lastCharRead:
    .word -2 # -2 => no buffered character
4892:prevHashConstant:
    .word 0x2785173c
4896:gcCount:
    .word 0

4900:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4927:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4950:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4985:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5019:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5052:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5083:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5131:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5152:gcMsg: 
      .asciiz "\nGC!\n"
5158:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5190:nullStr:
    .asciiz "null"
5195:trueString:
    .asciiz "true"
5200:falseString:
    .asciiz "false"
5206:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5225:newlineString:
    .asciiz "\n"
    
    .align 2
5228:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5232:seg0_start:
    .space 0x100000
1053808:seg0_end:

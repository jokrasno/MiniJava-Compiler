3140#    bge $t1,$zero,itsNonNegLoop
3141##...slt $at,$t1,$zero
3145##...beq $at,$zero,3152
3148#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
3152:  itsNonNegLoop:
3152#    divu $t1,$t3
3156#    mflo $t1 # quotient
3160#    mfhi $t4 # remainder
3164#    addu $t4,$t4,'0' # turn remainder into digit
3168#    subu $sp,$sp,4
3172#    sw $t4,($sp) # push digit onto stack
3176#    bne $t1,$zero,itsNonNegLoop

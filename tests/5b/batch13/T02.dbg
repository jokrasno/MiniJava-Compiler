1516#  addu $sp,$sp,4
1520#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1524:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1524#    lw $t0,-8($s2) # get word with hash bits from this
1528#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1532#    addu $t0,$t1

1536#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1540:mth_equals_Object:
1540#    move $t0,$s2 # first pointer (this)
1544#    lw $t1,($sp) # second pointer
1548#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1549##...subu $at,$t0,$t1
1553##...sltiu $t0,$at,1

1556#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1560:mth_hashCode_String:
1560#    move $t0,$s2 # put this pointer in t0

1564#    li $t2,0 # current hash value
1568#    lw $t1,-4($t0) # negative of number of characters in string
1572#    beq $t1,$zero,done_hashCode_String # if zero length => done
1576#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1580#    and $t0,0xfffffffc # adjust for padding
1581##...lui $at,65535
1585##...ori $at,$at,0xfffc
1589##...and $t0,$t0,$at
1592#    subu $t1,$t0,$t1 # address at end of string +12
1596:loop_hashCode_String:    
1596#    sll $t4,$t2,5 # multiply by 32
1600#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1604#    lbu $t3,-12($t0) # current character
1608#    addu $t2,$t3 # add in current character
1612#    addu $t0,1 # go to next character's address
1616#    bne $t0,$t1,loop_hashCode_String # loop back if more
1620:done_hashCode_String:    

    # push int on stack
1620#    move $t0, $t2 # put $t2 in return slot
1624#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1628:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1628#    subu $sp,4
1632#    sw $ra,($sp)
    
    # get hash value
1636#    lw $t2,-12($s2) # vtable address
1640#    lw $t0,($t2) # method address
1644#    jalr $t0
1648#    subu $sp,8 # push result (int in $t0) on stack
1652#    sw $s5,4($sp)
1656#    sw $t0,($sp)

    # compute print-size of hash value
1660#    li $t0, 1
1664#    lw $t1, ($sp)
1668#    srl $t1,$t1,4
1672#    beq $t1,$zero,toString_skip_loop
1676:toString_loop_top:
1676#    addu $t0,1
1680#    srl $t1,$t1,4
1684#    bne $t1,$zero,toString_loop_top
1688:toString_skip_loop:
1688#    subu $sp,8
1692#    sw $s5,4($sp)
1696#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1700#    lw $t2,-12($s2) # vtable address
1704#    move $t0,$t2
1708:toString_checkTagBit:
1708#    subu $t0,1
1712#    lb $t1,($t0)
1716#    and $t1,0x80
1717##...lui $at,0
1721##...ori $at,$at,0x80
1725##...and $t1,$t1,$at
1728#    beq $t1,$zero,toString_checkTagBit
1732#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1736#    subu $sp,8
1740#    sw $t1,($sp)
1744#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1748#    move $s7,$zero # -4 offset header word
1752#    lw $t4,8($sp) # bytes for hash value
1756#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1760#    addu $t4,8
1764#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1768#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1772#    li $t0,CLASS_String # store string vtable address into ...
1776#    sw $t0,-12($s7) # ... -12 offset in object header
1780#    lw $t2,-12($s2) # our object's vtable address
1784#    lw $t5,4($sp) # number characters in prefix
1788#    lw $t1,12($sp) # number of characters in hashcode
1792#    addu $t3,$t1,$t5 # number of characters in string ...
1796#    addu $t3,1 # ... including the '@' character
1800#    subu $t0,$zero,$t3 # store negated length into ...
1804#    sw $t0,-4($s7) # ... -4 offset header word
1808#    lw $t0,-8($s7) # get -8 offset header-word
1812#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1813##...slt $at,$t0,$zero
1817##...beq $at,$zero,1836
1820#    and $t0,0xff # mask off object's hash value ...
1821##...lui $at,0
1825##...ori $at,$at,0xff
1829##...and $t0,$t0,$at
1832#    sw $t0,-8($s7) # ... and store back into -8 header-word
1836:skipMask_toString:
1836#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1840#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1844#    subu $t4,$t2,$t5
1848:toString_copyLoop:    
1848#    lb $t3,($t4)
1852#    and $t3,0x7f # mask off sign bit (in case first word)
1853##...lui $at,0
1857##...ori $at,$at,0x7f
1861##...and $t3,$t3,$at
1864#    sb $t3,-8($t0)
1868#    addu $t4,1
1872#    addu $t0,1
1876#    blt $t4,$t2,toString_copyLoop
1877##...slt $at,$t4,$t2
1881##...bne $at,$zero,1848

    # copy the '@' sign
1884#    li $t3,'@'
1888#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1892#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1896#    lw $t3,20($sp) # hash code to print
1900:toString_hashCopyLoop:
1900#    and $t4,$t3,0xf
1904#    srl $t3,4
1908#    lb $t4,hexChars($t4)
1912#    sb $t4,-8($t2)
1916#    subu $t2,$t2,1
1920#    bgt $t2,$t0,toString_hashCopyLoop
1921##...slt $at,$t0,$t2
1925##...bne $at,$zero,1900

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1928#    addu $sp,28
1932#    lw $ra,($sp)
1936#    addu $sp,4
1940#    move $t0, $s7 # return string we created
1944#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1948:mth_equals_String:
    
    # quick test for obvious false
1948#    lw $t0,($sp) # second parameter
1952#    beq $t0,$zero,goEsFalse # go return false if null
1956#    lw $t1,-12($t0) # vtable pointer
1960#    la $t2,CLASS_String # string vtable pointer
1964#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1968#    subu $sp,12
1972#    sw $ra,8($sp)
1976#    sw $s2,4($sp)
1980#    sw $t0,($sp)
1984#    jal mth_compareTo_String
1988#    lw $s2, 4($sp) #restore this pointer and pop parameters
1992#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1996#    seq $t0,$t0,$zero
1997##...subu $at,$t0,$zero
2001##...sltiu $t0,$at,1

    # pop return address and return $t0
2004#    lw $ra,($sp)
2008#    addu $sp,4

2012#    jr $ra # return
    
2016:goEsFalse:
    # put 0 in $t0 and return
2016#    li $t0, 0
2020#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2024:mth_toString_String:
    #we are a string, so return this.
2024#    move $t0, $s2
2028#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2032:mth_readLine_Lib:
    
2032#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2036#    sw $ra, 4($sp) # save $ra
2040#    move $t1,$sp # save "original" sp

2044:  doRead:

    # read the character
2044#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2048#    subu $t2,$v0,13
2052#    bne $t2,$zero,notReturnRL
2056#    jal readLogicalChar
2060#    subu $t2,$v0,10 # check for newline
2064#    beq $t2,$zero,foundNewLine
2068#    sw $v0,lastCharRead # push back character into queue
2072#    j foundNewLine # go process the line

2076:  notReturnRL:

    # at this point, $v0 has our character

2076#    subu $t0,$v0,10
2080#    beq $t0,$zero,foundNewLine
2084#    blt $v0,$zero,foundEof
2085##...slt $at,$v0,$zero
2089##...bne $at,$zero,2104

    # we have a character, so push it onto stack
2092#    subu $sp,$sp,4
2096#    sw $v0,($sp)

    # loop back up to get next character
2100#    j doRead

2104:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2104#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2108#    li $s7, 0 # return-value: null
2112#    j rlReturn # return

2116:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2116#    subu $t0,$t1,$sp # number of chars we read (times 4)
2120#    srl $s6,$t0,2 # number of words on stack with chars
2124#    subu $sp,$sp,4 # push char-count ...
2128#    sw $s6,($sp) # ... onto stack
2132#    addu $t2,$t0,5 # GC tag, incl. for count-word
2136#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2140#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2144#    srl $s6,$s6,2  # data words in object
2148#    move $s7,$zero # object words in object
2152#    jal newObject  # allocate space
    
    # store header words
2156#    la $t0,CLASS_String
2160#    sw $t0,-12($s7)# store class tag (String) into object
2164#    lw $t2,4($sp) # char-count
2168#    sll $t1,$t2,2 # 4 times number of chars
2172#    subu $t2,$zero,$t2 # negative of char-count
2176#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2180#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2184#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2185##...slt $at,$t0,$zero
2189##...beq $at,$zero,2208
2192#    and $t0,0xff # mask off object's hash value ...
2193##...lui $at,0
2197##...ori $at,$at,0xff
2201##...and $t0,$t0,$at
2204#    sw $t0,-8($s7) # ... and store back into -8 header-word
2208:  skipMask_readLine:

2208#    sll $t0,$t0,2 # data bytes in object
2212#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2216#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2220#    addu $sp,$sp,8 # pop redundant object-pointer and count
2224#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2228#    beq $sp,$t1,rlReturn
2232:  charCopyLoop:
2232#    lw $t2,($sp)
2236#    sb $t2,-9($t0)
2240#    addu $sp,$sp,4
2244#    subu $t0,$t0,1
2248#    bne $sp,$t1,charCopyLoop
2252:  rlReturn:

2252#    lw $ra, 4($sp)
2256#    addu $sp, 8   # pop $ra and pointless word off stack
2260#    move $t0, $s7 # return string we allocated in $s7
2264#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2268:mth_readInt_Lib:

    # save $ra by pushing onto stack
2268#    subu $sp,$sp,4
2272#    sw $ra,($sp)

2276:  riSkipWhiteLoop:
    # read a character
2276#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2280#    subu $t0,$v0,32
2284#    bgt $t0,$zero,nonWhite
2285##...slt $at,$zero,$t0
2289##...bne $at,$zero,2332
2292#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2296#    subu $t0,$v0,10
2300#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2304#    subu $t0,$v0,9
2308#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2312#    subu $t0,$v0,13
2316#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2320#    subu $t0,$v0,12
2324#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2328#    j badIntegerFormat # illegal integer char: abort program

2332:  nonWhite:
2332#    subu $t0,$v0,'-'
2336#    li $t4,1 # final multiplier
2340#    bne $t0,$zero,helpReadInt # go read
2344#    li $t4,-1 # -1 in final multiplier


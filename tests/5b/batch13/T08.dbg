###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1284:mth_readLine_Lib:
    
1284#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1288#    sw $ra, 4($sp) # save $ra
1292#    move $t1,$sp # save "original" sp

1296:  doRead:

    # read the character
1296#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1300#    subu $t2,$v0,13
1304#    bne $t2,$zero,notReturnRL
1308#    jal readLogicalChar
1312#    subu $t2,$v0,10 # check for newline
1316#    beq $t2,$zero,foundNewLine
1320#    sw $v0,lastCharRead # push back character into queue
1324#    j foundNewLine # go process the line

1328:  notReturnRL:

    # at this point, $v0 has our character

1328#    subu $t0,$v0,10
1332#    beq $t0,$zero,foundNewLine
1336#    blt $v0,$zero,foundEof
1337##...slt $at,$v0,$zero
1341##...bne $at,$zero,1356

    # we have a character, so push it onto stack
1344#    subu $sp,$sp,4
1348#    sw $v0,($sp)

    # loop back up to get next character
1352#    j doRead

1356:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1356#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1360#    li $s7, 0 # return-value: null
1364#    j rlReturn # return

1368:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1368#    subu $t0,$t1,$sp # number of chars we read (times 4)
1372#    srl $s6,$t0,2 # number of words on stack with chars
1376#    subu $sp,$sp,4 # push char-count ...
1380#    sw $s6,($sp) # ... onto stack
1384#    addu $t2,$t0,5 # GC tag, incl. for count-word
1388#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1392#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1396#    srl $s6,$s6,2  # data words in object
1400#    move $s7,$zero # object words in object
1404#    jal newObject  # allocate space
    
    # store header words
1408#    la $t0,CLASS_String
1412#    sw $t0,-12($s7)# store class tag (String) into object
1416#    lw $t2,4($sp) # char-count
1420#    sll $t1,$t2,2 # 4 times number of chars
1424#    subu $t2,$zero,$t2 # negative of char-count
1428#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1432#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1436#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1437##...slt $at,$t0,$zero
1441##...beq $at,$zero,1460
1444#    and $t0,0xff # mask off object's hash value ...
1445##...lui $at,0
1449##...ori $at,$at,0xff
1453##...and $t0,$t0,$at
1456#    sw $t0,-8($s7) # ... and store back into -8 header-word
1460:  skipMask_readLine:

1460#    sll $t0,$t0,2 # data bytes in object
1464#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1468#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1472#    addu $sp,$sp,8 # pop redundant object-pointer and count
1476#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1480#    beq $sp,$t1,rlReturn
1484:  charCopyLoop:
1484#    lw $t2,($sp)
1488#    sb $t2,-9($t0)
1492#    addu $sp,$sp,4
1496#    subu $t0,$t0,1
1500#    bne $sp,$t1,charCopyLoop
1504:  rlReturn:

1504#    lw $ra, 4($sp)
1508#    addu $sp, 8   # pop $ra and pointless word off stack
1512#    move $t0, $s7 # return string we allocated in $s7
1516#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1520:mth_readInt_Lib:

    # save $ra by pushing onto stack
1520#    subu $sp,$sp,4
1524#    sw $ra,($sp)

1528:  riSkipWhiteLoop:
    # read a character
1528#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1532#    subu $t0,$v0,32
1536#    bgt $t0,$zero,nonWhite
1537##...slt $at,$zero,$t0
1541##...bne $at,$zero,1584
1544#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1548#    subu $t0,$v0,10
1552#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1556#    subu $t0,$v0,9
1560#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1564#    subu $t0,$v0,13
1568#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1572#    subu $t0,$v0,12
1576#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1580#    j badIntegerFormat # illegal integer char: abort program

1584:  nonWhite:
1584#    subu $t0,$v0,'-'
1588#    li $t4,1 # final multiplier
1592#    bne $t0,$zero,helpReadInt # go read
1596#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1600#    jal readLogicalChar

1604:  helpReadInt:
1604#    li $t2,10
1608#    subu $t1,$v0,'0' # convert digit to 0-9 value
1612#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1613##...sltu $at,$t1,$t2
1617##...beq $at,$zero,3864
1620#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1624:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1624#    jal readLogicalChar # read next character
1628#    subu $t1,$v0,'0' # convert digit to 0-9 value
1632#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1633##...sltu $at,$t1,$t2
1637##...beq $at,$zero,1656

1640#    mul $t3,$t3,$t2 # multiply old value by 10
1641##...mult $t3,$t2
1645##...mflo $t3
1648#    addu $t3,$t3,$t1 # add in value of new digit
1652#    j digitLoop

1656:  doneDigitLoop:

    # "push back" unused character into queue
1656#    sw $v0,lastCharRead

    # restore return address
1660#    lw $ra,($sp)
1664#    addu $sp, 4

    # multiply by sign and put return value in $t0
1668#    mult $t3,$t4 # multiply to account for poss. minus sign
1672#    mflo $t3
1676#    move $t0, $t3
    
    # return
1680#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1684:mth_readChar_Lib:

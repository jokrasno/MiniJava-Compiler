    # get pointers set up in preparation for copy
2008#    lw $t4,-8($t3) # data words in source string
2012#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
2016#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
2020#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
2024#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)

    # allocate memory
1928#    subu $s6,$t1,$t2 # # chars in target-string
1932#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1936#    srl $s6,$s6,2 # convert bytes-count to word-count
1940#    move $s7,$zero # (no object-bytes in string)
1944#    jal newObject

    # store "String" tag in object-type field
1948#    la $t0,CLASS_String
1952#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
1956#    lw $t4,-8($s7) # data words in source string
1960#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
1961##...slt $at,$t4,$zero
1965##...beq $at,$zero,1984
1968#    and $t4,0xff # mask off object's hash value ...
1969##...lui $at,0
1973##...ori $at,$at,0xff
1977##...and $t4,$t4,$at
1980#    sw $t4,-8($s7) # ... and store back into -8 header-word
1984:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1984#    lw $t1,8($sp) # k
1988#    lw $t2,16($sp) # n
1992#    subu $t0,$t2,$t1 # value to store
1996#    sw $t0,-4($s7) # store value
    
2000#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
2004#    beq $zero,$t0,doneSubCopyzz

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
2820:readLogicalChar:

    # check if we already have a character
2820#    lw $v0,lastCharRead
2824#    li $t0,-2
2828#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
2832#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2836#    jr $ra # return
    
2840:  doReadCh:
    # we need to actually read a character: read and return
2840#    li $v0,12 # use system call to read a character
2844#    syscall
2848#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
2852:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
2852#    blt $s7,$zero arraySizeOutOfBounds
2853##...slt $at,$s7,$zero
2857##...bne $at,$zero,3848

    # mark the fact that we have not yet GC'd for this allocation
2860#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

2864:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
2864#    addu $t0,$s6,$s7
2868#    sll $t0,$t0,2
2872#    addu $t0,$t0,8 # amount of memory needed
2876#    addu $t1,$t0,$s3
2880#    bgtu $t1,$s4,doGC
2881##...sltu $at,$s4,$t1
2885##...bne $at,$zero,3008

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
2888#    move $t2,$s3
2892:  zeroObjLoop:
2892#    sw $zero,($s3)
2896#    lw $zero,($s3)

2900#    addu $s3,4
2904#    bltu $s3,$t1,zeroObjLoop
2905##...sltu $at,$s3,$t1
2909##...bne $at,$zero,2892

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
2912#    sll $t0,$s7,2    # number of post-header bytes
2916#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
2920#    li $t2,255
2924#    bgeu $s6,$t2 firstHeaderLarge
2925##...sltu $at,$s6,$t2
2929##...beq $at,$zero,2976
2932#    lw $t1,prevHashConstant
2936#    addu $t1,0x12b68fd2
2937##...lui $at,4791
2941##...addiu $at,$at,-28718
2945##...addu $t1,$at,$t1
2948#    sw $t1,prevHashConstant # update hash constant
2952#    or $t1,0x80000000 # set top bit
2953##...lui $at,32768
2957##...or $t1,$at,$t1
2960#    and $t1,0xffffff00 # clear low bit
2961##...lui $at,65535
2965##...ori $at,$at,0xff00
2969##...and $t1,$t1,$at
2972#    or $s6,$t1
2976:firstHeaderLarge:
2976#    sw $s6,-8($t0) # store header-1 value
2980#    lw $zero,-8($t0)

    # store second header-value
2984#    sw $s7,-4($t0)   # second header-word
2988#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
2992#    move $s7,$t0
2996#    subu $sp,$sp,4
3000#    sw $t0,($sp)

3004#    jr $ra
    
3008:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
3008#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
3012#    lw $t5,gcCount
3016#    addu $t5,1
3020#    sw $t5,gcCount

    # save $s2 (our only rooted register) on the stack
    # so that the garbage collector processes it
3024#    subu $sp,$sp,4
3028#    sw $s2,($sp)

    # set $s3 to the address of the new segment and the
    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
3032#    lw $t0,cur_seg
3036#    move $t7,$s4
3040#    la $t6,seg1_start
3041##...lui $t6,16
3045##...addiu $t6,$t6,4440
3048#    la $s3,seg0_start
3052#    la $s4,seg0_end
3053##...lui $s4,16
3057##...addiu $s4,$s4,4440
3060#    sw $zero,cur_seg
3064#    bne $t0,$zero,skipGc1
3068#    la $t6,seg0_start
3072#    la $s3,seg1_start
3073##...lui $s3,16
3077##...addiu $s3,$s3,4440
3080#    la $s4,seg1_end
3081##...lui $s4,32
3085##...addiu $s4,$s4,4440
3088#    sw $s5,cur_seg
3092:  skipGc1:
3092#    li $t5,0x80000000
3096#    lw $t0,stack_bottom
3100#    subu $t0,4


    ###############################################################
    # at this point:
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first address of the target space
    # - $s4 contains the limit address of the target space
    # - cur_seg has been updated to refer to the target space
    # - $t0 contains the address of the deepest stack element
    # - $sp contains the address of the top stack element
    # - $s2 is available for use, having been pushed onto the stack
    # - $t5 contains the value 0x80000000
    ###############################################################

    ###### begin outer loop to copy all stack-direct objects ######

3104:  gcStackCopyLoop:
3104#    lw $t1,($t0) # current stack element

    # test if we have a GC tag
3108#    sll $t2,$t1,31 # zero iff low bit was zero
3112#    bne $t2,$zero,gcBump # go skip data values if low bit not zero

    # bump stack-address pointer
3116#    subu $t0,$t0,4

    # if value is out of range (which includes null=0), and is
    # therefore does not refer to an object on the heap, just go
    # loop back and do the next one
3120#    bleu $t1,$t6,gcTestIterDone1
3121##...sltu $at,$t6,$t1
3125##...beq $at,$zero,3288
3128#    bgtu $t1,$t7,gcTestIterDone1
3129##...sltu $at,$t7,$t1
3133##...bne $at,$zero,3288

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3136#    lw $t2,-8($t1) # possible forwarding tag
3140#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
3144#    lw $t2,-4($t1) # forwarding pointer: object's new address
3148#    sw $t2,4($t0) # update stack value
3152#    j gcTestIterDone1 # do next iteration

3156:  gcNoForward1:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    # compute the amount of space that is needed
3156#    bge $t2,$zero,gcSkip2
3157##...slt $at,$t2,$zero
3161##...beq $at,$zero,3176
3164#    and $t2,0xff #### mask off hash value
3165##...lui $at,0
3169##...ori $at,$at,0xff
3173##...and $t2,$t2,$at
    #### OLD
    #### subu $t2,$zero,$t2 # set to 1 if -1 (number of data words)

3176:  gcSkip2:
3176#    sll $t2,$t2,2
3180#    addu $t2,$t2,8
3184#    subu $t4,$t1,$t2 # address of first word of source
3188#    lw $t3,-4($t1) # number of object words (negative means zero)
3192#    bge $t3,$zero,gcH2Neg1
3193##...slt $at,$t3,$zero
3197##...beq $at,$zero,3204
3200#    move $t3,$zero
3204:  gcH2Neg1:
3204#    sll $t3,$t3,2
3208#    addu $t3,$t3,$t1 # address one word past last word of source

3212#    addu $t2,$s3,$t2 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object (i.e., the address just beyond the object's header)
    # - $t2 contains the pointer to the target object
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0-2
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger" in the target space
3216#    lw $s0,($t4)
3220#    lw $s1,-8($t1)
3224#    sw $s1,($t4)
3228#    sw $s0,-8($t1)
    
    # copy all source bytes to the target
3232:  gCinnerCopy1:
3232#    lw $s0,($t4)
3236#    sw $s0,($s3)
3240#    addu $t4,$t4,4
3244#    addu $s3,$s3,4
3248#    bltu $t4,$t3,gCinnerCopy1
3249##...sltu $at,$t4,$t3
3253##...bne $at,$zero,3232

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3256#    sw $zero,-8($t1) # 0 in first header-slot
3260#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
3264#    sw $t2,4($t0)
3268#    lw $zero,-8($t2)
3272#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
3276#    j gcTestIterDone1

3280:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
3280#    subu $t0,$t0,$t1
3284#    subu $t0,$t0,3

3288:  gcTestIterDone1:
3288#    bgeu $t0,$sp,gcStackCopyLoop
3289##...sltu $at,$t0,$sp
3293##...beq $at,$zero,3104

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
3296#    lw $t1,cur_seg
3300#    la $t0,seg0_start
3304#    beq $t1,$zero,gcSkip4
3308#    la $t0,seg1_start
3309##...lui $t0,16
3313##...addiu $t0,$t0,4440


3316:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
3316#    bgeu $t0,$s3,gcFinishUp
3317##...sltu $at,$t0,$s3
3321##...beq $at,$zero,3612

    ###### begin outer loop to copy all non-stack-direct objects ######

3324:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
3324#    lw $t1,($t0) # (what will be) first header word for current object
3328#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
3332#    bge $t2,$zero,gcSkip4a # are there hash bits?
3333##...slt $at,$t2,$zero
3337##...beq $at,$zero,3352
3340#    and $t2,0xff # mask off hash bits
3341##...lui $at,0
3345##...ori $at,$at,0xff
3349##...and $t2,$t2,$at
3352:gcSkip4a:    
3352#    sll $t2,$t2,2 # # data bytes
3356#    addu $t2,$t2,8 # to skip header words
3360#    addu $t2,$t0,$t2 # pointer to new object
3364#    lw $t3,-8($t2) # word to swap
3368#    sw $t1,-8($t2) # store header word
3372#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3376#    lw $t1,-12($t2) # vtable pointer
3380#    li $t0,dataArrayVTableStart # address of vtable for first data array
3384#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3385##...slt $at,$t1,$t0
3389##...bne $at,$zero,3408

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3392:  skipToNextObj:
3392#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3396#    sll $t1,$t1,2 # convert to byte-count
3400#    addu $t0,$t2,$t1 # skip over object
3404#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3408:  gcNotDataArray:
3408#    lw $t3,-4($t2) # # object words (negative treated as zero)
3412#    bge $t3,$zero,gcH2Neg2
3413##...slt $at,$t3,$zero
3417##...beq $at,$zero,3424
3420#    move $t3,$zero
3424:  gcH2Neg2:
3424#    sll $t3,$t3,2 # # object bytes
3428#    move $t0,$t2 # address of first pointer in object
3432#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3436#    beq $t0,$s1,gcTestIterDone2
    
3440:  gcNextPointerInObject:
    # get pointer from object
3440#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3444#    bleu $t1,$t6,gcGoNextPointerSlot
3445##...sltu $at,$t6,$t1
3449##...beq $at,$zero,3592
3452#    bgtu $t1,$t7,gcGoNextPointerSlot
3453##...sltu $at,$t7,$t1
3457##...bne $at,$zero,3592

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3460#    lw $t8,-8($t1) # possible forwarding tag
3464#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3468#    lw $t8,-4($t1) # forwarding pointer: object's new address
3472#    sw $t8,($t0) # update pointer in object
3476#    j gcGoNextPointerSlot # do next iteration

3480:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3480#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3481##...slt $at,$t8,$zero
3485##...beq $at,$zero,3500
3488#    and $t8,0xff # mask off hash bits
3489##...lui $at,0
3493##...ori $at,$at,0xff
3497##...and $t8,$t8,$at

3500:  gcSkip5:
3500#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3504#    addu $t8,$t8,8 # ... add in bytes for header-words
3508#    subu $t4,$t1,$t8 # address of first word of source object
3512#    lw $t3,-4($t1) # # words in positive-offset portion
3516#    bge $t3,$zero,gcNoNeg
3517##...slt $at,$t3,$zero
3521##...beq $at,$zero,3528
3524#    move $t3,$zero # negative treated as zero
3528:  gcNoNeg:
3528#    sll $t3,$t3,2 # bytes in negative-offset portion
3532#    addu $t3,$t3,$t1 # address one word past last word of source

3536#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3540#    lw $s0,($t4)
3544#    lw $t9,-8($t1)
3548#    sw $t9,($t4)
3552#    sw $s0,-8($t1)

    # copy all source bytes to the target
3556:  gCinnerCopy2:
3556#    lw $s0,($t4)
3560#    sw $s0,($s3)
3564#    addu $t4,$t4,4
3568#    addu $s3,$s3,4
3572#    bltu $t4,$t3,gCinnerCopy2
3573##...sltu $at,$t4,$t3
3577##...bne $at,$zero,3556

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3580#    sw $zero,-8($t1) # 0 in first header-slot
3584#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3588#    sw $t8,($t0)

3592:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3592#    addu $t0,$t0,4
3596#    bltu $t0,$s1,gcNextPointerInObject
3597##...sltu $at,$t0,$s1
3601##...bne $at,$zero,3440

3604:  gcTestIterDone2:
3604#    bltu $t0,$s3,gcHeapCopyLoop
3605##...sltu $at,$t0,$s3
3609##...bne $at,$zero,3324

    ###### end outer loop to copy all non-stack-direct objects ######

3612:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3612#    lw $s2,($sp)
3616#    addu $sp,$sp,4

    # mark us as having already GC'd
3620#    move $t5,$s5

    # go try and allocate again
3624#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3628:vm_init:

    # mark bottom of stack
3628#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3632#    move $s2,$zero

    #set up the "five" register
3636#    li $s5,5

3640#    la $s3,seg0_start
3644#    la $s4,seg0_end
3645##...lui $s4,16
3649##...addiu $s4,$s4,4440
    
    # return
3652#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3656:divide:
    # get parameters; abort if divisor zero
3656#    lw $t0,($sp)
3660#    lw $t1,8($sp)
3664#    beq $t0,$zero,divByZeroError
    
    # perform division
3668#    div $t1,$t0
3672#    mflo $t0

    # store result, adjust stack and return
3676#    addu $sp,$sp,8 # adjust stack
3680#    sw $t0,($sp) # store result
3684#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3688:remainder:
    # get parameters; abort if divisor zero
3688#    lw $t0,($sp)
3692#    lw $t1,8($sp)
3696#    beq $t0,$zero,divByZeroError
    
    # perform division
3700#    div $t1,$t0
3704#    mfhi $t0

    # store result, adjust stack and return
3708#    addu $sp,$sp,8 # adjust stack
3712#    sw $t0,($sp) # store result
3716#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3720:checkCast:
    # get object, allow immediately if null
3720#    lw $t2,($sp)
3724#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3728#    lw $t2,-12($t2) # vtable address
3732#    bge $t2,$t1,castException
3733##...slt $at,$t2,$t1
3737##...beq $at,$zero,3872
3740#    blt $t2,$t0,castException
3741##...slt $at,$t2,$t0
3745##...bne $at,$zero,3872
    
    # return, leaving object unchanged on stack
3748:  checkCastReturn:    
3748#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3752:instanceOf:
    # get object, go return false if null
3752#    lw $t2,($sp)
3756#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3760#    lw $t2,-12($t2) # vtable address
3764#    sge $t0,$t2,$t0 # are we >= the lower limit?
3765##...slt $t0,$t2,$t0
3769##...xori $t0,$t0,0x1
3772#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3776#    and $t2,$t0,$t1
3780#    sw $t2,($sp)
3784:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3784#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3788:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3788#    li $v0,4 # syscall-code for print-string
3792#    syscall
3796:exit:
    # print termination message
3796#    li $v0,4 # syscall-code for print-string
3800#    la $a0,exitString
3804#    syscall

    # terminate execution
3808#    li $v0,10 #syscall-code for "exit"
3812#    syscall

3816:outOfHeapMemory:
3816#    la $a0,heapMemoryMsg
3820#    j exitError
3824:divByZeroError:
3824#    la $a0,divByZeroMsg
3828#    j exitError
3832:strIndexOutOfBounds:
3832#    la $a0,strIndexOutOfBoundsMsg
3836#    j exitError
3840:arrayIndexOutOfBounds:
3840#    la $a0,arrayIndexOutOfBoundsMsg
3844#    j exitError
3848:arraySizeOutOfBounds:
3848#    la $a0,arraySizeOutOfBoundsMsg
3852#    j exitError
3856:nullPtrException:
3856#    la $a0,nullPtrExceptionMsg
3860#    j exitError
3864:badIntegerFormat:
3864#    la $a0,badIntegerFormatMsg
3868#    j exitError
3872:castException:
3872#    la $a0,castExceptionMsg
3876#    j exitError
############## data section ################
    .data
4076:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4092:cur_seg:
    .word 0

4096:lastCharRead:
    .word -2 # -2 => no buffered character
4100:prevHashConstant:
    .word 0x2785173c
4104:gcCount:
    .word 0

4108:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4135:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4158:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4193:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4227:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4260:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4291:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4339:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4360:gcMsg: 
      .asciiz "\nGC!\n"
4366:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4398:nullStr:
    .asciiz "null"
4403:trueString:
    .asciiz "true"
4408:falseString:
    .asciiz "false"
4414:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4433:newlineString:
    .asciiz "\n"
    
    .align 2
4436:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4440:seg0_start:
    .space 0x100000
1053016:seg0_end:
1053016:seg1_start:
    .space 0x100000
2101592:seg1_end:

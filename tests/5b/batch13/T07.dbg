1524#    subu $t0,$v0,10
1528#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1532#    subu $t0,$v0,9
1536#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1540#    subu $t0,$v0,13
1544#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1548#    subu $t0,$v0,12

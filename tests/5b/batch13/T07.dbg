    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3516#    lw $s0,($t4)
3520#    lw $t9,-8($t1)
3524#    sw $t9,($t4)
3528#    sw $s0,-8($t1)

    # copy all source bytes to the target
3532:  gCinnerCopy2:
3532#    lw $s0,($t4)
3536#    sw $s0,($s3)
3540#    addu $t4,$t4,4
3544#    addu $s3,$s3,4
3548#    bltu $t4,$t3,gCinnerCopy2
3549##...sltu $at,$t4,$t3
3553##...bne $at,$zero,3532

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3556#    sw $zero,-8($t1) # 0 in first header-slot
3560#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3564#    sw $t8,($t0)

3568:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3568#    addu $t0,$t0,4
3572#    bltu $t0,$s1,gcNextPointerInObject
3573##...sltu $at,$t0,$s1
3577##...bne $at,$zero,3416

3580:  gcTestIterDone2:
3580#    bltu $t0,$s3,gcHeapCopyLoop
3581##...sltu $at,$t0,$s3
3585##...bne $at,$zero,3300

    ###### end outer loop to copy all non-stack-direct objects ######

3588:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3588#    lw $s2,($sp)
3592#    addu $sp,$sp,4

    # mark us as having already GC'd
3596#    move $t5,$s5

    # go try and allocate again
3600#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3604:vm_init:

    # mark bottom of stack
3604#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3608#    move $s2,$zero

    #set up the "five" register
3612#    li $s5,5

3616#    la $s3,seg0_start
3620#    la $s4,seg0_end
3621##...lui $s4,16
3625##...addiu $s4,$s4,4416
    
    # return
3628#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3632:divide:
    # get parameters; abort if divisor zero
3632#    lw $t0,($sp)
3636#    lw $t1,8($sp)
3640#    beq $t0,$zero,divByZeroError
    
    # perform division
3644#    div $t1,$t0
3648#    mflo $t0

    # store result, adjust stack and return
3652#    addu $sp,$sp,8 # adjust stack
3656#    sw $t0,($sp) # store result
3660#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3664:remainder:
    # get parameters; abort if divisor zero
3664#    lw $t0,($sp)
3668#    lw $t1,8($sp)
3672#    beq $t0,$zero,divByZeroError
    
    # perform division
3676#    div $t1,$t0
3680#    mfhi $t0

    # store result, adjust stack and return
3684#    addu $sp,$sp,8 # adjust stack
3688#    sw $t0,($sp) # store result
3692#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3696:checkCast:
    # get object, allow immediately if null
3696#    lw $t2,($sp)
3700#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3704#    lw $t2,-12($t2) # vtable address
3708#    bge $t2,$t1,castException
3709##...slt $at,$t2,$t1
3713##...beq $at,$zero,3848
3716#    blt $t2,$t0,castException
3717##...slt $at,$t2,$t0
3721##...bne $at,$zero,3848
    
    # return, leaving object unchanged on stack
3724:  checkCastReturn:    
3724#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3728:instanceOf:
    # get object, go return false if null
3728#    lw $t2,($sp)
3732#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3736#    lw $t2,-12($t2) # vtable address
3740#    sge $t0,$t2,$t0 # are we >= the lower limit?
3741##...slt $t0,$t2,$t0
3745##...xori $t0,$t0,0x1
3748#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3752#    and $t2,$t0,$t1
3756#    sw $t2,($sp)
3760:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3760#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3764:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3764#    li $v0,4 # syscall-code for print-string
3768#    syscall
3772:exit:
    # print termination message
3772#    li $v0,4 # syscall-code for print-string
3776#    la $a0,exitString
3780#    syscall

    # terminate execution
3784#    li $v0,10 #syscall-code for "exit"
3788#    syscall

3792:outOfHeapMemory:
3792#    la $a0,heapMemoryMsg
3796#    j exitError
3800:divByZeroError:
3800#    la $a0,divByZeroMsg
3804#    j exitError
3808:strIndexOutOfBounds:
3808#    la $a0,strIndexOutOfBoundsMsg
3812#    j exitError
3816:arrayIndexOutOfBounds:
3816#    la $a0,arrayIndexOutOfBoundsMsg
3820#    j exitError
3824:arraySizeOutOfBounds:
3824#    la $a0,arraySizeOutOfBoundsMsg
3828#    j exitError
3832:nullPtrException:
3832#    la $a0,nullPtrExceptionMsg
3836#    j exitError
3840:badIntegerFormat:
3840#    la $a0,badIntegerFormatMsg
3844#    j exitError
3848:castException:
3848#    la $a0,castExceptionMsg
3852#    j exitError
############## data section ################
    .data
4052:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4068:cur_seg:
    .word 0

4072:lastCharRead:
    .word -2 # -2 => no buffered character
4076:prevHashConstant:
    .word 0x2785173c
4080:gcCount:
    .word 0

4084:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4111:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4134:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4169:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4203:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4236:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4267:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4315:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4336:gcMsg: 
      .asciiz "\nGC!\n"
4342:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4374:nullStr:
    .asciiz "null"
4379:trueString:
    .asciiz "true"
4384:falseString:
    .asciiz "false"
4390:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4409:newlineString:
    .asciiz "\n"
    
    .align 2
4412:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4416:seg0_start:
    .space 0x100000
1052992:seg0_end:
1052992:seg1_start:
    .space 0x100000
2101568:seg1_end:

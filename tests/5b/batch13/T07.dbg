2912#    addu $t1,0x12b68fd2
2913##...lui $at,4791
2917##...addiu $at,$at,-28718
2921##...addu $t1,$at,$t1
2924#    sw $t1,prevHashConstant # update hash constant
2928#    or $t1,0x80000000 # set top bit
2929##...lui $at,32768
2933##...or $t1,$at,$t1

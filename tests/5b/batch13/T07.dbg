##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
752:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
752#    lw $t0,-8($s2) # get word with hash bits from this
756#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
760#    addu $t0,$t1

764#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
768:mth_equals_Object:
768#    move $t0,$s2 # first pointer (this)
772#    lw $t1,($sp) # second pointer
776#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
777##...subu $at,$t0,$t1
781##...sltiu $t0,$at,1

784#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
788:mth_hashCode_String:
788#    move $t0,$s2 # put this pointer in t0

792#    li $t2,0 # current hash value
796#    lw $t1,-4($t0) # negative of number of characters in string
800#    beq $t1,$zero,done_hashCode_String # if zero length => done
804#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
808#    and $t0,0xfffffffc # adjust for padding
809##...lui $at,65535
813##...ori $at,$at,0xfffc
817##...and $t0,$t0,$at
820#    subu $t1,$t0,$t1 # address at end of string +12
824:loop_hashCode_String:    
824#    sll $t4,$t2,5 # multiply by 32
828#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
832#    lbu $t3,-12($t0) # current character
836#    addu $t2,$t3 # add in current character
840#    addu $t0,1 # go to next character's address
844#    bne $t0,$t1,loop_hashCode_String # loop back if more
848:done_hashCode_String:    

    # push int on stack
848#    move $t0, $t2 # put $t2 in return slot
852#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
856:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
856#    subu $sp,4
860#    sw $ra,($sp)
    
    # get hash value
864#    lw $t2,-12($s2) # vtable address
868#    lw $t0,($t2) # method address
872#    jalr $t0
876#    subu $sp,8 # push result (int in $t0) on stack
880#    sw $s5,4($sp)
884#    sw $t0,($sp)

    # compute print-size of hash value
888#    li $t0, 1
892#    lw $t1, ($sp)
896#    srl $t1,$t1,4
900#    beq $t1,$zero,toString_skip_loop
904:toString_loop_top:
904#    addu $t0,1
908#    srl $t1,$t1,4
912#    bne $t1,$zero,toString_loop_top
916:toString_skip_loop:
916#    subu $sp,8
920#    sw $s5,4($sp)
924#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
928#    lw $t2,-12($s2) # vtable address
932#    move $t0,$t2
936:toString_checkTagBit:
936#    subu $t0,1
940#    lb $t1,($t0)
944#    and $t1,0x80
945##...lui $at,0
949##...ori $at,$at,0x80
953##...and $t1,$t1,$at
956#    beq $t1,$zero,toString_checkTagBit
960#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
964#    subu $sp,8
968#    sw $t1,($sp)
972#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
976#    move $s7,$zero # -4 offset header word
980#    lw $t4,8($sp) # bytes for hash value
984#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
988#    addu $t4,8
992#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
996#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1000#    li $t0,CLASS_String # store string vtable address into ...
1004#    sw $t0,-12($s7) # ... -12 offset in object header
1008#    lw $t2,-12($s2) # our object's vtable address
1012#    lw $t5,4($sp) # number characters in prefix
1016#    lw $t1,12($sp) # number of characters in hashcode
1020#    addu $t3,$t1,$t5 # number of characters in string ...
1024#    addu $t3,1 # ... including the '@' character
1028#    subu $t0,$zero,$t3 # store negated length into ...
1032#    sw $t0,-4($s7) # ... -4 offset header word
1036#    lw $t0,-8($s7) # get -8 offset header-word
1040#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1041##...slt $at,$t0,$zero
1045##...beq $at,$zero,1064
1048#    and $t0,0xff # mask off object's hash value ...
1049##...lui $at,0
1053##...ori $at,$at,0xff
1057##...and $t0,$t0,$at
1060#    sw $t0,-8($s7) # ... and store back into -8 header-word
1064:skipMask_toString:
1064#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1068#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
5496:mth_readLine_Lib:
    
5496#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
5500#    sw $ra, 4($sp) # save $ra
5504#    move $t1,$sp # save "original" sp

5508:  doRead:

    # read the character
5508#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
5512#    subu $t2,$v0,13
5516#    bne $t2,$zero,notReturnRL
5520#    jal readLogicalChar
5524#    subu $t2,$v0,10 # check for newline
5528#    beq $t2,$zero,foundNewLine
5532#    sw $v0,lastCharRead # push back character into queue
5536#    j foundNewLine # go process the line

5540:  notReturnRL:

    # at this point, $v0 has our character

5540#    subu $t0,$v0,10
5544#    beq $t0,$zero,foundNewLine
5548#    blt $v0,$zero,foundEof
5549##...slt $at,$v0,$zero
5553##...bne $at,$zero,5568

    # we have a character, so push it onto stack
5556#    subu $sp,$sp,4
5560#    sw $v0,($sp)

    # loop back up to get next character
5564#    j doRead

5568:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
5568#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
5572#    li $s7, 0 # return-value: null
5576#    j rlReturn # return

5580:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
5580#    subu $t0,$t1,$sp # number of chars we read (times 4)
5584#    srl $s6,$t0,2 # number of words on stack with chars
5588#    subu $sp,$sp,4 # push char-count ...
5592#    sw $s6,($sp) # ... onto stack
5596#    addu $t2,$t0,5 # GC tag, incl. for count-word
5600#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
5604#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
5608#    srl $s6,$s6,2  # data words in object
5612#    move $s7,$zero # object words in object
5616#    jal newObject  # allocate space
    
    # store header words
5620#    la $t0,CLASS_String
5624#    sw $t0,-12($s7)# store class tag (String) into object
5628#    lw $t2,4($sp) # char-count
5632#    sll $t1,$t2,2 # 4 times number of chars
5636#    subu $t2,$zero,$t2 # negative of char-count
5640#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
5644#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
5648#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
5649##...slt $at,$t0,$zero
5653##...beq $at,$zero,5672
5656#    and $t0,0xff # mask off object's hash value ...
5657##...lui $at,0
5661##...ori $at,$at,0xff
5665##...and $t0,$t0,$at
5668#    sw $t0,-8($s7) # ... and store back into -8 header-word
5672:  skipMask_readLine:

5672#    sll $t0,$t0,2 # data bytes in object
5676#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
5680#    subu $t0,$t0,$t2 # place to store last character (plus 9)
5684#    addu $sp,$sp,8 # pop redundant object-pointer and count
5688#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

5692#    beq $sp,$t1,rlReturn
5696:  charCopyLoop:
5696#    lw $t2,($sp)
5700#    sb $t2,-9($t0)
5704#    addu $sp,$sp,4
5708#    subu $t0,$t0,1
5712#    bne $sp,$t1,charCopyLoop
5716:  rlReturn:

5716#    lw $ra, 4($sp)
5720#    addu $sp, 8   # pop $ra and pointless word off stack
5724#    move $t0, $s7 # return string we allocated in $s7
5728#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
5732:mth_readInt_Lib:

    # save $ra by pushing onto stack
5732#    subu $sp,$sp,4
5736#    sw $ra,($sp)

5740:  riSkipWhiteLoop:
    # read a character
5740#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
5744#    subu $t0,$v0,32
5748#    bgt $t0,$zero,nonWhite
5749##...slt $at,$zero,$t0
5753##...bne $at,$zero,5796
5756#    beq $t0,$zero,riSkipWhiteLoop # start over if space
5760#    subu $t0,$v0,10
5764#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
5768#    subu $t0,$v0,9
5772#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
5776#    subu $t0,$v0,13
5780#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
5784#    subu $t0,$v0,12
5788#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
5792#    j badIntegerFormat # illegal integer char: abort program

5796:  nonWhite:
5796#    subu $t0,$v0,'-'
5800#    li $t4,1 # final multiplier
5804#    bne $t0,$zero,helpReadInt # go read
5808#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
5812#    jal readLogicalChar

5816:  helpReadInt:
5816#    li $t2,10
5820#    subu $t1,$v0,'0' # convert digit to 0-9 value
5824#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
5825##...sltu $at,$t1,$t2
5829##...beq $at,$zero,8076
5832#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

5836:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

5836#    jal readLogicalChar # read next character
5840#    subu $t1,$v0,'0' # convert digit to 0-9 value
5844#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
5845##...sltu $at,$t1,$t2
5849##...beq $at,$zero,5868

5852#    mul $t3,$t3,$t2 # multiply old value by 10
5853##...mult $t3,$t2
5857##...mflo $t3
5860#    addu $t3,$t3,$t1 # add in value of new digit
5864#    j digitLoop

5868:  doneDigitLoop:

    # "push back" unused character into queue
5868#    sw $v0,lastCharRead

    # restore return address
5872#    lw $ra,($sp)
5876#    addu $sp, 4

    # multiply by sign and put return value in $t0
5880#    mult $t3,$t4 # multiply to account for poss. minus sign
5884#    mflo $t3
5888#    move $t0, $t3
    
    # return
5892#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
5896:mth_readChar_Lib:

    # save $ra by pushing onto stack
5896#    subu $sp,$sp,4
5900#    sw $ra,($sp)

      # read the character
5904#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
5908#    lw $ra,($sp)
5912#    addu $sp, 4
5916#    move $t0, $v0

    # return
5920#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
5924:mth_printStr_Lib:
    # check for null, printing "(null)", if so
5924#    lw $t0,($sp)
5928#    bne $t0,$zero,psNotNull

    # print "(null)"
5932#    la $a0,nullStr
5936#    li $v0,4
5940#    syscall
5944#    j donePrintStr
    
5948:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits

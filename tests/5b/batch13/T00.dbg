7576#    lw $t3,-8($t2) # word to swap
7580#    sw $t1,-8($t2) # store header word
7584#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
7588#    lw $t1,-12($t2) # vtable pointer
7592#    li $t0,dataArrayVTableStart # address of vtable for first data array
7596#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
7597##...slt $at,$t1,$t0
7601##...bne $at,$zero,7620

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
7604:  skipToNextObj:
7604#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
7608#    sll $t1,$t1,2 # convert to byte-count
7612#    addu $t0,$t2,$t1 # skip over object
7616#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
7620:  gcNotDataArray:
7620#    lw $t3,-4($t2) # # object words (negative treated as zero)
7624#    bge $t3,$zero,gcH2Neg2
7625##...slt $at,$t3,$zero
7629##...beq $at,$zero,7636
7632#    move $t3,$zero
7636:  gcH2Neg2:
7636#    sll $t3,$t3,2 # # object bytes
7640#    move $t0,$t2 # address of first pointer in object
7644#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
7648#    beq $t0,$s1,gcTestIterDone2
    
7652:  gcNextPointerInObject:
    # get pointer from object
7652#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
7656#    bleu $t1,$t6,gcGoNextPointerSlot
7657##...sltu $at,$t6,$t1
7661##...beq $at,$zero,7804
7664#    bgtu $t1,$t7,gcGoNextPointerSlot
7665##...sltu $at,$t7,$t1
7669##...bne $at,$zero,7804

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
7672#    lw $t8,-8($t1) # possible forwarding tag
7676#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
7680#    lw $t8,-4($t1) # forwarding pointer: object's new address
7684#    sw $t8,($t0) # update pointer in object
7688#    j gcGoNextPointerSlot # do next iteration

7692:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
7692#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
7693##...slt $at,$t8,$zero
7697##...beq $at,$zero,7712
7700#    and $t8,0xff # mask off hash bits
7701##...lui $at,0
7705##...ori $at,$at,0xff
7709##...and $t8,$t8,$at

7712:  gcSkip5:
7712#    sll $t8,$t8,2 # bytes in negative-offset portion ...
7716#    addu $t8,$t8,8 # ... add in bytes for header-words
7720#    subu $t4,$t1,$t8 # address of first word of source object
7724#    lw $t3,-4($t1) # # words in positive-offset portion
7728#    bge $t3,$zero,gcNoNeg
7729##...slt $at,$t3,$zero
7733##...beq $at,$zero,7740
7736#    move $t3,$zero # negative treated as zero
7740:  gcNoNeg:
7740#    sll $t3,$t3,2 # bytes in negative-offset portion
7744#    addu $t3,$t3,$t1 # address one word past last word of source

7748#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
7752#    lw $s0,($t4)
7756#    lw $t9,-8($t1)
7760#    sw $t9,($t4)
7764#    sw $s0,-8($t1)

    # copy all source bytes to the target
7768:  gCinnerCopy2:
7768#    lw $s0,($t4)
7772#    sw $s0,($s3)
7776#    addu $t4,$t4,4
7780#    addu $s3,$s3,4
7784#    bltu $t4,$t3,gCinnerCopy2
7785##...sltu $at,$t4,$t3
7789##...bne $at,$zero,7768

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
7792#    sw $zero,-8($t1) # 0 in first header-slot
7796#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
7800#    sw $t8,($t0)

7804:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
7804#    addu $t0,$t0,4
7808#    bltu $t0,$s1,gcNextPointerInObject
7809##...sltu $at,$t0,$s1
7813##...bne $at,$zero,7652

7816:  gcTestIterDone2:
7816#    bltu $t0,$s3,gcHeapCopyLoop
7817##...sltu $at,$t0,$s3
7821##...bne $at,$zero,7536

    ###### end outer loop to copy all non-stack-direct objects ######

7824:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
7824#    lw $s2,($sp)
7828#    addu $sp,$sp,4

    # mark us as having already GC'd
7832#    move $t5,$s5

    # go try and allocate again
7836#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
7840:vm_init:

    # mark bottom of stack
7840#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
7844#    move $s2,$zero

    #set up the "five" register
7848#    li $s5,5

7852#    la $s3,seg0_start
7856#    la $s4,seg0_end
7857##...lui $s4,16
7861##...addiu $s4,$s4,8724
    
    # return
7864#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
7868:divide:
    # get parameters; abort if divisor zero
7868#    lw $t0,($sp)
7872#    lw $t1,8($sp)
7876#    beq $t0,$zero,divByZeroError
    
    # perform division
7880#    div $t1,$t0
7884#    mflo $t0

    # store result, adjust stack and return
7888#    addu $sp,$sp,8 # adjust stack
7892#    sw $t0,($sp) # store result
7896#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
7900:remainder:
    # get parameters; abort if divisor zero
7900#    lw $t0,($sp)
7904#    lw $t1,8($sp)
7908#    beq $t0,$zero,divByZeroError
    
    # perform division
7912#    div $t1,$t0
7916#    mfhi $t0

    # store result, adjust stack and return
7920#    addu $sp,$sp,8 # adjust stack
7924#    sw $t0,($sp) # store result
7928#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
7932:checkCast:
    # get object, allow immediately if null
7932#    lw $t2,($sp)
7936#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
7940#    lw $t2,-12($t2) # vtable address
7944#    bge $t2,$t1,castException
7945##...slt $at,$t2,$t1
7949##...beq $at,$zero,8084
7952#    blt $t2,$t0,castException
7953##...slt $at,$t2,$t0
7957##...bne $at,$zero,8084
    
    # return, leaving object unchanged on stack
7960:  checkCastReturn:    
7960#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
7964:instanceOf:
    # get object, go return false if null
7964#    lw $t2,($sp)
7968#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
7972#    lw $t2,-12($t2) # vtable address
7976#    sge $t0,$t2,$t0 # are we >= the lower limit?
7977##...slt $t0,$t2,$t0
7981##...xori $t0,$t0,0x1
7984#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
7988#    and $t2,$t0,$t1
7992#    sw $t2,($sp)
7996:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
7996#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

8000:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
8000#    li $v0,4 # syscall-code for print-string
8004#    syscall
8008:exit:
    # print termination message
8008#    li $v0,4 # syscall-code for print-string
8012#    la $a0,exitString
8016#    syscall

    # terminate execution
8020#    li $v0,10 #syscall-code for "exit"
8024#    syscall

8028:outOfHeapMemory:
8028#    la $a0,heapMemoryMsg
8032#    j exitError
8036:divByZeroError:
8036#    la $a0,divByZeroMsg
8040#    j exitError
8044:strIndexOutOfBounds:
8044#    la $a0,strIndexOutOfBoundsMsg
8048#    j exitError
8052:arrayIndexOutOfBounds:
8052#    la $a0,arrayIndexOutOfBoundsMsg
8056#    j exitError
8060:arraySizeOutOfBounds:
8060#    la $a0,arraySizeOutOfBoundsMsg
8064#    j exitError
8068:nullPtrException:
8068#    la $a0,nullPtrExceptionMsg
8072#    j exitError
8076:badIntegerFormat:
8076#    la $a0,badIntegerFormatMsg
8080#    j exitError
8084:castException:
8084#    la $a0,castExceptionMsg
8088#    j exitError
############## data section ################
    .data
8360:hexChars:
    .ascii "0123456789abcdef"
    .align 2
8376:cur_seg:
    .word 0

8380:lastCharRead:
    .word -2 # -2 => no buffered character
8384:prevHashConstant:
    .word 0x2785173c
8388:gcCount:
    .word 0

8392:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
8419:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
8442:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
8477:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
8511:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
8544:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
8575:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
8623:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
8644:gcMsg: 
      .asciiz "\nGC!\n"
8650:gcCountMsg: 
      .asciiz "Number of garbage collections: "

8682:nullStr:
    .asciiz "null"
8687:trueString:
    .asciiz "true"
8692:falseString:
    .asciiz "false"
8698:exitString:
    .ascii "Program terminated."
    #### "falls through" here
8717:newlineString:
    .asciiz "\n"
    
    .align 2
8720:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

8724:seg0_start:
    .space 0x100000
1057300:seg0_end:
1057300:seg1_start:
    .space 0x100000
2105876:seg1_end:

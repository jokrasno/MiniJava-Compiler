7044#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
7048#    jr $ra # return
    
7052:  doReadCh:
    # we need to actually read a character: read and return
7052#    li $v0,12 # use system call to read a character
7056#    syscall
7060#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
5092:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
5092#    subu $sp,4
5096#    sw $ra,($sp)
    
    # get hash value
5100#    lw $t2,-12($s2) # vtable address
5104#    lw $t0,($t2) # method address
5108#    jalr $t0
5112#    subu $sp,8 # push result (int in $t0) on stack
5116#    sw $s5,4($sp)
5120#    sw $t0,($sp)

    # compute print-size of hash value
5124#    li $t0, 1
5128#    lw $t1, ($sp)
5132#    srl $t1,$t1,4
5136#    beq $t1,$zero,toString_skip_loop
5140:toString_loop_top:
5140#    addu $t0,1
5144#    srl $t1,$t1,4
5148#    bne $t1,$zero,toString_loop_top
5152:toString_skip_loop:
5152#    subu $sp,8
5156#    sw $s5,4($sp)
5160#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
5164#    lw $t2,-12($s2) # vtable address
5168#    move $t0,$t2
5172:toString_checkTagBit:
5172#    subu $t0,1
5176#    lb $t1,($t0)
5180#    and $t1,0x80
5181##...lui $at,0
5185##...ori $at,$at,0x80
5189##...and $t1,$t1,$at
5192#    beq $t1,$zero,toString_checkTagBit
5196#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
5200#    subu $sp,8
5204#    sw $t1,($sp)
5208#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
5212#    move $s7,$zero # -4 offset header word
5216#    lw $t4,8($sp) # bytes for hash value
5220#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
5224#    addu $t4,8
5228#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
5232#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

5236#    li $t0,CLASS_String # store string vtable address into ...
5240#    sw $t0,-12($s7) # ... -12 offset in object header
5244#    lw $t2,-12($s2) # our object's vtable address
5248#    lw $t5,4($sp) # number characters in prefix
5252#    lw $t1,12($sp) # number of characters in hashcode
5256#    addu $t3,$t1,$t5 # number of characters in string ...
5260#    addu $t3,1 # ... including the '@' character
5264#    subu $t0,$zero,$t3 # store negated length into ...
5268#    sw $t0,-4($s7) # ... -4 offset header word
5272#    lw $t0,-8($s7) # get -8 offset header-word
5276#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
5277##...slt $at,$t0,$zero
5281##...beq $at,$zero,5300
5284#    and $t0,0xff # mask off object's hash value ...
5285##...lui $at,0
5289##...ori $at,$at,0xff
5293##...and $t0,$t0,$at
5296#    sw $t0,-8($s7) # ... and store back into -8 header-word
5300:skipMask_toString:
5300#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
5304#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
5308#    subu $t4,$t2,$t5
5312:toString_copyLoop:    
5312#    lb $t3,($t4)
5316#    and $t3,0x7f # mask off sign bit (in case first word)
5317##...lui $at,0
5321##...ori $at,$at,0x7f
5325##...and $t3,$t3,$at
5328#    sb $t3,-8($t0)
5332#    addu $t4,1
5336#    addu $t0,1
5340#    blt $t4,$t2,toString_copyLoop
5341##...slt $at,$t4,$t2
5345##...bne $at,$zero,5312

    # copy the '@' sign
5348#    li $t3,'@'
5352#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
5356#    addu $t2,$t0,$t1 # address of last byte in string to store +8
5360#    lw $t3,20($sp) # hash code to print
5364:toString_hashCopyLoop:
5364#    and $t4,$t3,0xf
5368#    srl $t3,4
5372#    lb $t4,hexChars($t4)
5376#    sb $t4,-8($t2)
5380#    subu $t2,$t2,1
5384#    bgt $t2,$t0,toString_hashCopyLoop
5385##...slt $at,$t0,$t2
5389##...bne $at,$zero,5364

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
5392#    addu $sp,28
5396#    lw $ra,($sp)
5400#    addu $sp,4
5404#    move $t0, $s7 # return string we created
5408#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
5412:mth_equals_String:
    
    # quick test for obvious false
5412#    lw $t0,($sp) # second parameter
5416#    beq $t0,$zero,goEsFalse # go return false if null
5420#    lw $t1,-12($t0) # vtable pointer
5424#    la $t2,CLASS_String # string vtable pointer
5428#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
5432#    subu $sp,12
5436#    sw $ra,8($sp)
5440#    sw $s2,4($sp)
5444#    sw $t0,($sp)
5448#    jal mth_compareTo_String
5452#    lw $s2, 4($sp) #restore this pointer and pop parameters
5456#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
5460#    seq $t0,$t0,$zero
5461##...subu $at,$t0,$zero
5465##...sltiu $t0,$at,1

    # pop return address and return $t0
5468#    lw $ra,($sp)
5472#    addu $sp,4

5476#    jr $ra # return
    
5480:goEsFalse:
    # put 0 in $t0 and return
5480#    li $t0, 0
5484#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
5488:mth_toString_String:
    #we are a string, so return this.
5488#    move $t0, $s2
5492#    jr $ra

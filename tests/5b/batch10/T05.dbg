##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3704:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
3704#    lw $t0,-8($s2) # get word with hash bits from this
3708#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
3712#    addu $t0,$t1

3716#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3720:mth_equals_Object:
3720#    move $t0,$s2 # first pointer (this)
3724#    lw $t1,($sp) # second pointer
3728#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
3729##...subu $at,$t0,$t1
3733##...sltiu $t0,$at,1

3736#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3740:mth_hashCode_String:
3740#    move $t0,$s2 # put this pointer in t0

3744#    li $t2,0 # current hash value
3748#    lw $t1,-4($t0) # negative of number of characters in string
3752#    beq $t1,$zero,done_hashCode_String # if zero length => done
3756#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
3760#    and $t0,0xfffffffc # adjust for padding
3761##...lui $at,65535
3765##...ori $at,$at,0xfffc
3769##...and $t0,$t0,$at
3772#    subu $t1,$t0,$t1 # address at end of string +12
3776:loop_hashCode_String:    
3776#    sll $t4,$t2,5 # multiply by 32
3780#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
3784#    lbu $t3,-12($t0) # current character
3788#    addu $t2,$t3 # add in current character
3792#    addu $t0,1 # go to next character's address
3796#    bne $t0,$t1,loop_hashCode_String # loop back if more
3800:done_hashCode_String:    

    # push int on stack
3800#    move $t0, $t2 # put $t2 in return slot
3804#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
3808:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
3808#    subu $sp,4
3812#    sw $ra,($sp)
    
    # get hash value
3816#    lw $t2,-12($s2) # vtable address
3820#    lw $t0,($t2) # method address
3824#    jalr $t0
3828#    subu $sp,8 # push result (int in $t0) on stack
3832#    sw $s5,4($sp)
3836#    sw $t0,($sp)

    # compute print-size of hash value
3840#    li $t0, 1
3844#    lw $t1, ($sp)
3848#    srl $t1,$t1,4
3852#    beq $t1,$zero,toString_skip_loop
3856:toString_loop_top:
3856#    addu $t0,1
3860#    srl $t1,$t1,4
3864#    bne $t1,$zero,toString_loop_top
3868:toString_skip_loop:
3868#    subu $sp,8
3872#    sw $s5,4($sp)
3876#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
3880#    lw $t2,-12($s2) # vtable address
3884#    move $t0,$t2
3888:toString_checkTagBit:
3888#    subu $t0,1
3892#    lb $t1,($t0)
3896#    and $t1,0x80
3897##...lui $at,0
3901##...ori $at,$at,0x80
3905##...and $t1,$t1,$at
3908#    beq $t1,$zero,toString_checkTagBit
3912#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
3916#    subu $sp,8
3920#    sw $t1,($sp)
3924#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
3928#    move $s7,$zero # -4 offset header word
3932#    lw $t4,8($sp) # bytes for hash value
3936#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
3940#    addu $t4,8
3944#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
3948#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

3952#    li $t0,CLASS_String # store string vtable address into ...
3956#    sw $t0,-12($s7) # ... -12 offset in object header
3960#    lw $t2,-12($s2) # our object's vtable address
3964#    lw $t5,4($sp) # number characters in prefix
3968#    lw $t1,12($sp) # number of characters in hashcode
3972#    addu $t3,$t1,$t5 # number of characters in string ...
3976#    addu $t3,1 # ... including the '@' character
3980#    subu $t0,$zero,$t3 # store negated length into ...
3984#    sw $t0,-4($s7) # ... -4 offset header word
3988#    lw $t0,-8($s7) # get -8 offset header-word
3992#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
3993##...slt $at,$t0,$zero
3997##...beq $at,$zero,4016
4000#    and $t0,0xff # mask off object's hash value ...
4001##...lui $at,0
4005##...ori $at,$at,0xff
4009##...and $t0,$t0,$at
4012#    sw $t0,-8($s7) # ... and store back into -8 header-word
4016:skipMask_toString:
4016#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
4020#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
4024#    subu $t4,$t2,$t5
4028:toString_copyLoop:    
4028#    lb $t3,($t4)
4032#    and $t3,0x7f # mask off sign bit (in case first word)
4033##...lui $at,0
4037##...ori $at,$at,0x7f
4041##...and $t3,$t3,$at
4044#    sb $t3,-8($t0)
4048#    addu $t4,1
4052#    addu $t0,1
4056#    blt $t4,$t2,toString_copyLoop
4057##...slt $at,$t4,$t2
4061##...bne $at,$zero,4028

    # copy the '@' sign
4064#    li $t3,'@'
4068#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
4072#    addu $t2,$t0,$t1 # address of last byte in string to store +8
4076#    lw $t3,20($sp) # hash code to print
4080:toString_hashCopyLoop:
4080#    and $t4,$t3,0xf
4084#    srl $t3,4
4088#    lb $t4,hexChars($t4)
4092#    sb $t4,-8($t2)
4096#    subu $t2,$t2,1
4100#    bgt $t2,$t0,toString_hashCopyLoop
4101##...slt $at,$t0,$t2
4105##...bne $at,$zero,4080

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
4108#    addu $sp,28
4112#    lw $ra,($sp)
4116#    addu $sp,4
4120#    move $t0, $s7 # return string we created
4124#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
4128:mth_equals_String:
    
    # quick test for obvious false
4128#    lw $t0,($sp) # second parameter
4132#    beq $t0,$zero,goEsFalse # go return false if null
4136#    lw $t1,-12($t0) # vtable pointer
4140#    la $t2,CLASS_String # string vtable pointer
4144#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
4148#    subu $sp,12
4152#    sw $ra,8($sp)
4156#    sw $s2,4($sp)
4160#    sw $t0,($sp)
4164#    jal mth_compareTo_String
4168#    lw $s2, 4($sp) #restore this pointer and pop parameters
4172#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
4176#    seq $t0,$t0,$zero
4177##...subu $at,$t0,$zero
4181##...sltiu $t0,$at,1

    # pop return address and return $t0
4184#    lw $ra,($sp)
4188#    addu $sp,4

4192#    jr $ra # return
    
4196:goEsFalse:
    # put 0 in $t0 and return
4196#    li $t0, 0
4200#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
4204:mth_toString_String:
    #we are a string, so return this.
4204#    move $t0, $s2
4208#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
4212:mth_readLine_Lib:
    
4212#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
4216#    sw $ra, 4($sp) # save $ra
4220#    move $t1,$sp # save "original" sp

4224:  doRead:

    # read the character
4224#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
4228#    subu $t2,$v0,13
4232#    bne $t2,$zero,notReturnRL
4236#    jal readLogicalChar
4240#    subu $t2,$v0,10 # check for newline
4244#    beq $t2,$zero,foundNewLine
4248#    sw $v0,lastCharRead # push back character into queue
4252#    j foundNewLine # go process the line

4256:  notReturnRL:

    # at this point, $v0 has our character

4256#    subu $t0,$v0,10
4260#    beq $t0,$zero,foundNewLine
4264#    blt $v0,$zero,foundEof
4265##...slt $at,$v0,$zero
4269##...bne $at,$zero,4284

    # we have a character, so push it onto stack
4272#    subu $sp,$sp,4
4276#    sw $v0,($sp)

    # loop back up to get next character
4280#    j doRead

4284:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
4284#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
4288#    li $s7, 0 # return-value: null
4292#    j rlReturn # return

4296:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
4296#    subu $t0,$t1,$sp # number of chars we read (times 4)
4300#    srl $s6,$t0,2 # number of words on stack with chars

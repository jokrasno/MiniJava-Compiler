#       lexographically less than, equal to or greater than str2
########################################################
5632:mth_compareTo_String:
    # get string pointers and check parameter for null
5632#    lw $t0,($sp) # second string
5636#    beq $t0,$zero,nullPtrException
5640#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
5644#    lw $t2,-4($t0) # negative length of second string
5648#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
5652#    slt $t4,$t3,$t2
5656#    slt $t5,$t2,$t3
5660#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
5664#    lw $t2,-8($t0) # # data words in second string
5668#    lw $t3,-8($t1) # # data words in first string
5672#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
5676#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
5680#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
5684#    subu $t1,$t1,$t3 # beginning of str2 address (+8)

5748#    lw $v0,lastCharRead
5752#    li $t0,-2
5756#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
5760#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
5764#    jr $ra # return
    
5768:  doReadCh:

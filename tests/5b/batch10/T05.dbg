########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
6680:instanceOf:
    # get object, go return false if null
6680#    lw $t2,($sp)
6684#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
6688#    lw $t2,-12($t2) # vtable address
6692#    sge $t0,$t2,$t0 # are we >= the lower limit?
6693##...slt $t0,$t2,$t0
6697##...xori $t0,$t0,0x1
6700#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
6704#    and $t2,$t0,$t1
6708#    sw $t2,($sp)
6712:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
6712#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

6716:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
6716#    li $v0,4 # syscall-code for print-string
6720#    syscall
6724:exit:
    # print termination message
6724#    li $v0,4 # syscall-code for print-string
6728#    la $a0,exitString
6732#    syscall

    # terminate execution
6736#    li $v0,10 #syscall-code for "exit"
6740#    syscall

6744:outOfHeapMemory:
6744#    la $a0,heapMemoryMsg
6748#    j exitError
6752:divByZeroError:
6752#    la $a0,divByZeroMsg
6756#    j exitError
6760:strIndexOutOfBounds:
6760#    la $a0,strIndexOutOfBoundsMsg
6764#    j exitError
6768:arrayIndexOutOfBounds:
6768#    la $a0,arrayIndexOutOfBoundsMsg
6772#    j exitError
6776:arraySizeOutOfBounds:
6776#    la $a0,arraySizeOutOfBoundsMsg
6780#    j exitError
6784:nullPtrException:
6784#    la $a0,nullPtrExceptionMsg
6788#    j exitError
6792:badIntegerFormat:
6792#    la $a0,badIntegerFormatMsg
6796#    j exitError
6800:castException:
6800#    la $a0,castExceptionMsg
6804#    j exitError
############## data section ################
    .data
7096:hexChars:
    .ascii "0123456789abcdef"
    .align 2
7112:cur_seg:
    .word 0

7116:lastCharRead:
    .word -2 # -2 => no buffered character
7120:prevHashConstant:
    .word 0x2785173c
7124:gcCount:
    .word 0

7128:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
7155:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
7178:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
7213:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
7247:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
7280:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
7311:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
7359:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
7380:gcMsg: 
      .asciiz "\nGC!\n"
7386:gcCountMsg: 
      .asciiz "Number of garbage collections: "

7418:nullStr:
    .asciiz "null"
7423:trueString:
    .asciiz "true"
7428:falseString:
    .asciiz "false"
7434:exitString:
    .ascii "Program terminated."
    #### "falls through" here
7453:newlineString:
    .asciiz "\n"
    
    .align 2
7456:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

7460:seg0_start:
    .space 0x100000
1056036:seg0_end:
1056036:seg1_start:
    .space 0x100000
2104612:seg1_end:

4465##...slt $at,$zero,$t0
4469##...bne $at,$zero,4512
4472#    beq $t0,$zero,riSkipWhiteLoop # start over if space
4476#    subu $t0,$v0,10
4480#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
4484#    subu $t0,$v0,9
4488#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
4492#    subu $t0,$v0,13
4496#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
4500#    subu $t0,$v0,12
4504#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
4508#    j badIntegerFormat # illegal integer char: abort program

4512:  nonWhite:
4512#    subu $t0,$v0,'-'
4516#    li $t4,1 # final multiplier
4520#    bne $t0,$zero,helpReadInt # go read
4524#    li $t4,-1 # -1 in final multiplier


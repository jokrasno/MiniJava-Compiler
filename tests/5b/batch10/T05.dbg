5820#    sw $zero,($s3)
5824#    lw $zero,($s3)

5828#    addu $s3,4
5832#    bltu $s3,$t1,zeroObjLoop
5833##...sltu $at,$s3,$t1
5837##...bne $at,$zero,5820

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
5840#    sll $t0,$s7,2    # number of post-header bytes
5844#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
5848#    li $t2,255
5852#    bgeu $s6,$t2 firstHeaderLarge
5853##...sltu $at,$s6,$t2
5857##...beq $at,$zero,5904
5860#    lw $t1,prevHashConstant
5864#    addu $t1,0x12b68fd2
5865##...lui $at,4791
5869##...addiu $at,$at,-28718
5873##...addu $t1,$at,$t1
5876#    sw $t1,prevHashConstant # update hash constant
5880#    or $t1,0x80000000 # set top bit
5881##...lui $at,32768
5885##...or $t1,$at,$t1
5888#    and $t1,0xffffff00 # clear low bit
5889##...lui $at,65535
5893##...ori $at,$at,0xff00
5897##...and $t1,$t1,$at
5900#    or $s6,$t1
5904:firstHeaderLarge:
5904#    sw $s6,-8($t0) # store header-1 value
5908#    lw $zero,-8($t0)

    # store second header-value
5912#    sw $s7,-4($t0)   # second header-word
5916#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
5920#    move $s7,$t0
5924#    subu $sp,$sp,4
5928#    sw $t0,($sp)

5932#    jr $ra

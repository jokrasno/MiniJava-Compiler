########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
6584:divide:
    # get parameters; abort if divisor zero
6584#    lw $t0,($sp)
6588#    lw $t1,8($sp)
6592#    beq $t0,$zero,divByZeroError
    
    # perform division
6596#    div $t1,$t0
6600#    mflo $t0

    # store result, adjust stack and return
6604#    addu $sp,$sp,8 # adjust stack
6608#    sw $t0,($sp) # store result
6612#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################

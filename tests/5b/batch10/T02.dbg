###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
848:mth_readLine_Lib:
    
848#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
852#    sw $ra, 4($sp) # save $ra
856#    move $t1,$sp # save "original" sp

860:  doRead:

    # read the character
860#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
864#    subu $t2,$v0,13
868#    bne $t2,$zero,notReturnRL
872#    jal readLogicalChar
876#    subu $t2,$v0,10 # check for newline
880#    beq $t2,$zero,foundNewLine
884#    sw $v0,lastCharRead # push back character into queue
888#    j foundNewLine # go process the line

892:  notReturnRL:

    # at this point, $v0 has our character

892#    subu $t0,$v0,10
896#    beq $t0,$zero,foundNewLine
900#    blt $v0,$zero,foundEof
901##...slt $at,$v0,$zero
905##...bne $at,$zero,920

    # we have a character, so push it onto stack
908#    subu $sp,$sp,4
912#    sw $v0,($sp)

    # loop back up to get next character
916#    j doRead

920:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
920#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
924#    li $s7, 0 # return-value: null
928#    j rlReturn # return

932:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
932#    subu $t0,$t1,$sp # number of chars we read (times 4)
936#    srl $s6,$t0,2 # number of words on stack with chars
940#    subu $sp,$sp,4 # push char-count ...
944#    sw $s6,($sp) # ... onto stack
948#    addu $t2,$t0,5 # GC tag, incl. for count-word
952#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
956#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
960#    srl $s6,$s6,2  # data words in object
964#    move $s7,$zero # object words in object
968#    jal newObject  # allocate space
    
    # store header words
972#    la $t0,CLASS_String
976#    sw $t0,-12($s7)# store class tag (String) into object
980#    lw $t2,4($sp) # char-count
984#    sll $t1,$t2,2 # 4 times number of chars
988#    subu $t2,$zero,$t2 # negative of char-count
992#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
996#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1000#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1001##...slt $at,$t0,$zero
1005##...beq $at,$zero,1024
1008#    and $t0,0xff # mask off object's hash value ...
1009##...lui $at,0
1013##...ori $at,$at,0xff
1017##...and $t0,$t0,$at
1020#    sw $t0,-8($s7) # ... and store back into -8 header-word
1024:  skipMask_readLine:

1024#    sll $t0,$t0,2 # data bytes in object
1028#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1032#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1036#    addu $sp,$sp,8 # pop redundant object-pointer and count
1040#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1044#    beq $sp,$t1,rlReturn
1048:  charCopyLoop:
1048#    lw $t2,($sp)
1052#    sb $t2,-9($t0)
1056#    addu $sp,$sp,4
1060#    subu $t0,$t0,1
1064#    bne $sp,$t1,charCopyLoop
1068:  rlReturn:

1068#    lw $ra, 4($sp)
1072#    addu $sp, 8   # pop $ra and pointless word off stack
1076#    move $t0, $s7 # return string we allocated in $s7
1080#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1084:mth_readInt_Lib:

    # save $ra by pushing onto stack
1084#    subu $sp,$sp,4
1088#    sw $ra,($sp)

1092:  riSkipWhiteLoop:
    # read a character
1092#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1096#    subu $t0,$v0,32
1100#    bgt $t0,$zero,nonWhite
1101##...slt $at,$zero,$t0
1105##...bne $at,$zero,1148
1108#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1112#    subu $t0,$v0,10
1116#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1120#    subu $t0,$v0,9
1124#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1128#    subu $t0,$v0,13
1132#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1136#    subu $t0,$v0,12
1140#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1144#    j badIntegerFormat # illegal integer char: abort program

1148:  nonWhite:
1148#    subu $t0,$v0,'-'
1152#    li $t4,1 # final multiplier
1156#    bne $t0,$zero,helpReadInt # go read
1160#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1164#    jal readLogicalChar

1168:  helpReadInt:
1168#    li $t2,10
1172#    subu $t1,$v0,'0' # convert digit to 0-9 value
1176#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1177##...sltu $at,$t1,$t2
1181##...beq $at,$zero,3428
1184#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1188:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1188#    jal readLogicalChar # read next character
1192#    subu $t1,$v0,'0' # convert digit to 0-9 value
1196#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1197##...sltu $at,$t1,$t2
1201##...beq $at,$zero,1220

1204#    mul $t3,$t3,$t2 # multiply old value by 10
1205##...mult $t3,$t2
1209##...mflo $t3
1212#    addu $t3,$t3,$t1 # add in value of new digit
1216#    j digitLoop

1220:  doneDigitLoop:

    # "push back" unused character into queue
1220#    sw $v0,lastCharRead

    # restore return address
1224#    lw $ra,($sp)
1228#    addu $sp, 4

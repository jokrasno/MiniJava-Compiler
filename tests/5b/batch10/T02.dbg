##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
340:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
340#    lw $t0,-8($s2) # get word with hash bits from this
344#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
348#    addu $t0,$t1

352#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
356:mth_equals_Object:
356#    move $t0,$s2 # first pointer (this)
360#    lw $t1,($sp) # second pointer
364#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
365##...subu $at,$t0,$t1
369##...sltiu $t0,$at,1

372#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
376:mth_hashCode_String:
376#    move $t0,$s2 # put this pointer in t0

380#    li $t2,0 # current hash value
384#    lw $t1,-4($t0) # negative of number of characters in string
388#    beq $t1,$zero,done_hashCode_String # if zero length => done
392#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
396#    and $t0,0xfffffffc # adjust for padding
397##...lui $at,65535
401##...ori $at,$at,0xfffc
405##...and $t0,$t0,$at
408#    subu $t1,$t0,$t1 # address at end of string +12
412:loop_hashCode_String:    
412#    sll $t4,$t2,5 # multiply by 32
416#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
420#    lbu $t3,-12($t0) # current character
424#    addu $t2,$t3 # add in current character
428#    addu $t0,1 # go to next character's address
432#    bne $t0,$t1,loop_hashCode_String # loop back if more
436:done_hashCode_String:    

    # push int on stack
436#    move $t0, $t2 # put $t2 in return slot
440#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
444:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
444#    subu $sp,4
448#    sw $ra,($sp)
    
    # get hash value
452#    lw $t2,-12($s2) # vtable address
456#    lw $t0,($t2) # method address
460#    jalr $t0
464#    subu $sp,8 # push result (int in $t0) on stack
468#    sw $s5,4($sp)
472#    sw $t0,($sp)

    # compute print-size of hash value
476#    li $t0, 1
480#    lw $t1, ($sp)
484#    srl $t1,$t1,4
488#    beq $t1,$zero,toString_skip_loop
492:toString_loop_top:
492#    addu $t0,1
496#    srl $t1,$t1,4
500#    bne $t1,$zero,toString_loop_top
504:toString_skip_loop:
504#    subu $sp,8
508#    sw $s5,4($sp)
512#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
516#    lw $t2,-12($s2) # vtable address
520#    move $t0,$t2
524:toString_checkTagBit:
524#    subu $t0,1
528#    lb $t1,($t0)
532#    and $t1,0x80
533##...lui $at,0
537##...ori $at,$at,0x80
541##...and $t1,$t1,$at
544#    beq $t1,$zero,toString_checkTagBit
548#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
552#    subu $sp,8
556#    sw $t1,($sp)
560#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
564#    move $s7,$zero # -4 offset header word
568#    lw $t4,8($sp) # bytes for hash value
572#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
576#    addu $t4,8
580#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
584#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

588#    li $t0,CLASS_String # store string vtable address into ...
592#    sw $t0,-12($s7) # ... -12 offset in object header
596#    lw $t2,-12($s2) # our object's vtable address
600#    lw $t5,4($sp) # number characters in prefix
604#    lw $t1,12($sp) # number of characters in hashcode
608#    addu $t3,$t1,$t5 # number of characters in string ...
612#    addu $t3,1 # ... including the '@' character
616#    subu $t0,$zero,$t3 # store negated length into ...
620#    sw $t0,-4($s7) # ... -4 offset header word
624#    lw $t0,-8($s7) # get -8 offset header-word
628#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
629##...slt $at,$t0,$zero
633##...beq $at,$zero,652
636#    and $t0,0xff # mask off object's hash value ...
637##...lui $at,0
641##...ori $at,$at,0xff
645##...and $t0,$t0,$at
648#    sw $t0,-8($s7) # ... and store back into -8 header-word
652:skipMask_toString:
652#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
656#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
660#    subu $t4,$t2,$t5
664:toString_copyLoop:    
664#    lb $t3,($t4)
668#    and $t3,0x7f # mask off sign bit (in case first word)
669##...lui $at,0
673##...ori $at,$at,0x7f
677##...and $t3,$t3,$at
680#    sb $t3,-8($t0)
684#    addu $t4,1
688#    addu $t0,1
692#    blt $t4,$t2,toString_copyLoop
693##...slt $at,$t4,$t2
697##...bne $at,$zero,664

    # copy the '@' sign
700#    li $t3,'@'
704#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
708#    addu $t2,$t0,$t1 # address of last byte in string to store +8
712#    lw $t3,20($sp) # hash code to print
716:toString_hashCopyLoop:
716#    and $t4,$t3,0xf
720#    srl $t3,4
724#    lb $t4,hexChars($t4)
728#    sb $t4,-8($t2)
732#    subu $t2,$t2,1
736#    bgt $t2,$t0,toString_hashCopyLoop
737##...slt $at,$t0,$t2
741##...bne $at,$zero,716

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
744#    addu $sp,28
748#    lw $ra,($sp)
752#    addu $sp,4
756#    move $t0, $s7 # return string we created
760#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
764:mth_equals_String:
    
    # quick test for obvious false
764#    lw $t0,($sp) # second parameter
768#    beq $t0,$zero,goEsFalse # go return false if null
772#    lw $t1,-12($t0) # vtable pointer
776#    la $t2,CLASS_String # string vtable pointer
780#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
784#    subu $sp,12
788#    sw $ra,8($sp)
792#    sw $s2,4($sp)
796#    sw $t0,($sp)
800#    jal mth_compareTo_String
804#    lw $s2, 4($sp) #restore this pointer and pop parameters
808#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
812#    seq $t0,$t0,$zero
813##...subu $at,$t0,$zero
817##...sltiu $t0,$at,1

    # pop return address and return $t0
820#    lw $ra,($sp)
824#    addu $sp,4

828#    jr $ra # return
    
832:goEsFalse:
    # put 0 in $t0 and return
832#    li $t0, 0
836#    jr $ra # return


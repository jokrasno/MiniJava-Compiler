2512#    sw $t1,prevHashConstant # update hash constant
2516#    or $t1,0x80000000 # set top bit
2517##...lui $at,32768
2521##...or $t1,$at,$t1
2524#    and $t1,0xffffff00 # clear low bit
2525##...lui $at,65535
2529##...ori $at,$at,0xff00
2533##...and $t1,$t1,$at
2536#    or $s6,$t1

    # mark bottom of stack
3192#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3196#    move $s2,$zero

    #set up the "five" register
3200#    li $s5,5

3204#    la $s3,seg0_start
3208#    la $s4,seg0_end
3209##...lui $s4,16
3213##...addiu $s4,$s4,4020
    
    # return
3216#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3220:divide:
    # get parameters; abort if divisor zero
3220#    lw $t0,($sp)
3224#    lw $t1,8($sp)
3228#    beq $t0,$zero,divByZeroError
    
    # perform division
3232#    div $t1,$t0
3236#    mflo $t0

    # store result, adjust stack and return
3240#    addu $sp,$sp,8 # adjust stack
3244#    sw $t0,($sp) # store result
3248#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3252:remainder:
    # get parameters; abort if divisor zero
3252#    lw $t0,($sp)
3256#    lw $t1,8($sp)
3260#    beq $t0,$zero,divByZeroError
    
    # perform division
3264#    div $t1,$t0
3268#    mfhi $t0

    # store result, adjust stack and return
3272#    addu $sp,$sp,8 # adjust stack
3276#    sw $t0,($sp) # store result
3280#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3284:checkCast:
    # get object, allow immediately if null
3284#    lw $t2,($sp)
3288#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3292#    lw $t2,-12($t2) # vtable address
3296#    bge $t2,$t1,castException
3297##...slt $at,$t2,$t1
3301##...beq $at,$zero,3436
3304#    blt $t2,$t0,castException
3305##...slt $at,$t2,$t0
3309##...bne $at,$zero,3436
    
    # return, leaving object unchanged on stack
3312:  checkCastReturn:    
3312#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3316:instanceOf:
    # get object, go return false if null
3316#    lw $t2,($sp)
3320#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3324#    lw $t2,-12($t2) # vtable address
3328#    sge $t0,$t2,$t0 # are we >= the lower limit?
3329##...slt $t0,$t2,$t0
3333##...xori $t0,$t0,0x1
3336#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3340#    and $t2,$t0,$t1
3344#    sw $t2,($sp)
3348:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3348#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3352:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3352#    li $v0,4 # syscall-code for print-string
3356#    syscall
3360:exit:
    # print termination message
3360#    li $v0,4 # syscall-code for print-string
3364#    la $a0,exitString
3368#    syscall

    # terminate execution
3372#    li $v0,10 #syscall-code for "exit"
3376#    syscall

3380:outOfHeapMemory:
3380#    la $a0,heapMemoryMsg
3384#    j exitError
3388:divByZeroError:
3388#    la $a0,divByZeroMsg
3392#    j exitError
3396:strIndexOutOfBounds:
3396#    la $a0,strIndexOutOfBoundsMsg
3400#    j exitError
3404:arrayIndexOutOfBounds:
3404#    la $a0,arrayIndexOutOfBoundsMsg
3408#    j exitError
3412:arraySizeOutOfBounds:
3412#    la $a0,arraySizeOutOfBoundsMsg
3416#    j exitError
3420:nullPtrException:
3420#    la $a0,nullPtrExceptionMsg
3424#    j exitError
3428:badIntegerFormat:
3428#    la $a0,badIntegerFormatMsg
3432#    j exitError
3436:castException:
3436#    la $a0,castExceptionMsg
3440#    j exitError
############## data section ################
    .data
3656:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3672:cur_seg:
    .word 0

3676:lastCharRead:
    .word -2 # -2 => no buffered character
3680:prevHashConstant:
    .word 0x2785173c
3684:gcCount:
    .word 0

3688:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3715:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3738:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3773:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3807:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3840:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3871:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3919:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3940:gcMsg: 
      .asciiz "\nGC!\n"
3946:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3978:nullStr:
    .asciiz "null"
3983:trueString:
    .asciiz "true"
3988:falseString:
    .asciiz "false"
3994:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4013:newlineString:
    .asciiz "\n"
    
    .align 2
4016:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4020:seg0_start:
    .space 0x100000
1052596:seg0_end:
1052596:seg1_start:
    .space 0x100000
2101172:seg1_end:

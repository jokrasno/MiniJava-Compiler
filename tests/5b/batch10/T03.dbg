3109##...slt $at,$t8,$zero
3113##...beq $at,$zero,3128
3116#    and $t8,0xff # mask off hash bits
3117##...lui $at,0
3121##...ori $at,$at,0xff
3125##...and $t8,$t8,$at

3128:  gcSkip5:

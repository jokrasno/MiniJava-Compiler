    # storing digits on stack until we reach 0
2032:  itsNonNegLoop:
2032#    divu $t1,$t3
2036#    mflo $t1 # quotient
2040#    mfhi $t4 # remainder
2044#    addu $t4,$t4,'0' # turn remainder into digit
2048#    subu $sp,$sp,4
2052#    sw $t4,($sp) # push digit onto stack
2056#    bne $t1,$zero,itsNonNegLoop

#   - $t0 - the character found.
########################################################
1952:mth_charAt_String:
    # get string
1952#    move $t0,$s2

    # check that index is in bounds
1956#    lw $t1,-4($t0) # negative of # data words in string
1960#    subu $t3,$zero,$t1 # # chars in string

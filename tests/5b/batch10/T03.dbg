########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3256:vm_init:

    # mark bottom of stack
3256#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3260#    move $s2,$zero

    #set up the "five" register
3264#    li $s5,5

3268#    la $s3,seg0_start
3272#    la $s4,seg0_end
3273##...lui $s4,16
3277##...addiu $s4,$s4,4072
    
    # return
3280#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3284:divide:
    # get parameters; abort if divisor zero
3284#    lw $t0,($sp)
3288#    lw $t1,8($sp)
3292#    beq $t0,$zero,divByZeroError
    
    # perform division
3296#    div $t1,$t0
3300#    mflo $t0

    # store result, adjust stack and return
3304#    addu $sp,$sp,8 # adjust stack
3308#    sw $t0,($sp) # store result
3312#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3316:remainder:
    # get parameters; abort if divisor zero
3316#    lw $t0,($sp)
3320#    lw $t1,8($sp)
3324#    beq $t0,$zero,divByZeroError
    
    # perform division
3328#    div $t1,$t0
3332#    mfhi $t0

    # store result, adjust stack and return
3336#    addu $sp,$sp,8 # adjust stack
3340#    sw $t0,($sp) # store result
3344#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3348:checkCast:
    # get object, allow immediately if null
3348#    lw $t2,($sp)
3352#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3356#    lw $t2,-12($t2) # vtable address
3360#    bge $t2,$t1,castException
3361##...slt $at,$t2,$t1
3365##...beq $at,$zero,3500
3368#    blt $t2,$t0,castException
3369##...slt $at,$t2,$t0
3373##...bne $at,$zero,3500
    
    # return, leaving object unchanged on stack
3376:  checkCastReturn:    
3376#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3380:instanceOf:
    # get object, go return false if null
3380#    lw $t2,($sp)
3384#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3388#    lw $t2,-12($t2) # vtable address
3392#    sge $t0,$t2,$t0 # are we >= the lower limit?
3393##...slt $t0,$t2,$t0
3397##...xori $t0,$t0,0x1
3400#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3404#    and $t2,$t0,$t1
3408#    sw $t2,($sp)
3412:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3412#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3416:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3416#    li $v0,4 # syscall-code for print-string
3420#    syscall
3424:exit:
    # print termination message
3424#    li $v0,4 # syscall-code for print-string
3428#    la $a0,exitString
3432#    syscall

    # terminate execution
3436#    li $v0,10 #syscall-code for "exit"
3440#    syscall

3444:outOfHeapMemory:
3444#    la $a0,heapMemoryMsg
3448#    j exitError
3452:divByZeroError:
3452#    la $a0,divByZeroMsg
3456#    j exitError
3460:strIndexOutOfBounds:
3460#    la $a0,strIndexOutOfBoundsMsg
3464#    j exitError
3468:arrayIndexOutOfBounds:
3468#    la $a0,arrayIndexOutOfBoundsMsg
3472#    j exitError
3476:arraySizeOutOfBounds:
3476#    la $a0,arraySizeOutOfBoundsMsg
3480#    j exitError
3484:nullPtrException:
3484#    la $a0,nullPtrExceptionMsg
3488#    j exitError
3492:badIntegerFormat:
3492#    la $a0,badIntegerFormatMsg
3496#    j exitError
3500:castException:
3500#    la $a0,castExceptionMsg
3504#    j exitError
############## data section ################
    .data
3708:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3724:cur_seg:
    .word 0

3728:lastCharRead:
    .word -2 # -2 => no buffered character
3732:prevHashConstant:
    .word 0x2785173c
3736:gcCount:
    .word 0

3740:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3767:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3790:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3825:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3859:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3892:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3923:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3971:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3992:gcMsg: 
      .asciiz "\nGC!\n"
3998:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4030:nullStr:
    .asciiz "null"
4035:trueString:
    .asciiz "true"
4040:falseString:
    .asciiz "false"
4046:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4065:newlineString:
    .asciiz "\n"
    
    .align 2
4068:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4072:seg0_start:
    .space 0x100000
1052648:seg0_end:
1052648:seg1_start:
    .space 0x100000
2101224:seg1_end:

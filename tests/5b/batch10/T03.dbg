##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
404:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
404#    lw $t0,-8($s2) # get word with hash bits from this
408#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
412#    addu $t0,$t1

416#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
420:mth_equals_Object:
420#    move $t0,$s2 # first pointer (this)
424#    lw $t1,($sp) # second pointer
428#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
429##...subu $at,$t0,$t1
433##...sltiu $t0,$at,1

436#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
440:mth_hashCode_String:
440#    move $t0,$s2 # put this pointer in t0

444#    li $t2,0 # current hash value
448#    lw $t1,-4($t0) # negative of number of characters in string
452#    beq $t1,$zero,done_hashCode_String # if zero length => done
456#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
460#    and $t0,0xfffffffc # adjust for padding
461##...lui $at,65535
465##...ori $at,$at,0xfffc
469##...and $t0,$t0,$at
472#    subu $t1,$t0,$t1 # address at end of string +12
476:loop_hashCode_String:    
476#    sll $t4,$t2,5 # multiply by 32
480#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
484#    lbu $t3,-12($t0) # current character
488#    addu $t2,$t3 # add in current character
492#    addu $t0,1 # go to next character's address
496#    bne $t0,$t1,loop_hashCode_String # loop back if more
500:done_hashCode_String:    

    # push int on stack
500#    move $t0, $t2 # put $t2 in return slot
504#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
508:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
508#    subu $sp,4
512#    sw $ra,($sp)
    
    # get hash value
516#    lw $t2,-12($s2) # vtable address
520#    lw $t0,($t2) # method address
524#    jalr $t0
528#    subu $sp,8 # push result (int in $t0) on stack
532#    sw $s5,4($sp)
536#    sw $t0,($sp)

    # compute print-size of hash value
540#    li $t0, 1
544#    lw $t1, ($sp)
548#    srl $t1,$t1,4
552#    beq $t1,$zero,toString_skip_loop
556:toString_loop_top:
556#    addu $t0,1
560#    srl $t1,$t1,4
564#    bne $t1,$zero,toString_loop_top
568:toString_skip_loop:
568#    subu $sp,8
572#    sw $s5,4($sp)
576#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
580#    lw $t2,-12($s2) # vtable address
584#    move $t0,$t2
588:toString_checkTagBit:
588#    subu $t0,1
592#    lb $t1,($t0)
596#    and $t1,0x80
597##...lui $at,0
601##...ori $at,$at,0x80
605##...and $t1,$t1,$at
608#    beq $t1,$zero,toString_checkTagBit
612#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
616#    subu $sp,8
620#    sw $t1,($sp)
624#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
628#    move $s7,$zero # -4 offset header word
632#    lw $t4,8($sp) # bytes for hash value
636#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
640#    addu $t4,8
644#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
648#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

652#    li $t0,CLASS_String # store string vtable address into ...
656#    sw $t0,-12($s7) # ... -12 offset in object header
660#    lw $t2,-12($s2) # our object's vtable address
664#    lw $t5,4($sp) # number characters in prefix
668#    lw $t1,12($sp) # number of characters in hashcode
672#    addu $t3,$t1,$t5 # number of characters in string ...
676#    addu $t3,1 # ... including the '@' character
680#    subu $t0,$zero,$t3 # store negated length into ...
684#    sw $t0,-4($s7) # ... -4 offset header word
688#    lw $t0,-8($s7) # get -8 offset header-word
692#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
693##...slt $at,$t0,$zero
697##...beq $at,$zero,716
700#    and $t0,0xff # mask off object's hash value ...
701##...lui $at,0
705##...ori $at,$at,0xff
709##...and $t0,$t0,$at
712#    sw $t0,-8($s7) # ... and store back into -8 header-word
716:skipMask_toString:
716#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
720#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
724#    subu $t4,$t2,$t5
728:toString_copyLoop:    
728#    lb $t3,($t4)
732#    and $t3,0x7f # mask off sign bit (in case first word)
733##...lui $at,0
737##...ori $at,$at,0x7f
741##...and $t3,$t3,$at
744#    sb $t3,-8($t0)
748#    addu $t4,1
752#    addu $t0,1
756#    blt $t4,$t2,toString_copyLoop
757##...slt $at,$t4,$t2
761##...bne $at,$zero,728

    # copy the '@' sign
764#    li $t3,'@'
768#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
772#    addu $t2,$t0,$t1 # address of last byte in string to store +8
776#    lw $t3,20($sp) # hash code to print
780:toString_hashCopyLoop:
780#    and $t4,$t3,0xf
784#    srl $t3,4
788#    lb $t4,hexChars($t4)
792#    sb $t4,-8($t2)
796#    subu $t2,$t2,1
800#    bgt $t2,$t0,toString_hashCopyLoop
801##...slt $at,$t0,$t2
805##...bne $at,$zero,780

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
808#    addu $sp,28
812#    lw $ra,($sp)
816#    addu $sp,4
820#    move $t0, $s7 # return string we created
824#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
828:mth_equals_String:
    
    # quick test for obvious false
828#    lw $t0,($sp) # second parameter
832#    beq $t0,$zero,goEsFalse # go return false if null
836#    lw $t1,-12($t0) # vtable pointer
840#    la $t2,CLASS_String # string vtable pointer
844#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
848#    subu $sp,12
852#    sw $ra,8($sp)
856#    sw $s2,4($sp)
860#    sw $t0,($sp)
864#    jal mth_compareTo_String
868#    lw $s2, 4($sp) #restore this pointer and pop parameters
872#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
876#    seq $t0,$t0,$zero
877##...subu $at,$t0,$zero
881##...sltiu $t0,$at,1

    # pop return address and return $t0
884#    lw $ra,($sp)
888#    addu $sp,4


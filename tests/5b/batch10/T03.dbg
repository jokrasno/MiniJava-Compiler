###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
912:mth_readLine_Lib:
    
912#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
916#    sw $ra, 4($sp) # save $ra
920#    move $t1,$sp # save "original" sp

924:  doRead:

    # read the character
924#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
928#    subu $t2,$v0,13
932#    bne $t2,$zero,notReturnRL
936#    jal readLogicalChar
940#    subu $t2,$v0,10 # check for newline
944#    beq $t2,$zero,foundNewLine
948#    sw $v0,lastCharRead # push back character into queue
952#    j foundNewLine # go process the line

956:  notReturnRL:

    # at this point, $v0 has our character

956#    subu $t0,$v0,10
960#    beq $t0,$zero,foundNewLine
964#    blt $v0,$zero,foundEof
965##...slt $at,$v0,$zero
969##...bne $at,$zero,984

    # we have a character, so push it onto stack
972#    subu $sp,$sp,4
976#    sw $v0,($sp)

    # loop back up to get next character
980#    j doRead

984:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
984#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
988#    li $s7, 0 # return-value: null
992#    j rlReturn # return

996:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
996#    subu $t0,$t1,$sp # number of chars we read (times 4)
1000#    srl $s6,$t0,2 # number of words on stack with chars
1004#    subu $sp,$sp,4 # push char-count ...
1008#    sw $s6,($sp) # ... onto stack
1012#    addu $t2,$t0,5 # GC tag, incl. for count-word
1016#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1020#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1024#    srl $s6,$s6,2  # data words in object
1028#    move $s7,$zero # object words in object
1032#    jal newObject  # allocate space
    
    # store header words
1036#    la $t0,CLASS_String
1040#    sw $t0,-12($s7)# store class tag (String) into object
1044#    lw $t2,4($sp) # char-count
1048#    sll $t1,$t2,2 # 4 times number of chars
1052#    subu $t2,$zero,$t2 # negative of char-count
1056#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1060#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1064#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1065##...slt $at,$t0,$zero
1069##...beq $at,$zero,1088
1072#    and $t0,0xff # mask off object's hash value ...
1073##...lui $at,0
1077##...ori $at,$at,0xff
1081##...and $t0,$t0,$at
1084#    sw $t0,-8($s7) # ... and store back into -8 header-word
1088:  skipMask_readLine:

1088#    sll $t0,$t0,2 # data bytes in object
1092#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1096#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1100#    addu $sp,$sp,8 # pop redundant object-pointer and count
1104#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1108#    beq $sp,$t1,rlReturn
1112:  charCopyLoop:
1112#    lw $t2,($sp)
1116#    sb $t2,-9($t0)
1120#    addu $sp,$sp,4
1124#    subu $t0,$t0,1
1128#    bne $sp,$t1,charCopyLoop
1132:  rlReturn:

1132#    lw $ra, 4($sp)
1136#    addu $sp, 8   # pop $ra and pointless word off stack
1140#    move $t0, $s7 # return string we allocated in $s7
1144#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1148:mth_readInt_Lib:

    # save $ra by pushing onto stack
1148#    subu $sp,$sp,4
1152#    sw $ra,($sp)

1156:  riSkipWhiteLoop:
    # read a character
1156#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1160#    subu $t0,$v0,32
1164#    bgt $t0,$zero,nonWhite
1165##...slt $at,$zero,$t0
1169##...bne $at,$zero,1212
1172#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1176#    subu $t0,$v0,10
1180#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1184#    subu $t0,$v0,9
1188#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1192#    subu $t0,$v0,13
1196#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1200#    subu $t0,$v0,12
1204#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1208#    j badIntegerFormat # illegal integer char: abort program

1212:  nonWhite:
1212#    subu $t0,$v0,'-'
1216#    li $t4,1 # final multiplier
1220#    bne $t0,$zero,helpReadInt # go read
1224#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1228#    jal readLogicalChar

1232:  helpReadInt:
1232#    li $t2,10
1236#    subu $t1,$v0,'0' # convert digit to 0-9 value
1240#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1241##...sltu $at,$t1,$t2
1245##...beq $at,$zero,3492
1248#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1252:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1252#    jal readLogicalChar # read next character
1256#    subu $t1,$v0,'0' # convert digit to 0-9 value
1260#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1261##...sltu $at,$t1,$t2
1265##...beq $at,$zero,1284

1268#    mul $t3,$t3,$t2 # multiply old value by 10
1269##...mult $t3,$t2
1273##...mflo $t3
1276#    addu $t3,$t3,$t1 # add in value of new digit
1280#    j digitLoop

1284:  doneDigitLoop:

    # "push back" unused character into queue
1284#    sw $v0,lastCharRead

    # restore return address
1288#    lw $ra,($sp)
1292#    addu $sp, 4

    # multiply by sign and put return value in $t0
1296#    mult $t3,$t4 # multiply to account for poss. minus sign
1300#    mflo $t3
1304#    move $t0, $t3
    
    # return
1308#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
9692:divide:
    # get parameters; abort if divisor zero
9692#    lw $t0,($sp)
9696#    lw $t1,8($sp)
9700#    beq $t0,$zero,divByZeroError

# accesses a character in a string, as in Java
# - parameters:
#   - ($sp) - the index, n
#   - 4($sp) - GC tag
#   - 8($sp) - old this pointer
#   - $s2    - this pointer
# - returns:
#   - $t0 - the character found.
########################################################
8360:mth_charAt_String:
    # get string
8360#    move $t0,$s2

    # check that index is in bounds
8364#    lw $t1,-4($t0) # negative of # data words in string
8368#    subu $t3,$zero,$t1 # # chars in string
8372#    lw $t2,($sp) # index
8376#    bgeu $t2,$t3,strIndexOutOfBounds
8377##...sltu $at,$t2,$t3
8381##...beq $at,$zero,9868

    # access element
8384#    lw $t1,-8($t0) # # data words in object
8388#    sll $t1,$t1,2 # - byte-offset from end of chars
8392#    subu $t1,$t2,$t1 # - address of first char in string, offset by 8
8396#    addu $t0,$t0,$t1 # - address of our char, offset by 8
8400#    lb $t0,-8($t0) # our char

    # return
8404#    jr $ra

########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
8408:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
8408#    subu $sp,$sp,8
8412#    sw $ra,4($sp)

    # save current sp
8416#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
8420#    li $t3,10

    # get argument, negate if negative
8424#    lw $t1,8($sp)
8428#    bge $t1,$zero,itsNonNegLoop
8429##...slt $at,$t1,$zero
8433##...beq $at,$zero,8440
8436#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
8440:  itsNonNegLoop:
8440#    divu $t1,$t3
8444#    mflo $t1 # quotient
8448#    mfhi $t4 # remainder
8452#    addu $t4,$t4,'0' # turn remainder into digit
8456#    subu $sp,$sp,4
8460#    sw $t4,($sp) # push digit onto stack
8464#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
8468#    lw $t4,8($t0)
8472#    bge $t4,$zero,itsSkipNeg
8473##...slt $at,$t4,$zero
8477##...beq $at,$zero,8492
8480#    li $t4,'-'
8484#    subu $sp,$sp,4
8488#    sw $t4,($sp)
8492:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
8492#    subu $s6,$t0,$sp
8496#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
8500#    sw $t3,($t0)
8504#    srl $s6,$s6,2
8508#    subu $sp,$sp,4
8512#    sw $s6,($sp)
    
    # allocate memory
8516#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
8520#    srl $s6,$s6,2
8524#    move $s7,$zero # no "object" words in object
8528#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
8532#    lw $t0,4($sp)
8536#    addu $sp,$sp,8

    # store "String" tag into class field
8540#    subu $s7,$s7,8 # address of header-1 word
8544#    la $t1,CLASS_String
8548#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
8552#    lw $t4,($s7) # # data words in source string
8556#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
8557##...slt $at,$t4,$zero
8561##...beq $at,$zero,8580
8564#    and $t4,0xff # mask off object's hash value ...
8565##...lui $at,0
8569##...ori $at,$at,0xff
8573##...and $t4,$t4,$at
8576#    sw $t4,($s7) # ... and store back into -8 header-word
8580:skipMask_intToString:
    
    # store negative of char-count into header-2 word
8580#    subu $t0,$zero,$t0
8584#    sw $t0,4($s7)

8588#    lw $t1,($s7) # number of data words in string
8592#    sll $t1,$t1,2 # number data bytes in string
8596#    subu $t1,$s7,$t1 # first location to store chars in string
8600#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
8604:  itsLoop:
8604#    lw $t2,($sp)
8608#    addu $sp,$sp,4
8612#    sb $t2,($t1)
8616#    addu $t1,$t1,1
8620#    bne $t1,$t0,itsLoop

    ####################################################
    # At this point
    # - ($t0+15)&0xfffffffe is our return value
    # - ($sp) contains garbage (old GC tag)
    # - 4($sp) contains return address
    ####################################################

    # adjust stack, restore return address; return
8624#    lw $ra,4($sp)
8628#    addu $sp,$sp,8
8632#    addu $t0,$t0,15
8636#    and $t0,$t0,0xfffffffc
8637##...lui $at,65535
8641##...ori $at,$at,0xfffc
8645##...and $t0,$t0,$at
8648#    jr $ra

########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
8652:mth_intToChar_Lib:
    # save return address
8652#    subu $sp,$sp,4
8656#    sw $ra,($sp)

    # allocate object
8660#    li $s6,2
8664#    move $s7,$zero
8668#    jal newObject

    # get n from string.
8672#    lw $t1,8($sp)

    # store "String" tag into class field
8676#    la $t0,CLASS_String
8680#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
8684#    lw $t4,-8($s7) # # data words in source string
8688#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
8689##...slt $at,$t4,$zero
8693##...beq $at,$zero,8712
8696#    and $t4,0xff # mask off object's hash value ...
8697##...lui $at,0
8701##...ori $at,$at,0xff
8705##...and $t4,$t4,$at
8708#    sw $t4,-8($s7) # ... and store back into -8 header-word
8712:  skipMask_intToChar:

    # store data in string
8712#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
8716#    li $t0,-1
8720#    sw $t0,-4($s7)

    # we're returning $s7
8724#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
8728#    lw $ra,4($sp)
8732#    addu $sp,$sp,8

    # return
8736#    jr $ra

########################################################
# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
8740:mth_compareTo_String:
    # get string pointers and check parameter for null
8740#    lw $t0,($sp) # second string
8744#    beq $t0,$zero,nullPtrException
8748#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
8752#    lw $t2,-4($t0) # negative length of second string
8756#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
8760#    slt $t4,$t3,$t2
8764#    slt $t5,$t2,$t3
8768#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
8772#    lw $t2,-8($t0) # # data words in second string
8776#    lw $t3,-8($t1) # # data words in first string
8780#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
8784#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
8788#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
8792#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
8796#    beq $zero,$t5,skipStrCmpLenzz
8800#    move $t2,$t3
8804:  skipStrCmpLenzz:
8804#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
8808:  cmpLoopzz:
8808#    lw $t3,-8($t1) # word from str2
8812#    lw $t4,-8($t0) # word from str1
8816#    bne $t3,$t4,cmpNotEqualzz
8820#    addu $t1,$t1,4
8824#    addu $t0,$t0,4
8828#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
8832#    j cmpHitLimitzz

8836:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
8836#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
8840#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
8844#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
8848:  cmpHitLimitzz:
8848#    move $t0, $t5 # store return value
8852#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
8856:readLogicalChar:

    # check if we already have a character
8856#    lw $v0,lastCharRead
8860#    li $t0,-2
8864#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
8868#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
8872#    jr $ra # return
    
8876:  doReadCh:
    # we need to actually read a character: read and return
8876#    li $v0,12 # use system call to read a character
8880#    syscall
8884#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
8888:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
8888#    blt $s7,$zero arraySizeOutOfBounds
8889##...slt $at,$s7,$zero
8893##...bne $at,$zero,9884

    # mark the fact that we have not yet GC'd for this allocation
8896#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

8900:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
8900#    addu $t0,$s6,$s7
8904#    sll $t0,$t0,2
8908#    addu $t0,$t0,8 # amount of memory needed
8912#    addu $t1,$t0,$s3
8916#    bgtu $t1,$s4,doGC
8917##...sltu $at,$s4,$t1
8921##...bne $at,$zero,9044

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
8924#    move $t2,$s3
8928:  zeroObjLoop:
8928#    sw $zero,($s3)
8932#    lw $zero,($s3)

8936#    addu $s3,4
8940#    bltu $s3,$t1,zeroObjLoop
8941##...sltu $at,$s3,$t1
8945##...bne $at,$zero,8928

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
8948#    sll $t0,$s7,2    # number of post-header bytes
8952#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
8956#    li $t2,255
8960#    bgeu $s6,$t2 firstHeaderLarge
8961##...sltu $at,$s6,$t2
8965##...beq $at,$zero,9012
8968#    lw $t1,prevHashConstant
8972#    addu $t1,0x12b68fd2
8973##...lui $at,4791
8977##...addiu $at,$at,-28718
8981##...addu $t1,$at,$t1
8984#    sw $t1,prevHashConstant # update hash constant
8988#    or $t1,0x80000000 # set top bit
8989##...lui $at,32768
8993##...or $t1,$at,$t1
8996#    and $t1,0xffffff00 # clear low bit
8997##...lui $at,65535
9001##...ori $at,$at,0xff00
9005##...and $t1,$t1,$at
9008#    or $s6,$t1
9012:firstHeaderLarge:
9012#    sw $s6,-8($t0) # store header-1 value
9016#    lw $zero,-8($t0)

    # store second header-value
9020#    sw $s7,-4($t0)   # second header-word
9024#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
9028#    move $s7,$t0
9032#    subu $sp,$sp,4
9036#    sw $t0,($sp)

9040#    jr $ra
    
9044:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
9044#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
9048#    lw $t5,gcCount
9052#    addu $t5,1
9056#    sw $t5,gcCount

    # save $s2 (our only rooted register) on the stack
    # so that the garbage collector processes it
9060#    subu $sp,$sp,4
9064#    sw $s2,($sp)

    # set $s3 to the address of the new segment and the
    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
9068#    lw $t0,cur_seg
9072#    move $t7,$s4
9076#    la $t6,seg1_start
9077##...lui $t6,16
9081##...addiu $t6,$t6,10816
9084#    la $s3,seg0_start
9088#    la $s4,seg0_end
9089##...lui $s4,16
9093##...addiu $s4,$s4,10816
9096#    sw $zero,cur_seg
9100#    bne $t0,$zero,skipGc1
9104#    la $t6,seg0_start
9108#    la $s3,seg1_start
9109##...lui $s3,16
9113##...addiu $s3,$s3,10816
9116#    la $s4,seg1_end
9117##...lui $s4,32
9121##...addiu $s4,$s4,10816
9124#    sw $s5,cur_seg
9128:  skipGc1:
9128#    li $t5,0x80000000
9132#    lw $t0,stack_bottom
9136#    subu $t0,4


    ###############################################################
    # at this point:
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first address of the target space
    # - $s4 contains the limit address of the target space
    # - cur_seg has been updated to refer to the target space
    # - $t0 contains the address of the deepest stack element
    # - $sp contains the address of the top stack element
    # - $s2 is available for use, having been pushed onto the stack
    # - $t5 contains the value 0x80000000
    ###############################################################

    ###### begin outer loop to copy all stack-direct objects ######

9140:  gcStackCopyLoop:
9140#    lw $t1,($t0) # current stack element

    # test if we have a GC tag
9144#    sll $t2,$t1,31 # zero iff low bit was zero
9148#    bne $t2,$zero,gcBump # go skip data values if low bit not zero

    # bump stack-address pointer
9152#    subu $t0,$t0,4

    # if value is out of range (which includes null=0), and is
    # therefore does not refer to an object on the heap, just go
    # loop back and do the next one
9156#    bleu $t1,$t6,gcTestIterDone1
9157##...sltu $at,$t6,$t1
9161##...beq $at,$zero,9324
9164#    bgtu $t1,$t7,gcTestIterDone1
9165##...sltu $at,$t7,$t1
9169##...bne $at,$zero,9324

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
9172#    lw $t2,-8($t1) # possible forwarding tag

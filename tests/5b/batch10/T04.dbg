    # perform division
9704#    div $t1,$t0
9708#    mflo $t0

    # store result, adjust stack and return
9712#    addu $sp,$sp,8 # adjust stack
9716#    sw $t0,($sp) # store result
9720#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################

    # lower limit, and if we're < the higher limit
9796#    lw $t2,-12($t2) # vtable address
9800#    sge $t0,$t2,$t0 # are we >= the lower limit?
9801##...slt $t0,$t2,$t0
9805##...xori $t0,$t0,0x1
9808#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
9812#    and $t2,$t0,$t1
9816#    sw $t2,($sp)
9820:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
9820#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

9824:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
9824#    li $v0,4 # syscall-code for print-string
9828#    syscall
9832:exit:
    # print termination message
9832#    li $v0,4 # syscall-code for print-string
9836#    la $a0,exitString
9840#    syscall

    # terminate execution
9844#    li $v0,10 #syscall-code for "exit"
9848#    syscall

9852:outOfHeapMemory:
9852#    la $a0,heapMemoryMsg
9856#    j exitError
9860:divByZeroError:
9860#    la $a0,divByZeroMsg
9864#    j exitError
9868:strIndexOutOfBounds:
9868#    la $a0,strIndexOutOfBoundsMsg
9872#    j exitError
9876:arrayIndexOutOfBounds:
9876#    la $a0,arrayIndexOutOfBoundsMsg
9880#    j exitError
9884:arraySizeOutOfBounds:
9884#    la $a0,arraySizeOutOfBoundsMsg
9888#    j exitError
9892:nullPtrException:
9892#    la $a0,nullPtrExceptionMsg
9896#    j exitError
9900:badIntegerFormat:
9900#    la $a0,badIntegerFormatMsg
9904#    j exitError
9908:castException:
9908#    la $a0,castExceptionMsg
9912#    j exitError
############## data section ################
    .data
10452:hexChars:
    .ascii "0123456789abcdef"
    .align 2
10468:cur_seg:
    .word 0

10472:lastCharRead:
    .word -2 # -2 => no buffered character
10476:prevHashConstant:
    .word 0x2785173c
10480:gcCount:
    .word 0

10484:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
10511:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
10534:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
10569:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
10603:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
10636:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
10667:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
10715:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
10736:gcMsg: 
      .asciiz "\nGC!\n"
10742:gcCountMsg: 
      .asciiz "Number of garbage collections: "

10774:nullStr:
    .asciiz "null"
10779:trueString:
    .asciiz "true"
10784:falseString:
    .asciiz "false"
10790:exitString:
    .ascii "Program terminated."
    #### "falls through" here
10809:newlineString:
    .asciiz "\n"
    
    .align 2
10812:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

10816:seg0_start:
    .space 0x100000
1059392:seg0_end:
1059392:seg1_start:
    .space 0x100000
2107968:seg1_end:

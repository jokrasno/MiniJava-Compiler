7580#    beq $t0,$zero,riSkipWhiteLoop # start over if space
7584#    subu $t0,$v0,10
7588#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
7592#    subu $t0,$v0,9
7596#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
7600#    subu $t0,$v0,13
7604#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
7608#    subu $t0,$v0,12
7612#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
7616#    j badIntegerFormat # illegal integer char: abort program

7620:  nonWhite:
7620#    subu $t0,$v0,'-'
7624#    li $t4,1 # final multiplier
7628#    bne $t0,$zero,helpReadInt # go read

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
6812:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
6812#    lw $t0,-8($s2) # get word with hash bits from this
6816#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
6820#    addu $t0,$t1

6824#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
6828:mth_equals_Object:
6828#    move $t0,$s2 # first pointer (this)
6832#    lw $t1,($sp) # second pointer
6836#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
6837##...subu $at,$t0,$t1
6841##...sltiu $t0,$at,1

6844#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
6848:mth_hashCode_String:
6848#    move $t0,$s2 # put this pointer in t0

6852#    li $t2,0 # current hash value
6856#    lw $t1,-4($t0) # negative of number of characters in string
6860#    beq $t1,$zero,done_hashCode_String # if zero length => done
6864#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
6868#    and $t0,0xfffffffc # adjust for padding
6869##...lui $at,65535
6873##...ori $at,$at,0xfffc
6877##...and $t0,$t0,$at
6880#    subu $t1,$t0,$t1 # address at end of string +12
6884:loop_hashCode_String:    
6884#    sll $t4,$t2,5 # multiply by 32
6888#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
6892#    lbu $t3,-12($t0) # current character
6896#    addu $t2,$t3 # add in current character
6900#    addu $t0,1 # go to next character's address
6904#    bne $t0,$t1,loop_hashCode_String # loop back if more
6908:done_hashCode_String:    

    # push int on stack
6908#    move $t0, $t2 # put $t2 in return slot
6912#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
6916:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
6916#    subu $sp,4
6920#    sw $ra,($sp)
    
    # get hash value
6924#    lw $t2,-12($s2) # vtable address
6928#    lw $t0,($t2) # method address
6932#    jalr $t0
6936#    subu $sp,8 # push result (int in $t0) on stack
6940#    sw $s5,4($sp)
6944#    sw $t0,($sp)

    # compute print-size of hash value
6948#    li $t0, 1
6952#    lw $t1, ($sp)
6956#    srl $t1,$t1,4
6960#    beq $t1,$zero,toString_skip_loop
6964:toString_loop_top:
6964#    addu $t0,1
6968#    srl $t1,$t1,4
6972#    bne $t1,$zero,toString_loop_top
6976:toString_skip_loop:
6976#    subu $sp,8
6980#    sw $s5,4($sp)
6984#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
6988#    lw $t2,-12($s2) # vtable address
6992#    move $t0,$t2
6996:toString_checkTagBit:
6996#    subu $t0,1
7000#    lb $t1,($t0)
7004#    and $t1,0x80
7005##...lui $at,0
7009##...ori $at,$at,0x80
7013##...and $t1,$t1,$at
7016#    beq $t1,$zero,toString_checkTagBit
7020#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
7024#    subu $sp,8
7028#    sw $t1,($sp)
7032#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
7036#    move $s7,$zero # -4 offset header word
7040#    lw $t4,8($sp) # bytes for hash value
7044#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
7048#    addu $t4,8
7052#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
7056#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

7060#    li $t0,CLASS_String # store string vtable address into ...
7064#    sw $t0,-12($s7) # ... -12 offset in object header
7068#    lw $t2,-12($s2) # our object's vtable address
7072#    lw $t5,4($sp) # number characters in prefix
7076#    lw $t1,12($sp) # number of characters in hashcode
7080#    addu $t3,$t1,$t5 # number of characters in string ...
7084#    addu $t3,1 # ... including the '@' character
7088#    subu $t0,$zero,$t3 # store negated length into ...
7092#    sw $t0,-4($s7) # ... -4 offset header word
7096#    lw $t0,-8($s7) # get -8 offset header-word
7100#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
7101##...slt $at,$t0,$zero
7105##...beq $at,$zero,7124
7108#    and $t0,0xff # mask off object's hash value ...
7109##...lui $at,0
7113##...ori $at,$at,0xff
7117##...and $t0,$t0,$at
7120#    sw $t0,-8($s7) # ... and store back into -8 header-word
7124:skipMask_toString:
7124#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
7128#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
7132#    subu $t4,$t2,$t5
7136:toString_copyLoop:    
7136#    lb $t3,($t4)
7140#    and $t3,0x7f # mask off sign bit (in case first word)
7141##...lui $at,0
7145##...ori $at,$at,0x7f
7149##...and $t3,$t3,$at
7152#    sb $t3,-8($t0)
7156#    addu $t4,1
7160#    addu $t0,1
7164#    blt $t4,$t2,toString_copyLoop
7165##...slt $at,$t4,$t2
7169##...bne $at,$zero,7136

    # copy the '@' sign
7172#    li $t3,'@'
7176#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
7180#    addu $t2,$t0,$t1 # address of last byte in string to store +8
7184#    lw $t3,20($sp) # hash code to print
7188:toString_hashCopyLoop:
7188#    and $t4,$t3,0xf
7192#    srl $t3,4
7196#    lb $t4,hexChars($t4)
7200#    sb $t4,-8($t2)
7204#    subu $t2,$t2,1
7208#    bgt $t2,$t0,toString_hashCopyLoop
7209##...slt $at,$t0,$t2
7213##...bne $at,$zero,7188

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
7216#    addu $sp,28
7220#    lw $ra,($sp)
7224#    addu $sp,4
7228#    move $t0, $s7 # return string we created
7232#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
7236:mth_equals_String:
    
    # quick test for obvious false
7236#    lw $t0,($sp) # second parameter
7240#    beq $t0,$zero,goEsFalse # go return false if null
7244#    lw $t1,-12($t0) # vtable pointer
7248#    la $t2,CLASS_String # string vtable pointer
7252#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
7256#    subu $sp,12
7260#    sw $ra,8($sp)
7264#    sw $s2,4($sp)
7268#    sw $t0,($sp)
7272#    jal mth_compareTo_String
7276#    lw $s2, 4($sp) #restore this pointer and pop parameters
7280#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
7284#    seq $t0,$t0,$zero
7285##...subu $at,$t0,$zero
7289##...sltiu $t0,$at,1

    # pop return address and return $t0
7292#    lw $ra,($sp)
7296#    addu $sp,4

7300#    jr $ra # return
    
7304:goEsFalse:
    # put 0 in $t0 and return
7304#    li $t0, 0
7308#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
7312:mth_toString_String:
    #we are a string, so return this.
7312#    move $t0, $s2
7316#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
7320:mth_readLine_Lib:
    
7320#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
7324#    sw $ra, 4($sp) # save $ra
7328#    move $t1,$sp # save "original" sp

7332:  doRead:

    # read the character
7332#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
7336#    subu $t2,$v0,13
7340#    bne $t2,$zero,notReturnRL
7344#    jal readLogicalChar
7348#    subu $t2,$v0,10 # check for newline
7352#    beq $t2,$zero,foundNewLine
7356#    sw $v0,lastCharRead # push back character into queue
7360#    j foundNewLine # go process the line

7364:  notReturnRL:

    # at this point, $v0 has our character

7364#    subu $t0,$v0,10
7368#    beq $t0,$zero,foundNewLine
7372#    blt $v0,$zero,foundEof
7373##...slt $at,$v0,$zero
7377##...bne $at,$zero,7392

    # we have a character, so push it onto stack
7380#    subu $sp,$sp,4
7384#    sw $v0,($sp)

    # loop back up to get next character
7388#    j doRead

7392:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
7392#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
7396#    li $s7, 0 # return-value: null
7400#    j rlReturn # return

7404:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
7404#    subu $t0,$t1,$sp # number of chars we read (times 4)
7408#    srl $s6,$t0,2 # number of words on stack with chars
7412#    subu $sp,$sp,4 # push char-count ...
7416#    sw $s6,($sp) # ... onto stack
7420#    addu $t2,$t0,5 # GC tag, incl. for count-word
7424#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
7428#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
7432#    srl $s6,$s6,2  # data words in object
7436#    move $s7,$zero # object words in object
7440#    jal newObject  # allocate space
    
    # store header words
7444#    la $t0,CLASS_String

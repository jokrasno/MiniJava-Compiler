    # - $t2 contains the value 10

2632#    jal readLogicalChar # read next character
2636#    subu $t1,$v0,'0' # convert digit to 0-9 value
2640#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2641##...sltu $at,$t1,$t2
2645##...beq $at,$zero,2664

2648#    mul $t3,$t3,$t2 # multiply old value by 10
2649##...mult $t3,$t2
2653##...mflo $t3
2656#    addu $t3,$t3,$t1 # add in value of new digit
2660#    j digitLoop

2664:  doneDigitLoop:

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2528:mth_readInt_Lib:

    # save $ra by pushing onto stack
2528#    subu $sp,$sp,4
2532#    sw $ra,($sp)

2536:  riSkipWhiteLoop:
    # read a character
2536#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2540#    subu $t0,$v0,32
2544#    bgt $t0,$zero,nonWhite
2545##...slt $at,$zero,$t0
2549##...bne $at,$zero,2592
2552#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2556#    subu $t0,$v0,10
2560#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2564#    subu $t0,$v0,9
2568#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2572#    subu $t0,$v0,13
2576#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2580#    subu $t0,$v0,12
2584#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2588#    j badIntegerFormat # illegal integer char: abort program

2592:  nonWhite:
2592#    subu $t0,$v0,'-'
2596#    li $t4,1 # final multiplier
2600#    bne $t0,$zero,helpReadInt # go read
2604#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2608#    jal readLogicalChar

2612:  helpReadInt:
2612#    li $t2,10

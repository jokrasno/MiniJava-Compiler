
    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
4416:  gcNotDataArray:
4416#    lw $t3,-4($t2) # # object words (negative treated as zero)
4420#    bge $t3,$zero,gcH2Neg2
4421##...slt $at,$t3,$zero
4425##...beq $at,$zero,4432
4428#    move $t3,$zero
4432:  gcH2Neg2:
4432#    sll $t3,$t3,2 # # object bytes
4436#    move $t0,$t2 # address of first pointer in object

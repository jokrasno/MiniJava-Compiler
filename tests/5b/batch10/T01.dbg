########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4636:vm_init:

    # mark bottom of stack
4636#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4640#    move $s2,$zero

    #set up the "five" register
4644#    li $s5,5

4648#    la $s3,seg0_start
4652#    la $s4,seg0_end
4653##...lui $s4,16
4657##...addiu $s4,$s4,5460
    
    # return
4660#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4664:divide:
    # get parameters; abort if divisor zero
4664#    lw $t0,($sp)
4668#    lw $t1,8($sp)
4672#    beq $t0,$zero,divByZeroError
    
    # perform division
4676#    div $t1,$t0
4680#    mflo $t0

    # store result, adjust stack and return
4684#    addu $sp,$sp,8 # adjust stack
4688#    sw $t0,($sp) # store result
4692#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4696:remainder:
    # get parameters; abort if divisor zero
4696#    lw $t0,($sp)
4700#    lw $t1,8($sp)
4704#    beq $t0,$zero,divByZeroError
    
    # perform division
4708#    div $t1,$t0
4712#    mfhi $t0

    # store result, adjust stack and return
4716#    addu $sp,$sp,8 # adjust stack
4720#    sw $t0,($sp) # store result
4724#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4728:checkCast:
    # get object, allow immediately if null
4728#    lw $t2,($sp)
4732#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4736#    lw $t2,-12($t2) # vtable address
4740#    bge $t2,$t1,castException
4741##...slt $at,$t2,$t1
4745##...beq $at,$zero,4880
4748#    blt $t2,$t0,castException
4749##...slt $at,$t2,$t0
4753##...bne $at,$zero,4880
    
    # return, leaving object unchanged on stack
4756:  checkCastReturn:    
4756#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4760:instanceOf:
    # get object, go return false if null
4760#    lw $t2,($sp)
4764#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4768#    lw $t2,-12($t2) # vtable address
4772#    sge $t0,$t2,$t0 # are we >= the lower limit?
4773##...slt $t0,$t2,$t0
4777##...xori $t0,$t0,0x1
4780#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4784#    and $t2,$t0,$t1
4788#    sw $t2,($sp)
4792:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4792#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4796:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4796#    li $v0,4 # syscall-code for print-string
4800#    syscall
4804:exit:
    # print termination message
4804#    li $v0,4 # syscall-code for print-string
4808#    la $a0,exitString
4812#    syscall

    # terminate execution
4816#    li $v0,10 #syscall-code for "exit"
4820#    syscall

4824:outOfHeapMemory:
4824#    la $a0,heapMemoryMsg
4828#    j exitError
4832:divByZeroError:
4832#    la $a0,divByZeroMsg
4836#    j exitError
4840:strIndexOutOfBounds:
4840#    la $a0,strIndexOutOfBoundsMsg
4844#    j exitError
4848:arrayIndexOutOfBounds:
4848#    la $a0,arrayIndexOutOfBoundsMsg
4852#    j exitError
4856:arraySizeOutOfBounds:
4856#    la $a0,arraySizeOutOfBoundsMsg
4860#    j exitError
4864:nullPtrException:
4864#    la $a0,nullPtrExceptionMsg
4868#    j exitError
4872:badIntegerFormat:
4872#    la $a0,badIntegerFormatMsg
4876#    j exitError
4880:castException:
4880#    la $a0,castExceptionMsg
4884#    j exitError
############## data section ################
    .data
5096:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5112:cur_seg:
    .word 0

5116:lastCharRead:
    .word -2 # -2 => no buffered character
5120:prevHashConstant:
    .word 0x2785173c
5124:gcCount:
    .word 0

5128:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5155:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5178:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5213:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5247:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5280:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5311:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5359:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5380:gcMsg: 
      .asciiz "\nGC!\n"
5386:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5418:nullStr:
    .asciiz "null"
5423:trueString:
    .asciiz "true"
5428:falseString:
    .asciiz "false"
5434:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5453:newlineString:
    .asciiz "\n"
    
    .align 2
5456:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5460:seg0_start:
    .space 0x100000
1054036:seg0_end:
1054036:seg1_start:
    .space 0x100000
2102612:seg1_end:

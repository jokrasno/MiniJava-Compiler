    # set up the forwarding pointer
4264#    sw $zero,-8($t1) # 0 in first header-slot
4268#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
4272#    sw $t2,4($t0)
4276#    lw $zero,-8($t2)
4280#    lw $zero,-4($t2)

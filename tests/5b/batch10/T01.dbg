4341##...slt $at,$t2,$zero
4345##...beq $at,$zero,4360
4348#    and $t2,0xff # mask off hash bits
4349##...lui $at,0
4353##...ori $at,$at,0xff
4357##...and $t2,$t2,$at
4360:gcSkip4a:    
4360#    sll $t2,$t2,2 # # data bytes
4364#    addu $t2,$t2,8 # to skip header words
4368#    addu $t2,$t0,$t2 # pointer to new object
4372#    lw $t3,-8($t2) # word to swap
4376#    sw $t1,-8($t2) # store header word
4380#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
4384#    lw $t1,-12($t2) # vtable pointer

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1784:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1784#    lw $t0,-8($s2) # get word with hash bits from this
1788#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1792#    addu $t0,$t1

1796#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1800:mth_equals_Object:
1800#    move $t0,$s2 # first pointer (this)
1804#    lw $t1,($sp) # second pointer
1808#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1809##...subu $at,$t0,$t1
1813##...sltiu $t0,$at,1

1816#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1820:mth_hashCode_String:
1820#    move $t0,$s2 # put this pointer in t0

1824#    li $t2,0 # current hash value
1828#    lw $t1,-4($t0) # negative of number of characters in string
1832#    beq $t1,$zero,done_hashCode_String # if zero length => done
1836#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1840#    and $t0,0xfffffffc # adjust for padding
1841##...lui $at,65535
1845##...ori $at,$at,0xfffc
1849##...and $t0,$t0,$at
1852#    subu $t1,$t0,$t1 # address at end of string +12
1856:loop_hashCode_String:    
1856#    sll $t4,$t2,5 # multiply by 32
1860#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1864#    lbu $t3,-12($t0) # current character
1868#    addu $t2,$t3 # add in current character
1872#    addu $t0,1 # go to next character's address
1876#    bne $t0,$t1,loop_hashCode_String # loop back if more
1880:done_hashCode_String:    

    # push int on stack
1880#    move $t0, $t2 # put $t2 in return slot
1884#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1888:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1888#    subu $sp,4
1892#    sw $ra,($sp)
    
    # get hash value
1896#    lw $t2,-12($s2) # vtable address
1900#    lw $t0,($t2) # method address
1904#    jalr $t0
1908#    subu $sp,8 # push result (int in $t0) on stack
1912#    sw $s5,4($sp)
1916#    sw $t0,($sp)

    # compute print-size of hash value
1920#    li $t0, 1
1924#    lw $t1, ($sp)
1928#    srl $t1,$t1,4
1932#    beq $t1,$zero,toString_skip_loop
1936:toString_loop_top:
1936#    addu $t0,1
1940#    srl $t1,$t1,4
1944#    bne $t1,$zero,toString_loop_top
1948:toString_skip_loop:
1948#    subu $sp,8
1952#    sw $s5,4($sp)
1956#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1960#    lw $t2,-12($s2) # vtable address
1964#    move $t0,$t2
1968:toString_checkTagBit:
1968#    subu $t0,1
1972#    lb $t1,($t0)
1976#    and $t1,0x80
1977##...lui $at,0
1981##...ori $at,$at,0x80
1985##...and $t1,$t1,$at
1988#    beq $t1,$zero,toString_checkTagBit
1992#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1996#    subu $sp,8
2000#    sw $t1,($sp)
2004#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
2008#    move $s7,$zero # -4 offset header word
2012#    lw $t4,8($sp) # bytes for hash value
2016#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
2020#    addu $t4,8
2024#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
2028#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

2032#    li $t0,CLASS_String # store string vtable address into ...
2036#    sw $t0,-12($s7) # ... -12 offset in object header
2040#    lw $t2,-12($s2) # our object's vtable address
2044#    lw $t5,4($sp) # number characters in prefix
2048#    lw $t1,12($sp) # number of characters in hashcode
2052#    addu $t3,$t1,$t5 # number of characters in string ...
2056#    addu $t3,1 # ... including the '@' character
2060#    subu $t0,$zero,$t3 # store negated length into ...
2064#    sw $t0,-4($s7) # ... -4 offset header word
2068#    lw $t0,-8($s7) # get -8 offset header-word
2072#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2073##...slt $at,$t0,$zero
2077##...beq $at,$zero,2096
2080#    and $t0,0xff # mask off object's hash value ...
2081##...lui $at,0
2085##...ori $at,$at,0xff
2089##...and $t0,$t0,$at
2092#    sw $t0,-8($s7) # ... and store back into -8 header-word
2096:skipMask_toString:
2096#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2100#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2104#    subu $t4,$t2,$t5
2108:toString_copyLoop:    
2108#    lb $t3,($t4)
2112#    and $t3,0x7f # mask off sign bit (in case first word)
2113##...lui $at,0
2117##...ori $at,$at,0x7f
2121##...and $t3,$t3,$at
2124#    sb $t3,-8($t0)
2128#    addu $t4,1
2132#    addu $t0,1
2136#    blt $t4,$t2,toString_copyLoop
2137##...slt $at,$t4,$t2
2141##...bne $at,$zero,2108

    # copy the '@' sign
2144#    li $t3,'@'
2148#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2152#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2156#    lw $t3,20($sp) # hash code to print
2160:toString_hashCopyLoop:
2160#    and $t4,$t3,0xf
2164#    srl $t3,4
2168#    lb $t4,hexChars($t4)
2172#    sb $t4,-8($t2)
2176#    subu $t2,$t2,1
2180#    bgt $t2,$t0,toString_hashCopyLoop
2181##...slt $at,$t0,$t2
2185##...bne $at,$zero,2160

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2188#    addu $sp,28
2192#    lw $ra,($sp)
2196#    addu $sp,4
2200#    move $t0, $s7 # return string we created
2204#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2208:mth_equals_String:
    
    # quick test for obvious false
2208#    lw $t0,($sp) # second parameter
2212#    beq $t0,$zero,goEsFalse # go return false if null
2216#    lw $t1,-12($t0) # vtable pointer
2220#    la $t2,CLASS_String # string vtable pointer
2224#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2228#    subu $sp,12
2232#    sw $ra,8($sp)
2236#    sw $s2,4($sp)
2240#    sw $t0,($sp)
2244#    jal mth_compareTo_String
2248#    lw $s2, 4($sp) #restore this pointer and pop parameters
2252#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2256#    seq $t0,$t0,$zero
2257##...subu $at,$t0,$zero
2261##...sltiu $t0,$at,1

    # pop return address and return $t0
2264#    lw $ra,($sp)
2268#    addu $sp,4

2272#    jr $ra # return
    
2276:goEsFalse:
    # put 0 in $t0 and return
2276#    li $t0, 0
2280#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2284:mth_toString_String:
    #we are a string, so return this.
2284#    move $t0, $s2
2288#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2292:mth_readLine_Lib:
    
2292#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2296#    sw $ra, 4($sp) # save $ra
2300#    move $t1,$sp # save "original" sp

2304:  doRead:

    # read the character
2304#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2308#    subu $t2,$v0,13
2312#    bne $t2,$zero,notReturnRL
2316#    jal readLogicalChar
2320#    subu $t2,$v0,10 # check for newline
2324#    beq $t2,$zero,foundNewLine
2328#    sw $v0,lastCharRead # push back character into queue
2332#    j foundNewLine # go process the line

2336:  notReturnRL:

    # at this point, $v0 has our character

2336#    subu $t0,$v0,10
2340#    beq $t0,$zero,foundNewLine
2344#    blt $v0,$zero,foundEof
2345##...slt $at,$v0,$zero
2349##...bne $at,$zero,2364

    # we have a character, so push it onto stack
2352#    subu $sp,$sp,4
2356#    sw $v0,($sp)

    # loop back up to get next character
2360#    j doRead

2364:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2364#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2368#    li $s7, 0 # return-value: null
2372#    j rlReturn # return

2376:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2376#    subu $t0,$t1,$sp # number of chars we read (times 4)
2380#    srl $s6,$t0,2 # number of words on stack with chars
2384#    subu $sp,$sp,4 # push char-count ...
2388#    sw $s6,($sp) # ... onto stack
2392#    addu $t2,$t0,5 # GC tag, incl. for count-word
2396#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2400#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2404#    srl $s6,$s6,2  # data words in object
2408#    move $s7,$zero # object words in object
2412#    jal newObject  # allocate space
    
    # store header words
2416#    la $t0,CLASS_String
2420#    sw $t0,-12($s7)# store class tag (String) into object
2424#    lw $t2,4($sp) # char-count
2428#    sll $t1,$t2,2 # 4 times number of chars
2432#    subu $t2,$zero,$t2 # negative of char-count
2436#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2440#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2444#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2445##...slt $at,$t0,$zero
2449##...beq $at,$zero,2468
2452#    and $t0,0xff # mask off object's hash value ...
2453##...lui $at,0
2457##...ori $at,$at,0xff
2461##...and $t0,$t0,$at
2464#    sw $t0,-8($s7) # ... and store back into -8 header-word
2468:  skipMask_readLine:


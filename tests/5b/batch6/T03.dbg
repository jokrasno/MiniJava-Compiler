1892#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1896#    subu $t0,$v0,10
1900#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1904#    subu $t0,$v0,9
1908#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1912#    subu $t0,$v0,13
1916#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1920#    subu $t0,$v0,12
1924#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1928#    j badIntegerFormat # illegal integer char: abort program

1932:  nonWhite:
1932#    subu $t0,$v0,'-'
1936#    li $t4,1 # final multiplier
1940#    bne $t0,$zero,helpReadInt # go read
1944#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1948#    jal readLogicalChar

1952:  helpReadInt:
1952#    li $t2,10
1956#    subu $t1,$v0,'0' # convert digit to 0-9 value
1960#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1961##...sltu $at,$t1,$t2
1965##...beq $at,$zero,4212
1968#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1972:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1972#    jal readLogicalChar # read next character
1976#    subu $t1,$v0,'0' # convert digit to 0-9 value
1980#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1981##...sltu $at,$t1,$t2
1985##...beq $at,$zero,2004

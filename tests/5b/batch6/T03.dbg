3272#    bgeu $s6,$t2 firstHeaderLarge
3273##...sltu $at,$s6,$t2
3277##...beq $at,$zero,3324
3280#    lw $t1,prevHashConstant
3284#    addu $t1,0x12b68fd2
3285##...lui $at,4791
3289##...addiu $at,$at,-28718
3293##...addu $t1,$at,$t1
3296#    sw $t1,prevHashConstant # update hash constant
3300#    or $t1,0x80000000 # set top bit
3301##...lui $at,32768
3305##...or $t1,$at,$t1
3308#    and $t1,0xffffff00 # clear low bit
3309##...lui $at,65535
3313##...ori $at,$at,0xff00
3317##...and $t1,$t1,$at
3320#    or $s6,$t1
3324:firstHeaderLarge:
3324#    sw $s6,-8($t0) # store header-1 value
3328#    lw $zero,-8($t0)

    # store second header-value
3332#    sw $s7,-4($t0)   # second header-word
3336#    lw $zero,-4($t0)

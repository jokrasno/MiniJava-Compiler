1597##...subu $at,$t0,$zero
1601##...sltiu $t0,$at,1

    # pop return address and return $t0
1604#    lw $ra,($sp)
1608#    addu $sp,4

1612#    jr $ra # return
    
1616:goEsFalse:
    # put 0 in $t0 and return
1616#    li $t0, 0

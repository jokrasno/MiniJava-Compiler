        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1372#    li $t0,CLASS_String # store string vtable address into ...
1376#    sw $t0,-12($s7) # ... -12 offset in object header
1380#    lw $t2,-12($s2) # our object's vtable address
1384#    lw $t5,4($sp) # number characters in prefix
1388#    lw $t1,12($sp) # number of characters in hashcode
1392#    addu $t3,$t1,$t5 # number of characters in string ...
1396#    addu $t3,1 # ... including the '@' character
1400#    subu $t0,$zero,$t3 # store negated length into ...
1404#    sw $t0,-4($s7) # ... -4 offset header word
1408#    lw $t0,-8($s7) # get -8 offset header-word

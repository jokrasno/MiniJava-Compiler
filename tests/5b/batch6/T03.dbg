3212#    addu $t0,$s6,$s7
3216#    sll $t0,$t0,2
3220#    addu $t0,$t0,8 # amount of memory needed
3224#    addu $t1,$t0,$s3
3228#    bgtu $t1,$s4,doGC
3229##...sltu $at,$s4,$t1
3233##...bne $at,$zero,3356

1548#    lw $t0,($sp) # second parameter
1552#    beq $t0,$zero,goEsFalse # go return false if null
1556#    lw $t1,-12($t0) # vtable pointer
1560#    la $t2,CLASS_String # string vtable pointer
1564#    bne $t1,$t2,goEsFalse # go return false if not a string

    # greater
3148#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
3152#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
3156#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
3160:  cmpHitLimitzz:
3160#    move $t0, $t5 # store return value
3164#    jr $ra # return

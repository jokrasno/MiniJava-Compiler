    # buffer and return
3180#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
3184#    jr $ra # return
    
3188:  doReadCh:
    # we need to actually read a character: read and return
3188#    li $v0,12 # use system call to read a character
3192#    syscall
3196#    jr $ra # return

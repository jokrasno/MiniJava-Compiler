1828#    beq $sp,$t1,rlReturn
1832:  charCopyLoop:
1832#    lw $t2,($sp)
1836#    sb $t2,-9($t0)
1840#    addu $sp,$sp,4
1844#    subu $t0,$t0,1
1848#    bne $sp,$t1,charCopyLoop
1852:  rlReturn:

1852#    lw $ra, 4($sp)
1856#    addu $sp, 8   # pop $ra and pointless word off stack
1860#    move $t0, $s7 # return string we allocated in $s7
1864#    jr $ra

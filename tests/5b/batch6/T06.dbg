##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1716:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1716#    lw $t0,-8($s2) # get word with hash bits from this
1720#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1724#    addu $t0,$t1

1728#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1732:mth_equals_Object:
1732#    move $t0,$s2 # first pointer (this)
1736#    lw $t1,($sp) # second pointer
1740#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1741##...subu $at,$t0,$t1
1745##...sltiu $t0,$at,1

1748#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1752:mth_hashCode_String:
1752#    move $t0,$s2 # put this pointer in t0

1756#    li $t2,0 # current hash value
1760#    lw $t1,-4($t0) # negative of number of characters in string
1764#    beq $t1,$zero,done_hashCode_String # if zero length => done
1768#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1772#    and $t0,0xfffffffc # adjust for padding
1773##...lui $at,65535
1777##...ori $at,$at,0xfffc
1781##...and $t0,$t0,$at
1784#    subu $t1,$t0,$t1 # address at end of string +12
1788:loop_hashCode_String:    
1788#    sll $t4,$t2,5 # multiply by 32
1792#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1796#    lbu $t3,-12($t0) # current character
1800#    addu $t2,$t3 # add in current character
1804#    addu $t0,1 # go to next character's address
1808#    bne $t0,$t1,loop_hashCode_String # loop back if more
1812:done_hashCode_String:    

    # push int on stack
1812#    move $t0, $t2 # put $t2 in return slot
1816#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1820:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1820#    subu $sp,4
1824#    sw $ra,($sp)
    
    # get hash value
1828#    lw $t2,-12($s2) # vtable address
1832#    lw $t0,($t2) # method address
1836#    jalr $t0
1840#    subu $sp,8 # push result (int in $t0) on stack
1844#    sw $s5,4($sp)
1848#    sw $t0,($sp)

    # compute print-size of hash value
1852#    li $t0, 1
1856#    lw $t1, ($sp)
1860#    srl $t1,$t1,4
1864#    beq $t1,$zero,toString_skip_loop
1868:toString_loop_top:
1868#    addu $t0,1
1872#    srl $t1,$t1,4
1876#    bne $t1,$zero,toString_loop_top
1880:toString_skip_loop:
1880#    subu $sp,8
1884#    sw $s5,4($sp)
1888#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1892#    lw $t2,-12($s2) # vtable address
1896#    move $t0,$t2
1900:toString_checkTagBit:
1900#    subu $t0,1
1904#    lb $t1,($t0)
1908#    and $t1,0x80
1909##...lui $at,0
1913##...ori $at,$at,0x80
1917##...and $t1,$t1,$at
1920#    beq $t1,$zero,toString_checkTagBit
1924#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1928#    subu $sp,8
1932#    sw $t1,($sp)
1936#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1940#    move $s7,$zero # -4 offset header word
1944#    lw $t4,8($sp) # bytes for hash value
1948#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1952#    addu $t4,8
1956#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1960#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1964#    li $t0,CLASS_String # store string vtable address into ...
1968#    sw $t0,-12($s7) # ... -12 offset in object header
1972#    lw $t2,-12($s2) # our object's vtable address
1976#    lw $t5,4($sp) # number characters in prefix
1980#    lw $t1,12($sp) # number of characters in hashcode
1984#    addu $t3,$t1,$t5 # number of characters in string ...
1988#    addu $t3,1 # ... including the '@' character
1992#    subu $t0,$zero,$t3 # store negated length into ...
1996#    sw $t0,-4($s7) # ... -4 offset header word
2000#    lw $t0,-8($s7) # get -8 offset header-word
2004#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2005##...slt $at,$t0,$zero
2009##...beq $at,$zero,2028
2012#    and $t0,0xff # mask off object's hash value ...
2013##...lui $at,0
2017##...ori $at,$at,0xff
2021##...and $t0,$t0,$at
2024#    sw $t0,-8($s7) # ... and store back into -8 header-word
2028:skipMask_toString:
2028#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2032#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2036#    subu $t4,$t2,$t5
2040:toString_copyLoop:    
2040#    lb $t3,($t4)
2044#    and $t3,0x7f # mask off sign bit (in case first word)
2045##...lui $at,0
2049##...ori $at,$at,0x7f
2053##...and $t3,$t3,$at
2056#    sb $t3,-8($t0)
2060#    addu $t4,1
2064#    addu $t0,1
2068#    blt $t4,$t2,toString_copyLoop
2069##...slt $at,$t4,$t2
2073##...bne $at,$zero,2040

    # copy the '@' sign
2076#    li $t3,'@'
2080#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2084#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2088#    lw $t3,20($sp) # hash code to print
2092:toString_hashCopyLoop:
2092#    and $t4,$t3,0xf
2096#    srl $t3,4
2100#    lb $t4,hexChars($t4)
2104#    sb $t4,-8($t2)
2108#    subu $t2,$t2,1
2112#    bgt $t2,$t0,toString_hashCopyLoop
2113##...slt $at,$t0,$t2
2117##...bne $at,$zero,2092

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2120#    addu $sp,28
2124#    lw $ra,($sp)
2128#    addu $sp,4
2132#    move $t0, $s7 # return string we created
2136#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2140:mth_equals_String:
    
    # quick test for obvious false
2140#    lw $t0,($sp) # second parameter
2144#    beq $t0,$zero,goEsFalse # go return false if null
2148#    lw $t1,-12($t0) # vtable pointer
2152#    la $t2,CLASS_String # string vtable pointer
2156#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2160#    subu $sp,12
2164#    sw $ra,8($sp)
2168#    sw $s2,4($sp)
2172#    sw $t0,($sp)
2176#    jal mth_compareTo_String
2180#    lw $s2, 4($sp) #restore this pointer and pop parameters
2184#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2188#    seq $t0,$t0,$zero
2189##...subu $at,$t0,$zero
2193##...sltiu $t0,$at,1

    # pop return address and return $t0
2196#    lw $ra,($sp)
2200#    addu $sp,4

2204#    jr $ra # return
    
2208:goEsFalse:
    # put 0 in $t0 and return
2208#    li $t0, 0
2212#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2216:mth_toString_String:
    #we are a string, so return this.
2216#    move $t0, $s2
2220#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2224:mth_readLine_Lib:
    
2224#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2228#    sw $ra, 4($sp) # save $ra
2232#    move $t1,$sp # save "original" sp

2236:  doRead:

    # read the character
2236#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2240#    subu $t2,$v0,13
2244#    bne $t2,$zero,notReturnRL
2248#    jal readLogicalChar
2252#    subu $t2,$v0,10 # check for newline
2256#    beq $t2,$zero,foundNewLine
2260#    sw $v0,lastCharRead # push back character into queue
2264#    j foundNewLine # go process the line

2268:  notReturnRL:

    # at this point, $v0 has our character

2268#    subu $t0,$v0,10
2272#    beq $t0,$zero,foundNewLine
2276#    blt $v0,$zero,foundEof
2277##...slt $at,$v0,$zero
2281##...bne $at,$zero,2296

    # we have a character, so push it onto stack
2284#    subu $sp,$sp,4
2288#    sw $v0,($sp)

    # loop back up to get next character
2292#    j doRead

2296:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2296#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2300#    li $s7, 0 # return-value: null
2304#    j rlReturn # return

2308:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2308#    subu $t0,$t1,$sp # number of chars we read (times 4)
2312#    srl $s6,$t0,2 # number of words on stack with chars
2316#    subu $sp,$sp,4 # push char-count ...
2320#    sw $s6,($sp) # ... onto stack
2324#    addu $t2,$t0,5 # GC tag, incl. for count-word
2328#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2332#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2336#    srl $s6,$s6,2  # data words in object
2340#    move $s7,$zero # object words in object
2344#    jal newObject  # allocate space
    
    # store header words
2348#    la $t0,CLASS_String
2352#    sw $t0,-12($s7)# store class tag (String) into object
2356#    lw $t2,4($sp) # char-count
2360#    sll $t1,$t2,2 # 4 times number of chars
2364#    subu $t2,$zero,$t2 # negative of char-count
2368#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2372#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2376#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2377##...slt $at,$t0,$zero
2381##...beq $at,$zero,2400
2384#    and $t0,0xff # mask off object's hash value ...
2385##...lui $at,0
2389##...ori $at,$at,0xff
2393##...and $t0,$t0,$at
2396#    sw $t0,-8($s7) # ... and store back into -8 header-word
2400:  skipMask_readLine:

2400#    sll $t0,$t0,2 # data bytes in object
2404#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2408#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2412#    addu $sp,$sp,8 # pop redundant object-pointer and count
2416#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2420#    beq $sp,$t1,rlReturn
2424:  charCopyLoop:
2424#    lw $t2,($sp)
2428#    sb $t2,-9($t0)
2432#    addu $sp,$sp,4
2436#    subu $t0,$t0,1
2440#    bne $sp,$t1,charCopyLoop
2444:  rlReturn:

2444#    lw $ra, 4($sp)
2448#    addu $sp, 8   # pop $ra and pointless word off stack
2452#    move $t0, $s7 # return string we allocated in $s7
2456#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2460:mth_readInt_Lib:

    # save $ra by pushing onto stack
2460#    subu $sp,$sp,4
2464#    sw $ra,($sp)

2468:  riSkipWhiteLoop:
    # read a character
2468#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2472#    subu $t0,$v0,32
2476#    bgt $t0,$zero,nonWhite
2477##...slt $at,$zero,$t0
2481##...bne $at,$zero,2524
2484#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2488#    subu $t0,$v0,10
2492#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2496#    subu $t0,$v0,9
2500#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2504#    subu $t0,$v0,13
2508#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2512#    subu $t0,$v0,12
2516#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2520#    j badIntegerFormat # illegal integer char: abort program

2524:  nonWhite:
2524#    subu $t0,$v0,'-'
2528#    li $t4,1 # final multiplier
2532#    bne $t0,$zero,helpReadInt # go read
2536#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2540#    jal readLogicalChar

2544:  helpReadInt:
2544#    li $t2,10
2548#    subu $t1,$v0,'0' # convert digit to 0-9 value
2552#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2553##...sltu $at,$t1,$t2
2557##...beq $at,$zero,4804
2560#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2564:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2564#    jal readLogicalChar # read next character
2568#    subu $t1,$v0,'0' # convert digit to 0-9 value
2572#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2573##...sltu $at,$t1,$t2
2577##...beq $at,$zero,2596

2580#    mul $t3,$t3,$t2 # multiply old value by 10
2581##...mult $t3,$t2
2585##...mflo $t3
2588#    addu $t3,$t3,$t1 # add in value of new digit
2592#    j digitLoop

2596:  doneDigitLoop:

    # "push back" unused character into queue
2596#    sw $v0,lastCharRead

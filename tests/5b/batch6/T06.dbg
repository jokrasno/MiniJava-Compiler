3593##...slt $at,$t4,$zero
3597##...beq $at,$zero,3616
3600#    and $t4,0xff # mask off object's hash value ...
3601##...lui $at,0
3605##...ori $at,$at,0xff
3609##...and $t4,$t4,$at
3612#    sw $t4,-8($s7) # ... and store back into -8 header-word
3616:  skipMask_intToChar:

    # store data in string
3616#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
3620#    li $t0,-1
3624#    sw $t0,-4($s7)

    # we're returning $s7
3628#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
3632#    lw $ra,4($sp)
3636#    addu $sp,$sp,8

    # return
3640#    jr $ra

    # restore return address
2600#    lw $ra,($sp)
2604#    addu $sp, 4

    # multiply by sign and put return value in $t0
2608#    mult $t3,$t4 # multiply to account for poss. minus sign
2612#    mflo $t3
2616#    move $t0, $t3
    
    # return
2620#    jr $ra


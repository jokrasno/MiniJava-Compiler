    # get argument, negate if negative
3328#    lw $t1,8($sp)
3332#    bge $t1,$zero,itsNonNegLoop
3333##...slt $at,$t1,$zero
3337##...beq $at,$zero,3344
3340#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
3344:  itsNonNegLoop:
3344#    divu $t1,$t3
3348#    mflo $t1 # quotient
3352#    mfhi $t4 # remainder
3356#    addu $t4,$t4,'0' # turn remainder into digit
3360#    subu $sp,$sp,4
3364#    sw $t4,($sp) # push digit onto stack
3368#    bne $t1,$zero,itsNonNegLoop

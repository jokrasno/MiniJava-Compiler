    # restore char-count; pop it and return value from 'newObject'
3436#    lw $t0,4($sp)
3440#    addu $sp,$sp,8

    # store "String" tag into class field
3444#    subu $s7,$s7,8 # address of header-1 word
3448#    la $t1,CLASS_String
3452#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
3456#    lw $t4,($s7) # # data words in source string
3460#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
3461##...slt $at,$t4,$zero
3465##...beq $at,$zero,3484
3468#    and $t4,0xff # mask off object's hash value ...
3469##...lui $at,0
3473##...ori $at,$at,0xff
3477##...and $t4,$t4,$at
3480#    sw $t4,($s7) # ... and store back into -8 header-word
3484:skipMask_intToString:
    
    # store negative of char-count into header-2 word
3484#    subu $t0,$zero,$t0
3488#    sw $t0,4($s7)

3492#    lw $t1,($s7) # number of data words in string
3496#    sll $t1,$t1,2 # number data bytes in string
3500#    subu $t1,$s7,$t1 # first location to store chars in string
3504#    subu $t0,$t1,$t0 # limit address for chars in string

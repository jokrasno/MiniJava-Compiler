########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4596:divide:
    # get parameters; abort if divisor zero
4596#    lw $t0,($sp)
4600#    lw $t1,8($sp)
4604#    beq $t0,$zero,divByZeroError
    
    # perform division
4608#    div $t1,$t0
4612#    mflo $t0

    # store result, adjust stack and return
4616#    addu $sp,$sp,8 # adjust stack
4620#    sw $t0,($sp) # store result
4624#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4628:remainder:
    # get parameters; abort if divisor zero
4628#    lw $t0,($sp)
4632#    lw $t1,8($sp)
4636#    beq $t0,$zero,divByZeroError
    
    # perform division
4640#    div $t1,$t0
4644#    mfhi $t0

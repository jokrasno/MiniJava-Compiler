#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4692:instanceOf:
    # get object, go return false if null
4692#    lw $t2,($sp)
4696#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4700#    lw $t2,-12($t2) # vtable address
4704#    sge $t0,$t2,$t0 # are we >= the lower limit?
4705##...slt $t0,$t2,$t0
4709##...xori $t0,$t0,0x1
4712#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4716#    and $t2,$t0,$t1
4720#    sw $t2,($sp)
4724:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4724#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4728:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4728#    li $v0,4 # syscall-code for print-string
4732#    syscall
4736:exit:
    # print termination message
4736#    li $v0,4 # syscall-code for print-string
4740#    la $a0,exitString
4744#    syscall

    # terminate execution
4748#    li $v0,10 #syscall-code for "exit"
4752#    syscall

4756:outOfHeapMemory:
4756#    la $a0,heapMemoryMsg
4760#    j exitError
4764:divByZeroError:
4764#    la $a0,divByZeroMsg
4768#    j exitError
4772:strIndexOutOfBounds:
4772#    la $a0,strIndexOutOfBoundsMsg
4776#    j exitError
4780:arrayIndexOutOfBounds:
4780#    la $a0,arrayIndexOutOfBoundsMsg
4784#    j exitError
4788:arraySizeOutOfBounds:
4788#    la $a0,arraySizeOutOfBoundsMsg
4792#    j exitError
4796:nullPtrException:
4796#    la $a0,nullPtrExceptionMsg
4800#    j exitError
4804:badIntegerFormat:
4804#    la $a0,badIntegerFormatMsg
4808#    j exitError
4812:castException:
4812#    la $a0,castExceptionMsg
4816#    j exitError
############## data section ################
    .data
5176:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5192:cur_seg:
    .word 0

5196:lastCharRead:
    .word -2 # -2 => no buffered character
5200:prevHashConstant:
    .word 0x2785173c
5204:gcCount:
    .word 0

5208:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5235:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5258:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5293:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5327:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5360:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5391:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5439:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5460:gcMsg: 
      .asciiz "\nGC!\n"
5466:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5498:nullStr:
    .asciiz "null"
5503:trueString:
    .asciiz "true"
5508:falseString:
    .asciiz "false"
5514:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5533:newlineString:
    .asciiz "\n"
    
    .align 2
5536:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5540:seg0_start:
    .space 0x100000
1054116:seg0_end:
1054116:seg1_start:
    .space 0x100000
2102692:seg1_end:

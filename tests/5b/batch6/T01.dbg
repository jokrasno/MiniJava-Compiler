1408#    subu $t0,$v0,10
1412#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1416#    subu $t0,$v0,9
1420#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1424#    subu $t0,$v0,13
1428#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1432#    subu $t0,$v0,12

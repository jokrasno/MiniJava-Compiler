    # set up the forwarding pointer
3440#    sw $zero,-8($t1) # 0 in first header-slot
3444#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3448#    sw $t8,($t0)

3452:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3452#    addu $t0,$t0,4
3456#    bltu $t0,$s1,gcNextPointerInObject
3457##...sltu $at,$t0,$s1
3461##...bne $at,$zero,3300

3464:  gcTestIterDone2:
3464#    bltu $t0,$s3,gcHeapCopyLoop
3465##...sltu $at,$t0,$s3
3469##...bne $at,$zero,3184

    ###### end outer loop to copy all non-stack-direct objects ######

3472:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3472#    lw $s2,($sp)
3476#    addu $sp,$sp,4

    # mark us as having already GC'd
3480#    move $t5,$s5

    # go try and allocate again
3484#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3488:vm_init:

    # mark bottom of stack
3488#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3492#    move $s2,$zero

    #set up the "five" register
3496#    li $s5,5

3500#    la $s3,seg0_start
3504#    la $s4,seg0_end
3505##...lui $s4,16
3509##...addiu $s4,$s4,4304
    
    # return
3512#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3516:divide:
    # get parameters; abort if divisor zero
3516#    lw $t0,($sp)
3520#    lw $t1,8($sp)
3524#    beq $t0,$zero,divByZeroError
    
    # perform division
3528#    div $t1,$t0
3532#    mflo $t0

    # store result, adjust stack and return
3536#    addu $sp,$sp,8 # adjust stack
3540#    sw $t0,($sp) # store result
3544#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3548:remainder:
    # get parameters; abort if divisor zero
3548#    lw $t0,($sp)
3552#    lw $t1,8($sp)
3556#    beq $t0,$zero,divByZeroError
    
    # perform division
3560#    div $t1,$t0
3564#    mfhi $t0

    # store result, adjust stack and return
3568#    addu $sp,$sp,8 # adjust stack
3572#    sw $t0,($sp) # store result
3576#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3580:checkCast:
    # get object, allow immediately if null
3580#    lw $t2,($sp)
3584#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3588#    lw $t2,-12($t2) # vtable address
3592#    bge $t2,$t1,castException
3593##...slt $at,$t2,$t1
3597##...beq $at,$zero,3732
3600#    blt $t2,$t0,castException
3601##...slt $at,$t2,$t0
3605##...bne $at,$zero,3732
    
    # return, leaving object unchanged on stack
3608:  checkCastReturn:    
3608#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3612:instanceOf:
    # get object, go return false if null
3612#    lw $t2,($sp)
3616#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3620#    lw $t2,-12($t2) # vtable address
3624#    sge $t0,$t2,$t0 # are we >= the lower limit?
3625##...slt $t0,$t2,$t0
3629##...xori $t0,$t0,0x1
3632#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3636#    and $t2,$t0,$t1
3640#    sw $t2,($sp)
3644:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3644#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3648:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3648#    li $v0,4 # syscall-code for print-string
3652#    syscall
3656:exit:
    # print termination message
3656#    li $v0,4 # syscall-code for print-string
3660#    la $a0,exitString
3664#    syscall

    # terminate execution
3668#    li $v0,10 #syscall-code for "exit"
3672#    syscall

3676:outOfHeapMemory:
3676#    la $a0,heapMemoryMsg
3680#    j exitError
3684:divByZeroError:
3684#    la $a0,divByZeroMsg
3688#    j exitError
3692:strIndexOutOfBounds:
3692#    la $a0,strIndexOutOfBoundsMsg
3696#    j exitError
3700:arrayIndexOutOfBounds:
3700#    la $a0,arrayIndexOutOfBoundsMsg
3704#    j exitError
3708:arraySizeOutOfBounds:
3708#    la $a0,arraySizeOutOfBoundsMsg
3712#    j exitError
3716:nullPtrException:
3716#    la $a0,nullPtrExceptionMsg
3720#    j exitError
3724:badIntegerFormat:
3724#    la $a0,badIntegerFormatMsg
3728#    j exitError
3732:castException:
3732#    la $a0,castExceptionMsg
3736#    j exitError
############## data section ################
    .data
3940:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3956:cur_seg:
    .word 0

3960:lastCharRead:
    .word -2 # -2 => no buffered character
3964:prevHashConstant:
    .word 0x2785173c
3968:gcCount:
    .word 0

3972:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3999:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4022:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4057:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4091:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4124:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4155:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4203:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4224:gcMsg: 
      .asciiz "\nGC!\n"
4230:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4262:nullStr:
    .asciiz "null"
4267:trueString:
    .asciiz "true"
4272:falseString:
    .asciiz "false"
4278:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4297:newlineString:
    .asciiz "\n"
    
    .align 2
4300:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4304:seg0_start:
    .space 0x100000
1052880:seg0_end:
1052880:seg1_start:
    .space 0x100000
2101456:seg1_end:

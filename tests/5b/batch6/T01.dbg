1108#    seq $t0,$t0,$zero
1109##...subu $at,$t0,$zero
1113##...sltiu $t0,$at,1

    # pop return address and return $t0
1116#    lw $ra,($sp)
1120#    addu $sp,4

1124#    jr $ra # return
    
1128:goEsFalse:
    # put 0 in $t0 and return
1128#    li $t0, 0
1132#    jr $ra # return

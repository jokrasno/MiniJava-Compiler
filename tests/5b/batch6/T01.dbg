##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
636:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
636#    lw $t0,-8($s2) # get word with hash bits from this
640#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
644#    addu $t0,$t1

648#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
652:mth_equals_Object:
652#    move $t0,$s2 # first pointer (this)
656#    lw $t1,($sp) # second pointer
660#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
661##...subu $at,$t0,$t1
665##...sltiu $t0,$at,1

668#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
672:mth_hashCode_String:
672#    move $t0,$s2 # put this pointer in t0

676#    li $t2,0 # current hash value
680#    lw $t1,-4($t0) # negative of number of characters in string
684#    beq $t1,$zero,done_hashCode_String # if zero length => done
688#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
692#    and $t0,0xfffffffc # adjust for padding
693##...lui $at,65535
697##...ori $at,$at,0xfffc
701##...and $t0,$t0,$at
704#    subu $t1,$t0,$t1 # address at end of string +12
708:loop_hashCode_String:    
708#    sll $t4,$t2,5 # multiply by 32
712#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
716#    lbu $t3,-12($t0) # current character
720#    addu $t2,$t3 # add in current character
724#    addu $t0,1 # go to next character's address
728#    bne $t0,$t1,loop_hashCode_String # loop back if more
732:done_hashCode_String:    

    # push int on stack
732#    move $t0, $t2 # put $t2 in return slot
736#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
740:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
740#    subu $sp,4
744#    sw $ra,($sp)
    
    # get hash value
748#    lw $t2,-12($s2) # vtable address
752#    lw $t0,($t2) # method address
756#    jalr $t0
760#    subu $sp,8 # push result (int in $t0) on stack
764#    sw $s5,4($sp)
768#    sw $t0,($sp)

    # compute print-size of hash value
772#    li $t0, 1
776#    lw $t1, ($sp)
780#    srl $t1,$t1,4
784#    beq $t1,$zero,toString_skip_loop
788:toString_loop_top:
788#    addu $t0,1
792#    srl $t1,$t1,4
796#    bne $t1,$zero,toString_loop_top
800:toString_skip_loop:
800#    subu $sp,8
804#    sw $s5,4($sp)
808#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
812#    lw $t2,-12($s2) # vtable address
816#    move $t0,$t2
820:toString_checkTagBit:
820#    subu $t0,1
824#    lb $t1,($t0)
828#    and $t1,0x80
829##...lui $at,0
833##...ori $at,$at,0x80
837##...and $t1,$t1,$at
840#    beq $t1,$zero,toString_checkTagBit
844#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
848#    subu $sp,8
852#    sw $t1,($sp)
856#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
860#    move $s7,$zero # -4 offset header word
864#    lw $t4,8($sp) # bytes for hash value
868#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
872#    addu $t4,8
876#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
880#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

884#    li $t0,CLASS_String # store string vtable address into ...
888#    sw $t0,-12($s7) # ... -12 offset in object header
892#    lw $t2,-12($s2) # our object's vtable address
896#    lw $t5,4($sp) # number characters in prefix
900#    lw $t1,12($sp) # number of characters in hashcode
904#    addu $t3,$t1,$t5 # number of characters in string ...
908#    addu $t3,1 # ... including the '@' character
912#    subu $t0,$zero,$t3 # store negated length into ...
916#    sw $t0,-4($s7) # ... -4 offset header word
920#    lw $t0,-8($s7) # get -8 offset header-word
924#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
925##...slt $at,$t0,$zero
929##...beq $at,$zero,948
932#    and $t0,0xff # mask off object's hash value ...
933##...lui $at,0
937##...ori $at,$at,0xff
941##...and $t0,$t0,$at
944#    sw $t0,-8($s7) # ... and store back into -8 header-word
948:skipMask_toString:
948#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
952#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
956#    subu $t4,$t2,$t5
960:toString_copyLoop:    
960#    lb $t3,($t4)
964#    and $t3,0x7f # mask off sign bit (in case first word)
965##...lui $at,0
969##...ori $at,$at,0x7f
973##...and $t3,$t3,$at
976#    sb $t3,-8($t0)
980#    addu $t4,1
984#    addu $t0,1
988#    blt $t4,$t2,toString_copyLoop
989##...slt $at,$t4,$t2
993##...bne $at,$zero,960

    # copy the '@' sign
996#    li $t3,'@'
1000#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode

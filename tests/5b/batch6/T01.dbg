1012:toString_hashCopyLoop:
1012#    and $t4,$t3,0xf
1016#    srl $t3,4
1020#    lb $t4,hexChars($t4)
1024#    sb $t4,-8($t2)
1028#    subu $t2,$t2,1
1032#    bgt $t2,$t0,toString_hashCopyLoop
1033##...slt $at,$t0,$t2
1037##...bne $at,$zero,1012

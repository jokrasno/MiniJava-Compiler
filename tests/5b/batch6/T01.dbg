    # get begin-of-string addresses
2596#    lw $t2,-8($t0) # # data words in second string
2600#    lw $t3,-8($t1) # # data words in first string
2604#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
2608#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
2612#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
2616#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
2620#    beq $zero,$t5,skipStrCmpLenzz
2624#    move $t2,$t3
2628:  skipStrCmpLenzz:
2628#    add $t2,$t1,$t2

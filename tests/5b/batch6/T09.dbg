2692#    subu $t0,$v0,10
2696#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2700#    subu $t0,$v0,9
2704#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2708#    subu $t0,$v0,13
2712#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2716#    subu $t0,$v0,12
2720#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2724#    j badIntegerFormat # illegal integer char: abort program

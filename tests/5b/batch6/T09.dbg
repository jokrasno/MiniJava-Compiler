#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4896:instanceOf:
    # get object, go return false if null
4896#    lw $t2,($sp)
4900#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4904#    lw $t2,-12($t2) # vtable address
4908#    sge $t0,$t2,$t0 # are we >= the lower limit?
4909##...slt $t0,$t2,$t0
4913##...xori $t0,$t0,0x1
4916#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4920#    and $t2,$t0,$t1
4924#    sw $t2,($sp)
4928:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4928#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4932:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4932#    li $v0,4 # syscall-code for print-string
4936#    syscall
4940:exit:
    # print termination message
4940#    li $v0,4 # syscall-code for print-string
4944#    la $a0,exitString
4948#    syscall

    # terminate execution
4952#    li $v0,10 #syscall-code for "exit"
4956#    syscall

4960:outOfHeapMemory:
4960#    la $a0,heapMemoryMsg
4964#    j exitError
4968:divByZeroError:
4968#    la $a0,divByZeroMsg
4972#    j exitError
4976:strIndexOutOfBounds:
4976#    la $a0,strIndexOutOfBoundsMsg
4980#    j exitError
4984:arrayIndexOutOfBounds:
4984#    la $a0,arrayIndexOutOfBoundsMsg
4988#    j exitError
4992:arraySizeOutOfBounds:
4992#    la $a0,arraySizeOutOfBoundsMsg
4996#    j exitError
5000:nullPtrException:
5000#    la $a0,nullPtrExceptionMsg
5004#    j exitError
5008:badIntegerFormat:
5008#    la $a0,badIntegerFormatMsg
5012#    j exitError
5016:castException:
5016#    la $a0,castExceptionMsg
5020#    j exitError
############## data section ################
    .data
5316:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5332:cur_seg:
    .word 0

5336:lastCharRead:
    .word -2 # -2 => no buffered character
5340:prevHashConstant:
    .word 0x2785173c
5344:gcCount:
    .word 0

5348:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5375:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5398:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5433:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5467:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5500:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5531:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5579:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5600:gcMsg: 
      .asciiz "\nGC!\n"
5606:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5638:nullStr:
    .asciiz "null"
5643:trueString:
    .asciiz "true"
5648:falseString:
    .asciiz "false"
5654:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5673:newlineString:
    .asciiz "\n"
    
    .align 2
5676:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5680:seg0_start:
    .space 0x100000
1054256:seg0_end:
1054256:seg1_start:
    .space 0x100000
2102832:seg1_end:

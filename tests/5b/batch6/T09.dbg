    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
4176#    lw $t0,cur_seg
4180#    move $t7,$s4
4184#    la $t6,seg1_start
4185##...lui $t6,16
4189##...addiu $t6,$t6,5680
4192#    la $s3,seg0_start
4196#    la $s4,seg0_end
4197##...lui $s4,16
4201##...addiu $s4,$s4,5680
4204#    sw $zero,cur_seg
4208#    bne $t0,$zero,skipGc1
4212#    la $t6,seg0_start
4216#    la $s3,seg1_start
4217##...lui $s3,16
4221##...addiu $s3,$s3,5680
4224#    la $s4,seg1_end
4225##...lui $s4,32
4229##...addiu $s4,$s4,5680
4232#    sw $s5,cur_seg
4236:  skipGc1:
4236#    li $t5,0x80000000
4240#    lw $t0,stack_bottom
4244#    subu $t0,4


    ###############################################################
    # at this point:
    # - $t6 contains the first address of the source space

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1920:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1920#    lw $t0,-8($s2) # get word with hash bits from this
1924#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1928#    addu $t0,$t1

1932#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1936:mth_equals_Object:
1936#    move $t0,$s2 # first pointer (this)
1940#    lw $t1,($sp) # second pointer
1944#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1945##...subu $at,$t0,$t1
1949##...sltiu $t0,$at,1

1952#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1956:mth_hashCode_String:
1956#    move $t0,$s2 # put this pointer in t0

1960#    li $t2,0 # current hash value
1964#    lw $t1,-4($t0) # negative of number of characters in string
1968#    beq $t1,$zero,done_hashCode_String # if zero length => done
1972#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1976#    and $t0,0xfffffffc # adjust for padding
1977##...lui $at,65535
1981##...ori $at,$at,0xfffc
1985##...and $t0,$t0,$at
1988#    subu $t1,$t0,$t1 # address at end of string +12
1992:loop_hashCode_String:    
1992#    sll $t4,$t2,5 # multiply by 32
1996#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
2000#    lbu $t3,-12($t0) # current character
2004#    addu $t2,$t3 # add in current character
2008#    addu $t0,1 # go to next character's address
2012#    bne $t0,$t1,loop_hashCode_String # loop back if more
2016:done_hashCode_String:    

    # push int on stack
2016#    move $t0, $t2 # put $t2 in return slot
2020#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
2024:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
2024#    subu $sp,4
2028#    sw $ra,($sp)
    
    # get hash value
2032#    lw $t2,-12($s2) # vtable address
2036#    lw $t0,($t2) # method address
2040#    jalr $t0
2044#    subu $sp,8 # push result (int in $t0) on stack
2048#    sw $s5,4($sp)
2052#    sw $t0,($sp)

    # compute print-size of hash value
2056#    li $t0, 1
2060#    lw $t1, ($sp)
2064#    srl $t1,$t1,4
2068#    beq $t1,$zero,toString_skip_loop
2072:toString_loop_top:
2072#    addu $t0,1
2076#    srl $t1,$t1,4
2080#    bne $t1,$zero,toString_loop_top
2084:toString_skip_loop:
2084#    subu $sp,8
2088#    sw $s5,4($sp)
2092#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
2096#    lw $t2,-12($s2) # vtable address
2100#    move $t0,$t2
2104:toString_checkTagBit:
2104#    subu $t0,1
2108#    lb $t1,($t0)
2112#    and $t1,0x80
2113##...lui $at,0
2117##...ori $at,$at,0x80
2121##...and $t1,$t1,$at
2124#    beq $t1,$zero,toString_checkTagBit
2128#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
2132#    subu $sp,8
2136#    sw $t1,($sp)
2140#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
2144#    move $s7,$zero # -4 offset header word
2148#    lw $t4,8($sp) # bytes for hash value
2152#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
2156#    addu $t4,8
2160#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
2164#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

2168#    li $t0,CLASS_String # store string vtable address into ...
2172#    sw $t0,-12($s7) # ... -12 offset in object header
2176#    lw $t2,-12($s2) # our object's vtable address
2180#    lw $t5,4($sp) # number characters in prefix
2184#    lw $t1,12($sp) # number of characters in hashcode
2188#    addu $t3,$t1,$t5 # number of characters in string ...
2192#    addu $t3,1 # ... including the '@' character
2196#    subu $t0,$zero,$t3 # store negated length into ...
2200#    sw $t0,-4($s7) # ... -4 offset header word
2204#    lw $t0,-8($s7) # get -8 offset header-word
2208#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2209##...slt $at,$t0,$zero
2213##...beq $at,$zero,2232
2216#    and $t0,0xff # mask off object's hash value ...
2217##...lui $at,0
2221##...ori $at,$at,0xff
2225##...and $t0,$t0,$at
2228#    sw $t0,-8($s7) # ... and store back into -8 header-word
2232:skipMask_toString:
2232#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2236#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2240#    subu $t4,$t2,$t5
2244:toString_copyLoop:    
2244#    lb $t3,($t4)
2248#    and $t3,0x7f # mask off sign bit (in case first word)
2249##...lui $at,0
2253##...ori $at,$at,0x7f
2257##...and $t3,$t3,$at
2260#    sb $t3,-8($t0)
2264#    addu $t4,1
2268#    addu $t0,1
2272#    blt $t4,$t2,toString_copyLoop
2273##...slt $at,$t4,$t2
2277##...bne $at,$zero,2244

    # copy the '@' sign
2280#    li $t3,'@'
2284#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2288#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2292#    lw $t3,20($sp) # hash code to print
2296:toString_hashCopyLoop:
2296#    and $t4,$t3,0xf
2300#    srl $t3,4
2304#    lb $t4,hexChars($t4)
2308#    sb $t4,-8($t2)
2312#    subu $t2,$t2,1
2316#    bgt $t2,$t0,toString_hashCopyLoop
2317##...slt $at,$t0,$t2
2321##...bne $at,$zero,2296

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2324#    addu $sp,28
2328#    lw $ra,($sp)
2332#    addu $sp,4
2336#    move $t0, $s7 # return string we created
2340#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2344:mth_equals_String:
    
    # quick test for obvious false
2344#    lw $t0,($sp) # second parameter
2348#    beq $t0,$zero,goEsFalse # go return false if null
2352#    lw $t1,-12($t0) # vtable pointer
2356#    la $t2,CLASS_String # string vtable pointer
2360#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2364#    subu $sp,12
2368#    sw $ra,8($sp)
2372#    sw $s2,4($sp)
2376#    sw $t0,($sp)
2380#    jal mth_compareTo_String
2384#    lw $s2, 4($sp) #restore this pointer and pop parameters
2388#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2392#    seq $t0,$t0,$zero
2393##...subu $at,$t0,$zero
2397##...sltiu $t0,$at,1

    # pop return address and return $t0
2400#    lw $ra,($sp)
2404#    addu $sp,4

2408#    jr $ra # return
    
2412:goEsFalse:
    # put 0 in $t0 and return
2412#    li $t0, 0
2416#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2420:mth_toString_String:
    #we are a string, so return this.
2420#    move $t0, $s2
2424#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2428:mth_readLine_Lib:
    
2428#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2432#    sw $ra, 4($sp) # save $ra
2436#    move $t1,$sp # save "original" sp

2440:  doRead:

    # read the character
2440#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2444#    subu $t2,$v0,13
2448#    bne $t2,$zero,notReturnRL
2452#    jal readLogicalChar
2456#    subu $t2,$v0,10 # check for newline
2460#    beq $t2,$zero,foundNewLine
2464#    sw $v0,lastCharRead # push back character into queue
2468#    j foundNewLine # go process the line

2472:  notReturnRL:

    # at this point, $v0 has our character

2472#    subu $t0,$v0,10
2476#    beq $t0,$zero,foundNewLine
2480#    blt $v0,$zero,foundEof
2481##...slt $at,$v0,$zero
2485##...bne $at,$zero,2500

    # we have a character, so push it onto stack
2488#    subu $sp,$sp,4
2492#    sw $v0,($sp)

    # loop back up to get next character
2496#    j doRead

2500:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2500#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2504#    li $s7, 0 # return-value: null
2508#    j rlReturn # return

2512:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2512#    subu $t0,$t1,$sp # number of chars we read (times 4)
2516#    srl $s6,$t0,2 # number of words on stack with chars
2520#    subu $sp,$sp,4 # push char-count ...
2524#    sw $s6,($sp) # ... onto stack
2528#    addu $t2,$t0,5 # GC tag, incl. for count-word
2532#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2536#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2540#    srl $s6,$s6,2  # data words in object
2544#    move $s7,$zero # object words in object
2548#    jal newObject  # allocate space
    
    # store header words
2552#    la $t0,CLASS_String
2556#    sw $t0,-12($s7)# store class tag (String) into object
2560#    lw $t2,4($sp) # char-count
2564#    sll $t1,$t2,2 # 4 times number of chars
2568#    subu $t2,$zero,$t2 # negative of char-count
2572#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2576#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2580#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2581##...slt $at,$t0,$zero
2585##...beq $at,$zero,2604
2588#    and $t0,0xff # mask off object's hash value ...
2589##...lui $at,0
2593##...ori $at,$at,0xff
2597##...and $t0,$t0,$at
2600#    sw $t0,-8($s7) # ... and store back into -8 header-word
2604:  skipMask_readLine:

2604#    sll $t0,$t0,2 # data bytes in object
2608#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2612#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2616#    addu $sp,$sp,8 # pop redundant object-pointer and count
2620#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2624#    beq $sp,$t1,rlReturn
2628:  charCopyLoop:
2628#    lw $t2,($sp)
2632#    sb $t2,-9($t0)
2636#    addu $sp,$sp,4
2640#    subu $t0,$t0,1
2644#    bne $sp,$t1,charCopyLoop
2648:  rlReturn:

2648#    lw $ra, 4($sp)
2652#    addu $sp, 8   # pop $ra and pointless word off stack
2656#    move $t0, $s7 # return string we allocated in $s7
2660#    jr $ra

6737##...addiu $at,$at,-28718
6741##...addu $t1,$at,$t1
6744#    sw $t1,prevHashConstant # update hash constant
6748#    or $t1,0x80000000 # set top bit
6749##...lui $at,32768
6753##...or $t1,$at,$t1
6756#    and $t1,0xffffff00 # clear low bit
6757##...lui $at,65535
6761##...ori $at,$at,0xff00
6765##...and $t1,$t1,$at
6768#    or $s6,$t1

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
5080:mth_readLine_Lib:
    
5080#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
5084#    sw $ra, 4($sp) # save $ra
5088#    move $t1,$sp # save "original" sp

5092:  doRead:

    # read the character
5092#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
5096#    subu $t2,$v0,13
5100#    bne $t2,$zero,notReturnRL
5104#    jal readLogicalChar
5108#    subu $t2,$v0,10 # check for newline
5112#    beq $t2,$zero,foundNewLine
5116#    sw $v0,lastCharRead # push back character into queue
5120#    j foundNewLine # go process the line

5124:  notReturnRL:

    # at this point, $v0 has our character

5124#    subu $t0,$v0,10
5128#    beq $t0,$zero,foundNewLine
5132#    blt $v0,$zero,foundEof
5133##...slt $at,$v0,$zero
5137##...bne $at,$zero,5152

    # we have a character, so push it onto stack
5140#    subu $sp,$sp,4
5144#    sw $v0,($sp)

    # loop back up to get next character
5148#    j doRead

5152:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
5152#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
5156#    li $s7, 0 # return-value: null
5160#    j rlReturn # return

5164:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
5164#    subu $t0,$t1,$sp # number of chars we read (times 4)
5168#    srl $s6,$t0,2 # number of words on stack with chars
5172#    subu $sp,$sp,4 # push char-count ...
5176#    sw $s6,($sp) # ... onto stack
5180#    addu $t2,$t0,5 # GC tag, incl. for count-word
5184#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
5188#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
5192#    srl $s6,$s6,2  # data words in object
5196#    move $s7,$zero # object words in object
5200#    jal newObject  # allocate space
    
    # store header words
5204#    la $t0,CLASS_String
5208#    sw $t0,-12($s7)# store class tag (String) into object
5212#    lw $t2,4($sp) # char-count
5216#    sll $t1,$t2,2 # 4 times number of chars
5220#    subu $t2,$zero,$t2 # negative of char-count
5224#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
5228#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
5232#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
5233##...slt $at,$t0,$zero
5237##...beq $at,$zero,5256
5240#    and $t0,0xff # mask off object's hash value ...
5241##...lui $at,0
5245##...ori $at,$at,0xff
5249##...and $t0,$t0,$at
5252#    sw $t0,-8($s7) # ... and store back into -8 header-word
5256:  skipMask_readLine:

5256#    sll $t0,$t0,2 # data bytes in object
5260#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
5264#    subu $t0,$t0,$t2 # place to store last character (plus 9)
5268#    addu $sp,$sp,8 # pop redundant object-pointer and count
5272#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

5276#    beq $sp,$t1,rlReturn
5280:  charCopyLoop:
5280#    lw $t2,($sp)
5284#    sb $t2,-9($t0)
5288#    addu $sp,$sp,4
5292#    subu $t0,$t0,1
5296#    bne $sp,$t1,charCopyLoop
5300:  rlReturn:

5300#    lw $ra, 4($sp)
5304#    addu $sp, 8   # pop $ra and pointless word off stack
5308#    move $t0, $s7 # return string we allocated in $s7
5312#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
5316:mth_readInt_Lib:

    # save $ra by pushing onto stack
5316#    subu $sp,$sp,4
5320#    sw $ra,($sp)

5324:  riSkipWhiteLoop:
    # read a character
5324#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
5328#    subu $t0,$v0,32
5332#    bgt $t0,$zero,nonWhite
5333##...slt $at,$zero,$t0
5337##...bne $at,$zero,5380
5340#    beq $t0,$zero,riSkipWhiteLoop # start over if space
5344#    subu $t0,$v0,10
5348#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
5352#    subu $t0,$v0,9
5356#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
5360#    subu $t0,$v0,13
5364#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
5368#    subu $t0,$v0,12
5372#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
5376#    j badIntegerFormat # illegal integer char: abort program

5380:  nonWhite:
5380#    subu $t0,$v0,'-'
5384#    li $t4,1 # final multiplier
5388#    bne $t0,$zero,helpReadInt # go read
5392#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
5396#    jal readLogicalChar

5400:  helpReadInt:
5400#    li $t2,10
5404#    subu $t1,$v0,'0' # convert digit to 0-9 value
5408#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
5409##...sltu $at,$t1,$t2
5413##...beq $at,$zero,7660
5416#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

5420:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

5420#    jal readLogicalChar # read next character
5424#    subu $t1,$v0,'0' # convert digit to 0-9 value
5428#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
5429##...sltu $at,$t1,$t2
5433##...beq $at,$zero,5452

5436#    mul $t3,$t3,$t2 # multiply old value by 10
5437##...mult $t3,$t2
5441##...mflo $t3
5444#    addu $t3,$t3,$t1 # add in value of new digit
5448#    j digitLoop

5452:  doneDigitLoop:

    # "push back" unused character into queue
5452#    sw $v0,lastCharRead

    # restore return address
5456#    lw $ra,($sp)
5460#    addu $sp, 4

    # multiply by sign and put return value in $t0
5464#    mult $t3,$t4 # multiply to account for poss. minus sign
5468#    mflo $t3
5472#    move $t0, $t3
    
    # return
5476#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
5480:mth_readChar_Lib:

    # buffer and return
6628#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
6632#    jr $ra # return
    
6636:  doReadCh:
    # we need to actually read a character: read and return
6636#    li $v0,12 # use system call to read a character
6640#    syscall
6644#    jr $ra # return

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
4996:mth_equals_String:
    
    # quick test for obvious false
4996#    lw $t0,($sp) # second parameter
5000#    beq $t0,$zero,goEsFalse # go return false if null
5004#    lw $t1,-12($t0) # vtable pointer
5008#    la $t2,CLASS_String # string vtable pointer
5012#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
5016#    subu $sp,12
5020#    sw $ra,8($sp)
5024#    sw $s2,4($sp)
5028#    sw $t0,($sp)
5032#    jal mth_compareTo_String
5036#    lw $s2, 4($sp) #restore this pointer and pop parameters
5040#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
5044#    seq $t0,$t0,$zero
5045##...subu $at,$t0,$zero
5049##...sltiu $t0,$at,1

    # pop return address and return $t0
5052#    lw $ra,($sp)
5056#    addu $sp,4

5060#    jr $ra # return
    
5064:goEsFalse:
    # put 0 in $t0 and return
5064#    li $t0, 0
5068#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object

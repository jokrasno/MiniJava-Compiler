##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
4572:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
4572#    lw $t0,-8($s2) # get word with hash bits from this
4576#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
4580#    addu $t0,$t1

4584#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
4588:mth_equals_Object:
4588#    move $t0,$s2 # first pointer (this)
4592#    lw $t1,($sp) # second pointer
4596#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
4597##...subu $at,$t0,$t1
4601##...sltiu $t0,$at,1

4604#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
4608:mth_hashCode_String:
4608#    move $t0,$s2 # put this pointer in t0

4612#    li $t2,0 # current hash value
4616#    lw $t1,-4($t0) # negative of number of characters in string
4620#    beq $t1,$zero,done_hashCode_String # if zero length => done
4624#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
4628#    and $t0,0xfffffffc # adjust for padding
4629##...lui $at,65535
4633##...ori $at,$at,0xfffc
4637##...and $t0,$t0,$at
4640#    subu $t1,$t0,$t1 # address at end of string +12
4644:loop_hashCode_String:    
4644#    sll $t4,$t2,5 # multiply by 32
4648#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
4652#    lbu $t3,-12($t0) # current character
4656#    addu $t2,$t3 # add in current character
4660#    addu $t0,1 # go to next character's address
4664#    bne $t0,$t1,loop_hashCode_String # loop back if more
4668:done_hashCode_String:    

    # push int on stack
4668#    move $t0, $t2 # put $t2 in return slot
4672#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
4676:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
4676#    subu $sp,4
4680#    sw $ra,($sp)
    
    # get hash value
4684#    lw $t2,-12($s2) # vtable address
4688#    lw $t0,($t2) # method address
4692#    jalr $t0
4696#    subu $sp,8 # push result (int in $t0) on stack
4700#    sw $s5,4($sp)
4704#    sw $t0,($sp)

    # compute print-size of hash value
4708#    li $t0, 1
4712#    lw $t1, ($sp)
4716#    srl $t1,$t1,4
4720#    beq $t1,$zero,toString_skip_loop
4724:toString_loop_top:
4724#    addu $t0,1
4728#    srl $t1,$t1,4
4732#    bne $t1,$zero,toString_loop_top
4736:toString_skip_loop:
4736#    subu $sp,8
4740#    sw $s5,4($sp)
4744#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
4748#    lw $t2,-12($s2) # vtable address
4752#    move $t0,$t2
4756:toString_checkTagBit:
4756#    subu $t0,1
4760#    lb $t1,($t0)
4764#    and $t1,0x80
4765##...lui $at,0
4769##...ori $at,$at,0x80
4773##...and $t1,$t1,$at
4776#    beq $t1,$zero,toString_checkTagBit
4780#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
4784#    subu $sp,8
4788#    sw $t1,($sp)
4792#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
4796#    move $s7,$zero # -4 offset header word
4800#    lw $t4,8($sp) # bytes for hash value
4804#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
4808#    addu $t4,8
4812#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
4816#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

4820#    li $t0,CLASS_String # store string vtable address into ...
4824#    sw $t0,-12($s7) # ... -12 offset in object header
4828#    lw $t2,-12($s2) # our object's vtable address
4832#    lw $t5,4($sp) # number characters in prefix
4836#    lw $t1,12($sp) # number of characters in hashcode
4840#    addu $t3,$t1,$t5 # number of characters in string ...
4844#    addu $t3,1 # ... including the '@' character
4848#    subu $t0,$zero,$t3 # store negated length into ...
4852#    sw $t0,-4($s7) # ... -4 offset header word
4856#    lw $t0,-8($s7) # get -8 offset header-word
4860#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
4861##...slt $at,$t0,$zero
4865##...beq $at,$zero,4884
4868#    and $t0,0xff # mask off object's hash value ...
4869##...lui $at,0
4873##...ori $at,$at,0xff
4877##...and $t0,$t0,$at
4880#    sw $t0,-8($s7) # ... and store back into -8 header-word
4884:skipMask_toString:
4884#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
4888#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
4892#    subu $t4,$t2,$t5
4896:toString_copyLoop:    
4896#    lb $t3,($t4)
4900#    and $t3,0x7f # mask off sign bit (in case first word)
4901##...lui $at,0
4905##...ori $at,$at,0x7f
4909##...and $t3,$t3,$at
4912#    sb $t3,-8($t0)
4916#    addu $t4,1
4920#    addu $t0,1
4924#    blt $t4,$t2,toString_copyLoop
4925##...slt $at,$t4,$t2
4929##...bne $at,$zero,4896

    # copy the '@' sign
4932#    li $t3,'@'
4936#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
4940#    addu $t2,$t0,$t1 # address of last byte in string to store +8
4944#    lw $t3,20($sp) # hash code to print
4948:toString_hashCopyLoop:
4948#    and $t4,$t3,0xf
4952#    srl $t3,4
4956#    lb $t4,hexChars($t4)
4960#    sb $t4,-8($t2)
4964#    subu $t2,$t2,1
4968#    bgt $t2,$t0,toString_hashCopyLoop
4969##...slt $at,$t0,$t2
4973##...bne $at,$zero,4948

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
4976#    addu $sp,28
4980#    lw $ra,($sp)
4984#    addu $sp,4
4988#    move $t0, $s7 # return string we created
4992#    jr $ra

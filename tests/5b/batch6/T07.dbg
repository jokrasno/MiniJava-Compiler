    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
7276#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
7277##...slt $at,$t8,$zero
7281##...beq $at,$zero,7296
7284#    and $t8,0xff # mask off hash bits
7285##...lui $at,0
7289##...ori $at,$at,0xff
7293##...and $t8,$t8,$at

7296:  gcSkip5:
7296#    sll $t8,$t8,2 # bytes in negative-offset portion ...
7300#    addu $t8,$t8,8 # ... add in bytes for header-words
7304#    subu $t4,$t1,$t8 # address of first word of source object
7308#    lw $t3,-4($t1) # # words in positive-offset portion
7312#    bge $t3,$zero,gcNoNeg
7313##...slt $at,$t3,$zero
7317##...beq $at,$zero,7324
7320#    move $t3,$zero # negative treated as zero
7324:  gcNoNeg:
7324#    sll $t3,$t3,2 # bytes in negative-offset portion
7328#    addu $t3,$t3,$t1 # address one word past last word of source

7332#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
7336#    lw $s0,($t4)
7340#    lw $t9,-8($t1)
7344#    sw $t9,($t4)
7348#    sw $s0,-8($t1)

    # copy all source bytes to the target
7352:  gCinnerCopy2:
7352#    lw $s0,($t4)
7356#    sw $s0,($s3)
7360#    addu $t4,$t4,4
7364#    addu $s3,$s3,4
7368#    bltu $t4,$t3,gCinnerCopy2
7369##...sltu $at,$t4,$t3
7373##...bne $at,$zero,7352

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
7376#    sw $zero,-8($t1) # 0 in first header-slot
7380#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
7384#    sw $t8,($t0)

7388:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
7388#    addu $t0,$t0,4
7392#    bltu $t0,$s1,gcNextPointerInObject
7393##...sltu $at,$t0,$s1
7397##...bne $at,$zero,7236

7400:  gcTestIterDone2:
7400#    bltu $t0,$s3,gcHeapCopyLoop
7401##...sltu $at,$t0,$s3
7405##...bne $at,$zero,7120

    ###### end outer loop to copy all non-stack-direct objects ######

7408:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
7408#    lw $s2,($sp)
7412#    addu $sp,$sp,4

    # mark us as having already GC'd
7416#    move $t5,$s5

    # go try and allocate again
7420#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
7424:vm_init:

    # mark bottom of stack
7424#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
7428#    move $s2,$zero

    #set up the "five" register
7432#    li $s5,5

7436#    la $s3,seg0_start
7440#    la $s4,seg0_end
7441##...lui $s4,16
7445##...addiu $s4,$s4,8316
    
    # return
7448#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
7452:divide:
    # get parameters; abort if divisor zero
7452#    lw $t0,($sp)
7456#    lw $t1,8($sp)
7460#    beq $t0,$zero,divByZeroError
    
    # perform division
7464#    div $t1,$t0
7468#    mflo $t0

    # store result, adjust stack and return
7472#    addu $sp,$sp,8 # adjust stack
7476#    sw $t0,($sp) # store result
7480#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
7484:remainder:
    # get parameters; abort if divisor zero
7484#    lw $t0,($sp)
7488#    lw $t1,8($sp)
7492#    beq $t0,$zero,divByZeroError
    
    # perform division
7496#    div $t1,$t0
7500#    mfhi $t0

    # store result, adjust stack and return
7504#    addu $sp,$sp,8 # adjust stack
7508#    sw $t0,($sp) # store result
7512#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
7516:checkCast:
    # get object, allow immediately if null
7516#    lw $t2,($sp)
7520#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
7524#    lw $t2,-12($t2) # vtable address
7528#    bge $t2,$t1,castException
7529##...slt $at,$t2,$t1
7533##...beq $at,$zero,7668
7536#    blt $t2,$t0,castException
7537##...slt $at,$t2,$t0
7541##...bne $at,$zero,7668
    
    # return, leaving object unchanged on stack
7544:  checkCastReturn:    
7544#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
7548:instanceOf:
    # get object, go return false if null
7548#    lw $t2,($sp)
7552#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
7556#    lw $t2,-12($t2) # vtable address
7560#    sge $t0,$t2,$t0 # are we >= the lower limit?
7561##...slt $t0,$t2,$t0
7565##...xori $t0,$t0,0x1
7568#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
7572#    and $t2,$t0,$t1
7576#    sw $t2,($sp)
7580:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
7580#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

7584:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
7584#    li $v0,4 # syscall-code for print-string
7588#    syscall
7592:exit:
    # print termination message
7592#    li $v0,4 # syscall-code for print-string
7596#    la $a0,exitString
7600#    syscall

    # terminate execution
7604#    li $v0,10 #syscall-code for "exit"
7608#    syscall

7612:outOfHeapMemory:
7612#    la $a0,heapMemoryMsg
7616#    j exitError
7620:divByZeroError:
7620#    la $a0,divByZeroMsg
7624#    j exitError
7628:strIndexOutOfBounds:
7628#    la $a0,strIndexOutOfBoundsMsg
7632#    j exitError
7636:arrayIndexOutOfBounds:
7636#    la $a0,arrayIndexOutOfBoundsMsg
7640#    j exitError
7644:arraySizeOutOfBounds:
7644#    la $a0,arraySizeOutOfBoundsMsg
7648#    j exitError
7652:nullPtrException:
7652#    la $a0,nullPtrExceptionMsg
7656#    j exitError
7660:badIntegerFormat:
7660#    la $a0,badIntegerFormatMsg
7664#    j exitError
7668:castException:
7668#    la $a0,castExceptionMsg
7672#    j exitError
############## data section ################
    .data
7952:hexChars:
    .ascii "0123456789abcdef"
    .align 2
7968:cur_seg:
    .word 0

7972:lastCharRead:
    .word -2 # -2 => no buffered character
7976:prevHashConstant:
    .word 0x2785173c
7980:gcCount:
    .word 0

7984:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
8011:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
8034:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
8069:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
8103:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
8136:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
8167:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
8215:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
8236:gcMsg: 
      .asciiz "\nGC!\n"
8242:gcCountMsg: 
      .asciiz "Number of garbage collections: "

8274:nullStr:
    .asciiz "null"
8279:trueString:
    .asciiz "true"
8284:falseString:
    .asciiz "false"
8290:exitString:
    .ascii "Program terminated."
    #### "falls through" here
8309:newlineString:
    .asciiz "\n"
    
    .align 2
8312:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

8316:seg0_start:
    .space 0x100000
1056892:seg0_end:
1056892:seg1_start:
    .space 0x100000
2105468:seg1_end:

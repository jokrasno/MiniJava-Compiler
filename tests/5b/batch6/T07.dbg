6660#    addu $t0,$s6,$s7
6664#    sll $t0,$t0,2
6668#    addu $t0,$t0,8 # amount of memory needed
6672#    addu $t1,$t0,$s3
6676#    bgtu $t1,$s4,doGC
6677##...sltu $at,$s4,$t1
6681##...bne $at,$zero,6804

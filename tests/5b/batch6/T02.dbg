# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
3088:mth_compareTo_String:
    # get string pointers and check parameter for null
3088#    lw $t0,($sp) # second string
3092#    beq $t0,$zero,nullPtrException
3096#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
3100#    lw $t2,-4($t0) # negative length of second string
3104#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
3108#    slt $t4,$t3,$t2
3112#    slt $t5,$t2,$t3
3116#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
3120#    lw $t2,-8($t0) # # data words in second string
3124#    lw $t3,-8($t1) # # data words in first string
3128#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
3132#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
3136#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
3140#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
3144#    beq $zero,$t5,skipStrCmpLenzz
3148#    move $t2,$t3
3152:  skipStrCmpLenzz:
3152#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
3156:  cmpLoopzz:
3156#    lw $t3,-8($t1) # word from str2
3160#    lw $t4,-8($t0) # word from str1
3164#    bne $t3,$t4,cmpNotEqualzz
3168#    addu $t1,$t1,4
3172#    addu $t0,$t0,4
3176#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
3180#    j cmpHitLimitzz

3184:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
3184#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
3188#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
3192#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
3196:  cmpHitLimitzz:
3196#    move $t0, $t5 # store return value
3200#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
3204:readLogicalChar:

    # check if we already have a character
3204#    lw $v0,lastCharRead
3208#    li $t0,-2
3212#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
3216#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
3220#    jr $ra # return
    
3224:  doReadCh:
    # we need to actually read a character: read and return
3224#    li $v0,12 # use system call to read a character
3228#    syscall
3232#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
3236:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
3236#    blt $s7,$zero arraySizeOutOfBounds
3237##...slt $at,$s7,$zero
3241##...bne $at,$zero,4232

    # mark the fact that we have not yet GC'd for this allocation
3244#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

3248:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
3248#    addu $t0,$s6,$s7
3252#    sll $t0,$t0,2
3256#    addu $t0,$t0,8 # amount of memory needed
3260#    addu $t1,$t0,$s3
3264#    bgtu $t1,$s4,doGC
3265##...sltu $at,$s4,$t1
3269##...bne $at,$zero,3392

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
3272#    move $t2,$s3
3276:  zeroObjLoop:
3276#    sw $zero,($s3)
3280#    lw $zero,($s3)

3284#    addu $s3,4
3288#    bltu $s3,$t1,zeroObjLoop
3289##...sltu $at,$s3,$t1
3293##...bne $at,$zero,3276

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
3296#    sll $t0,$s7,2    # number of post-header bytes
3300#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
3304#    li $t2,255
3308#    bgeu $s6,$t2 firstHeaderLarge
3309##...sltu $at,$s6,$t2
3313##...beq $at,$zero,3360
3316#    lw $t1,prevHashConstant
3320#    addu $t1,0x12b68fd2
3321##...lui $at,4791
3325##...addiu $at,$at,-28718
3329##...addu $t1,$at,$t1
3332#    sw $t1,prevHashConstant # update hash constant
3336#    or $t1,0x80000000 # set top bit
3337##...lui $at,32768
3341##...or $t1,$at,$t1
3344#    and $t1,0xffffff00 # clear low bit
3345##...lui $at,65535
3349##...ori $at,$at,0xff00
3353##...and $t1,$t1,$at
3356#    or $s6,$t1
3360:firstHeaderLarge:
3360#    sw $s6,-8($t0) # store header-1 value
3364#    lw $zero,-8($t0)

    # store second header-value
3368#    sw $s7,-4($t0)   # second header-word
3372#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
3376#    move $s7,$t0
3380#    subu $sp,$sp,4
3384#    sw $t0,($sp)

3388#    jr $ra
    
3392:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
3392#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
3396#    lw $t5,gcCount
3400#    addu $t5,1
3404#    sw $t5,gcCount

    # save $s2 (our only rooted register) on the stack
    # so that the garbage collector processes it
3408#    subu $sp,$sp,4
3412#    sw $s2,($sp)

    # set $s3 to the address of the new segment and the
    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
3416#    lw $t0,cur_seg
3420#    move $t7,$s4
3424#    la $t6,seg1_start
3425##...lui $t6,16
3429##...addiu $t6,$t6,4852
3432#    la $s3,seg0_start
3436#    la $s4,seg0_end
3437##...lui $s4,16
3441##...addiu $s4,$s4,4852
3444#    sw $zero,cur_seg
3448#    bne $t0,$zero,skipGc1
3452#    la $t6,seg0_start
3456#    la $s3,seg1_start
3457##...lui $s3,16
3461##...addiu $s3,$s3,4852
3464#    la $s4,seg1_end
3465##...lui $s4,32
3469##...addiu $s4,$s4,4852
3472#    sw $s5,cur_seg
3476:  skipGc1:
3476#    li $t5,0x80000000
3480#    lw $t0,stack_bottom
3484#    subu $t0,4


    ###############################################################
    # at this point:
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first address of the target space
    # - $s4 contains the limit address of the target space
    # - cur_seg has been updated to refer to the target space
    # - $t0 contains the address of the deepest stack element
    # - $sp contains the address of the top stack element
    # - $s2 is available for use, having been pushed onto the stack
    # - $t5 contains the value 0x80000000
    ###############################################################

    ###### begin outer loop to copy all stack-direct objects ######

3488:  gcStackCopyLoop:
3488#    lw $t1,($t0) # current stack element

    # test if we have a GC tag
3492#    sll $t2,$t1,31 # zero iff low bit was zero
3496#    bne $t2,$zero,gcBump # go skip data values if low bit not zero

    # bump stack-address pointer
3500#    subu $t0,$t0,4

    # if value is out of range (which includes null=0), and is
    # therefore does not refer to an object on the heap, just go
    # loop back and do the next one
3504#    bleu $t1,$t6,gcTestIterDone1
3505##...sltu $at,$t6,$t1
3509##...beq $at,$zero,3672
3512#    bgtu $t1,$t7,gcTestIterDone1
3513##...sltu $at,$t7,$t1
3517##...bne $at,$zero,3672

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3520#    lw $t2,-8($t1) # possible forwarding tag
3524#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
3528#    lw $t2,-4($t1) # forwarding pointer: object's new address
3532#    sw $t2,4($t0) # update stack value
3536#    j gcTestIterDone1 # do next iteration

3540:  gcNoForward1:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    # compute the amount of space that is needed
3540#    bge $t2,$zero,gcSkip2
3541##...slt $at,$t2,$zero
3545##...beq $at,$zero,3560
3548#    and $t2,0xff #### mask off hash value
3549##...lui $at,0
3553##...ori $at,$at,0xff
3557##...and $t2,$t2,$at
    #### OLD
    #### subu $t2,$zero,$t2 # set to 1 if -1 (number of data words)

3560:  gcSkip2:
3560#    sll $t2,$t2,2
3564#    addu $t2,$t2,8
3568#    subu $t4,$t1,$t2 # address of first word of source
3572#    lw $t3,-4($t1) # number of object words (negative means zero)
3576#    bge $t3,$zero,gcH2Neg1
3577##...slt $at,$t3,$zero
3581##...beq $at,$zero,3588
3584#    move $t3,$zero
3588:  gcH2Neg1:
3588#    sll $t3,$t3,2
3592#    addu $t3,$t3,$t1 # address one word past last word of source

3596#    addu $t2,$s3,$t2 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object (i.e., the address just beyond the object's header)
    # - $t2 contains the pointer to the target object
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0-2
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger" in the target space
3600#    lw $s0,($t4)
3604#    lw $s1,-8($t1)
3608#    sw $s1,($t4)
3612#    sw $s0,-8($t1)
    
    # copy all source bytes to the target
3616:  gCinnerCopy1:
3616#    lw $s0,($t4)
3620#    sw $s0,($s3)
3624#    addu $t4,$t4,4
3628#    addu $s3,$s3,4
3632#    bltu $t4,$t3,gCinnerCopy1
3633##...sltu $at,$t4,$t3
3637##...bne $at,$zero,3616

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3640#    sw $zero,-8($t1) # 0 in first header-slot
3644#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
3648#    sw $t2,4($t0)
3652#    lw $zero,-8($t2)
3656#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
3660#    j gcTestIterDone1

3664:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
3664#    subu $t0,$t0,$t1
3668#    subu $t0,$t0,3

3672:  gcTestIterDone1:
3672#    bgeu $t0,$sp,gcStackCopyLoop
3673##...sltu $at,$t0,$sp
3677##...beq $at,$zero,3488

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
3680#    lw $t1,cur_seg
3684#    la $t0,seg0_start
3688#    beq $t1,$zero,gcSkip4
3692#    la $t0,seg1_start
3693##...lui $t0,16
3697##...addiu $t0,$t0,4852


3700:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
3700#    bgeu $t0,$s3,gcFinishUp
3701##...sltu $at,$t0,$s3
3705##...beq $at,$zero,3996

    ###### begin outer loop to copy all non-stack-direct objects ######

3708:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
3708#    lw $t1,($t0) # (what will be) first header word for current object
3712#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
3716#    bge $t2,$zero,gcSkip4a # are there hash bits?
3717##...slt $at,$t2,$zero
3721##...beq $at,$zero,3736
3724#    and $t2,0xff # mask off hash bits
3725##...lui $at,0
3729##...ori $at,$at,0xff
3733##...and $t2,$t2,$at
3736:gcSkip4a:    
3736#    sll $t2,$t2,2 # # data bytes
3740#    addu $t2,$t2,8 # to skip header words
3744#    addu $t2,$t0,$t2 # pointer to new object
3748#    lw $t3,-8($t2) # word to swap
3752#    sw $t1,-8($t2) # store header word
3756#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3760#    lw $t1,-12($t2) # vtable pointer
3764#    li $t0,dataArrayVTableStart # address of vtable for first data array
3768#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3769##...slt $at,$t1,$t0
3773##...bne $at,$zero,3792

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3776:  skipToNextObj:
3776#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3780#    sll $t1,$t1,2 # convert to byte-count
3784#    addu $t0,$t2,$t1 # skip over object
3788#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3792:  gcNotDataArray:
3792#    lw $t3,-4($t2) # # object words (negative treated as zero)
3796#    bge $t3,$zero,gcH2Neg2
3797##...slt $at,$t3,$zero
3801##...beq $at,$zero,3808
3804#    move $t3,$zero
3808:  gcH2Neg2:
3808#    sll $t3,$t3,2 # # object bytes
3812#    move $t0,$t2 # address of first pointer in object
3816#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3820#    beq $t0,$s1,gcTestIterDone2
    
3824:  gcNextPointerInObject:
    # get pointer from object
3824#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3828#    bleu $t1,$t6,gcGoNextPointerSlot
3829##...sltu $at,$t6,$t1
3833##...beq $at,$zero,3976
3836#    bgtu $t1,$t7,gcGoNextPointerSlot
3837##...sltu $at,$t7,$t1
3841##...bne $at,$zero,3976

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3844#    lw $t8,-8($t1) # possible forwarding tag
3848#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3852#    lw $t8,-4($t1) # forwarding pointer: object's new address
3856#    sw $t8,($t0) # update pointer in object
3860#    j gcGoNextPointerSlot # do next iteration

3864:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3864#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3865##...slt $at,$t8,$zero
3869##...beq $at,$zero,3884
3872#    and $t8,0xff # mask off hash bits
3873##...lui $at,0
3877##...ori $at,$at,0xff
3881##...and $t8,$t8,$at

3884:  gcSkip5:
3884#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3888#    addu $t8,$t8,8 # ... add in bytes for header-words
3892#    subu $t4,$t1,$t8 # address of first word of source object
3896#    lw $t3,-4($t1) # # words in positive-offset portion
3900#    bge $t3,$zero,gcNoNeg
3901##...slt $at,$t3,$zero
3905##...beq $at,$zero,3912
3908#    move $t3,$zero # negative treated as zero
3912:  gcNoNeg:
3912#    sll $t3,$t3,2 # bytes in negative-offset portion
3916#    addu $t3,$t3,$t1 # address one word past last word of source

3920#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3924#    lw $s0,($t4)
3928#    lw $t9,-8($t1)
3932#    sw $t9,($t4)
3936#    sw $s0,-8($t1)

    # copy all source bytes to the target
3940:  gCinnerCopy2:
3940#    lw $s0,($t4)
3944#    sw $s0,($s3)
3948#    addu $t4,$t4,4
3952#    addu $s3,$s3,4
3956#    bltu $t4,$t3,gCinnerCopy2
3957##...sltu $at,$t4,$t3
3961##...bne $at,$zero,3940

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3964#    sw $zero,-8($t1) # 0 in first header-slot
3968#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3972#    sw $t8,($t0)

3976:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3976#    addu $t0,$t0,4
3980#    bltu $t0,$s1,gcNextPointerInObject
3981##...sltu $at,$t0,$s1
3985##...bne $at,$zero,3824

3988:  gcTestIterDone2:
3988#    bltu $t0,$s3,gcHeapCopyLoop
3989##...sltu $at,$t0,$s3
3993##...bne $at,$zero,3708

    ###### end outer loop to copy all non-stack-direct objects ######

3996:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3996#    lw $s2,($sp)
4000#    addu $sp,$sp,4

    # mark us as having already GC'd
4004#    move $t5,$s5

    # go try and allocate again
4008#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4012:vm_init:

    # mark bottom of stack
4012#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4016#    move $s2,$zero

    #set up the "five" register
4020#    li $s5,5

4024#    la $s3,seg0_start
4028#    la $s4,seg0_end
4029##...lui $s4,16
4033##...addiu $s4,$s4,4852
    
    # return
4036#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4040:divide:
    # get parameters; abort if divisor zero
4040#    lw $t0,($sp)
4044#    lw $t1,8($sp)
4048#    beq $t0,$zero,divByZeroError
    
    # perform division
4052#    div $t1,$t0
4056#    mflo $t0

    # store result, adjust stack and return
4060#    addu $sp,$sp,8 # adjust stack
4064#    sw $t0,($sp) # store result
4068#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4072:remainder:
    # get parameters; abort if divisor zero
4072#    lw $t0,($sp)
4076#    lw $t1,8($sp)
4080#    beq $t0,$zero,divByZeroError
    
    # perform division
4084#    div $t1,$t0
4088#    mfhi $t0

    # store result, adjust stack and return
4092#    addu $sp,$sp,8 # adjust stack
4096#    sw $t0,($sp) # store result
4100#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4104:checkCast:
    # get object, allow immediately if null
4104#    lw $t2,($sp)
4108#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4112#    lw $t2,-12($t2) # vtable address
4116#    bge $t2,$t1,castException
4117##...slt $at,$t2,$t1
4121##...beq $at,$zero,4256
4124#    blt $t2,$t0,castException
4125##...slt $at,$t2,$t0
4129##...bne $at,$zero,4256
    
    # return, leaving object unchanged on stack
4132:  checkCastReturn:    
4132#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4136:instanceOf:
    # get object, go return false if null
4136#    lw $t2,($sp)
4140#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4144#    lw $t2,-12($t2) # vtable address
4148#    sge $t0,$t2,$t0 # are we >= the lower limit?
4149##...slt $t0,$t2,$t0
4153##...xori $t0,$t0,0x1
4156#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4160#    and $t2,$t0,$t1
4164#    sw $t2,($sp)
4168:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4168#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4172:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4172#    li $v0,4 # syscall-code for print-string
4176#    syscall
4180:exit:
    # print termination message
4180#    li $v0,4 # syscall-code for print-string
4184#    la $a0,exitString
4188#    syscall

    # terminate execution
4192#    li $v0,10 #syscall-code for "exit"
4196#    syscall

4200:outOfHeapMemory:
4200#    la $a0,heapMemoryMsg
4204#    j exitError
4208:divByZeroError:
4208#    la $a0,divByZeroMsg
4212#    j exitError
4216:strIndexOutOfBounds:
4216#    la $a0,strIndexOutOfBoundsMsg
4220#    j exitError
4224:arrayIndexOutOfBounds:
4224#    la $a0,arrayIndexOutOfBoundsMsg
4228#    j exitError
4232:arraySizeOutOfBounds:
4232#    la $a0,arraySizeOutOfBoundsMsg
4236#    j exitError
4240:nullPtrException:
4240#    la $a0,nullPtrExceptionMsg
4244#    j exitError
4248:badIntegerFormat:
4248#    la $a0,badIntegerFormatMsg
4252#    j exitError
4256:castException:
4256#    la $a0,castExceptionMsg
4260#    j exitError
############## data section ################
    .data
4488:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4504:cur_seg:
    .word 0

4508:lastCharRead:
    .word -2 # -2 => no buffered character
4512:prevHashConstant:
    .word 0x2785173c
4516:gcCount:
    .word 0

4520:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4547:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4570:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4605:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4639:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4672:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4703:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4751:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4772:gcMsg: 
      .asciiz "\nGC!\n"
4778:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4810:nullStr:
    .asciiz "null"
4815:trueString:
    .asciiz "true"
4820:falseString:
    .asciiz "false"
4826:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4845:newlineString:
    .asciiz "\n"
    
    .align 2
4848:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4852:seg0_start:
    .space 0x100000
1053428:seg0_end:
1053428:seg1_start:
    .space 0x100000
2102004:seg1_end:

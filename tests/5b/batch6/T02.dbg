##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1160:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1160#    lw $t0,-8($s2) # get word with hash bits from this
1164#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1168#    addu $t0,$t1

1172#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1176:mth_equals_Object:
1176#    move $t0,$s2 # first pointer (this)
1180#    lw $t1,($sp) # second pointer
1184#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1185##...subu $at,$t0,$t1
1189##...sltiu $t0,$at,1

1192#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1196:mth_hashCode_String:
1196#    move $t0,$s2 # put this pointer in t0

1200#    li $t2,0 # current hash value
1204#    lw $t1,-4($t0) # negative of number of characters in string
1208#    beq $t1,$zero,done_hashCode_String # if zero length => done
1212#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1216#    and $t0,0xfffffffc # adjust for padding
1217##...lui $at,65535
1221##...ori $at,$at,0xfffc
1225##...and $t0,$t0,$at
1228#    subu $t1,$t0,$t1 # address at end of string +12
1232:loop_hashCode_String:    
1232#    sll $t4,$t2,5 # multiply by 32
1236#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1240#    lbu $t3,-12($t0) # current character
1244#    addu $t2,$t3 # add in current character
1248#    addu $t0,1 # go to next character's address
1252#    bne $t0,$t1,loop_hashCode_String # loop back if more
1256:done_hashCode_String:    

    # push int on stack
1256#    move $t0, $t2 # put $t2 in return slot
1260#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1264:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1264#    subu $sp,4
1268#    sw $ra,($sp)
    
    # get hash value
1272#    lw $t2,-12($s2) # vtable address
1276#    lw $t0,($t2) # method address
1280#    jalr $t0
1284#    subu $sp,8 # push result (int in $t0) on stack
1288#    sw $s5,4($sp)
1292#    sw $t0,($sp)

    # compute print-size of hash value
1296#    li $t0, 1
1300#    lw $t1, ($sp)
1304#    srl $t1,$t1,4
1308#    beq $t1,$zero,toString_skip_loop
1312:toString_loop_top:
1312#    addu $t0,1
1316#    srl $t1,$t1,4
1320#    bne $t1,$zero,toString_loop_top
1324:toString_skip_loop:
1324#    subu $sp,8
1328#    sw $s5,4($sp)
1332#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1336#    lw $t2,-12($s2) # vtable address
1340#    move $t0,$t2
1344:toString_checkTagBit:
1344#    subu $t0,1
1348#    lb $t1,($t0)
1352#    and $t1,0x80
1353##...lui $at,0
1357##...ori $at,$at,0x80
1361##...and $t1,$t1,$at
1364#    beq $t1,$zero,toString_checkTagBit
1368#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1372#    subu $sp,8
1376#    sw $t1,($sp)
1380#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1384#    move $s7,$zero # -4 offset header word
1388#    lw $t4,8($sp) # bytes for hash value
1392#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1396#    addu $t4,8
1400#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1404#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1408#    li $t0,CLASS_String # store string vtable address into ...
1412#    sw $t0,-12($s7) # ... -12 offset in object header
1416#    lw $t2,-12($s2) # our object's vtable address
1420#    lw $t5,4($sp) # number characters in prefix
1424#    lw $t1,12($sp) # number of characters in hashcode
1428#    addu $t3,$t1,$t5 # number of characters in string ...
1432#    addu $t3,1 # ... including the '@' character
1436#    subu $t0,$zero,$t3 # store negated length into ...
1440#    sw $t0,-4($s7) # ... -4 offset header word
1444#    lw $t0,-8($s7) # get -8 offset header-word
1448#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1449##...slt $at,$t0,$zero
1453##...beq $at,$zero,1472
1456#    and $t0,0xff # mask off object's hash value ...
1457##...lui $at,0
1461##...ori $at,$at,0xff
1465##...and $t0,$t0,$at
1468#    sw $t0,-8($s7) # ... and store back into -8 header-word
1472:skipMask_toString:
1472#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1476#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1480#    subu $t4,$t2,$t5
1484:toString_copyLoop:    
1484#    lb $t3,($t4)
1488#    and $t3,0x7f # mask off sign bit (in case first word)
1489##...lui $at,0
1493##...ori $at,$at,0x7f
1497##...and $t3,$t3,$at
1500#    sb $t3,-8($t0)
1504#    addu $t4,1
1508#    addu $t0,1
1512#    blt $t4,$t2,toString_copyLoop
1513##...slt $at,$t4,$t2
1517##...bne $at,$zero,1484

    # copy the '@' sign
1520#    li $t3,'@'
1524#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1528#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1532#    lw $t3,20($sp) # hash code to print
1536:toString_hashCopyLoop:
1536#    and $t4,$t3,0xf
1540#    srl $t3,4
1544#    lb $t4,hexChars($t4)
1548#    sb $t4,-8($t2)
1552#    subu $t2,$t2,1
1556#    bgt $t2,$t0,toString_hashCopyLoop
1557##...slt $at,$t0,$t2
1561##...bne $at,$zero,1536

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1564#    addu $sp,28
1568#    lw $ra,($sp)
1572#    addu $sp,4
1576#    move $t0, $s7 # return string we created
1580#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1584:mth_equals_String:
    
    # quick test for obvious false
1584#    lw $t0,($sp) # second parameter
1588#    beq $t0,$zero,goEsFalse # go return false if null
1592#    lw $t1,-12($t0) # vtable pointer
1596#    la $t2,CLASS_String # string vtable pointer
1600#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1604#    subu $sp,12
1608#    sw $ra,8($sp)
1612#    sw $s2,4($sp)
1616#    sw $t0,($sp)
1620#    jal mth_compareTo_String
1624#    lw $s2, 4($sp) #restore this pointer and pop parameters
1628#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1632#    seq $t0,$t0,$zero
1633##...subu $at,$t0,$zero
1637##...sltiu $t0,$at,1

    # pop return address and return $t0
1640#    lw $ra,($sp)
1644#    addu $sp,4

1648#    jr $ra # return
    
1652:goEsFalse:
    # put 0 in $t0 and return
1652#    li $t0, 0
1656#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1660:mth_toString_String:
    #we are a string, so return this.
1660#    move $t0, $s2
1664#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1668:mth_readLine_Lib:
    
1668#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1672#    sw $ra, 4($sp) # save $ra
1676#    move $t1,$sp # save "original" sp

1680:  doRead:

    # read the character
1680#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1684#    subu $t2,$v0,13
1688#    bne $t2,$zero,notReturnRL
1692#    jal readLogicalChar
1696#    subu $t2,$v0,10 # check for newline
1700#    beq $t2,$zero,foundNewLine
1704#    sw $v0,lastCharRead # push back character into queue
1708#    j foundNewLine # go process the line

1712:  notReturnRL:

    # at this point, $v0 has our character

1712#    subu $t0,$v0,10
1716#    beq $t0,$zero,foundNewLine
1720#    blt $v0,$zero,foundEof
1721##...slt $at,$v0,$zero
1725##...bne $at,$zero,1740

    # we have a character, so push it onto stack
1728#    subu $sp,$sp,4
1732#    sw $v0,($sp)

    # loop back up to get next character
1736#    j doRead

1740:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1740#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1744#    li $s7, 0 # return-value: null
1748#    j rlReturn # return

1752:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1752#    subu $t0,$t1,$sp # number of chars we read (times 4)
1756#    srl $s6,$t0,2 # number of words on stack with chars
1760#    subu $sp,$sp,4 # push char-count ...
1764#    sw $s6,($sp) # ... onto stack
1768#    addu $t2,$t0,5 # GC tag, incl. for count-word
1772#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1776#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1780#    srl $s6,$s6,2  # data words in object
1784#    move $s7,$zero # object words in object
1788#    jal newObject  # allocate space
    
    # store header words
1792#    la $t0,CLASS_String
1796#    sw $t0,-12($s7)# store class tag (String) into object
1800#    lw $t2,4($sp) # char-count
1804#    sll $t1,$t2,2 # 4 times number of chars
1808#    subu $t2,$zero,$t2 # negative of char-count
1812#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1816#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1820#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1821##...slt $at,$t0,$zero
1825##...beq $at,$zero,1844
1828#    and $t0,0xff # mask off object's hash value ...
1829##...lui $at,0
1833##...ori $at,$at,0xff
1837##...and $t0,$t0,$at
1840#    sw $t0,-8($s7) # ... and store back into -8 header-word
1844:  skipMask_readLine:

1844#    sll $t0,$t0,2 # data bytes in object
1848#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1852#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1856#    addu $sp,$sp,8 # pop redundant object-pointer and count
1860#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1864#    beq $sp,$t1,rlReturn
1868:  charCopyLoop:
1868#    lw $t2,($sp)
1872#    sb $t2,-9($t0)
1876#    addu $sp,$sp,4
1880#    subu $t0,$t0,1
1884#    bne $sp,$t1,charCopyLoop
1888:  rlReturn:

1888#    lw $ra, 4($sp)
1892#    addu $sp, 8   # pop $ra and pointless word off stack
1896#    move $t0, $s7 # return string we allocated in $s7
1900#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1904:mth_readInt_Lib:

    # save $ra by pushing onto stack
1904#    subu $sp,$sp,4
1908#    sw $ra,($sp)

1912:  riSkipWhiteLoop:
    # read a character
1912#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1916#    subu $t0,$v0,32
1920#    bgt $t0,$zero,nonWhite
1921##...slt $at,$zero,$t0
1925##...bne $at,$zero,1968
1928#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1932#    subu $t0,$v0,10
1936#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1940#    subu $t0,$v0,9
1944#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1948#    subu $t0,$v0,13
1952#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1956#    subu $t0,$v0,12
1960#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1964#    j badIntegerFormat # illegal integer char: abort program

1968:  nonWhite:
1968#    subu $t0,$v0,'-'
1972#    li $t4,1 # final multiplier
1976#    bne $t0,$zero,helpReadInt # go read
1980#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1984#    jal readLogicalChar

1988:  helpReadInt:
1988#    li $t2,10
1992#    subu $t1,$v0,'0' # convert digit to 0-9 value
1996#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1997##...sltu $at,$t1,$t2
2001##...beq $at,$zero,4248
2004#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2008:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2008#    jal readLogicalChar # read next character
2012#    subu $t1,$v0,'0' # convert digit to 0-9 value
2016#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2017##...sltu $at,$t1,$t2
2021##...beq $at,$zero,2040

2024#    mul $t3,$t3,$t2 # multiply old value by 10
2025##...mult $t3,$t2
2029##...mflo $t3
2032#    addu $t3,$t3,$t1 # add in value of new digit
2036#    j digitLoop

2040:  doneDigitLoop:

    # "push back" unused character into queue
2040#    sw $v0,lastCharRead

    # restore return address
2044#    lw $ra,($sp)
2048#    addu $sp, 4

    # multiply by sign and put return value in $t0
2052#    mult $t3,$t4 # multiply to account for poss. minus sign
2056#    mflo $t3
2060#    move $t0, $t3
    
    # return
2064#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2068:mth_readChar_Lib:

    # save $ra by pushing onto stack
2068#    subu $sp,$sp,4
2072#    sw $ra,($sp)

      # read the character
2076#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
2080#    lw $ra,($sp)
2084#    addu $sp, 4
2088#    move $t0, $v0

    # return
2092#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
2096:mth_printStr_Lib:
    # check for null, printing "(null)", if so
2096#    lw $t0,($sp)
2100#    bne $t0,$zero,psNotNull

    # print "(null)"
2104#    la $a0,nullStr
2108#    li $v0,4
2112#    syscall
2116#    j donePrintStr
    
2120:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
2120#    subu $t0,$t0,8
2124#    lw $t1,($t0) # number of data words, but needs modification
2128#    blt $t1,$zero,skipPrintStr1
2129##...slt $at,$t1,$zero
2133##...bne $at,$zero,2152
2136#    and $t1,0xff # mask out all but low byte
2137##...lui $at,0
2141##...ori $at,$at,0xff
2145##...and $t1,$t1,$at
2148#    b skipPrintStr2
2152:skipPrintStr1:
2152#    and $t1,0x7ffffff
2153##...lui $at,2047
2157##...ori $at,$at,0xffff
2161##...and $t1,$t1,$at
2164:skipPrintStr2:    
2164#    sll $t1,$t1,2
2168#    subu $t1,$t0,$t1 # first word in string
2172#    lw $t0,4($t0) # negative of string-length
2176#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
2180#    beq $t0,$t1,donePrintStr
2184:  psLoop:
2184#    lb $a0,($t1) # next byte
2188#    li $v0,11 # code for printing char

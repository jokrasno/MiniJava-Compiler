    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
3744#    lw $t1,cur_seg
3748#    la $t0,seg0_start
3752#    beq $t1,$zero,gcSkip4
3756#    la $t0,seg1_start
3757##...lui $t0,16
3761##...addiu $t0,$t0,5016


3764:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
3764#    bgeu $t0,$s3,gcFinishUp
3765##...sltu $at,$t0,$s3
3769##...beq $at,$zero,4060

    ###### begin outer loop to copy all non-stack-direct objects ######

3772:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
3772#    lw $t1,($t0) # (what will be) first header word for current object
3776#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
3780#    bge $t2,$zero,gcSkip4a # are there hash bits?
3781##...slt $at,$t2,$zero
3785##...beq $at,$zero,3800
3788#    and $t2,0xff # mask off hash bits
3789##...lui $at,0
3793##...ori $at,$at,0xff
3797##...and $t2,$t2,$at
3800:gcSkip4a:    
3800#    sll $t2,$t2,2 # # data bytes
3804#    addu $t2,$t2,8 # to skip header words
3808#    addu $t2,$t0,$t2 # pointer to new object
3812#    lw $t3,-8($t2) # word to swap
3816#    sw $t1,-8($t2) # store header word
3820#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3824#    lw $t1,-12($t2) # vtable pointer
3828#    li $t0,dataArrayVTableStart # address of vtable for first data array
3832#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3833##...slt $at,$t1,$t0
3837##...bne $at,$zero,3856

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3840:  skipToNextObj:
3840#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3844#    sll $t1,$t1,2 # convert to byte-count
3848#    addu $t0,$t2,$t1 # skip over object
3852#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3856:  gcNotDataArray:
3856#    lw $t3,-4($t2) # # object words (negative treated as zero)
3860#    bge $t3,$zero,gcH2Neg2
3861##...slt $at,$t3,$zero
3865##...beq $at,$zero,3872
3868#    move $t3,$zero
3872:  gcH2Neg2:
3872#    sll $t3,$t3,2 # # object bytes
3876#    move $t0,$t2 # address of first pointer in object
3880#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3884#    beq $t0,$s1,gcTestIterDone2
    
3888:  gcNextPointerInObject:
    # get pointer from object
3888#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3892#    bleu $t1,$t6,gcGoNextPointerSlot
3893##...sltu $at,$t6,$t1
3897##...beq $at,$zero,4040
3900#    bgtu $t1,$t7,gcGoNextPointerSlot
3901##...sltu $at,$t7,$t1
3905##...bne $at,$zero,4040

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3908#    lw $t8,-8($t1) # possible forwarding tag
3912#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3916#    lw $t8,-4($t1) # forwarding pointer: object's new address
3920#    sw $t8,($t0) # update pointer in object
3924#    j gcGoNextPointerSlot # do next iteration

3928:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3928#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3929##...slt $at,$t8,$zero
3933##...beq $at,$zero,3948
3936#    and $t8,0xff # mask off hash bits
3937##...lui $at,0
3941##...ori $at,$at,0xff
3945##...and $t8,$t8,$at

3948:  gcSkip5:
3948#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3952#    addu $t8,$t8,8 # ... add in bytes for header-words
3956#    subu $t4,$t1,$t8 # address of first word of source object
3960#    lw $t3,-4($t1) # # words in positive-offset portion
3964#    bge $t3,$zero,gcNoNeg
3965##...slt $at,$t3,$zero
3969##...beq $at,$zero,3976
3972#    move $t3,$zero # negative treated as zero
3976:  gcNoNeg:
3976#    sll $t3,$t3,2 # bytes in negative-offset portion
3980#    addu $t3,$t3,$t1 # address one word past last word of source

3984#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3988#    lw $s0,($t4)
3992#    lw $t9,-8($t1)
3996#    sw $t9,($t4)
4000#    sw $s0,-8($t1)

    # copy all source bytes to the target
4004:  gCinnerCopy2:
4004#    lw $s0,($t4)
4008#    sw $s0,($s3)
4012#    addu $t4,$t4,4
4016#    addu $s3,$s3,4
4020#    bltu $t4,$t3,gCinnerCopy2
4021##...sltu $at,$t4,$t3
4025##...bne $at,$zero,4004

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4028#    sw $zero,-8($t1) # 0 in first header-slot
4032#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4036#    sw $t8,($t0)

4040:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4040#    addu $t0,$t0,4
4044#    bltu $t0,$s1,gcNextPointerInObject
4045##...sltu $at,$t0,$s1
4049##...bne $at,$zero,3888

4052:  gcTestIterDone2:
4052#    bltu $t0,$s3,gcHeapCopyLoop
4053##...sltu $at,$t0,$s3
4057##...bne $at,$zero,3772

    ###### end outer loop to copy all non-stack-direct objects ######

4060:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4060#    lw $s2,($sp)
4064#    addu $sp,$sp,4

    # mark us as having already GC'd
4068#    move $t5,$s5

    # go try and allocate again
4072#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4076:vm_init:

    # mark bottom of stack
4076#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4080#    move $s2,$zero

    #set up the "five" register
4084#    li $s5,5

4088#    la $s3,seg0_start
4092#    la $s4,seg0_end
4093##...lui $s4,16
4097##...addiu $s4,$s4,5016
    
    # return
4100#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4104:divide:
    # get parameters; abort if divisor zero
4104#    lw $t0,($sp)
4108#    lw $t1,8($sp)
4112#    beq $t0,$zero,divByZeroError
    
    # perform division
4116#    div $t1,$t0
4120#    mflo $t0

    # store result, adjust stack and return
4124#    addu $sp,$sp,8 # adjust stack
4128#    sw $t0,($sp) # store result
4132#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4136:remainder:
    # get parameters; abort if divisor zero
4136#    lw $t0,($sp)
4140#    lw $t1,8($sp)
4144#    beq $t0,$zero,divByZeroError
    
    # perform division
4148#    div $t1,$t0
4152#    mfhi $t0

    # store result, adjust stack and return
4156#    addu $sp,$sp,8 # adjust stack
4160#    sw $t0,($sp) # store result
4164#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4168:checkCast:
    # get object, allow immediately if null
4168#    lw $t2,($sp)
4172#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4176#    lw $t2,-12($t2) # vtable address
4180#    bge $t2,$t1,castException
4181##...slt $at,$t2,$t1
4185##...beq $at,$zero,4320
4188#    blt $t2,$t0,castException
4189##...slt $at,$t2,$t0
4193##...bne $at,$zero,4320
    
    # return, leaving object unchanged on stack
4196:  checkCastReturn:    
4196#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4200:instanceOf:
    # get object, go return false if null
4200#    lw $t2,($sp)
4204#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4208#    lw $t2,-12($t2) # vtable address
4212#    sge $t0,$t2,$t0 # are we >= the lower limit?
4213##...slt $t0,$t2,$t0
4217##...xori $t0,$t0,0x1
4220#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4224#    and $t2,$t0,$t1
4228#    sw $t2,($sp)
4232:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4232#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4236:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4236#    li $v0,4 # syscall-code for print-string
4240#    syscall
4244:exit:
    # print termination message
4244#    li $v0,4 # syscall-code for print-string
4248#    la $a0,exitString
4252#    syscall

    # terminate execution
4256#    li $v0,10 #syscall-code for "exit"
4260#    syscall

4264:outOfHeapMemory:
4264#    la $a0,heapMemoryMsg
4268#    j exitError
4272:divByZeroError:
4272#    la $a0,divByZeroMsg
4276#    j exitError
4280:strIndexOutOfBounds:
4280#    la $a0,strIndexOutOfBoundsMsg
4284#    j exitError
4288:arrayIndexOutOfBounds:
4288#    la $a0,arrayIndexOutOfBoundsMsg
4292#    j exitError
4296:arraySizeOutOfBounds:
4296#    la $a0,arraySizeOutOfBoundsMsg
4300#    j exitError
4304:nullPtrException:
4304#    la $a0,nullPtrExceptionMsg
4308#    j exitError
4312:badIntegerFormat:
4312#    la $a0,badIntegerFormatMsg
4316#    j exitError
4320:castException:
4320#    la $a0,castExceptionMsg
4324#    j exitError
############## data section ################
    .data
4652:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4668:cur_seg:
    .word 0

4672:lastCharRead:
    .word -2 # -2 => no buffered character
4676:prevHashConstant:
    .word 0x2785173c
4680:gcCount:
    .word 0

4684:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4711:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4734:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4769:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4803:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4836:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4867:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4915:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4936:gcMsg: 
      .asciiz "\nGC!\n"
4942:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4974:nullStr:
    .asciiz "null"
4979:trueString:
    .asciiz "true"
4984:falseString:
    .asciiz "false"
4990:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5009:newlineString:
    .asciiz "\n"
    
    .align 2
5012:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5016:seg0_start:
    .space 0x100000
1053592:seg0_end:
1053592:seg1_start:
    .space 0x100000
2102168:seg1_end:

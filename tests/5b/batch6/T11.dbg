########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
2320:mth_substring_String:

    # save $ra by pushing onto stack
2320#    subu $sp,$sp,4
2324#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
2328#    move $t0,$s2
2332#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
2336#    lw $t0,-4($t0) # negative of string length
2340#    subu $t0,$zero,$t0 # string length
2344#    lw $t1,4($sp) # k
2348#    lw $t2,12($sp) # n
2352#    bgt $zero,$t2,strIndexOutOfBounds
2353##...slt $at,$t2,$zero
2357##...bne $at,$zero,4280
2360#    bgt $t2,$t1,strIndexOutOfBounds
2361##...slt $at,$t1,$t2
2365##...bne $at,$zero,4280
2368#    bgt $t1,$t0,strIndexOutOfBounds
2369##...slt $at,$t0,$t1
2373##...bne $at,$zero,4280

    # allocate memory
2376#    subu $s6,$t1,$t2 # # chars in target-string
2380#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
2384#    srl $s6,$s6,2 # convert bytes-count to word-count
2388#    move $s7,$zero # (no object-bytes in string)
2392#    jal newObject

    # store "String" tag in object-type field
2396#    la $t0,CLASS_String
2400#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
2404#    lw $t4,-8($s7) # data words in source string
2408#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
2409##...slt $at,$t4,$zero
2413##...beq $at,$zero,2432
2416#    and $t4,0xff # mask off object's hash value ...
2417##...lui $at,0
2421##...ori $at,$at,0xff
2425##...and $t4,$t4,$at
2428#    sw $t4,-8($s7) # ... and store back into -8 header-word
2432:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
2432#    lw $t1,8($sp) # k
2436#    lw $t2,16($sp) # n
2440#    subu $t0,$t2,$t1 # value to store
2444#    sw $t0,-4($s7) # store value
    
2448#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
2452#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
2456#    lw $t4,-8($t3) # data words in source string
2460#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
2464#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
2468#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
2472#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
2476#    lw $t2,-8($s7)   # data words in target string
2480#    sll $t2,$t2,2    # data bytes in target string
2484#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target
2488:  subCopyLoopzz:
2488#    lb $t4,-8($t3)
2492#    sb $t4,-8($t2)
2496#    addu $t2,$t2,1
2500#    addu $t3,$t3,1
2504#    blt $t3,$t1,subCopyLoopzz
2505##...slt $at,$t3,$t1
2509##...bne $at,$zero,2488
    
2512:  doneSubCopyzz:
    # restore return address, store return value, pop stack
2512#    lw $ra,4($sp) # restore $ra
2516#    addu $sp,$sp,8 # pop ra, and allocated newObject
2520#    move $t0, $s7 # we're returning the string we got back
                  # from newObject
    
    # return
2524#    jr $ra

########################################################
# length() - library method (class String)
# returns length of a string: Java: str.length()
# - parameters:
#   - ($sp) - old this pointer
# - return-value:
#   - $t0 - length of string
########################################################
2528:mth_length_String:

    # the length is the negative of 4($s2)
2528#    lw $t0,-4($s2) # -length
2532#    subu $t0,$zero,$t0

    # return
2536#    jr $ra


########################################################
# str1.concat(str2) - library method (class String)
# (as in Java)
# - parameters:
#   - ($sp) - the second string
#   - 4($sp) - old this pointer
#   - $s2 - the first string (this)
# - returns:
#   - $t0 - pointer to concatenated string
########################################################
2540:mth_concat_String:
    # save $ra by pushing onto stack
2540#    subu $sp,$sp,4
2544#    sw $ra, ($sp)

    # get string pointers and check parameter for null
2548#    lw $t0,4($sp)
2552#    beq $t0,$zero,nullPtrException
2556#    move $t1,$s2
    
    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
2560#    lw $t0,-4($t0) # negative size of second object
2564#    lw $t1,-4($t1) # negative size of first object
2568#    addu $s6,$t0,$t1 # sum of negative sizes
2572#    sra $s6,$s6,2 # negative word-size of char part
2576#    subu $s6,$zero,$s6 # word size of char part
2580#    addu $s6,$s6,1 # data word size, including v-table word
2584#    move $s7,$zero
2588#    jal newObject

    # store String vtable address in vtable address field
2592#    la $t0,CLASS_String
2596#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
2600#    lw $t4,-8($s7) # # data words in source string
2604#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
2605##...slt $at,$t4,$zero
2609##...beq $at,$zero,2628
2612#    and $t4,0xff # mask off object's hash value ...
2613##...lui $at,0
2617##...ori $at,$at,0xff
2621##...and $t4,$t4,$at
2624#    sw $t4,-8($s7) # ... and store back into -8 header-word
2628:skipMask_concat:

2628#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
2632#    move $t1,$s2   # first object
2636#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
2640#    lw $t2,-4($t0) # negative length of second object
2644#    lw $t3,-4($t1) # negative length of first object
2648#    addu $t4,$t2,$t3 # sum of negative lengths
2652#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################

    # compute addresses for moving data from first string
2656#    lw $t4,-8($t1) # # data words in first string
2660#    sll $t4,$t4,2 # # data bytes in first string
2664#    subu $t1,$t1,$t4 # addr. (+8) of first byte in first string
2668#    lw $t4,-8($s7) # # data words in new string
2672#    sll $t4,$t4,2 # # data bytes in new string
2676#    subu $s7,$s7,$t4 # addr. (+8) of first byte in new string
2680#    beq $zero,$t3,doneConcatLoop1zz # skip first loop is no bytes to copy
2684#    subu $t3,$t1,$t3 # limit (+8) address for first string

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is address (+8) of first byte in first object
    # - $t2 is negated length of second object
    # - $t3 is limit-address (+8) of data in first object
    # - $s7 is address (+8) of first byte in new object
    # - note: if data-length of first object is zero, then
    #   we skip over this part, and go to 'doneConcatLoop1'
    #########################################################

    # copy the bytes from first source to target
2688:  concatLoop1zz:
2688#    lb $t4,-8($t1)
2692#    sb $t4,-8($s7)
2696#    addu $s7,$s7,1
2700#    addu $t1,$t1,1
2704#    blt $t1,$t3,concatLoop1zz
2705##...slt $at,$t1,$t3
2709##...bne $at,$zero,2688
2712:  doneConcatLoop1zz:
  
    # if second string is empty, skip rest of copy
2712#    beq $zero,$t2,doneConcatLoop2zz

      # compute addresses for moving data from second string
2716#    lw $t4,-8($t0) # # data words in second string
2720#    sll $t4,$t4,2 # # data bytes in second string
2724#    subu $t1,$t0,$t4 # addr. (+8) of first byte in second string
2728#    subu $t3,$t1,$t2 # limit (+8) address for second string

    #########################################################
    # at this point:
    # - $t1 is address (+8) of first byte in second object
    # - $t3 is limit-address (+8) of data in second object
    # - $s7 is address (+8) of next byte to write new object
    # - note: if data-length of second object is zero, then
    #   we skip over this part, and go to 'doneConcatLoop2'
    #########################################################

    # copy the bytes from first source to target
2732:  concatLoop2zz:
2732#    lb $t4,-8($t1)
2736#    sb $t4,-8($s7)
2740#    addu $s7,$s7,1
2744#    addu $t1,$t1,1
2748#    blt $t1,$t3,concatLoop2zz
2749##...slt $at,$t1,$t3
2753##...bne $at,$zero,2732
2756:  doneConcatLoop2zz:
 
2756:  concatRtnzz:
    # return
2756#    move $t0, $t9 # put saved return string in $t0
2760#    lw $ra, 4($sp)
2764#    addu $sp, 8 # pop ra and allocated newObject
2768#    jr $ra

########################################################
# str.charAt(n) - library method (class String)
# accesses a character in a string, as in Java
# - parameters:
#   - ($sp) - the index, n
#   - 4($sp) - GC tag
#   - 8($sp) - old this pointer
#   - $s2    - this pointer
# - returns:
#   - $t0 - the character found.
########################################################
2772:mth_charAt_String:
    # get string
2772#    move $t0,$s2

    # check that index is in bounds
2776#    lw $t1,-4($t0) # negative of # data words in string
2780#    subu $t3,$zero,$t1 # # chars in string
2784#    lw $t2,($sp) # index
2788#    bgeu $t2,$t3,strIndexOutOfBounds
2789##...sltu $at,$t2,$t3
2793##...beq $at,$zero,4280

    # access element
2796#    lw $t1,-8($t0) # # data words in object
2800#    sll $t1,$t1,2 # - byte-offset from end of chars
2804#    subu $t1,$t2,$t1 # - address of first char in string, offset by 8
2808#    addu $t0,$t0,$t1 # - address of our char, offset by 8
2812#    lb $t0,-8($t0) # our char

    # return
2816#    jr $ra

########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
2820:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
2820#    subu $sp,$sp,8
2824#    sw $ra,4($sp)

    # save current sp
2828#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
2832#    li $t3,10

    # get argument, negate if negative
2836#    lw $t1,8($sp)
2840#    bge $t1,$zero,itsNonNegLoop
2841##...slt $at,$t1,$zero
2845##...beq $at,$zero,2852
2848#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
2852:  itsNonNegLoop:
2852#    divu $t1,$t3
2856#    mflo $t1 # quotient
2860#    mfhi $t4 # remainder
2864#    addu $t4,$t4,'0' # turn remainder into digit
2868#    subu $sp,$sp,4
2872#    sw $t4,($sp) # push digit onto stack
2876#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
2880#    lw $t4,8($t0)
2884#    bge $t4,$zero,itsSkipNeg
2885##...slt $at,$t4,$zero
2889##...beq $at,$zero,2904
2892#    li $t4,'-'
2896#    subu $sp,$sp,4
2900#    sw $t4,($sp)
2904:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
2904#    subu $s6,$t0,$sp
2908#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
2912#    sw $t3,($t0)
2916#    srl $s6,$s6,2
2920#    subu $sp,$sp,4
2924#    sw $s6,($sp)
    
    # allocate memory
2928#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
2932#    srl $s6,$s6,2
2936#    move $s7,$zero # no "object" words in object
2940#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
2944#    lw $t0,4($sp)
2948#    addu $sp,$sp,8

    # store "String" tag into class field
2952#    subu $s7,$s7,8 # address of header-1 word
2956#    la $t1,CLASS_String
2960#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
2964#    lw $t4,($s7) # # data words in source string
2968#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
2969##...slt $at,$t4,$zero
2973##...beq $at,$zero,2992
2976#    and $t4,0xff # mask off object's hash value ...
2977##...lui $at,0
2981##...ori $at,$at,0xff
2985##...and $t4,$t4,$at
2988#    sw $t4,($s7) # ... and store back into -8 header-word
2992:skipMask_intToString:
    
    # store negative of char-count into header-2 word
2992#    subu $t0,$zero,$t0
2996#    sw $t0,4($s7)

3000#    lw $t1,($s7) # number of data words in string
3004#    sll $t1,$t1,2 # number data bytes in string
3008#    subu $t1,$s7,$t1 # first location to store chars in string
3012#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
3016:  itsLoop:

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1224:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1224#    lw $t0,-8($s2) # get word with hash bits from this
1228#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1232#    addu $t0,$t1

1236#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1240:mth_equals_Object:
1240#    move $t0,$s2 # first pointer (this)
1244#    lw $t1,($sp) # second pointer
1248#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1249##...subu $at,$t0,$t1
1253##...sltiu $t0,$at,1

1256#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1260:mth_hashCode_String:
1260#    move $t0,$s2 # put this pointer in t0

1264#    li $t2,0 # current hash value
1268#    lw $t1,-4($t0) # negative of number of characters in string
1272#    beq $t1,$zero,done_hashCode_String # if zero length => done
1276#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1280#    and $t0,0xfffffffc # adjust for padding
1281##...lui $at,65535
1285##...ori $at,$at,0xfffc
1289##...and $t0,$t0,$at
1292#    subu $t1,$t0,$t1 # address at end of string +12
1296:loop_hashCode_String:    
1296#    sll $t4,$t2,5 # multiply by 32
1300#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1304#    lbu $t3,-12($t0) # current character
1308#    addu $t2,$t3 # add in current character
1312#    addu $t0,1 # go to next character's address
1316#    bne $t0,$t1,loop_hashCode_String # loop back if more
1320:done_hashCode_String:    

    # push int on stack
1320#    move $t0, $t2 # put $t2 in return slot
1324#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1328:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1328#    subu $sp,4
1332#    sw $ra,($sp)
    
    # get hash value
1336#    lw $t2,-12($s2) # vtable address
1340#    lw $t0,($t2) # method address
1344#    jalr $t0
1348#    subu $sp,8 # push result (int in $t0) on stack
1352#    sw $s5,4($sp)
1356#    sw $t0,($sp)

    # compute print-size of hash value
1360#    li $t0, 1
1364#    lw $t1, ($sp)
1368#    srl $t1,$t1,4
1372#    beq $t1,$zero,toString_skip_loop
1376:toString_loop_top:
1376#    addu $t0,1
1380#    srl $t1,$t1,4
1384#    bne $t1,$zero,toString_loop_top
1388:toString_skip_loop:
1388#    subu $sp,8
1392#    sw $s5,4($sp)
1396#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1400#    lw $t2,-12($s2) # vtable address
1404#    move $t0,$t2
1408:toString_checkTagBit:
1408#    subu $t0,1
1412#    lb $t1,($t0)
1416#    and $t1,0x80
1417##...lui $at,0
1421##...ori $at,$at,0x80
1425##...and $t1,$t1,$at
1428#    beq $t1,$zero,toString_checkTagBit
1432#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1436#    subu $sp,8
1440#    sw $t1,($sp)
1444#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1448#    move $s7,$zero # -4 offset header word
1452#    lw $t4,8($sp) # bytes for hash value
1456#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1460#    addu $t4,8
1464#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1468#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1472#    li $t0,CLASS_String # store string vtable address into ...
1476#    sw $t0,-12($s7) # ... -12 offset in object header
1480#    lw $t2,-12($s2) # our object's vtable address
1484#    lw $t5,4($sp) # number characters in prefix
1488#    lw $t1,12($sp) # number of characters in hashcode
1492#    addu $t3,$t1,$t5 # number of characters in string ...
1496#    addu $t3,1 # ... including the '@' character
1500#    subu $t0,$zero,$t3 # store negated length into ...
1504#    sw $t0,-4($s7) # ... -4 offset header word
1508#    lw $t0,-8($s7) # get -8 offset header-word
1512#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1513##...slt $at,$t0,$zero
1517##...beq $at,$zero,1536
1520#    and $t0,0xff # mask off object's hash value ...
1521##...lui $at,0
1525##...ori $at,$at,0xff
1529##...and $t0,$t0,$at
1532#    sw $t0,-8($s7) # ... and store back into -8 header-word
1536:skipMask_toString:
1536#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1540#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1544#    subu $t4,$t2,$t5
1548:toString_copyLoop:    
1548#    lb $t3,($t4)
1552#    and $t3,0x7f # mask off sign bit (in case first word)
1553##...lui $at,0
1557##...ori $at,$at,0x7f
1561##...and $t3,$t3,$at
1564#    sb $t3,-8($t0)
1568#    addu $t4,1
1572#    addu $t0,1
1576#    blt $t4,$t2,toString_copyLoop
1577##...slt $at,$t4,$t2
1581##...bne $at,$zero,1548

    # copy the '@' sign
1584#    li $t3,'@'
1588#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1592#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1596#    lw $t3,20($sp) # hash code to print
1600:toString_hashCopyLoop:
1600#    and $t4,$t3,0xf
1604#    srl $t3,4
1608#    lb $t4,hexChars($t4)
1612#    sb $t4,-8($t2)
1616#    subu $t2,$t2,1
1620#    bgt $t2,$t0,toString_hashCopyLoop
1621##...slt $at,$t0,$t2
1625##...bne $at,$zero,1600

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1628#    addu $sp,28
1632#    lw $ra,($sp)
1636#    addu $sp,4
1640#    move $t0, $s7 # return string we created
1644#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1648:mth_equals_String:
    
    # quick test for obvious false
1648#    lw $t0,($sp) # second parameter
1652#    beq $t0,$zero,goEsFalse # go return false if null
1656#    lw $t1,-12($t0) # vtable pointer
1660#    la $t2,CLASS_String # string vtable pointer
1664#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1668#    subu $sp,12
1672#    sw $ra,8($sp)
1676#    sw $s2,4($sp)
1680#    sw $t0,($sp)
1684#    jal mth_compareTo_String
1688#    lw $s2, 4($sp) #restore this pointer and pop parameters
1692#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1696#    seq $t0,$t0,$zero
1697##...subu $at,$t0,$zero
1701##...sltiu $t0,$at,1

    # pop return address and return $t0
1704#    lw $ra,($sp)
1708#    addu $sp,4

1712#    jr $ra # return
    
1716:goEsFalse:
    # put 0 in $t0 and return
1716#    li $t0, 0
1720#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1724:mth_toString_String:
    #we are a string, so return this.
1724#    move $t0, $s2
1728#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1732:mth_readLine_Lib:
    
1732#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1736#    sw $ra, 4($sp) # save $ra
1740#    move $t1,$sp # save "original" sp

1744:  doRead:

    # read the character
1744#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1748#    subu $t2,$v0,13
1752#    bne $t2,$zero,notReturnRL
1756#    jal readLogicalChar
1760#    subu $t2,$v0,10 # check for newline
1764#    beq $t2,$zero,foundNewLine
1768#    sw $v0,lastCharRead # push back character into queue
1772#    j foundNewLine # go process the line

1776:  notReturnRL:

    # at this point, $v0 has our character

1776#    subu $t0,$v0,10
1780#    beq $t0,$zero,foundNewLine
1784#    blt $v0,$zero,foundEof
1785##...slt $at,$v0,$zero
1789##...bne $at,$zero,1804

    # we have a character, so push it onto stack
1792#    subu $sp,$sp,4
1796#    sw $v0,($sp)

    # loop back up to get next character
1800#    j doRead

1804:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1804#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1808#    li $s7, 0 # return-value: null
1812#    j rlReturn # return

1816:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1816#    subu $t0,$t1,$sp # number of chars we read (times 4)
1820#    srl $s6,$t0,2 # number of words on stack with chars
1824#    subu $sp,$sp,4 # push char-count ...
1828#    sw $s6,($sp) # ... onto stack
1832#    addu $t2,$t0,5 # GC tag, incl. for count-word
1836#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1840#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1844#    srl $s6,$s6,2  # data words in object
1848#    move $s7,$zero # object words in object
1852#    jal newObject  # allocate space
    
    # store header words
1856#    la $t0,CLASS_String
1860#    sw $t0,-12($s7)# store class tag (String) into object
1864#    lw $t2,4($sp) # char-count
1868#    sll $t1,$t2,2 # 4 times number of chars
1872#    subu $t2,$zero,$t2 # negative of char-count
1876#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1880#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1884#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1885##...slt $at,$t0,$zero
1889##...beq $at,$zero,1908
1892#    and $t0,0xff # mask off object's hash value ...
1893##...lui $at,0
1897##...ori $at,$at,0xff
1901##...and $t0,$t0,$at
1904#    sw $t0,-8($s7) # ... and store back into -8 header-word
1908:  skipMask_readLine:

1908#    sll $t0,$t0,2 # data bytes in object
1912#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1916#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1920#    addu $sp,$sp,8 # pop redundant object-pointer and count
1924#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1928#    beq $sp,$t1,rlReturn
1932:  charCopyLoop:
1932#    lw $t2,($sp)
1936#    sb $t2,-9($t0)
1940#    addu $sp,$sp,4
1944#    subu $t0,$t0,1
1948#    bne $sp,$t1,charCopyLoop
1952:  rlReturn:

1952#    lw $ra, 4($sp)
1956#    addu $sp, 8   # pop $ra and pointless word off stack
1960#    move $t0, $s7 # return string we allocated in $s7
1964#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1968:mth_readInt_Lib:

    # save $ra by pushing onto stack
1968#    subu $sp,$sp,4
1972#    sw $ra,($sp)

1976:  riSkipWhiteLoop:
    # read a character
1976#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1980#    subu $t0,$v0,32
1984#    bgt $t0,$zero,nonWhite
1985##...slt $at,$zero,$t0
1989##...bne $at,$zero,2032
1992#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1996#    subu $t0,$v0,10
2000#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2004#    subu $t0,$v0,9
2008#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2012#    subu $t0,$v0,13
2016#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2020#    subu $t0,$v0,12
2024#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2028#    j badIntegerFormat # illegal integer char: abort program

2032:  nonWhite:
2032#    subu $t0,$v0,'-'
2036#    li $t4,1 # final multiplier
2040#    bne $t0,$zero,helpReadInt # go read
2044#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2048#    jal readLogicalChar

2052:  helpReadInt:
2052#    li $t2,10
2056#    subu $t1,$v0,'0' # convert digit to 0-9 value
2060#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2061##...sltu $at,$t1,$t2
2065##...beq $at,$zero,4312
2068#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2072:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2072#    jal readLogicalChar # read next character
2076#    subu $t1,$v0,'0' # convert digit to 0-9 value
2080#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2081##...sltu $at,$t1,$t2
2085##...beq $at,$zero,2104

2088#    mul $t3,$t3,$t2 # multiply old value by 10
2089##...mult $t3,$t2
2093##...mflo $t3
2096#    addu $t3,$t3,$t1 # add in value of new digit
2100#    j digitLoop

2104:  doneDigitLoop:

    # "push back" unused character into queue
2104#    sw $v0,lastCharRead

    # restore return address
2108#    lw $ra,($sp)
2112#    addu $sp, 4

    # multiply by sign and put return value in $t0
2116#    mult $t3,$t4 # multiply to account for poss. minus sign
2120#    mflo $t3
2124#    move $t0, $t3
    
    # return
2128#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2132:mth_readChar_Lib:

    # save $ra by pushing onto stack
2132#    subu $sp,$sp,4
2136#    sw $ra,($sp)

      # read the character
2140#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
2144#    lw $ra,($sp)
2148#    addu $sp, 4
2152#    move $t0, $v0

    # return
2156#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
2160:mth_printStr_Lib:
    # check for null, printing "(null)", if so
2160#    lw $t0,($sp)
2164#    bne $t0,$zero,psNotNull

    # print "(null)"
2168#    la $a0,nullStr
2172#    li $v0,4
2176#    syscall
2180#    j donePrintStr
    
2184:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
2184#    subu $t0,$t0,8
2188#    lw $t1,($t0) # number of data words, but needs modification
2192#    blt $t1,$zero,skipPrintStr1
2193##...slt $at,$t1,$zero
2197##...bne $at,$zero,2216
2200#    and $t1,0xff # mask out all but low byte
2201##...lui $at,0
2205##...ori $at,$at,0xff
2209##...and $t1,$t1,$at
2212#    b skipPrintStr2
2216:skipPrintStr1:
2216#    and $t1,0x7ffffff
2217##...lui $at,2047
2221##...ori $at,$at,0xffff
2225##...and $t1,$t1,$at
2228:skipPrintStr2:    
2228#    sll $t1,$t1,2
2232#    subu $t1,$t0,$t1 # first word in string
2236#    lw $t0,4($t0) # negative of string-length
2240#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
2244#    beq $t0,$t1,donePrintStr
2248:  psLoop:
2248#    lb $a0,($t1) # next byte
2252#    li $v0,11 # code for printing char
2256#        syscall # print the char
2260#    addu $t1,$t1,1 # go to next char
2264#    blt $t1,$t0,psLoop
2265##...slt $at,$t1,$t0
2269##...bne $at,$zero,2248

2272:  donePrintStr:
2272#    jr $ra


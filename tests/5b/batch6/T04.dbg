4028#    j gcTestIterDone1 # do next iteration

4032:  gcNoForward1:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    # compute the amount of space that is needed
4032#    bge $t2,$zero,gcSkip2
4033##...slt $at,$t2,$zero
4037##...beq $at,$zero,4052

3837##...lui $at,65535
3841##...ori $at,$at,0xff00
3845##...and $t1,$t1,$at
3848#    or $s6,$t1
3852:firstHeaderLarge:
3852#    sw $s6,-8($t0) # store header-1 value
3856#    lw $zero,-8($t0)

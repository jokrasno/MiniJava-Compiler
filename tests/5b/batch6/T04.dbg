    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4012#    lw $t2,-8($t1) # possible forwarding tag
4016#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
4020#    lw $t2,-4($t1) # forwarding pointer: object's new address

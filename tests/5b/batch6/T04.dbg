##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1652:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1652#    lw $t0,-8($s2) # get word with hash bits from this
1656#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1660#    addu $t0,$t1

1664#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1668:mth_equals_Object:
1668#    move $t0,$s2 # first pointer (this)
1672#    lw $t1,($sp) # second pointer
1676#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1677##...subu $at,$t0,$t1
1681##...sltiu $t0,$at,1

1684#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1688:mth_hashCode_String:
1688#    move $t0,$s2 # put this pointer in t0

1692#    li $t2,0 # current hash value
1696#    lw $t1,-4($t0) # negative of number of characters in string
1700#    beq $t1,$zero,done_hashCode_String # if zero length => done
1704#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1708#    and $t0,0xfffffffc # adjust for padding
1709##...lui $at,65535
1713##...ori $at,$at,0xfffc
1717##...and $t0,$t0,$at
1720#    subu $t1,$t0,$t1 # address at end of string +12
1724:loop_hashCode_String:    
1724#    sll $t4,$t2,5 # multiply by 32
1728#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1732#    lbu $t3,-12($t0) # current character
1736#    addu $t2,$t3 # add in current character
1740#    addu $t0,1 # go to next character's address
1744#    bne $t0,$t1,loop_hashCode_String # loop back if more
1748:done_hashCode_String:    

    # push int on stack
1748#    move $t0, $t2 # put $t2 in return slot
1752#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1756:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1756#    subu $sp,4
1760#    sw $ra,($sp)
    
    # get hash value
1764#    lw $t2,-12($s2) # vtable address
1768#    lw $t0,($t2) # method address
1772#    jalr $t0
1776#    subu $sp,8 # push result (int in $t0) on stack
1780#    sw $s5,4($sp)
1784#    sw $t0,($sp)

    # compute print-size of hash value
1788#    li $t0, 1
1792#    lw $t1, ($sp)
1796#    srl $t1,$t1,4
1800#    beq $t1,$zero,toString_skip_loop
1804:toString_loop_top:
1804#    addu $t0,1
1808#    srl $t1,$t1,4
1812#    bne $t1,$zero,toString_loop_top
1816:toString_skip_loop:
1816#    subu $sp,8
1820#    sw $s5,4($sp)
1824#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1828#    lw $t2,-12($s2) # vtable address
1832#    move $t0,$t2
1836:toString_checkTagBit:
1836#    subu $t0,1
1840#    lb $t1,($t0)
1844#    and $t1,0x80
1845##...lui $at,0
1849##...ori $at,$at,0x80
1853##...and $t1,$t1,$at
1856#    beq $t1,$zero,toString_checkTagBit
1860#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1864#    subu $sp,8
1868#    sw $t1,($sp)
1872#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1876#    move $s7,$zero # -4 offset header word
1880#    lw $t4,8($sp) # bytes for hash value
1884#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1888#    addu $t4,8
1892#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1896#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1900#    li $t0,CLASS_String # store string vtable address into ...
1904#    sw $t0,-12($s7) # ... -12 offset in object header
1908#    lw $t2,-12($s2) # our object's vtable address
1912#    lw $t5,4($sp) # number characters in prefix
1916#    lw $t1,12($sp) # number of characters in hashcode
1920#    addu $t3,$t1,$t5 # number of characters in string ...
1924#    addu $t3,1 # ... including the '@' character
1928#    subu $t0,$zero,$t3 # store negated length into ...
1932#    sw $t0,-4($s7) # ... -4 offset header word
1936#    lw $t0,-8($s7) # get -8 offset header-word
1940#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1941##...slt $at,$t0,$zero
1945##...beq $at,$zero,1964
1948#    and $t0,0xff # mask off object's hash value ...
1949##...lui $at,0
1953##...ori $at,$at,0xff
1957##...and $t0,$t0,$at
1960#    sw $t0,-8($s7) # ... and store back into -8 header-word
1964:skipMask_toString:
1964#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1968#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1972#    subu $t4,$t2,$t5
1976:toString_copyLoop:    
1976#    lb $t3,($t4)
1980#    and $t3,0x7f # mask off sign bit (in case first word)
1981##...lui $at,0
1985##...ori $at,$at,0x7f
1989##...and $t3,$t3,$at
1992#    sb $t3,-8($t0)
1996#    addu $t4,1
2000#    addu $t0,1
2004#    blt $t4,$t2,toString_copyLoop
2005##...slt $at,$t4,$t2
2009##...bne $at,$zero,1976

    # copy the '@' sign
2012#    li $t3,'@'
2016#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2020#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2024#    lw $t3,20($sp) # hash code to print
2028:toString_hashCopyLoop:
2028#    and $t4,$t3,0xf
2032#    srl $t3,4
2036#    lb $t4,hexChars($t4)
2040#    sb $t4,-8($t2)
2044#    subu $t2,$t2,1
2048#    bgt $t2,$t0,toString_hashCopyLoop
2049##...slt $at,$t0,$t2
2053##...bne $at,$zero,2028

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2056#    addu $sp,28
2060#    lw $ra,($sp)
2064#    addu $sp,4
2068#    move $t0, $s7 # return string we created
2072#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2076:mth_equals_String:
    
    # quick test for obvious false
2076#    lw $t0,($sp) # second parameter
2080#    beq $t0,$zero,goEsFalse # go return false if null
2084#    lw $t1,-12($t0) # vtable pointer
2088#    la $t2,CLASS_String # string vtable pointer
2092#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2096#    subu $sp,12
2100#    sw $ra,8($sp)
2104#    sw $s2,4($sp)
2108#    sw $t0,($sp)
2112#    jal mth_compareTo_String
2116#    lw $s2, 4($sp) #restore this pointer and pop parameters
2120#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2124#    seq $t0,$t0,$zero
2125##...subu $at,$t0,$zero
2129##...sltiu $t0,$at,1

    # pop return address and return $t0
2132#    lw $ra,($sp)
2136#    addu $sp,4

2140#    jr $ra # return
    
2144:goEsFalse:
    # put 0 in $t0 and return
2144#    li $t0, 0
2148#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2152:mth_toString_String:
    #we are a string, so return this.
2152#    move $t0, $s2
2156#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2160:mth_readLine_Lib:
    
2160#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2164#    sw $ra, 4($sp) # save $ra
2168#    move $t1,$sp # save "original" sp

2172:  doRead:

    # read the character
2172#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2176#    subu $t2,$v0,13
2180#    bne $t2,$zero,notReturnRL
2184#    jal readLogicalChar
2188#    subu $t2,$v0,10 # check for newline
2192#    beq $t2,$zero,foundNewLine
2196#    sw $v0,lastCharRead # push back character into queue
2200#    j foundNewLine # go process the line

2204:  notReturnRL:

    # at this point, $v0 has our character

2204#    subu $t0,$v0,10
2208#    beq $t0,$zero,foundNewLine
2212#    blt $v0,$zero,foundEof
2213##...slt $at,$v0,$zero
2217##...bne $at,$zero,2232

    # we have a character, so push it onto stack
2220#    subu $sp,$sp,4
2224#    sw $v0,($sp)

    # loop back up to get next character
2228#    j doRead

2232:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2232#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2236#    li $s7, 0 # return-value: null
2240#    j rlReturn # return

2244:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2244#    subu $t0,$t1,$sp # number of chars we read (times 4)
2248#    srl $s6,$t0,2 # number of words on stack with chars
2252#    subu $sp,$sp,4 # push char-count ...
2256#    sw $s6,($sp) # ... onto stack
2260#    addu $t2,$t0,5 # GC tag, incl. for count-word
2264#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2268#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2272#    srl $s6,$s6,2  # data words in object
2276#    move $s7,$zero # object words in object
2280#    jal newObject  # allocate space
    
    # store header words
2284#    la $t0,CLASS_String
2288#    sw $t0,-12($s7)# store class tag (String) into object
2292#    lw $t2,4($sp) # char-count
2296#    sll $t1,$t2,2 # 4 times number of chars
2300#    subu $t2,$zero,$t2 # negative of char-count
2304#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2308#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2312#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2313##...slt $at,$t0,$zero
2317##...beq $at,$zero,2336
2320#    and $t0,0xff # mask off object's hash value ...
2321##...lui $at,0
2325##...ori $at,$at,0xff
2329##...and $t0,$t0,$at
2332#    sw $t0,-8($s7) # ... and store back into -8 header-word
2336:  skipMask_readLine:

2336#    sll $t0,$t0,2 # data bytes in object
2340#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2344#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2348#    addu $sp,$sp,8 # pop redundant object-pointer and count
2352#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2356#    beq $sp,$t1,rlReturn
2360:  charCopyLoop:
2360#    lw $t2,($sp)
2364#    sb $t2,-9($t0)
2368#    addu $sp,$sp,4
2372#    subu $t0,$t0,1
2376#    bne $sp,$t1,charCopyLoop
2380:  rlReturn:

2380#    lw $ra, 4($sp)
2384#    addu $sp, 8   # pop $ra and pointless word off stack
2388#    move $t0, $s7 # return string we allocated in $s7
2392#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2396:mth_readInt_Lib:

    # save $ra by pushing onto stack
2396#    subu $sp,$sp,4
2400#    sw $ra,($sp)

2404:  riSkipWhiteLoop:
    # read a character
2404#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2408#    subu $t0,$v0,32
2412#    bgt $t0,$zero,nonWhite
2413##...slt $at,$zero,$t0
2417##...bne $at,$zero,2460
2420#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2424#    subu $t0,$v0,10
2428#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2432#    subu $t0,$v0,9
2436#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2440#    subu $t0,$v0,13
2444#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return

1536#  lw $t0,-16($s2)
1540#  subu $sp,$sp,8
1544#  sw $s5,4($sp)
1548#  sw $t0,($sp)
1552#  li $t0,1
1556#  subu $sp,$sp,8
1560#  sw $s5,4($sp)
1564#  sw $t0,($sp)
1568#  lw $t2,($sp)
1572#  addu $sp,$sp,8
1576#  lw $t1,($sp)
1580#  addu $sp,$sp,8
1584#  addu $t0,$t1,$t2
1588#  subu $sp,$sp,8
1592#  sw $s5,4($sp)
1596#  sw $t0,($sp)
1600#  lw $t0,($sp)
1604#  addu $sp,$sp,8

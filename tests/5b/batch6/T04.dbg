4041##...lui $at,0
4045##...ori $at,$at,0xff
4049##...and $t2,$t2,$at
    #### OLD
    #### subu $t2,$zero,$t2 # set to 1 if -1 (number of data words)

4052:  gcSkip2:
4052#    sll $t2,$t2,2
4056#    addu $t2,$t2,8
4060#    subu $t4,$t1,$t2 # address of first word of source
4064#    lw $t3,-4($t1) # number of object words (negative means zero)
4068#    bge $t3,$zero,gcH2Neg1
4069##...slt $at,$t3,$zero
4073##...beq $at,$zero,4080
4076#    move $t3,$zero
4080:  gcH2Neg1:
4080#    sll $t3,$t3,2
4084#    addu $t3,$t3,$t1 # address one word past last word of source

4088#    addu $t2,$s3,$t2 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object (i.e., the address just beyond the object's header)
    # - $t2 contains the pointer to the target object
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0-2
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger" in the target space
4092#    lw $s0,($t4)
4096#    lw $s1,-8($t1)
4100#    sw $s1,($t4)
4104#    sw $s0,-8($t1)
    
    # copy all source bytes to the target
4108:  gCinnerCopy1:
4108#    lw $s0,($t4)
4112#    sw $s0,($s3)
4116#    addu $t4,$t4,4
4120#    addu $s3,$s3,4
4124#    bltu $t4,$t3,gCinnerCopy1
4125##...sltu $at,$t4,$t3
4129##...bne $at,$zero,4108

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4132#    sw $zero,-8($t1) # 0 in first header-slot
4136#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
4140#    sw $t2,4($t0)
4144#    lw $zero,-8($t2)
4148#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
4152#    j gcTestIterDone1

4156:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
4156#    subu $t0,$t0,$t1
4160#    subu $t0,$t0,3

4164:  gcTestIterDone1:
4164#    bgeu $t0,$sp,gcStackCopyLoop
4165##...sltu $at,$t0,$sp
4169##...beq $at,$zero,3980

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
4172#    lw $t1,cur_seg
4176#    la $t0,seg0_start
4180#    beq $t1,$zero,gcSkip4
4184#    la $t0,seg1_start
4185##...lui $t0,16
4189##...addiu $t0,$t0,5336


4192:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
4192#    bgeu $t0,$s3,gcFinishUp
4193##...sltu $at,$t0,$s3
4197##...beq $at,$zero,4488

    ###### begin outer loop to copy all non-stack-direct objects ######

4200:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
4200#    lw $t1,($t0) # (what will be) first header word for current object
4204#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
4208#    bge $t2,$zero,gcSkip4a # are there hash bits?
4209##...slt $at,$t2,$zero
4213##...beq $at,$zero,4228
4216#    and $t2,0xff # mask off hash bits
4217##...lui $at,0
4221##...ori $at,$at,0xff
4225##...and $t2,$t2,$at
4228:gcSkip4a:    
4228#    sll $t2,$t2,2 # # data bytes
4232#    addu $t2,$t2,8 # to skip header words
4236#    addu $t2,$t0,$t2 # pointer to new object
4240#    lw $t3,-8($t2) # word to swap
4244#    sw $t1,-8($t2) # store header word
4248#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
4252#    lw $t1,-12($t2) # vtable pointer
4256#    li $t0,dataArrayVTableStart # address of vtable for first data array
4260#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
4261##...slt $at,$t1,$t0
4265##...bne $at,$zero,4284

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
4268:  skipToNextObj:
4268#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
4272#    sll $t1,$t1,2 # convert to byte-count
4276#    addu $t0,$t2,$t1 # skip over object
4280#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
4284:  gcNotDataArray:
4284#    lw $t3,-4($t2) # # object words (negative treated as zero)
4288#    bge $t3,$zero,gcH2Neg2
4289##...slt $at,$t3,$zero
4293##...beq $at,$zero,4300
4296#    move $t3,$zero
4300:  gcH2Neg2:
4300#    sll $t3,$t3,2 # # object bytes
4304#    move $t0,$t2 # address of first pointer in object
4308#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
4312#    beq $t0,$s1,gcTestIterDone2
    
4316:  gcNextPointerInObject:
    # get pointer from object
4316#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
4320#    bleu $t1,$t6,gcGoNextPointerSlot
4321##...sltu $at,$t6,$t1
4325##...beq $at,$zero,4468
4328#    bgtu $t1,$t7,gcGoNextPointerSlot
4329##...sltu $at,$t7,$t1
4333##...bne $at,$zero,4468

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4336#    lw $t8,-8($t1) # possible forwarding tag
4340#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
4344#    lw $t8,-4($t1) # forwarding pointer: object's new address
4348#    sw $t8,($t0) # update pointer in object
4352#    j gcGoNextPointerSlot # do next iteration

4356:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
4356#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
4357##...slt $at,$t8,$zero
4361##...beq $at,$zero,4376
4364#    and $t8,0xff # mask off hash bits
4365##...lui $at,0
4369##...ori $at,$at,0xff
4373##...and $t8,$t8,$at

4376:  gcSkip5:
4376#    sll $t8,$t8,2 # bytes in negative-offset portion ...
4380#    addu $t8,$t8,8 # ... add in bytes for header-words
4384#    subu $t4,$t1,$t8 # address of first word of source object
4388#    lw $t3,-4($t1) # # words in positive-offset portion
4392#    bge $t3,$zero,gcNoNeg
4393##...slt $at,$t3,$zero
4397##...beq $at,$zero,4404
4400#    move $t3,$zero # negative treated as zero
4404:  gcNoNeg:
4404#    sll $t3,$t3,2 # bytes in negative-offset portion
4408#    addu $t3,$t3,$t1 # address one word past last word of source

4412#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4416#    lw $s0,($t4)
4420#    lw $t9,-8($t1)
4424#    sw $t9,($t4)
4428#    sw $s0,-8($t1)

    # copy all source bytes to the target
4432:  gCinnerCopy2:
4432#    lw $s0,($t4)
4436#    sw $s0,($s3)
4440#    addu $t4,$t4,4
4444#    addu $s3,$s3,4
4448#    bltu $t4,$t3,gCinnerCopy2
4449##...sltu $at,$t4,$t3
4453##...bne $at,$zero,4432

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4456#    sw $zero,-8($t1) # 0 in first header-slot
4460#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4464#    sw $t8,($t0)

4468:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4468#    addu $t0,$t0,4
4472#    bltu $t0,$s1,gcNextPointerInObject
4473##...sltu $at,$t0,$s1
4477##...bne $at,$zero,4316

4480:  gcTestIterDone2:
4480#    bltu $t0,$s3,gcHeapCopyLoop
4481##...sltu $at,$t0,$s3
4485##...bne $at,$zero,4200

    ###### end outer loop to copy all non-stack-direct objects ######

4488:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4488#    lw $s2,($sp)
4492#    addu $sp,$sp,4

    # mark us as having already GC'd
4496#    move $t5,$s5

    # go try and allocate again
4500#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4504:vm_init:

    # mark bottom of stack
4504#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4508#    move $s2,$zero

    #set up the "five" register
4512#    li $s5,5

4516#    la $s3,seg0_start
4520#    la $s4,seg0_end
4521##...lui $s4,16
4525##...addiu $s4,$s4,5336
    
    # return
4528#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4532:divide:
    # get parameters; abort if divisor zero
4532#    lw $t0,($sp)
4536#    lw $t1,8($sp)
4540#    beq $t0,$zero,divByZeroError
    
    # perform division
4544#    div $t1,$t0
4548#    mflo $t0

    # store result, adjust stack and return
4552#    addu $sp,$sp,8 # adjust stack
4556#    sw $t0,($sp) # store result
4560#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4564:remainder:
    # get parameters; abort if divisor zero
4564#    lw $t0,($sp)
4568#    lw $t1,8($sp)
4572#    beq $t0,$zero,divByZeroError
    
    # perform division
4576#    div $t1,$t0
4580#    mfhi $t0

    # store result, adjust stack and return
4584#    addu $sp,$sp,8 # adjust stack
4588#    sw $t0,($sp) # store result
4592#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4596:checkCast:
    # get object, allow immediately if null
4596#    lw $t2,($sp)
4600#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4604#    lw $t2,-12($t2) # vtable address
4608#    bge $t2,$t1,castException
4609##...slt $at,$t2,$t1
4613##...beq $at,$zero,4748
4616#    blt $t2,$t0,castException
4617##...slt $at,$t2,$t0
4621##...bne $at,$zero,4748
    
    # return, leaving object unchanged on stack
4624:  checkCastReturn:    
4624#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4628:instanceOf:
    # get object, go return false if null
4628#    lw $t2,($sp)
4632#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4636#    lw $t2,-12($t2) # vtable address
4640#    sge $t0,$t2,$t0 # are we >= the lower limit?
4641##...slt $t0,$t2,$t0
4645##...xori $t0,$t0,0x1
4648#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4652#    and $t2,$t0,$t1
4656#    sw $t2,($sp)
4660:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4660#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4664:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4664#    li $v0,4 # syscall-code for print-string
4668#    syscall
4672:exit:
    # print termination message
4672#    li $v0,4 # syscall-code for print-string
4676#    la $a0,exitString
4680#    syscall

    # terminate execution
4684#    li $v0,10 #syscall-code for "exit"
4688#    syscall

4692:outOfHeapMemory:
4692#    la $a0,heapMemoryMsg
4696#    j exitError
4700:divByZeroError:
4700#    la $a0,divByZeroMsg
4704#    j exitError
4708:strIndexOutOfBounds:
4708#    la $a0,strIndexOutOfBoundsMsg
4712#    j exitError
4716:arrayIndexOutOfBounds:
4716#    la $a0,arrayIndexOutOfBoundsMsg
4720#    j exitError
4724:arraySizeOutOfBounds:
4724#    la $a0,arraySizeOutOfBoundsMsg
4728#    j exitError
4732:nullPtrException:
4732#    la $a0,nullPtrExceptionMsg
4736#    j exitError
4740:badIntegerFormat:
4740#    la $a0,badIntegerFormatMsg
4744#    j exitError
4748:castException:
4748#    la $a0,castExceptionMsg
4752#    j exitError
############## data section ################
    .data
4972:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4988:cur_seg:
    .word 0

4992:lastCharRead:
    .word -2 # -2 => no buffered character
4996:prevHashConstant:
    .word 0x2785173c
5000:gcCount:
    .word 0

5004:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5031:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5054:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5089:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5123:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5156:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5187:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5235:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5256:gcMsg: 
      .asciiz "\nGC!\n"
5262:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5294:nullStr:
    .asciiz "null"
5299:trueString:
    .asciiz "true"
5304:falseString:
    .asciiz "false"

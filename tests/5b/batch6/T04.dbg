    
    # store negative of size in header-word 2
3556#    li $t0,-1
3560#    sw $t0,-4($s7)

    # we're returning $s7
3564#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
3568#    lw $ra,4($sp)
3572#    addu $sp,$sp,8

    # return
3576#    jr $ra

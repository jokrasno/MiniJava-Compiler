5512#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
5516#    sw $t3,($t0)
5520#    srl $s6,$s6,2
5524#    subu $sp,$sp,4
5528#    sw $s6,($sp)
    
    # allocate memory
5532#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
5536#    srl $s6,$s6,2
5540#    move $s7,$zero # no "object" words in object

    # therefore does not refer to an object on the heap, just go
    # loop back and do the next one
6172#    bleu $t1,$t6,gcTestIterDone1
6173##...sltu $at,$t6,$t1
6177##...beq $at,$zero,6340
6180#    bgtu $t1,$t7,gcTestIterDone1
6181##...sltu $at,$t7,$t1
6185##...bne $at,$zero,6340

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
6188#    lw $t2,-8($t1) # possible forwarding tag
6192#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
6196#    lw $t2,-4($t1) # forwarding pointer: object's new address
6200#    sw $t2,4($t0) # update stack value
6204#    j gcTestIterDone1 # do next iteration

6208:  gcNoForward1:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    # compute the amount of space that is needed
6208#    bge $t2,$zero,gcSkip2
6209##...slt $at,$t2,$zero
6213##...beq $at,$zero,6228
6216#    and $t2,0xff #### mask off hash value
6217##...lui $at,0
6221##...ori $at,$at,0xff
6225##...and $t2,$t2,$at
    #### OLD
    #### subu $t2,$zero,$t2 # set to 1 if -1 (number of data words)

6228:  gcSkip2:
6228#    sll $t2,$t2,2
6232#    addu $t2,$t2,8
6236#    subu $t4,$t1,$t2 # address of first word of source
6240#    lw $t3,-4($t1) # number of object words (negative means zero)
6244#    bge $t3,$zero,gcH2Neg1
6245##...slt $at,$t3,$zero
6249##...beq $at,$zero,6256
6252#    move $t3,$zero

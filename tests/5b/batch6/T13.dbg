5944#    sw $zero,($s3)
5948#    lw $zero,($s3)

5952#    addu $s3,4
5956#    bltu $s3,$t1,zeroObjLoop
5957##...sltu $at,$s3,$t1
5961##...bne $at,$zero,5944

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

5972#    li $t2,255
5976#    bgeu $s6,$t2 firstHeaderLarge
5977##...sltu $at,$s6,$t2
5981##...beq $at,$zero,6028
5984#    lw $t1,prevHashConstant
5988#    addu $t1,0x12b68fd2
5989##...lui $at,4791
5993##...addiu $at,$at,-28718
5997##...addu $t1,$at,$t1
6000#    sw $t1,prevHashConstant # update hash constant
6004#    or $t1,0x80000000 # set top bit
6005##...lui $at,32768
6009##...or $t1,$at,$t1
6012#    and $t1,0xffffff00 # clear low bit
6013##...lui $at,65535
6017##...ori $at,$at,0xff00
6021##...and $t1,$t1,$at
6024#    or $s6,$t1
6028:firstHeaderLarge:
6028#    sw $s6,-8($t0) # store header-1 value
6032#    lw $zero,-8($t0)

    # store second header-value
6036#    sw $s7,-4($t0)   # second header-word
6040#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
6044#    move $s7,$t0
6048#    subu $sp,$sp,4
6052#    sw $t0,($sp)

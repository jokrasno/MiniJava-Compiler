
    # restore char-count; pop it and return value from 'newObject'
5548#    lw $t0,4($sp)
5552#    addu $sp,$sp,8

    # store "String" tag into class field
5556#    subu $s7,$s7,8 # address of header-1 word
5560#    la $t1,CLASS_String
5564#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
5568#    lw $t4,($s7) # # data words in source string
5572#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
5573##...slt $at,$t4,$zero
5577##...beq $at,$zero,5596
5580#    and $t4,0xff # mask off object's hash value ...
5581##...lui $at,0
5585##...ori $at,$at,0xff
5589##...and $t4,$t4,$at
5592#    sw $t4,($s7) # ... and store back into -8 header-word
5596:skipMask_intToString:
    
    # store negative of char-count into header-2 word
5596#    subu $t0,$zero,$t0
5600#    sw $t0,4($s7)

5604#    lw $t1,($s7) # number of data words in string
5608#    sll $t1,$t1,2 # number data bytes in string
5612#    subu $t1,$s7,$t1 # first location to store chars in string
5616#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
5620:  itsLoop:
5620#    lw $t2,($sp)
5624#    addu $sp,$sp,4
5628#    sb $t2,($t1)
5632#    addu $t1,$t1,1
5636#    bne $t1,$t0,itsLoop

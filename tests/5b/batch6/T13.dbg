



###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3828:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
3828#    lw $t0,-8($s2) # get word with hash bits from this
3832#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
3836#    addu $t0,$t1

3840#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3844:mth_equals_Object:
3844#    move $t0,$s2 # first pointer (this)
3848#    lw $t1,($sp) # second pointer
3852#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
3853##...subu $at,$t0,$t1
3857##...sltiu $t0,$at,1

3860#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3864:mth_hashCode_String:
3864#    move $t0,$s2 # put this pointer in t0

3868#    li $t2,0 # current hash value
3872#    lw $t1,-4($t0) # negative of number of characters in string
3876#    beq $t1,$zero,done_hashCode_String # if zero length => done
3880#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
3884#    and $t0,0xfffffffc # adjust for padding
3885##...lui $at,65535
3889##...ori $at,$at,0xfffc
3893##...and $t0,$t0,$at
3896#    subu $t1,$t0,$t1 # address at end of string +12
3900:loop_hashCode_String:    
3900#    sll $t4,$t2,5 # multiply by 32
3904#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
3908#    lbu $t3,-12($t0) # current character
3912#    addu $t2,$t3 # add in current character
3916#    addu $t0,1 # go to next character's address
3920#    bne $t0,$t1,loop_hashCode_String # loop back if more
3924:done_hashCode_String:    

    # push int on stack
3924#    move $t0, $t2 # put $t2 in return slot
3928#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
3932:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
3932#    subu $sp,4
3936#    sw $ra,($sp)
    
    # get hash value
3940#    lw $t2,-12($s2) # vtable address
3944#    lw $t0,($t2) # method address
3948#    jalr $t0
3952#    subu $sp,8 # push result (int in $t0) on stack
3956#    sw $s5,4($sp)
3960#    sw $t0,($sp)

    # compute print-size of hash value
3964#    li $t0, 1
3968#    lw $t1, ($sp)
3972#    srl $t1,$t1,4
3976#    beq $t1,$zero,toString_skip_loop
3980:toString_loop_top:
3980#    addu $t0,1
3984#    srl $t1,$t1,4
3988#    bne $t1,$zero,toString_loop_top
3992:toString_skip_loop:
3992#    subu $sp,8
3996#    sw $s5,4($sp)
4000#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
4004#    lw $t2,-12($s2) # vtable address
4008#    move $t0,$t2
4012:toString_checkTagBit:
4012#    subu $t0,1
4016#    lb $t1,($t0)
4020#    and $t1,0x80
4021##...lui $at,0
4025##...ori $at,$at,0x80
4029##...and $t1,$t1,$at
4032#    beq $t1,$zero,toString_checkTagBit
4036#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
4040#    subu $sp,8
4044#    sw $t1,($sp)
4048#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
4052#    move $s7,$zero # -4 offset header word
4056#    lw $t4,8($sp) # bytes for hash value
4060#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
4064#    addu $t4,8
4068#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
4072#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

4076#    li $t0,CLASS_String # store string vtable address into ...
4080#    sw $t0,-12($s7) # ... -12 offset in object header
4084#    lw $t2,-12($s2) # our object's vtable address
4088#    lw $t5,4($sp) # number characters in prefix
4092#    lw $t1,12($sp) # number of characters in hashcode
4096#    addu $t3,$t1,$t5 # number of characters in string ...
4100#    addu $t3,1 # ... including the '@' character
4104#    subu $t0,$zero,$t3 # store negated length into ...
4108#    sw $t0,-4($s7) # ... -4 offset header word
4112#    lw $t0,-8($s7) # get -8 offset header-word
4116#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
4117##...slt $at,$t0,$zero
4121##...beq $at,$zero,4140
4124#    and $t0,0xff # mask off object's hash value ...
4125##...lui $at,0
4129##...ori $at,$at,0xff
4133##...and $t0,$t0,$at
4136#    sw $t0,-8($s7) # ... and store back into -8 header-word
4140:skipMask_toString:
4140#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
4144#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
4148#    subu $t4,$t2,$t5
4152:toString_copyLoop:    
4152#    lb $t3,($t4)
4156#    and $t3,0x7f # mask off sign bit (in case first word)
4157##...lui $at,0
4161##...ori $at,$at,0x7f
4165##...and $t3,$t3,$at
4168#    sb $t3,-8($t0)
4172#    addu $t4,1
4176#    addu $t0,1
4180#    blt $t4,$t2,toString_copyLoop
4181##...slt $at,$t4,$t2
4185##...bne $at,$zero,4152

    # copy the '@' sign
4188#    li $t3,'@'
4192#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
4196#    addu $t2,$t0,$t1 # address of last byte in string to store +8
4200#    lw $t3,20($sp) # hash code to print
4204:toString_hashCopyLoop:
4204#    and $t4,$t3,0xf
4208#    srl $t3,4
4212#    lb $t4,hexChars($t4)
4216#    sb $t4,-8($t2)
4220#    subu $t2,$t2,1
4224#    bgt $t2,$t0,toString_hashCopyLoop
4225##...slt $at,$t0,$t2
4229##...bne $at,$zero,4204

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
4232#    addu $sp,28
4236#    lw $ra,($sp)
4240#    addu $sp,4
4244#    move $t0, $s7 # return string we created
4248#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
4252:mth_equals_String:
    
    # quick test for obvious false
4252#    lw $t0,($sp) # second parameter
4256#    beq $t0,$zero,goEsFalse # go return false if null
4260#    lw $t1,-12($t0) # vtable pointer
4264#    la $t2,CLASS_String # string vtable pointer
4268#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
4272#    subu $sp,12
4276#    sw $ra,8($sp)
4280#    sw $s2,4($sp)
4284#    sw $t0,($sp)
4288#    jal mth_compareTo_String
4292#    lw $s2, 4($sp) #restore this pointer and pop parameters
4296#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
4300#    seq $t0,$t0,$zero
4301##...subu $at,$t0,$zero
4305##...sltiu $t0,$at,1

    # pop return address and return $t0
4308#    lw $ra,($sp)
4312#    addu $sp,4

4316#    jr $ra # return
    
4320:goEsFalse:
    # put 0 in $t0 and return
4320#    li $t0, 0
4324#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
4328:mth_toString_String:
    #we are a string, so return this.
4328#    move $t0, $s2
4332#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
4336:mth_readLine_Lib:
    
4336#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
4340#    sw $ra, 4($sp) # save $ra
4344#    move $t1,$sp # save "original" sp

4348:  doRead:

    # read the character
4348#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
4352#    subu $t2,$v0,13
4356#    bne $t2,$zero,notReturnRL
4360#    jal readLogicalChar
4364#    subu $t2,$v0,10 # check for newline
4368#    beq $t2,$zero,foundNewLine
4372#    sw $v0,lastCharRead # push back character into queue
4376#    j foundNewLine # go process the line

4380:  notReturnRL:

    # at this point, $v0 has our character

4380#    subu $t0,$v0,10
4384#    beq $t0,$zero,foundNewLine
4388#    blt $v0,$zero,foundEof
4389##...slt $at,$v0,$zero
4393##...bne $at,$zero,4408

    # we have a character, so push it onto stack
4396#    subu $sp,$sp,4
4400#    sw $v0,($sp)

    # loop back up to get next character
4404#    j doRead

4408:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
4408#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
4412#    li $s7, 0 # return-value: null
4416#    j rlReturn # return

4420:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
4420#    subu $t0,$t1,$sp # number of chars we read (times 4)
4424#    srl $s6,$t0,2 # number of words on stack with chars
4428#    subu $sp,$sp,4 # push char-count ...
4432#    sw $s6,($sp) # ... onto stack
4436#    addu $t2,$t0,5 # GC tag, incl. for count-word
4440#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
4444#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
4448#    srl $s6,$s6,2  # data words in object
4452#    move $s7,$zero # object words in object
4456#    jal newObject  # allocate space
    
    # store header words
4460#    la $t0,CLASS_String
4464#    sw $t0,-12($s7)# store class tag (String) into object
4468#    lw $t2,4($sp) # char-count
4472#    sll $t1,$t2,2 # 4 times number of chars
4476#    subu $t2,$zero,$t2 # negative of char-count
4480#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
4484#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
4488#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
4489##...slt $at,$t0,$zero
4493##...beq $at,$zero,4512
4496#    and $t0,0xff # mask off object's hash value ...
4497##...lui $at,0
4501##...ori $at,$at,0xff
4505##...and $t0,$t0,$at
4508#    sw $t0,-8($s7) # ... and store back into -8 header-word
4512:  skipMask_readLine:

4512#    sll $t0,$t0,2 # data bytes in object
4516#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
4520#    subu $t0,$t0,$t2 # place to store last character (plus 9)
4524#    addu $sp,$sp,8 # pop redundant object-pointer and count
4528#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:

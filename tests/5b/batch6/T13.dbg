    # return
6704#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
6708:divide:
    # get parameters; abort if divisor zero
6708#    lw $t0,($sp)
6712#    lw $t1,8($sp)
6716#    beq $t0,$zero,divByZeroError
    
    # perform division
6720#    div $t1,$t0
6724#    mflo $t0

    # store result, adjust stack and return
6728#    addu $sp,$sp,8 # adjust stack
6732#    sw $t0,($sp) # store result
6736#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
6740:remainder:
    # get parameters; abort if divisor zero
6740#    lw $t0,($sp)
6744#    lw $t1,8($sp)
6748#    beq $t0,$zero,divByZeroError
    
    # perform division
6752#    div $t1,$t0
6756#    mfhi $t0

    # store result, adjust stack and return
6760#    addu $sp,$sp,8 # adjust stack
6764#    sw $t0,($sp) # store result
6768#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
6772:checkCast:
    # get object, allow immediately if null
6772#    lw $t2,($sp)
6776#    beq $t2,$zero,checkCastReturn

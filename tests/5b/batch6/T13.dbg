########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
5668:mth_intToChar_Lib:
    # save return address
5668#    subu $sp,$sp,4
5672#    sw $ra,($sp)

    # allocate object
5676#    li $s6,2
5680#    move $s7,$zero
5684#    jal newObject

    # get n from string.
5688#    lw $t1,8($sp)

    # store "String" tag into class field
5692#    la $t0,CLASS_String
5696#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
5700#    lw $t4,-8($s7) # # data words in source string
5704#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
5705##...slt $at,$t4,$zero
5709##...beq $at,$zero,5728
5712#    and $t4,0xff # mask off object's hash value ...
5713##...lui $at,0
5717##...ori $at,$at,0xff
5721##...and $t4,$t4,$at
5724#    sw $t4,-8($s7) # ... and store back into -8 header-word
5728:  skipMask_intToChar:

    # store data in string
5728#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
5732#    li $t0,-1
5736#    sw $t0,-4($s7)

    # we're returning $s7
5740#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
5744#    lw $ra,4($sp)
5748#    addu $sp,$sp,8

    # return
5752#    jr $ra

########################################################
# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
5756:mth_compareTo_String:
    # get string pointers and check parameter for null
5756#    lw $t0,($sp) # second string
5760#    beq $t0,$zero,nullPtrException
5764#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
5768#    lw $t2,-4($t0) # negative length of second string
5772#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
5776#    slt $t4,$t3,$t2
5780#    slt $t5,$t2,$t3
5784#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
5788#    lw $t2,-8($t0) # # data words in second string
5792#    lw $t3,-8($t1) # # data words in first string
5796#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
5800#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
5804#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
5808#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
5812#    beq $zero,$t5,skipStrCmpLenzz
5816#    move $t2,$t3
5820:  skipStrCmpLenzz:
5820#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
5824:  cmpLoopzz:
5824#    lw $t3,-8($t1) # word from str2
5828#    lw $t4,-8($t0) # word from str1
5832#    bne $t3,$t4,cmpNotEqualzz
5836#    addu $t1,$t1,4
5840#    addu $t0,$t0,4
5844#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
5848#    j cmpHitLimitzz

5852:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
5852#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
5856#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
5860#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
5864:  cmpHitLimitzz:
5864#    move $t0, $t5 # store return value
5868#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
5872:readLogicalChar:

    # check if we already have a character
5872#    lw $v0,lastCharRead
5876#    li $t0,-2
5880#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
5884#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
5888#    jr $ra # return
    
5892:  doReadCh:
    # we need to actually read a character: read and return
5892#    li $v0,12 # use system call to read a character
5896#    syscall
5900#    jr $ra # return

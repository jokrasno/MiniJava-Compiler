############## data section ################
    .data
7132:hexChars:
    .ascii "0123456789abcdef"
    .align 2
7148:cur_seg:
    .word 0

7152:lastCharRead:
    .word -2 # -2 => no buffered character
7156:prevHashConstant:
    .word 0x2785173c
7160:gcCount:
    .word 0

7164:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
7191:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
7214:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
7249:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
7283:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
7316:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
7347:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
7395:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
7416:gcMsg: 
      .asciiz "\nGC!\n"
7422:gcCountMsg: 
      .asciiz "Number of garbage collections: "

7454:nullStr:
    .asciiz "null"
7459:trueString:
    .asciiz "true"
7464:falseString:
    .asciiz "false"
7470:exitString:
    .ascii "Program terminated."
    #### "falls through" here
7489:newlineString:
    .asciiz "\n"
    
    .align 2
7492:stack_bottom:
    .word 0


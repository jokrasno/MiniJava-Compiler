    # buffer and return
3260#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
3264#    jr $ra # return
    
3268:  doReadCh:
    # we need to actually read a character: read and return
3268#    li $v0,12 # use system call to read a character
3272#    syscall
3276#    jr $ra # return

3357##...beq $at,$zero,3404
3360#    lw $t1,prevHashConstant
3364#    addu $t1,0x12b68fd2
3365##...lui $at,4791
3369##...addiu $at,$at,-28718
3373##...addu $t1,$at,$t1
3376#    sw $t1,prevHashConstant # update hash constant
3380#    or $t1,0x80000000 # set top bit
3381##...lui $at,32768
3385##...or $t1,$at,$t1

3224#    j cmpHitLimitzz

3228:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
3228#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
3232#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
3236#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
3240:  cmpHitLimitzz:
3240#    move $t0, $t5 # store return value
3244#    jr $ra # return

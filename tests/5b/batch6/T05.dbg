    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3836:  gcNotDataArray:
3836#    lw $t3,-4($t2) # # object words (negative treated as zero)
3840#    bge $t3,$zero,gcH2Neg2
3841##...slt $at,$t3,$zero
3845##...beq $at,$zero,3852
3848#    move $t3,$zero
3852:  gcH2Neg2:
3852#    sll $t3,$t3,2 # # object bytes
3856#    move $t0,$t2 # address of first pointer in object
3860#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3864#    beq $t0,$s1,gcTestIterDone2
    
3868:  gcNextPointerInObject:
    # get pointer from object
3868#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3872#    bleu $t1,$t6,gcGoNextPointerSlot
3873##...sltu $at,$t6,$t1
3877##...beq $at,$zero,4020
3880#    bgtu $t1,$t7,gcGoNextPointerSlot
3881##...sltu $at,$t7,$t1
3885##...bne $at,$zero,4020

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3888#    lw $t8,-8($t1) # possible forwarding tag
3892#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3896#    lw $t8,-4($t1) # forwarding pointer: object's new address
3900#    sw $t8,($t0) # update pointer in object
3904#    j gcGoNextPointerSlot # do next iteration

3908:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3908#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3909##...slt $at,$t8,$zero
3913##...beq $at,$zero,3928
3916#    and $t8,0xff # mask off hash bits
3917##...lui $at,0
3921##...ori $at,$at,0xff
3925##...and $t8,$t8,$at

3928:  gcSkip5:
3928#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3932#    addu $t8,$t8,8 # ... add in bytes for header-words
3936#    subu $t4,$t1,$t8 # address of first word of source object
3940#    lw $t3,-4($t1) # # words in positive-offset portion
3944#    bge $t3,$zero,gcNoNeg
3945##...slt $at,$t3,$zero
3949##...beq $at,$zero,3956
3952#    move $t3,$zero # negative treated as zero
3956:  gcNoNeg:
3956#    sll $t3,$t3,2 # bytes in negative-offset portion
3960#    addu $t3,$t3,$t1 # address one word past last word of source

3964#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3968#    lw $s0,($t4)
3972#    lw $t9,-8($t1)
3976#    sw $t9,($t4)
3980#    sw $s0,-8($t1)

    # copy all source bytes to the target
3984:  gCinnerCopy2:
3984#    lw $s0,($t4)
3988#    sw $s0,($s3)
3992#    addu $t4,$t4,4
3996#    addu $s3,$s3,4
4000#    bltu $t4,$t3,gCinnerCopy2
4001##...sltu $at,$t4,$t3
4005##...bne $at,$zero,3984

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4008#    sw $zero,-8($t1) # 0 in first header-slot
4012#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4016#    sw $t8,($t0)

4020:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4020#    addu $t0,$t0,4
4024#    bltu $t0,$s1,gcNextPointerInObject
4025##...sltu $at,$t0,$s1
4029##...bne $at,$zero,3868

4032:  gcTestIterDone2:
4032#    bltu $t0,$s3,gcHeapCopyLoop
4033##...sltu $at,$t0,$s3
4037##...bne $at,$zero,3752

    ###### end outer loop to copy all non-stack-direct objects ######

4040:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4040#    lw $s2,($sp)
4044#    addu $sp,$sp,4

    # mark us as having already GC'd
4048#    move $t5,$s5

    # go try and allocate again
4052#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4056:vm_init:

    # mark bottom of stack
4056#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4060#    move $s2,$zero

    #set up the "five" register
4064#    li $s5,5

4068#    la $s3,seg0_start
4072#    la $s4,seg0_end
4073##...lui $s4,16
4077##...addiu $s4,$s4,4888
    
    # return
4080#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4084:divide:
    # get parameters; abort if divisor zero
4084#    lw $t0,($sp)
4088#    lw $t1,8($sp)
4092#    beq $t0,$zero,divByZeroError
    
    # perform division
4096#    div $t1,$t0
4100#    mflo $t0

    # store result, adjust stack and return
4104#    addu $sp,$sp,8 # adjust stack
4108#    sw $t0,($sp) # store result
4112#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4116:remainder:
    # get parameters; abort if divisor zero
4116#    lw $t0,($sp)
4120#    lw $t1,8($sp)
4124#    beq $t0,$zero,divByZeroError
    
    # perform division
4128#    div $t1,$t0
4132#    mfhi $t0

    # store result, adjust stack and return
4136#    addu $sp,$sp,8 # adjust stack
4140#    sw $t0,($sp) # store result
4144#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4148:checkCast:
    # get object, allow immediately if null
4148#    lw $t2,($sp)
4152#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4156#    lw $t2,-12($t2) # vtable address
4160#    bge $t2,$t1,castException
4161##...slt $at,$t2,$t1
4165##...beq $at,$zero,4300
4168#    blt $t2,$t0,castException
4169##...slt $at,$t2,$t0
4173##...bne $at,$zero,4300
    
    # return, leaving object unchanged on stack
4176:  checkCastReturn:    
4176#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4180:instanceOf:
    # get object, go return false if null
4180#    lw $t2,($sp)
4184#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4188#    lw $t2,-12($t2) # vtable address
4192#    sge $t0,$t2,$t0 # are we >= the lower limit?
4193##...slt $t0,$t2,$t0
4197##...xori $t0,$t0,0x1
4200#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4204#    and $t2,$t0,$t1
4208#    sw $t2,($sp)
4212:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4212#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4216:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4216#    li $v0,4 # syscall-code for print-string
4220#    syscall
4224:exit:
    # print termination message
4224#    li $v0,4 # syscall-code for print-string
4228#    la $a0,exitString
4232#    syscall

    # terminate execution
4236#    li $v0,10 #syscall-code for "exit"
4240#    syscall

4244:outOfHeapMemory:
4244#    la $a0,heapMemoryMsg
4248#    j exitError
4252:divByZeroError:
4252#    la $a0,divByZeroMsg
4256#    j exitError
4260:strIndexOutOfBounds:
4260#    la $a0,strIndexOutOfBoundsMsg
4264#    j exitError
4268:arrayIndexOutOfBounds:
4268#    la $a0,arrayIndexOutOfBoundsMsg
4272#    j exitError
4276:arraySizeOutOfBounds:
4276#    la $a0,arraySizeOutOfBoundsMsg
4280#    j exitError
4284:nullPtrException:
4284#    la $a0,nullPtrExceptionMsg
4288#    j exitError
4292:badIntegerFormat:
4292#    la $a0,badIntegerFormatMsg
4296#    j exitError
4300:castException:
4300#    la $a0,castExceptionMsg
4304#    j exitError
############## data section ################
    .data
4524:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4540:cur_seg:
    .word 0

4544:lastCharRead:
    .word -2 # -2 => no buffered character
4548:prevHashConstant:
    .word 0x2785173c
4552:gcCount:
    .word 0

4556:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4583:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4606:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4641:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4675:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4708:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4739:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4787:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4808:gcMsg: 
      .asciiz "\nGC!\n"
4814:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4846:nullStr:
    .asciiz "null"
4851:trueString:
    .asciiz "true"
4856:falseString:
    .asciiz "false"
4862:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4881:newlineString:
    .asciiz "\n"
    
    .align 2
4884:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4888:seg0_start:
    .space 0x100000
1053464:seg0_end:
1053464:seg1_start:
    .space 0x100000
2102040:seg1_end:

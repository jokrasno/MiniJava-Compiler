###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1308:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1308#    subu $sp,4
1312#    sw $ra,($sp)
    
    # get hash value
1316#    lw $t2,-12($s2) # vtable address
1320#    lw $t0,($t2) # method address
1324#    jalr $t0
1328#    subu $sp,8 # push result (int in $t0) on stack
1332#    sw $s5,4($sp)
1336#    sw $t0,($sp)

    # compute print-size of hash value
1340#    li $t0, 1
1344#    lw $t1, ($sp)
1348#    srl $t1,$t1,4
1352#    beq $t1,$zero,toString_skip_loop
1356:toString_loop_top:
1356#    addu $t0,1
1360#    srl $t1,$t1,4
1364#    bne $t1,$zero,toString_loop_top
1368:toString_skip_loop:
1368#    subu $sp,8
1372#    sw $s5,4($sp)
1376#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1380#    lw $t2,-12($s2) # vtable address
1384#    move $t0,$t2
1388:toString_checkTagBit:
1388#    subu $t0,1
1392#    lb $t1,($t0)
1396#    and $t1,0x80
1397##...lui $at,0
1401##...ori $at,$at,0x80
1405##...and $t1,$t1,$at
1408#    beq $t1,$zero,toString_checkTagBit
1412#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1416#    subu $sp,8
1420#    sw $t1,($sp)
1424#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1428#    move $s7,$zero # -4 offset header word
1432#    lw $t4,8($sp) # bytes for hash value
1436#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1440#    addu $t4,8
1444#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1448#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1452#    li $t0,CLASS_String # store string vtable address into ...
1456#    sw $t0,-12($s7) # ... -12 offset in object header
1460#    lw $t2,-12($s2) # our object's vtable address
1464#    lw $t5,4($sp) # number characters in prefix
1468#    lw $t1,12($sp) # number of characters in hashcode
1472#    addu $t3,$t1,$t5 # number of characters in string ...
1476#    addu $t3,1 # ... including the '@' character
1480#    subu $t0,$zero,$t3 # store negated length into ...
1484#    sw $t0,-4($s7) # ... -4 offset header word
1488#    lw $t0,-8($s7) # get -8 offset header-word
1492#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1493##...slt $at,$t0,$zero
1497##...beq $at,$zero,1516
1500#    and $t0,0xff # mask off object's hash value ...
1501##...lui $at,0
1505##...ori $at,$at,0xff
1509##...and $t0,$t0,$at
1512#    sw $t0,-8($s7) # ... and store back into -8 header-word
1516:skipMask_toString:
1516#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1520#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1524#    subu $t4,$t2,$t5
1528:toString_copyLoop:    
1528#    lb $t3,($t4)
1532#    and $t3,0x7f # mask off sign bit (in case first word)
1533##...lui $at,0
1537##...ori $at,$at,0x7f
1541##...and $t3,$t3,$at
1544#    sb $t3,-8($t0)
1548#    addu $t4,1
1552#    addu $t0,1
1556#    blt $t4,$t2,toString_copyLoop
1557##...slt $at,$t4,$t2
1561##...bne $at,$zero,1528

    # copy the '@' sign
1564#    li $t3,'@'
1568#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1572#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1576#    lw $t3,20($sp) # hash code to print
1580:toString_hashCopyLoop:
1580#    and $t4,$t3,0xf
1584#    srl $t3,4
1588#    lb $t4,hexChars($t4)
1592#    sb $t4,-8($t2)
1596#    subu $t2,$t2,1
1600#    bgt $t2,$t0,toString_hashCopyLoop
1601##...slt $at,$t0,$t2
1605##...bne $at,$zero,1580

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1608#    addu $sp,28
1612#    lw $ra,($sp)
1616#    addu $sp,4
1620#    move $t0, $s7 # return string we created
1624#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1628:mth_equals_String:
    
    # quick test for obvious false
1628#    lw $t0,($sp) # second parameter
1632#    beq $t0,$zero,goEsFalse # go return false if null
1636#    lw $t1,-12($t0) # vtable pointer
1640#    la $t2,CLASS_String # string vtable pointer
1644#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1648#    subu $sp,12
1652#    sw $ra,8($sp)
1656#    sw $s2,4($sp)
1660#    sw $t0,($sp)
1664#    jal mth_compareTo_String
1668#    lw $s2, 4($sp) #restore this pointer and pop parameters
1672#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1676#    seq $t0,$t0,$zero
1677##...subu $at,$t0,$zero
1681##...sltiu $t0,$at,1

    # pop return address and return $t0
1684#    lw $ra,($sp)
1688#    addu $sp,4

1692#    jr $ra # return
    
1696:goEsFalse:
    # put 0 in $t0 and return
1696#    li $t0, 0
1700#    jr $ra # return

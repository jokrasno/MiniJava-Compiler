###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1712:mth_readLine_Lib:
    
1712#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1716#    sw $ra, 4($sp) # save $ra
1720#    move $t1,$sp # save "original" sp

1724:  doRead:

    # read the character
1724#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1728#    subu $t2,$v0,13
1732#    bne $t2,$zero,notReturnRL
1736#    jal readLogicalChar
1740#    subu $t2,$v0,10 # check for newline
1744#    beq $t2,$zero,foundNewLine
1748#    sw $v0,lastCharRead # push back character into queue
1752#    j foundNewLine # go process the line

1756:  notReturnRL:

    # at this point, $v0 has our character

1756#    subu $t0,$v0,10
1760#    beq $t0,$zero,foundNewLine
1764#    blt $v0,$zero,foundEof
1765##...slt $at,$v0,$zero
1769##...bne $at,$zero,1784

    # we have a character, so push it onto stack
1772#    subu $sp,$sp,4
1776#    sw $v0,($sp)

    # loop back up to get next character
1780#    j doRead

1784:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1784#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1788#    li $s7, 0 # return-value: null
1792#    j rlReturn # return

1796:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1796#    subu $t0,$t1,$sp # number of chars we read (times 4)
1800#    srl $s6,$t0,2 # number of words on stack with chars
1804#    subu $sp,$sp,4 # push char-count ...
1808#    sw $s6,($sp) # ... onto stack
1812#    addu $t2,$t0,5 # GC tag, incl. for count-word
1816#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1820#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1824#    srl $s6,$s6,2  # data words in object
1828#    move $s7,$zero # object words in object
1832#    jal newObject  # allocate space
    
    # store header words
1836#    la $t0,CLASS_String
1840#    sw $t0,-12($s7)# store class tag (String) into object
1844#    lw $t2,4($sp) # char-count
1848#    sll $t1,$t2,2 # 4 times number of chars
1852#    subu $t2,$zero,$t2 # negative of char-count
1856#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1860#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1864#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1865##...slt $at,$t0,$zero
1869##...beq $at,$zero,1888
1872#    and $t0,0xff # mask off object's hash value ...
1873##...lui $at,0
1877##...ori $at,$at,0xff
1881##...and $t0,$t0,$at
1884#    sw $t0,-8($s7) # ... and store back into -8 header-word
1888:  skipMask_readLine:

1888#    sll $t0,$t0,2 # data bytes in object
1892#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1896#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1900#    addu $sp,$sp,8 # pop redundant object-pointer and count
1904#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1908#    beq $sp,$t1,rlReturn
1912:  charCopyLoop:
1912#    lw $t2,($sp)
1916#    sb $t2,-9($t0)
1920#    addu $sp,$sp,4
1924#    subu $t0,$t0,1
1928#    bne $sp,$t1,charCopyLoop
1932:  rlReturn:

1932#    lw $ra, 4($sp)
1936#    addu $sp, 8   # pop $ra and pointless word off stack
1940#    move $t0, $s7 # return string we allocated in $s7
1944#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1948:mth_readInt_Lib:

    # save $ra by pushing onto stack
1948#    subu $sp,$sp,4
1952#    sw $ra,($sp)

1956:  riSkipWhiteLoop:
    # read a character
1956#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1960#    subu $t0,$v0,32
1964#    bgt $t0,$zero,nonWhite
1965##...slt $at,$zero,$t0
1969##...bne $at,$zero,2012
1972#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1976#    subu $t0,$v0,10
1980#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1984#    subu $t0,$v0,9
1988#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1992#    subu $t0,$v0,13
1996#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2000#    subu $t0,$v0,12
2004#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2008#    j badIntegerFormat # illegal integer char: abort program

2012:  nonWhite:
2012#    subu $t0,$v0,'-'
2016#    li $t4,1 # final multiplier
2020#    bne $t0,$zero,helpReadInt # go read
2024#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2028#    jal readLogicalChar

2032:  helpReadInt:
2032#    li $t2,10
2036#    subu $t1,$v0,'0' # convert digit to 0-9 value
2040#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2041##...sltu $at,$t1,$t2
2045##...beq $at,$zero,4292
2048#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2052:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2052#    jal readLogicalChar # read next character
2056#    subu $t1,$v0,'0' # convert digit to 0-9 value
2060#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2061##...sltu $at,$t1,$t2
2065##...beq $at,$zero,2084

2068#    mul $t3,$t3,$t2 # multiply old value by 10
2069##...mult $t3,$t2
2073##...mflo $t3
2076#    addu $t3,$t3,$t1 # add in value of new digit
2080#    j digitLoop

2084:  doneDigitLoop:

    # "push back" unused character into queue
2084#    sw $v0,lastCharRead

    # restore return address
2088#    lw $ra,($sp)
2092#    addu $sp, 4

    # multiply by sign and put return value in $t0
2096#    mult $t3,$t4 # multiply to account for poss. minus sign
2100#    mflo $t3
2104#    move $t0, $t3
    
    # return
2108#    jr $ra

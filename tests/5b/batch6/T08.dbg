
3476:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3476#    addu $t0,$t0,4
3480#    bltu $t0,$s1,gcNextPointerInObject
3481##...sltu $at,$t0,$s1
3485##...bne $at,$zero,3324

3488:  gcTestIterDone2:
3488#    bltu $t0,$s3,gcHeapCopyLoop
3489##...sltu $at,$t0,$s3
3493##...bne $at,$zero,3208

    ###### end outer loop to copy all non-stack-direct objects ######

3496:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3496#    lw $s2,($sp)
3500#    addu $sp,$sp,4

    # mark us as having already GC'd
3504#    move $t5,$s5

    # go try and allocate again
3508#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3512:vm_init:

    # mark bottom of stack
3512#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3516#    move $s2,$zero

    #set up the "five" register
3520#    li $s5,5

3524#    la $s3,seg0_start
3528#    la $s4,seg0_end
3529##...lui $s4,16
3533##...addiu $s4,$s4,4312
    
    # return
3536#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3540:divide:
    # get parameters; abort if divisor zero
3540#    lw $t0,($sp)
3544#    lw $t1,8($sp)
3548#    beq $t0,$zero,divByZeroError
    
    # perform division
3552#    div $t1,$t0
3556#    mflo $t0

    # store result, adjust stack and return
3560#    addu $sp,$sp,8 # adjust stack
3564#    sw $t0,($sp) # store result
3568#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3572:remainder:
    # get parameters; abort if divisor zero
3572#    lw $t0,($sp)
3576#    lw $t1,8($sp)
3580#    beq $t0,$zero,divByZeroError
    
    # perform division
3584#    div $t1,$t0
3588#    mfhi $t0

    # store result, adjust stack and return
3592#    addu $sp,$sp,8 # adjust stack
3596#    sw $t0,($sp) # store result
3600#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3604:checkCast:
    # get object, allow immediately if null
3604#    lw $t2,($sp)
3608#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3612#    lw $t2,-12($t2) # vtable address
3616#    bge $t2,$t1,castException
3617##...slt $at,$t2,$t1
3621##...beq $at,$zero,3756
3624#    blt $t2,$t0,castException
3625##...slt $at,$t2,$t0
3629##...bne $at,$zero,3756
    
    # return, leaving object unchanged on stack
3632:  checkCastReturn:    
3632#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3636:instanceOf:
    # get object, go return false if null
3636#    lw $t2,($sp)
3640#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3644#    lw $t2,-12($t2) # vtable address
3648#    sge $t0,$t2,$t0 # are we >= the lower limit?
3649##...slt $t0,$t2,$t0
3653##...xori $t0,$t0,0x1
3656#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3660#    and $t2,$t0,$t1
3664#    sw $t2,($sp)
3668:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3668#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3672:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3672#    li $v0,4 # syscall-code for print-string
3676#    syscall
3680:exit:
    # print termination message
3680#    li $v0,4 # syscall-code for print-string
3684#    la $a0,exitString
3688#    syscall

    # terminate execution
3692#    li $v0,10 #syscall-code for "exit"
3696#    syscall

3700:outOfHeapMemory:
3700#    la $a0,heapMemoryMsg
3704#    j exitError
3708:divByZeroError:
3708#    la $a0,divByZeroMsg
3712#    j exitError
3716:strIndexOutOfBounds:
3716#    la $a0,strIndexOutOfBoundsMsg
3720#    j exitError
3724:arrayIndexOutOfBounds:
3724#    la $a0,arrayIndexOutOfBoundsMsg
3728#    j exitError
3732:arraySizeOutOfBounds:
3732#    la $a0,arraySizeOutOfBoundsMsg
3736#    j exitError
3740:nullPtrException:
3740#    la $a0,nullPtrExceptionMsg
3744#    j exitError
3748:badIntegerFormat:
3748#    la $a0,badIntegerFormatMsg
3752#    j exitError
3756:castException:
3756#    la $a0,castExceptionMsg
3760#    j exitError
############## data section ################
    .data
3948:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3964:cur_seg:
    .word 0

3968:lastCharRead:
    .word -2 # -2 => no buffered character
3972:prevHashConstant:
    .word 0x2785173c
3976:gcCount:
    .word 0

3980:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4007:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4030:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4065:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4099:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4132:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4163:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4211:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4232:gcMsg: 
      .asciiz "\nGC!\n"
4238:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4270:nullStr:
    .asciiz "null"
4275:trueString:
    .asciiz "true"
4280:falseString:
    .asciiz "false"
4286:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4305:newlineString:
    .asciiz "\n"
    
    .align 2
4308:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4312:seg0_start:
    .space 0x100000
1052888:seg0_end:
1052888:seg1_start:
    .space 0x100000
2101464:seg1_end:

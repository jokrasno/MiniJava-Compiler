##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
660:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
660#    lw $t0,-8($s2) # get word with hash bits from this
664#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
668#    addu $t0,$t1

672#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
676:mth_equals_Object:
676#    move $t0,$s2 # first pointer (this)
680#    lw $t1,($sp) # second pointer
684#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
685##...subu $at,$t0,$t1
689##...sltiu $t0,$at,1

692#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
696:mth_hashCode_String:
696#    move $t0,$s2 # put this pointer in t0

700#    li $t2,0 # current hash value
704#    lw $t1,-4($t0) # negative of number of characters in string
708#    beq $t1,$zero,done_hashCode_String # if zero length => done
712#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
716#    and $t0,0xfffffffc # adjust for padding
717##...lui $at,65535
721##...ori $at,$at,0xfffc
725##...and $t0,$t0,$at
728#    subu $t1,$t0,$t1 # address at end of string +12
732:loop_hashCode_String:    
732#    sll $t4,$t2,5 # multiply by 32
736#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
740#    lbu $t3,-12($t0) # current character
744#    addu $t2,$t3 # add in current character
748#    addu $t0,1 # go to next character's address
752#    bne $t0,$t1,loop_hashCode_String # loop back if more
756:done_hashCode_String:    

    # push int on stack
756#    move $t0, $t2 # put $t2 in return slot
760#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
764:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
764#    subu $sp,4
768#    sw $ra,($sp)
    
    # get hash value
772#    lw $t2,-12($s2) # vtable address
776#    lw $t0,($t2) # method address
780#    jalr $t0
784#    subu $sp,8 # push result (int in $t0) on stack
788#    sw $s5,4($sp)
792#    sw $t0,($sp)

    # compute print-size of hash value
796#    li $t0, 1
800#    lw $t1, ($sp)
804#    srl $t1,$t1,4
808#    beq $t1,$zero,toString_skip_loop
812:toString_loop_top:
812#    addu $t0,1
816#    srl $t1,$t1,4
820#    bne $t1,$zero,toString_loop_top
824:toString_skip_loop:
824#    subu $sp,8
828#    sw $s5,4($sp)
832#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
836#    lw $t2,-12($s2) # vtable address
840#    move $t0,$t2
844:toString_checkTagBit:
844#    subu $t0,1
848#    lb $t1,($t0)
852#    and $t1,0x80
853##...lui $at,0
857##...ori $at,$at,0x80
861##...and $t1,$t1,$at
864#    beq $t1,$zero,toString_checkTagBit
868#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
872#    subu $sp,8
876#    sw $t1,($sp)
880#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
884#    move $s7,$zero # -4 offset header word
888#    lw $t4,8($sp) # bytes for hash value
892#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
896#    addu $t4,8
900#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
904#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

908#    li $t0,CLASS_String # store string vtable address into ...
912#    sw $t0,-12($s7) # ... -12 offset in object header
916#    lw $t2,-12($s2) # our object's vtable address
920#    lw $t5,4($sp) # number characters in prefix
924#    lw $t1,12($sp) # number of characters in hashcode
928#    addu $t3,$t1,$t5 # number of characters in string ...
932#    addu $t3,1 # ... including the '@' character
936#    subu $t0,$zero,$t3 # store negated length into ...
940#    sw $t0,-4($s7) # ... -4 offset header word
944#    lw $t0,-8($s7) # get -8 offset header-word
948#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
949##...slt $at,$t0,$zero
953##...beq $at,$zero,972
956#    and $t0,0xff # mask off object's hash value ...
957##...lui $at,0
961##...ori $at,$at,0xff
965##...and $t0,$t0,$at
968#    sw $t0,-8($s7) # ... and store back into -8 header-word
972:skipMask_toString:
972#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
976#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
980#    subu $t4,$t2,$t5
984:toString_copyLoop:    
984#    lb $t3,($t4)
988#    and $t3,0x7f # mask off sign bit (in case first word)
989##...lui $at,0
993##...ori $at,$at,0x7f
997##...and $t3,$t3,$at
1000#    sb $t3,-8($t0)
1004#    addu $t4,1
1008#    addu $t0,1
1012#    blt $t4,$t2,toString_copyLoop
1013##...slt $at,$t4,$t2
1017##...bne $at,$zero,984

    # copy the '@' sign
1020#    li $t3,'@'
1024#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value

2509##...addiu $s4,$s4,3876
2512#    sw $zero,cur_seg
2516#    bne $t0,$zero,skipGc1
2520#    la $t6,seg0_start
2524#    la $s3,seg1_start
2525##...lui $s3,16
2529##...addiu $s3,$s3,3876
2532#    la $s4,seg1_end
2533##...lui $s4,32

2188#    lw $t2,-8($t0) # # data words in second string
2192#    lw $t3,-8($t1) # # data words in first string
2196#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
2200#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
2204#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
2208#    subu $t1,$t1,$t3 # beginning of str2 address (+8)

1644#    lw $t2,-4($t0) # negative length of second object
1648#    lw $t3,-4($t1) # negative length of first object
1652#    addu $t4,$t2,$t3 # sum of negative lengths
1656#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object

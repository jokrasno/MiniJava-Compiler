793##...bne $at,$zero,808

    # we have a character, so push it onto stack
796#    subu $sp,$sp,4
800#    sw $v0,($sp)

    # loop back up to get next character
804#    j doRead

808:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
808#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
812#    li $s7, 0 # return-value: null
816#    j rlReturn # return

820:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
820#    subu $t0,$t1,$sp # number of chars we read (times 4)
824#    srl $s6,$t0,2 # number of words on stack with chars
828#    subu $sp,$sp,4 # push char-count ...
832#    sw $s6,($sp) # ... onto stack
836#    addu $t2,$t0,5 # GC tag, incl. for count-word
840#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
844#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
848#    srl $s6,$s6,2  # data words in object
852#    move $s7,$zero # object words in object
856#    jal newObject  # allocate space
    
    # store header words
860#    la $t0,CLASS_String
864#    sw $t0,-12($s7)# store class tag (String) into object
868#    lw $t2,4($sp) # char-count
872#    sll $t1,$t2,2 # 4 times number of chars
876#    subu $t2,$zero,$t2 # negative of char-count
880#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
884#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
888#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
889##...slt $at,$t0,$zero
893##...beq $at,$zero,912
896#    and $t0,0xff # mask off object's hash value ...
897##...lui $at,0
901##...ori $at,$at,0xff
905##...and $t0,$t0,$at
908#    sw $t0,-8($s7) # ... and store back into -8 header-word
912:  skipMask_readLine:

912#    sll $t0,$t0,2 # data bytes in object
916#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
920#    subu $t0,$t0,$t2 # place to store last character (plus 9)
924#    addu $sp,$sp,8 # pop redundant object-pointer and count
928#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

932#    beq $sp,$t1,rlReturn
936:  charCopyLoop:
936#    lw $t2,($sp)
940#    sb $t2,-9($t0)
944#    addu $sp,$sp,4
948#    subu $t0,$t0,1
952#    bne $sp,$t1,charCopyLoop
956:  rlReturn:

956#    lw $ra, 4($sp)
960#    addu $sp, 8   # pop $ra and pointless word off stack
964#    move $t0, $s7 # return string we allocated in $s7
968#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
972:mth_readInt_Lib:

    # save $ra by pushing onto stack
972#    subu $sp,$sp,4
976#    sw $ra,($sp)

980:  riSkipWhiteLoop:
    # read a character
980#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
984#    subu $t0,$v0,32
988#    bgt $t0,$zero,nonWhite
989##...slt $at,$zero,$t0
993##...bne $at,$zero,1036
996#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1000#    subu $t0,$v0,10
1004#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1008#    subu $t0,$v0,9
1012#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1016#    subu $t0,$v0,13
1020#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1024#    subu $t0,$v0,12
1028#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1032#    j badIntegerFormat # illegal integer char: abort program

1036:  nonWhite:
1036#    subu $t0,$v0,'-'
1040#    li $t4,1 # final multiplier
1044#    bne $t0,$zero,helpReadInt # go read
1048#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1052#    jal readLogicalChar

1056:  helpReadInt:
1056#    li $t2,10
1060#    subu $t1,$v0,'0' # convert digit to 0-9 value

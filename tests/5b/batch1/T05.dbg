0:main:
0#  jal vm_init
4#  li $s6,1
8#  li $s7,0
12#  jal newObject
16#  la $t0,CLASS_Main
20#  sw $t0,-12($s7)
24#  lw $t0,0($sp)
28#  sw $s2,0($sp)
32#  move $s2,$t0
36#beq $s2, $zero, nullPtrException
40#  lw $t0,-12($s2)
44#  lw $t0,44($t0)
48#  jalr $t0
52#  lw $s2,($sp)
56#  addu $sp,$sp,4
60#  move $t0,$zero
64#  subu $sp,$sp,4
68#  sw $t0,($sp)
72#  addu $sp,$sp,4
76#  li $v0, 10
80#  syscall
84:mth_main_Main:
84#  subu $sp,$sp,4
88#  sw $ra,($sp)
92#  subu $sp,$sp,4
96#  sw $s2,($sp)
100#  li $t0,3
104#  subu $sp,$sp,8
108#  sw $s5,4($sp)
112#  sw $t0,($sp)
116#  li $t0,52
120#  subu $sp,$sp,8
124#  sw $s5,4($sp)
128#  sw $t0,($sp)
132#  lw $t2,($sp)
136#  addu $sp,$sp,8
140#  lw $t1,($sp)
144#  addu $sp,$sp,8
148#  mul $t0,$t1,$t2
149##...mult $t1,$t2
153##...mflo $t0
156#  subu $sp,$sp,8
160#  sw $s5,4($sp)
164#  sw $t0,($sp)
168#  lw $t0,8($sp)
172#  sw $s2,8($sp)
176#  move $s2,$t0
180#beq $s2, $zero, nullPtrException
184#  jal mth_printInt_Lib
188#  addu $sp,$sp,8
192#  lw $s2,($sp)
196#  addu $sp,$sp,4
200#  move $t0,$zero
204#  subu $sp,$sp,4
208#  sw $t0,($sp)
212#  addu $sp,$sp,4
216#  lw $ra,($sp)
220#  addu $sp,$sp,4
224#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
228:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
228#    lw $t0,-8($s2) # get word with hash bits from this
232#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
236#    addu $t0,$t1

240#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
244:mth_equals_Object:
244#    move $t0,$s2 # first pointer (this)
248#    lw $t1,($sp) # second pointer
252#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
253##...subu $at,$t0,$t1
257##...sltiu $t0,$at,1

260#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
264:mth_hashCode_String:
264#    move $t0,$s2 # put this pointer in t0

268#    li $t2,0 # current hash value
272#    lw $t1,-4($t0) # negative of number of characters in string
276#    beq $t1,$zero,done_hashCode_String # if zero length => done
280#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
284#    and $t0,0xfffffffc # adjust for padding
285##...lui $at,65535
289##...ori $at,$at,0xfffc
293##...and $t0,$t0,$at
296#    subu $t1,$t0,$t1 # address at end of string +12
300:loop_hashCode_String:    
300#    sll $t4,$t2,5 # multiply by 32
304#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
308#    lbu $t3,-12($t0) # current character
312#    addu $t2,$t3 # add in current character
316#    addu $t0,1 # go to next character's address
320#    bne $t0,$t1,loop_hashCode_String # loop back if more
324:done_hashCode_String:    

    # push int on stack
324#    move $t0, $t2 # put $t2 in return slot
328#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
332:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
332#    subu $sp,4
336#    sw $ra,($sp)
    
    # get hash value
340#    lw $t2,-12($s2) # vtable address
344#    lw $t0,($t2) # method address
348#    jalr $t0
352#    subu $sp,8 # push result (int in $t0) on stack
356#    sw $s5,4($sp)
360#    sw $t0,($sp)

    # compute print-size of hash value
364#    li $t0, 1
368#    lw $t1, ($sp)
372#    srl $t1,$t1,4
376#    beq $t1,$zero,toString_skip_loop
380:toString_loop_top:
380#    addu $t0,1
384#    srl $t1,$t1,4
388#    bne $t1,$zero,toString_loop_top
392:toString_skip_loop:
392#    subu $sp,8
396#    sw $s5,4($sp)
400#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
404#    lw $t2,-12($s2) # vtable address
408#    move $t0,$t2
412:toString_checkTagBit:
412#    subu $t0,1
416#    lb $t1,($t0)
420#    and $t1,0x80
421##...lui $at,0
425##...ori $at,$at,0x80
429##...and $t1,$t1,$at
432#    beq $t1,$zero,toString_checkTagBit
436#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
440#    subu $sp,8
444#    sw $t1,($sp)
448#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
452#    move $s7,$zero # -4 offset header word
456#    lw $t4,8($sp) # bytes for hash value
460#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
464#    addu $t4,8
468#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
472#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

476#    li $t0,CLASS_String # store string vtable address into ...
480#    sw $t0,-12($s7) # ... -12 offset in object header
484#    lw $t2,-12($s2) # our object's vtable address
488#    lw $t5,4($sp) # number characters in prefix
492#    lw $t1,12($sp) # number of characters in hashcode
496#    addu $t3,$t1,$t5 # number of characters in string ...
500#    addu $t3,1 # ... including the '@' character
504#    subu $t0,$zero,$t3 # store negated length into ...
508#    sw $t0,-4($s7) # ... -4 offset header word
512#    lw $t0,-8($s7) # get -8 offset header-word
516#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
517##...slt $at,$t0,$zero
521##...beq $at,$zero,540
524#    and $t0,0xff # mask off object's hash value ...
525##...lui $at,0
529##...ori $at,$at,0xff
533##...and $t0,$t0,$at
536#    sw $t0,-8($s7) # ... and store back into -8 header-word
540:skipMask_toString:
540#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
544#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
548#    subu $t4,$t2,$t5
552:toString_copyLoop:    
552#    lb $t3,($t4)
556#    and $t3,0x7f # mask off sign bit (in case first word)
557##...lui $at,0
561##...ori $at,$at,0x7f
565##...and $t3,$t3,$at
568#    sb $t3,-8($t0)
572#    addu $t4,1
576#    addu $t0,1
580#    blt $t4,$t2,toString_copyLoop
581##...slt $at,$t4,$t2
585##...bne $at,$zero,552

    # copy the '@' sign
588#    li $t3,'@'
592#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
596#    addu $t2,$t0,$t1 # address of last byte in string to store +8
600#    lw $t3,20($sp) # hash code to print
604:toString_hashCopyLoop:
604#    and $t4,$t3,0xf
608#    srl $t3,4
612#    lb $t4,hexChars($t4)
616#    sb $t4,-8($t2)
620#    subu $t2,$t2,1
624#    bgt $t2,$t0,toString_hashCopyLoop
625##...slt $at,$t0,$t2
629##...bne $at,$zero,604

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
632#    addu $sp,28
636#    lw $ra,($sp)
640#    addu $sp,4
644#    move $t0, $s7 # return string we created
648#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
652:mth_equals_String:
    
    # quick test for obvious false
652#    lw $t0,($sp) # second parameter
656#    beq $t0,$zero,goEsFalse # go return false if null
660#    lw $t1,-12($t0) # vtable pointer
664#    la $t2,CLASS_String # string vtable pointer
668#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
672#    subu $sp,12
676#    sw $ra,8($sp)
680#    sw $s2,4($sp)
684#    sw $t0,($sp)
688#    jal mth_compareTo_String
692#    lw $s2, 4($sp) #restore this pointer and pop parameters
696#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
700#    seq $t0,$t0,$zero
701##...subu $at,$t0,$zero
705##...sltiu $t0,$at,1

    # pop return address and return $t0
708#    lw $ra,($sp)
712#    addu $sp,4

716#    jr $ra # return
    
720:goEsFalse:
    # put 0 in $t0 and return
720#    li $t0, 0
724#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
728:mth_toString_String:
    #we are a string, so return this.
728#    move $t0, $s2
732#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
736:mth_readLine_Lib:
    
736#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
740#    sw $ra, 4($sp) # save $ra
744#    move $t1,$sp # save "original" sp

748:  doRead:

    # read the character
748#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
752#    subu $t2,$v0,13
756#    bne $t2,$zero,notReturnRL
760#    jal readLogicalChar
764#    subu $t2,$v0,10 # check for newline
768#    beq $t2,$zero,foundNewLine
772#    sw $v0,lastCharRead # push back character into queue
776#    j foundNewLine # go process the line

780:  notReturnRL:

    # at this point, $v0 has our character

780#    subu $t0,$v0,10
784#    beq $t0,$zero,foundNewLine

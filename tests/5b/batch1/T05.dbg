1065##...sltu $at,$t1,$t2
1069##...beq $at,$zero,3316
1072#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1076:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1076#    jal readLogicalChar # read next character
1080#    subu $t1,$v0,'0' # convert digit to 0-9 value
1084#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1085##...sltu $at,$t1,$t2
1089##...beq $at,$zero,1108

1092#    mul $t3,$t3,$t2 # multiply old value by 10
1093##...mult $t3,$t2
1097##...mflo $t3
1100#    addu $t3,$t3,$t1 # add in value of new digit
1104#    j digitLoop

1108:  doneDigitLoop:

    # "push back" unused character into queue

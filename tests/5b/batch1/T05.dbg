
    # determine if we have enough memory available
2316#    addu $t0,$s6,$s7
2320#    sll $t0,$t0,2
2324#    addu $t0,$t0,8 # amount of memory needed
2328#    addu $t1,$t0,$s3
2332#    bgtu $t1,$s4,doGC
2333##...sltu $at,$s4,$t1
2337##...bne $at,$zero,2460

2393##...addiu $at,$at,-28718
2397##...addu $t1,$at,$t1
2400#    sw $t1,prevHashConstant # update hash constant
2404#    or $t1,0x80000000 # set top bit
2405##...lui $at,32768
2409##...or $t1,$at,$t1
2412#    and $t1,0xffffff00 # clear low bit
2413##...lui $at,65535
2417##...ori $at,$at,0xff00
2421##...and $t1,$t1,$at
2424#    or $s6,$t1

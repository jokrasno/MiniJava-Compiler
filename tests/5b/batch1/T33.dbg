1305##...slt $at,$t2,$zero
1309##...bne $at,$zero,3232
1312#    bgt $t2,$t1,strIndexOutOfBounds
1313##...slt $at,$t1,$t2
1317##...bne $at,$zero,3232
1320#    bgt $t1,$t0,strIndexOutOfBounds
1321##...slt $at,$t0,$t1
1325##...bne $at,$zero,3232

    # allocate memory
1328#    subu $s6,$t1,$t2 # # chars in target-string
1332#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1336#    srl $s6,$s6,2 # convert bytes-count to word-count
1340#    move $s7,$zero # (no object-bytes in string)
1344#    jal newObject

    # store "String" tag in object-type field
1348#    la $t0,CLASS_String
1352#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
1356#    lw $t4,-8($s7) # data words in source string
1360#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
1361##...slt $at,$t4,$zero
1365##...beq $at,$zero,1384
1368#    and $t4,0xff # mask off object's hash value ...
1369##...lui $at,0
1373##...ori $at,$at,0xff
1377##...and $t4,$t4,$at
1380#    sw $t4,-8($s7) # ... and store back into -8 header-word
1384:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1384#    lw $t1,8($sp) # k
1388#    lw $t2,16($sp) # n
1392#    subu $t0,$t2,$t1 # value to store
1396#    sw $t0,-4($s7) # store value
    
1400#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
1404#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
1408#    lw $t4,-8($t3) # data words in source string
1412#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
1416#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
1420#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
1424#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
1428#    lw $t2,-8($s7)   # data words in target string
1432#    sll $t2,$t2,2    # data bytes in target string
1436#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target

.text
.globl main
0:main:
0#  jal vm_init
4#  li $s6,1
8#  li $s7,0
12#  jal newObject
16#  la $t0,CLASS_Main
20#  sw $t0,-12($s7)
24#  lw $t0,0($sp)
28#  sw $s2,0($sp)
32#  move $s2,$t0
36#beq $s2, $zero, nullPtrException
40#  lw $t0,-12($s2)
44#  lw $t0,44($t0)
48#  jalr $t0
52#  lw $s2,($sp)
56#  addu $sp,$sp,4
60#  move $t0,$zero
64#  subu $sp,$sp,4
68#  sw $t0,($sp)
72#  addu $sp,$sp,4
76#  li $v0, 10
80#  syscall
84:mth_main_Main:
84#  subu $sp,$sp,4
88#  sw $ra,($sp)
92#  subu $sp,$sp,4
96#  sw $s2,($sp)
100#  move $t0, $zero
104#  subu $sp,$sp,8
108#  sw $s5,4($sp)
112#  sw $t0,($sp)
116#  lw $t0,8($sp)
120#  sw $s2,8($sp)
124#  move $s2,$t0
128#beq $s2, $zero, nullPtrException
132#  jal mth_printBool_Lib
136#  addu $sp,$sp,8
140#  lw $s2,($sp)
144#  addu $sp,$sp,4
148#  move $t0,$zero
152#  subu $sp,$sp,4
156#  sw $t0,($sp)
160#  addu $sp,$sp,4
164#  lw $ra,($sp)
168#  addu $sp,$sp,4
172#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
176:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
176#    lw $t0,-8($s2) # get word with hash bits from this
180#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
184#    addu $t0,$t1

188#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
192:mth_equals_Object:
192#    move $t0,$s2 # first pointer (this)
196#    lw $t1,($sp) # second pointer
200#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
201##...subu $at,$t0,$t1
205##...sltiu $t0,$at,1

208#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
212:mth_hashCode_String:
212#    move $t0,$s2 # put this pointer in t0

216#    li $t2,0 # current hash value
220#    lw $t1,-4($t0) # negative of number of characters in string
224#    beq $t1,$zero,done_hashCode_String # if zero length => done
228#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
232#    and $t0,0xfffffffc # adjust for padding
233##...lui $at,65535
237##...ori $at,$at,0xfffc
241##...and $t0,$t0,$at
244#    subu $t1,$t0,$t1 # address at end of string +12
248:loop_hashCode_String:    
248#    sll $t4,$t2,5 # multiply by 32
252#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
256#    lbu $t3,-12($t0) # current character
260#    addu $t2,$t3 # add in current character
264#    addu $t0,1 # go to next character's address
268#    bne $t0,$t1,loop_hashCode_String # loop back if more
272:done_hashCode_String:    

    # push int on stack
272#    move $t0, $t2 # put $t2 in return slot
276#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
280:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
280#    subu $sp,4
284#    sw $ra,($sp)
    
    # get hash value
288#    lw $t2,-12($s2) # vtable address
292#    lw $t0,($t2) # method address
296#    jalr $t0
300#    subu $sp,8 # push result (int in $t0) on stack
304#    sw $s5,4($sp)
308#    sw $t0,($sp)

    # compute print-size of hash value
312#    li $t0, 1
316#    lw $t1, ($sp)
320#    srl $t1,$t1,4
324#    beq $t1,$zero,toString_skip_loop
328:toString_loop_top:
328#    addu $t0,1
332#    srl $t1,$t1,4
336#    bne $t1,$zero,toString_loop_top
340:toString_skip_loop:
340#    subu $sp,8
344#    sw $s5,4($sp)
348#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
352#    lw $t2,-12($s2) # vtable address
356#    move $t0,$t2
360:toString_checkTagBit:
360#    subu $t0,1
364#    lb $t1,($t0)
368#    and $t1,0x80
369##...lui $at,0
373##...ori $at,$at,0x80
377##...and $t1,$t1,$at
380#    beq $t1,$zero,toString_checkTagBit
384#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
388#    subu $sp,8
392#    sw $t1,($sp)
396#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
400#    move $s7,$zero # -4 offset header word
404#    lw $t4,8($sp) # bytes for hash value
408#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
412#    addu $t4,8
416#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
420#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

424#    li $t0,CLASS_String # store string vtable address into ...
428#    sw $t0,-12($s7) # ... -12 offset in object header
432#    lw $t2,-12($s2) # our object's vtable address
436#    lw $t5,4($sp) # number characters in prefix
440#    lw $t1,12($sp) # number of characters in hashcode
444#    addu $t3,$t1,$t5 # number of characters in string ...
448#    addu $t3,1 # ... including the '@' character
452#    subu $t0,$zero,$t3 # store negated length into ...
456#    sw $t0,-4($s7) # ... -4 offset header word
460#    lw $t0,-8($s7) # get -8 offset header-word
464#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
465##...slt $at,$t0,$zero
469##...beq $at,$zero,488
472#    and $t0,0xff # mask off object's hash value ...
473##...lui $at,0
477##...ori $at,$at,0xff
481##...and $t0,$t0,$at
484#    sw $t0,-8($s7) # ... and store back into -8 header-word
488:skipMask_toString:
488#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
492#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
496#    subu $t4,$t2,$t5
500:toString_copyLoop:    
500#    lb $t3,($t4)
504#    and $t3,0x7f # mask off sign bit (in case first word)
505##...lui $at,0
509##...ori $at,$at,0x7f
513##...and $t3,$t3,$at
516#    sb $t3,-8($t0)
520#    addu $t4,1
524#    addu $t0,1
528#    blt $t4,$t2,toString_copyLoop
529##...slt $at,$t4,$t2
533##...bne $at,$zero,500

    # copy the '@' sign
536#    li $t3,'@'
540#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
544#    addu $t2,$t0,$t1 # address of last byte in string to store +8
548#    lw $t3,20($sp) # hash code to print
552:toString_hashCopyLoop:
552#    and $t4,$t3,0xf
556#    srl $t3,4
560#    lb $t4,hexChars($t4)
564#    sb $t4,-8($t2)
568#    subu $t2,$t2,1
572#    bgt $t2,$t0,toString_hashCopyLoop
573##...slt $at,$t0,$t2
577##...bne $at,$zero,552

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
580#    addu $sp,28
584#    lw $ra,($sp)
588#    addu $sp,4
592#    move $t0, $s7 # return string we created
596#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
600:mth_equals_String:
    
    # quick test for obvious false
600#    lw $t0,($sp) # second parameter
604#    beq $t0,$zero,goEsFalse # go return false if null
608#    lw $t1,-12($t0) # vtable pointer
612#    la $t2,CLASS_String # string vtable pointer
616#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
620#    subu $sp,12
624#    sw $ra,8($sp)
628#    sw $s2,4($sp)
632#    sw $t0,($sp)
636#    jal mth_compareTo_String
640#    lw $s2, 4($sp) #restore this pointer and pop parameters
644#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
648#    seq $t0,$t0,$zero
649##...subu $at,$t0,$zero
653##...sltiu $t0,$at,1

    # pop return address and return $t0
656#    lw $ra,($sp)
660#    addu $sp,4

664#    jr $ra # return
    
668:goEsFalse:
    # put 0 in $t0 and return
668#    li $t0, 0
672#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
676:mth_toString_String:
    #we are a string, so return this.
676#    move $t0, $s2
680#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
684:mth_readLine_Lib:
    
684#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
688#    sw $ra, 4($sp) # save $ra
692#    move $t1,$sp # save "original" sp

696:  doRead:

    # read the character
696#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
700#    subu $t2,$v0,13
704#    bne $t2,$zero,notReturnRL
708#    jal readLogicalChar
712#    subu $t2,$v0,10 # check for newline
716#    beq $t2,$zero,foundNewLine
720#    sw $v0,lastCharRead # push back character into queue
724#    j foundNewLine # go process the line

728:  notReturnRL:

    # at this point, $v0 has our character

728#    subu $t0,$v0,10
732#    beq $t0,$zero,foundNewLine
736#    blt $v0,$zero,foundEof
737##...slt $at,$v0,$zero
741##...bne $at,$zero,756

    # we have a character, so push it onto stack
744#    subu $sp,$sp,4
748#    sw $v0,($sp)

    # loop back up to get next character
752#    j doRead

756:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
756#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
760#    li $s7, 0 # return-value: null
764#    j rlReturn # return

768:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
768#    subu $t0,$t1,$sp # number of chars we read (times 4)
772#    srl $s6,$t0,2 # number of words on stack with chars
776#    subu $sp,$sp,4 # push char-count ...
780#    sw $s6,($sp) # ... onto stack
784#    addu $t2,$t0,5 # GC tag, incl. for count-word
788#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
792#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
796#    srl $s6,$s6,2  # data words in object
800#    move $s7,$zero # object words in object
804#    jal newObject  # allocate space
    
    # store header words
808#    la $t0,CLASS_String
812#    sw $t0,-12($s7)# store class tag (String) into object
816#    lw $t2,4($sp) # char-count
820#    sll $t1,$t2,2 # 4 times number of chars
824#    subu $t2,$zero,$t2 # negative of char-count
828#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
832#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
836#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
837##...slt $at,$t0,$zero
841##...beq $at,$zero,860
844#    and $t0,0xff # mask off object's hash value ...
845##...lui $at,0
849##...ori $at,$at,0xff
853##...and $t0,$t0,$at
856#    sw $t0,-8($s7) # ... and store back into -8 header-word
860:  skipMask_readLine:

860#    sll $t0,$t0,2 # data bytes in object
864#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
868#    subu $t0,$t0,$t2 # place to store last character (plus 9)
872#    addu $sp,$sp,8 # pop redundant object-pointer and count
876#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

880#    beq $sp,$t1,rlReturn
884:  charCopyLoop:
884#    lw $t2,($sp)
888#    sb $t2,-9($t0)
892#    addu $sp,$sp,4
896#    subu $t0,$t0,1
900#    bne $sp,$t1,charCopyLoop
904:  rlReturn:

904#    lw $ra, 4($sp)
908#    addu $sp, 8   # pop $ra and pointless word off stack
912#    move $t0, $s7 # return string we allocated in $s7
916#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
920:mth_readInt_Lib:

    # save $ra by pushing onto stack
920#    subu $sp,$sp,4
924#    sw $ra,($sp)

928:  riSkipWhiteLoop:
    # read a character
928#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
932#    subu $t0,$v0,32
936#    bgt $t0,$zero,nonWhite
937##...slt $at,$zero,$t0
941##...bne $at,$zero,984
944#    beq $t0,$zero,riSkipWhiteLoop # start over if space
948#    subu $t0,$v0,10
952#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
956#    subu $t0,$v0,9
960#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
964#    subu $t0,$v0,13
968#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
972#    subu $t0,$v0,12
976#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
980#    j badIntegerFormat # illegal integer char: abort program

984:  nonWhite:
984#    subu $t0,$v0,'-'
988#    li $t4,1 # final multiplier
992#    bne $t0,$zero,helpReadInt # go read
996#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1000#    jal readLogicalChar

1004:  helpReadInt:
1004#    li $t2,10
1008#    subu $t1,$v0,'0' # convert digit to 0-9 value
1012#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1013##...sltu $at,$t1,$t2
1017##...beq $at,$zero,3264
1020#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1024:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1024#    jal readLogicalChar # read next character
1028#    subu $t1,$v0,'0' # convert digit to 0-9 value
1032#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1033##...sltu $at,$t1,$t2
1037##...beq $at,$zero,1056

1040#    mul $t3,$t3,$t2 # multiply old value by 10
1041##...mult $t3,$t2
1045##...mflo $t3
1048#    addu $t3,$t3,$t1 # add in value of new digit
1052#    j digitLoop

1056:  doneDigitLoop:

    # "push back" unused character into queue
1056#    sw $v0,lastCharRead

    # restore return address
1060#    lw $ra,($sp)
1064#    addu $sp, 4

    # multiply by sign and put return value in $t0
1068#    mult $t3,$t4 # multiply to account for poss. minus sign
1072#    mflo $t3
1076#    move $t0, $t3
    
    # return
1080#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1084:mth_readChar_Lib:

    # save $ra by pushing onto stack
1084#    subu $sp,$sp,4
1088#    sw $ra,($sp)

      # read the character
1092#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1096#    lw $ra,($sp)
1100#    addu $sp, 4
1104#    move $t0, $v0

    # return
1108#    jr $ra

########################################################
# printStr(str) - library method (class Lib)

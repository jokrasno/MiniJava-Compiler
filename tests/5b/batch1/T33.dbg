    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
1512#    lw $t0,-4($t0) # negative size of second object
1516#    lw $t1,-4($t1) # negative size of first object
1520#    addu $s6,$t0,$t1 # sum of negative sizes
1524#    sra $s6,$s6,2 # negative word-size of char part
1528#    subu $s6,$zero,$s6 # word size of char part
1532#    addu $s6,$s6,1 # data word size, including v-table word
1536#    move $s7,$zero
1540#    jal newObject

    # store String vtable address in vtable address field
1544#    la $t0,CLASS_String
1548#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
1552#    lw $t4,-8($s7) # # data words in source string
1556#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
1557##...slt $at,$t4,$zero
1561##...beq $at,$zero,1580
1564#    and $t4,0xff # mask off object's hash value ...
1565##...lui $at,0
1569##...ori $at,$at,0xff
1573##...and $t4,$t4,$at
1576#    sw $t4,-8($s7) # ... and store back into -8 header-word
1580:skipMask_concat:

1580#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
1584#    move $t1,$s2   # first object
1588#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
1592#    lw $t2,-4($t0) # negative length of second object
1596#    lw $t3,-4($t1) # negative length of first object
1600#    addu $t4,$t2,$t3 # sum of negative lengths
1604#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################

    # compute addresses for moving data from first string
1608#    lw $t4,-8($t1) # # data words in first string
1612#    sll $t4,$t4,2 # # data bytes in first string
1616#    subu $t1,$t1,$t4 # addr. (+8) of first byte in first string
1620#    lw $t4,-8($s7) # # data words in new string
1624#    sll $t4,$t4,2 # # data bytes in new string

########################################################
2104:mth_compareTo_String:
    # get string pointers and check parameter for null
2104#    lw $t0,($sp) # second string
2108#    beq $t0,$zero,nullPtrException
2112#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
2116#    lw $t2,-4($t0) # negative length of second string
2120#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
2124#    slt $t4,$t3,$t2
2128#    slt $t5,$t2,$t3
2132#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
2136#    lw $t2,-8($t0) # # data words in second string
2140#    lw $t3,-8($t1) # # data words in first string
2144#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
2148#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
2152#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
2156#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2

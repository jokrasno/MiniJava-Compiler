216#  subu $sp,$sp,4
220#  sw $t0,($sp)
224#  addu $sp,$sp,4
228#  lw $ra,($sp)
232#  addu $sp,$sp,4
236#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
240:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
240#    lw $t0,-8($s2) # get word with hash bits from this
244#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
248#    addu $t0,$t1

252#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
256:mth_equals_Object:
256#    move $t0,$s2 # first pointer (this)
260#    lw $t1,($sp) # second pointer
264#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
265##...subu $at,$t0,$t1
269##...sltiu $t0,$at,1

272#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
276:mth_hashCode_String:
276#    move $t0,$s2 # put this pointer in t0

280#    li $t2,0 # current hash value
284#    lw $t1,-4($t0) # negative of number of characters in string
288#    beq $t1,$zero,done_hashCode_String # if zero length => done
292#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
296#    and $t0,0xfffffffc # adjust for padding
297##...lui $at,65535
301##...ori $at,$at,0xfffc
305##...and $t0,$t0,$at
308#    subu $t1,$t0,$t1 # address at end of string +12
312:loop_hashCode_String:    
312#    sll $t4,$t2,5 # multiply by 32
316#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
320#    lbu $t3,-12($t0) # current character
324#    addu $t2,$t3 # add in current character
328#    addu $t0,1 # go to next character's address
332#    bne $t0,$t1,loop_hashCode_String # loop back if more
336:done_hashCode_String:    

    # push int on stack
336#    move $t0, $t2 # put $t2 in return slot
340#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
344:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
344#    subu $sp,4
348#    sw $ra,($sp)
    
    # get hash value
352#    lw $t2,-12($s2) # vtable address
356#    lw $t0,($t2) # method address
360#    jalr $t0
364#    subu $sp,8 # push result (int in $t0) on stack
368#    sw $s5,4($sp)
372#    sw $t0,($sp)

    # compute print-size of hash value
376#    li $t0, 1
380#    lw $t1, ($sp)
384#    srl $t1,$t1,4
388#    beq $t1,$zero,toString_skip_loop
392:toString_loop_top:
392#    addu $t0,1
396#    srl $t1,$t1,4
400#    bne $t1,$zero,toString_loop_top
404:toString_skip_loop:
404#    subu $sp,8
408#    sw $s5,4($sp)
412#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
416#    lw $t2,-12($s2) # vtable address
420#    move $t0,$t2
424:toString_checkTagBit:
424#    subu $t0,1
428#    lb $t1,($t0)
432#    and $t1,0x80
433##...lui $at,0
437##...ori $at,$at,0x80
441##...and $t1,$t1,$at
444#    beq $t1,$zero,toString_checkTagBit
448#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
452#    subu $sp,8
456#    sw $t1,($sp)
460#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
464#    move $s7,$zero # -4 offset header word
468#    lw $t4,8($sp) # bytes for hash value
472#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
476#    addu $t4,8
480#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
484#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

488#    li $t0,CLASS_String # store string vtable address into ...
492#    sw $t0,-12($s7) # ... -12 offset in object header
496#    lw $t2,-12($s2) # our object's vtable address
500#    lw $t5,4($sp) # number characters in prefix
504#    lw $t1,12($sp) # number of characters in hashcode
508#    addu $t3,$t1,$t5 # number of characters in string ...
512#    addu $t3,1 # ... including the '@' character
516#    subu $t0,$zero,$t3 # store negated length into ...
520#    sw $t0,-4($s7) # ... -4 offset header word
524#    lw $t0,-8($s7) # get -8 offset header-word
528#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
529##...slt $at,$t0,$zero
533##...beq $at,$zero,552
536#    and $t0,0xff # mask off object's hash value ...
537##...lui $at,0
541##...ori $at,$at,0xff
545##...and $t0,$t0,$at
548#    sw $t0,-8($s7) # ... and store back into -8 header-word
552:skipMask_toString:
552#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
556#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
560#    subu $t4,$t2,$t5
564:toString_copyLoop:    
564#    lb $t3,($t4)
568#    and $t3,0x7f # mask off sign bit (in case first word)
569##...lui $at,0
573##...ori $at,$at,0x7f
577##...and $t3,$t3,$at
580#    sb $t3,-8($t0)
584#    addu $t4,1
588#    addu $t0,1
592#    blt $t4,$t2,toString_copyLoop
593##...slt $at,$t4,$t2
597##...bne $at,$zero,564

    # copy the '@' sign
600#    li $t3,'@'
604#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
608#    addu $t2,$t0,$t1 # address of last byte in string to store +8
612#    lw $t3,20($sp) # hash code to print
616:toString_hashCopyLoop:
616#    and $t4,$t3,0xf
620#    srl $t3,4
624#    lb $t4,hexChars($t4)
628#    sb $t4,-8($t2)
632#    subu $t2,$t2,1
636#    bgt $t2,$t0,toString_hashCopyLoop
637##...slt $at,$t0,$t2
641##...bne $at,$zero,616

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
644#    addu $sp,28
648#    lw $ra,($sp)
652#    addu $sp,4
656#    move $t0, $s7 # return string we created
660#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
664:mth_equals_String:
    
    # quick test for obvious false
664#    lw $t0,($sp) # second parameter
668#    beq $t0,$zero,goEsFalse # go return false if null
672#    lw $t1,-12($t0) # vtable pointer
676#    la $t2,CLASS_String # string vtable pointer
680#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
684#    subu $sp,12
688#    sw $ra,8($sp)
692#    sw $s2,4($sp)
696#    sw $t0,($sp)
700#    jal mth_compareTo_String
704#    lw $s2, 4($sp) #restore this pointer and pop parameters
708#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
712#    seq $t0,$t0,$zero
713##...subu $at,$t0,$zero
717##...sltiu $t0,$at,1

    # pop return address and return $t0
720#    lw $ra,($sp)
724#    addu $sp,4

728#    jr $ra # return
    
732:goEsFalse:
    # put 0 in $t0 and return
732#    li $t0, 0
736#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
740:mth_toString_String:
    #we are a string, so return this.
740#    move $t0, $s2
744#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
748:mth_readLine_Lib:
    
748#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
752#    sw $ra, 4($sp) # save $ra
756#    move $t1,$sp # save "original" sp

760:  doRead:

    # read the character
760#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
764#    subu $t2,$v0,13
768#    bne $t2,$zero,notReturnRL
772#    jal readLogicalChar
776#    subu $t2,$v0,10 # check for newline
780#    beq $t2,$zero,foundNewLine
784#    sw $v0,lastCharRead # push back character into queue
788#    j foundNewLine # go process the line

792:  notReturnRL:

    # at this point, $v0 has our character

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3092:vm_init:

    # mark bottom of stack
3092#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3096#    move $s2,$zero

    #set up the "five" register
3100#    li $s5,5

3104#    la $s3,seg0_start
3108#    la $s4,seg0_end
3109##...lui $s4,16
3113##...addiu $s4,$s4,3872
    
    # return
3116#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3120:divide:
    # get parameters; abort if divisor zero
3120#    lw $t0,($sp)
3124#    lw $t1,8($sp)
3128#    beq $t0,$zero,divByZeroError
    
    # perform division
3132#    div $t1,$t0
3136#    mflo $t0

    # store result, adjust stack and return
3140#    addu $sp,$sp,8 # adjust stack
3144#    sw $t0,($sp) # store result
3148#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3152:remainder:
    # get parameters; abort if divisor zero
3152#    lw $t0,($sp)
3156#    lw $t1,8($sp)
3160#    beq $t0,$zero,divByZeroError
    
    # perform division
3164#    div $t1,$t0
3168#    mfhi $t0

    # store result, adjust stack and return
3172#    addu $sp,$sp,8 # adjust stack
3176#    sw $t0,($sp) # store result
3180#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3184:checkCast:
    # get object, allow immediately if null
3184#    lw $t2,($sp)
3188#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3192#    lw $t2,-12($t2) # vtable address
3196#    bge $t2,$t1,castException
3197##...slt $at,$t2,$t1
3201##...beq $at,$zero,3336
3204#    blt $t2,$t0,castException
3205##...slt $at,$t2,$t0
3209##...bne $at,$zero,3336
    
    # return, leaving object unchanged on stack
3212:  checkCastReturn:    
3212#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3216:instanceOf:
    # get object, go return false if null
3216#    lw $t2,($sp)
3220#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3224#    lw $t2,-12($t2) # vtable address
3228#    sge $t0,$t2,$t0 # are we >= the lower limit?
3229##...slt $t0,$t2,$t0
3233##...xori $t0,$t0,0x1
3236#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3240#    and $t2,$t0,$t1
3244#    sw $t2,($sp)
3248:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3248#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3252:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3252#    li $v0,4 # syscall-code for print-string
3256#    syscall
3260:exit:
    # print termination message
3260#    li $v0,4 # syscall-code for print-string
3264#    la $a0,exitString
3268#    syscall

    # terminate execution
3272#    li $v0,10 #syscall-code for "exit"
3276#    syscall

3280:outOfHeapMemory:
3280#    la $a0,heapMemoryMsg
3284#    j exitError
3288:divByZeroError:
3288#    la $a0,divByZeroMsg
3292#    j exitError
3296:strIndexOutOfBounds:
3296#    la $a0,strIndexOutOfBoundsMsg
3300#    j exitError
3304:arrayIndexOutOfBounds:
3304#    la $a0,arrayIndexOutOfBoundsMsg
3308#    j exitError
3312:arraySizeOutOfBounds:
3312#    la $a0,arraySizeOutOfBoundsMsg
3316#    j exitError
3320:nullPtrException:
3320#    la $a0,nullPtrExceptionMsg
3324#    j exitError
3328:badIntegerFormat:
3328#    la $a0,badIntegerFormatMsg
3332#    j exitError
3336:castException:
3336#    la $a0,castExceptionMsg
3340#    j exitError
############## data section ################
    .data
3508:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3524:cur_seg:
    .word 0

3528:lastCharRead:
    .word -2 # -2 => no buffered character
3532:prevHashConstant:
    .word 0x2785173c
3536:gcCount:
    .word 0

3540:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3567:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3590:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3625:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3659:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3692:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3723:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3771:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3792:gcMsg: 
      .asciiz "\nGC!\n"
3798:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3830:nullStr:
    .asciiz "null"
3835:trueString:
    .asciiz "true"
3840:falseString:
    .asciiz "false"
3846:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3865:newlineString:
    .asciiz "\n"
    
    .align 2
3868:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3872:seg0_start:
    .space 0x100000
1052448:seg0_end:
1052448:seg1_start:
    .space 0x100000
2101024:seg1_end:

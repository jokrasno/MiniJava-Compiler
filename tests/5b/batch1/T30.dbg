84:mth_main_Main:
84#  subu $sp,$sp,4
88#  sw $ra,($sp)
92#  li $s6,1
96#  li $s7,0
100#  jal newObject
104#  la $t0,CLASS_Lib
108#  sw $t0,-12($s7)
112#  la $t0,strLit_2
116#  subu $sp,$sp,4
120#  sw $t0,($sp)
124#  move $t0, $zero
128#  subu $sp,$sp,4
132#  sw $t0,($sp)
136#  lw $t2,($sp)
140#  addu $sp,$sp,4
144#  lw $t1,($sp)
148#  addu $sp,$sp,4
152#  seq $t0, $t1, $t2
153##...subu $at,$t1,$t2
157##...sltiu $t0,$at,1
160#  subu $sp,$sp,8
164#  sw $s5,4($sp)
168#  sw $t0,($sp)
172#  lw $t0,8($sp)
176#  sw $s2,8($sp)
180#  move $s2,$t0
184#beq $s2, $zero, nullPtrException
188#  lw $t0,-12($s2)
192#  lw $t0,28($t0)
196#  jalr $t0
200#  addu $sp,$sp,8
204#  lw $s2,($sp)
208#  addu $sp,$sp,4

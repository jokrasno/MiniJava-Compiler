1001##...slt $at,$zero,$t0
1005##...bne $at,$zero,1048
1008#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1012#    subu $t0,$v0,10
1016#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1020#    subu $t0,$v0,9
1024#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1028#    subu $t0,$v0,13
1032#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1036#    subu $t0,$v0,12
1040#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1044#    j badIntegerFormat # illegal integer char: abort program

1048:  nonWhite:
1048#    subu $t0,$v0,'-'
1052#    li $t4,1 # final multiplier
1056#    bne $t0,$zero,helpReadInt # go read
1060#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1064#    jal readLogicalChar

1068:  helpReadInt:
1068#    li $t2,10
1072#    subu $t1,$v0,'0' # convert digit to 0-9 value

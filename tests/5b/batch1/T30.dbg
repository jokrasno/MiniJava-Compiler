1077##...sltu $at,$t1,$t2
1081##...beq $at,$zero,3328
1084#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1088:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1088#    jal readLogicalChar # read next character
1092#    subu $t1,$v0,'0' # convert digit to 0-9 value
1096#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1097##...sltu $at,$t1,$t2
1101##...beq $at,$zero,1120

1104#    mul $t3,$t3,$t2 # multiply old value by 10
1105##...mult $t3,$t2
1109##...mflo $t3
1112#    addu $t3,$t3,$t1 # add in value of new digit
1116#    j digitLoop

1120:  doneDigitLoop:

    # "push back" unused character into queue

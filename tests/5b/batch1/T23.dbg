80#  syscall
84:mth_main_Main:
84#  subu $sp,$sp,4
88#  sw $ra,($sp)
92#  subu $sp,$sp,4
96#  sw $s2,($sp)
100#  li $t0,4027
104#  subu $sp,$sp,8
108#  sw $s5,4($sp)
112#  sw $t0,($sp)
116#  li $t0,4027
120#  subu $sp,$sp,8
124#  sw $s5,4($sp)
128#  sw $t0,($sp)
132#  lw $t2,($sp)
136#  addu $sp,$sp,8
140#  lw $t1,($sp)
144#  addu $sp,$sp,8
148#  slt $t0, $t1, $t2
152#  subu $sp,$sp,8
156#  sw $s5,4($sp)
160#  sw $t0,($sp)
164#  lw $t0,8($sp)
168#  sw $s2,8($sp)
172#  move $s2,$t0
176#beq $s2, $zero, nullPtrException
180#  jal mth_printBool_Lib
184#  addu $sp,$sp,8
188#  lw $s2,($sp)
192#  addu $sp,$sp,4
196#  move $t0,$zero
200#  subu $sp,$sp,4
204#  sw $t0,($sp)

8#  li $s7,0
12#  jal newObject
16#  la $t0,CLASS_Main
20#  sw $t0,-12($s7)
24#  lw $t0,0($sp)
28#  sw $s2,0($sp)
32#  move $s2,$t0
36#beq $s2, $zero, nullPtrException
40#  lw $t0,-12($s2)
44#  lw $t0,44($t0)
48#  jalr $t0
52#  lw $s2,($sp)
56#  addu $sp,$sp,4
60#  move $t0,$zero
64#  subu $sp,$sp,4

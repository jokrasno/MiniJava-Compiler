
    # determine if we have enough memory available
2312#    addu $t0,$s6,$s7
2316#    sll $t0,$t0,2
2320#    addu $t0,$t0,8 # amount of memory needed
2324#    addu $t1,$t0,$s3
2328#    bgtu $t1,$s4,doGC

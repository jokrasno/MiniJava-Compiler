###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
968:mth_readInt_Lib:

    # save $ra by pushing onto stack
968#    subu $sp,$sp,4
972#    sw $ra,($sp)

976:  riSkipWhiteLoop:
    # read a character
976#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
980#    subu $t0,$v0,32
984#    bgt $t0,$zero,nonWhite
985##...slt $at,$zero,$t0
989##...bne $at,$zero,1032
992#    beq $t0,$zero,riSkipWhiteLoop # start over if space
996#    subu $t0,$v0,10
1000#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1004#    subu $t0,$v0,9
1008#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1012#    subu $t0,$v0,13
1016#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1020#    subu $t0,$v0,12
1024#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1028#    j badIntegerFormat # illegal integer char: abort program

1032:  nonWhite:
1032#    subu $t0,$v0,'-'
1036#    li $t4,1 # final multiplier
1040#    bne $t0,$zero,helpReadInt # go read
1044#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1048#    jal readLogicalChar

1052:  helpReadInt:
1052#    li $t2,10
1056#    subu $t1,$v0,'0' # convert digit to 0-9 value

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
224:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
224#    lw $t0,-8($s2) # get word with hash bits from this
228#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
232#    addu $t0,$t1

236#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
240:mth_equals_Object:
240#    move $t0,$s2 # first pointer (this)
244#    lw $t1,($sp) # second pointer
248#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
249##...subu $at,$t0,$t1
253##...sltiu $t0,$at,1

256#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
260:mth_hashCode_String:
260#    move $t0,$s2 # put this pointer in t0

264#    li $t2,0 # current hash value
268#    lw $t1,-4($t0) # negative of number of characters in string
272#    beq $t1,$zero,done_hashCode_String # if zero length => done
276#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
280#    and $t0,0xfffffffc # adjust for padding
281##...lui $at,65535
285##...ori $at,$at,0xfffc
289##...and $t0,$t0,$at
292#    subu $t1,$t0,$t1 # address at end of string +12
296:loop_hashCode_String:    
296#    sll $t4,$t2,5 # multiply by 32
300#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
304#    lbu $t3,-12($t0) # current character
308#    addu $t2,$t3 # add in current character
312#    addu $t0,1 # go to next character's address
316#    bne $t0,$t1,loop_hashCode_String # loop back if more
320:done_hashCode_String:    

    # push int on stack
320#    move $t0, $t2 # put $t2 in return slot
324#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
328:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
328#    subu $sp,4
332#    sw $ra,($sp)
    
    # get hash value
336#    lw $t2,-12($s2) # vtable address
340#    lw $t0,($t2) # method address
344#    jalr $t0
348#    subu $sp,8 # push result (int in $t0) on stack
352#    sw $s5,4($sp)
356#    sw $t0,($sp)

    # compute print-size of hash value
360#    li $t0, 1
364#    lw $t1, ($sp)
368#    srl $t1,$t1,4
372#    beq $t1,$zero,toString_skip_loop
376:toString_loop_top:
376#    addu $t0,1
380#    srl $t1,$t1,4
384#    bne $t1,$zero,toString_loop_top
388:toString_skip_loop:
388#    subu $sp,8
392#    sw $s5,4($sp)
396#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
400#    lw $t2,-12($s2) # vtable address
404#    move $t0,$t2
408:toString_checkTagBit:
408#    subu $t0,1
412#    lb $t1,($t0)
416#    and $t1,0x80
417##...lui $at,0
421##...ori $at,$at,0x80
425##...and $t1,$t1,$at
428#    beq $t1,$zero,toString_checkTagBit
432#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
436#    subu $sp,8
440#    sw $t1,($sp)
444#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
448#    move $s7,$zero # -4 offset header word
452#    lw $t4,8($sp) # bytes for hash value
456#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
460#    addu $t4,8
464#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
468#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

472#    li $t0,CLASS_String # store string vtable address into ...
476#    sw $t0,-12($s7) # ... -12 offset in object header
480#    lw $t2,-12($s2) # our object's vtable address
484#    lw $t5,4($sp) # number characters in prefix
488#    lw $t1,12($sp) # number of characters in hashcode
492#    addu $t3,$t1,$t5 # number of characters in string ...
496#    addu $t3,1 # ... including the '@' character
500#    subu $t0,$zero,$t3 # store negated length into ...
504#    sw $t0,-4($s7) # ... -4 offset header word
508#    lw $t0,-8($s7) # get -8 offset header-word
512#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
513##...slt $at,$t0,$zero
517##...beq $at,$zero,536
520#    and $t0,0xff # mask off object's hash value ...
521##...lui $at,0
525##...ori $at,$at,0xff
529##...and $t0,$t0,$at
532#    sw $t0,-8($s7) # ... and store back into -8 header-word
536:skipMask_toString:
536#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
540#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
544#    subu $t4,$t2,$t5
548:toString_copyLoop:    
548#    lb $t3,($t4)
552#    and $t3,0x7f # mask off sign bit (in case first word)
553##...lui $at,0
557##...ori $at,$at,0x7f
561##...and $t3,$t3,$at
564#    sb $t3,-8($t0)
568#    addu $t4,1
572#    addu $t0,1
576#    blt $t4,$t2,toString_copyLoop
577##...slt $at,$t4,$t2
581##...bne $at,$zero,548

    # copy the '@' sign
584#    li $t3,'@'
588#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
592#    addu $t2,$t0,$t1 # address of last byte in string to store +8
596#    lw $t3,20($sp) # hash code to print
600:toString_hashCopyLoop:
600#    and $t4,$t3,0xf
604#    srl $t3,4
608#    lb $t4,hexChars($t4)
612#    sb $t4,-8($t2)
616#    subu $t2,$t2,1
620#    bgt $t2,$t0,toString_hashCopyLoop
621##...slt $at,$t0,$t2
625##...bne $at,$zero,600

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
628#    addu $sp,28
632#    lw $ra,($sp)
636#    addu $sp,4
640#    move $t0, $s7 # return string we created
644#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
648:mth_equals_String:
    
    # quick test for obvious false
648#    lw $t0,($sp) # second parameter
652#    beq $t0,$zero,goEsFalse # go return false if null
656#    lw $t1,-12($t0) # vtable pointer
660#    la $t2,CLASS_String # string vtable pointer
664#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
668#    subu $sp,12
672#    sw $ra,8($sp)
676#    sw $s2,4($sp)
680#    sw $t0,($sp)
684#    jal mth_compareTo_String
688#    lw $s2, 4($sp) #restore this pointer and pop parameters
692#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
696#    seq $t0,$t0,$zero
697##...subu $at,$t0,$zero
701##...sltiu $t0,$at,1

    # pop return address and return $t0
704#    lw $ra,($sp)
708#    addu $sp,4

712#    jr $ra # return
    
716:goEsFalse:
    # put 0 in $t0 and return
716#    li $t0, 0
720#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
724:mth_toString_String:
    #we are a string, so return this.
724#    move $t0, $s2
728#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
732:mth_readLine_Lib:
    
732#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
736#    sw $ra, 4($sp) # save $ra
740#    move $t1,$sp # save "original" sp

744:  doRead:

    # read the character
744#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
748#    subu $t2,$v0,13
752#    bne $t2,$zero,notReturnRL
756#    jal readLogicalChar
760#    subu $t2,$v0,10 # check for newline
764#    beq $t2,$zero,foundNewLine
768#    sw $v0,lastCharRead # push back character into queue
772#    j foundNewLine # go process the line

776:  notReturnRL:

    # at this point, $v0 has our character


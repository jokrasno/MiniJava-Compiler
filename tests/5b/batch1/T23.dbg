1081##...sltu $at,$t1,$t2
1085##...beq $at,$zero,1104

1088#    mul $t3,$t3,$t2 # multiply old value by 10
1089##...mult $t3,$t2
1093##...mflo $t3
1096#    addu $t3,$t3,$t1 # add in value of new digit
1100#    j digitLoop

1104:  doneDigitLoop:

    # "push back" unused character into queue

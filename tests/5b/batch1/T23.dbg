# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3200:instanceOf:
    # get object, go return false if null
3200#    lw $t2,($sp)
3204#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3208#    lw $t2,-12($t2) # vtable address
3212#    sge $t0,$t2,$t0 # are we >= the lower limit?
3213##...slt $t0,$t2,$t0
3217##...xori $t0,$t0,0x1
3220#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3224#    and $t2,$t0,$t1
3228#    sw $t2,($sp)
3232:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3232#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3236:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3236#    li $v0,4 # syscall-code for print-string
3240#    syscall
3244:exit:
    # print termination message
3244#    li $v0,4 # syscall-code for print-string
3248#    la $a0,exitString
3252#    syscall

    # terminate execution
3256#    li $v0,10 #syscall-code for "exit"
3260#    syscall

3264:outOfHeapMemory:
3264#    la $a0,heapMemoryMsg
3268#    j exitError
3272:divByZeroError:
3272#    la $a0,divByZeroMsg
3276#    j exitError
3280:strIndexOutOfBounds:
3280#    la $a0,strIndexOutOfBoundsMsg
3284#    j exitError
3288:arrayIndexOutOfBounds:
3288#    la $a0,arrayIndexOutOfBoundsMsg
3292#    j exitError
3296:arraySizeOutOfBounds:
3296#    la $a0,arraySizeOutOfBoundsMsg
3300#    j exitError
3304:nullPtrException:
3304#    la $a0,nullPtrExceptionMsg
3308#    j exitError
3312:badIntegerFormat:
3312#    la $a0,badIntegerFormatMsg
3316#    j exitError
3320:castException:
3320#    la $a0,castExceptionMsg
3324#    j exitError
############## data section ################
    .data
3508:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3524:cur_seg:
    .word 0

3528:lastCharRead:
    .word -2 # -2 => no buffered character
3532:prevHashConstant:
    .word 0x2785173c
3536:gcCount:
    .word 0

3540:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3567:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3590:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3625:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3659:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3692:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3723:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3771:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3792:gcMsg: 
      .asciiz "\nGC!\n"
3798:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3830:nullStr:
    .asciiz "null"
3835:trueString:
    .asciiz "true"
3840:falseString:
    .asciiz "false"
3846:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3865:newlineString:
    .asciiz "\n"
    
    .align 2
3868:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3872:seg0_start:
    .space 0x100000
1052448:seg0_end:
1052448:seg1_start:
    .space 0x100000
2101024:seg1_end:

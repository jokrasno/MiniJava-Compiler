100#  la $t0,strLit_0
104#  subu $sp,$sp,4
108#  sw $t0,($sp)
112#  la $t0,strLit_1
116#  subu $sp,$sp,4
120#  sw $t0,($sp)
124#  lw $t2,($sp)
128#  addu $sp,$sp,4
132#  lw $t1,($sp)
136#  addu $sp,$sp,4
140#  seq $t0, $t1, $t2
141##...subu $at,$t1,$t2
145##...sltiu $t0,$at,1
148#  subu $sp,$sp,8
152#  sw $s5,4($sp)
156#  sw $t0,($sp)
160#  lw $t0,8($sp)
164#  sw $s2,8($sp)
168#  move $s2,$t0
172#beq $s2, $zero, nullPtrException
176#  jal mth_printBool_Lib

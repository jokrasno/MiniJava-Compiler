########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3072:vm_init:

    # mark bottom of stack
3072#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3076#    move $s2,$zero

    #set up the "five" register
3080#    li $s5,5

3084#    la $s3,seg0_start
3088#    la $s4,seg0_end
3089##...lui $s4,16
3093##...addiu $s4,$s4,3900
    
    # return
3096#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3100:divide:
    # get parameters; abort if divisor zero
3100#    lw $t0,($sp)
3104#    lw $t1,8($sp)
3108#    beq $t0,$zero,divByZeroError
    
    # perform division
3112#    div $t1,$t0
3116#    mflo $t0

    # store result, adjust stack and return
3120#    addu $sp,$sp,8 # adjust stack
3124#    sw $t0,($sp) # store result
3128#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3132:remainder:
    # get parameters; abort if divisor zero
3132#    lw $t0,($sp)
3136#    lw $t1,8($sp)
3140#    beq $t0,$zero,divByZeroError
    
    # perform division
3144#    div $t1,$t0
3148#    mfhi $t0

    # store result, adjust stack and return
3152#    addu $sp,$sp,8 # adjust stack
3156#    sw $t0,($sp) # store result
3160#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3164:checkCast:
    # get object, allow immediately if null
3164#    lw $t2,($sp)
3168#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3172#    lw $t2,-12($t2) # vtable address
3176#    bge $t2,$t1,castException
3177##...slt $at,$t2,$t1
3181##...beq $at,$zero,3316
3184#    blt $t2,$t0,castException
3185##...slt $at,$t2,$t0
3189##...bne $at,$zero,3316
    
    # return, leaving object unchanged on stack
3192:  checkCastReturn:    
3192#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3196:instanceOf:
    # get object, go return false if null
3196#    lw $t2,($sp)
3200#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3204#    lw $t2,-12($t2) # vtable address
3208#    sge $t0,$t2,$t0 # are we >= the lower limit?
3209##...slt $t0,$t2,$t0
3213##...xori $t0,$t0,0x1
3216#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3220#    and $t2,$t0,$t1
3224#    sw $t2,($sp)
3228:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3228#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3232:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3232#    li $v0,4 # syscall-code for print-string
3236#    syscall
3240:exit:
    # print termination message
3240#    li $v0,4 # syscall-code for print-string
3244#    la $a0,exitString
3248#    syscall

    # terminate execution
3252#    li $v0,10 #syscall-code for "exit"
3256#    syscall

3260:outOfHeapMemory:
3260#    la $a0,heapMemoryMsg
3264#    j exitError
3268:divByZeroError:
3268#    la $a0,divByZeroMsg
3272#    j exitError
3276:strIndexOutOfBounds:
3276#    la $a0,strIndexOutOfBoundsMsg
3280#    j exitError
3284:arrayIndexOutOfBounds:
3284#    la $a0,arrayIndexOutOfBoundsMsg
3288#    j exitError
3292:arraySizeOutOfBounds:
3292#    la $a0,arraySizeOutOfBoundsMsg
3296#    j exitError
3300:nullPtrException:
3300#    la $a0,nullPtrExceptionMsg
3304#    j exitError
3308:badIntegerFormat:
3308#    la $a0,badIntegerFormatMsg
3312#    j exitError
3316:castException:
3316#    la $a0,castExceptionMsg
3320#    j exitError
############## data section ################
    .data
3536:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3552:cur_seg:
    .word 0

3556:lastCharRead:
    .word -2 # -2 => no buffered character
3560:prevHashConstant:
    .word 0x2785173c
3564:gcCount:
    .word 0

3568:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3595:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3618:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3653:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3687:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3720:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3751:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3799:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3820:gcMsg: 
      .asciiz "\nGC!\n"
3826:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3858:nullStr:
    .asciiz "null"
3863:trueString:
    .asciiz "true"
3868:falseString:
    .asciiz "false"
3874:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3893:newlineString:
    .asciiz "\n"
    
    .align 2
3896:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3900:seg0_start:
    .space 0x100000
1052476:seg0_end:
1052476:seg1_start:
    .space 0x100000
2101052:seg1_end:

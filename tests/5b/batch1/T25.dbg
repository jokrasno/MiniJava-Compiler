1068:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1068#    jal readLogicalChar # read next character
1072#    subu $t1,$v0,'0' # convert digit to 0-9 value

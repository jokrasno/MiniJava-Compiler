##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
220:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
220#    lw $t0,-8($s2) # get word with hash bits from this
224#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
228#    addu $t0,$t1

232#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
236:mth_equals_Object:
236#    move $t0,$s2 # first pointer (this)
240#    lw $t1,($sp) # second pointer
244#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
245##...subu $at,$t0,$t1
249##...sltiu $t0,$at,1

252#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
256:mth_hashCode_String:
256#    move $t0,$s2 # put this pointer in t0

260#    li $t2,0 # current hash value
264#    lw $t1,-4($t0) # negative of number of characters in string
268#    beq $t1,$zero,done_hashCode_String # if zero length => done
272#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
276#    and $t0,0xfffffffc # adjust for padding
277##...lui $at,65535
281##...ori $at,$at,0xfffc
285##...and $t0,$t0,$at
288#    subu $t1,$t0,$t1 # address at end of string +12
292:loop_hashCode_String:    
292#    sll $t4,$t2,5 # multiply by 32
296#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
300#    lbu $t3,-12($t0) # current character
304#    addu $t2,$t3 # add in current character
308#    addu $t0,1 # go to next character's address
312#    bne $t0,$t1,loop_hashCode_String # loop back if more
316:done_hashCode_String:    

    # push int on stack
316#    move $t0, $t2 # put $t2 in return slot
320#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
324:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
324#    subu $sp,4
328#    sw $ra,($sp)
    
    # get hash value
332#    lw $t2,-12($s2) # vtable address
336#    lw $t0,($t2) # method address
340#    jalr $t0
344#    subu $sp,8 # push result (int in $t0) on stack
348#    sw $s5,4($sp)
352#    sw $t0,($sp)

    # compute print-size of hash value
356#    li $t0, 1
360#    lw $t1, ($sp)
364#    srl $t1,$t1,4
368#    beq $t1,$zero,toString_skip_loop
372:toString_loop_top:
372#    addu $t0,1
376#    srl $t1,$t1,4
380#    bne $t1,$zero,toString_loop_top
384:toString_skip_loop:
384#    subu $sp,8
388#    sw $s5,4($sp)
392#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
396#    lw $t2,-12($s2) # vtable address
400#    move $t0,$t2
404:toString_checkTagBit:
404#    subu $t0,1
408#    lb $t1,($t0)
412#    and $t1,0x80
413##...lui $at,0
417##...ori $at,$at,0x80
421##...and $t1,$t1,$at
424#    beq $t1,$zero,toString_checkTagBit
428#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
432#    subu $sp,8
436#    sw $t1,($sp)
440#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
444#    move $s7,$zero # -4 offset header word
448#    lw $t4,8($sp) # bytes for hash value
452#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
456#    addu $t4,8
460#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
464#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

468#    li $t0,CLASS_String # store string vtable address into ...
472#    sw $t0,-12($s7) # ... -12 offset in object header
476#    lw $t2,-12($s2) # our object's vtable address
480#    lw $t5,4($sp) # number characters in prefix
484#    lw $t1,12($sp) # number of characters in hashcode
488#    addu $t3,$t1,$t5 # number of characters in string ...
492#    addu $t3,1 # ... including the '@' character
496#    subu $t0,$zero,$t3 # store negated length into ...
500#    sw $t0,-4($s7) # ... -4 offset header word
504#    lw $t0,-8($s7) # get -8 offset header-word
508#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
509##...slt $at,$t0,$zero
513##...beq $at,$zero,532
516#    and $t0,0xff # mask off object's hash value ...
517##...lui $at,0
521##...ori $at,$at,0xff
525##...and $t0,$t0,$at
528#    sw $t0,-8($s7) # ... and store back into -8 header-word
532:skipMask_toString:
532#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
536#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
540#    subu $t4,$t2,$t5
544:toString_copyLoop:    
544#    lb $t3,($t4)
548#    and $t3,0x7f # mask off sign bit (in case first word)
549##...lui $at,0
553##...ori $at,$at,0x7f
557##...and $t3,$t3,$at
560#    sb $t3,-8($t0)
564#    addu $t4,1
568#    addu $t0,1
572#    blt $t4,$t2,toString_copyLoop
573##...slt $at,$t4,$t2
577##...bne $at,$zero,544

    # copy the '@' sign
580#    li $t3,'@'
584#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
588#    addu $t2,$t0,$t1 # address of last byte in string to store +8
592#    lw $t3,20($sp) # hash code to print
596:toString_hashCopyLoop:
596#    and $t4,$t3,0xf
600#    srl $t3,4
604#    lb $t4,hexChars($t4)
608#    sb $t4,-8($t2)
612#    subu $t2,$t2,1
616#    bgt $t2,$t0,toString_hashCopyLoop
617##...slt $at,$t0,$t2
621##...bne $at,$zero,596

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
624#    addu $sp,28
628#    lw $ra,($sp)
632#    addu $sp,4
636#    move $t0, $s7 # return string we created
640#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
644:mth_equals_String:
    
    # quick test for obvious false
644#    lw $t0,($sp) # second parameter
648#    beq $t0,$zero,goEsFalse # go return false if null
652#    lw $t1,-12($t0) # vtable pointer
656#    la $t2,CLASS_String # string vtable pointer
660#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
664#    subu $sp,12
668#    sw $ra,8($sp)
672#    sw $s2,4($sp)
676#    sw $t0,($sp)
680#    jal mth_compareTo_String
684#    lw $s2, 4($sp) #restore this pointer and pop parameters
688#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
692#    seq $t0,$t0,$zero
693##...subu $at,$t0,$zero
697##...sltiu $t0,$at,1

    # pop return address and return $t0
700#    lw $ra,($sp)
704#    addu $sp,4

708#    jr $ra # return
    
712:goEsFalse:
    # put 0 in $t0 and return
712#    li $t0, 0
716#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
720:mth_toString_String:
    #we are a string, so return this.
720#    move $t0, $s2
724#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
728:mth_readLine_Lib:
    
728#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
732#    sw $ra, 4($sp) # save $ra
736#    move $t1,$sp # save "original" sp

968#    sw $ra,($sp)

972:  riSkipWhiteLoop:
    # read a character
972#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
976#    subu $t0,$v0,32
980#    bgt $t0,$zero,nonWhite
981##...slt $at,$zero,$t0
985##...bne $at,$zero,1028
988#    beq $t0,$zero,riSkipWhiteLoop # start over if space
992#    subu $t0,$v0,10
996#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1000#    subu $t0,$v0,9
1004#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1008#    subu $t0,$v0,13
1012#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1016#    subu $t0,$v0,12
1020#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1024#    j badIntegerFormat # illegal integer char: abort program

1028:  nonWhite:
1028#    subu $t0,$v0,'-'
1032#    li $t4,1 # final multiplier
1036#    bne $t0,$zero,helpReadInt # go read
1040#    li $t4,-1 # -1 in final multiplier

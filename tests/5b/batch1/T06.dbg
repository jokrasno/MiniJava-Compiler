904#    lw $t2,($sp)
908#    sb $t2,-9($t0)
912#    addu $sp,$sp,4
916#    subu $t0,$t0,1
920#    bne $sp,$t1,charCopyLoop
924:  rlReturn:

924#    lw $ra, 4($sp)
928#    addu $sp, 8   # pop $ra and pointless word off stack
932#    move $t0, $s7 # return string we allocated in $s7
936#    jr $ra

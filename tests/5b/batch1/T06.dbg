##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
196:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
196#    lw $t0,-8($s2) # get word with hash bits from this
200#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
204#    addu $t0,$t1

208#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
212:mth_equals_Object:
212#    move $t0,$s2 # first pointer (this)
216#    lw $t1,($sp) # second pointer
220#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
221##...subu $at,$t0,$t1
225##...sltiu $t0,$at,1

228#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
232:mth_hashCode_String:
232#    move $t0,$s2 # put this pointer in t0

236#    li $t2,0 # current hash value
240#    lw $t1,-4($t0) # negative of number of characters in string
244#    beq $t1,$zero,done_hashCode_String # if zero length => done
248#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
252#    and $t0,0xfffffffc # adjust for padding
253##...lui $at,65535
257##...ori $at,$at,0xfffc
261##...and $t0,$t0,$at
264#    subu $t1,$t0,$t1 # address at end of string +12
268:loop_hashCode_String:    
268#    sll $t4,$t2,5 # multiply by 32
272#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
276#    lbu $t3,-12($t0) # current character
280#    addu $t2,$t3 # add in current character
284#    addu $t0,1 # go to next character's address
288#    bne $t0,$t1,loop_hashCode_String # loop back if more
292:done_hashCode_String:    

    # push int on stack
292#    move $t0, $t2 # put $t2 in return slot
296#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
300:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
300#    subu $sp,4
304#    sw $ra,($sp)
    
    # get hash value
308#    lw $t2,-12($s2) # vtable address
312#    lw $t0,($t2) # method address
316#    jalr $t0
320#    subu $sp,8 # push result (int in $t0) on stack
324#    sw $s5,4($sp)
328#    sw $t0,($sp)

    # compute print-size of hash value
332#    li $t0, 1
336#    lw $t1, ($sp)
340#    srl $t1,$t1,4
344#    beq $t1,$zero,toString_skip_loop
348:toString_loop_top:
348#    addu $t0,1
352#    srl $t1,$t1,4
356#    bne $t1,$zero,toString_loop_top
360:toString_skip_loop:
360#    subu $sp,8
364#    sw $s5,4($sp)
368#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
372#    lw $t2,-12($s2) # vtable address
376#    move $t0,$t2
380:toString_checkTagBit:
380#    subu $t0,1
384#    lb $t1,($t0)
388#    and $t1,0x80
389##...lui $at,0
393##...ori $at,$at,0x80
397##...and $t1,$t1,$at
400#    beq $t1,$zero,toString_checkTagBit
404#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
408#    subu $sp,8
412#    sw $t1,($sp)
416#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
420#    move $s7,$zero # -4 offset header word
424#    lw $t4,8($sp) # bytes for hash value
428#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
432#    addu $t4,8
436#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
440#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

444#    li $t0,CLASS_String # store string vtable address into ...
448#    sw $t0,-12($s7) # ... -12 offset in object header
452#    lw $t2,-12($s2) # our object's vtable address
456#    lw $t5,4($sp) # number characters in prefix
460#    lw $t1,12($sp) # number of characters in hashcode
464#    addu $t3,$t1,$t5 # number of characters in string ...
468#    addu $t3,1 # ... including the '@' character
472#    subu $t0,$zero,$t3 # store negated length into ...
476#    sw $t0,-4($s7) # ... -4 offset header word
480#    lw $t0,-8($s7) # get -8 offset header-word
484#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
485##...slt $at,$t0,$zero
489##...beq $at,$zero,508
492#    and $t0,0xff # mask off object's hash value ...
493##...lui $at,0
497##...ori $at,$at,0xff
501##...and $t0,$t0,$at
504#    sw $t0,-8($s7) # ... and store back into -8 header-word
508:skipMask_toString:
508#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
512#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
516#    subu $t4,$t2,$t5
520:toString_copyLoop:    
520#    lb $t3,($t4)
524#    and $t3,0x7f # mask off sign bit (in case first word)
525##...lui $at,0
529##...ori $at,$at,0x7f
533##...and $t3,$t3,$at
536#    sb $t3,-8($t0)
540#    addu $t4,1
544#    addu $t0,1
548#    blt $t4,$t2,toString_copyLoop
549##...slt $at,$t4,$t2
553##...bne $at,$zero,520

    # copy the '@' sign
556#    li $t3,'@'
560#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
564#    addu $t2,$t0,$t1 # address of last byte in string to store +8
568#    lw $t3,20($sp) # hash code to print
572:toString_hashCopyLoop:
572#    and $t4,$t3,0xf
576#    srl $t3,4
580#    lb $t4,hexChars($t4)
584#    sb $t4,-8($t2)
588#    subu $t2,$t2,1
592#    bgt $t2,$t0,toString_hashCopyLoop
593##...slt $at,$t0,$t2
597##...bne $at,$zero,572

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
600#    addu $sp,28
604#    lw $ra,($sp)
608#    addu $sp,4
612#    move $t0, $s7 # return string we created
616#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
620:mth_equals_String:
    
    # quick test for obvious false
620#    lw $t0,($sp) # second parameter
624#    beq $t0,$zero,goEsFalse # go return false if null
628#    lw $t1,-12($t0) # vtable pointer
632#    la $t2,CLASS_String # string vtable pointer
636#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
640#    subu $sp,12
644#    sw $ra,8($sp)
648#    sw $s2,4($sp)
652#    sw $t0,($sp)
656#    jal mth_compareTo_String
660#    lw $s2, 4($sp) #restore this pointer and pop parameters
664#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
668#    seq $t0,$t0,$zero
669##...subu $at,$t0,$zero
673##...sltiu $t0,$at,1

    # pop return address and return $t0
676#    lw $ra,($sp)
680#    addu $sp,4

684#    jr $ra # return
    
688:goEsFalse:
    # put 0 in $t0 and return
688#    li $t0, 0
692#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
696:mth_toString_String:
    #we are a string, so return this.
696#    move $t0, $s2
700#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
704:mth_readLine_Lib:
    
704#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
708#    sw $ra, 4($sp) # save $ra
712#    move $t1,$sp # save "original" sp

716:  doRead:

    # read the character
716#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
720#    subu $t2,$v0,13
724#    bne $t2,$zero,notReturnRL
728#    jal readLogicalChar
732#    subu $t2,$v0,10 # check for newline
736#    beq $t2,$zero,foundNewLine
740#    sw $v0,lastCharRead # push back character into queue
744#    j foundNewLine # go process the line

748:  notReturnRL:

    # at this point, $v0 has our character

748#    subu $t0,$v0,10
752#    beq $t0,$zero,foundNewLine
756#    blt $v0,$zero,foundEof
757##...slt $at,$v0,$zero
761##...bne $at,$zero,776

    # we have a character, so push it onto stack
764#    subu $sp,$sp,4
768#    sw $v0,($sp)

    # loop back up to get next character
772#    j doRead

776:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
776#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
780#    li $s7, 0 # return-value: null
784#    j rlReturn # return

788:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
788#    subu $t0,$t1,$sp # number of chars we read (times 4)
792#    srl $s6,$t0,2 # number of words on stack with chars
796#    subu $sp,$sp,4 # push char-count ...
800#    sw $s6,($sp) # ... onto stack
804#    addu $t2,$t0,5 # GC tag, incl. for count-word
808#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
812#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
816#    srl $s6,$s6,2  # data words in object
820#    move $s7,$zero # object words in object
824#    jal newObject  # allocate space
    
    # store header words
828#    la $t0,CLASS_String
832#    sw $t0,-12($s7)# store class tag (String) into object
836#    lw $t2,4($sp) # char-count
840#    sll $t1,$t2,2 # 4 times number of chars
844#    subu $t2,$zero,$t2 # negative of char-count
848#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
852#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
856#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
857##...slt $at,$t0,$zero
861##...beq $at,$zero,880
864#    and $t0,0xff # mask off object's hash value ...
865##...lui $at,0
869##...ori $at,$at,0xff
873##...and $t0,$t0,$at
876#    sw $t0,-8($s7) # ... and store back into -8 header-word
880:  skipMask_readLine:

880#    sll $t0,$t0,2 # data bytes in object
884#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
888#    subu $t0,$t0,$t2 # place to store last character (plus 9)
892#    addu $sp,$sp,8 # pop redundant object-pointer and count
896#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

900#    beq $sp,$t1,rlReturn

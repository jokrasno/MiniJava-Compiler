8#  li $s7,0
12#  jal newObject
16#  la $t0,CLASS_Main
20#  sw $t0,-12($s7)
24#  lw $t0,0($sp)
28#  sw $s2,0($sp)
32#  move $s2,$t0
36#beq $s2, $zero, nullPtrException
40#  lw $t0,-12($s2)
44#  lw $t0,44($t0)
48#  jalr $t0
52#  lw $s2,($sp)
56#  addu $sp,$sp,4
60#  move $t0,$zero
64#  subu $sp,$sp,4
68#  sw $t0,($sp)
72#  addu $sp,$sp,4
76#  li $v0, 10
80#  syscall
84:mth_main_Main:
84#  subu $sp,$sp,4
88#  sw $ra,($sp)
92#  subu $sp,$sp,4
96#  sw $s2,($sp)
100#  li $t0,52
104#  subu $sp,$sp,8
108#  sw $s5,4($sp)
112#  sw $t0,($sp)
116#  li $t0,5
120#  subu $sp,$sp,8
124#  sw $s5,4($sp)
128#  sw $t0,($sp)
132#  jal divide
136#  lw $t0,8($sp)
140#  sw $s2,8($sp)
144#  move $s2,$t0
148#beq $s2, $zero, nullPtrException
152#  jal mth_printInt_Lib
156#  addu $sp,$sp,8
160#  lw $s2,($sp)
164#  addu $sp,$sp,4
168#  move $t0,$zero
172#  subu $sp,$sp,4
176#  sw $t0,($sp)
180#  addu $sp,$sp,4

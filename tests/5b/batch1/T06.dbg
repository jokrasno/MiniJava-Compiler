#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3172:instanceOf:
    # get object, go return false if null
3172#    lw $t2,($sp)
3176#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3180#    lw $t2,-12($t2) # vtable address
3184#    sge $t0,$t2,$t0 # are we >= the lower limit?
3185##...slt $t0,$t2,$t0
3189##...xori $t0,$t0,0x1
3192#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3196#    and $t2,$t0,$t1
3200#    sw $t2,($sp)
3204:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3204#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3208:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3208#    li $v0,4 # syscall-code for print-string
3212#    syscall
3216:exit:
    # print termination message
3216#    li $v0,4 # syscall-code for print-string
3220#    la $a0,exitString
3224#    syscall

    # terminate execution
3228#    li $v0,10 #syscall-code for "exit"
3232#    syscall

3236:outOfHeapMemory:
3236#    la $a0,heapMemoryMsg
3240#    j exitError
3244:divByZeroError:
3244#    la $a0,divByZeroMsg
3248#    j exitError
3252:strIndexOutOfBounds:
3252#    la $a0,strIndexOutOfBoundsMsg
3256#    j exitError
3260:arrayIndexOutOfBounds:
3260#    la $a0,arrayIndexOutOfBoundsMsg
3264#    j exitError
3268:arraySizeOutOfBounds:
3268#    la $a0,arraySizeOutOfBoundsMsg
3272#    j exitError
3276:nullPtrException:
3276#    la $a0,nullPtrExceptionMsg
3280#    j exitError
3284:badIntegerFormat:
3284#    la $a0,badIntegerFormatMsg
3288#    j exitError
3292:castException:
3292#    la $a0,castExceptionMsg
3296#    j exitError
############## data section ################
    .data
3480:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3496:cur_seg:
    .word 0

3500:lastCharRead:
    .word -2 # -2 => no buffered character
3504:prevHashConstant:
    .word 0x2785173c
3508:gcCount:
    .word 0

3512:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3539:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3562:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3597:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3631:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3664:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3695:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3743:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3764:gcMsg: 
      .asciiz "\nGC!\n"
3770:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3802:nullStr:
    .asciiz "null"
3807:trueString:
    .asciiz "true"
3812:falseString:
    .asciiz "false"
3818:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3837:newlineString:
    .asciiz "\n"
    
    .align 2
3840:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3844:seg0_start:
    .space 0x100000
1052420:seg0_end:
1052420:seg1_start:
    .space 0x100000
2100996:seg1_end:

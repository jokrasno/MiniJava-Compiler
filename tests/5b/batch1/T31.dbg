##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
232:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
232#    lw $t0,-8($s2) # get word with hash bits from this
236#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
240#    addu $t0,$t1

244#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
248:mth_equals_Object:
248#    move $t0,$s2 # first pointer (this)
252#    lw $t1,($sp) # second pointer
256#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
257##...subu $at,$t0,$t1
261##...sltiu $t0,$at,1

264#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
268:mth_hashCode_String:
268#    move $t0,$s2 # put this pointer in t0

272#    li $t2,0 # current hash value
276#    lw $t1,-4($t0) # negative of number of characters in string
280#    beq $t1,$zero,done_hashCode_String # if zero length => done
284#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
288#    and $t0,0xfffffffc # adjust for padding
289##...lui $at,65535
293##...ori $at,$at,0xfffc
297##...and $t0,$t0,$at
300#    subu $t1,$t0,$t1 # address at end of string +12
304:loop_hashCode_String:    
304#    sll $t4,$t2,5 # multiply by 32
308#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
312#    lbu $t3,-12($t0) # current character
316#    addu $t2,$t3 # add in current character
320#    addu $t0,1 # go to next character's address
324#    bne $t0,$t1,loop_hashCode_String # loop back if more
328:done_hashCode_String:    

    # push int on stack
328#    move $t0, $t2 # put $t2 in return slot
332#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
336:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
336#    subu $sp,4
340#    sw $ra,($sp)
    
    # get hash value
344#    lw $t2,-12($s2) # vtable address
348#    lw $t0,($t2) # method address
352#    jalr $t0
356#    subu $sp,8 # push result (int in $t0) on stack
360#    sw $s5,4($sp)
364#    sw $t0,($sp)

    # compute print-size of hash value
368#    li $t0, 1
372#    lw $t1, ($sp)
376#    srl $t1,$t1,4
380#    beq $t1,$zero,toString_skip_loop
384:toString_loop_top:
384#    addu $t0,1
388#    srl $t1,$t1,4
392#    bne $t1,$zero,toString_loop_top
396:toString_skip_loop:
396#    subu $sp,8
400#    sw $s5,4($sp)
404#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
408#    lw $t2,-12($s2) # vtable address
412#    move $t0,$t2
416:toString_checkTagBit:
416#    subu $t0,1
420#    lb $t1,($t0)
424#    and $t1,0x80
425##...lui $at,0
429##...ori $at,$at,0x80
433##...and $t1,$t1,$at
436#    beq $t1,$zero,toString_checkTagBit
440#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
444#    subu $sp,8
448#    sw $t1,($sp)
452#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
456#    move $s7,$zero # -4 offset header word
460#    lw $t4,8($sp) # bytes for hash value
464#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
468#    addu $t4,8
472#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
476#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

480#    li $t0,CLASS_String # store string vtable address into ...
484#    sw $t0,-12($s7) # ... -12 offset in object header
488#    lw $t2,-12($s2) # our object's vtable address
492#    lw $t5,4($sp) # number characters in prefix
496#    lw $t1,12($sp) # number of characters in hashcode
500#    addu $t3,$t1,$t5 # number of characters in string ...
504#    addu $t3,1 # ... including the '@' character
508#    subu $t0,$zero,$t3 # store negated length into ...
512#    sw $t0,-4($s7) # ... -4 offset header word
516#    lw $t0,-8($s7) # get -8 offset header-word
520#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
521##...slt $at,$t0,$zero
525##...beq $at,$zero,544
528#    and $t0,0xff # mask off object's hash value ...
529##...lui $at,0
533##...ori $at,$at,0xff
537##...and $t0,$t0,$at
540#    sw $t0,-8($s7) # ... and store back into -8 header-word
544:skipMask_toString:
544#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
548#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
552#    subu $t4,$t2,$t5
556:toString_copyLoop:    
556#    lb $t3,($t4)
560#    and $t3,0x7f # mask off sign bit (in case first word)
561##...lui $at,0
565##...ori $at,$at,0x7f
569##...and $t3,$t3,$at
572#    sb $t3,-8($t0)
576#    addu $t4,1
580#    addu $t0,1
584#    blt $t4,$t2,toString_copyLoop
585##...slt $at,$t4,$t2
589##...bne $at,$zero,556

    # copy the '@' sign
592#    li $t3,'@'
596#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
600#    addu $t2,$t0,$t1 # address of last byte in string to store +8
604#    lw $t3,20($sp) # hash code to print
608:toString_hashCopyLoop:
608#    and $t4,$t3,0xf
612#    srl $t3,4
616#    lb $t4,hexChars($t4)
620#    sb $t4,-8($t2)
624#    subu $t2,$t2,1
628#    bgt $t2,$t0,toString_hashCopyLoop
629##...slt $at,$t0,$t2
633##...bne $at,$zero,608

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
636#    addu $sp,28
640#    lw $ra,($sp)
644#    addu $sp,4
648#    move $t0, $s7 # return string we created
652#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
656:mth_equals_String:
    
    # quick test for obvious false
656#    lw $t0,($sp) # second parameter
660#    beq $t0,$zero,goEsFalse # go return false if null
664#    lw $t1,-12($t0) # vtable pointer
668#    la $t2,CLASS_String # string vtable pointer
672#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
676#    subu $sp,12
680#    sw $ra,8($sp)
684#    sw $s2,4($sp)
688#    sw $t0,($sp)
692#    jal mth_compareTo_String
696#    lw $s2, 4($sp) #restore this pointer and pop parameters
700#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
704#    seq $t0,$t0,$zero
705##...subu $at,$t0,$zero
709##...sltiu $t0,$at,1

    # pop return address and return $t0
712#    lw $ra,($sp)
716#    addu $sp,4

720#    jr $ra # return
    
724:goEsFalse:
    # put 0 in $t0 and return
724#    li $t0, 0
728#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
732:mth_toString_String:
    #we are a string, so return this.
732#    move $t0, $s2
736#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
740:mth_readLine_Lib:
    
740#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
744#    sw $ra, 4($sp) # save $ra
748#    move $t1,$sp # save "original" sp

752:  doRead:

    # read the character
752#    jal readLogicalChar

    # if we have a 'return', read another character to check for

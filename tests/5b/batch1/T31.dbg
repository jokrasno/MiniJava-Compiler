    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3184#    lw $t2,-12($t2) # vtable address
3188#    bge $t2,$t1,castException
3189##...slt $at,$t2,$t1
3193##...beq $at,$zero,3328
3196#    blt $t2,$t0,castException
3197##...slt $at,$t2,$t0
3201##...bne $at,$zero,3328
    
    # return, leaving object unchanged on stack
3204:  checkCastReturn:    
3204#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3208:instanceOf:
    # get object, go return false if null
3208#    lw $t2,($sp)
3212#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3216#    lw $t2,-12($t2) # vtable address
3220#    sge $t0,$t2,$t0 # are we >= the lower limit?
3221##...slt $t0,$t2,$t0
3225##...xori $t0,$t0,0x1
3228#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3232#    and $t2,$t0,$t1
3236#    sw $t2,($sp)
3240:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3240#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3244:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3244#    li $v0,4 # syscall-code for print-string
3248#    syscall
3252:exit:
    # print termination message
3252#    li $v0,4 # syscall-code for print-string
3256#    la $a0,exitString
3260#    syscall

    # terminate execution
3264#    li $v0,10 #syscall-code for "exit"
3268#    syscall

3272:outOfHeapMemory:
3272#    la $a0,heapMemoryMsg
3276#    j exitError
3280:divByZeroError:
3280#    la $a0,divByZeroMsg
3284#    j exitError
3288:strIndexOutOfBounds:
3288#    la $a0,strIndexOutOfBoundsMsg
3292#    j exitError
3296:arrayIndexOutOfBounds:
3296#    la $a0,arrayIndexOutOfBoundsMsg
3300#    j exitError
3304:arraySizeOutOfBounds:
3304#    la $a0,arraySizeOutOfBoundsMsg
3308#    j exitError
3312:nullPtrException:
3312#    la $a0,nullPtrExceptionMsg
3316#    j exitError
3320:badIntegerFormat:
3320#    la $a0,badIntegerFormatMsg
3324#    j exitError
3328:castException:
3328#    la $a0,castExceptionMsg
3332#    j exitError
############## data section ################
    .data
3532:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3548:cur_seg:
    .word 0

3552:lastCharRead:
    .word -2 # -2 => no buffered character
3556:prevHashConstant:
    .word 0x2785173c
3560:gcCount:
    .word 0

3564:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3591:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3614:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3649:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3683:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3716:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3747:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3795:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3816:gcMsg: 
      .asciiz "\nGC!\n"
3822:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3854:nullStr:
    .asciiz "null"
3859:trueString:
    .asciiz "true"
3864:falseString:
    .asciiz "false"
3870:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3889:newlineString:
    .asciiz "\n"
    
    .align 2
3892:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3896:seg0_start:
    .space 0x100000
1052472:seg0_end:
1052472:seg1_start:
    .space 0x100000
2101048:seg1_end:

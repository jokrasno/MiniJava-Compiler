905##...ori $at,$at,0xff
909##...and $t0,$t0,$at
912#    sw $t0,-8($s7) # ... and store back into -8 header-word
916:  skipMask_readLine:

916#    sll $t0,$t0,2 # data bytes in object
920#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
924#    subu $t0,$t0,$t2 # place to store last character (plus 9)

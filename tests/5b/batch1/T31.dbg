    # store header words
864#    la $t0,CLASS_String
868#    sw $t0,-12($s7)# store class tag (String) into object
872#    lw $t2,4($sp) # char-count
876#    sll $t1,$t2,2 # 4 times number of chars
880#    subu $t2,$zero,$t2 # negative of char-count
884#    sw $t2,-4($s7) # store negative char-count as header-word 2

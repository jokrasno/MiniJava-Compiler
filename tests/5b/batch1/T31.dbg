824#    subu $t0,$t1,$sp # number of chars we read (times 4)
828#    srl $s6,$t0,2 # number of words on stack with chars
832#    subu $sp,$sp,4 # push char-count ...
836#    sw $s6,($sp) # ... onto stack
840#    addu $t2,$t0,5 # GC tag, incl. for count-word
844#    sw $t2,($t1) # store GC tag

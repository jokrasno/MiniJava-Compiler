1012#    subu $t0,$v0,9
1016#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1020#    subu $t0,$v0,13
1024#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1028#    subu $t0,$v0,12
1032#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed

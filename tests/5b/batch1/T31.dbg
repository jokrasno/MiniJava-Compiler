104#  subu $sp,$sp,4
108#  sw $t0,($sp)
112#  move $t0, $zero
116#  subu $sp,$sp,4
120#  sw $t0,($sp)
124#  lw $t2,($sp)
128#  addu $sp,$sp,4
132#  lw $t1,($sp)
136#  addu $sp,$sp,4
140#  seq $t0, $t1, $t2
141##...subu $at,$t1,$t2
145##...sltiu $t0,$at,1
148#  subu $sp,$sp,8
152#  sw $s5,4($sp)
156#  sw $t0,($sp)
160#  lw $t0, ($sp)
164#  xor $t0, $t0, 1
168#  sw $t0, ($sp)
172#  lw $t0,8($sp)
176#  sw $s2,8($sp)
180#  move $s2,$t0
184#beq $s2, $zero, nullPtrException
188#  jal mth_printBool_Lib

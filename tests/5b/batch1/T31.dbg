    # mask off hash bits, if needed
1608#    lw $t4,-8($s7) # # data words in source string
1612#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
1613##...slt $at,$t4,$zero
1617##...beq $at,$zero,1636

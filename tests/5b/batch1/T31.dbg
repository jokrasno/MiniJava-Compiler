1632#    sw $t4,-8($s7) # ... and store back into -8 header-word
1636:skipMask_concat:

1636#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
1640#    move $t1,$s2   # first object
1644#    lw $t0,8($sp) # second object

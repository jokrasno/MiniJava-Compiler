#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
19716:instanceOf:
    # get object, go return false if null
19716#    lw $t2,($sp)
19720#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
19724#    lw $t2,-12($t2) # vtable address
19728#    sge $t0,$t2,$t0 # are we >= the lower limit?
19729##...slt $t0,$t2,$t0
19733##...xori $t0,$t0,0x1
19736#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
19740#    and $t2,$t0,$t1
19744#    sw $t2,($sp)
19748:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
19748#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

19752:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
19752#    li $v0,4 # syscall-code for print-string
19756#    syscall
19760:exit:
    # print termination message
19760#    li $v0,4 # syscall-code for print-string
19764#    la $a0,exitString
19768#    syscall

    # terminate execution
19772#    li $v0,10 #syscall-code for "exit"
19776#    syscall

19780:outOfHeapMemory:
19780#    la $a0,heapMemoryMsg
19784#    j exitError
19788:divByZeroError:
19788#    la $a0,divByZeroMsg
19792#    j exitError
19796:strIndexOutOfBounds:
19796#    la $a0,strIndexOutOfBoundsMsg
19800#    j exitError
19804:arrayIndexOutOfBounds:
19804#    la $a0,arrayIndexOutOfBoundsMsg
19808#    j exitError
19812:arraySizeOutOfBounds:
19812#    la $a0,arraySizeOutOfBoundsMsg
19816#    j exitError
19820:nullPtrException:
19820#    la $a0,nullPtrExceptionMsg
19824#    j exitError
19828:badIntegerFormat:
19828#    la $a0,badIntegerFormatMsg
19832#    j exitError
19836:castException:
19836#    la $a0,castExceptionMsg
19840#    j exitError
############## data section ################
    .data
21060:hexChars:
    .ascii "0123456789abcdef"
    .align 2
21076:cur_seg:
    .word 0

21080:lastCharRead:
    .word -2 # -2 => no buffered character
21084:prevHashConstant:
    .word 0x2785173c
21088:gcCount:
    .word 0

21092:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
21119:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
21142:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
21177:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
21211:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
21244:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
21275:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
21323:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
21344:gcMsg: 
      .asciiz "\nGC!\n"
21350:gcCountMsg: 
      .asciiz "Number of garbage collections: "

21382:nullStr:
    .asciiz "null"
21387:trueString:
    .asciiz "true"
21392:falseString:
    .asciiz "false"
21398:exitString:
    .ascii "Program terminated."
    #### "falls through" here
21417:newlineString:
    .asciiz "\n"
    
    .align 2
21420:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

21424:seg0_start:
    .space 0x100000
1070000:seg0_end:
1070000:seg1_start:
    .space 0x100000
2118576:seg1_end:

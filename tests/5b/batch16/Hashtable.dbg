##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
16740:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
16740#    lw $t0,-8($s2) # get word with hash bits from this
16744#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
16748#    addu $t0,$t1

16752#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
16756:mth_equals_Object:
16756#    move $t0,$s2 # first pointer (this)
16760#    lw $t1,($sp) # second pointer
16764#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
16765##...subu $at,$t0,$t1
16769##...sltiu $t0,$at,1

16772#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
16776:mth_hashCode_String:
16776#    move $t0,$s2 # put this pointer in t0

16780#    li $t2,0 # current hash value
16784#    lw $t1,-4($t0) # negative of number of characters in string
16788#    beq $t1,$zero,done_hashCode_String # if zero length => done
16792#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
16796#    and $t0,0xfffffffc # adjust for padding
16797##...lui $at,65535
16801##...ori $at,$at,0xfffc
16805##...and $t0,$t0,$at
16808#    subu $t1,$t0,$t1 # address at end of string +12
16812:loop_hashCode_String:    
16812#    sll $t4,$t2,5 # multiply by 32
16816#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
16820#    lbu $t3,-12($t0) # current character
16824#    addu $t2,$t3 # add in current character
16828#    addu $t0,1 # go to next character's address
16832#    bne $t0,$t1,loop_hashCode_String # loop back if more
16836:done_hashCode_String:    

    # push int on stack
16836#    move $t0, $t2 # put $t2 in return slot
16840#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
16844:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
16844#    subu $sp,4
16848#    sw $ra,($sp)
    
    # get hash value
16852#    lw $t2,-12($s2) # vtable address
16856#    lw $t0,($t2) # method address
16860#    jalr $t0
16864#    subu $sp,8 # push result (int in $t0) on stack
16868#    sw $s5,4($sp)
16872#    sw $t0,($sp)

    # compute print-size of hash value
16876#    li $t0, 1
16880#    lw $t1, ($sp)
16884#    srl $t1,$t1,4
16888#    beq $t1,$zero,toString_skip_loop
16892:toString_loop_top:
16892#    addu $t0,1
16896#    srl $t1,$t1,4
16900#    bne $t1,$zero,toString_loop_top
16904:toString_skip_loop:
16904#    subu $sp,8
16908#    sw $s5,4($sp)
16912#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
16916#    lw $t2,-12($s2) # vtable address
16920#    move $t0,$t2
16924:toString_checkTagBit:
16924#    subu $t0,1
16928#    lb $t1,($t0)
16932#    and $t1,0x80
16933##...lui $at,0
16937##...ori $at,$at,0x80
16941##...and $t1,$t1,$at
16944#    beq $t1,$zero,toString_checkTagBit
16948#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
16952#    subu $sp,8
16956#    sw $t1,($sp)
16960#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
16964#    move $s7,$zero # -4 offset header word
16968#    lw $t4,8($sp) # bytes for hash value
16972#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
16976#    addu $t4,8
16980#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
16984#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

16988#    li $t0,CLASS_String # store string vtable address into ...
16992#    sw $t0,-12($s7) # ... -12 offset in object header
16996#    lw $t2,-12($s2) # our object's vtable address
17000#    lw $t5,4($sp) # number characters in prefix
17004#    lw $t1,12($sp) # number of characters in hashcode
17008#    addu $t3,$t1,$t5 # number of characters in string ...
17012#    addu $t3,1 # ... including the '@' character
17016#    subu $t0,$zero,$t3 # store negated length into ...
17020#    sw $t0,-4($s7) # ... -4 offset header word
17024#    lw $t0,-8($s7) # get -8 offset header-word
17028#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
17029##...slt $at,$t0,$zero
17033##...beq $at,$zero,17052
17036#    and $t0,0xff # mask off object's hash value ...
17037##...lui $at,0
17041##...ori $at,$at,0xff
17045##...and $t0,$t0,$at
17048#    sw $t0,-8($s7) # ... and store back into -8 header-word
17052:skipMask_toString:
17052#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
17056#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
17060#    subu $t4,$t2,$t5
17064:toString_copyLoop:    
17064#    lb $t3,($t4)
17068#    and $t3,0x7f # mask off sign bit (in case first word)
17069##...lui $at,0
17073##...ori $at,$at,0x7f
17077##...and $t3,$t3,$at
17080#    sb $t3,-8($t0)
17084#    addu $t4,1
17088#    addu $t0,1
17092#    blt $t4,$t2,toString_copyLoop
17093##...slt $at,$t4,$t2
17097##...bne $at,$zero,17064

    # copy the '@' sign
17100#    li $t3,'@'
17104#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
17108#    addu $t2,$t0,$t1 # address of last byte in string to store +8
17112#    lw $t3,20($sp) # hash code to print
17116:toString_hashCopyLoop:
17116#    and $t4,$t3,0xf
17120#    srl $t3,4
17124#    lb $t4,hexChars($t4)
17128#    sb $t4,-8($t2)
17132#    subu $t2,$t2,1
17136#    bgt $t2,$t0,toString_hashCopyLoop
17137##...slt $at,$t0,$t2
17141##...bne $at,$zero,17116

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
17144#    addu $sp,28
17148#    lw $ra,($sp)
17152#    addu $sp,4
17156#    move $t0, $s7 # return string we created
17160#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
17164:mth_equals_String:
    
    # quick test for obvious false
17164#    lw $t0,($sp) # second parameter
17168#    beq $t0,$zero,goEsFalse # go return false if null
17172#    lw $t1,-12($t0) # vtable pointer
17176#    la $t2,CLASS_String # string vtable pointer
17180#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
17184#    subu $sp,12
17188#    sw $ra,8($sp)
17192#    sw $s2,4($sp)
17196#    sw $t0,($sp)
17200#    jal mth_compareTo_String
17204#    lw $s2, 4($sp) #restore this pointer and pop parameters
17208#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
17212#    seq $t0,$t0,$zero
17213##...subu $at,$t0,$zero
17217##...sltiu $t0,$at,1

    # pop return address and return $t0
17220#    lw $ra,($sp)
17224#    addu $sp,4

17228#    jr $ra # return
    
17232:goEsFalse:
    # put 0 in $t0 and return
17232#    li $t0, 0
17236#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
17240:mth_toString_String:
    #we are a string, so return this.
17240#    move $t0, $s2
17244#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
17248:mth_readLine_Lib:
    
17248#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
17252#    sw $ra, 4($sp) # save $ra
17256#    move $t1,$sp # save "original" sp

17260:  doRead:

    # read the character
17260#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
17264#    subu $t2,$v0,13
17268#    bne $t2,$zero,notReturnRL
17272#    jal readLogicalChar
17276#    subu $t2,$v0,10 # check for newline
17280#    beq $t2,$zero,foundNewLine
17284#    sw $v0,lastCharRead # push back character into queue
17288#    j foundNewLine # go process the line

17292:  notReturnRL:

    # at this point, $v0 has our character

17292#    subu $t0,$v0,10
17296#    beq $t0,$zero,foundNewLine
17300#    blt $v0,$zero,foundEof
17301##...slt $at,$v0,$zero
17305##...bne $at,$zero,17320

    # we have a character, so push it onto stack
17308#    subu $sp,$sp,4
17312#    sw $v0,($sp)

    # loop back up to get next character
17316#    j doRead

17320:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
17320#    bne $t1,$sp foundNewLine

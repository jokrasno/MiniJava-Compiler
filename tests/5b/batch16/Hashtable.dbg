17332:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
17332#    subu $t0,$t1,$sp # number of chars we read (times 4)
17336#    srl $s6,$t0,2 # number of words on stack with chars
17340#    subu $sp,$sp,4 # push char-count ...
17344#    sw $s6,($sp) # ... onto stack
17348#    addu $t2,$t0,5 # GC tag, incl. for count-word
17352#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
17356#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
17360#    srl $s6,$s6,2  # data words in object
17364#    move $s7,$zero # object words in object
17368#    jal newObject  # allocate space
    
    # store header words
17372#    la $t0,CLASS_String
17376#    sw $t0,-12($s7)# store class tag (String) into object
17380#    lw $t2,4($sp) # char-count
17384#    sll $t1,$t2,2 # 4 times number of chars
17388#    subu $t2,$zero,$t2 # negative of char-count
17392#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
17396#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
17400#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
17401##...slt $at,$t0,$zero
17405##...beq $at,$zero,17424
17408#    and $t0,0xff # mask off object's hash value ...
17409##...lui $at,0
17413##...ori $at,$at,0xff
17417##...and $t0,$t0,$at
17420#    sw $t0,-8($s7) # ... and store back into -8 header-word
17424:  skipMask_readLine:

17424#    sll $t0,$t0,2 # data bytes in object
17428#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
17432#    subu $t0,$t0,$t2 # place to store last character (plus 9)
17436#    addu $sp,$sp,8 # pop redundant object-pointer and count
17440#    addu $t1,$t1,$sp # first non-char spot on stack

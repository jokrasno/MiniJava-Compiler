19049##...addiu $s4,$s4,21424
19052#    sw $s5,cur_seg
19056:  skipGc1:
19056#    li $t5,0x80000000
19060#    lw $t0,stack_bottom
19064#    subu $t0,4


    ###############################################################
    # at this point:
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space

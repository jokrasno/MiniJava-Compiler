19701##...beq $at,$zero,19836
19704#    blt $t2,$t0,castException
19705##...slt $at,$t2,$t0
19709##...bne $at,$zero,19836
    
    # return, leaving object unchanged on stack
19712:  checkCastReturn:    
19712#    jr $ra    

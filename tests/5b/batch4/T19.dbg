###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1404:mth_hashCode_String:
1404#    move $t0,$s2 # put this pointer in t0

1408#    li $t2,0 # current hash value
1412#    lw $t1,-4($t0) # negative of number of characters in string
1416#    beq $t1,$zero,done_hashCode_String # if zero length => done
1420#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1424#    and $t0,0xfffffffc # adjust for padding
1425##...lui $at,65535
1429##...ori $at,$at,0xfffc
1433##...and $t0,$t0,$at
1436#    subu $t1,$t0,$t1 # address at end of string +12
1440:loop_hashCode_String:    
1440#    sll $t4,$t2,5 # multiply by 32
1444#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1448#    lbu $t3,-12($t0) # current character
1452#    addu $t2,$t3 # add in current character
1456#    addu $t0,1 # go to next character's address
1460#    bne $t0,$t1,loop_hashCode_String # loop back if more
1464:done_hashCode_String:    

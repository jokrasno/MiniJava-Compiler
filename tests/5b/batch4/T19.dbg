###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1876:mth_readLine_Lib:
    
1876#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1880#    sw $ra, 4($sp) # save $ra
1884#    move $t1,$sp # save "original" sp

1888:  doRead:

    # read the character
1888#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1892#    subu $t2,$v0,13
1896#    bne $t2,$zero,notReturnRL
1900#    jal readLogicalChar
1904#    subu $t2,$v0,10 # check for newline
1908#    beq $t2,$zero,foundNewLine
1912#    sw $v0,lastCharRead # push back character into queue
1916#    j foundNewLine # go process the line

1920:  notReturnRL:

    # at this point, $v0 has our character

1920#    subu $t0,$v0,10
1924#    beq $t0,$zero,foundNewLine
1928#    blt $v0,$zero,foundEof
1929##...slt $at,$v0,$zero
1933##...bne $at,$zero,1948

    # we have a character, so push it onto stack
1936#    subu $sp,$sp,4
1940#    sw $v0,($sp)

    # loop back up to get next character
1944#    j doRead

1948:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1948#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1952#    li $s7, 0 # return-value: null
1956#    j rlReturn # return

1960:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1960#    subu $t0,$t1,$sp # number of chars we read (times 4)
1964#    srl $s6,$t0,2 # number of words on stack with chars
1968#    subu $sp,$sp,4 # push char-count ...
1972#    sw $s6,($sp) # ... onto stack
1976#    addu $t2,$t0,5 # GC tag, incl. for count-word
1980#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1984#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1988#    srl $s6,$s6,2  # data words in object
1992#    move $s7,$zero # object words in object
1996#    jal newObject  # allocate space
    
    # store header words
2000#    la $t0,CLASS_String
2004#    sw $t0,-12($s7)# store class tag (String) into object
2008#    lw $t2,4($sp) # char-count
2012#    sll $t1,$t2,2 # 4 times number of chars
2016#    subu $t2,$zero,$t2 # negative of char-count
2020#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2024#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2028#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2029##...slt $at,$t0,$zero
2033##...beq $at,$zero,2052
2036#    and $t0,0xff # mask off object's hash value ...
2037##...lui $at,0
2041##...ori $at,$at,0xff
2045##...and $t0,$t0,$at
2048#    sw $t0,-8($s7) # ... and store back into -8 header-word
2052:  skipMask_readLine:

2052#    sll $t0,$t0,2 # data bytes in object
2056#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2060#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2064#    addu $sp,$sp,8 # pop redundant object-pointer and count
2068#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2072#    beq $sp,$t1,rlReturn
2076:  charCopyLoop:
2076#    lw $t2,($sp)
2080#    sb $t2,-9($t0)
2084#    addu $sp,$sp,4
2088#    subu $t0,$t0,1
2092#    bne $sp,$t1,charCopyLoop
2096:  rlReturn:

2096#    lw $ra, 4($sp)
2100#    addu $sp, 8   # pop $ra and pointless word off stack
2104#    move $t0, $s7 # return string we allocated in $s7
2108#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2112:mth_readInt_Lib:

    # save $ra by pushing onto stack
2112#    subu $sp,$sp,4
2116#    sw $ra,($sp)

2120:  riSkipWhiteLoop:
    # read a character
2120#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2124#    subu $t0,$v0,32
2128#    bgt $t0,$zero,nonWhite
2129##...slt $at,$zero,$t0
2133##...bne $at,$zero,2176
2136#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2140#    subu $t0,$v0,10
2144#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2148#    subu $t0,$v0,9
2152#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2156#    subu $t0,$v0,13
2160#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2164#    subu $t0,$v0,12
2168#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2172#    j badIntegerFormat # illegal integer char: abort program

2176:  nonWhite:
2176#    subu $t0,$v0,'-'
2180#    li $t4,1 # final multiplier
2184#    bne $t0,$zero,helpReadInt # go read
2188#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2192#    jal readLogicalChar

2196:  helpReadInt:
2196#    li $t2,10
2200#    subu $t1,$v0,'0' # convert digit to 0-9 value
2204#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2205##...sltu $at,$t1,$t2
2209##...beq $at,$zero,4456
2212#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2216:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2216#    jal readLogicalChar # read next character
2220#    subu $t1,$v0,'0' # convert digit to 0-9 value
2224#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2225##...sltu $at,$t1,$t2
2229##...beq $at,$zero,2248

2232#    mul $t3,$t3,$t2 # multiply old value by 10
2233##...mult $t3,$t2
2237##...mflo $t3
2240#    addu $t3,$t3,$t1 # add in value of new digit
2244#    j digitLoop

2248:  doneDigitLoop:

    # "push back" unused character into queue
2248#    sw $v0,lastCharRead

    # restore return address
2252#    lw $ra,($sp)
2256#    addu $sp, 4

    # multiply by sign and put return value in $t0
2260#    mult $t3,$t4 # multiply to account for poss. minus sign
2264#    mflo $t3
2268#    move $t0, $t3
    
    # return
2272#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2276:mth_readChar_Lib:

    # save $ra by pushing onto stack
2276#    subu $sp,$sp,4
2280#    sw $ra,($sp)

      # read the character
2284#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
2288#    lw $ra,($sp)
2292#    addu $sp, 4
2296#    move $t0, $v0

    # return

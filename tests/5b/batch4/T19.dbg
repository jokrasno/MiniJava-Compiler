
    # get n from string.
3228#    lw $t1,8($sp)

    # store "String" tag into class field
3232#    la $t0,CLASS_String
3236#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
3240#    lw $t4,-8($s7) # # data words in source string

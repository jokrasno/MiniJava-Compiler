3916:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
3916#    lw $t1,($t0) # (what will be) first header word for current object
3920#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
3924#    bge $t2,$zero,gcSkip4a # are there hash bits?
3925##...slt $at,$t2,$zero
3929##...beq $at,$zero,3944
3932#    and $t2,0xff # mask off hash bits
3933##...lui $at,0
3937##...ori $at,$at,0xff
3941##...and $t2,$t2,$at
3944:gcSkip4a:    
3944#    sll $t2,$t2,2 # # data bytes
3948#    addu $t2,$t2,8 # to skip header words
3952#    addu $t2,$t0,$t2 # pointer to new object
3956#    lw $t3,-8($t2) # word to swap
3960#    sw $t1,-8($t2) # store header word
3964#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3968#    lw $t1,-12($t2) # vtable pointer
3972#    li $t0,dataArrayVTableStart # address of vtable for first data array
3976#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3977##...slt $at,$t1,$t0
3981##...bne $at,$zero,4000

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3984:  skipToNextObj:
3984#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3988#    sll $t1,$t1,2 # convert to byte-count
3992#    addu $t0,$t2,$t1 # skip over object
3996#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
4000:  gcNotDataArray:
4000#    lw $t3,-4($t2) # # object words (negative treated as zero)
4004#    bge $t3,$zero,gcH2Neg2
4005##...slt $at,$t3,$zero
4009##...beq $at,$zero,4016
4012#    move $t3,$zero
4016:  gcH2Neg2:
4016#    sll $t3,$t3,2 # # object bytes
4020#    move $t0,$t2 # address of first pointer in object
4024#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
4028#    beq $t0,$s1,gcTestIterDone2
    
4032:  gcNextPointerInObject:
    # get pointer from object
4032#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
4036#    bleu $t1,$t6,gcGoNextPointerSlot
4037##...sltu $at,$t6,$t1
4041##...beq $at,$zero,4184
4044#    bgtu $t1,$t7,gcGoNextPointerSlot
4045##...sltu $at,$t7,$t1
4049##...bne $at,$zero,4184

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4052#    lw $t8,-8($t1) # possible forwarding tag
4056#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
4060#    lw $t8,-4($t1) # forwarding pointer: object's new address
4064#    sw $t8,($t0) # update pointer in object
4068#    j gcGoNextPointerSlot # do next iteration

4072:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
4072#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
4073##...slt $at,$t8,$zero
4077##...beq $at,$zero,4092
4080#    and $t8,0xff # mask off hash bits
4081##...lui $at,0
4085##...ori $at,$at,0xff
4089##...and $t8,$t8,$at

4092:  gcSkip5:
4092#    sll $t8,$t8,2 # bytes in negative-offset portion ...
4096#    addu $t8,$t8,8 # ... add in bytes for header-words
4100#    subu $t4,$t1,$t8 # address of first word of source object
4104#    lw $t3,-4($t1) # # words in positive-offset portion
4108#    bge $t3,$zero,gcNoNeg
4109##...slt $at,$t3,$zero
4113##...beq $at,$zero,4120
4116#    move $t3,$zero # negative treated as zero
4120:  gcNoNeg:
4120#    sll $t3,$t3,2 # bytes in negative-offset portion
4124#    addu $t3,$t3,$t1 # address one word past last word of source

4128#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4132#    lw $s0,($t4)
4136#    lw $t9,-8($t1)
4140#    sw $t9,($t4)
4144#    sw $s0,-8($t1)

    # copy all source bytes to the target
4148:  gCinnerCopy2:
4148#    lw $s0,($t4)
4152#    sw $s0,($s3)
4156#    addu $t4,$t4,4
4160#    addu $s3,$s3,4
4164#    bltu $t4,$t3,gCinnerCopy2
4165##...sltu $at,$t4,$t3
4169##...bne $at,$zero,4148

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4172#    sw $zero,-8($t1) # 0 in first header-slot
4176#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4180#    sw $t8,($t0)

4184:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4184#    addu $t0,$t0,4
4188#    bltu $t0,$s1,gcNextPointerInObject
4189##...sltu $at,$t0,$s1
4193##...bne $at,$zero,4032

4196:  gcTestIterDone2:
4196#    bltu $t0,$s3,gcHeapCopyLoop
4197##...sltu $at,$t0,$s3
4201##...bne $at,$zero,3916

    ###### end outer loop to copy all non-stack-direct objects ######

4204:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4204#    lw $s2,($sp)
4208#    addu $sp,$sp,4

    # mark us as having already GC'd
4212#    move $t5,$s5

    # go try and allocate again
4216#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4220:vm_init:

    # mark bottom of stack
4220#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4224#    move $s2,$zero

    #set up the "five" register
4228#    li $s5,5

4232#    la $s3,seg0_start
4236#    la $s4,seg0_end
4237##...lui $s4,16
4241##...addiu $s4,$s4,5048
    
    # return
4244#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4248:divide:
    # get parameters; abort if divisor zero
4248#    lw $t0,($sp)
4252#    lw $t1,8($sp)
4256#    beq $t0,$zero,divByZeroError
    
    # perform division
4260#    div $t1,$t0
4264#    mflo $t0

    # store result, adjust stack and return
4268#    addu $sp,$sp,8 # adjust stack
4272#    sw $t0,($sp) # store result
4276#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4280:remainder:
    # get parameters; abort if divisor zero
4280#    lw $t0,($sp)
4284#    lw $t1,8($sp)
4288#    beq $t0,$zero,divByZeroError
    
    # perform division
4292#    div $t1,$t0
4296#    mfhi $t0

    # store result, adjust stack and return
4300#    addu $sp,$sp,8 # adjust stack
4304#    sw $t0,($sp) # store result
4308#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4312:checkCast:
    # get object, allow immediately if null
4312#    lw $t2,($sp)
4316#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4320#    lw $t2,-12($t2) # vtable address
4324#    bge $t2,$t1,castException
4325##...slt $at,$t2,$t1
4329##...beq $at,$zero,4464
4332#    blt $t2,$t0,castException
4333##...slt $at,$t2,$t0
4337##...bne $at,$zero,4464
    
    # return, leaving object unchanged on stack
4340:  checkCastReturn:    
4340#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4344:instanceOf:
    # get object, go return false if null
4344#    lw $t2,($sp)
4348#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4352#    lw $t2,-12($t2) # vtable address
4356#    sge $t0,$t2,$t0 # are we >= the lower limit?
4357##...slt $t0,$t2,$t0
4361##...xori $t0,$t0,0x1
4364#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4368#    and $t2,$t0,$t1
4372#    sw $t2,($sp)
4376:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4376#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4380:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4380#    li $v0,4 # syscall-code for print-string
4384#    syscall
4388:exit:
    # print termination message
4388#    li $v0,4 # syscall-code for print-string
4392#    la $a0,exitString
4396#    syscall

    # terminate execution
4400#    li $v0,10 #syscall-code for "exit"
4404#    syscall

4408:outOfHeapMemory:
4408#    la $a0,heapMemoryMsg
4412#    j exitError
4416:divByZeroError:
4416#    la $a0,divByZeroMsg
4420#    j exitError
4424:strIndexOutOfBounds:
4424#    la $a0,strIndexOutOfBoundsMsg
4428#    j exitError
4432:arrayIndexOutOfBounds:
4432#    la $a0,arrayIndexOutOfBoundsMsg
4436#    j exitError
4440:arraySizeOutOfBounds:
4440#    la $a0,arraySizeOutOfBoundsMsg
4444#    j exitError
4448:nullPtrException:
4448#    la $a0,nullPtrExceptionMsg
4452#    j exitError
4456:badIntegerFormat:
4456#    la $a0,badIntegerFormatMsg
4460#    j exitError
4464:castException:
4464#    la $a0,castExceptionMsg
4468#    j exitError
############## data section ################
    .data
4684:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4700:cur_seg:
    .word 0

4704:lastCharRead:
    .word -2 # -2 => no buffered character
4708:prevHashConstant:
    .word 0x2785173c
4712:gcCount:
    .word 0

4716:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4743:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4766:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4801:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4835:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4868:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4899:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4947:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4968:gcMsg: 
      .asciiz "\nGC!\n"
4974:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5006:nullStr:
    .asciiz "null"
5011:trueString:
    .asciiz "true"
5016:falseString:
    .asciiz "false"
5022:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5041:newlineString:
    .asciiz "\n"
    
    .align 2
5044:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5048:seg0_start:
    .space 0x100000
1053624:seg0_end:
1053624:seg1_start:
    .space 0x100000
2102200:seg1_end:

3268#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
3272#    li $t0,-1
3276#    sw $t0,-4($s7)

    # we're returning $s7
3280#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
3284#    lw $ra,4($sp)
3288#    addu $sp,$sp,8

    # return
3292#    jr $ra

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1472:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1472#    subu $sp,4
1476#    sw $ra,($sp)
    
    # get hash value
1480#    lw $t2,-12($s2) # vtable address
1484#    lw $t0,($t2) # method address
1488#    jalr $t0
1492#    subu $sp,8 # push result (int in $t0) on stack
1496#    sw $s5,4($sp)
1500#    sw $t0,($sp)

    # compute print-size of hash value
1504#    li $t0, 1
1508#    lw $t1, ($sp)
1512#    srl $t1,$t1,4
1516#    beq $t1,$zero,toString_skip_loop
1520:toString_loop_top:
1520#    addu $t0,1
1524#    srl $t1,$t1,4
1528#    bne $t1,$zero,toString_loop_top
1532:toString_skip_loop:
1532#    subu $sp,8
1536#    sw $s5,4($sp)
1540#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1544#    lw $t2,-12($s2) # vtable address
1548#    move $t0,$t2
1552:toString_checkTagBit:
1552#    subu $t0,1
1556#    lb $t1,($t0)
1560#    and $t1,0x80
1561##...lui $at,0
1565##...ori $at,$at,0x80
1569##...and $t1,$t1,$at
1572#    beq $t1,$zero,toString_checkTagBit
1576#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1580#    subu $sp,8
1584#    sw $t1,($sp)
1588#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1592#    move $s7,$zero # -4 offset header word
1596#    lw $t4,8($sp) # bytes for hash value
1600#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1604#    addu $t4,8
1608#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1612#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1616#    li $t0,CLASS_String # store string vtable address into ...
1620#    sw $t0,-12($s7) # ... -12 offset in object header
1624#    lw $t2,-12($s2) # our object's vtable address
1628#    lw $t5,4($sp) # number characters in prefix
1632#    lw $t1,12($sp) # number of characters in hashcode
1636#    addu $t3,$t1,$t5 # number of characters in string ...
1640#    addu $t3,1 # ... including the '@' character
1644#    subu $t0,$zero,$t3 # store negated length into ...
1648#    sw $t0,-4($s7) # ... -4 offset header word
1652#    lw $t0,-8($s7) # get -8 offset header-word
1656#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1657##...slt $at,$t0,$zero
1661##...beq $at,$zero,1680
1664#    and $t0,0xff # mask off object's hash value ...
1665##...lui $at,0
1669##...ori $at,$at,0xff
1673##...and $t0,$t0,$at
1676#    sw $t0,-8($s7) # ... and store back into -8 header-word
1680:skipMask_toString:
1680#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1684#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1688#    subu $t4,$t2,$t5
1692:toString_copyLoop:    
1692#    lb $t3,($t4)
1696#    and $t3,0x7f # mask off sign bit (in case first word)
1697##...lui $at,0
1701##...ori $at,$at,0x7f
1705##...and $t3,$t3,$at
1708#    sb $t3,-8($t0)
1712#    addu $t4,1
1716#    addu $t0,1

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
3144:mth_readLine_Lib:
    
3144#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
3148#    sw $ra, 4($sp) # save $ra
3152#    move $t1,$sp # save "original" sp

3156:  doRead:

    # read the character
3156#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
3160#    subu $t2,$v0,13
3164#    bne $t2,$zero,notReturnRL
3168#    jal readLogicalChar
3172#    subu $t2,$v0,10 # check for newline
3176#    beq $t2,$zero,foundNewLine
3180#    sw $v0,lastCharRead # push back character into queue
3184#    j foundNewLine # go process the line

3188:  notReturnRL:

    # at this point, $v0 has our character

3188#    subu $t0,$v0,10
3192#    beq $t0,$zero,foundNewLine
3196#    blt $v0,$zero,foundEof
3197##...slt $at,$v0,$zero
3201##...bne $at,$zero,3216

    # we have a character, so push it onto stack
3204#    subu $sp,$sp,4
3208#    sw $v0,($sp)

    # loop back up to get next character
3212#    j doRead

3216:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
3216#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
3220#    li $s7, 0 # return-value: null
3224#    j rlReturn # return

3228:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
3228#    subu $t0,$t1,$sp # number of chars we read (times 4)
3232#    srl $s6,$t0,2 # number of words on stack with chars
3236#    subu $sp,$sp,4 # push char-count ...
3240#    sw $s6,($sp) # ... onto stack
3244#    addu $t2,$t0,5 # GC tag, incl. for count-word
3248#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
3252#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
3256#    srl $s6,$s6,2  # data words in object
3260#    move $s7,$zero # object words in object
3264#    jal newObject  # allocate space
    
    # store header words
3268#    la $t0,CLASS_String
3272#    sw $t0,-12($s7)# store class tag (String) into object
3276#    lw $t2,4($sp) # char-count
3280#    sll $t1,$t2,2 # 4 times number of chars
3284#    subu $t2,$zero,$t2 # negative of char-count
3288#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3292#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3296#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3297##...slt $at,$t0,$zero
3301##...beq $at,$zero,3320
3304#    and $t0,0xff # mask off object's hash value ...
3305##...lui $at,0
3309##...ori $at,$at,0xff
3313##...and $t0,$t0,$at
3316#    sw $t0,-8($s7) # ... and store back into -8 header-word
3320:  skipMask_readLine:

3320#    sll $t0,$t0,2 # data bytes in object
3324#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
3328#    subu $t0,$t0,$t2 # place to store last character (plus 9)
3332#    addu $sp,$sp,8 # pop redundant object-pointer and count
3336#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

3340#    beq $sp,$t1,rlReturn
3344:  charCopyLoop:
3344#    lw $t2,($sp)
3348#    sb $t2,-9($t0)
3352#    addu $sp,$sp,4
3356#    subu $t0,$t0,1
3360#    bne $sp,$t1,charCopyLoop
3364:  rlReturn:

3364#    lw $ra, 4($sp)
3368#    addu $sp, 8   # pop $ra and pointless word off stack
3372#    move $t0, $s7 # return string we allocated in $s7
3376#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3380:mth_readInt_Lib:

    # save $ra by pushing onto stack
3380#    subu $sp,$sp,4
3384#    sw $ra,($sp)

3388:  riSkipWhiteLoop:
    # read a character
3388#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
3392#    subu $t0,$v0,32
3396#    bgt $t0,$zero,nonWhite
3397##...slt $at,$zero,$t0
3401##...bne $at,$zero,3444
3404#    beq $t0,$zero,riSkipWhiteLoop # start over if space
3408#    subu $t0,$v0,10
3412#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
3416#    subu $t0,$v0,9
3420#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
3424#    subu $t0,$v0,13
3428#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
3432#    subu $t0,$v0,12
3436#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
3440#    j badIntegerFormat # illegal integer char: abort program

3444:  nonWhite:
3444#    subu $t0,$v0,'-'
3448#    li $t4,1 # final multiplier
3452#    bne $t0,$zero,helpReadInt # go read
3456#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
3460#    jal readLogicalChar

3464:  helpReadInt:
3464#    li $t2,10
3468#    subu $t1,$v0,'0' # convert digit to 0-9 value
3472#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
3473##...sltu $at,$t1,$t2
3477##...beq $at,$zero,5724
3480#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

3484:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

3484#    jal readLogicalChar # read next character
3488#    subu $t1,$v0,'0' # convert digit to 0-9 value
3492#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
3493##...sltu $at,$t1,$t2
3497##...beq $at,$zero,3516

3500#    mul $t3,$t3,$t2 # multiply old value by 10
3501##...mult $t3,$t2
3505##...mflo $t3
3508#    addu $t3,$t3,$t1 # add in value of new digit
3512#    j digitLoop

3516:  doneDigitLoop:

    # "push back" unused character into queue
3516#    sw $v0,lastCharRead

    # restore return address
3520#    lw $ra,($sp)
3524#    addu $sp, 4

    # multiply by sign and put return value in $t0
3528#    mult $t3,$t4 # multiply to account for poss. minus sign
3532#    mflo $t3
3536#    move $t0, $t3
    
    # return
3540#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:

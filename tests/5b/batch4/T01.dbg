4532#    sw $t4,-8($s7) # ... and store back into -8 header-word
4536:  skipMask_intToChar:

    # store data in string
4536#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
4540#    li $t0,-1
4544#    sw $t0,-4($s7)

    # we're returning $s7
4548#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
4552#    lw $ra,4($sp)
4556#    addu $sp,$sp,8

    # return
4560#    jr $ra

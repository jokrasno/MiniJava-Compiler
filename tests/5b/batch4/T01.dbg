3833##...ori $at,$at,0xff
3837##...and $t4,$t4,$at
3840#    sw $t4,-8($s7) # ... and store back into -8 header-word
3844:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
3844#    lw $t1,8($sp) # k
3848#    lw $t2,16($sp) # n


    # set up the forwarding pointer
5440#    sw $zero,-8($t1) # 0 in first header-slot
5444#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
5448#    sw $t8,($t0)

5452:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
5452#    addu $t0,$t0,4
5456#    bltu $t0,$s1,gcNextPointerInObject
5457##...sltu $at,$t0,$s1
5461##...bne $at,$zero,5300

5464:  gcTestIterDone2:
5464#    bltu $t0,$s3,gcHeapCopyLoop
5465##...sltu $at,$t0,$s3
5469##...bne $at,$zero,5184

    ###### end outer loop to copy all non-stack-direct objects ######

5472:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
5472#    lw $s2,($sp)
5476#    addu $sp,$sp,4

    # mark us as having already GC'd
5480#    move $t5,$s5

    # go try and allocate again
5484#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
5488:vm_init:

    # mark bottom of stack
5488#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
5492#    move $s2,$zero

    #set up the "five" register
5496#    li $s5,5

5500#    la $s3,seg0_start
5504#    la $s4,seg0_end
5505##...lui $s4,16
5509##...addiu $s4,$s4,6300
    
    # return
5512#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5516:divide:
    # get parameters; abort if divisor zero
5516#    lw $t0,($sp)
5520#    lw $t1,8($sp)
5524#    beq $t0,$zero,divByZeroError
    
    # perform division
5528#    div $t1,$t0
5532#    mflo $t0

    # store result, adjust stack and return
5536#    addu $sp,$sp,8 # adjust stack
5540#    sw $t0,($sp) # store result
5544#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5548:remainder:
    # get parameters; abort if divisor zero
5548#    lw $t0,($sp)
5552#    lw $t1,8($sp)
5556#    beq $t0,$zero,divByZeroError
    
    # perform division
5560#    div $t1,$t0
5564#    mfhi $t0

    # store result, adjust stack and return
5568#    addu $sp,$sp,8 # adjust stack
5572#    sw $t0,($sp) # store result
5576#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
5580:checkCast:
    # get object, allow immediately if null
5580#    lw $t2,($sp)
5584#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
5588#    lw $t2,-12($t2) # vtable address
5592#    bge $t2,$t1,castException
5593##...slt $at,$t2,$t1
5597##...beq $at,$zero,5732
5600#    blt $t2,$t0,castException
5601##...slt $at,$t2,$t0
5605##...bne $at,$zero,5732
    
    # return, leaving object unchanged on stack
5608:  checkCastReturn:    
5608#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
5612:instanceOf:
    # get object, go return false if null
5612#    lw $t2,($sp)
5616#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
5620#    lw $t2,-12($t2) # vtable address
5624#    sge $t0,$t2,$t0 # are we >= the lower limit?
5625##...slt $t0,$t2,$t0
5629##...xori $t0,$t0,0x1
5632#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
5636#    and $t2,$t0,$t1
5640#    sw $t2,($sp)
5644:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
5644#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

5648:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
5648#    li $v0,4 # syscall-code for print-string
5652#    syscall
5656:exit:
    # print termination message
5656#    li $v0,4 # syscall-code for print-string
5660#    la $a0,exitString
5664#    syscall

    # terminate execution
5668#    li $v0,10 #syscall-code for "exit"
5672#    syscall

5676:outOfHeapMemory:
5676#    la $a0,heapMemoryMsg
5680#    j exitError
5684:divByZeroError:
5684#    la $a0,divByZeroMsg
5688#    j exitError
5692:strIndexOutOfBounds:
5692#    la $a0,strIndexOutOfBoundsMsg
5696#    j exitError
5700:arrayIndexOutOfBounds:
5700#    la $a0,arrayIndexOutOfBoundsMsg
5704#    j exitError
5708:arraySizeOutOfBounds:
5708#    la $a0,arraySizeOutOfBoundsMsg
5712#    j exitError
5716:nullPtrException:
5716#    la $a0,nullPtrExceptionMsg
5720#    j exitError
5724:badIntegerFormat:
5724#    la $a0,badIntegerFormatMsg
5728#    j exitError
5732:castException:
5732#    la $a0,castExceptionMsg
5736#    j exitError
############## data section ################
    .data
5936:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5952:cur_seg:
    .word 0

5956:lastCharRead:
    .word -2 # -2 => no buffered character
5960:prevHashConstant:
    .word 0x2785173c
5964:gcCount:
    .word 0

5968:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5995:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
6018:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
6053:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
6087:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
6120:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
6151:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
6199:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
6220:gcMsg: 
      .asciiz "\nGC!\n"
6226:gcCountMsg: 
      .asciiz "Number of garbage collections: "

6258:nullStr:
    .asciiz "null"
6263:trueString:
    .asciiz "true"
6268:falseString:
    .asciiz "false"
6274:exitString:
    .ascii "Program terminated."
    #### "falls through" here
6293:newlineString:
    .asciiz "\n"
    
    .align 2
6296:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

6300:seg0_start:
    .space 0x100000
1054876:seg0_end:
1054876:seg1_start:
    .space 0x100000
2103452:seg1_end:

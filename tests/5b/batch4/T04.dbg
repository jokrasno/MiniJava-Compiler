2469##...slt $at,$zero,$t0
2473##...bne $at,$zero,2516
2476#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2480#    subu $t0,$v0,10
2484#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2488#    subu $t0,$v0,9
2492#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2496#    subu $t0,$v0,13
2500#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2504#    subu $t0,$v0,12
2508#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2512#    j badIntegerFormat # illegal integer char: abort program

2516:  nonWhite:
2516#    subu $t0,$v0,'-'
2520#    li $t4,1 # final multiplier
2524#    bne $t0,$zero,helpReadInt # go read

4716:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4716#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4720:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4720#    li $v0,4 # syscall-code for print-string
4724#    syscall
4728:exit:
    # print termination message
4728#    li $v0,4 # syscall-code for print-string
4732#    la $a0,exitString
4736#    syscall

    # terminate execution
4740#    li $v0,10 #syscall-code for "exit"
4744#    syscall

4748:outOfHeapMemory:
4748#    la $a0,heapMemoryMsg
4752#    j exitError
4756:divByZeroError:
4756#    la $a0,divByZeroMsg
4760#    j exitError
4764:strIndexOutOfBounds:
4764#    la $a0,strIndexOutOfBoundsMsg
4768#    j exitError
4772:arrayIndexOutOfBounds:
4772#    la $a0,arrayIndexOutOfBoundsMsg
4776#    j exitError
4780:arraySizeOutOfBounds:
4780#    la $a0,arraySizeOutOfBoundsMsg
4784#    j exitError
4788:nullPtrException:
4788#    la $a0,nullPtrExceptionMsg
4792#    j exitError
4796:badIntegerFormat:
4796#    la $a0,badIntegerFormatMsg
4800#    j exitError
4804:castException:
4804#    la $a0,castExceptionMsg
4808#    j exitError
############## data section ################
    .data
5100:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5116:cur_seg:
    .word 0

5120:lastCharRead:
    .word -2 # -2 => no buffered character
5124:prevHashConstant:
    .word 0x2785173c
5128:gcCount:
    .word 0

5132:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5159:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5182:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5217:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5251:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5284:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5315:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5363:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5384:gcMsg: 
      .asciiz "\nGC!\n"
5390:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5422:nullStr:
    .asciiz "null"
5427:trueString:
    .asciiz "true"
5432:falseString:
    .asciiz "false"
5438:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5457:newlineString:
    .asciiz "\n"
    
    .align 2
5460:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5464:seg0_start:
    .space 0x100000
1054040:seg0_end:
1054040:seg1_start:
    .space 0x100000
2102616:seg1_end:

2565##...sltu $at,$t1,$t2
2569##...beq $at,$zero,2588

2572#    mul $t3,$t3,$t2 # multiply old value by 10
2573##...mult $t3,$t2
2577##...mflo $t3
2580#    addu $t3,$t3,$t1 # add in value of new digit
2584#    j digitLoop

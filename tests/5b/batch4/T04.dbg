###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1708:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1708#    lw $t0,-8($s2) # get word with hash bits from this
1712#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1716#    addu $t0,$t1

1720#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1724:mth_equals_Object:
1724#    move $t0,$s2 # first pointer (this)
1728#    lw $t1,($sp) # second pointer
1732#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1733##...subu $at,$t0,$t1
1737##...sltiu $t0,$at,1

1740#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1744:mth_hashCode_String:
1744#    move $t0,$s2 # put this pointer in t0

1748#    li $t2,0 # current hash value
1752#    lw $t1,-4($t0) # negative of number of characters in string
1756#    beq $t1,$zero,done_hashCode_String # if zero length => done
1760#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1764#    and $t0,0xfffffffc # adjust for padding
1765##...lui $at,65535
1769##...ori $at,$at,0xfffc
1773##...and $t0,$t0,$at
1776#    subu $t1,$t0,$t1 # address at end of string +12
1780:loop_hashCode_String:    
1780#    sll $t4,$t2,5 # multiply by 32
1784#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1788#    lbu $t3,-12($t0) # current character
1792#    addu $t2,$t3 # add in current character
1796#    addu $t0,1 # go to next character's address
1800#    bne $t0,$t1,loop_hashCode_String # loop back if more
1804:done_hashCode_String:    

    # push int on stack
1804#    move $t0, $t2 # put $t2 in return slot
1808#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1812:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1812#    subu $sp,4
1816#    sw $ra,($sp)
    
    # get hash value
1820#    lw $t2,-12($s2) # vtable address
1824#    lw $t0,($t2) # method address
1828#    jalr $t0
1832#    subu $sp,8 # push result (int in $t0) on stack
1836#    sw $s5,4($sp)
1840#    sw $t0,($sp)

    # compute print-size of hash value
1844#    li $t0, 1
1848#    lw $t1, ($sp)
1852#    srl $t1,$t1,4
1856#    beq $t1,$zero,toString_skip_loop
1860:toString_loop_top:
1860#    addu $t0,1
1864#    srl $t1,$t1,4
1868#    bne $t1,$zero,toString_loop_top
1872:toString_skip_loop:
1872#    subu $sp,8
1876#    sw $s5,4($sp)
1880#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1884#    lw $t2,-12($s2) # vtable address
1888#    move $t0,$t2
1892:toString_checkTagBit:
1892#    subu $t0,1
1896#    lb $t1,($t0)
1900#    and $t1,0x80
1901##...lui $at,0
1905##...ori $at,$at,0x80
1909##...and $t1,$t1,$at
1912#    beq $t1,$zero,toString_checkTagBit
1916#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1920#    subu $sp,8
1924#    sw $t1,($sp)
1928#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1932#    move $s7,$zero # -4 offset header word
1936#    lw $t4,8($sp) # bytes for hash value
1940#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1944#    addu $t4,8
1948#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1952#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1956#    li $t0,CLASS_String # store string vtable address into ...
1960#    sw $t0,-12($s7) # ... -12 offset in object header
1964#    lw $t2,-12($s2) # our object's vtable address
1968#    lw $t5,4($sp) # number characters in prefix
1972#    lw $t1,12($sp) # number of characters in hashcode
1976#    addu $t3,$t1,$t5 # number of characters in string ...
1980#    addu $t3,1 # ... including the '@' character
1984#    subu $t0,$zero,$t3 # store negated length into ...
1988#    sw $t0,-4($s7) # ... -4 offset header word
1992#    lw $t0,-8($s7) # get -8 offset header-word
1996#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1997##...slt $at,$t0,$zero
2001##...beq $at,$zero,2020
2004#    and $t0,0xff # mask off object's hash value ...
2005##...lui $at,0
2009##...ori $at,$at,0xff
2013##...and $t0,$t0,$at
2016#    sw $t0,-8($s7) # ... and store back into -8 header-word
2020:skipMask_toString:
2020#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2024#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2028#    subu $t4,$t2,$t5
2032:toString_copyLoop:    
2032#    lb $t3,($t4)
2036#    and $t3,0x7f # mask off sign bit (in case first word)
2037##...lui $at,0
2041##...ori $at,$at,0x7f
2045##...and $t3,$t3,$at
2048#    sb $t3,-8($t0)
2052#    addu $t4,1
2056#    addu $t0,1
2060#    blt $t4,$t2,toString_copyLoop
2061##...slt $at,$t4,$t2
2065##...bne $at,$zero,2032

    # copy the '@' sign
2068#    li $t3,'@'
2072#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2076#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2080#    lw $t3,20($sp) # hash code to print
2084:toString_hashCopyLoop:
2084#    and $t4,$t3,0xf
2088#    srl $t3,4
2092#    lb $t4,hexChars($t4)
2096#    sb $t4,-8($t2)
2100#    subu $t2,$t2,1
2104#    bgt $t2,$t0,toString_hashCopyLoop
2105##...slt $at,$t0,$t2
2109##...bne $at,$zero,2084

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2112#    addu $sp,28
2116#    lw $ra,($sp)
2120#    addu $sp,4
2124#    move $t0, $s7 # return string we created
2128#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2132:mth_equals_String:
    
    # quick test for obvious false
2132#    lw $t0,($sp) # second parameter
2136#    beq $t0,$zero,goEsFalse # go return false if null
2140#    lw $t1,-12($t0) # vtable pointer
2144#    la $t2,CLASS_String # string vtable pointer
2148#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2152#    subu $sp,12
2156#    sw $ra,8($sp)
2160#    sw $s2,4($sp)
2164#    sw $t0,($sp)
2168#    jal mth_compareTo_String
2172#    lw $s2, 4($sp) #restore this pointer and pop parameters
2176#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2180#    seq $t0,$t0,$zero
2181##...subu $at,$t0,$zero
2185##...sltiu $t0,$at,1

    # pop return address and return $t0
2188#    lw $ra,($sp)
2192#    addu $sp,4

2196#    jr $ra # return
    
2200:goEsFalse:
    # put 0 in $t0 and return
2200#    li $t0, 0
2204#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2208:mth_toString_String:
    #we are a string, so return this.
2208#    move $t0, $s2
2212#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2216:mth_readLine_Lib:
    
2216#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2220#    sw $ra, 4($sp) # save $ra
2224#    move $t1,$sp # save "original" sp

2228:  doRead:

    # read the character
2228#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2232#    subu $t2,$v0,13
2236#    bne $t2,$zero,notReturnRL
2240#    jal readLogicalChar
2244#    subu $t2,$v0,10 # check for newline
2248#    beq $t2,$zero,foundNewLine
2252#    sw $v0,lastCharRead # push back character into queue
2256#    j foundNewLine # go process the line

2260:  notReturnRL:

    # at this point, $v0 has our character

2260#    subu $t0,$v0,10
2264#    beq $t0,$zero,foundNewLine
2268#    blt $v0,$zero,foundEof
2269##...slt $at,$v0,$zero
2273##...bne $at,$zero,2288

    # we have a character, so push it onto stack
2276#    subu $sp,$sp,4
2280#    sw $v0,($sp)

    # loop back up to get next character
2284#    j doRead

2288:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2288#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2292#    li $s7, 0 # return-value: null
2296#    j rlReturn # return

2300:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2300#    subu $t0,$t1,$sp # number of chars we read (times 4)
2304#    srl $s6,$t0,2 # number of words on stack with chars
2308#    subu $sp,$sp,4 # push char-count ...
2312#    sw $s6,($sp) # ... onto stack
2316#    addu $t2,$t0,5 # GC tag, incl. for count-word
2320#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2324#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2328#    srl $s6,$s6,2  # data words in object
2332#    move $s7,$zero # object words in object
2336#    jal newObject  # allocate space
    
    # store header words
2340#    la $t0,CLASS_String
2344#    sw $t0,-12($s7)# store class tag (String) into object
2348#    lw $t2,4($sp) # char-count
2352#    sll $t1,$t2,2 # 4 times number of chars
2356#    subu $t2,$zero,$t2 # negative of char-count
2360#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2364#    lw $t0,-8($s7) # data words in object, possibly must mask off hash

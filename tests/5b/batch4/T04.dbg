########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
3304:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
3304#    subu $sp,$sp,8
3308#    sw $ra,4($sp)

    # save current sp
3312#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
3316#    li $t3,10

    # get argument, negate if negative
3320#    lw $t1,8($sp)
3324#    bge $t1,$zero,itsNonNegLoop
3325##...slt $at,$t1,$zero
3329##...beq $at,$zero,3336
3332#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
3336:  itsNonNegLoop:
3336#    divu $t1,$t3
3340#    mflo $t1 # quotient
3344#    mfhi $t4 # remainder
3348#    addu $t4,$t4,'0' # turn remainder into digit
3352#    subu $sp,$sp,4
3356#    sw $t4,($sp) # push digit onto stack
3360#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
3364#    lw $t4,8($t0)
3368#    bge $t4,$zero,itsSkipNeg
3369##...slt $at,$t4,$zero
3373##...beq $at,$zero,3388
3376#    li $t4,'-'
3380#    subu $sp,$sp,4
3384#    sw $t4,($sp)
3388:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
3388#    subu $s6,$t0,$sp
3392#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
3396#    sw $t3,($t0)
3400#    srl $s6,$s6,2
3404#    subu $sp,$sp,4
3408#    sw $s6,($sp)
    
    # allocate memory
3412#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
3416#    srl $s6,$s6,2
3420#    move $s7,$zero # no "object" words in object
3424#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
3428#    lw $t0,4($sp)
3432#    addu $sp,$sp,8

    # store "String" tag into class field
3436#    subu $s7,$s7,8 # address of header-1 word
3440#    la $t1,CLASS_String
3444#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
3448#    lw $t4,($s7) # # data words in source string
3452#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
3453##...slt $at,$t4,$zero
3457##...beq $at,$zero,3476
3460#    and $t4,0xff # mask off object's hash value ...
3461##...lui $at,0
3465##...ori $at,$at,0xff
3469##...and $t4,$t4,$at
3472#    sw $t4,($s7) # ... and store back into -8 header-word
3476:skipMask_intToString:
    
    # store negative of char-count into header-2 word
3476#    subu $t0,$zero,$t0
3480#    sw $t0,4($s7)

3484#    lw $t1,($s7) # number of data words in string
3488#    sll $t1,$t1,2 # number data bytes in string
3492#    subu $t1,$s7,$t1 # first location to store chars in string
3496#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
3500:  itsLoop:
3500#    lw $t2,($sp)
3504#    addu $sp,$sp,4
3508#    sb $t2,($t1)
3512#    addu $t1,$t1,1
3516#    bne $t1,$t0,itsLoop

    ####################################################
    # At this point
    # - ($t0+15)&0xfffffffe is our return value
    # - ($sp) contains garbage (old GC tag)
    # - 4($sp) contains return address
    ####################################################

    # adjust stack, restore return address; return
3520#    lw $ra,4($sp)
3524#    addu $sp,$sp,8
3528#    addu $t0,$t0,15
3532#    and $t0,$t0,0xfffffffc
3533##...lui $at,65535
3537##...ori $at,$at,0xfffc
3541##...and $t0,$t0,$at
3544#    jr $ra

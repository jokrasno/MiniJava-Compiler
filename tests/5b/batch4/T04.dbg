########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
3548:mth_intToChar_Lib:
    # save return address
3548#    subu $sp,$sp,4
3552#    sw $ra,($sp)

    # allocate object
3556#    li $s6,2
3560#    move $s7,$zero
3564#    jal newObject

    # get n from string.
3568#    lw $t1,8($sp)

    # store "String" tag into class field
3572#    la $t0,CLASS_String
3576#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
3580#    lw $t4,-8($s7) # # data words in source string
3584#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
3585##...slt $at,$t4,$zero
3589##...beq $at,$zero,3608
3592#    and $t4,0xff # mask off object's hash value ...
3593##...lui $at,0
3597##...ori $at,$at,0xff
3601##...and $t4,$t4,$at
3604#    sw $t4,-8($s7) # ... and store back into -8 header-word
3608:  skipMask_intToChar:

    # store data in string
3608#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
3612#    li $t0,-1
3616#    sw $t0,-4($s7)

    # we're returning $s7
3620#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
3624#    lw $ra,4($sp)
3628#    addu $sp,$sp,8

    # return
3632#    jr $ra

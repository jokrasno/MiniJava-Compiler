1753##...ori $at,$at,0xff
1757##...and $t4,$t4,$at
1760#    sw $t4,-8($s7) # ... and store back into -8 header-word
1764:skipMask_concat:

1764#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
1768#    move $t1,$s2   # first object
1772#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
1776#    lw $t2,-4($t0) # negative length of second object
1780#    lw $t3,-4($t1) # negative length of first object
1784#    addu $t4,$t2,$t3 # sum of negative lengths
1788#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################

    # compute addresses for moving data from first string
1792#    lw $t4,-8($t1) # # data words in first string
1796#    sll $t4,$t4,2 # # data bytes in first string
1800#    subu $t1,$t1,$t4 # addr. (+8) of first byte in first string
1804#    lw $t4,-8($s7) # # data words in new string
1808#    sll $t4,$t4,2 # # data bytes in new string
1812#    subu $s7,$s7,$t4 # addr. (+8) of first byte in new string
1816#    beq $zero,$t3,doneConcatLoop1zz # skip first loop is no bytes to copy
1820#    subu $t3,$t1,$t3 # limit (+8) address for first string

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is address (+8) of first byte in first object
    # - $t2 is negated length of second object
    # - $t3 is limit-address (+8) of data in first object
    # - $s7 is address (+8) of first byte in new object
    # - note: if data-length of first object is zero, then
    #   we skip over this part, and go to 'doneConcatLoop1'
    #########################################################

    # copy the bytes from first source to target
1824:  concatLoop1zz:
1824#    lb $t4,-8($t1)
1828#    sb $t4,-8($s7)

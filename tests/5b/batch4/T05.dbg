########################################################
# str.charAt(n) - library method (class String)
# accesses a character in a string, as in Java
# - parameters:
#   - ($sp) - the index, n
#   - 4($sp) - GC tag
#   - 8($sp) - old this pointer
#   - $s2    - this pointer
# - returns:
#   - $t0 - the character found.
########################################################
1908:mth_charAt_String:
    # get string
1908#    move $t0,$s2

    # check that index is in bounds
1912#    lw $t1,-4($t0) # negative of # data words in string
1916#    subu $t3,$zero,$t1 # # chars in string
1920#    lw $t2,($sp) # index
1924#    bgeu $t2,$t3,strIndexOutOfBounds
1925##...sltu $at,$t2,$t3
1929##...beq $at,$zero,3416

    # access element
1932#    lw $t1,-8($t0) # # data words in object
1936#    sll $t1,$t1,2 # - byte-offset from end of chars
1940#    subu $t1,$t2,$t1 # - address of first char in string, offset by 8
1944#    addu $t0,$t0,$t1 # - address of our char, offset by 8
1948#    lb $t0,-8($t0) # our char

    # return
1952#    jr $ra

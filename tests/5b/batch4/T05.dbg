########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
1956:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
1956#    subu $sp,$sp,8
1960#    sw $ra,4($sp)

    # save current sp
1964#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
1968#    li $t3,10

    # get argument, negate if negative
1972#    lw $t1,8($sp)
1976#    bge $t1,$zero,itsNonNegLoop
1977##...slt $at,$t1,$zero
1981##...beq $at,$zero,1988
1984#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
1988:  itsNonNegLoop:
1988#    divu $t1,$t3
1992#    mflo $t1 # quotient
1996#    mfhi $t4 # remainder
2000#    addu $t4,$t4,'0' # turn remainder into digit
2004#    subu $sp,$sp,4
2008#    sw $t4,($sp) # push digit onto stack
2012#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
2016#    lw $t4,8($t0)
2020#    bge $t4,$zero,itsSkipNeg
2021##...slt $at,$t4,$zero
2025##...beq $at,$zero,2040
2028#    li $t4,'-'
2032#    subu $sp,$sp,4
2036#    sw $t4,($sp)
2040:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
2040#    subu $s6,$t0,$sp
2044#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
2048#    sw $t3,($t0)
2052#    srl $s6,$s6,2
2056#    subu $sp,$sp,4
2060#    sw $s6,($sp)
    
    # allocate memory
2064#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
2068#    srl $s6,$s6,2
2072#    move $s7,$zero # no "object" words in object
2076#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
2080#    lw $t0,4($sp)
2084#    addu $sp,$sp,8

    # store "String" tag into class field
2088#    subu $s7,$s7,8 # address of header-1 word
2092#    la $t1,CLASS_String
2096#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
2100#    lw $t4,($s7) # # data words in source string
2104#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
2105##...slt $at,$t4,$zero
2109##...beq $at,$zero,2128
2112#    and $t4,0xff # mask off object's hash value ...
2113##...lui $at,0
2117##...ori $at,$at,0xff
2121##...and $t4,$t4,$at
2124#    sw $t4,($s7) # ... and store back into -8 header-word
2128:skipMask_intToString:
    
    # store negative of char-count into header-2 word
2128#    subu $t0,$zero,$t0
2132#    sw $t0,4($s7)

2136#    lw $t1,($s7) # number of data words in string
2140#    sll $t1,$t1,2 # number data bytes in string
2144#    subu $t1,$s7,$t1 # first location to store chars in string
2148#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
2152:  itsLoop:
2152#    lw $t2,($sp)
2156#    addu $sp,$sp,4
2160#    sb $t2,($t1)
2164#    addu $t1,$t1,1
2168#    bne $t1,$t0,itsLoop

    ####################################################
    # At this point
    # - ($t0+15)&0xfffffffe is our return value
    # - ($sp) contains garbage (old GC tag)
    # - 4($sp) contains return address
    ####################################################

    # adjust stack, restore return address; return
2172#    lw $ra,4($sp)
2176#    addu $sp,$sp,8
2180#    addu $t0,$t0,15
2184#    and $t0,$t0,0xfffffffc
2185##...lui $at,65535
2189##...ori $at,$at,0xfffc
2193##...and $t0,$t0,$at
2196#    jr $ra

########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
2200:mth_intToChar_Lib:
    # save return address
2200#    subu $sp,$sp,4
2204#    sw $ra,($sp)

    # allocate object
2208#    li $s6,2
2212#    move $s7,$zero
2216#    jal newObject

    # get n from string.
2220#    lw $t1,8($sp)

    # store "String" tag into class field
2224#    la $t0,CLASS_String
2228#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
2232#    lw $t4,-8($s7) # # data words in source string
2236#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
2237##...slt $at,$t4,$zero
2241##...beq $at,$zero,2260
2244#    and $t4,0xff # mask off object's hash value ...
2245##...lui $at,0
2249##...ori $at,$at,0xff
2253##...and $t4,$t4,$at
2256#    sw $t4,-8($s7) # ... and store back into -8 header-word
2260:  skipMask_intToChar:

    # store data in string
2260#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
2264#    li $t0,-1
2268#    sw $t0,-4($s7)

    # we're returning $s7
2272#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
2276#    lw $ra,4($sp)
2280#    addu $sp,$sp,8

    # return
2284#    jr $ra

########################################################
# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
2288:mth_compareTo_String:
    # get string pointers and check parameter for null
2288#    lw $t0,($sp) # second string
2292#    beq $t0,$zero,nullPtrException
2296#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
2300#    lw $t2,-4($t0) # negative length of second string
2304#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
2308#    slt $t4,$t3,$t2
2312#    slt $t5,$t2,$t3
2316#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
2320#    lw $t2,-8($t0) # # data words in second string
2324#    lw $t3,-8($t1) # # data words in first string
2328#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
2332#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
2336#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
2340#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
2344#    beq $zero,$t5,skipStrCmpLenzz
2348#    move $t2,$t3
2352:  skipStrCmpLenzz:
2352#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
2356:  cmpLoopzz:
2356#    lw $t3,-8($t1) # word from str2
2360#    lw $t4,-8($t0) # word from str1
2364#    bne $t3,$t4,cmpNotEqualzz
2368#    addu $t1,$t1,4
2372#    addu $t0,$t0,4
2376#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
2380#    j cmpHitLimitzz

2384:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
2384#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
2388#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
2392#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
2396:  cmpHitLimitzz:
2396#    move $t0, $t5 # store return value
2400#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
2404:readLogicalChar:

    # check if we already have a character
2404#    lw $v0,lastCharRead
2408#    li $t0,-2
2412#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
2416#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2420#    jr $ra # return
    
2424:  doReadCh:
    # we need to actually read a character: read and return
2424#    li $v0,12 # use system call to read a character
2428#    syscall
2432#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
2436:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
2436#    blt $s7,$zero arraySizeOutOfBounds
2437##...slt $at,$s7,$zero
2441##...bne $at,$zero,3432

    # mark the fact that we have not yet GC'd for this allocation
2444#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

2448:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
2448#    addu $t0,$s6,$s7
2452#    sll $t0,$t0,2
2456#    addu $t0,$t0,8 # amount of memory needed
2460#    addu $t1,$t0,$s3
2464#    bgtu $t1,$s4,doGC
2465##...sltu $at,$s4,$t1
2469##...bne $at,$zero,2592

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
2472#    move $t2,$s3
2476:  zeroObjLoop:
2476#    sw $zero,($s3)
2480#    lw $zero,($s3)

2484#    addu $s3,4
2488#    bltu $s3,$t1,zeroObjLoop

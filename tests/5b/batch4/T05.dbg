    # get pointers set up in preparation for copy
1592#    lw $t4,-8($t3) # data words in source string
1596#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
1600#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
1604#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
1608#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
1612#    lw $t2,-8($s7)   # data words in target string
1616#    sll $t2,$t2,2    # data bytes in target string
1620#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target
1624:  subCopyLoopzz:
1624#    lb $t4,-8($t3)
1628#    sb $t4,-8($t2)
1632#    addu $t2,$t2,1
1636#    addu $t3,$t3,1

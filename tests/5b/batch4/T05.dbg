###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
868:mth_readLine_Lib:
    
868#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
872#    sw $ra, 4($sp) # save $ra
876#    move $t1,$sp # save "original" sp

880:  doRead:

    # read the character
880#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
884#    subu $t2,$v0,13
888#    bne $t2,$zero,notReturnRL
892#    jal readLogicalChar
896#    subu $t2,$v0,10 # check for newline
900#    beq $t2,$zero,foundNewLine
904#    sw $v0,lastCharRead # push back character into queue
908#    j foundNewLine # go process the line

912:  notReturnRL:

    # at this point, $v0 has our character

912#    subu $t0,$v0,10
916#    beq $t0,$zero,foundNewLine
920#    blt $v0,$zero,foundEof
921##...slt $at,$v0,$zero
925##...bne $at,$zero,940

    # we have a character, so push it onto stack
928#    subu $sp,$sp,4
932#    sw $v0,($sp)

    # loop back up to get next character
936#    j doRead

940:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
940#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
944#    li $s7, 0 # return-value: null
948#    j rlReturn # return

952:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
952#    subu $t0,$t1,$sp # number of chars we read (times 4)
956#    srl $s6,$t0,2 # number of words on stack with chars
960#    subu $sp,$sp,4 # push char-count ...
964#    sw $s6,($sp) # ... onto stack
968#    addu $t2,$t0,5 # GC tag, incl. for count-word
972#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
976#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
980#    srl $s6,$s6,2  # data words in object
984#    move $s7,$zero # object words in object
988#    jal newObject  # allocate space
    
    # store header words
992#    la $t0,CLASS_String
996#    sw $t0,-12($s7)# store class tag (String) into object
1000#    lw $t2,4($sp) # char-count
1004#    sll $t1,$t2,2 # 4 times number of chars
1008#    subu $t2,$zero,$t2 # negative of char-count
1012#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1016#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1020#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1021##...slt $at,$t0,$zero
1025##...beq $at,$zero,1044
1028#    and $t0,0xff # mask off object's hash value ...
1029##...lui $at,0
1033##...ori $at,$at,0xff
1037##...and $t0,$t0,$at
1040#    sw $t0,-8($s7) # ... and store back into -8 header-word
1044:  skipMask_readLine:

1044#    sll $t0,$t0,2 # data bytes in object
1048#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1052#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1056#    addu $sp,$sp,8 # pop redundant object-pointer and count
1060#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1064#    beq $sp,$t1,rlReturn
1068:  charCopyLoop:
1068#    lw $t2,($sp)
1072#    sb $t2,-9($t0)
1076#    addu $sp,$sp,4
1080#    subu $t0,$t0,1
1084#    bne $sp,$t1,charCopyLoop
1088:  rlReturn:

1088#    lw $ra, 4($sp)
1092#    addu $sp, 8   # pop $ra and pointless word off stack
1096#    move $t0, $s7 # return string we allocated in $s7
1100#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1104:mth_readInt_Lib:

    # save $ra by pushing onto stack
1104#    subu $sp,$sp,4
1108#    sw $ra,($sp)

1112:  riSkipWhiteLoop:
    # read a character
1112#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1116#    subu $t0,$v0,32
1120#    bgt $t0,$zero,nonWhite
1121##...slt $at,$zero,$t0
1125##...bne $at,$zero,1168
1128#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1132#    subu $t0,$v0,10
1136#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1140#    subu $t0,$v0,9
1144#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1148#    subu $t0,$v0,13
1152#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1156#    subu $t0,$v0,12
1160#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1164#    j badIntegerFormat # illegal integer char: abort program

1168:  nonWhite:
1168#    subu $t0,$v0,'-'
1172#    li $t4,1 # final multiplier
1176#    bne $t0,$zero,helpReadInt # go read
1180#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1184#    jal readLogicalChar

1188:  helpReadInt:
1188#    li $t2,10
1192#    subu $t1,$v0,'0' # convert digit to 0-9 value
1196#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1197##...sltu $at,$t1,$t2
1201##...beq $at,$zero,3448
1204#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1208:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1208#    jal readLogicalChar # read next character
1212#    subu $t1,$v0,'0' # convert digit to 0-9 value
1216#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1217##...sltu $at,$t1,$t2
1221##...beq $at,$zero,1240

1224#    mul $t3,$t3,$t2 # multiply old value by 10
1225##...mult $t3,$t2
1229##...mflo $t3
1232#    addu $t3,$t3,$t1 # add in value of new digit
1236#    j digitLoop

1240:  doneDigitLoop:

    # "push back" unused character into queue
1240#    sw $v0,lastCharRead

    # restore return address
1244#    lw $ra,($sp)
1248#    addu $sp, 4

    # multiply by sign and put return value in $t0
1252#    mult $t3,$t4 # multiply to account for poss. minus sign
1256#    mflo $t3
1260#    move $t0, $t3
    
    # return
1264#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:

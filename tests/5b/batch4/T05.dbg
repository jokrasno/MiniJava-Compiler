
########################################################
# str1.concat(str2) - library method (class String)
# (as in Java)
# - parameters:
#   - ($sp) - the second string
#   - 4($sp) - old this pointer
#   - $s2 - the first string (this)
# - returns:
#   - $t0 - pointer to concatenated string
########################################################
1676:mth_concat_String:
    # save $ra by pushing onto stack
1676#    subu $sp,$sp,4
1680#    sw $ra, ($sp)

    # get string pointers and check parameter for null
1684#    lw $t0,4($sp)
1688#    beq $t0,$zero,nullPtrException
1692#    move $t1,$s2
    
    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
1696#    lw $t0,-4($t0) # negative size of second object
1700#    lw $t1,-4($t1) # negative size of first object
1704#    addu $s6,$t0,$t1 # sum of negative sizes
1708#    sra $s6,$s6,2 # negative word-size of char part
1712#    subu $s6,$zero,$s6 # word size of char part
1716#    addu $s6,$s6,1 # data word size, including v-table word
1720#    move $s7,$zero
1724#    jal newObject

    # store String vtable address in vtable address field
1728#    la $t0,CLASS_String
1732#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
1736#    lw $t4,-8($s7) # # data words in source string
1740#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
1741##...slt $at,$t4,$zero
1745##...beq $at,$zero,1764
1748#    and $t4,0xff # mask off object's hash value ...

########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
1456:mth_substring_String:

    # save $ra by pushing onto stack
1456#    subu $sp,$sp,4
1460#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
1464#    move $t0,$s2
1468#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
1472#    lw $t0,-4($t0) # negative of string length
1476#    subu $t0,$zero,$t0 # string length
1480#    lw $t1,4($sp) # k
1484#    lw $t2,12($sp) # n
1488#    bgt $zero,$t2,strIndexOutOfBounds
1489##...slt $at,$t2,$zero
1493##...bne $at,$zero,3416
1496#    bgt $t2,$t1,strIndexOutOfBounds
1497##...slt $at,$t1,$t2
1501##...bne $at,$zero,3416
1504#    bgt $t1,$t0,strIndexOutOfBounds
1505##...slt $at,$t0,$t1
1509##...bne $at,$zero,3416

    # allocate memory
1512#    subu $s6,$t1,$t2 # # chars in target-string
1516#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1520#    srl $s6,$s6,2 # convert bytes-count to word-count
1524#    move $s7,$zero # (no object-bytes in string)
1528#    jal newObject

    # store "String" tag in object-type field
1532#    la $t0,CLASS_String
1536#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
1540#    lw $t4,-8($s7) # data words in source string
1544#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
1545##...slt $at,$t4,$zero
1549##...beq $at,$zero,1568
1552#    and $t4,0xff # mask off object's hash value ...
1553##...lui $at,0
1557##...ori $at,$at,0xff
1561##...and $t4,$t4,$at
1564#    sw $t4,-8($s7) # ... and store back into -8 header-word
1568:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1568#    lw $t1,8($sp) # k
1572#    lw $t2,16($sp) # n
1576#    subu $t0,$t2,$t1 # value to store
1580#    sw $t0,-4($s7) # store value
    
1584#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
1588#    beq $zero,$t0,doneSubCopyzz

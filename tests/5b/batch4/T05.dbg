1641##...slt $at,$t3,$t1
1645##...bne $at,$zero,1624
    
1648:  doneSubCopyzz:
    # restore return address, store return value, pop stack
1648#    lw $ra,4($sp) # restore $ra
1652#    addu $sp,$sp,8 # pop ra, and allocated newObject
1656#    move $t0, $s7 # we're returning the string we got back
                  # from newObject
    
    # return
1660#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
784:mth_equals_String:
    
    # quick test for obvious false
784#    lw $t0,($sp) # second parameter
788#    beq $t0,$zero,goEsFalse # go return false if null
792#    lw $t1,-12($t0) # vtable pointer
796#    la $t2,CLASS_String # string vtable pointer
800#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
804#    subu $sp,12
808#    sw $ra,8($sp)
812#    sw $s2,4($sp)
816#    sw $t0,($sp)
820#    jal mth_compareTo_String
824#    lw $s2, 4($sp) #restore this pointer and pop parameters
828#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
832#    seq $t0,$t0,$zero
833##...subu $at,$t0,$zero
837##...sltiu $t0,$at,1

    # pop return address and return $t0
840#    lw $ra,($sp)
844#    addu $sp,4

848#    jr $ra # return
    
852:goEsFalse:
    # put 0 in $t0 and return
852#    li $t0, 0
856#    jr $ra # return

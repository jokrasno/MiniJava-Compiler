##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
360:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
360#    lw $t0,-8($s2) # get word with hash bits from this
364#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
368#    addu $t0,$t1

372#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
376:mth_equals_Object:
376#    move $t0,$s2 # first pointer (this)
380#    lw $t1,($sp) # second pointer
384#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
385##...subu $at,$t0,$t1
389##...sltiu $t0,$at,1

392#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
396:mth_hashCode_String:
396#    move $t0,$s2 # put this pointer in t0

400#    li $t2,0 # current hash value
404#    lw $t1,-4($t0) # negative of number of characters in string
408#    beq $t1,$zero,done_hashCode_String # if zero length => done
412#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
416#    and $t0,0xfffffffc # adjust for padding
417##...lui $at,65535
421##...ori $at,$at,0xfffc
425##...and $t0,$t0,$at
428#    subu $t1,$t0,$t1 # address at end of string +12
432:loop_hashCode_String:    
432#    sll $t4,$t2,5 # multiply by 32
436#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
440#    lbu $t3,-12($t0) # current character
444#    addu $t2,$t3 # add in current character
448#    addu $t0,1 # go to next character's address
452#    bne $t0,$t1,loop_hashCode_String # loop back if more
456:done_hashCode_String:    

    # push int on stack
456#    move $t0, $t2 # put $t2 in return slot
460#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
464:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
464#    subu $sp,4
468#    sw $ra,($sp)
    
    # get hash value
472#    lw $t2,-12($s2) # vtable address
476#    lw $t0,($t2) # method address
480#    jalr $t0
484#    subu $sp,8 # push result (int in $t0) on stack
488#    sw $s5,4($sp)
492#    sw $t0,($sp)

    # compute print-size of hash value
496#    li $t0, 1
500#    lw $t1, ($sp)
504#    srl $t1,$t1,4
508#    beq $t1,$zero,toString_skip_loop
512:toString_loop_top:
512#    addu $t0,1
516#    srl $t1,$t1,4
520#    bne $t1,$zero,toString_loop_top
524:toString_skip_loop:
524#    subu $sp,8
528#    sw $s5,4($sp)
532#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
536#    lw $t2,-12($s2) # vtable address
540#    move $t0,$t2
544:toString_checkTagBit:
544#    subu $t0,1
548#    lb $t1,($t0)
552#    and $t1,0x80
553##...lui $at,0
557##...ori $at,$at,0x80
561##...and $t1,$t1,$at
564#    beq $t1,$zero,toString_checkTagBit
568#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
572#    subu $sp,8
576#    sw $t1,($sp)
580#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
584#    move $s7,$zero # -4 offset header word
588#    lw $t4,8($sp) # bytes for hash value
592#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
596#    addu $t4,8
600#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
604#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

608#    li $t0,CLASS_String # store string vtable address into ...
612#    sw $t0,-12($s7) # ... -12 offset in object header
616#    lw $t2,-12($s2) # our object's vtable address
620#    lw $t5,4($sp) # number characters in prefix
624#    lw $t1,12($sp) # number of characters in hashcode
628#    addu $t3,$t1,$t5 # number of characters in string ...
632#    addu $t3,1 # ... including the '@' character
636#    subu $t0,$zero,$t3 # store negated length into ...
640#    sw $t0,-4($s7) # ... -4 offset header word
644#    lw $t0,-8($s7) # get -8 offset header-word
648#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
649##...slt $at,$t0,$zero
653##...beq $at,$zero,672
656#    and $t0,0xff # mask off object's hash value ...
657##...lui $at,0
661##...ori $at,$at,0xff
665##...and $t0,$t0,$at
668#    sw $t0,-8($s7) # ... and store back into -8 header-word
672:skipMask_toString:
672#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
676#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
680#    subu $t4,$t2,$t5
684:toString_copyLoop:    
684#    lb $t3,($t4)
688#    and $t3,0x7f # mask off sign bit (in case first word)
689##...lui $at,0
693##...ori $at,$at,0x7f
697##...and $t3,$t3,$at
700#    sb $t3,-8($t0)
704#    addu $t4,1
708#    addu $t0,1
712#    blt $t4,$t2,toString_copyLoop
713##...slt $at,$t4,$t2
717##...bne $at,$zero,684

    # copy the '@' sign
720#    li $t3,'@'
724#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
728#    addu $t2,$t0,$t1 # address of last byte in string to store +8
732#    lw $t3,20($sp) # hash code to print
736:toString_hashCopyLoop:
736#    and $t4,$t3,0xf
740#    srl $t3,4
744#    lb $t4,hexChars($t4)
748#    sb $t4,-8($t2)
752#    subu $t2,$t2,1
756#    bgt $t2,$t0,toString_hashCopyLoop
757##...slt $at,$t0,$t2
761##...bne $at,$zero,736

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
764#    addu $sp,28
768#    lw $ra,($sp)
772#    addu $sp,4
776#    move $t0, $s7 # return string we created
780#    jr $ra

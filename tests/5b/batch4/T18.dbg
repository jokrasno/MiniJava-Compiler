3785##...slt $at,$t3,$zero
3789##...beq $at,$zero,3796
3792#    move $t3,$zero
3796:  gcH2Neg2:
3796#    sll $t3,$t3,2 # # object bytes
3800#    move $t0,$t2 # address of first pointer in object
3804#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3808#    beq $t0,$s1,gcTestIterDone2
    
3812:  gcNextPointerInObject:
    # get pointer from object
3812#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3816#    bleu $t1,$t6,gcGoNextPointerSlot
3817##...sltu $at,$t6,$t1
3821##...beq $at,$zero,3964
3824#    bgtu $t1,$t7,gcGoNextPointerSlot
3825##...sltu $at,$t7,$t1
3829##...bne $at,$zero,3964

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3832#    lw $t8,-8($t1) # possible forwarding tag
3836#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3840#    lw $t8,-4($t1) # forwarding pointer: object's new address
3844#    sw $t8,($t0) # update pointer in object
3848#    j gcGoNextPointerSlot # do next iteration

3852:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3852#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3853##...slt $at,$t8,$zero
3857##...beq $at,$zero,3872
3860#    and $t8,0xff # mask off hash bits
3861##...lui $at,0
3865##...ori $at,$at,0xff
3869##...and $t8,$t8,$at

3872:  gcSkip5:
3872#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3876#    addu $t8,$t8,8 # ... add in bytes for header-words
3880#    subu $t4,$t1,$t8 # address of first word of source object
3884#    lw $t3,-4($t1) # # words in positive-offset portion
3888#    bge $t3,$zero,gcNoNeg
3889##...slt $at,$t3,$zero
3893##...beq $at,$zero,3900
3896#    move $t3,$zero # negative treated as zero
3900:  gcNoNeg:
3900#    sll $t3,$t3,2 # bytes in negative-offset portion
3904#    addu $t3,$t3,$t1 # address one word past last word of source

3908#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3912#    lw $s0,($t4)
3916#    lw $t9,-8($t1)
3920#    sw $t9,($t4)
3924#    sw $s0,-8($t1)

    # copy all source bytes to the target
3928:  gCinnerCopy2:
3928#    lw $s0,($t4)
3932#    sw $s0,($s3)
3936#    addu $t4,$t4,4
3940#    addu $s3,$s3,4
3944#    bltu $t4,$t3,gCinnerCopy2
3945##...sltu $at,$t4,$t3
3949##...bne $at,$zero,3928

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3952#    sw $zero,-8($t1) # 0 in first header-slot
3956#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3960#    sw $t8,($t0)

3964:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3964#    addu $t0,$t0,4
3968#    bltu $t0,$s1,gcNextPointerInObject
3969##...sltu $at,$t0,$s1
3973##...bne $at,$zero,3812

3976:  gcTestIterDone2:
3976#    bltu $t0,$s3,gcHeapCopyLoop
3977##...sltu $at,$t0,$s3
3981##...bne $at,$zero,3696

    ###### end outer loop to copy all non-stack-direct objects ######

3984:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3984#    lw $s2,($sp)
3988#    addu $sp,$sp,4

    # mark us as having already GC'd
3992#    move $t5,$s5

    # go try and allocate again
3996#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4000:vm_init:

    # mark bottom of stack
4000#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4004#    move $s2,$zero

    #set up the "five" register
4008#    li $s5,5

4012#    la $s3,seg0_start
4016#    la $s4,seg0_end
4017##...lui $s4,16
4021##...addiu $s4,$s4,4828
    
    # return
4024#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4028:divide:
    # get parameters; abort if divisor zero
4028#    lw $t0,($sp)
4032#    lw $t1,8($sp)
4036#    beq $t0,$zero,divByZeroError
    
    # perform division
4040#    div $t1,$t0
4044#    mflo $t0

    # store result, adjust stack and return
4048#    addu $sp,$sp,8 # adjust stack
4052#    sw $t0,($sp) # store result
4056#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4060:remainder:
    # get parameters; abort if divisor zero
4060#    lw $t0,($sp)
4064#    lw $t1,8($sp)
4068#    beq $t0,$zero,divByZeroError
    
    # perform division
4072#    div $t1,$t0
4076#    mfhi $t0

    # store result, adjust stack and return
4080#    addu $sp,$sp,8 # adjust stack
4084#    sw $t0,($sp) # store result
4088#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4092:checkCast:
    # get object, allow immediately if null
4092#    lw $t2,($sp)
4096#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4100#    lw $t2,-12($t2) # vtable address
4104#    bge $t2,$t1,castException
4105##...slt $at,$t2,$t1
4109##...beq $at,$zero,4244
4112#    blt $t2,$t0,castException
4113##...slt $at,$t2,$t0
4117##...bne $at,$zero,4244
    
    # return, leaving object unchanged on stack
4120:  checkCastReturn:    
4120#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4124:instanceOf:
    # get object, go return false if null
4124#    lw $t2,($sp)
4128#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4132#    lw $t2,-12($t2) # vtable address
4136#    sge $t0,$t2,$t0 # are we >= the lower limit?
4137##...slt $t0,$t2,$t0
4141##...xori $t0,$t0,0x1
4144#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4148#    and $t2,$t0,$t1
4152#    sw $t2,($sp)
4156:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4156#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4160:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4160#    li $v0,4 # syscall-code for print-string
4164#    syscall
4168:exit:
    # print termination message
4168#    li $v0,4 # syscall-code for print-string
4172#    la $a0,exitString
4176#    syscall

    # terminate execution
4180#    li $v0,10 #syscall-code for "exit"
4184#    syscall

4188:outOfHeapMemory:
4188#    la $a0,heapMemoryMsg
4192#    j exitError
4196:divByZeroError:
4196#    la $a0,divByZeroMsg
4200#    j exitError
4204:strIndexOutOfBounds:
4204#    la $a0,strIndexOutOfBoundsMsg
4208#    j exitError
4212:arrayIndexOutOfBounds:
4212#    la $a0,arrayIndexOutOfBoundsMsg
4216#    j exitError
4220:arraySizeOutOfBounds:
4220#    la $a0,arraySizeOutOfBoundsMsg
4224#    j exitError
4228:nullPtrException:
4228#    la $a0,nullPtrExceptionMsg
4232#    j exitError
4236:badIntegerFormat:
4236#    la $a0,badIntegerFormatMsg
4240#    j exitError
4244:castException:
4244#    la $a0,castExceptionMsg
4248#    j exitError
############## data section ################
    .data
4464:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4480:cur_seg:
    .word 0

4484:lastCharRead:
    .word -2 # -2 => no buffered character
4488:prevHashConstant:
    .word 0x2785173c
4492:gcCount:
    .word 0

4496:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4523:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4546:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4581:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4615:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4648:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4679:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4727:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4748:gcMsg: 
      .asciiz "\nGC!\n"
4754:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4786:nullStr:
    .asciiz "null"
4791:trueString:
    .asciiz "true"
4796:falseString:
    .asciiz "false"
4802:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4821:newlineString:
    .asciiz "\n"
    
    .align 2
4824:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4828:seg0_start:
    .space 0x100000
1053404:seg0_end:
1053404:seg1_start:
    .space 0x100000
2101980:seg1_end:

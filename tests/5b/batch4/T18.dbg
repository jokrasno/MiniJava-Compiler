##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1148:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1148#    lw $t0,-8($s2) # get word with hash bits from this
1152#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1156#    addu $t0,$t1

1160#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1164:mth_equals_Object:
1164#    move $t0,$s2 # first pointer (this)
1168#    lw $t1,($sp) # second pointer
1172#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1173##...subu $at,$t0,$t1
1177##...sltiu $t0,$at,1

1180#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1184:mth_hashCode_String:
1184#    move $t0,$s2 # put this pointer in t0

1188#    li $t2,0 # current hash value
1192#    lw $t1,-4($t0) # negative of number of characters in string
1196#    beq $t1,$zero,done_hashCode_String # if zero length => done
1200#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1204#    and $t0,0xfffffffc # adjust for padding
1205##...lui $at,65535
1209##...ori $at,$at,0xfffc
1213##...and $t0,$t0,$at
1216#    subu $t1,$t0,$t1 # address at end of string +12
1220:loop_hashCode_String:    
1220#    sll $t4,$t2,5 # multiply by 32
1224#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1228#    lbu $t3,-12($t0) # current character
1232#    addu $t2,$t3 # add in current character
1236#    addu $t0,1 # go to next character's address
1240#    bne $t0,$t1,loop_hashCode_String # loop back if more
1244:done_hashCode_String:    

    # push int on stack
1244#    move $t0, $t2 # put $t2 in return slot
1248#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1252:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1252#    subu $sp,4
1256#    sw $ra,($sp)
    
    # get hash value
1260#    lw $t2,-12($s2) # vtable address
1264#    lw $t0,($t2) # method address
1268#    jalr $t0
1272#    subu $sp,8 # push result (int in $t0) on stack
1276#    sw $s5,4($sp)
1280#    sw $t0,($sp)

    # compute print-size of hash value
1284#    li $t0, 1
1288#    lw $t1, ($sp)
1292#    srl $t1,$t1,4
1296#    beq $t1,$zero,toString_skip_loop
1300:toString_loop_top:
1300#    addu $t0,1
1304#    srl $t1,$t1,4
1308#    bne $t1,$zero,toString_loop_top
1312:toString_skip_loop:
1312#    subu $sp,8
1316#    sw $s5,4($sp)
1320#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1324#    lw $t2,-12($s2) # vtable address
1328#    move $t0,$t2
1332:toString_checkTagBit:
1332#    subu $t0,1
1336#    lb $t1,($t0)
1340#    and $t1,0x80
1341##...lui $at,0
1345##...ori $at,$at,0x80
1349##...and $t1,$t1,$at
1352#    beq $t1,$zero,toString_checkTagBit
1356#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1360#    subu $sp,8
1364#    sw $t1,($sp)
1368#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1372#    move $s7,$zero # -4 offset header word
1376#    lw $t4,8($sp) # bytes for hash value
1380#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1384#    addu $t4,8
1388#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1392#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1396#    li $t0,CLASS_String # store string vtable address into ...
1400#    sw $t0,-12($s7) # ... -12 offset in object header
1404#    lw $t2,-12($s2) # our object's vtable address
1408#    lw $t5,4($sp) # number characters in prefix
1412#    lw $t1,12($sp) # number of characters in hashcode
1416#    addu $t3,$t1,$t5 # number of characters in string ...
1420#    addu $t3,1 # ... including the '@' character
1424#    subu $t0,$zero,$t3 # store negated length into ...
1428#    sw $t0,-4($s7) # ... -4 offset header word
1432#    lw $t0,-8($s7) # get -8 offset header-word
1436#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1437##...slt $at,$t0,$zero
1441##...beq $at,$zero,1460
1444#    and $t0,0xff # mask off object's hash value ...
1445##...lui $at,0
1449##...ori $at,$at,0xff
1453##...and $t0,$t0,$at
1456#    sw $t0,-8($s7) # ... and store back into -8 header-word
1460:skipMask_toString:
1460#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1464#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1468#    subu $t4,$t2,$t5
1472:toString_copyLoop:    
1472#    lb $t3,($t4)
1476#    and $t3,0x7f # mask off sign bit (in case first word)
1477##...lui $at,0
1481##...ori $at,$at,0x7f
1485##...and $t3,$t3,$at
1488#    sb $t3,-8($t0)
1492#    addu $t4,1
1496#    addu $t0,1
1500#    blt $t4,$t2,toString_copyLoop
1501##...slt $at,$t4,$t2
1505##...bne $at,$zero,1472

    # copy the '@' sign
1508#    li $t3,'@'
1512#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1516#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1520#    lw $t3,20($sp) # hash code to print
1524:toString_hashCopyLoop:
1524#    and $t4,$t3,0xf
1528#    srl $t3,4
1532#    lb $t4,hexChars($t4)
1536#    sb $t4,-8($t2)
1540#    subu $t2,$t2,1
1544#    bgt $t2,$t0,toString_hashCopyLoop
1545##...slt $at,$t0,$t2
1549##...bne $at,$zero,1524

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1552#    addu $sp,28
1556#    lw $ra,($sp)
1560#    addu $sp,4
1564#    move $t0, $s7 # return string we created
1568#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1572:mth_equals_String:
    
    # quick test for obvious false
1572#    lw $t0,($sp) # second parameter
1576#    beq $t0,$zero,goEsFalse # go return false if null
1580#    lw $t1,-12($t0) # vtable pointer
1584#    la $t2,CLASS_String # string vtable pointer
1588#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1592#    subu $sp,12
1596#    sw $ra,8($sp)
1600#    sw $s2,4($sp)
1604#    sw $t0,($sp)
1608#    jal mth_compareTo_String
1612#    lw $s2, 4($sp) #restore this pointer and pop parameters
1616#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1620#    seq $t0,$t0,$zero
1621##...subu $at,$t0,$zero
1625##...sltiu $t0,$at,1

    # pop return address and return $t0
1628#    lw $ra,($sp)
1632#    addu $sp,4

1636#    jr $ra # return
    
1640:goEsFalse:
    # put 0 in $t0 and return
1640#    li $t0, 0
1644#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1648:mth_toString_String:
    #we are a string, so return this.
1648#    move $t0, $s2
1652#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1656:mth_readLine_Lib:
    
1656#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1660#    sw $ra, 4($sp) # save $ra
1664#    move $t1,$sp # save "original" sp

1668:  doRead:

    # read the character
1668#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1672#    subu $t2,$v0,13
1676#    bne $t2,$zero,notReturnRL
1680#    jal readLogicalChar
1684#    subu $t2,$v0,10 # check for newline
1688#    beq $t2,$zero,foundNewLine
1692#    sw $v0,lastCharRead # push back character into queue
1696#    j foundNewLine # go process the line

1700:  notReturnRL:

    # at this point, $v0 has our character

1700#    subu $t0,$v0,10
1704#    beq $t0,$zero,foundNewLine
1708#    blt $v0,$zero,foundEof
1709##...slt $at,$v0,$zero
1713##...bne $at,$zero,1728

    # we have a character, so push it onto stack
1716#    subu $sp,$sp,4
1720#    sw $v0,($sp)

    # loop back up to get next character
1724#    j doRead

1728:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1728#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1732#    li $s7, 0 # return-value: null
1736#    j rlReturn # return

1740:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1740#    subu $t0,$t1,$sp # number of chars we read (times 4)
1744#    srl $s6,$t0,2 # number of words on stack with chars
1748#    subu $sp,$sp,4 # push char-count ...
1752#    sw $s6,($sp) # ... onto stack
1756#    addu $t2,$t0,5 # GC tag, incl. for count-word
1760#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1764#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1768#    srl $s6,$s6,2  # data words in object
1772#    move $s7,$zero # object words in object
1776#    jal newObject  # allocate space
    
    # store header words
1780#    la $t0,CLASS_String
1784#    sw $t0,-12($s7)# store class tag (String) into object
1788#    lw $t2,4($sp) # char-count
1792#    sll $t1,$t2,2 # 4 times number of chars
1796#    subu $t2,$zero,$t2 # negative of char-count
1800#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1804#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1808#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1809##...slt $at,$t0,$zero
1813##...beq $at,$zero,1832
1816#    and $t0,0xff # mask off object's hash value ...
1817##...lui $at,0
1821##...ori $at,$at,0xff
1825##...and $t0,$t0,$at
1828#    sw $t0,-8($s7) # ... and store back into -8 header-word
1832:  skipMask_readLine:

1832#    sll $t0,$t0,2 # data bytes in object
1836#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1840#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1844#    addu $sp,$sp,8 # pop redundant object-pointer and count
1848#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1852#    beq $sp,$t1,rlReturn
1856:  charCopyLoop:
1856#    lw $t2,($sp)
1860#    sb $t2,-9($t0)
1864#    addu $sp,$sp,4
1868#    subu $t0,$t0,1
1872#    bne $sp,$t1,charCopyLoop
1876:  rlReturn:

1876#    lw $ra, 4($sp)
1880#    addu $sp, 8   # pop $ra and pointless word off stack
1884#    move $t0, $s7 # return string we allocated in $s7
1888#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1892:mth_readInt_Lib:

    # save $ra by pushing onto stack
1892#    subu $sp,$sp,4
1896#    sw $ra,($sp)

1900:  riSkipWhiteLoop:
    # read a character
1900#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1904#    subu $t0,$v0,32
1908#    bgt $t0,$zero,nonWhite
1909##...slt $at,$zero,$t0
1913##...bne $at,$zero,1956
1916#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1920#    subu $t0,$v0,10
1924#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1928#    subu $t0,$v0,9
1932#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1936#    subu $t0,$v0,13
1940#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1944#    subu $t0,$v0,12
1948#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1952#    j badIntegerFormat # illegal integer char: abort program

1956:  nonWhite:
1956#    subu $t0,$v0,'-'
1960#    li $t4,1 # final multiplier
1964#    bne $t0,$zero,helpReadInt # go read
1968#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1972#    jal readLogicalChar

1976:  helpReadInt:
1976#    li $t2,10
1980#    subu $t1,$v0,'0' # convert digit to 0-9 value
1984#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1985##...sltu $at,$t1,$t2
1989##...beq $at,$zero,4236
1992#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1996:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1996#    jal readLogicalChar # read next character
2000#    subu $t1,$v0,'0' # convert digit to 0-9 value
2004#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2005##...sltu $at,$t1,$t2
2009##...beq $at,$zero,2028

2012#    mul $t3,$t3,$t2 # multiply old value by 10
2013##...mult $t3,$t2
2017##...mflo $t3
2020#    addu $t3,$t3,$t1 # add in value of new digit
2024#    j digitLoop

2028:  doneDigitLoop:

    # "push back" unused character into queue
2028#    sw $v0,lastCharRead

    # restore return address
2032#    lw $ra,($sp)
2036#    addu $sp, 4

    # multiply by sign and put return value in $t0
2040#    mult $t3,$t4 # multiply to account for poss. minus sign
2044#    mflo $t3
2048#    move $t0, $t3
    
    # return
2052#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2056:mth_readChar_Lib:

    # save $ra by pushing onto stack
2056#    subu $sp,$sp,4
2060#    sw $ra,($sp)

      # read the character
2064#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
2068#    lw $ra,($sp)
2072#    addu $sp, 4
2076#    move $t0, $v0

    # return
2080#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
2084:mth_printStr_Lib:
    # check for null, printing "(null)", if so
2084#    lw $t0,($sp)
2088#    bne $t0,$zero,psNotNull

    # print "(null)"
2092#    la $a0,nullStr
2096#    li $v0,4
2100#    syscall
2104#    j donePrintStr
    
2108:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
2108#    subu $t0,$t0,8
2112#    lw $t1,($t0) # number of data words, but needs modification
2116#    blt $t1,$zero,skipPrintStr1
2117##...slt $at,$t1,$zero
2121##...bne $at,$zero,2140
2124#    and $t1,0xff # mask out all but low byte
2125##...lui $at,0
2129##...ori $at,$at,0xff
2133##...and $t1,$t1,$at
2136#    b skipPrintStr2
2140:skipPrintStr1:
2140#    and $t1,0x7ffffff
2141##...lui $at,2047
2145##...ori $at,$at,0xffff
2149##...and $t1,$t1,$at
2152:skipPrintStr2:    
2152#    sll $t1,$t1,2
2156#    subu $t1,$t0,$t1 # first word in string
2160#    lw $t0,4($t0) # negative of string-length
2164#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
2168#    beq $t0,$t1,donePrintStr
2172:  psLoop:
2172#    lb $a0,($t1) # next byte
2176#    li $v0,11 # code for printing char
2180#        syscall # print the char
2184#    addu $t1,$t1,1 # go to next char
2188#    blt $t1,$t0,psLoop
2189##...slt $at,$t1,$t0

3417##...addiu $t6,$t6,4828
3420#    la $s3,seg0_start
3424#    la $s4,seg0_end
3425##...lui $s4,16
3429##...addiu $s4,$s4,4828
3432#    sw $zero,cur_seg
3436#    bne $t0,$zero,skipGc1

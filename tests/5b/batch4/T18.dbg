3444#    la $s3,seg1_start
3445##...lui $s3,16
3449##...addiu $s3,$s3,4828
3452#    la $s4,seg1_end
3453##...lui $s4,32
3457##...addiu $s4,$s4,4828
3460#    sw $s5,cur_seg

3704#    bge $t2,$zero,gcSkip4a # are there hash bits?
3705##...slt $at,$t2,$zero
3709##...beq $at,$zero,3724
3712#    and $t2,0xff # mask off hash bits
3713##...lui $at,0
3717##...ori $at,$at,0xff
3721##...and $t2,$t2,$at
3724:gcSkip4a:    
3724#    sll $t2,$t2,2 # # data bytes
3728#    addu $t2,$t2,8 # to skip header words
3732#    addu $t2,$t0,$t2 # pointer to new object

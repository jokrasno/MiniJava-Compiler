1625##...slt $at,$t4,$zero
1629##...beq $at,$zero,1648
1632#    and $t4,0xff # mask off object's hash value ...
1633##...lui $at,0
1637##...ori $at,$at,0xff
1641##...and $t4,$t4,$at
1644#    sw $t4,-8($s7) # ... and store back into -8 header-word
1648:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word

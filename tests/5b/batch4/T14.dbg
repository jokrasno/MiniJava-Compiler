##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
440:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
440#    lw $t0,-8($s2) # get word with hash bits from this
444#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
448#    addu $t0,$t1

452#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
456:mth_equals_Object:
456#    move $t0,$s2 # first pointer (this)
460#    lw $t1,($sp) # second pointer
464#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
465##...subu $at,$t0,$t1
469##...sltiu $t0,$at,1

472#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
476:mth_hashCode_String:
476#    move $t0,$s2 # put this pointer in t0

480#    li $t2,0 # current hash value
484#    lw $t1,-4($t0) # negative of number of characters in string
488#    beq $t1,$zero,done_hashCode_String # if zero length => done
492#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
496#    and $t0,0xfffffffc # adjust for padding
497##...lui $at,65535
501##...ori $at,$at,0xfffc
505##...and $t0,$t0,$at
508#    subu $t1,$t0,$t1 # address at end of string +12
512:loop_hashCode_String:    
512#    sll $t4,$t2,5 # multiply by 32
516#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
520#    lbu $t3,-12($t0) # current character
524#    addu $t2,$t3 # add in current character
528#    addu $t0,1 # go to next character's address
532#    bne $t0,$t1,loop_hashCode_String # loop back if more
536:done_hashCode_String:    

    # push int on stack
536#    move $t0, $t2 # put $t2 in return slot
540#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
544:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
544#    subu $sp,4
548#    sw $ra,($sp)
    
    # get hash value
552#    lw $t2,-12($s2) # vtable address
556#    lw $t0,($t2) # method address
560#    jalr $t0
564#    subu $sp,8 # push result (int in $t0) on stack
568#    sw $s5,4($sp)
572#    sw $t0,($sp)

    # compute print-size of hash value
576#    li $t0, 1
580#    lw $t1, ($sp)
584#    srl $t1,$t1,4
588#    beq $t1,$zero,toString_skip_loop
592:toString_loop_top:
592#    addu $t0,1
596#    srl $t1,$t1,4
600#    bne $t1,$zero,toString_loop_top
604:toString_skip_loop:
604#    subu $sp,8
608#    sw $s5,4($sp)
612#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
616#    lw $t2,-12($s2) # vtable address
620#    move $t0,$t2
624:toString_checkTagBit:
624#    subu $t0,1
628#    lb $t1,($t0)
632#    and $t1,0x80
633##...lui $at,0
637##...ori $at,$at,0x80
641##...and $t1,$t1,$at
644#    beq $t1,$zero,toString_checkTagBit
648#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
652#    subu $sp,8
656#    sw $t1,($sp)
660#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
664#    move $s7,$zero # -4 offset header word
668#    lw $t4,8($sp) # bytes for hash value
672#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
676#    addu $t4,8
680#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
684#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

688#    li $t0,CLASS_String # store string vtable address into ...
692#    sw $t0,-12($s7) # ... -12 offset in object header
696#    lw $t2,-12($s2) # our object's vtable address
700#    lw $t5,4($sp) # number characters in prefix
704#    lw $t1,12($sp) # number of characters in hashcode
708#    addu $t3,$t1,$t5 # number of characters in string ...
712#    addu $t3,1 # ... including the '@' character
716#    subu $t0,$zero,$t3 # store negated length into ...
720#    sw $t0,-4($s7) # ... -4 offset header word
724#    lw $t0,-8($s7) # get -8 offset header-word
728#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
729##...slt $at,$t0,$zero
733##...beq $at,$zero,752
736#    and $t0,0xff # mask off object's hash value ...
737##...lui $at,0
741##...ori $at,$at,0xff
745##...and $t0,$t0,$at
748#    sw $t0,-8($s7) # ... and store back into -8 header-word
752:skipMask_toString:
752#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
756#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
760#    subu $t4,$t2,$t5
764:toString_copyLoop:    
764#    lb $t3,($t4)
768#    and $t3,0x7f # mask off sign bit (in case first word)
769##...lui $at,0
773##...ori $at,$at,0x7f
777##...and $t3,$t3,$at
780#    sb $t3,-8($t0)
784#    addu $t4,1
788#    addu $t0,1

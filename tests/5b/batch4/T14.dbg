    # copy all source bytes to the target
3220:  gCinnerCopy2:
3220#    lw $s0,($t4)
3224#    sw $s0,($s3)
3228#    addu $t4,$t4,4
3232#    addu $s3,$s3,4
3236#    bltu $t4,$t3,gCinnerCopy2
3237##...sltu $at,$t4,$t3
3241##...bne $at,$zero,3220

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3244#    sw $zero,-8($t1) # 0 in first header-slot
3248#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3252#    sw $t8,($t0)

3256:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3256#    addu $t0,$t0,4
3260#    bltu $t0,$s1,gcNextPointerInObject
3261##...sltu $at,$t0,$s1
3265##...bne $at,$zero,3104

3268:  gcTestIterDone2:
3268#    bltu $t0,$s3,gcHeapCopyLoop
3269##...sltu $at,$t0,$s3
3273##...bne $at,$zero,2988

    ###### end outer loop to copy all non-stack-direct objects ######

3276:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3276#    lw $s2,($sp)
3280#    addu $sp,$sp,4

    # mark us as having already GC'd
3284#    move $t5,$s5

    # go try and allocate again
3288#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3292:vm_init:

    # mark bottom of stack
3292#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3296#    move $s2,$zero

    #set up the "five" register
3300#    li $s5,5

3304#    la $s3,seg0_start
3308#    la $s4,seg0_end
3309##...lui $s4,16
3313##...addiu $s4,$s4,4200
    
    # return
3316#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3320:divide:
    # get parameters; abort if divisor zero
3320#    lw $t0,($sp)
3324#    lw $t1,8($sp)
3328#    beq $t0,$zero,divByZeroError
    
    # perform division
3332#    div $t1,$t0
3336#    mflo $t0

    # store result, adjust stack and return
3340#    addu $sp,$sp,8 # adjust stack
3344#    sw $t0,($sp) # store result
3348#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3352:remainder:
    # get parameters; abort if divisor zero
3352#    lw $t0,($sp)
3356#    lw $t1,8($sp)
3360#    beq $t0,$zero,divByZeroError
    
    # perform division
3364#    div $t1,$t0
3368#    mfhi $t0

    # store result, adjust stack and return
3372#    addu $sp,$sp,8 # adjust stack
3376#    sw $t0,($sp) # store result
3380#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3384:checkCast:
    # get object, allow immediately if null
3384#    lw $t2,($sp)
3388#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3392#    lw $t2,-12($t2) # vtable address
3396#    bge $t2,$t1,castException
3397##...slt $at,$t2,$t1
3401##...beq $at,$zero,3536
3404#    blt $t2,$t0,castException
3405##...slt $at,$t2,$t0
3409##...bne $at,$zero,3536
    
    # return, leaving object unchanged on stack
3412:  checkCastReturn:    
3412#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3416:instanceOf:
    # get object, go return false if null
3416#    lw $t2,($sp)
3420#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3424#    lw $t2,-12($t2) # vtable address
3428#    sge $t0,$t2,$t0 # are we >= the lower limit?
3429##...slt $t0,$t2,$t0
3433##...xori $t0,$t0,0x1
3436#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3440#    and $t2,$t0,$t1
3444#    sw $t2,($sp)
3448:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3448#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3452:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3452#    li $v0,4 # syscall-code for print-string
3456#    syscall
3460:exit:
    # print termination message
3460#    li $v0,4 # syscall-code for print-string
3464#    la $a0,exitString
3468#    syscall

    # terminate execution
3472#    li $v0,10 #syscall-code for "exit"
3476#    syscall

3480:outOfHeapMemory:
3480#    la $a0,heapMemoryMsg
3484#    j exitError
3488:divByZeroError:
3488#    la $a0,divByZeroMsg
3492#    j exitError
3496:strIndexOutOfBounds:
3496#    la $a0,strIndexOutOfBoundsMsg
3500#    j exitError
3504:arrayIndexOutOfBounds:
3504#    la $a0,arrayIndexOutOfBoundsMsg
3508#    j exitError
3512:arraySizeOutOfBounds:
3512#    la $a0,arraySizeOutOfBoundsMsg
3516#    j exitError
3520:nullPtrException:
3520#    la $a0,nullPtrExceptionMsg
3524#    j exitError
3528:badIntegerFormat:
3528#    la $a0,badIntegerFormatMsg
3532#    j exitError
3536:castException:
3536#    la $a0,castExceptionMsg
3540#    j exitError
############## data section ################
    .data
3836:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3852:cur_seg:
    .word 0

3856:lastCharRead:
    .word -2 # -2 => no buffered character
3860:prevHashConstant:
    .word 0x2785173c
3864:gcCount:
    .word 0

3868:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3895:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3918:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3953:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3987:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4020:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4051:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4099:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4120:gcMsg: 
      .asciiz "\nGC!\n"
4126:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4158:nullStr:
    .asciiz "null"
4163:trueString:
    .asciiz "true"
4168:falseString:
    .asciiz "false"
4174:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4193:newlineString:
    .asciiz "\n"
    
    .align 2
4196:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4200:seg0_start:
    .space 0x100000
1052776:seg0_end:
1052776:seg1_start:
    .space 0x100000
2101352:seg1_end:

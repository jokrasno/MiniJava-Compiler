2528#    addu $t0,$s6,$s7
2532#    sll $t0,$t0,2
2536#    addu $t0,$t0,8 # amount of memory needed
2540#    addu $t1,$t0,$s3
2544#    bgtu $t1,$s4,doGC
2545##...sltu $at,$s4,$t1
2549##...bne $at,$zero,2672

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
2552#    move $t2,$s3
2556:  zeroObjLoop:
2556#    sw $zero,($s3)
2560#    lw $zero,($s3)

2564#    addu $s3,4
2568#    bltu $s3,$t1,zeroObjLoop

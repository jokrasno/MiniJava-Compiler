892#    sw $s2,4($sp)
896#    sw $t0,($sp)
900#    jal mth_compareTo_String
904#    lw $s2, 4($sp) #restore this pointer and pop parameters
908#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
912#    seq $t0,$t0,$zero
913##...subu $at,$t0,$zero
917##...sltiu $t0,$at,1

    # pop return address and return $t0
920#    lw $ra,($sp)
924#    addu $sp,4

928#    jr $ra # return
    
932:goEsFalse:
    # put 0 in $t0 and return
932#    li $t0, 0
936#    jr $ra # return

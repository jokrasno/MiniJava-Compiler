1205##...bne $at,$zero,1248
1208#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1212#    subu $t0,$v0,10
1216#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1220#    subu $t0,$v0,9
1224#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1228#    subu $t0,$v0,13
1232#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1236#    subu $t0,$v0,12
1240#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1244#    j badIntegerFormat # illegal integer char: abort program

1248:  nonWhite:
1248#    subu $t0,$v0,'-'
1252#    li $t4,1 # final multiplier
1256#    bne $t0,$zero,helpReadInt # go read
1260#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1264#    jal readLogicalChar

1268:  helpReadInt:
1268#    li $t2,10
1272#    subu $t1,$v0,'0' # convert digit to 0-9 value
1276#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1277##...sltu $at,$t1,$t2
1281##...beq $at,$zero,3528
1284#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1288:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1288#    jal readLogicalChar # read next character
1292#    subu $t1,$v0,'0' # convert digit to 0-9 value
1296#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1297##...sltu $at,$t1,$t2
1301##...beq $at,$zero,1320

1304#    mul $t3,$t3,$t2 # multiply old value by 10
1305##...mult $t3,$t2
1309##...mflo $t3
1312#    addu $t3,$t3,$t1 # add in value of new digit
1316#    j digitLoop

1320:  doneDigitLoop:

    # "push back" unused character into queue

1692#    lw $t2,-8($s7)   # data words in target string
1696#    sll $t2,$t2,2    # data bytes in target string
1700#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length

2593##...beq $at,$zero,2640
2596#    lw $t1,prevHashConstant
2600#    addu $t1,0x12b68fd2
2601##...lui $at,4791
2605##...addiu $at,$at,-28718
2609##...addu $t1,$at,$t1
2612#    sw $t1,prevHashConstant # update hash constant

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
948:mth_readLine_Lib:
    
948#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
952#    sw $ra, 4($sp) # save $ra
956#    move $t1,$sp # save "original" sp

960:  doRead:

    # read the character
960#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
964#    subu $t2,$v0,13
968#    bne $t2,$zero,notReturnRL
972#    jal readLogicalChar
976#    subu $t2,$v0,10 # check for newline
980#    beq $t2,$zero,foundNewLine
984#    sw $v0,lastCharRead # push back character into queue
988#    j foundNewLine # go process the line

992:  notReturnRL:

    # at this point, $v0 has our character

992#    subu $t0,$v0,10
996#    beq $t0,$zero,foundNewLine
1000#    blt $v0,$zero,foundEof
1001##...slt $at,$v0,$zero
1005##...bne $at,$zero,1020

    # we have a character, so push it onto stack
1008#    subu $sp,$sp,4
1012#    sw $v0,($sp)

    # loop back up to get next character
1016#    j doRead

1020:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1020#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1024#    li $s7, 0 # return-value: null
1028#    j rlReturn # return

1032:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1032#    subu $t0,$t1,$sp # number of chars we read (times 4)
1036#    srl $s6,$t0,2 # number of words on stack with chars
1040#    subu $sp,$sp,4 # push char-count ...
1044#    sw $s6,($sp) # ... onto stack
1048#    addu $t2,$t0,5 # GC tag, incl. for count-word
1052#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1056#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1060#    srl $s6,$s6,2  # data words in object
1064#    move $s7,$zero # object words in object
1068#    jal newObject  # allocate space
    
    # store header words
1072#    la $t0,CLASS_String
1076#    sw $t0,-12($s7)# store class tag (String) into object
1080#    lw $t2,4($sp) # char-count
1084#    sll $t1,$t2,2 # 4 times number of chars
1088#    subu $t2,$zero,$t2 # negative of char-count
1092#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1096#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1100#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1101##...slt $at,$t0,$zero
1105##...beq $at,$zero,1124
1108#    and $t0,0xff # mask off object's hash value ...
1109##...lui $at,0
1113##...ori $at,$at,0xff
1117##...and $t0,$t0,$at
1120#    sw $t0,-8($s7) # ... and store back into -8 header-word
1124:  skipMask_readLine:

1124#    sll $t0,$t0,2 # data bytes in object
1128#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1132#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1136#    addu $sp,$sp,8 # pop redundant object-pointer and count
1140#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1144#    beq $sp,$t1,rlReturn
1148:  charCopyLoop:
1148#    lw $t2,($sp)
1152#    sb $t2,-9($t0)
1156#    addu $sp,$sp,4
1160#    subu $t0,$t0,1
1164#    bne $sp,$t1,charCopyLoop
1168:  rlReturn:

1168#    lw $ra, 4($sp)
1172#    addu $sp, 8   # pop $ra and pointless word off stack
1176#    move $t0, $s7 # return string we allocated in $s7
1180#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1184:mth_readInt_Lib:

    # save $ra by pushing onto stack
1184#    subu $sp,$sp,4
1188#    sw $ra,($sp)

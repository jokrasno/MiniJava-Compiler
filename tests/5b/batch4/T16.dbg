    # allocate memory
4164#    subu $s6,$t1,$t2 # # chars in target-string
4168#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
4172#    srl $s6,$s6,2 # convert bytes-count to word-count
4176#    move $s7,$zero # (no object-bytes in string)
4180#    jal newObject

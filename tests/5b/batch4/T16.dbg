    # greater
5036#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
5040#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
5044#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
5048:  cmpHitLimitzz:
5048#    move $t0, $t5 # store return value

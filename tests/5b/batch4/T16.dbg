4581##...beq $at,$zero,6068

    # access element
4584#    lw $t1,-8($t0) # # data words in object
4588#    sll $t1,$t1,2 # - byte-offset from end of chars
4592#    subu $t1,$t2,$t1 # - address of first char in string, offset by 8
4596#    addu $t0,$t0,$t1 # - address of our char, offset by 8
4600#    lb $t0,-8($t0) # our char

    # return
4604#    jr $ra

########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
4608:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
4608#    subu $sp,$sp,8
4612#    sw $ra,4($sp)

    # save current sp
4616#    move $t0,$sp

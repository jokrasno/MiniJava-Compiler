3780#    beq $t0,$zero,riSkipWhiteLoop # start over if space
3784#    subu $t0,$v0,10
3788#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
3792#    subu $t0,$v0,9
3796#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
3800#    subu $t0,$v0,13
3804#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
3808#    subu $t0,$v0,12
3812#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
3816#    j badIntegerFormat # illegal integer char: abort program

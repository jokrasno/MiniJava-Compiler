    # compute pointer value and set up header-words
5148#    sll $t0,$s7,2    # number of post-header bytes
5152#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
5156#    li $t2,255
5160#    bgeu $s6,$t2 firstHeaderLarge
5161##...sltu $at,$s6,$t2
5165##...beq $at,$zero,5212
5168#    lw $t1,prevHashConstant
5172#    addu $t1,0x12b68fd2
5173##...lui $at,4791
5177##...addiu $at,$at,-28718
5181##...addu $t1,$at,$t1
5184#    sw $t1,prevHashConstant # update hash constant
5188#    or $t1,0x80000000 # set top bit
5189##...lui $at,32768
5193##...or $t1,$at,$t1
5196#    and $t1,0xffffff00 # clear low bit
5197##...lui $at,65535
5201##...ori $at,$at,0xff00
5205##...and $t1,$t1,$at
5208#    or $s6,$t1
5212:firstHeaderLarge:
5212#    sw $s6,-8($t0) # store header-1 value
5216#    lw $zero,-8($t0)

    # store second header-value
5220#    sw $s7,-4($t0)   # second header-word
5224#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
5228#    move $s7,$t0
5232#    subu $sp,$sp,4
5236#    sw $t0,($sp)

5240#    jr $ra

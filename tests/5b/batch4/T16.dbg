5796#    sw $s0,($s3)
5800#    addu $t4,$t4,4
5804#    addu $s3,$s3,4
5808#    bltu $t4,$t3,gCinnerCopy2
5809##...sltu $at,$t4,$t3
5813##...bne $at,$zero,5792

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
5056:readLogicalChar:

    # check if we already have a character
5056#    lw $v0,lastCharRead
5060#    li $t0,-2
5064#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
5068#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
5072#    jr $ra # return
    
5076:  doReadCh:
    # we need to actually read a character: read and return
5076#    li $v0,12 # use system call to read a character
5080#    syscall
5084#    jr $ra # return

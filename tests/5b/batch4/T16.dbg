5128#    sw $zero,($s3)
5132#    lw $zero,($s3)

5136#    addu $s3,4
5140#    bltu $s3,$t1,zeroObjLoop
5141##...sltu $at,$s3,$t1
5145##...bne $at,$zero,5128

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # mask off hash bits, if needed
4192#    lw $t4,-8($s7) # data words in source string
4196#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
4197##...slt $at,$t4,$zero
4201##...beq $at,$zero,4220
4204#    and $t4,0xff # mask off object's hash value ...
4205##...lui $at,0

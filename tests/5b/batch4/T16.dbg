    # get string pointers and check parameter for null
4336#    lw $t0,4($sp)
4340#    beq $t0,$zero,nullPtrException
4344#    move $t1,$s2
    
    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
4348#    lw $t0,-4($t0) # negative size of second object
4352#    lw $t1,-4($t1) # negative size of first object
4356#    addu $s6,$t0,$t1 # sum of negative sizes
4360#    sra $s6,$s6,2 # negative word-size of char part
4364#    subu $s6,$zero,$s6 # word size of char part
4368#    addu $s6,$s6,1 # data word size, including v-table word
4372#    move $s7,$zero
4376#    jal newObject

    # store String vtable address in vtable address field
4380#    la $t0,CLASS_String
4384#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
4388#    lw $t4,-8($s7) # # data words in source string
4392#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
4393##...slt $at,$t4,$zero
4397##...beq $at,$zero,4416
4400#    and $t4,0xff # mask off object's hash value ...
4401##...lui $at,0
4405##...ori $at,$at,0xff
4409##...and $t4,$t4,$at
4412#    sw $t4,-8($s7) # ... and store back into -8 header-word
4416:skipMask_concat:

4416#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
4420#    move $t1,$s2   # first object
4424#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
4428#    lw $t2,-4($t0) # negative length of second object
4432#    lw $t3,-4($t1) # negative length of first object
4436#    addu $t4,$t2,$t3 # sum of negative lengths
4440#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################

    # compute addresses for moving data from first string
4444#    lw $t4,-8($t1) # # data words in first string
4448#    sll $t4,$t4,2 # # data bytes in first string

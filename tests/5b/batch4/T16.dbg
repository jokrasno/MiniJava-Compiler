    # compute the amount of space that is needed
5716#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
5717##...slt $at,$t8,$zero
5721##...beq $at,$zero,5736
5724#    and $t8,0xff # mask off hash bits
5725##...lui $at,0
5729##...ori $at,$at,0xff
5733##...and $t8,$t8,$at

5736:  gcSkip5:
5736#    sll $t8,$t8,2 # bytes in negative-offset portion ...

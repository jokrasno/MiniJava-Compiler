########################################################
# str.charAt(n) - library method (class String)
# accesses a character in a string, as in Java
# - parameters:
#   - ($sp) - the index, n
#   - 4($sp) - GC tag
#   - 8($sp) - old this pointer
#   - $s2    - this pointer
# - returns:
#   - $t0 - the character found.
########################################################
4560:mth_charAt_String:
    # get string
4560#    move $t0,$s2

    # check that index is in bounds
4564#    lw $t1,-4($t0) # negative of # data words in string
4568#    subu $t3,$zero,$t1 # # chars in string
4572#    lw $t2,($sp) # index

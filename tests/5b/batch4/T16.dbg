########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
5864:vm_init:

    # mark bottom of stack
5864#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
5868#    move $s2,$zero

    #set up the "five" register
5872#    li $s5,5

5876#    la $s3,seg0_start
5880#    la $s4,seg0_end
5881##...lui $s4,16
5885##...addiu $s4,$s4,6912
    
    # return
5888#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5892:divide:
    # get parameters; abort if divisor zero
5892#    lw $t0,($sp)
5896#    lw $t1,8($sp)
5900#    beq $t0,$zero,divByZeroError
    
    # perform division
5904#    div $t1,$t0
5908#    mflo $t0

    # store result, adjust stack and return
5912#    addu $sp,$sp,8 # adjust stack
5916#    sw $t0,($sp) # store result
5920#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5924:remainder:
    # get parameters; abort if divisor zero
5924#    lw $t0,($sp)
5928#    lw $t1,8($sp)
5932#    beq $t0,$zero,divByZeroError
    
    # perform division
5936#    div $t1,$t0
5940#    mfhi $t0

    # store result, adjust stack and return
5944#    addu $sp,$sp,8 # adjust stack
5948#    sw $t0,($sp) # store result
5952#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
5956:checkCast:
    # get object, allow immediately if null
5956#    lw $t2,($sp)
5960#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
5964#    lw $t2,-12($t2) # vtable address
5968#    bge $t2,$t1,castException
5969##...slt $at,$t2,$t1
5973##...beq $at,$zero,6108
5976#    blt $t2,$t0,castException
5977##...slt $at,$t2,$t0
5981##...bne $at,$zero,6108
    
    # return, leaving object unchanged on stack
5984:  checkCastReturn:    
5984#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
5988:instanceOf:
    # get object, go return false if null
5988#    lw $t2,($sp)
5992#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
5996#    lw $t2,-12($t2) # vtable address
6000#    sge $t0,$t2,$t0 # are we >= the lower limit?
6001##...slt $t0,$t2,$t0
6005##...xori $t0,$t0,0x1
6008#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
6012#    and $t2,$t0,$t1
6016#    sw $t2,($sp)
6020:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
6020#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

6024:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
6024#    li $v0,4 # syscall-code for print-string
6028#    syscall
6032:exit:
    # print termination message
6032#    li $v0,4 # syscall-code for print-string
6036#    la $a0,exitString
6040#    syscall

    # terminate execution
6044#    li $v0,10 #syscall-code for "exit"
6048#    syscall

6052:outOfHeapMemory:
6052#    la $a0,heapMemoryMsg
6056#    j exitError
6060:divByZeroError:
6060#    la $a0,divByZeroMsg
6064#    j exitError
6068:strIndexOutOfBounds:
6068#    la $a0,strIndexOutOfBoundsMsg
6072#    j exitError
6076:arrayIndexOutOfBounds:
6076#    la $a0,arrayIndexOutOfBoundsMsg
6080#    j exitError
6084:arraySizeOutOfBounds:
6084#    la $a0,arraySizeOutOfBoundsMsg
6088#    j exitError
6092:nullPtrException:

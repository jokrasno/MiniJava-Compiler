###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3012:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
3012#    lw $t0,-8($s2) # get word with hash bits from this
3016#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
3020#    addu $t0,$t1

3024#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3028:mth_equals_Object:
3028#    move $t0,$s2 # first pointer (this)
3032#    lw $t1,($sp) # second pointer
3036#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
3037##...subu $at,$t0,$t1
3041##...sltiu $t0,$at,1

3044#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3048:mth_hashCode_String:
3048#    move $t0,$s2 # put this pointer in t0

3052#    li $t2,0 # current hash value
3056#    lw $t1,-4($t0) # negative of number of characters in string
3060#    beq $t1,$zero,done_hashCode_String # if zero length => done
3064#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
3068#    and $t0,0xfffffffc # adjust for padding
3069##...lui $at,65535
3073##...ori $at,$at,0xfffc
3077##...and $t0,$t0,$at
3080#    subu $t1,$t0,$t1 # address at end of string +12
3084:loop_hashCode_String:    
3084#    sll $t4,$t2,5 # multiply by 32
3088#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
3092#    lbu $t3,-12($t0) # current character
3096#    addu $t2,$t3 # add in current character
3100#    addu $t0,1 # go to next character's address
3104#    bne $t0,$t1,loop_hashCode_String # loop back if more
3108:done_hashCode_String:    

    # push int on stack
3108#    move $t0, $t2 # put $t2 in return slot
3112#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
3116:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
3116#    subu $sp,4
3120#    sw $ra,($sp)
    
    # get hash value
3124#    lw $t2,-12($s2) # vtable address
3128#    lw $t0,($t2) # method address
3132#    jalr $t0
3136#    subu $sp,8 # push result (int in $t0) on stack
3140#    sw $s5,4($sp)
3144#    sw $t0,($sp)

    # compute print-size of hash value
3148#    li $t0, 1
3152#    lw $t1, ($sp)
3156#    srl $t1,$t1,4
3160#    beq $t1,$zero,toString_skip_loop
3164:toString_loop_top:
3164#    addu $t0,1
3168#    srl $t1,$t1,4
3172#    bne $t1,$zero,toString_loop_top
3176:toString_skip_loop:
3176#    subu $sp,8
3180#    sw $s5,4($sp)
3184#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
3188#    lw $t2,-12($s2) # vtable address
3192#    move $t0,$t2
3196:toString_checkTagBit:
3196#    subu $t0,1
3200#    lb $t1,($t0)
3204#    and $t1,0x80
3205##...lui $at,0
3209##...ori $at,$at,0x80
3213##...and $t1,$t1,$at
3216#    beq $t1,$zero,toString_checkTagBit
3220#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
3224#    subu $sp,8
3228#    sw $t1,($sp)
3232#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
3236#    move $s7,$zero # -4 offset header word
3240#    lw $t4,8($sp) # bytes for hash value
3244#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
3248#    addu $t4,8
3252#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
3256#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

3260#    li $t0,CLASS_String # store string vtable address into ...
3264#    sw $t0,-12($s7) # ... -12 offset in object header
3268#    lw $t2,-12($s2) # our object's vtable address
3272#    lw $t5,4($sp) # number characters in prefix
3276#    lw $t1,12($sp) # number of characters in hashcode
3280#    addu $t3,$t1,$t5 # number of characters in string ...
3284#    addu $t3,1 # ... including the '@' character
3288#    subu $t0,$zero,$t3 # store negated length into ...
3292#    sw $t0,-4($s7) # ... -4 offset header word
3296#    lw $t0,-8($s7) # get -8 offset header-word
3300#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
3301##...slt $at,$t0,$zero
3305##...beq $at,$zero,3324
3308#    and $t0,0xff # mask off object's hash value ...
3309##...lui $at,0
3313##...ori $at,$at,0xff
3317##...and $t0,$t0,$at
3320#    sw $t0,-8($s7) # ... and store back into -8 header-word
3324:skipMask_toString:
3324#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
3328#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
3332#    subu $t4,$t2,$t5
3336:toString_copyLoop:    
3336#    lb $t3,($t4)
3340#    and $t3,0x7f # mask off sign bit (in case first word)
3341##...lui $at,0
3345##...ori $at,$at,0x7f
3349##...and $t3,$t3,$at
3352#    sb $t3,-8($t0)
3356#    addu $t4,1
3360#    addu $t0,1
3364#    blt $t4,$t2,toString_copyLoop
3365##...slt $at,$t4,$t2
3369##...bne $at,$zero,3336

    # copy the '@' sign
3372#    li $t3,'@'
3376#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
3380#    addu $t2,$t0,$t1 # address of last byte in string to store +8
3384#    lw $t3,20($sp) # hash code to print
3388:toString_hashCopyLoop:
3388#    and $t4,$t3,0xf
3392#    srl $t3,4
3396#    lb $t4,hexChars($t4)
3400#    sb $t4,-8($t2)
3404#    subu $t2,$t2,1
3408#    bgt $t2,$t0,toString_hashCopyLoop
3409##...slt $at,$t0,$t2
3413##...bne $at,$zero,3388

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
3416#    addu $sp,28
3420#    lw $ra,($sp)
3424#    addu $sp,4
3428#    move $t0, $s7 # return string we created
3432#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
3436:mth_equals_String:
    
    # quick test for obvious false
3436#    lw $t0,($sp) # second parameter
3440#    beq $t0,$zero,goEsFalse # go return false if null
3444#    lw $t1,-12($t0) # vtable pointer
3448#    la $t2,CLASS_String # string vtable pointer
3452#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
3456#    subu $sp,12
3460#    sw $ra,8($sp)
3464#    sw $s2,4($sp)
3468#    sw $t0,($sp)
3472#    jal mth_compareTo_String
3476#    lw $s2, 4($sp) #restore this pointer and pop parameters
3480#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
3484#    seq $t0,$t0,$zero
3485##...subu $at,$t0,$zero
3489##...sltiu $t0,$at,1

    # pop return address and return $t0
3492#    lw $ra,($sp)
3496#    addu $sp,4

3500#    jr $ra # return
    
3504:goEsFalse:
    # put 0 in $t0 and return
3504#    li $t0, 0
3508#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
3512:mth_toString_String:
    #we are a string, so return this.
3512#    move $t0, $s2
3516#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
3520:mth_readLine_Lib:
    
3520#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
3524#    sw $ra, 4($sp) # save $ra
3528#    move $t1,$sp # save "original" sp

3532:  doRead:

    # read the character
3532#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
3536#    subu $t2,$v0,13
3540#    bne $t2,$zero,notReturnRL
3544#    jal readLogicalChar
3548#    subu $t2,$v0,10 # check for newline
3552#    beq $t2,$zero,foundNewLine
3556#    sw $v0,lastCharRead # push back character into queue
3560#    j foundNewLine # go process the line

3564:  notReturnRL:

    # at this point, $v0 has our character

3564#    subu $t0,$v0,10
3568#    beq $t0,$zero,foundNewLine
3572#    blt $v0,$zero,foundEof
3573##...slt $at,$v0,$zero
3577##...bne $at,$zero,3592

    # we have a character, so push it onto stack
3580#    subu $sp,$sp,4
3584#    sw $v0,($sp)

    # loop back up to get next character
3588#    j doRead

3592:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
3592#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
3596#    li $s7, 0 # return-value: null
3600#    j rlReturn # return

3604:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
3604#    subu $t0,$t1,$sp # number of chars we read (times 4)
3608#    srl $s6,$t0,2 # number of words on stack with chars
3612#    subu $sp,$sp,4 # push char-count ...
3616#    sw $s6,($sp) # ... onto stack
3620#    addu $t2,$t0,5 # GC tag, incl. for count-word
3624#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
3628#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
3632#    srl $s6,$s6,2  # data words in object
3636#    move $s7,$zero # object words in object
3640#    jal newObject  # allocate space
    
    # store header words
3644#    la $t0,CLASS_String
3648#    sw $t0,-12($s7)# store class tag (String) into object
3652#    lw $t2,4($sp) # char-count
3656#    sll $t1,$t2,2 # 4 times number of chars
3660#    subu $t2,$zero,$t2 # negative of char-count
3664#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3668#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3672#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3673##...slt $at,$t0,$zero
3677##...beq $at,$zero,3696
3680#    and $t0,0xff # mask off object's hash value ...
3681##...lui $at,0
3685##...ori $at,$at,0xff
3689##...and $t0,$t0,$at
3692#    sw $t0,-8($s7) # ... and store back into -8 header-word
3696:  skipMask_readLine:

3696#    sll $t0,$t0,2 # data bytes in object
3700#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
3704#    subu $t0,$t0,$t2 # place to store last character (plus 9)
3708#    addu $sp,$sp,8 # pop redundant object-pointer and count
3712#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

3716#    beq $sp,$t1,rlReturn
3720:  charCopyLoop:
3720#    lw $t2,($sp)
3724#    sb $t2,-9($t0)
3728#    addu $sp,$sp,4
3732#    subu $t0,$t0,1
3736#    bne $sp,$t1,charCopyLoop

5569##...slt $at,$t2,$zero
5573##...beq $at,$zero,5588
5576#    and $t2,0xff # mask off hash bits
5577##...lui $at,0
5581##...ori $at,$at,0xff
5585##...and $t2,$t2,$at
5588:gcSkip4a:    
5588#    sll $t2,$t2,2 # # data bytes
5592#    addu $t2,$t2,8 # to skip header words
5596#    addu $t2,$t0,$t2 # pointer to new object

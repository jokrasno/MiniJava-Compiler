    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3320#    lw $s0,($t4)
3324#    lw $t9,-8($t1)
3328#    sw $t9,($t4)
3332#    sw $s0,-8($t1)

    # copy all source bytes to the target
3336:  gCinnerCopy2:
3336#    lw $s0,($t4)
3340#    sw $s0,($s3)
3344#    addu $t4,$t4,4
3348#    addu $s3,$s3,4
3352#    bltu $t4,$t3,gCinnerCopy2
3353##...sltu $at,$t4,$t3
3357##...bne $at,$zero,3336

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3360#    sw $zero,-8($t1) # 0 in first header-slot
3364#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3368#    sw $t8,($t0)

3372:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3372#    addu $t0,$t0,4
3376#    bltu $t0,$s1,gcNextPointerInObject
3377##...sltu $at,$t0,$s1
3381##...bne $at,$zero,3220

3384:  gcTestIterDone2:
3384#    bltu $t0,$s3,gcHeapCopyLoop
3385##...sltu $at,$t0,$s3
3389##...bne $at,$zero,3104

    ###### end outer loop to copy all non-stack-direct objects ######

3392:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3392#    lw $s2,($sp)
3396#    addu $sp,$sp,4

    # mark us as having already GC'd
3400#    move $t5,$s5

    # go try and allocate again
3404#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3408:vm_init:

    # mark bottom of stack
3408#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3412#    move $s2,$zero

    #set up the "five" register
3416#    li $s5,5

3420#    la $s3,seg0_start
3424#    la $s4,seg0_end
3425##...lui $s4,16
3429##...addiu $s4,$s4,4316
    
    # return
3432#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3436:divide:
    # get parameters; abort if divisor zero
3436#    lw $t0,($sp)
3440#    lw $t1,8($sp)
3444#    beq $t0,$zero,divByZeroError
    
    # perform division
3448#    div $t1,$t0
3452#    mflo $t0

    # store result, adjust stack and return
3456#    addu $sp,$sp,8 # adjust stack
3460#    sw $t0,($sp) # store result
3464#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3468:remainder:
    # get parameters; abort if divisor zero
3468#    lw $t0,($sp)
3472#    lw $t1,8($sp)
3476#    beq $t0,$zero,divByZeroError
    
    # perform division
3480#    div $t1,$t0
3484#    mfhi $t0

    # store result, adjust stack and return
3488#    addu $sp,$sp,8 # adjust stack
3492#    sw $t0,($sp) # store result
3496#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3500:checkCast:
    # get object, allow immediately if null
3500#    lw $t2,($sp)
3504#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3508#    lw $t2,-12($t2) # vtable address
3512#    bge $t2,$t1,castException
3513##...slt $at,$t2,$t1
3517##...beq $at,$zero,3652
3520#    blt $t2,$t0,castException
3521##...slt $at,$t2,$t0
3525##...bne $at,$zero,3652
    
    # return, leaving object unchanged on stack
3528:  checkCastReturn:    
3528#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3532:instanceOf:
    # get object, go return false if null
3532#    lw $t2,($sp)
3536#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3540#    lw $t2,-12($t2) # vtable address
3544#    sge $t0,$t2,$t0 # are we >= the lower limit?
3545##...slt $t0,$t2,$t0
3549##...xori $t0,$t0,0x1
3552#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3556#    and $t2,$t0,$t1
3560#    sw $t2,($sp)
3564:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3564#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3568:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3568#    li $v0,4 # syscall-code for print-string
3572#    syscall
3576:exit:
    # print termination message
3576#    li $v0,4 # syscall-code for print-string
3580#    la $a0,exitString
3584#    syscall

    # terminate execution
3588#    li $v0,10 #syscall-code for "exit"
3592#    syscall

3596:outOfHeapMemory:
3596#    la $a0,heapMemoryMsg
3600#    j exitError
3604:divByZeroError:
3604#    la $a0,divByZeroMsg
3608#    j exitError
3612:strIndexOutOfBounds:
3612#    la $a0,strIndexOutOfBoundsMsg
3616#    j exitError
3620:arrayIndexOutOfBounds:
3620#    la $a0,arrayIndexOutOfBoundsMsg
3624#    j exitError
3628:arraySizeOutOfBounds:
3628#    la $a0,arraySizeOutOfBoundsMsg
3632#    j exitError
3636:nullPtrException:
3636#    la $a0,nullPtrExceptionMsg
3640#    j exitError
3644:badIntegerFormat:
3644#    la $a0,badIntegerFormatMsg
3648#    j exitError
3652:castException:
3652#    la $a0,castExceptionMsg
3656#    j exitError
############## data section ################
    .data
3952:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3968:cur_seg:
    .word 0

3972:lastCharRead:
    .word -2 # -2 => no buffered character
3976:prevHashConstant:
    .word 0x2785173c
3980:gcCount:
    .word 0

3984:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4011:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4034:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4069:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4103:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4136:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4167:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4215:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4236:gcMsg: 
      .asciiz "\nGC!\n"
4242:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4274:nullStr:
    .asciiz "null"
4279:trueString:
    .asciiz "true"
4284:falseString:
    .asciiz "false"
4290:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4309:newlineString:
    .asciiz "\n"
    
    .align 2
4312:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4316:seg0_start:
    .space 0x100000
1052892:seg0_end:
1052892:seg1_start:
    .space 0x100000
2101468:seg1_end:

2828#    la $s3,seg0_start
2832#    la $s4,seg0_end
2833##...lui $s4,16
2837##...addiu $s4,$s4,4316
2840#    sw $zero,cur_seg
2844#    bne $t0,$zero,skipGc1
2848#    la $t6,seg0_start
2852#    la $s3,seg1_start
2853##...lui $s3,16
2857##...addiu $s3,$s3,4316
2860#    la $s4,seg1_end
2861##...lui $s4,32
2865##...addiu $s4,$s4,4316
2868#    sw $s5,cur_seg

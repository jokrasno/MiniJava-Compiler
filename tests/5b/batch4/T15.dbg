###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
980:mth_equals_String:
    
    # quick test for obvious false
980#    lw $t0,($sp) # second parameter
984#    beq $t0,$zero,goEsFalse # go return false if null
988#    lw $t1,-12($t0) # vtable pointer
992#    la $t2,CLASS_String # string vtable pointer
996#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1000#    subu $sp,12
1004#    sw $ra,8($sp)
1008#    sw $s2,4($sp)
1012#    sw $t0,($sp)
1016#    jal mth_compareTo_String
1020#    lw $s2, 4($sp) #restore this pointer and pop parameters
1024#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1028#    seq $t0,$t0,$zero
1029##...subu $at,$t0,$zero
1033##...sltiu $t0,$at,1

    # pop return address and return $t0
1036#    lw $ra,($sp)
1040#    addu $sp,4

1044#    jr $ra # return
    
1048:goEsFalse:
    # put 0 in $t0 and return
1048#    li $t0, 0
1052#    jr $ra # return

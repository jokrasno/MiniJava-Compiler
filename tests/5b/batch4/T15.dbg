2705##...sltu $at,$s6,$t2
2709##...beq $at,$zero,2756
2712#    lw $t1,prevHashConstant
2716#    addu $t1,0x12b68fd2
2717##...lui $at,4791
2721##...addiu $at,$at,-28718
2725##...addu $t1,$at,$t1
2728#    sw $t1,prevHashConstant # update hash constant
2732#    or $t1,0x80000000 # set top bit
2733##...lui $at,32768
2737##...or $t1,$at,$t1
2740#    and $t1,0xffffff00 # clear low bit
2741##...lui $at,65535
2745##...ori $at,$at,0xff00
2749##...and $t1,$t1,$at
2752#    or $s6,$t1
2756:firstHeaderLarge:
2756#    sw $s6,-8($t0) # store header-1 value
2760#    lw $zero,-8($t0)

    # store second header-value
2764#    sw $s7,-4($t0)   # second header-word
2768#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
2772#    move $s7,$t0
2776#    subu $sp,$sp,4
2780#    sw $t0,($sp)

2784#    jr $ra

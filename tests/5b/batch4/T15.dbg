853##...lui $at,0
857##...ori $at,$at,0xff
861##...and $t0,$t0,$at
864#    sw $t0,-8($s7) # ... and store back into -8 header-word
868:skipMask_toString:
868#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
872#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
876#    subu $t4,$t2,$t5
880:toString_copyLoop:    
880#    lb $t3,($t4)

1533##...slt $at,$t0,$zero
1537##...beq $at,$zero,1556
1540#    and $t0,0xff # mask off object's hash value ...
1541##...lui $at,0
1545##...ori $at,$at,0xff
1549##...and $t0,$t0,$at
1552#    sw $t0,-8($s7) # ... and store back into -8 header-word
1556:skipMask_toString:
1556#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1560#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1564#    subu $t4,$t2,$t5
1568:toString_copyLoop:    
1568#    lb $t3,($t4)
1572#    and $t3,0x7f # mask off sign bit (in case first word)
1573##...lui $at,0
1577##...ori $at,$at,0x7f
1581##...and $t3,$t3,$at
1584#    sb $t3,-8($t0)

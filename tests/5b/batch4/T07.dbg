1716#    seq $t0,$t0,$zero
1717##...subu $at,$t0,$zero
1721##...sltiu $t0,$at,1

    # pop return address and return $t0
1724#    lw $ra,($sp)
1728#    addu $sp,4

1732#    jr $ra # return
    
1736:goEsFalse:
    # put 0 in $t0 and return
1736#    li $t0, 0
1740#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1348:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1348#    subu $sp,4
1352#    sw $ra,($sp)
    
    # get hash value
1356#    lw $t2,-12($s2) # vtable address
1360#    lw $t0,($t2) # method address
1364#    jalr $t0
1368#    subu $sp,8 # push result (int in $t0) on stack
1372#    sw $s5,4($sp)
1376#    sw $t0,($sp)

    # compute print-size of hash value
1380#    li $t0, 1
1384#    lw $t1, ($sp)
1388#    srl $t1,$t1,4
1392#    beq $t1,$zero,toString_skip_loop
1396:toString_loop_top:
1396#    addu $t0,1
1400#    srl $t1,$t1,4
1404#    bne $t1,$zero,toString_loop_top
1408:toString_skip_loop:
1408#    subu $sp,8
1412#    sw $s5,4($sp)
1416#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1420#    lw $t2,-12($s2) # vtable address
1424#    move $t0,$t2
1428:toString_checkTagBit:
1428#    subu $t0,1
1432#    lb $t1,($t0)
1436#    and $t1,0x80
1437##...lui $at,0
1441##...ori $at,$at,0x80
1445##...and $t1,$t1,$at
1448#    beq $t1,$zero,toString_checkTagBit
1452#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1456#    subu $sp,8
1460#    sw $t1,($sp)
1464#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1468#    move $s7,$zero # -4 offset header word
1472#    lw $t4,8($sp) # bytes for hash value
1476#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1480#    addu $t4,8
1484#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1488#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1492#    li $t0,CLASS_String # store string vtable address into ...
1496#    sw $t0,-12($s7) # ... -12 offset in object header
1500#    lw $t2,-12($s2) # our object's vtable address
1504#    lw $t5,4($sp) # number characters in prefix
1508#    lw $t1,12($sp) # number of characters in hashcode
1512#    addu $t3,$t1,$t5 # number of characters in string ...
1516#    addu $t3,1 # ... including the '@' character
1520#    subu $t0,$zero,$t3 # store negated length into ...
1524#    sw $t0,-4($s7) # ... -4 offset header word
1528#    lw $t0,-8($s7) # get -8 offset header-word

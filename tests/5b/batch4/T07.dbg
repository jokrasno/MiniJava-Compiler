    # we need skip over it then loop back to do next object.
3860:  skipToNextObj:
3860#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3864#    sll $t1,$t1,2 # convert to byte-count
3868#    addu $t0,$t2,$t1 # skip over object
3872#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3876:  gcNotDataArray:
3876#    lw $t3,-4($t2) # # object words (negative treated as zero)
3880#    bge $t3,$zero,gcH2Neg2
3881##...slt $at,$t3,$zero
3885##...beq $at,$zero,3892
3888#    move $t3,$zero
3892:  gcH2Neg2:
3892#    sll $t3,$t3,2 # # object bytes
3896#    move $t0,$t2 # address of first pointer in object
3900#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3904#    beq $t0,$s1,gcTestIterDone2
    
3908:  gcNextPointerInObject:
    # get pointer from object
3908#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3912#    bleu $t1,$t6,gcGoNextPointerSlot
3913##...sltu $at,$t6,$t1
3917##...beq $at,$zero,4060
3920#    bgtu $t1,$t7,gcGoNextPointerSlot
3921##...sltu $at,$t7,$t1
3925##...bne $at,$zero,4060

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
3928#    lw $t8,-8($t1) # possible forwarding tag
3932#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3936#    lw $t8,-4($t1) # forwarding pointer: object's new address
3940#    sw $t8,($t0) # update pointer in object
3944#    j gcGoNextPointerSlot # do next iteration

3948:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3948#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3949##...slt $at,$t8,$zero
3953##...beq $at,$zero,3968
3956#    and $t8,0xff # mask off hash bits
3957##...lui $at,0
3961##...ori $at,$at,0xff
3965##...and $t8,$t8,$at

3968:  gcSkip5:
3968#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3972#    addu $t8,$t8,8 # ... add in bytes for header-words
3976#    subu $t4,$t1,$t8 # address of first word of source object
3980#    lw $t3,-4($t1) # # words in positive-offset portion
3984#    bge $t3,$zero,gcNoNeg
3985##...slt $at,$t3,$zero
3989##...beq $at,$zero,3996
3992#    move $t3,$zero # negative treated as zero
3996:  gcNoNeg:
3996#    sll $t3,$t3,2 # bytes in negative-offset portion
4000#    addu $t3,$t3,$t1 # address one word past last word of source

4004#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4008#    lw $s0,($t4)
4012#    lw $t9,-8($t1)
4016#    sw $t9,($t4)
4020#    sw $s0,-8($t1)

    # copy all source bytes to the target
4024:  gCinnerCopy2:
4024#    lw $s0,($t4)
4028#    sw $s0,($s3)
4032#    addu $t4,$t4,4
4036#    addu $s3,$s3,4
4040#    bltu $t4,$t3,gCinnerCopy2
4041##...sltu $at,$t4,$t3
4045##...bne $at,$zero,4024

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4048#    sw $zero,-8($t1) # 0 in first header-slot
4052#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4056#    sw $t8,($t0)

4060:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4060#    addu $t0,$t0,4
4064#    bltu $t0,$s1,gcNextPointerInObject
4065##...sltu $at,$t0,$s1
4069##...bne $at,$zero,3908

4072:  gcTestIterDone2:
4072#    bltu $t0,$s3,gcHeapCopyLoop
4073##...sltu $at,$t0,$s3
4077##...bne $at,$zero,3792

    ###### end outer loop to copy all non-stack-direct objects ######

4080:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4080#    lw $s2,($sp)
4084#    addu $sp,$sp,4

    # mark us as having already GC'd
4088#    move $t5,$s5

    # go try and allocate again
4092#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4096:vm_init:

    # mark bottom of stack
4096#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4100#    move $s2,$zero

    #set up the "five" register
4104#    li $s5,5

4108#    la $s3,seg0_start
4112#    la $s4,seg0_end
4113##...lui $s4,16
4117##...addiu $s4,$s4,4924
    
    # return
4120#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4124:divide:
    # get parameters; abort if divisor zero
4124#    lw $t0,($sp)
4128#    lw $t1,8($sp)
4132#    beq $t0,$zero,divByZeroError
    
    # perform division
4136#    div $t1,$t0
4140#    mflo $t0

    # store result, adjust stack and return
4144#    addu $sp,$sp,8 # adjust stack
4148#    sw $t0,($sp) # store result
4152#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4156:remainder:
    # get parameters; abort if divisor zero
4156#    lw $t0,($sp)
4160#    lw $t1,8($sp)
4164#    beq $t0,$zero,divByZeroError
    
    # perform division
4168#    div $t1,$t0
4172#    mfhi $t0

    # store result, adjust stack and return
4176#    addu $sp,$sp,8 # adjust stack
4180#    sw $t0,($sp) # store result
4184#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4188:checkCast:
    # get object, allow immediately if null
4188#    lw $t2,($sp)
4192#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4196#    lw $t2,-12($t2) # vtable address
4200#    bge $t2,$t1,castException
4201##...slt $at,$t2,$t1
4205##...beq $at,$zero,4340
4208#    blt $t2,$t0,castException
4209##...slt $at,$t2,$t0
4213##...bne $at,$zero,4340
    
    # return, leaving object unchanged on stack
4216:  checkCastReturn:    
4216#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4220:instanceOf:
    # get object, go return false if null
4220#    lw $t2,($sp)
4224#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4228#    lw $t2,-12($t2) # vtable address
4232#    sge $t0,$t2,$t0 # are we >= the lower limit?
4233##...slt $t0,$t2,$t0
4237##...xori $t0,$t0,0x1
4240#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4244#    and $t2,$t0,$t1
4248#    sw $t2,($sp)
4252:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4252#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4256:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4256#    li $v0,4 # syscall-code for print-string
4260#    syscall
4264:exit:
    # print termination message
4264#    li $v0,4 # syscall-code for print-string
4268#    la $a0,exitString
4272#    syscall

    # terminate execution
4276#    li $v0,10 #syscall-code for "exit"
4280#    syscall

4284:outOfHeapMemory:
4284#    la $a0,heapMemoryMsg
4288#    j exitError
4292:divByZeroError:
4292#    la $a0,divByZeroMsg
4296#    j exitError
4300:strIndexOutOfBounds:
4300#    la $a0,strIndexOutOfBoundsMsg
4304#    j exitError
4308:arrayIndexOutOfBounds:
4308#    la $a0,arrayIndexOutOfBoundsMsg
4312#    j exitError
4316:arraySizeOutOfBounds:
4316#    la $a0,arraySizeOutOfBoundsMsg
4320#    j exitError
4324:nullPtrException:
4324#    la $a0,nullPtrExceptionMsg
4328#    j exitError
4332:badIntegerFormat:
4332#    la $a0,badIntegerFormatMsg
4336#    j exitError
4340:castException:
4340#    la $a0,castExceptionMsg
4344#    j exitError
############## data section ################
    .data
4560:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4576:cur_seg:
    .word 0

4580:lastCharRead:
    .word -2 # -2 => no buffered character
4584:prevHashConstant:
    .word 0x2785173c
4588:gcCount:
    .word 0

4592:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4619:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4642:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4677:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4711:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4744:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4775:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4823:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4844:gcMsg: 
      .asciiz "\nGC!\n"
4850:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4882:nullStr:
    .asciiz "null"
4887:trueString:
    .asciiz "true"
4892:falseString:
    .asciiz "false"
4898:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4917:newlineString:
    .asciiz "\n"
    
    .align 2
4920:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4924:seg0_start:
    .space 0x100000
1053500:seg0_end:
1053500:seg1_start:
    .space 0x100000
2102076:seg1_end:

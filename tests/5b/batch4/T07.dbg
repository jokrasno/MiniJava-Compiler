###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1752:mth_readLine_Lib:
    
1752#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1756#    sw $ra, 4($sp) # save $ra
1760#    move $t1,$sp # save "original" sp

1764:  doRead:

    # read the character
1764#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1768#    subu $t2,$v0,13
1772#    bne $t2,$zero,notReturnRL
1776#    jal readLogicalChar
1780#    subu $t2,$v0,10 # check for newline
1784#    beq $t2,$zero,foundNewLine
1788#    sw $v0,lastCharRead # push back character into queue
1792#    j foundNewLine # go process the line

1796:  notReturnRL:

    # at this point, $v0 has our character

1796#    subu $t0,$v0,10
1800#    beq $t0,$zero,foundNewLine
1804#    blt $v0,$zero,foundEof
1805##...slt $at,$v0,$zero
1809##...bne $at,$zero,1824

    # we have a character, so push it onto stack
1812#    subu $sp,$sp,4
1816#    sw $v0,($sp)

    # loop back up to get next character
1820#    j doRead

1824:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1824#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1828#    li $s7, 0 # return-value: null
1832#    j rlReturn # return

1836:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1836#    subu $t0,$t1,$sp # number of chars we read (times 4)
1840#    srl $s6,$t0,2 # number of words on stack with chars
1844#    subu $sp,$sp,4 # push char-count ...
1848#    sw $s6,($sp) # ... onto stack
1852#    addu $t2,$t0,5 # GC tag, incl. for count-word
1856#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1860#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1864#    srl $s6,$s6,2  # data words in object
1868#    move $s7,$zero # object words in object
1872#    jal newObject  # allocate space
    
    # store header words
1876#    la $t0,CLASS_String
1880#    sw $t0,-12($s7)# store class tag (String) into object
1884#    lw $t2,4($sp) # char-count
1888#    sll $t1,$t2,2 # 4 times number of chars
1892#    subu $t2,$zero,$t2 # negative of char-count
1896#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1900#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1904#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1905##...slt $at,$t0,$zero
1909##...beq $at,$zero,1928
1912#    and $t0,0xff # mask off object's hash value ...
1913##...lui $at,0
1917##...ori $at,$at,0xff
1921##...and $t0,$t0,$at
1924#    sw $t0,-8($s7) # ... and store back into -8 header-word
1928:  skipMask_readLine:

1928#    sll $t0,$t0,2 # data bytes in object
1932#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1936#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1940#    addu $sp,$sp,8 # pop redundant object-pointer and count
1944#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1948#    beq $sp,$t1,rlReturn
1952:  charCopyLoop:
1952#    lw $t2,($sp)
1956#    sb $t2,-9($t0)
1960#    addu $sp,$sp,4
1964#    subu $t0,$t0,1
1968#    bne $sp,$t1,charCopyLoop
1972:  rlReturn:

1972#    lw $ra, 4($sp)
1976#    addu $sp, 8   # pop $ra and pointless word off stack
1980#    move $t0, $s7 # return string we allocated in $s7
1984#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1988:mth_readInt_Lib:

    # save $ra by pushing onto stack
1988#    subu $sp,$sp,4
1992#    sw $ra,($sp)

1996:  riSkipWhiteLoop:
    # read a character
1996#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2000#    subu $t0,$v0,32
2004#    bgt $t0,$zero,nonWhite
2005##...slt $at,$zero,$t0
2009##...bne $at,$zero,2052
2012#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2016#    subu $t0,$v0,10
2020#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2024#    subu $t0,$v0,9
2028#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2032#    subu $t0,$v0,13
2036#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2040#    subu $t0,$v0,12
2044#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2048#    j badIntegerFormat # illegal integer char: abort program

2052:  nonWhite:
2052#    subu $t0,$v0,'-'
2056#    li $t4,1 # final multiplier
2060#    bne $t0,$zero,helpReadInt # go read
2064#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2068#    jal readLogicalChar

2072:  helpReadInt:
2072#    li $t2,10
2076#    subu $t1,$v0,'0' # convert digit to 0-9 value
2080#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2081##...sltu $at,$t1,$t2
2085##...beq $at,$zero,4332
2088#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2092:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2092#    jal readLogicalChar # read next character
2096#    subu $t1,$v0,'0' # convert digit to 0-9 value
2100#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2101##...sltu $at,$t1,$t2
2105##...beq $at,$zero,2124

2108#    mul $t3,$t3,$t2 # multiply old value by 10
2109##...mult $t3,$t2
2113##...mflo $t3
2116#    addu $t3,$t3,$t1 # add in value of new digit
2120#    j digitLoop

2124:  doneDigitLoop:

    # "push back" unused character into queue
2124#    sw $v0,lastCharRead

    # restore return address
2128#    lw $ra,($sp)
2132#    addu $sp, 4

    # multiply by sign and put return value in $t0
2136#    mult $t3,$t4 # multiply to account for poss. minus sign
2140#    mflo $t3
2144#    move $t0, $t3
    
    # return
2148#    jr $ra

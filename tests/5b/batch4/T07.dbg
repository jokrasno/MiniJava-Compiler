1641##...slt $at,$t0,$t2
1645##...bne $at,$zero,1620

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1648#    addu $sp,28
1652#    lw $ra,($sp)
1656#    addu $sp,4
1660#    move $t0, $s7 # return string we created
1664#    jr $ra

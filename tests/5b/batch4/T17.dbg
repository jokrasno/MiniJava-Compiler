14660#    lw $s0,($t4)
14664#    lw $t9,-8($t1)
14668#    sw $t9,($t4)
14672#    sw $s0,-8($t1)

    # copy all source bytes to the target
14676:  gCinnerCopy2:
14676#    lw $s0,($t4)
14680#    sw $s0,($s3)
14684#    addu $t4,$t4,4
14688#    addu $s3,$s3,4
14692#    bltu $t4,$t3,gCinnerCopy2
14693##...sltu $at,$t4,$t3
14697##...bne $at,$zero,14676

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
14700#    sw $zero,-8($t1) # 0 in first header-slot
14704#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
14708#    sw $t8,($t0)

14712:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
14712#    addu $t0,$t0,4
14716#    bltu $t0,$s1,gcNextPointerInObject
14717##...sltu $at,$t0,$s1
14721##...bne $at,$zero,14560

14724:  gcTestIterDone2:
14724#    bltu $t0,$s3,gcHeapCopyLoop
14725##...sltu $at,$t0,$s3
14729##...bne $at,$zero,14444

    ###### end outer loop to copy all non-stack-direct objects ######

14732:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
14732#    lw $s2,($sp)
14736#    addu $sp,$sp,4

    # mark us as having already GC'd
14740#    move $t5,$s5

    # go try and allocate again
14744#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
14748:vm_init:

    # mark bottom of stack
14748#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
14752#    move $s2,$zero

    #set up the "five" register
14756#    li $s5,5

14760#    la $s3,seg0_start
14764#    la $s4,seg0_end
14765##...lui $s4,16
14769##...addiu $s4,$s4,15708
    
    # return
14772#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
14776:divide:
    # get parameters; abort if divisor zero
14776#    lw $t0,($sp)
14780#    lw $t1,8($sp)
14784#    beq $t0,$zero,divByZeroError
    
    # perform division
14788#    div $t1,$t0
14792#    mflo $t0

    # store result, adjust stack and return
14796#    addu $sp,$sp,8 # adjust stack
14800#    sw $t0,($sp) # store result
14804#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
14808:remainder:
    # get parameters; abort if divisor zero
14808#    lw $t0,($sp)
14812#    lw $t1,8($sp)
14816#    beq $t0,$zero,divByZeroError
    
    # perform division
14820#    div $t1,$t0
14824#    mfhi $t0

    # store result, adjust stack and return
14828#    addu $sp,$sp,8 # adjust stack
14832#    sw $t0,($sp) # store result
14836#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
14840:checkCast:
    # get object, allow immediately if null
14840#    lw $t2,($sp)
14844#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
14848#    lw $t2,-12($t2) # vtable address
14852#    bge $t2,$t1,castException
14853##...slt $at,$t2,$t1
14857##...beq $at,$zero,14992
14860#    blt $t2,$t0,castException
14861##...slt $at,$t2,$t0
14865##...bne $at,$zero,14992
    
    # return, leaving object unchanged on stack
14868:  checkCastReturn:    
14868#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
14872:instanceOf:
    # get object, go return false if null
14872#    lw $t2,($sp)
14876#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
14880#    lw $t2,-12($t2) # vtable address
14884#    sge $t0,$t2,$t0 # are we >= the lower limit?
14885##...slt $t0,$t2,$t0
14889##...xori $t0,$t0,0x1
14892#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
14896#    and $t2,$t0,$t1
14900#    sw $t2,($sp)
14904:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
14904#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

14908:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
14908#    li $v0,4 # syscall-code for print-string
14912#    syscall
14916:exit:
    # print termination message
14916#    li $v0,4 # syscall-code for print-string
14920#    la $a0,exitString
14924#    syscall

    # terminate execution
14928#    li $v0,10 #syscall-code for "exit"
14932#    syscall

14936:outOfHeapMemory:
14936#    la $a0,heapMemoryMsg
14940#    j exitError
14944:divByZeroError:
14944#    la $a0,divByZeroMsg
14948#    j exitError
14952:strIndexOutOfBounds:
14952#    la $a0,strIndexOutOfBoundsMsg
14956#    j exitError
14960:arrayIndexOutOfBounds:
14960#    la $a0,arrayIndexOutOfBoundsMsg
14964#    j exitError
14968:arraySizeOutOfBounds:
14968#    la $a0,arraySizeOutOfBoundsMsg
14972#    j exitError
14976:nullPtrException:
14976#    la $a0,nullPtrExceptionMsg
14980#    j exitError
14984:badIntegerFormat:
14984#    la $a0,badIntegerFormatMsg
14988#    j exitError
14992:castException:
14992#    la $a0,castExceptionMsg
14996#    j exitError
############## data section ################
    .data
15344:hexChars:
    .ascii "0123456789abcdef"
    .align 2
15360:cur_seg:
    .word 0

15364:lastCharRead:
    .word -2 # -2 => no buffered character
15368:prevHashConstant:
    .word 0x2785173c
15372:gcCount:
    .word 0

15376:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
15403:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
15426:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
15461:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
15495:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
15528:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
15559:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
15607:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
15628:gcMsg: 
      .asciiz "\nGC!\n"
15634:gcCountMsg: 
      .asciiz "Number of garbage collections: "

15666:nullStr:
    .asciiz "null"
15671:trueString:
    .asciiz "true"
15676:falseString:
    .asciiz "false"
15682:exitString:
    .ascii "Program terminated."
    #### "falls through" here
15701:newlineString:
    .asciiz "\n"
    
    .align 2
15704:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

15708:seg0_start:
    .space 0x100000
1064284:seg0_end:
1064284:seg1_start:
    .space 0x100000
2112860:seg1_end:

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
11896:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
11896#    lw $t0,-8($s2) # get word with hash bits from this
11900#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
11904#    addu $t0,$t1

11908#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
11912:mth_equals_Object:
11912#    move $t0,$s2 # first pointer (this)
11916#    lw $t1,($sp) # second pointer
11920#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
11921##...subu $at,$t0,$t1
11925##...sltiu $t0,$at,1

11928#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
11932:mth_hashCode_String:
11932#    move $t0,$s2 # put this pointer in t0

11936#    li $t2,0 # current hash value
11940#    lw $t1,-4($t0) # negative of number of characters in string
11944#    beq $t1,$zero,done_hashCode_String # if zero length => done
11948#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
11952#    and $t0,0xfffffffc # adjust for padding
11953##...lui $at,65535
11957##...ori $at,$at,0xfffc
11961##...and $t0,$t0,$at
11964#    subu $t1,$t0,$t1 # address at end of string +12
11968:loop_hashCode_String:    
11968#    sll $t4,$t2,5 # multiply by 32
11972#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
11976#    lbu $t3,-12($t0) # current character
11980#    addu $t2,$t3 # add in current character
11984#    addu $t0,1 # go to next character's address
11988#    bne $t0,$t1,loop_hashCode_String # loop back if more
11992:done_hashCode_String:    

    # push int on stack
11992#    move $t0, $t2 # put $t2 in return slot
11996#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
12000:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
12000#    subu $sp,4
12004#    sw $ra,($sp)
    
    # get hash value
12008#    lw $t2,-12($s2) # vtable address
12012#    lw $t0,($t2) # method address
12016#    jalr $t0
12020#    subu $sp,8 # push result (int in $t0) on stack
12024#    sw $s5,4($sp)
12028#    sw $t0,($sp)

    # compute print-size of hash value
12032#    li $t0, 1
12036#    lw $t1, ($sp)
12040#    srl $t1,$t1,4
12044#    beq $t1,$zero,toString_skip_loop
12048:toString_loop_top:
12048#    addu $t0,1
12052#    srl $t1,$t1,4
12056#    bne $t1,$zero,toString_loop_top
12060:toString_skip_loop:
12060#    subu $sp,8
12064#    sw $s5,4($sp)
12068#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
12072#    lw $t2,-12($s2) # vtable address
12076#    move $t0,$t2
12080:toString_checkTagBit:
12080#    subu $t0,1
12084#    lb $t1,($t0)
12088#    and $t1,0x80
12089##...lui $at,0
12093##...ori $at,$at,0x80
12097##...and $t1,$t1,$at
12100#    beq $t1,$zero,toString_checkTagBit
12104#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
12108#    subu $sp,8
12112#    sw $t1,($sp)
12116#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
12120#    move $s7,$zero # -4 offset header word
12124#    lw $t4,8($sp) # bytes for hash value
12128#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
12132#    addu $t4,8
12136#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
12140#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

12144#    li $t0,CLASS_String # store string vtable address into ...
12148#    sw $t0,-12($s7) # ... -12 offset in object header
12152#    lw $t2,-12($s2) # our object's vtable address
12156#    lw $t5,4($sp) # number characters in prefix
12160#    lw $t1,12($sp) # number of characters in hashcode
12164#    addu $t3,$t1,$t5 # number of characters in string ...
12168#    addu $t3,1 # ... including the '@' character
12172#    subu $t0,$zero,$t3 # store negated length into ...
12176#    sw $t0,-4($s7) # ... -4 offset header word
12180#    lw $t0,-8($s7) # get -8 offset header-word
12184#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
12185##...slt $at,$t0,$zero
12189##...beq $at,$zero,12208
12192#    and $t0,0xff # mask off object's hash value ...
12193##...lui $at,0
12197##...ori $at,$at,0xff
12201##...and $t0,$t0,$at
12204#    sw $t0,-8($s7) # ... and store back into -8 header-word
12208:skipMask_toString:
12208#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
12212#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
12216#    subu $t4,$t2,$t5
12220:toString_copyLoop:    
12220#    lb $t3,($t4)
12224#    and $t3,0x7f # mask off sign bit (in case first word)
12225##...lui $at,0
12229##...ori $at,$at,0x7f
12233##...and $t3,$t3,$at
12236#    sb $t3,-8($t0)
12240#    addu $t4,1
12244#    addu $t0,1
12248#    blt $t4,$t2,toString_copyLoop

12600#    beq $sp,$t1,rlReturn
12604:  charCopyLoop:
12604#    lw $t2,($sp)
12608#    sb $t2,-9($t0)
12612#    addu $sp,$sp,4
12616#    subu $t0,$t0,1
12620#    bne $sp,$t1,charCopyLoop
12624:  rlReturn:

12624#    lw $ra, 4($sp)
12628#    addu $sp, 8   # pop $ra and pointless word off stack
12632#    move $t0, $s7 # return string we allocated in $s7
12636#    jr $ra

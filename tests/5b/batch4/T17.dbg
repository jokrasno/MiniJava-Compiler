###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
12404:mth_readLine_Lib:
    
12404#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
12408#    sw $ra, 4($sp) # save $ra
12412#    move $t1,$sp # save "original" sp

12416:  doRead:

    # read the character
12416#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
12420#    subu $t2,$v0,13
12424#    bne $t2,$zero,notReturnRL
12428#    jal readLogicalChar
12432#    subu $t2,$v0,10 # check for newline
12436#    beq $t2,$zero,foundNewLine
12440#    sw $v0,lastCharRead # push back character into queue
12444#    j foundNewLine # go process the line

12448:  notReturnRL:

    # at this point, $v0 has our character

12448#    subu $t0,$v0,10
12452#    beq $t0,$zero,foundNewLine
12456#    blt $v0,$zero,foundEof
12457##...slt $at,$v0,$zero
12461##...bne $at,$zero,12476

    # we have a character, so push it onto stack
12464#    subu $sp,$sp,4
12468#    sw $v0,($sp)

    # loop back up to get next character
12472#    j doRead

12476:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
12476#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
12480#    li $s7, 0 # return-value: null
12484#    j rlReturn # return

12488:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
12488#    subu $t0,$t1,$sp # number of chars we read (times 4)
12492#    srl $s6,$t0,2 # number of words on stack with chars
12496#    subu $sp,$sp,4 # push char-count ...
12500#    sw $s6,($sp) # ... onto stack
12504#    addu $t2,$t0,5 # GC tag, incl. for count-word
12508#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
12512#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
12516#    srl $s6,$s6,2  # data words in object
12520#    move $s7,$zero # object words in object
12524#    jal newObject  # allocate space
    
    # store header words
12528#    la $t0,CLASS_String
12532#    sw $t0,-12($s7)# store class tag (String) into object
12536#    lw $t2,4($sp) # char-count
12540#    sll $t1,$t2,2 # 4 times number of chars
12544#    subu $t2,$zero,$t2 # negative of char-count
12548#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
12552#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
12556#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
12557##...slt $at,$t0,$zero
12561##...beq $at,$zero,12580
12564#    and $t0,0xff # mask off object's hash value ...
12565##...lui $at,0
12569##...ori $at,$at,0xff
12573##...and $t0,$t0,$at
12576#    sw $t0,-8($s7) # ... and store back into -8 header-word
12580:  skipMask_readLine:

12580#    sll $t0,$t0,2 # data bytes in object
12584#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
12588#    subu $t0,$t0,$t2 # place to store last character (plus 9)
12592#    addu $sp,$sp,8 # pop redundant object-pointer and count
12596#    addu $t1,$t1,$sp # first non-char spot on stack

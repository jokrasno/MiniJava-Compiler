    # return value is 1 iff result is 0; else 0
12368#    seq $t0,$t0,$zero
12369##...subu $at,$t0,$zero
12373##...sltiu $t0,$at,1

    # pop return address and return $t0
12376#    lw $ra,($sp)
12380#    addu $sp,4

12384#    jr $ra # return
    
12388:goEsFalse:
    # put 0 in $t0 and return
12388#    li $t0, 0
12392#    jr $ra # return

12661##...bne $at,$zero,12704
12664#    beq $t0,$zero,riSkipWhiteLoop # start over if space
12668#    subu $t0,$v0,10
12672#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
12676#    subu $t0,$v0,9
12680#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
12684#    subu $t0,$v0,13
12688#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
12692#    subu $t0,$v0,12
12696#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
12700#    j badIntegerFormat # illegal integer char: abort program

12704:  nonWhite:
12704#    subu $t0,$v0,'-'
12708#    li $t4,1 # final multiplier
12712#    bne $t0,$zero,helpReadInt # go read
12716#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
12720#    jal readLogicalChar

12724:  helpReadInt:
12724#    li $t2,10
12728#    subu $t1,$v0,'0' # convert digit to 0-9 value
12732#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
12733##...sltu $at,$t1,$t2
12737##...beq $at,$zero,14984
12740#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

12744:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

12744#    jal readLogicalChar # read next character
12748#    subu $t1,$v0,'0' # convert digit to 0-9 value
12752#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
12753##...sltu $at,$t1,$t2
12757##...beq $at,$zero,12776

12760#    mul $t3,$t3,$t2 # multiply old value by 10
12761##...mult $t3,$t2
12765##...mflo $t3
12768#    addu $t3,$t3,$t1 # add in value of new digit
12772#    j digitLoop

12776:  doneDigitLoop:

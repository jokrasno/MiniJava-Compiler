1853##...ori $at,$at,0xffff
1857##...and $t1,$t1,$at
1860:skipPrintStr2:    
1860#    sll $t1,$t1,2
1864#    subu $t1,$t0,$t1 # first word in string
1868#    lw $t0,4($t0) # negative of string-length
1872#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
1876#    beq $t0,$t1,donePrintStr
1880:  psLoop:
1880#    lb $a0,($t1) # next byte

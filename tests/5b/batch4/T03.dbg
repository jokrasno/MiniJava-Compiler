###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1364:mth_readLine_Lib:
    
1364#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1368#    sw $ra, 4($sp) # save $ra
1372#    move $t1,$sp # save "original" sp

1376:  doRead:

    # read the character
1376#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1380#    subu $t2,$v0,13
1384#    bne $t2,$zero,notReturnRL
1388#    jal readLogicalChar
1392#    subu $t2,$v0,10 # check for newline
1396#    beq $t2,$zero,foundNewLine
1400#    sw $v0,lastCharRead # push back character into queue
1404#    j foundNewLine # go process the line

1408:  notReturnRL:

    # at this point, $v0 has our character

1408#    subu $t0,$v0,10
1412#    beq $t0,$zero,foundNewLine
1416#    blt $v0,$zero,foundEof
1417##...slt $at,$v0,$zero
1421##...bne $at,$zero,1436

    # we have a character, so push it onto stack
1424#    subu $sp,$sp,4
1428#    sw $v0,($sp)

    # loop back up to get next character
1432#    j doRead

1436:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1436#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1440#    li $s7, 0 # return-value: null
1444#    j rlReturn # return

1448:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1448#    subu $t0,$t1,$sp # number of chars we read (times 4)
1452#    srl $s6,$t0,2 # number of words on stack with chars
1456#    subu $sp,$sp,4 # push char-count ...
1460#    sw $s6,($sp) # ... onto stack
1464#    addu $t2,$t0,5 # GC tag, incl. for count-word
1468#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1472#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1476#    srl $s6,$s6,2  # data words in object
1480#    move $s7,$zero # object words in object
1484#    jal newObject  # allocate space
    
    # store header words
1488#    la $t0,CLASS_String
1492#    sw $t0,-12($s7)# store class tag (String) into object
1496#    lw $t2,4($sp) # char-count
1500#    sll $t1,$t2,2 # 4 times number of chars
1504#    subu $t2,$zero,$t2 # negative of char-count
1508#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1512#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1516#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1517##...slt $at,$t0,$zero
1521##...beq $at,$zero,1540
1524#    and $t0,0xff # mask off object's hash value ...
1525##...lui $at,0
1529##...ori $at,$at,0xff
1533##...and $t0,$t0,$at
1536#    sw $t0,-8($s7) # ... and store back into -8 header-word
1540:  skipMask_readLine:

1540#    sll $t0,$t0,2 # data bytes in object
1544#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1548#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1552#    addu $sp,$sp,8 # pop redundant object-pointer and count
1556#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1560#    beq $sp,$t1,rlReturn
1564:  charCopyLoop:
1564#    lw $t2,($sp)
1568#    sb $t2,-9($t0)
1572#    addu $sp,$sp,4
1576#    subu $t0,$t0,1
1580#    bne $sp,$t1,charCopyLoop
1584:  rlReturn:

1584#    lw $ra, 4($sp)
1588#    addu $sp, 8   # pop $ra and pointless word off stack
1592#    move $t0, $s7 # return string we allocated in $s7
1596#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1600:mth_readInt_Lib:

    # save $ra by pushing onto stack
1600#    subu $sp,$sp,4
1604#    sw $ra,($sp)

1608:  riSkipWhiteLoop:
    # read a character
1608#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1612#    subu $t0,$v0,32
1616#    bgt $t0,$zero,nonWhite
1617##...slt $at,$zero,$t0
1621##...bne $at,$zero,1664
1624#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1628#    subu $t0,$v0,10
1632#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1636#    subu $t0,$v0,9
1640#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1644#    subu $t0,$v0,13
1648#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1652#    subu $t0,$v0,12
1656#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1660#    j badIntegerFormat # illegal integer char: abort program

1664:  nonWhite:
1664#    subu $t0,$v0,'-'
1668#    li $t4,1 # final multiplier
1672#    bne $t0,$zero,helpReadInt # go read
1676#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1680#    jal readLogicalChar

1684:  helpReadInt:
1684#    li $t2,10
1688#    subu $t1,$v0,'0' # convert digit to 0-9 value
1692#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1693##...sltu $at,$t1,$t2
1697##...beq $at,$zero,3944
1700#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1704:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1704#    jal readLogicalChar # read next character
1708#    subu $t1,$v0,'0' # convert digit to 0-9 value
1712#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1713##...sltu $at,$t1,$t2
1717##...beq $at,$zero,1736

1720#    mul $t3,$t3,$t2 # multiply old value by 10
1721##...mult $t3,$t2
1725##...mflo $t3
1728#    addu $t3,$t3,$t1 # add in value of new digit
1732#    j digitLoop

1736:  doneDigitLoop:

    # "push back" unused character into queue
1736#    sw $v0,lastCharRead

    # restore return address
1740#    lw $ra,($sp)
1744#    addu $sp, 4

    # multiply by sign and put return value in $t0
1748#    mult $t3,$t4 # multiply to account for poss. minus sign
1752#    mflo $t3
1756#    move $t0, $t3
    
    # return
1760#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1764:mth_readChar_Lib:

    # save $ra by pushing onto stack
1764#    subu $sp,$sp,4
1768#    sw $ra,($sp)

      # read the character
1772#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1776#    lw $ra,($sp)
1780#    addu $sp, 4
1784#    move $t0, $v0

    # return
1788#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
1792:mth_printStr_Lib:
    # check for null, printing "(null)", if so
1792#    lw $t0,($sp)
1796#    bne $t0,$zero,psNotNull

    # print "(null)"
1800#    la $a0,nullStr
1804#    li $v0,4
1808#    syscall
1812#    j donePrintStr
    
1816:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
1816#    subu $t0,$t0,8
1820#    lw $t1,($t0) # number of data words, but needs modification
1824#    blt $t1,$zero,skipPrintStr1

    # via the forwarding pointer
3540#    lw $t8,-8($t1) # possible forwarding tag
3544#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
3548#    lw $t8,-4($t1) # forwarding pointer: object's new address
3552#    sw $t8,($t0) # update pointer in object
3556#    j gcGoNextPointerSlot # do next iteration

3560:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3560#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3561##...slt $at,$t8,$zero
3565##...beq $at,$zero,3580
3568#    and $t8,0xff # mask off hash bits
3569##...lui $at,0
3573##...ori $at,$at,0xff
3577##...and $t8,$t8,$at

3580:  gcSkip5:
3580#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3584#    addu $t8,$t8,8 # ... add in bytes for header-words
3588#    subu $t4,$t1,$t8 # address of first word of source object
3592#    lw $t3,-4($t1) # # words in positive-offset portion
3596#    bge $t3,$zero,gcNoNeg
3597##...slt $at,$t3,$zero
3601##...beq $at,$zero,3608
3604#    move $t3,$zero # negative treated as zero
3608:  gcNoNeg:
3608#    sll $t3,$t3,2 # bytes in negative-offset portion
3612#    addu $t3,$t3,$t1 # address one word past last word of source

3616#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3620#    lw $s0,($t4)
3624#    lw $t9,-8($t1)
3628#    sw $t9,($t4)
3632#    sw $s0,-8($t1)

    # copy all source bytes to the target
3636:  gCinnerCopy2:
3636#    lw $s0,($t4)
3640#    sw $s0,($s3)
3644#    addu $t4,$t4,4
3648#    addu $s3,$s3,4
3652#    bltu $t4,$t3,gCinnerCopy2
3653##...sltu $at,$t4,$t3
3657##...bne $at,$zero,3636

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3660#    sw $zero,-8($t1) # 0 in first header-slot
3664#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3668#    sw $t8,($t0)

3672:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3672#    addu $t0,$t0,4
3676#    bltu $t0,$s1,gcNextPointerInObject
3677##...sltu $at,$t0,$s1
3681##...bne $at,$zero,3520

3684:  gcTestIterDone2:
3684#    bltu $t0,$s3,gcHeapCopyLoop
3685##...sltu $at,$t0,$s3
3689##...bne $at,$zero,3404

    ###### end outer loop to copy all non-stack-direct objects ######

3692:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3692#    lw $s2,($sp)
3696#    addu $sp,$sp,4

    # mark us as having already GC'd
3700#    move $t5,$s5

    # go try and allocate again
3704#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3708:vm_init:

    # mark bottom of stack
3708#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3712#    move $s2,$zero

    #set up the "five" register
3716#    li $s5,5

3720#    la $s3,seg0_start
3724#    la $s4,seg0_end
3725##...lui $s4,16
3729##...addiu $s4,$s4,4612
    
    # return
3732#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3736:divide:
    # get parameters; abort if divisor zero
3736#    lw $t0,($sp)
3740#    lw $t1,8($sp)
3744#    beq $t0,$zero,divByZeroError
    
    # perform division
3748#    div $t1,$t0
3752#    mflo $t0

    # store result, adjust stack and return
3756#    addu $sp,$sp,8 # adjust stack
3760#    sw $t0,($sp) # store result
3764#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3768:remainder:
    # get parameters; abort if divisor zero
3768#    lw $t0,($sp)
3772#    lw $t1,8($sp)
3776#    beq $t0,$zero,divByZeroError
    
    # perform division
3780#    div $t1,$t0
3784#    mfhi $t0

    # store result, adjust stack and return
3788#    addu $sp,$sp,8 # adjust stack
3792#    sw $t0,($sp) # store result
3796#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3800:checkCast:
    # get object, allow immediately if null
3800#    lw $t2,($sp)
3804#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3808#    lw $t2,-12($t2) # vtable address
3812#    bge $t2,$t1,castException
3813##...slt $at,$t2,$t1
3817##...beq $at,$zero,3952
3820#    blt $t2,$t0,castException
3821##...slt $at,$t2,$t0
3825##...bne $at,$zero,3952
    
    # return, leaving object unchanged on stack
3828:  checkCastReturn:    
3828#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3832:instanceOf:
    # get object, go return false if null
3832#    lw $t2,($sp)
3836#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3840#    lw $t2,-12($t2) # vtable address
3844#    sge $t0,$t2,$t0 # are we >= the lower limit?
3845##...slt $t0,$t2,$t0
3849##...xori $t0,$t0,0x1
3852#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3856#    and $t2,$t0,$t1
3860#    sw $t2,($sp)
3864:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3864#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3868:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3868#    li $v0,4 # syscall-code for print-string
3872#    syscall
3876:exit:
    # print termination message
3876#    li $v0,4 # syscall-code for print-string
3880#    la $a0,exitString
3884#    syscall

    # terminate execution
3888#    li $v0,10 #syscall-code for "exit"
3892#    syscall

3896:outOfHeapMemory:
3896#    la $a0,heapMemoryMsg
3900#    j exitError
3904:divByZeroError:
3904#    la $a0,divByZeroMsg
3908#    j exitError
3912:strIndexOutOfBounds:
3912#    la $a0,strIndexOutOfBoundsMsg
3916#    j exitError
3920:arrayIndexOutOfBounds:
3920#    la $a0,arrayIndexOutOfBoundsMsg
3924#    j exitError
3928:arraySizeOutOfBounds:
3928#    la $a0,arraySizeOutOfBoundsMsg
3932#    j exitError
3936:nullPtrException:
3936#    la $a0,nullPtrExceptionMsg
3940#    j exitError
3944:badIntegerFormat:
3944#    la $a0,badIntegerFormatMsg
3948#    j exitError
3952:castException:
3952#    la $a0,castExceptionMsg
3956#    j exitError
############## data section ################
    .data
4248:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4264:cur_seg:
    .word 0

4268:lastCharRead:
    .word -2 # -2 => no buffered character
4272:prevHashConstant:
    .word 0x2785173c
4276:gcCount:
    .word 0

4280:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4307:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4330:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4365:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4399:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4432:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4463:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4511:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4532:gcMsg: 
      .asciiz "\nGC!\n"
4538:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4570:nullStr:
    .asciiz "null"
4575:trueString:
    .asciiz "true"
4580:falseString:
    .asciiz "false"
4586:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4605:newlineString:
    .asciiz "\n"
    
    .align 2
4608:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4612:seg0_start:
    .space 0x100000
1053188:seg0_end:
1053188:seg1_start:
    .space 0x100000
2101764:seg1_end:

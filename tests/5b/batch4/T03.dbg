###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1280:mth_equals_String:
    
    # quick test for obvious false
1280#    lw $t0,($sp) # second parameter
1284#    beq $t0,$zero,goEsFalse # go return false if null
1288#    lw $t1,-12($t0) # vtable pointer
1292#    la $t2,CLASS_String # string vtable pointer
1296#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1300#    subu $sp,12
1304#    sw $ra,8($sp)
1308#    sw $s2,4($sp)
1312#    sw $t0,($sp)
1316#    jal mth_compareTo_String
1320#    lw $s2, 4($sp) #restore this pointer and pop parameters
1324#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1328#    seq $t0,$t0,$zero
1329##...subu $at,$t0,$zero
1333##...sltiu $t0,$at,1

    # pop return address and return $t0
1336#    lw $ra,($sp)
1340#    addu $sp,4

1344#    jr $ra # return
    
1348:goEsFalse:
    # put 0 in $t0 and return
1348#    li $t0, 0
1352#    jr $ra # return

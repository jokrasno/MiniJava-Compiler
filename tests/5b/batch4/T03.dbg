##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
856:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
856#    lw $t0,-8($s2) # get word with hash bits from this
860#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
864#    addu $t0,$t1

868#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
872:mth_equals_Object:
872#    move $t0,$s2 # first pointer (this)
876#    lw $t1,($sp) # second pointer
880#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
881##...subu $at,$t0,$t1
885##...sltiu $t0,$at,1

888#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
892:mth_hashCode_String:
892#    move $t0,$s2 # put this pointer in t0

896#    li $t2,0 # current hash value
900#    lw $t1,-4($t0) # negative of number of characters in string
904#    beq $t1,$zero,done_hashCode_String # if zero length => done
908#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
912#    and $t0,0xfffffffc # adjust for padding
913##...lui $at,65535
917##...ori $at,$at,0xfffc
921##...and $t0,$t0,$at
924#    subu $t1,$t0,$t1 # address at end of string +12
928:loop_hashCode_String:    
928#    sll $t4,$t2,5 # multiply by 32
932#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
936#    lbu $t3,-12($t0) # current character
940#    addu $t2,$t3 # add in current character
944#    addu $t0,1 # go to next character's address
948#    bne $t0,$t1,loop_hashCode_String # loop back if more
952:done_hashCode_String:    

    # push int on stack
952#    move $t0, $t2 # put $t2 in return slot
956#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
960:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
960#    subu $sp,4
964#    sw $ra,($sp)
    
    # get hash value
968#    lw $t2,-12($s2) # vtable address
972#    lw $t0,($t2) # method address
976#    jalr $t0
980#    subu $sp,8 # push result (int in $t0) on stack
984#    sw $s5,4($sp)
988#    sw $t0,($sp)

    # compute print-size of hash value
992#    li $t0, 1
996#    lw $t1, ($sp)
1000#    srl $t1,$t1,4
1004#    beq $t1,$zero,toString_skip_loop
1008:toString_loop_top:
1008#    addu $t0,1
1012#    srl $t1,$t1,4
1016#    bne $t1,$zero,toString_loop_top
1020:toString_skip_loop:
1020#    subu $sp,8
1024#    sw $s5,4($sp)
1028#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1032#    lw $t2,-12($s2) # vtable address
1036#    move $t0,$t2
1040:toString_checkTagBit:
1040#    subu $t0,1
1044#    lb $t1,($t0)
1048#    and $t1,0x80
1049##...lui $at,0
1053##...ori $at,$at,0x80
1057##...and $t1,$t1,$at
1060#    beq $t1,$zero,toString_checkTagBit
1064#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1068#    subu $sp,8
1072#    sw $t1,($sp)
1076#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1080#    move $s7,$zero # -4 offset header word
1084#    lw $t4,8($sp) # bytes for hash value
1088#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1092#    addu $t4,8
1096#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1100#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1104#    li $t0,CLASS_String # store string vtable address into ...
1108#    sw $t0,-12($s7) # ... -12 offset in object header
1112#    lw $t2,-12($s2) # our object's vtable address
1116#    lw $t5,4($sp) # number characters in prefix
1120#    lw $t1,12($sp) # number of characters in hashcode
1124#    addu $t3,$t1,$t5 # number of characters in string ...
1128#    addu $t3,1 # ... including the '@' character
1132#    subu $t0,$zero,$t3 # store negated length into ...
1136#    sw $t0,-4($s7) # ... -4 offset header word
1140#    lw $t0,-8($s7) # get -8 offset header-word
1144#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1145##...slt $at,$t0,$zero
1149##...beq $at,$zero,1168
1152#    and $t0,0xff # mask off object's hash value ...
1153##...lui $at,0
1157##...ori $at,$at,0xff
1161##...and $t0,$t0,$at
1164#    sw $t0,-8($s7) # ... and store back into -8 header-word
1168:skipMask_toString:
1168#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1172#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1176#    subu $t4,$t2,$t5
1180:toString_copyLoop:    
1180#    lb $t3,($t4)
1184#    and $t3,0x7f # mask off sign bit (in case first word)
1185##...lui $at,0
1189##...ori $at,$at,0x7f
1193##...and $t3,$t3,$at
1196#    sb $t3,-8($t0)
1200#    addu $t4,1

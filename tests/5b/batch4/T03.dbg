2972#    sw $zero,($s3)
2976#    lw $zero,($s3)

2980#    addu $s3,4
2984#    bltu $s3,$t1,zeroObjLoop
2985##...sltu $at,$s3,$t1
2989##...bne $at,$zero,2972

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object


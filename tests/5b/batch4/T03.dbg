2944#    addu $t0,$s6,$s7
2948#    sll $t0,$t0,2
2952#    addu $t0,$t0,8 # amount of memory needed
2956#    addu $t1,$t0,$s3
2960#    bgtu $t1,$s4,doGC
2961##...sltu $at,$s4,$t1
2965##...bne $at,$zero,3088

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end


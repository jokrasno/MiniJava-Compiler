6296#    li $v0,4 # syscall-code for print-string
6300#    syscall
6304:exit:
    # print termination message
6304#    li $v0,4 # syscall-code for print-string
6308#    la $a0,exitString
6312#    syscall

    # terminate execution
6316#    li $v0,10 #syscall-code for "exit"
6320#    syscall

6324:outOfHeapMemory:
6324#    la $a0,heapMemoryMsg
6328#    j exitError
6332:divByZeroError:
6332#    la $a0,divByZeroMsg
6336#    j exitError
6340:strIndexOutOfBounds:
6340#    la $a0,strIndexOutOfBoundsMsg
6344#    j exitError
6348:arrayIndexOutOfBounds:
6348#    la $a0,arrayIndexOutOfBoundsMsg
6352#    j exitError
6356:arraySizeOutOfBounds:
6356#    la $a0,arraySizeOutOfBoundsMsg
6360#    j exitError
6364:nullPtrException:
6364#    la $a0,nullPtrExceptionMsg
6368#    j exitError
6372:badIntegerFormat:
6372#    la $a0,badIntegerFormatMsg
6376#    j exitError
6380:castException:
6380#    la $a0,castExceptionMsg
6384#    j exitError
############## data section ################
    .data
6772:hexChars:
    .ascii "0123456789abcdef"
    .align 2
6788:cur_seg:
    .word 0

6792:lastCharRead:
    .word -2 # -2 => no buffered character
6796:prevHashConstant:
    .word 0x2785173c
6800:gcCount:
    .word 0

6804:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
6831:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
6854:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
6889:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
6923:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
6956:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
6987:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
7035:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
7056:gcMsg: 
      .asciiz "\nGC!\n"
7062:gcCountMsg: 
      .asciiz "Number of garbage collections: "

7094:nullStr:
    .asciiz "null"
7099:trueString:
    .asciiz "true"
7104:falseString:
    .asciiz "false"
7110:exitString:
    .ascii "Program terminated."
    #### "falls through" here
7129:newlineString:
    .asciiz "\n"
    
    .align 2
7132:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

7136:seg0_start:
    .space 0x100000
1055712:seg0_end:
1055712:seg1_start:

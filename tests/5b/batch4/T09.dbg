5161##...slt $at,$t4,$zero
5165##...beq $at,$zero,5184
5168#    and $t4,0xff # mask off object's hash value ...
5169##...lui $at,0
5173##...ori $at,$at,0xff
5177##...and $t4,$t4,$at
5180#    sw $t4,-8($s7) # ... and store back into -8 header-word
5184:  skipMask_intToChar:

    # store data in string
5184#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
5188#    li $t0,-1
5192#    sw $t0,-4($s7)

    # we're returning $s7
5196#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
5200#    lw $ra,4($sp)
5204#    addu $sp,$sp,8

    # return
5208#    jr $ra

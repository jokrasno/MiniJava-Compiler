    # get argument, negate if negative
4896#    lw $t1,8($sp)
4900#    bge $t1,$zero,itsNonNegLoop
4901##...slt $at,$t1,$zero
4905##...beq $at,$zero,4912
4908#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
4912:  itsNonNegLoop:
4912#    divu $t1,$t3
4916#    mflo $t1 # quotient
4920#    mfhi $t4 # remainder
4924#    addu $t4,$t4,'0' # turn remainder into digit
4928#    subu $sp,$sp,4
4932#    sw $t4,($sp) # push digit onto stack
4936#    bne $t1,$zero,itsNonNegLoop

5004#    lw $t0,4($sp)
5008#    addu $sp,$sp,8

    # store "String" tag into class field
5012#    subu $s7,$s7,8 # address of header-1 word
5016#    la $t1,CLASS_String
5020#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
5024#    lw $t4,($s7) # # data words in source string
5028#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
5029##...slt $at,$t4,$zero
5033##...beq $at,$zero,5052
5036#    and $t4,0xff # mask off object's hash value ...
5037##...lui $at,0
5041##...ori $at,$at,0xff
5045##...and $t4,$t4,$at
5048#    sw $t4,($s7) # ... and store back into -8 header-word
5052:skipMask_intToString:
    
    # store negative of char-count into header-2 word
5052#    subu $t0,$zero,$t0
5056#    sw $t0,4($s7)

5060#    lw $t1,($s7) # number of data words in string

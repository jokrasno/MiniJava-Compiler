4052#    beq $t0,$zero,riSkipWhiteLoop # start over if space
4056#    subu $t0,$v0,10
4060#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
4064#    subu $t0,$v0,9
4068#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
4072#    subu $t0,$v0,13
4076#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
4080#    subu $t0,$v0,12
4084#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
4088#    j badIntegerFormat # illegal integer char: abort program


6277##...xori $t0,$t0,0x1
6280#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
6284#    and $t2,$t0,$t1
6288#    sw $t2,($sp)
6292:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
6292#    jr $ra

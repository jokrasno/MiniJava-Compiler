    # write GC tag onto stack; push char-count onto stack
4964#    subu $s6,$t0,$sp
4968#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
4972#    sw $t3,($t0)
4976#    srl $s6,$s6,2
4980#    subu $sp,$sp,4
4984#    sw $s6,($sp)
    
    # allocate memory
4988#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
4992#    srl $s6,$s6,2
4996#    move $s7,$zero # no "object" words in object
5000#    jal newObject

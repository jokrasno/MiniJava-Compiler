# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3284:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
3284#    lw $t0,-8($s2) # get word with hash bits from this
3288#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
3292#    addu $t0,$t1

3296#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3300:mth_equals_Object:
3300#    move $t0,$s2 # first pointer (this)
3304#    lw $t1,($sp) # second pointer
3308#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
3309##...subu $at,$t0,$t1
3313##...sltiu $t0,$at,1

3316#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3320:mth_hashCode_String:
3320#    move $t0,$s2 # put this pointer in t0

3324#    li $t2,0 # current hash value
3328#    lw $t1,-4($t0) # negative of number of characters in string
3332#    beq $t1,$zero,done_hashCode_String # if zero length => done
3336#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
3340#    and $t0,0xfffffffc # adjust for padding
3341##...lui $at,65535
3345##...ori $at,$at,0xfffc
3349##...and $t0,$t0,$at
3352#    subu $t1,$t0,$t1 # address at end of string +12
3356:loop_hashCode_String:    
3356#    sll $t4,$t2,5 # multiply by 32
3360#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
3364#    lbu $t3,-12($t0) # current character
3368#    addu $t2,$t3 # add in current character
3372#    addu $t0,1 # go to next character's address
3376#    bne $t0,$t1,loop_hashCode_String # loop back if more
3380:done_hashCode_String:    

    # push int on stack
3380#    move $t0, $t2 # put $t2 in return slot
3384#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
3388:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
3388#    subu $sp,4
3392#    sw $ra,($sp)
    
    # get hash value
3396#    lw $t2,-12($s2) # vtable address
3400#    lw $t0,($t2) # method address
3404#    jalr $t0
3408#    subu $sp,8 # push result (int in $t0) on stack
3412#    sw $s5,4($sp)
3416#    sw $t0,($sp)

    # compute print-size of hash value
3420#    li $t0, 1
3424#    lw $t1, ($sp)
3428#    srl $t1,$t1,4
3432#    beq $t1,$zero,toString_skip_loop
3436:toString_loop_top:
3436#    addu $t0,1
3440#    srl $t1,$t1,4
3444#    bne $t1,$zero,toString_loop_top
3448:toString_skip_loop:
3448#    subu $sp,8
3452#    sw $s5,4($sp)
3456#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
3460#    lw $t2,-12($s2) # vtable address
3464#    move $t0,$t2
3468:toString_checkTagBit:
3468#    subu $t0,1
3472#    lb $t1,($t0)
3476#    and $t1,0x80
3477##...lui $at,0
3481##...ori $at,$at,0x80
3485##...and $t1,$t1,$at
3488#    beq $t1,$zero,toString_checkTagBit
3492#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
3496#    subu $sp,8
3500#    sw $t1,($sp)
3504#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
3508#    move $s7,$zero # -4 offset header word
3512#    lw $t4,8($sp) # bytes for hash value
3516#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
3520#    addu $t4,8
3524#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
3528#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

3532#    li $t0,CLASS_String # store string vtable address into ...
3536#    sw $t0,-12($s7) # ... -12 offset in object header
3540#    lw $t2,-12($s2) # our object's vtable address
3544#    lw $t5,4($sp) # number characters in prefix
3548#    lw $t1,12($sp) # number of characters in hashcode
3552#    addu $t3,$t1,$t5 # number of characters in string ...
3556#    addu $t3,1 # ... including the '@' character
3560#    subu $t0,$zero,$t3 # store negated length into ...
3564#    sw $t0,-4($s7) # ... -4 offset header word
3568#    lw $t0,-8($s7) # get -8 offset header-word
3572#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
3573##...slt $at,$t0,$zero
3577##...beq $at,$zero,3596
3580#    and $t0,0xff # mask off object's hash value ...
3581##...lui $at,0
3585##...ori $at,$at,0xff
3589##...and $t0,$t0,$at
3592#    sw $t0,-8($s7) # ... and store back into -8 header-word
3596:skipMask_toString:
3596#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
3600#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
3604#    subu $t4,$t2,$t5
3608:toString_copyLoop:    
3608#    lb $t3,($t4)
3612#    and $t3,0x7f # mask off sign bit (in case first word)
3613##...lui $at,0
3617##...ori $at,$at,0x7f
3621##...and $t3,$t3,$at
3624#    sb $t3,-8($t0)
3628#    addu $t4,1
3632#    addu $t0,1
3636#    blt $t4,$t2,toString_copyLoop
3637##...slt $at,$t4,$t2
3641##...bne $at,$zero,3608

    # copy the '@' sign
3644#    li $t3,'@'
3648#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
3652#    addu $t2,$t0,$t1 # address of last byte in string to store +8
3656#    lw $t3,20($sp) # hash code to print
3660:toString_hashCopyLoop:
3660#    and $t4,$t3,0xf
3664#    srl $t3,4
3668#    lb $t4,hexChars($t4)
3672#    sb $t4,-8($t2)
3676#    subu $t2,$t2,1
3680#    bgt $t2,$t0,toString_hashCopyLoop
3681##...slt $at,$t0,$t2
3685##...bne $at,$zero,3660

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
3688#    addu $sp,28
3692#    lw $ra,($sp)
3696#    addu $sp,4
3700#    move $t0, $s7 # return string we created
3704#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
3708:mth_equals_String:
    
    # quick test for obvious false
3708#    lw $t0,($sp) # second parameter
3712#    beq $t0,$zero,goEsFalse # go return false if null
3716#    lw $t1,-12($t0) # vtable pointer
3720#    la $t2,CLASS_String # string vtable pointer
3724#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
3728#    subu $sp,12
3732#    sw $ra,8($sp)
3736#    sw $s2,4($sp)
3740#    sw $t0,($sp)
3744#    jal mth_compareTo_String
3748#    lw $s2, 4($sp) #restore this pointer and pop parameters
3752#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
3756#    seq $t0,$t0,$zero
3757##...subu $at,$t0,$zero
3761##...sltiu $t0,$at,1

    # pop return address and return $t0
3764#    lw $ra,($sp)
3768#    addu $sp,4

3772#    jr $ra # return
    
3776:goEsFalse:
    # put 0 in $t0 and return
3776#    li $t0, 0
3780#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
3784:mth_toString_String:
    #we are a string, so return this.
3784#    move $t0, $s2
3788#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
3792:mth_readLine_Lib:
    
3792#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
3796#    sw $ra, 4($sp) # save $ra
3800#    move $t1,$sp # save "original" sp

3804:  doRead:

    # read the character
3804#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
3808#    subu $t2,$v0,13
3812#    bne $t2,$zero,notReturnRL
3816#    jal readLogicalChar
3820#    subu $t2,$v0,10 # check for newline
3824#    beq $t2,$zero,foundNewLine
3828#    sw $v0,lastCharRead # push back character into queue
3832#    j foundNewLine # go process the line

3836:  notReturnRL:

    # at this point, $v0 has our character

3836#    subu $t0,$v0,10
3840#    beq $t0,$zero,foundNewLine
3844#    blt $v0,$zero,foundEof
3845##...slt $at,$v0,$zero
3849##...bne $at,$zero,3864

    # we have a character, so push it onto stack
3852#    subu $sp,$sp,4
3856#    sw $v0,($sp)

    # loop back up to get next character
3860#    j doRead

3864:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
3864#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
3868#    li $s7, 0 # return-value: null
3872#    j rlReturn # return

3876:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
3876#    subu $t0,$t1,$sp # number of chars we read (times 4)
3880#    srl $s6,$t0,2 # number of words on stack with chars
3884#    subu $sp,$sp,4 # push char-count ...
3888#    sw $s6,($sp) # ... onto stack
3892#    addu $t2,$t0,5 # GC tag, incl. for count-word
3896#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
3900#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
3904#    srl $s6,$s6,2  # data words in object
3908#    move $s7,$zero # object words in object
3912#    jal newObject  # allocate space
    
    # store header words
3916#    la $t0,CLASS_String
3920#    sw $t0,-12($s7)# store class tag (String) into object
3924#    lw $t2,4($sp) # char-count
3928#    sll $t1,$t2,2 # 4 times number of chars
3932#    subu $t2,$zero,$t2 # negative of char-count
3936#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3940#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3944#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3945##...slt $at,$t0,$zero
3949##...beq $at,$zero,3968
3952#    and $t0,0xff # mask off object's hash value ...
3953##...lui $at,0
3957##...ori $at,$at,0xff
3961##...and $t0,$t0,$at
3964#    sw $t0,-8($s7) # ... and store back into -8 header-word

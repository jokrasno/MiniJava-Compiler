1284#    lw $t1,12($sp) # number of characters in hashcode
1288#    addu $t3,$t1,$t5 # number of characters in string ...
1292#    addu $t3,1 # ... including the '@' character
1296#    subu $t0,$zero,$t3 # store negated length into ...
1300#    sw $t0,-4($s7) # ... -4 offset header word

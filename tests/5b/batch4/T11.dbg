
    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3724#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3725##...slt $at,$t8,$zero
3729##...beq $at,$zero,3744
3732#    and $t8,0xff # mask off hash bits
3733##...lui $at,0
3737##...ori $at,$at,0xff
3741##...and $t8,$t8,$at

3744:  gcSkip5:
3744#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3748#    addu $t8,$t8,8 # ... add in bytes for header-words
3752#    subu $t4,$t1,$t8 # address of first word of source object
3756#    lw $t3,-4($t1) # # words in positive-offset portion
3760#    bge $t3,$zero,gcNoNeg
3761##...slt $at,$t3,$zero
3765##...beq $at,$zero,3772
3768#    move $t3,$zero # negative treated as zero
3772:  gcNoNeg:
3772#    sll $t3,$t3,2 # bytes in negative-offset portion
3776#    addu $t3,$t3,$t1 # address one word past last word of source

3780#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3784#    lw $s0,($t4)
3788#    lw $t9,-8($t1)
3792#    sw $t9,($t4)
3796#    sw $s0,-8($t1)

    # copy all source bytes to the target
3800:  gCinnerCopy2:
3800#    lw $s0,($t4)
3804#    sw $s0,($s3)
3808#    addu $t4,$t4,4
3812#    addu $s3,$s3,4
3816#    bltu $t4,$t3,gCinnerCopy2
3817##...sltu $at,$t4,$t3
3821##...bne $at,$zero,3800

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3824#    sw $zero,-8($t1) # 0 in first header-slot
3828#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3832#    sw $t8,($t0)

3836:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3836#    addu $t0,$t0,4
3840#    bltu $t0,$s1,gcNextPointerInObject
3841##...sltu $at,$t0,$s1
3845##...bne $at,$zero,3684

3848:  gcTestIterDone2:
3848#    bltu $t0,$s3,gcHeapCopyLoop
3849##...sltu $at,$t0,$s3
3853##...bne $at,$zero,3568

    ###### end outer loop to copy all non-stack-direct objects ######

3856:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3856#    lw $s2,($sp)
3860#    addu $sp,$sp,4

    # mark us as having already GC'd
3864#    move $t5,$s5

    # go try and allocate again
3868#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3872:vm_init:

    # mark bottom of stack
3872#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3876#    move $s2,$zero

    #set up the "five" register
3880#    li $s5,5

3884#    la $s3,seg0_start
3888#    la $s4,seg0_end
3889##...lui $s4,16
3893##...addiu $s4,$s4,4700
    
    # return
3896#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3900:divide:
    # get parameters; abort if divisor zero
3900#    lw $t0,($sp)
3904#    lw $t1,8($sp)
3908#    beq $t0,$zero,divByZeroError
    
    # perform division
3912#    div $t1,$t0
3916#    mflo $t0

    # store result, adjust stack and return
3920#    addu $sp,$sp,8 # adjust stack
3924#    sw $t0,($sp) # store result
3928#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3932:remainder:
    # get parameters; abort if divisor zero
3932#    lw $t0,($sp)
3936#    lw $t1,8($sp)
3940#    beq $t0,$zero,divByZeroError
    
    # perform division
3944#    div $t1,$t0
3948#    mfhi $t0

    # store result, adjust stack and return
3952#    addu $sp,$sp,8 # adjust stack
3956#    sw $t0,($sp) # store result
3960#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3964:checkCast:
    # get object, allow immediately if null
3964#    lw $t2,($sp)
3968#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3972#    lw $t2,-12($t2) # vtable address
3976#    bge $t2,$t1,castException
3977##...slt $at,$t2,$t1
3981##...beq $at,$zero,4116
3984#    blt $t2,$t0,castException
3985##...slt $at,$t2,$t0
3989##...bne $at,$zero,4116
    
    # return, leaving object unchanged on stack
3992:  checkCastReturn:    
3992#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3996:instanceOf:
    # get object, go return false if null
3996#    lw $t2,($sp)
4000#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4004#    lw $t2,-12($t2) # vtable address
4008#    sge $t0,$t2,$t0 # are we >= the lower limit?
4009##...slt $t0,$t2,$t0
4013##...xori $t0,$t0,0x1
4016#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4020#    and $t2,$t0,$t1
4024#    sw $t2,($sp)
4028:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4028#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4032:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4032#    li $v0,4 # syscall-code for print-string
4036#    syscall
4040:exit:
    # print termination message
4040#    li $v0,4 # syscall-code for print-string
4044#    la $a0,exitString
4048#    syscall

    # terminate execution
4052#    li $v0,10 #syscall-code for "exit"
4056#    syscall

4060:outOfHeapMemory:
4060#    la $a0,heapMemoryMsg
4064#    j exitError
4068:divByZeroError:
4068#    la $a0,divByZeroMsg
4072#    j exitError
4076:strIndexOutOfBounds:
4076#    la $a0,strIndexOutOfBoundsMsg
4080#    j exitError
4084:arrayIndexOutOfBounds:
4084#    la $a0,arrayIndexOutOfBoundsMsg
4088#    j exitError
4092:arraySizeOutOfBounds:
4092#    la $a0,arraySizeOutOfBoundsMsg
4096#    j exitError
4100:nullPtrException:
4100#    la $a0,nullPtrExceptionMsg
4104#    j exitError
4108:badIntegerFormat:
4108#    la $a0,badIntegerFormatMsg
4112#    j exitError
4116:castException:
4116#    la $a0,castExceptionMsg
4120#    j exitError
############## data section ################
    .data
4336:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4352:cur_seg:
    .word 0

4356:lastCharRead:
    .word -2 # -2 => no buffered character
4360:prevHashConstant:
    .word 0x2785173c
4364:gcCount:
    .word 0

4368:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4395:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4418:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4453:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4487:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4520:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4551:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4599:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4620:gcMsg: 
      .asciiz "\nGC!\n"
4626:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4658:nullStr:
    .asciiz "null"
4663:trueString:
    .asciiz "true"
4668:falseString:
    .asciiz "false"
4674:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4693:newlineString:
    .asciiz "\n"
    
    .align 2
4696:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4700:seg0_start:
    .space 0x100000
1053276:seg0_end:
1053276:seg1_start:
    .space 0x100000
2101852:seg1_end:

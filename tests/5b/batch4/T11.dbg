1792#    subu $t0,$v0,10
1796#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1800#    subu $t0,$v0,9
1804#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1808#    subu $t0,$v0,13
1812#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1816#    subu $t0,$v0,12
1820#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1824#    j badIntegerFormat # illegal integer char: abort program

1828:  nonWhite:
1828#    subu $t0,$v0,'-'
1832#    li $t4,1 # final multiplier
1836#    bne $t0,$zero,helpReadInt # go read
1840#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1844#    jal readLogicalChar

1848:  helpReadInt:
1848#    li $t2,10
1852#    subu $t1,$v0,'0' # convert digit to 0-9 value

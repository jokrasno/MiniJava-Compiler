#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1444:mth_equals_String:
    
    # quick test for obvious false
1444#    lw $t0,($sp) # second parameter
1448#    beq $t0,$zero,goEsFalse # go return false if null
1452#    lw $t1,-12($t0) # vtable pointer
1456#    la $t2,CLASS_String # string vtable pointer
1460#    bne $t1,$t2,goEsFalse # go return false if not a string


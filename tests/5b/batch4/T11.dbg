    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1868#    jal readLogicalChar # read next character
1872#    subu $t1,$v0,'0' # convert digit to 0-9 value
1876#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1877##...sltu $at,$t1,$t2
1881##...beq $at,$zero,1900

1492#    seq $t0,$t0,$zero
1493##...subu $at,$t0,$zero
1497##...sltiu $t0,$at,1

    # pop return address and return $t0
1500#    lw $ra,($sp)
1504#    addu $sp,4

1508#    jr $ra # return
    
1512:goEsFalse:
    # put 0 in $t0 and return
1512#    li $t0, 0
1516#    jr $ra # return

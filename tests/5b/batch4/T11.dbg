    # we have our character from the buffer. Wipe out
    # buffer and return
3076#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
3080#    jr $ra # return
    
3084:  doReadCh:
    # we need to actually read a character: read and return
3084#    li $v0,12 # use system call to read a character
3088#    syscall
3092#    jr $ra # return

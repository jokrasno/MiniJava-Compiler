##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
896:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
896#    lw $t0,-8($s2) # get word with hash bits from this
900#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
904#    addu $t0,$t1

908#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
912:mth_equals_Object:
912#    move $t0,$s2 # first pointer (this)
916#    lw $t1,($sp) # second pointer
920#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
921##...subu $at,$t0,$t1
925##...sltiu $t0,$at,1

928#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
932:mth_hashCode_String:
932#    move $t0,$s2 # put this pointer in t0

936#    li $t2,0 # current hash value
940#    lw $t1,-4($t0) # negative of number of characters in string
944#    beq $t1,$zero,done_hashCode_String # if zero length => done
948#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
952#    and $t0,0xfffffffc # adjust for padding
953##...lui $at,65535
957##...ori $at,$at,0xfffc
961##...and $t0,$t0,$at
964#    subu $t1,$t0,$t1 # address at end of string +12
968:loop_hashCode_String:    
968#    sll $t4,$t2,5 # multiply by 32
972#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
976#    lbu $t3,-12($t0) # current character
980#    addu $t2,$t3 # add in current character
984#    addu $t0,1 # go to next character's address
988#    bne $t0,$t1,loop_hashCode_String # loop back if more
992:done_hashCode_String:    

    # push int on stack
992#    move $t0, $t2 # put $t2 in return slot
996#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1000:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1000#    subu $sp,4
1004#    sw $ra,($sp)
    
    # get hash value
1008#    lw $t2,-12($s2) # vtable address
1012#    lw $t0,($t2) # method address
1016#    jalr $t0
1020#    subu $sp,8 # push result (int in $t0) on stack
1024#    sw $s5,4($sp)
1028#    sw $t0,($sp)

    # compute print-size of hash value
1032#    li $t0, 1
1036#    lw $t1, ($sp)
1040#    srl $t1,$t1,4
1044#    beq $t1,$zero,toString_skip_loop
1048:toString_loop_top:
1048#    addu $t0,1
1052#    srl $t1,$t1,4
1056#    bne $t1,$zero,toString_loop_top
1060:toString_skip_loop:
1060#    subu $sp,8
1064#    sw $s5,4($sp)
1068#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1072#    lw $t2,-12($s2) # vtable address
1076#    move $t0,$t2
1080:toString_checkTagBit:
1080#    subu $t0,1
1084#    lb $t1,($t0)
1088#    and $t1,0x80
1089##...lui $at,0
1093##...ori $at,$at,0x80
1097##...and $t1,$t1,$at
1100#    beq $t1,$zero,toString_checkTagBit
1104#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1108#    subu $sp,8
1112#    sw $t1,($sp)
1116#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1120#    move $s7,$zero # -4 offset header word
1124#    lw $t4,8($sp) # bytes for hash value
1128#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1132#    addu $t4,8
1136#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1140#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1144#    li $t0,CLASS_String # store string vtable address into ...
1148#    sw $t0,-12($s7) # ... -12 offset in object header
1152#    lw $t2,-12($s2) # our object's vtable address
1156#    lw $t5,4($sp) # number characters in prefix
1160#    lw $t1,12($sp) # number of characters in hashcode
1164#    addu $t3,$t1,$t5 # number of characters in string ...
1168#    addu $t3,1 # ... including the '@' character
1172#    subu $t0,$zero,$t3 # store negated length into ...
1176#    sw $t0,-4($s7) # ... -4 offset header word
1180#    lw $t0,-8($s7) # get -8 offset header-word
1184#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1185##...slt $at,$t0,$zero
1189##...beq $at,$zero,1208
1192#    and $t0,0xff # mask off object's hash value ...
1193##...lui $at,0
1197##...ori $at,$at,0xff
1201##...and $t0,$t0,$at
1204#    sw $t0,-8($s7) # ... and store back into -8 header-word
1208:skipMask_toString:
1208#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1212#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1216#    subu $t4,$t2,$t5
1220:toString_copyLoop:    
1220#    lb $t3,($t4)
1224#    and $t3,0x7f # mask off sign bit (in case first word)
1225##...lui $at,0
1229##...ori $at,$at,0x7f
1233##...and $t3,$t3,$at
1236#    sb $t3,-8($t0)
1240#    addu $t4,1
1244#    addu $t0,1
1248#    blt $t4,$t2,toString_copyLoop
1249##...slt $at,$t4,$t2
1253##...bne $at,$zero,1220

    # copy the '@' sign
1256#    li $t3,'@'
1260#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1264#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1268#    lw $t3,20($sp) # hash code to print
1272:toString_hashCopyLoop:
1272#    and $t4,$t3,0xf
1276#    srl $t3,4
1280#    lb $t4,hexChars($t4)
1284#    sb $t4,-8($t2)
1288#    subu $t2,$t2,1
1292#    bgt $t2,$t0,toString_hashCopyLoop
1293##...slt $at,$t0,$t2
1297##...bne $at,$zero,1272

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1300#    addu $sp,28
1304#    lw $ra,($sp)
1308#    addu $sp,4
1312#    move $t0, $s7 # return string we created
1316#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1320:mth_equals_String:
    
    # quick test for obvious false
1320#    lw $t0,($sp) # second parameter
1324#    beq $t0,$zero,goEsFalse # go return false if null
1328#    lw $t1,-12($t0) # vtable pointer
1332#    la $t2,CLASS_String # string vtable pointer
1336#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1340#    subu $sp,12
1344#    sw $ra,8($sp)
1348#    sw $s2,4($sp)
1352#    sw $t0,($sp)
1356#    jal mth_compareTo_String
1360#    lw $s2, 4($sp) #restore this pointer and pop parameters
1364#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1368#    seq $t0,$t0,$zero
1369##...subu $at,$t0,$zero
1373##...sltiu $t0,$at,1

    # pop return address and return $t0
1376#    lw $ra,($sp)
1380#    addu $sp,4

1384#    jr $ra # return
    
1388:goEsFalse:
    # put 0 in $t0 and return
1388#    li $t0, 0
1392#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
1396:mth_toString_String:

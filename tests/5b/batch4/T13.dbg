    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3600#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3601##...slt $at,$t8,$zero
3605##...beq $at,$zero,3620
3608#    and $t8,0xff # mask off hash bits
3609##...lui $at,0
3613##...ori $at,$at,0xff
3617##...and $t8,$t8,$at

3620:  gcSkip5:
3620#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3624#    addu $t8,$t8,8 # ... add in bytes for header-words
3628#    subu $t4,$t1,$t8 # address of first word of source object
3632#    lw $t3,-4($t1) # # words in positive-offset portion
3636#    bge $t3,$zero,gcNoNeg
3637##...slt $at,$t3,$zero
3641##...beq $at,$zero,3648
3644#    move $t3,$zero # negative treated as zero
3648:  gcNoNeg:
3648#    sll $t3,$t3,2 # bytes in negative-offset portion
3652#    addu $t3,$t3,$t1 # address one word past last word of source

3656#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3660#    lw $s0,($t4)
3664#    lw $t9,-8($t1)
3668#    sw $t9,($t4)
3672#    sw $s0,-8($t1)

    # copy all source bytes to the target
3676:  gCinnerCopy2:
3676#    lw $s0,($t4)
3680#    sw $s0,($s3)
3684#    addu $t4,$t4,4
3688#    addu $s3,$s3,4
3692#    bltu $t4,$t3,gCinnerCopy2
3693##...sltu $at,$t4,$t3
3697##...bne $at,$zero,3676

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3700#    sw $zero,-8($t1) # 0 in first header-slot
3704#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3708#    sw $t8,($t0)

3712:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3712#    addu $t0,$t0,4
3716#    bltu $t0,$s1,gcNextPointerInObject
3717##...sltu $at,$t0,$s1
3721##...bne $at,$zero,3560

3724:  gcTestIterDone2:
3724#    bltu $t0,$s3,gcHeapCopyLoop
3725##...sltu $at,$t0,$s3
3729##...bne $at,$zero,3444

    ###### end outer loop to copy all non-stack-direct objects ######

3732:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3732#    lw $s2,($sp)
3736#    addu $sp,$sp,4

    # mark us as having already GC'd
3740#    move $t5,$s5

    # go try and allocate again
3744#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3748:vm_init:

    # mark bottom of stack
3748#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3752#    move $s2,$zero

    #set up the "five" register
3756#    li $s5,5

3760#    la $s3,seg0_start
3764#    la $s4,seg0_end
3765##...lui $s4,16
3769##...addiu $s4,$s4,4576
    
    # return
3772#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3776:divide:
    # get parameters; abort if divisor zero
3776#    lw $t0,($sp)
3780#    lw $t1,8($sp)
3784#    beq $t0,$zero,divByZeroError
    
    # perform division
3788#    div $t1,$t0
3792#    mflo $t0

    # store result, adjust stack and return
3796#    addu $sp,$sp,8 # adjust stack
3800#    sw $t0,($sp) # store result
3804#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3808:remainder:
    # get parameters; abort if divisor zero
3808#    lw $t0,($sp)
3812#    lw $t1,8($sp)
3816#    beq $t0,$zero,divByZeroError
    
    # perform division
3820#    div $t1,$t0
3824#    mfhi $t0

    # store result, adjust stack and return
3828#    addu $sp,$sp,8 # adjust stack
3832#    sw $t0,($sp) # store result
3836#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3840:checkCast:
    # get object, allow immediately if null
3840#    lw $t2,($sp)
3844#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3848#    lw $t2,-12($t2) # vtable address
3852#    bge $t2,$t1,castException
3853##...slt $at,$t2,$t1
3857##...beq $at,$zero,3992
3860#    blt $t2,$t0,castException
3861##...slt $at,$t2,$t0
3865##...bne $at,$zero,3992
    
    # return, leaving object unchanged on stack
3868:  checkCastReturn:    
3868#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3872:instanceOf:
    # get object, go return false if null
3872#    lw $t2,($sp)
3876#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3880#    lw $t2,-12($t2) # vtable address
3884#    sge $t0,$t2,$t0 # are we >= the lower limit?
3885##...slt $t0,$t2,$t0
3889##...xori $t0,$t0,0x1
3892#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3896#    and $t2,$t0,$t1
3900#    sw $t2,($sp)
3904:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3904#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3908:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3908#    li $v0,4 # syscall-code for print-string
3912#    syscall
3916:exit:
    # print termination message
3916#    li $v0,4 # syscall-code for print-string
3920#    la $a0,exitString
3924#    syscall

    # terminate execution
3928#    li $v0,10 #syscall-code for "exit"
3932#    syscall

3936:outOfHeapMemory:
3936#    la $a0,heapMemoryMsg
3940#    j exitError
3944:divByZeroError:
3944#    la $a0,divByZeroMsg
3948#    j exitError
3952:strIndexOutOfBounds:
3952#    la $a0,strIndexOutOfBoundsMsg
3956#    j exitError
3960:arrayIndexOutOfBounds:
3960#    la $a0,arrayIndexOutOfBoundsMsg
3964#    j exitError
3968:arraySizeOutOfBounds:
3968#    la $a0,arraySizeOutOfBoundsMsg
3972#    j exitError
3976:nullPtrException:
3976#    la $a0,nullPtrExceptionMsg
3980#    j exitError
3984:badIntegerFormat:
3984#    la $a0,badIntegerFormatMsg
3988#    j exitError
3992:castException:
3992#    la $a0,castExceptionMsg
3996#    j exitError
############## data section ################
    .data
4212:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4228:cur_seg:
    .word 0

4232:lastCharRead:
    .word -2 # -2 => no buffered character
4236:prevHashConstant:
    .word 0x2785173c
4240:gcCount:
    .word 0

4244:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4271:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4294:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4329:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4363:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4396:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4427:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4475:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4496:gcMsg: 
      .asciiz "\nGC!\n"
4502:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4534:nullStr:
    .asciiz "null"
4539:trueString:
    .asciiz "true"
4544:falseString:
    .asciiz "false"
4550:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4569:newlineString:
    .asciiz "\n"
    
    .align 2
4572:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4576:seg0_start:
    .space 0x100000
1053152:seg0_end:
1053152:seg1_start:
    .space 0x100000
2101728:seg1_end:

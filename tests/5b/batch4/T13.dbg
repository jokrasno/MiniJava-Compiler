###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1404:mth_readLine_Lib:
    
1404#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1408#    sw $ra, 4($sp) # save $ra
1412#    move $t1,$sp # save "original" sp

1416:  doRead:

    # read the character
1416#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1420#    subu $t2,$v0,13
1424#    bne $t2,$zero,notReturnRL
1428#    jal readLogicalChar
1432#    subu $t2,$v0,10 # check for newline
1436#    beq $t2,$zero,foundNewLine
1440#    sw $v0,lastCharRead # push back character into queue
1444#    j foundNewLine # go process the line

1448:  notReturnRL:

    # at this point, $v0 has our character

1448#    subu $t0,$v0,10
1452#    beq $t0,$zero,foundNewLine
1456#    blt $v0,$zero,foundEof
1457##...slt $at,$v0,$zero
1461##...bne $at,$zero,1476

    # we have a character, so push it onto stack
1464#    subu $sp,$sp,4
1468#    sw $v0,($sp)

    # loop back up to get next character
1472#    j doRead

1476:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1476#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1480#    li $s7, 0 # return-value: null
1484#    j rlReturn # return

1488:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1488#    subu $t0,$t1,$sp # number of chars we read (times 4)
1492#    srl $s6,$t0,2 # number of words on stack with chars
1496#    subu $sp,$sp,4 # push char-count ...
1500#    sw $s6,($sp) # ... onto stack
1504#    addu $t2,$t0,5 # GC tag, incl. for count-word
1508#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1512#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1516#    srl $s6,$s6,2  # data words in object
1520#    move $s7,$zero # object words in object
1524#    jal newObject  # allocate space
    
    # store header words
1528#    la $t0,CLASS_String
1532#    sw $t0,-12($s7)# store class tag (String) into object
1536#    lw $t2,4($sp) # char-count
1540#    sll $t1,$t2,2 # 4 times number of chars
1544#    subu $t2,$zero,$t2 # negative of char-count
1548#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1552#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1556#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1557##...slt $at,$t0,$zero
1561##...beq $at,$zero,1580
1564#    and $t0,0xff # mask off object's hash value ...
1565##...lui $at,0
1569##...ori $at,$at,0xff
1573##...and $t0,$t0,$at
1576#    sw $t0,-8($s7) # ... and store back into -8 header-word
1580:  skipMask_readLine:

1580#    sll $t0,$t0,2 # data bytes in object
1584#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1588#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1592#    addu $sp,$sp,8 # pop redundant object-pointer and count
1596#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1600#    beq $sp,$t1,rlReturn
1604:  charCopyLoop:
1604#    lw $t2,($sp)
1608#    sb $t2,-9($t0)
1612#    addu $sp,$sp,4
1616#    subu $t0,$t0,1
1620#    bne $sp,$t1,charCopyLoop
1624:  rlReturn:

1624#    lw $ra, 4($sp)
1628#    addu $sp, 8   # pop $ra and pointless word off stack
1632#    move $t0, $s7 # return string we allocated in $s7
1636#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1640:mth_readInt_Lib:

    # save $ra by pushing onto stack
1640#    subu $sp,$sp,4
1644#    sw $ra,($sp)

1648:  riSkipWhiteLoop:
    # read a character
1648#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1652#    subu $t0,$v0,32
1656#    bgt $t0,$zero,nonWhite
1657##...slt $at,$zero,$t0
1661##...bne $at,$zero,1704
1664#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1668#    subu $t0,$v0,10
1672#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1676#    subu $t0,$v0,9
1680#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1684#    subu $t0,$v0,13
1688#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1692#    subu $t0,$v0,12
1696#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1700#    j badIntegerFormat # illegal integer char: abort program

1704:  nonWhite:
1704#    subu $t0,$v0,'-'
1708#    li $t4,1 # final multiplier
1712#    bne $t0,$zero,helpReadInt # go read
1716#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1720#    jal readLogicalChar

1724:  helpReadInt:
1724#    li $t2,10
1728#    subu $t1,$v0,'0' # convert digit to 0-9 value
1732#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1733##...sltu $at,$t1,$t2
1737##...beq $at,$zero,3984
1740#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1744:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1744#    jal readLogicalChar # read next character
1748#    subu $t1,$v0,'0' # convert digit to 0-9 value
1752#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1753##...sltu $at,$t1,$t2
1757##...beq $at,$zero,1776

1760#    mul $t3,$t3,$t2 # multiply old value by 10
1761##...mult $t3,$t2
1765##...mflo $t3
1768#    addu $t3,$t3,$t1 # add in value of new digit
1772#    j digitLoop

1776:  doneDigitLoop:

    # "push back" unused character into queue
1776#    sw $v0,lastCharRead

    # restore return address
1780#    lw $ra,($sp)
1784#    addu $sp, 4

    # multiply by sign and put return value in $t0
1788#    mult $t3,$t4 # multiply to account for poss. minus sign
1792#    mflo $t3
1796#    move $t0, $t3
    
    # return
1800#    jr $ra

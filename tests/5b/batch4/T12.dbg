    # set $s3 to the address of the new segment and the
    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
2860#    lw $t0,cur_seg
2864#    move $t7,$s4
2868#    la $t6,seg1_start
2869##...lui $t6,16
2873##...addiu $t6,$t6,4284
2876#    la $s3,seg0_start
2880#    la $s4,seg0_end
2881##...lui $s4,16
2885##...addiu $s4,$s4,4284
2888#    sw $zero,cur_seg
2892#    bne $t0,$zero,skipGc1
2896#    la $t6,seg0_start
2900#    la $s3,seg1_start
2901##...lui $s3,16
2905##...addiu $s3,$s3,4284
2908#    la $s4,seg1_end
2909##...lui $s4,32
2913##...addiu $s4,$s4,4284
2916#    sw $s5,cur_seg
2920:  skipGc1:
2920#    li $t5,0x80000000

1365##...slt $at,$zero,$t0
1369##...bne $at,$zero,1412
1372#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1376#    subu $t0,$v0,10
1380#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1384#    subu $t0,$v0,9
1388#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1392#    subu $t0,$v0,13
1396#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1400#    subu $t0,$v0,12
1404#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1408#    j badIntegerFormat # illegal integer char: abort program

1412:  nonWhite:
1412#    subu $t0,$v0,'-'
1416#    li $t4,1 # final multiplier
1420#    bne $t0,$zero,helpReadInt # go read
1424#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1428#    jal readLogicalChar

1432:  helpReadInt:
1432#    li $t2,10
1436#    subu $t1,$v0,'0' # convert digit to 0-9 value
1440#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1441##...sltu $at,$t1,$t2
1445##...beq $at,$zero,3692
1448#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

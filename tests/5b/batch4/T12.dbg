1452:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1452#    jal readLogicalChar # read next character
1456#    subu $t1,$v0,'0' # convert digit to 0-9 value
1460#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1461##...sltu $at,$t1,$t2
1465##...beq $at,$zero,1484

1468#    mul $t3,$t3,$t2 # multiply old value by 10
1469##...mult $t3,$t2
1473##...mflo $t3
1476#    addu $t3,$t3,$t1 # add in value of new digit
1480#    j digitLoop

1484:  doneDigitLoop:

    # "push back" unused character into queue

1077##...subu $at,$t0,$zero
1081##...sltiu $t0,$at,1

    # pop return address and return $t0
1084#    lw $ra,($sp)
1088#    addu $sp,4

1092#    jr $ra # return
    
1096:goEsFalse:
    # put 0 in $t0 and return
1096#    li $t0, 0
1100#    jr $ra # return

3412#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3416#    sw $t8,($t0)

3420:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3420#    addu $t0,$t0,4
3424#    bltu $t0,$s1,gcNextPointerInObject
3425##...sltu $at,$t0,$s1
3429##...bne $at,$zero,3268

3432:  gcTestIterDone2:
3432#    bltu $t0,$s3,gcHeapCopyLoop
3433##...sltu $at,$t0,$s3
3437##...bne $at,$zero,3152

    ###### end outer loop to copy all non-stack-direct objects ######

3440:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3440#    lw $s2,($sp)
3444#    addu $sp,$sp,4

    # mark us as having already GC'd
3448#    move $t5,$s5

    # go try and allocate again
3452#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3456:vm_init:

    # mark bottom of stack
3456#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3460#    move $s2,$zero

    #set up the "five" register
3464#    li $s5,5

3468#    la $s3,seg0_start
3472#    la $s4,seg0_end
3473##...lui $s4,16
3477##...addiu $s4,$s4,4284
    
    # return
3480#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3484:divide:
    # get parameters; abort if divisor zero
3484#    lw $t0,($sp)
3488#    lw $t1,8($sp)
3492#    beq $t0,$zero,divByZeroError
    
    # perform division
3496#    div $t1,$t0
3500#    mflo $t0

    # store result, adjust stack and return
3504#    addu $sp,$sp,8 # adjust stack
3508#    sw $t0,($sp) # store result
3512#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3516:remainder:
    # get parameters; abort if divisor zero
3516#    lw $t0,($sp)
3520#    lw $t1,8($sp)
3524#    beq $t0,$zero,divByZeroError
    
    # perform division
3528#    div $t1,$t0
3532#    mfhi $t0

    # store result, adjust stack and return
3536#    addu $sp,$sp,8 # adjust stack
3540#    sw $t0,($sp) # store result
3544#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3548:checkCast:
    # get object, allow immediately if null
3548#    lw $t2,($sp)
3552#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3556#    lw $t2,-12($t2) # vtable address
3560#    bge $t2,$t1,castException
3561##...slt $at,$t2,$t1
3565##...beq $at,$zero,3700
3568#    blt $t2,$t0,castException
3569##...slt $at,$t2,$t0
3573##...bne $at,$zero,3700
    
    # return, leaving object unchanged on stack
3576:  checkCastReturn:    
3576#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3580:instanceOf:
    # get object, go return false if null
3580#    lw $t2,($sp)
3584#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3588#    lw $t2,-12($t2) # vtable address
3592#    sge $t0,$t2,$t0 # are we >= the lower limit?
3593##...slt $t0,$t2,$t0
3597##...xori $t0,$t0,0x1
3600#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3604#    and $t2,$t0,$t1
3608#    sw $t2,($sp)
3612:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3612#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3616:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3616#    li $v0,4 # syscall-code for print-string
3620#    syscall
3624:exit:
    # print termination message
3624#    li $v0,4 # syscall-code for print-string
3628#    la $a0,exitString
3632#    syscall

    # terminate execution
3636#    li $v0,10 #syscall-code for "exit"
3640#    syscall

3644:outOfHeapMemory:
3644#    la $a0,heapMemoryMsg
3648#    j exitError
3652:divByZeroError:
3652#    la $a0,divByZeroMsg
3656#    j exitError
3660:strIndexOutOfBounds:
3660#    la $a0,strIndexOutOfBoundsMsg
3664#    j exitError
3668:arrayIndexOutOfBounds:
3668#    la $a0,arrayIndexOutOfBoundsMsg
3672#    j exitError
3676:arraySizeOutOfBounds:
3676#    la $a0,arraySizeOutOfBoundsMsg
3680#    j exitError
3684:nullPtrException:
3684#    la $a0,nullPtrExceptionMsg
3688#    j exitError
3692:badIntegerFormat:
3692#    la $a0,badIntegerFormatMsg
3696#    j exitError
3700:castException:
3700#    la $a0,castExceptionMsg
3704#    j exitError
############## data section ################
    .data
3920:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3936:cur_seg:
    .word 0

3940:lastCharRead:
    .word -2 # -2 => no buffered character
3944:prevHashConstant:
    .word 0x2785173c
3948:gcCount:
    .word 0

3952:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3979:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4002:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4037:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4071:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4104:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4135:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4183:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4204:gcMsg: 
      .asciiz "\nGC!\n"
4210:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4242:nullStr:
    .asciiz "null"
4247:trueString:
    .asciiz "true"
4252:falseString:
    .asciiz "false"
4258:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4277:newlineString:
    .asciiz "\n"
    
    .align 2
4280:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4284:seg0_start:
    .space 0x100000
1052860:seg0_end:
1052860:seg1_start:
    .space 0x100000
2101436:seg1_end:

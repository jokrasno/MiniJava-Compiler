2692:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
2692#    addu $t0,$s6,$s7
2696#    sll $t0,$t0,2
2700#    addu $t0,$t0,8 # amount of memory needed
2704#    addu $t1,$t0,$s3
2708#    bgtu $t1,$s4,doGC
2709##...sltu $at,$s4,$t1
2713##...bne $at,$zero,2836

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
2716#    move $t2,$s3
2720:  zeroObjLoop:
2720#    sw $zero,($s3)
2724#    lw $zero,($s3)

2728#    addu $s3,4
2732#    bltu $s3,$t1,zeroObjLoop
2733##...sltu $at,$s3,$t1
2737##...bne $at,$zero,2720


    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
2748#    li $t2,255
2752#    bgeu $s6,$t2 firstHeaderLarge
2753##...sltu $at,$s6,$t2
2757##...beq $at,$zero,2804
2760#    lw $t1,prevHashConstant
2764#    addu $t1,0x12b68fd2
2765##...lui $at,4791
2769##...addiu $at,$at,-28718
2773##...addu $t1,$at,$t1
2776#    sw $t1,prevHashConstant # update hash constant
2780#    or $t1,0x80000000 # set top bit
2781##...lui $at,32768
2785##...or $t1,$at,$t1
2788#    and $t1,0xffffff00 # clear low bit
2789##...lui $at,65535
2793##...ori $at,$at,0xff00
2797##...and $t1,$t1,$at
2800#    or $s6,$t1
2804:firstHeaderLarge:
2804#    sw $s6,-8($t0) # store header-1 value
2808#    lw $zero,-8($t0)

    # store second header-value
2812#    sw $s7,-4($t0)   # second header-word
2816#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
2820#    move $s7,$t0
2824#    subu $sp,$sp,4
2828#    sw $t0,($sp)

2832#    jr $ra
    
2836:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
2836#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
2840#    lw $t5,gcCount
2844#    addu $t5,1
2848#    sw $t5,gcCount

    # save $s2 (our only rooted register) on the stack
    # so that the garbage collector processes it
2852#    subu $sp,$sp,4
2856#    sw $s2,($sp)

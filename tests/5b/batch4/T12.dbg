##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
604:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
604#    lw $t0,-8($s2) # get word with hash bits from this
608#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
612#    addu $t0,$t1

616#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
620:mth_equals_Object:
620#    move $t0,$s2 # first pointer (this)
624#    lw $t1,($sp) # second pointer
628#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
629##...subu $at,$t0,$t1
633##...sltiu $t0,$at,1

636#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
640:mth_hashCode_String:
640#    move $t0,$s2 # put this pointer in t0

644#    li $t2,0 # current hash value
648#    lw $t1,-4($t0) # negative of number of characters in string
652#    beq $t1,$zero,done_hashCode_String # if zero length => done
656#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
660#    and $t0,0xfffffffc # adjust for padding
661##...lui $at,65535
665##...ori $at,$at,0xfffc
669##...and $t0,$t0,$at
672#    subu $t1,$t0,$t1 # address at end of string +12
676:loop_hashCode_String:    
676#    sll $t4,$t2,5 # multiply by 32
680#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
684#    lbu $t3,-12($t0) # current character
688#    addu $t2,$t3 # add in current character
692#    addu $t0,1 # go to next character's address
696#    bne $t0,$t1,loop_hashCode_String # loop back if more
700:done_hashCode_String:    

    # push int on stack
700#    move $t0, $t2 # put $t2 in return slot
704#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
708:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
708#    subu $sp,4
712#    sw $ra,($sp)
    
    # get hash value
716#    lw $t2,-12($s2) # vtable address
720#    lw $t0,($t2) # method address
724#    jalr $t0
728#    subu $sp,8 # push result (int in $t0) on stack
732#    sw $s5,4($sp)
736#    sw $t0,($sp)

    # compute print-size of hash value
740#    li $t0, 1
744#    lw $t1, ($sp)
748#    srl $t1,$t1,4
752#    beq $t1,$zero,toString_skip_loop
756:toString_loop_top:
756#    addu $t0,1
760#    srl $t1,$t1,4
764#    bne $t1,$zero,toString_loop_top
768:toString_skip_loop:
768#    subu $sp,8
772#    sw $s5,4($sp)
776#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
780#    lw $t2,-12($s2) # vtable address
784#    move $t0,$t2
788:toString_checkTagBit:
788#    subu $t0,1
792#    lb $t1,($t0)
796#    and $t1,0x80
797##...lui $at,0
801##...ori $at,$at,0x80
805##...and $t1,$t1,$at
808#    beq $t1,$zero,toString_checkTagBit
812#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
816#    subu $sp,8
820#    sw $t1,($sp)
824#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
828#    move $s7,$zero # -4 offset header word
832#    lw $t4,8($sp) # bytes for hash value
836#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
840#    addu $t4,8
844#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
848#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

852#    li $t0,CLASS_String # store string vtable address into ...
856#    sw $t0,-12($s7) # ... -12 offset in object header
860#    lw $t2,-12($s2) # our object's vtable address
864#    lw $t5,4($sp) # number characters in prefix
868#    lw $t1,12($sp) # number of characters in hashcode
872#    addu $t3,$t1,$t5 # number of characters in string ...
876#    addu $t3,1 # ... including the '@' character
880#    subu $t0,$zero,$t3 # store negated length into ...
884#    sw $t0,-4($s7) # ... -4 offset header word
888#    lw $t0,-8($s7) # get -8 offset header-word
892#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
893##...slt $at,$t0,$zero
897##...beq $at,$zero,916
900#    and $t0,0xff # mask off object's hash value ...
901##...lui $at,0
905##...ori $at,$at,0xff
909##...and $t0,$t0,$at
912#    sw $t0,-8($s7) # ... and store back into -8 header-word
916:skipMask_toString:
916#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
920#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
924#    subu $t4,$t2,$t5
928:toString_copyLoop:    
928#    lb $t3,($t4)
932#    and $t3,0x7f # mask off sign bit (in case first word)
933##...lui $at,0
937##...ori $at,$at,0x7f
941##...and $t3,$t3,$at
944#    sb $t3,-8($t0)
948#    addu $t4,1
952#    addu $t0,1
956#    blt $t4,$t2,toString_copyLoop
957##...slt $at,$t4,$t2
961##...bne $at,$zero,928

    # copy the '@' sign
964#    li $t3,'@'
968#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value

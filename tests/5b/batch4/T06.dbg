###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1444:mth_readLine_Lib:
    
1444#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1448#    sw $ra, 4($sp) # save $ra
1452#    move $t1,$sp # save "original" sp

1456:  doRead:

    # read the character
1456#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1460#    subu $t2,$v0,13
1464#    bne $t2,$zero,notReturnRL
1468#    jal readLogicalChar
1472#    subu $t2,$v0,10 # check for newline
1476#    beq $t2,$zero,foundNewLine
1480#    sw $v0,lastCharRead # push back character into queue
1484#    j foundNewLine # go process the line

1488:  notReturnRL:

    # at this point, $v0 has our character

1488#    subu $t0,$v0,10
1492#    beq $t0,$zero,foundNewLine
1496#    blt $v0,$zero,foundEof
1497##...slt $at,$v0,$zero
1501##...bne $at,$zero,1516

    # we have a character, so push it onto stack
1504#    subu $sp,$sp,4
1508#    sw $v0,($sp)

    # loop back up to get next character
1512#    j doRead

1516:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1516#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1520#    li $s7, 0 # return-value: null
1524#    j rlReturn # return

1528:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1528#    subu $t0,$t1,$sp # number of chars we read (times 4)
1532#    srl $s6,$t0,2 # number of words on stack with chars
1536#    subu $sp,$sp,4 # push char-count ...
1540#    sw $s6,($sp) # ... onto stack
1544#    addu $t2,$t0,5 # GC tag, incl. for count-word
1548#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1552#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1556#    srl $s6,$s6,2  # data words in object
1560#    move $s7,$zero # object words in object
1564#    jal newObject  # allocate space
    
    # store header words
1568#    la $t0,CLASS_String
1572#    sw $t0,-12($s7)# store class tag (String) into object
1576#    lw $t2,4($sp) # char-count
1580#    sll $t1,$t2,2 # 4 times number of chars
1584#    subu $t2,$zero,$t2 # negative of char-count
1588#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1592#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1596#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1597##...slt $at,$t0,$zero
1601##...beq $at,$zero,1620
1604#    and $t0,0xff # mask off object's hash value ...
1605##...lui $at,0
1609##...ori $at,$at,0xff
1613##...and $t0,$t0,$at
1616#    sw $t0,-8($s7) # ... and store back into -8 header-word
1620:  skipMask_readLine:

1620#    sll $t0,$t0,2 # data bytes in object
1624#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1628#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1632#    addu $sp,$sp,8 # pop redundant object-pointer and count
1636#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1640#    beq $sp,$t1,rlReturn
1644:  charCopyLoop:
1644#    lw $t2,($sp)
1648#    sb $t2,-9($t0)
1652#    addu $sp,$sp,4
1656#    subu $t0,$t0,1
1660#    bne $sp,$t1,charCopyLoop
1664:  rlReturn:

1664#    lw $ra, 4($sp)
1668#    addu $sp, 8   # pop $ra and pointless word off stack
1672#    move $t0, $s7 # return string we allocated in $s7
1676#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1680:mth_readInt_Lib:

    # save $ra by pushing onto stack
1680#    subu $sp,$sp,4
1684#    sw $ra,($sp)

1688:  riSkipWhiteLoop:
    # read a character
1688#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1692#    subu $t0,$v0,32
1696#    bgt $t0,$zero,nonWhite
1697##...slt $at,$zero,$t0
1701##...bne $at,$zero,1744
1704#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1708#    subu $t0,$v0,10
1712#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1716#    subu $t0,$v0,9
1720#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1724#    subu $t0,$v0,13
1728#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1732#    subu $t0,$v0,12
1736#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1740#    j badIntegerFormat # illegal integer char: abort program

1744:  nonWhite:
1744#    subu $t0,$v0,'-'
1748#    li $t4,1 # final multiplier
1752#    bne $t0,$zero,helpReadInt # go read
1756#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1760#    jal readLogicalChar

1764:  helpReadInt:
1764#    li $t2,10
1768#    subu $t1,$v0,'0' # convert digit to 0-9 value
1772#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1773##...sltu $at,$t1,$t2
1777##...beq $at,$zero,4024
1780#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1784:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1784#    jal readLogicalChar # read next character
1788#    subu $t1,$v0,'0' # convert digit to 0-9 value
1792#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1793##...sltu $at,$t1,$t2
1797##...beq $at,$zero,1816

1800#    mul $t3,$t3,$t2 # multiply old value by 10
1801##...mult $t3,$t2
1805##...mflo $t3
1808#    addu $t3,$t3,$t1 # add in value of new digit
1812#    j digitLoop

1816:  doneDigitLoop:

    # "push back" unused character into queue

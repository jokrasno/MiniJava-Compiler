##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
936:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
936#    lw $t0,-8($s2) # get word with hash bits from this
940#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
944#    addu $t0,$t1

948#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
952:mth_equals_Object:
952#    move $t0,$s2 # first pointer (this)
956#    lw $t1,($sp) # second pointer
960#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
961##...subu $at,$t0,$t1
965##...sltiu $t0,$at,1

968#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
972:mth_hashCode_String:
972#    move $t0,$s2 # put this pointer in t0

976#    li $t2,0 # current hash value
980#    lw $t1,-4($t0) # negative of number of characters in string
984#    beq $t1,$zero,done_hashCode_String # if zero length => done
988#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
992#    and $t0,0xfffffffc # adjust for padding
993##...lui $at,65535
997##...ori $at,$at,0xfffc
1001##...and $t0,$t0,$at
1004#    subu $t1,$t0,$t1 # address at end of string +12
1008:loop_hashCode_String:    
1008#    sll $t4,$t2,5 # multiply by 32
1012#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1016#    lbu $t3,-12($t0) # current character
1020#    addu $t2,$t3 # add in current character
1024#    addu $t0,1 # go to next character's address
1028#    bne $t0,$t1,loop_hashCode_String # loop back if more
1032:done_hashCode_String:    

    # push int on stack
1032#    move $t0, $t2 # put $t2 in return slot
1036#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1040:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1040#    subu $sp,4
1044#    sw $ra,($sp)
    
    # get hash value
1048#    lw $t2,-12($s2) # vtable address
1052#    lw $t0,($t2) # method address
1056#    jalr $t0
1060#    subu $sp,8 # push result (int in $t0) on stack
1064#    sw $s5,4($sp)
1068#    sw $t0,($sp)

    # compute print-size of hash value
1072#    li $t0, 1
1076#    lw $t1, ($sp)
1080#    srl $t1,$t1,4
1084#    beq $t1,$zero,toString_skip_loop
1088:toString_loop_top:
1088#    addu $t0,1
1092#    srl $t1,$t1,4
1096#    bne $t1,$zero,toString_loop_top
1100:toString_skip_loop:
1100#    subu $sp,8
1104#    sw $s5,4($sp)
1108#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1112#    lw $t2,-12($s2) # vtable address
1116#    move $t0,$t2
1120:toString_checkTagBit:
1120#    subu $t0,1
1124#    lb $t1,($t0)
1128#    and $t1,0x80
1129##...lui $at,0
1133##...ori $at,$at,0x80
1137##...and $t1,$t1,$at
1140#    beq $t1,$zero,toString_checkTagBit
1144#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
1148#    subu $sp,8
1152#    sw $t1,($sp)
1156#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
1160#    move $s7,$zero # -4 offset header word
1164#    lw $t4,8($sp) # bytes for hash value
1168#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
1172#    addu $t4,8
1176#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
1180#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

1184#    li $t0,CLASS_String # store string vtable address into ...
1188#    sw $t0,-12($s7) # ... -12 offset in object header
1192#    lw $t2,-12($s2) # our object's vtable address
1196#    lw $t5,4($sp) # number characters in prefix
1200#    lw $t1,12($sp) # number of characters in hashcode
1204#    addu $t3,$t1,$t5 # number of characters in string ...
1208#    addu $t3,1 # ... including the '@' character
1212#    subu $t0,$zero,$t3 # store negated length into ...
1216#    sw $t0,-4($s7) # ... -4 offset header word
1220#    lw $t0,-8($s7) # get -8 offset header-word
1224#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
1225##...slt $at,$t0,$zero
1229##...beq $at,$zero,1248
1232#    and $t0,0xff # mask off object's hash value ...
1233##...lui $at,0
1237##...ori $at,$at,0xff
1241##...and $t0,$t0,$at
1244#    sw $t0,-8($s7) # ... and store back into -8 header-word
1248:skipMask_toString:
1248#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
1252#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1256#    subu $t4,$t2,$t5
1260:toString_copyLoop:    
1260#    lb $t3,($t4)
1264#    and $t3,0x7f # mask off sign bit (in case first word)
1265##...lui $at,0
1269##...ori $at,$at,0x7f
1273##...and $t3,$t3,$at
1276#    sb $t3,-8($t0)
1280#    addu $t4,1
1284#    addu $t0,1
1288#    blt $t4,$t2,toString_copyLoop
1289##...slt $at,$t4,$t2
1293##...bne $at,$zero,1260

    # copy the '@' sign
1296#    li $t3,'@'
1300#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1304#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1308#    lw $t3,20($sp) # hash code to print
1312:toString_hashCopyLoop:
1312#    and $t4,$t3,0xf
1316#    srl $t3,4
1320#    lb $t4,hexChars($t4)
1324#    sb $t4,-8($t2)
1328#    subu $t2,$t2,1
1332#    bgt $t2,$t0,toString_hashCopyLoop
1333##...slt $at,$t0,$t2
1337##...bne $at,$zero,1312

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1340#    addu $sp,28
1344#    lw $ra,($sp)
1348#    addu $sp,4
1352#    move $t0, $s7 # return string we created
1356#    jr $ra

    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3640#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3641##...slt $at,$t8,$zero
3645##...beq $at,$zero,3660
3648#    and $t8,0xff # mask off hash bits
3649##...lui $at,0
3653##...ori $at,$at,0xff
3657##...and $t8,$t8,$at

3660:  gcSkip5:
3660#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3664#    addu $t8,$t8,8 # ... add in bytes for header-words
3668#    subu $t4,$t1,$t8 # address of first word of source object
3672#    lw $t3,-4($t1) # # words in positive-offset portion
3676#    bge $t3,$zero,gcNoNeg
3677##...slt $at,$t3,$zero
3681##...beq $at,$zero,3688
3684#    move $t3,$zero # negative treated as zero
3688:  gcNoNeg:
3688#    sll $t3,$t3,2 # bytes in negative-offset portion
3692#    addu $t3,$t3,$t1 # address one word past last word of source

3696#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3700#    lw $s0,($t4)
3704#    lw $t9,-8($t1)
3708#    sw $t9,($t4)
3712#    sw $s0,-8($t1)

    # copy all source bytes to the target
3716:  gCinnerCopy2:
3716#    lw $s0,($t4)
3720#    sw $s0,($s3)
3724#    addu $t4,$t4,4
3728#    addu $s3,$s3,4
3732#    bltu $t4,$t3,gCinnerCopy2
3733##...sltu $at,$t4,$t3
3737##...bne $at,$zero,3716

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3740#    sw $zero,-8($t1) # 0 in first header-slot
3744#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3748#    sw $t8,($t0)

3752:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3752#    addu $t0,$t0,4
3756#    bltu $t0,$s1,gcNextPointerInObject
3757##...sltu $at,$t0,$s1
3761##...bne $at,$zero,3600

3764:  gcTestIterDone2:
3764#    bltu $t0,$s3,gcHeapCopyLoop
3765##...sltu $at,$t0,$s3
3769##...bne $at,$zero,3484

    ###### end outer loop to copy all non-stack-direct objects ######

3772:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3772#    lw $s2,($sp)
3776#    addu $sp,$sp,4

    # mark us as having already GC'd
3780#    move $t5,$s5

    # go try and allocate again
3784#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3788:vm_init:

    # mark bottom of stack
3788#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3792#    move $s2,$zero

    #set up the "five" register
3796#    li $s5,5

3800#    la $s3,seg0_start
3804#    la $s4,seg0_end
3805##...lui $s4,16
3809##...addiu $s4,$s4,4600
    
    # return
3812#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3816:divide:
    # get parameters; abort if divisor zero
3816#    lw $t0,($sp)
3820#    lw $t1,8($sp)
3824#    beq $t0,$zero,divByZeroError
    
    # perform division
3828#    div $t1,$t0
3832#    mflo $t0

    # store result, adjust stack and return
3836#    addu $sp,$sp,8 # adjust stack
3840#    sw $t0,($sp) # store result
3844#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3848:remainder:
    # get parameters; abort if divisor zero
3848#    lw $t0,($sp)
3852#    lw $t1,8($sp)
3856#    beq $t0,$zero,divByZeroError
    
    # perform division
3860#    div $t1,$t0
3864#    mfhi $t0

    # store result, adjust stack and return
3868#    addu $sp,$sp,8 # adjust stack
3872#    sw $t0,($sp) # store result
3876#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3880:checkCast:
    # get object, allow immediately if null
3880#    lw $t2,($sp)
3884#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3888#    lw $t2,-12($t2) # vtable address
3892#    bge $t2,$t1,castException
3893##...slt $at,$t2,$t1
3897##...beq $at,$zero,4032
3900#    blt $t2,$t0,castException
3901##...slt $at,$t2,$t0
3905##...bne $at,$zero,4032
    
    # return, leaving object unchanged on stack
3908:  checkCastReturn:    
3908#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3912:instanceOf:
    # get object, go return false if null
3912#    lw $t2,($sp)
3916#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3920#    lw $t2,-12($t2) # vtable address
3924#    sge $t0,$t2,$t0 # are we >= the lower limit?
3925##...slt $t0,$t2,$t0
3929##...xori $t0,$t0,0x1
3932#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3936#    and $t2,$t0,$t1
3940#    sw $t2,($sp)
3944:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3944#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3948:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3948#    li $v0,4 # syscall-code for print-string
3952#    syscall
3956:exit:
    # print termination message
3956#    li $v0,4 # syscall-code for print-string
3960#    la $a0,exitString
3964#    syscall

    # terminate execution
3968#    li $v0,10 #syscall-code for "exit"
3972#    syscall

3976:outOfHeapMemory:
3976#    la $a0,heapMemoryMsg
3980#    j exitError
3984:divByZeroError:
3984#    la $a0,divByZeroMsg
3988#    j exitError
3992:strIndexOutOfBounds:
3992#    la $a0,strIndexOutOfBoundsMsg
3996#    j exitError
4000:arrayIndexOutOfBounds:
4000#    la $a0,arrayIndexOutOfBoundsMsg
4004#    j exitError
4008:arraySizeOutOfBounds:
4008#    la $a0,arraySizeOutOfBoundsMsg
4012#    j exitError
4016:nullPtrException:
4016#    la $a0,nullPtrExceptionMsg
4020#    j exitError
4024:badIntegerFormat:
4024#    la $a0,badIntegerFormatMsg
4028#    j exitError
4032:castException:
4032#    la $a0,castExceptionMsg
4036#    j exitError
############## data section ################
    .data
4236:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4252:cur_seg:
    .word 0

4256:lastCharRead:
    .word -2 # -2 => no buffered character
4260:prevHashConstant:
    .word 0x2785173c
4264:gcCount:
    .word 0

4268:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4295:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4318:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4353:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4387:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4420:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4451:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4499:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4520:gcMsg: 
      .asciiz "\nGC!\n"
4526:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4558:nullStr:
    .asciiz "null"
4563:trueString:
    .asciiz "true"
4568:falseString:
    .asciiz "false"
4574:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4593:newlineString:
    .asciiz "\n"
    
    .align 2
4596:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4600:seg0_start:
    .space 0x100000
1053176:seg0_end:
1053176:seg1_start:
    .space 0x100000
2101752:seg1_end:

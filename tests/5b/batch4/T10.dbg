##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
432:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
432#    lw $t0,-8($s2) # get word with hash bits from this
436#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
440#    addu $t0,$t1

444#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
448:mth_equals_Object:
448#    move $t0,$s2 # first pointer (this)
452#    lw $t1,($sp) # second pointer
456#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
457##...subu $at,$t0,$t1
461##...sltiu $t0,$at,1

464#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
468:mth_hashCode_String:
468#    move $t0,$s2 # put this pointer in t0

472#    li $t2,0 # current hash value
476#    lw $t1,-4($t0) # negative of number of characters in string
480#    beq $t1,$zero,done_hashCode_String # if zero length => done
484#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
488#    and $t0,0xfffffffc # adjust for padding
489##...lui $at,65535
493##...ori $at,$at,0xfffc
497##...and $t0,$t0,$at
500#    subu $t1,$t0,$t1 # address at end of string +12
504:loop_hashCode_String:    
504#    sll $t4,$t2,5 # multiply by 32
508#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
512#    lbu $t3,-12($t0) # current character
516#    addu $t2,$t3 # add in current character
520#    addu $t0,1 # go to next character's address
524#    bne $t0,$t1,loop_hashCode_String # loop back if more
528:done_hashCode_String:    

    # push int on stack
528#    move $t0, $t2 # put $t2 in return slot
532#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
536:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
536#    subu $sp,4
540#    sw $ra,($sp)
    
    # get hash value
544#    lw $t2,-12($s2) # vtable address
548#    lw $t0,($t2) # method address
552#    jalr $t0
556#    subu $sp,8 # push result (int in $t0) on stack
560#    sw $s5,4($sp)
564#    sw $t0,($sp)

    # compute print-size of hash value
568#    li $t0, 1
572#    lw $t1, ($sp)
576#    srl $t1,$t1,4
580#    beq $t1,$zero,toString_skip_loop
584:toString_loop_top:
584#    addu $t0,1
588#    srl $t1,$t1,4
592#    bne $t1,$zero,toString_loop_top
596:toString_skip_loop:
596#    subu $sp,8
600#    sw $s5,4($sp)
604#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
608#    lw $t2,-12($s2) # vtable address
612#    move $t0,$t2
616:toString_checkTagBit:
616#    subu $t0,1
620#    lb $t1,($t0)
624#    and $t1,0x80
625##...lui $at,0
629##...ori $at,$at,0x80
633##...and $t1,$t1,$at
636#    beq $t1,$zero,toString_checkTagBit
640#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
644#    subu $sp,8
648#    sw $t1,($sp)
652#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
656#    move $s7,$zero # -4 offset header word
660#    lw $t4,8($sp) # bytes for hash value
664#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
668#    addu $t4,8
672#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
676#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

680#    li $t0,CLASS_String # store string vtable address into ...
684#    sw $t0,-12($s7) # ... -12 offset in object header
688#    lw $t2,-12($s2) # our object's vtable address
692#    lw $t5,4($sp) # number characters in prefix
696#    lw $t1,12($sp) # number of characters in hashcode
700#    addu $t3,$t1,$t5 # number of characters in string ...
704#    addu $t3,1 # ... including the '@' character
708#    subu $t0,$zero,$t3 # store negated length into ...
712#    sw $t0,-4($s7) # ... -4 offset header word
716#    lw $t0,-8($s7) # get -8 offset header-word
720#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
721##...slt $at,$t0,$zero
725##...beq $at,$zero,744
728#    and $t0,0xff # mask off object's hash value ...
729##...lui $at,0
733##...ori $at,$at,0xff
737##...and $t0,$t0,$at
740#    sw $t0,-8($s7) # ... and store back into -8 header-word
744:skipMask_toString:
744#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
748#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
752#    subu $t4,$t2,$t5
756:toString_copyLoop:    
756#    lb $t3,($t4)
760#    and $t3,0x7f # mask off sign bit (in case first word)
761##...lui $at,0
765##...ori $at,$at,0x7f
769##...and $t3,$t3,$at
772#    sb $t3,-8($t0)
776#    addu $t4,1
780#    addu $t0,1
784#    blt $t4,$t2,toString_copyLoop
785##...slt $at,$t4,$t2
789##...bne $at,$zero,756

    # copy the '@' sign
792#    li $t3,'@'
796#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
800#    addu $t2,$t0,$t1 # address of last byte in string to store +8
804#    lw $t3,20($sp) # hash code to print
808:toString_hashCopyLoop:
808#    and $t4,$t3,0xf
812#    srl $t3,4
816#    lb $t4,hexChars($t4)
820#    sb $t4,-8($t2)
824#    subu $t2,$t2,1
828#    bgt $t2,$t0,toString_hashCopyLoop
829##...slt $at,$t0,$t2
833##...bne $at,$zero,808

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
836#    addu $sp,28
840#    lw $ra,($sp)
844#    addu $sp,4
848#    move $t0, $s7 # return string we created
852#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
856:mth_equals_String:
    
    # quick test for obvious false
856#    lw $t0,($sp) # second parameter
860#    beq $t0,$zero,goEsFalse # go return false if null
864#    lw $t1,-12($t0) # vtable pointer
868#    la $t2,CLASS_String # string vtable pointer
872#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
876#    subu $sp,12
880#    sw $ra,8($sp)
884#    sw $s2,4($sp)
888#    sw $t0,($sp)
892#    jal mth_compareTo_String
896#    lw $s2, 4($sp) #restore this pointer and pop parameters
900#    addu $sp, 8 # pop parameters


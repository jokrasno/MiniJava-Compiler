###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
940:mth_readLine_Lib:
    
940#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
944#    sw $ra, 4($sp) # save $ra
948#    move $t1,$sp # save "original" sp

952:  doRead:

    # read the character
952#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
956#    subu $t2,$v0,13
960#    bne $t2,$zero,notReturnRL
964#    jal readLogicalChar
968#    subu $t2,$v0,10 # check for newline
972#    beq $t2,$zero,foundNewLine
976#    sw $v0,lastCharRead # push back character into queue
980#    j foundNewLine # go process the line

984:  notReturnRL:

    # at this point, $v0 has our character

984#    subu $t0,$v0,10
988#    beq $t0,$zero,foundNewLine
992#    blt $v0,$zero,foundEof
993##...slt $at,$v0,$zero
997##...bne $at,$zero,1012

    # we have a character, so push it onto stack
1000#    subu $sp,$sp,4
1004#    sw $v0,($sp)

    # loop back up to get next character
1008#    j doRead

1012:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1012#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1016#    li $s7, 0 # return-value: null
1020#    j rlReturn # return

1024:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1024#    subu $t0,$t1,$sp # number of chars we read (times 4)
1028#    srl $s6,$t0,2 # number of words on stack with chars
1032#    subu $sp,$sp,4 # push char-count ...
1036#    sw $s6,($sp) # ... onto stack
1040#    addu $t2,$t0,5 # GC tag, incl. for count-word
1044#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1048#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1052#    srl $s6,$s6,2  # data words in object
1056#    move $s7,$zero # object words in object
1060#    jal newObject  # allocate space
    
    # store header words
1064#    la $t0,CLASS_String
1068#    sw $t0,-12($s7)# store class tag (String) into object
1072#    lw $t2,4($sp) # char-count
1076#    sll $t1,$t2,2 # 4 times number of chars
1080#    subu $t2,$zero,$t2 # negative of char-count
1084#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1088#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1092#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1093##...slt $at,$t0,$zero
1097##...beq $at,$zero,1116
1100#    and $t0,0xff # mask off object's hash value ...
1101##...lui $at,0
1105##...ori $at,$at,0xff
1109##...and $t0,$t0,$at
1112#    sw $t0,-8($s7) # ... and store back into -8 header-word
1116:  skipMask_readLine:

1116#    sll $t0,$t0,2 # data bytes in object
1120#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1124#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1128#    addu $sp,$sp,8 # pop redundant object-pointer and count
1132#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1136#    beq $sp,$t1,rlReturn
1140:  charCopyLoop:
1140#    lw $t2,($sp)
1144#    sb $t2,-9($t0)
1148#    addu $sp,$sp,4
1152#    subu $t0,$t0,1
1156#    bne $sp,$t1,charCopyLoop
1160:  rlReturn:

1160#    lw $ra, 4($sp)
1164#    addu $sp, 8   # pop $ra and pointless word off stack
1168#    move $t0, $s7 # return string we allocated in $s7
1172#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1176:mth_readInt_Lib:

    # save $ra by pushing onto stack
1176#    subu $sp,$sp,4
1180#    sw $ra,($sp)

1184:  riSkipWhiteLoop:
    # read a character
1184#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1188#    subu $t0,$v0,32
1192#    bgt $t0,$zero,nonWhite
1193##...slt $at,$zero,$t0
1197##...bne $at,$zero,1240
1200#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1204#    subu $t0,$v0,10
1208#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1212#    subu $t0,$v0,9
1216#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1220#    subu $t0,$v0,13
1224#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1228#    subu $t0,$v0,12
1232#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1236#    j badIntegerFormat # illegal integer char: abort program

1240:  nonWhite:
1240#    subu $t0,$v0,'-'
1244#    li $t4,1 # final multiplier
1248#    bne $t0,$zero,helpReadInt # go read
1252#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1256#    jal readLogicalChar

1260:  helpReadInt:
1260#    li $t2,10
1264#    subu $t1,$v0,'0' # convert digit to 0-9 value
1268#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1269##...sltu $at,$t1,$t2
1273##...beq $at,$zero,3520
1276#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1280:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1280#    jal readLogicalChar # read next character
1284#    subu $t1,$v0,'0' # convert digit to 0-9 value
1288#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1289##...sltu $at,$t1,$t2
1293##...beq $at,$zero,1312

1296#    mul $t3,$t3,$t2 # multiply old value by 10
1297##...mult $t3,$t2
1301##...mflo $t3
1304#    addu $t3,$t3,$t1 # add in value of new digit
1308#    j digitLoop

1312:  doneDigitLoop:

    # "push back" unused character into queue
1312#    sw $v0,lastCharRead

    # restore return address
1316#    lw $ra,($sp)
1320#    addu $sp, 4

    # multiply by sign and put return value in $t0
1324#    mult $t3,$t4 # multiply to account for poss. minus sign
1328#    mflo $t3
1332#    move $t0, $t3
    
    # return
1336#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input

2549##...lui $at,4791
2553##...addiu $at,$at,-28718
2557##...addu $t1,$at,$t1
2560#    sw $t1,prevHashConstant # update hash constant
2564#    or $t1,0x80000000 # set top bit
2565##...lui $at,32768
2569##...or $t1,$at,$t1
2572#    and $t1,0xffffff00 # clear low bit
2573##...lui $at,65535
2577##...ori $at,$at,0xff00
2581##...and $t1,$t1,$at
2584#    or $s6,$t1
2588:firstHeaderLarge:
2588#    sw $s6,-8($t0) # store header-1 value
2592#    lw $zero,-8($t0)

    # store second header-value

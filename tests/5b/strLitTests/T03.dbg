##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
388:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
388#    lw $t0,-8($s2) # get word with hash bits from this
392#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
396#    addu $t0,$t1

400#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
404:mth_equals_Object:
404#    move $t0,$s2 # first pointer (this)
408#    lw $t1,($sp) # second pointer
412#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
413##...subu $at,$t0,$t1
417##...sltiu $t0,$at,1

420#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
424:mth_hashCode_String:
424#    move $t0,$s2 # put this pointer in t0

428#    li $t2,0 # current hash value
432#    lw $t1,-4($t0) # negative of number of characters in string
436#    beq $t1,$zero,done_hashCode_String # if zero length => done
440#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
444#    and $t0,0xfffffffc # adjust for padding
445##...lui $at,65535
449##...ori $at,$at,0xfffc
453##...and $t0,$t0,$at
456#    subu $t1,$t0,$t1 # address at end of string +12
460:loop_hashCode_String:    
460#    sll $t4,$t2,5 # multiply by 32
464#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
468#    lbu $t3,-12($t0) # current character
472#    addu $t2,$t3 # add in current character
476#    addu $t0,1 # go to next character's address
480#    bne $t0,$t1,loop_hashCode_String # loop back if more
484:done_hashCode_String:    

    # push int on stack
484#    move $t0, $t2 # put $t2 in return slot
488#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
492:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
492#    subu $sp,4
496#    sw $ra,($sp)
    
    # get hash value
500#    lw $t2,-12($s2) # vtable address
504#    lw $t0,($t2) # method address
508#    jalr $t0
512#    subu $sp,8 # push result (int in $t0) on stack
516#    sw $s5,4($sp)
520#    sw $t0,($sp)

    # compute print-size of hash value
524#    li $t0, 1
528#    lw $t1, ($sp)
532#    srl $t1,$t1,4
536#    beq $t1,$zero,toString_skip_loop
540:toString_loop_top:
540#    addu $t0,1
544#    srl $t1,$t1,4
548#    bne $t1,$zero,toString_loop_top
552:toString_skip_loop:
552#    subu $sp,8
556#    sw $s5,4($sp)
560#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
564#    lw $t2,-12($s2) # vtable address
568#    move $t0,$t2
572:toString_checkTagBit:
572#    subu $t0,1
576#    lb $t1,($t0)
580#    and $t1,0x80
581##...lui $at,0
585##...ori $at,$at,0x80
589##...and $t1,$t1,$at
592#    beq $t1,$zero,toString_checkTagBit
596#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
600#    subu $sp,8
604#    sw $t1,($sp)
608#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
612#    move $s7,$zero # -4 offset header word
616#    lw $t4,8($sp) # bytes for hash value
620#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
624#    addu $t4,8
628#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
632#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

636#    li $t0,CLASS_String # store string vtable address into ...
640#    sw $t0,-12($s7) # ... -12 offset in object header
644#    lw $t2,-12($s2) # our object's vtable address
648#    lw $t5,4($sp) # number characters in prefix
652#    lw $t1,12($sp) # number of characters in hashcode
656#    addu $t3,$t1,$t5 # number of characters in string ...
660#    addu $t3,1 # ... including the '@' character
664#    subu $t0,$zero,$t3 # store negated length into ...
668#    sw $t0,-4($s7) # ... -4 offset header word
672#    lw $t0,-8($s7) # get -8 offset header-word
676#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
677##...slt $at,$t0,$zero
681##...beq $at,$zero,700
684#    and $t0,0xff # mask off object's hash value ...
685##...lui $at,0
689##...ori $at,$at,0xff
693##...and $t0,$t0,$at
696#    sw $t0,-8($s7) # ... and store back into -8 header-word
700:skipMask_toString:
700#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
704#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
708#    subu $t4,$t2,$t5
712:toString_copyLoop:    
712#    lb $t3,($t4)
716#    and $t3,0x7f # mask off sign bit (in case first word)
717##...lui $at,0
721##...ori $at,$at,0x7f
725##...and $t3,$t3,$at
728#    sb $t3,-8($t0)
732#    addu $t4,1
736#    addu $t0,1
740#    blt $t4,$t2,toString_copyLoop
741##...slt $at,$t4,$t2
745##...bne $at,$zero,712

    # copy the '@' sign
748#    li $t3,'@'
752#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
756#    addu $t2,$t0,$t1 # address of last byte in string to store +8
760#    lw $t3,20($sp) # hash code to print
764:toString_hashCopyLoop:
764#    and $t4,$t3,0xf
768#    srl $t3,4
772#    lb $t4,hexChars($t4)
776#    sb $t4,-8($t2)
780#    subu $t2,$t2,1
784#    bgt $t2,$t0,toString_hashCopyLoop
785##...slt $at,$t0,$t2
789##...bne $at,$zero,764

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
792#    addu $sp,28
796#    lw $ra,($sp)
800#    addu $sp,4
804#    move $t0, $s7 # return string we created
808#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
812:mth_equals_String:
    
    # quick test for obvious false
812#    lw $t0,($sp) # second parameter
816#    beq $t0,$zero,goEsFalse # go return false if null
820#    lw $t1,-12($t0) # vtable pointer
824#    la $t2,CLASS_String # string vtable pointer
828#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
832#    subu $sp,12
836#    sw $ra,8($sp)
840#    sw $s2,4($sp)
844#    sw $t0,($sp)
848#    jal mth_compareTo_String
852#    lw $s2, 4($sp) #restore this pointer and pop parameters
856#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
860#    seq $t0,$t0,$zero
861##...subu $at,$t0,$zero
865##...sltiu $t0,$at,1

    # pop return address and return $t0
868#    lw $ra,($sp)
872#    addu $sp,4


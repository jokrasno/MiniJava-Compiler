###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
896:mth_readLine_Lib:
    
896#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
900#    sw $ra, 4($sp) # save $ra
904#    move $t1,$sp # save "original" sp

908:  doRead:

    # read the character
908#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
912#    subu $t2,$v0,13
916#    bne $t2,$zero,notReturnRL
920#    jal readLogicalChar
924#    subu $t2,$v0,10 # check for newline
928#    beq $t2,$zero,foundNewLine
932#    sw $v0,lastCharRead # push back character into queue
936#    j foundNewLine # go process the line

940:  notReturnRL:

    # at this point, $v0 has our character

940#    subu $t0,$v0,10
944#    beq $t0,$zero,foundNewLine
948#    blt $v0,$zero,foundEof
949##...slt $at,$v0,$zero
953##...bne $at,$zero,968

    # we have a character, so push it onto stack
956#    subu $sp,$sp,4
960#    sw $v0,($sp)

    # loop back up to get next character
964#    j doRead

968:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
968#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
972#    li $s7, 0 # return-value: null
976#    j rlReturn # return

980:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
980#    subu $t0,$t1,$sp # number of chars we read (times 4)
984#    srl $s6,$t0,2 # number of words on stack with chars
988#    subu $sp,$sp,4 # push char-count ...
992#    sw $s6,($sp) # ... onto stack
996#    addu $t2,$t0,5 # GC tag, incl. for count-word
1000#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1004#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1008#    srl $s6,$s6,2  # data words in object
1012#    move $s7,$zero # object words in object
1016#    jal newObject  # allocate space
    
    # store header words
1020#    la $t0,CLASS_String
1024#    sw $t0,-12($s7)# store class tag (String) into object
1028#    lw $t2,4($sp) # char-count
1032#    sll $t1,$t2,2 # 4 times number of chars
1036#    subu $t2,$zero,$t2 # negative of char-count
1040#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1044#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1048#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1049##...slt $at,$t0,$zero
1053##...beq $at,$zero,1072
1056#    and $t0,0xff # mask off object's hash value ...
1057##...lui $at,0
1061##...ori $at,$at,0xff
1065##...and $t0,$t0,$at
1068#    sw $t0,-8($s7) # ... and store back into -8 header-word
1072:  skipMask_readLine:

1072#    sll $t0,$t0,2 # data bytes in object
1076#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1080#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1084#    addu $sp,$sp,8 # pop redundant object-pointer and count
1088#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1092#    beq $sp,$t1,rlReturn
1096:  charCopyLoop:
1096#    lw $t2,($sp)
1100#    sb $t2,-9($t0)
1104#    addu $sp,$sp,4
1108#    subu $t0,$t0,1
1112#    bne $sp,$t1,charCopyLoop
1116:  rlReturn:

1116#    lw $ra, 4($sp)
1120#    addu $sp, 8   # pop $ra and pointless word off stack
1124#    move $t0, $s7 # return string we allocated in $s7
1128#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1132:mth_readInt_Lib:

    # save $ra by pushing onto stack
1132#    subu $sp,$sp,4
1136#    sw $ra,($sp)

1140:  riSkipWhiteLoop:
    # read a character
1140#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1144#    subu $t0,$v0,32
1148#    bgt $t0,$zero,nonWhite
1149##...slt $at,$zero,$t0
1153##...bne $at,$zero,1196
1156#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1160#    subu $t0,$v0,10
1164#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1168#    subu $t0,$v0,9
1172#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1176#    subu $t0,$v0,13
1180#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1184#    subu $t0,$v0,12
1188#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1192#    j badIntegerFormat # illegal integer char: abort program

1196:  nonWhite:
1196#    subu $t0,$v0,'-'
1200#    li $t4,1 # final multiplier
1204#    bne $t0,$zero,helpReadInt # go read
1208#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1212#    jal readLogicalChar

1216:  helpReadInt:
1216#    li $t2,10
1220#    subu $t1,$v0,'0' # convert digit to 0-9 value
1224#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1225##...sltu $at,$t1,$t2
1229##...beq $at,$zero,3476
1232#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1236:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1236#    jal readLogicalChar # read next character
1240#    subu $t1,$v0,'0' # convert digit to 0-9 value
1244#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1245##...sltu $at,$t1,$t2
1249##...beq $at,$zero,1268

1252#    mul $t3,$t3,$t2 # multiply old value by 10
1253##...mult $t3,$t2
1257##...mflo $t3
1260#    addu $t3,$t3,$t1 # add in value of new digit
1264#    j digitLoop

1268:  doneDigitLoop:

    # "push back" unused character into queue
1268#    sw $v0,lastCharRead

    # restore return address
1272#    lw $ra,($sp)
1276#    addu $sp, 4

    # multiply by sign and put return value in $t0
1280#    mult $t3,$t4 # multiply to account for poss. minus sign
1284#    mflo $t3
1288#    move $t0, $t3
    
    # return
1292#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input

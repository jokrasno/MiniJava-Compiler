########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3240:vm_init:

    # mark bottom of stack
3240#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3244#    move $s2,$zero

    #set up the "five" register
3248#    li $s5,5

3252#    la $s3,seg0_start
3256#    la $s4,seg0_end
3257##...lui $s4,16
3261##...addiu $s4,$s4,4056
    
    # return
3264#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3268:divide:
    # get parameters; abort if divisor zero
3268#    lw $t0,($sp)
3272#    lw $t1,8($sp)
3276#    beq $t0,$zero,divByZeroError
    
    # perform division
3280#    div $t1,$t0
3284#    mflo $t0

    # store result, adjust stack and return
3288#    addu $sp,$sp,8 # adjust stack
3292#    sw $t0,($sp) # store result
3296#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3300:remainder:
    # get parameters; abort if divisor zero
3300#    lw $t0,($sp)
3304#    lw $t1,8($sp)
3308#    beq $t0,$zero,divByZeroError
    
    # perform division
3312#    div $t1,$t0
3316#    mfhi $t0

    # store result, adjust stack and return
3320#    addu $sp,$sp,8 # adjust stack
3324#    sw $t0,($sp) # store result
3328#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3332:checkCast:
    # get object, allow immediately if null
3332#    lw $t2,($sp)
3336#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3340#    lw $t2,-12($t2) # vtable address
3344#    bge $t2,$t1,castException
3345##...slt $at,$t2,$t1
3349##...beq $at,$zero,3484
3352#    blt $t2,$t0,castException
3353##...slt $at,$t2,$t0
3357##...bne $at,$zero,3484
    
    # return, leaving object unchanged on stack
3360:  checkCastReturn:    
3360#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3364:instanceOf:
    # get object, go return false if null
3364#    lw $t2,($sp)
3368#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3372#    lw $t2,-12($t2) # vtable address
3376#    sge $t0,$t2,$t0 # are we >= the lower limit?
3377##...slt $t0,$t2,$t0
3381##...xori $t0,$t0,0x1
3384#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3388#    and $t2,$t0,$t1
3392#    sw $t2,($sp)
3396:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3396#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3400:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3400#    li $v0,4 # syscall-code for print-string
3404#    syscall
3408:exit:
    # print termination message
3408#    li $v0,4 # syscall-code for print-string
3412#    la $a0,exitString
3416#    syscall

    # terminate execution
3420#    li $v0,10 #syscall-code for "exit"
3424#    syscall

3428:outOfHeapMemory:
3428#    la $a0,heapMemoryMsg
3432#    j exitError
3436:divByZeroError:
3436#    la $a0,divByZeroMsg
3440#    j exitError
3444:strIndexOutOfBounds:
3444#    la $a0,strIndexOutOfBoundsMsg
3448#    j exitError
3452:arrayIndexOutOfBounds:
3452#    la $a0,arrayIndexOutOfBoundsMsg
3456#    j exitError
3460:arraySizeOutOfBounds:
3460#    la $a0,arraySizeOutOfBoundsMsg
3464#    j exitError
3468:nullPtrException:
3468#    la $a0,nullPtrExceptionMsg
3472#    j exitError
3476:badIntegerFormat:
3476#    la $a0,badIntegerFormatMsg
3480#    j exitError
3484:castException:
3484#    la $a0,castExceptionMsg
3488#    j exitError
############## data section ################
    .data
3692:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3708:cur_seg:
    .word 0

3712:lastCharRead:
    .word -2 # -2 => no buffered character
3716:prevHashConstant:
    .word 0x2785173c
3720:gcCount:
    .word 0

3724:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3751:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3774:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3809:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3843:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3876:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3907:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3955:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3976:gcMsg: 
      .asciiz "\nGC!\n"
3982:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4014:nullStr:
    .asciiz "null"
4019:trueString:
    .asciiz "true"
4024:falseString:
    .asciiz "false"
4030:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4049:newlineString:
    .asciiz "\n"
    
    .align 2
4052:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4056:seg0_start:
    .space 0x100000
1052632:seg0_end:
1052632:seg1_start:
    .space 0x100000
2101208:seg1_end:

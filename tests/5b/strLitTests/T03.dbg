2432#    lw $v0,lastCharRead
2436#    li $t0,-2
2440#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
2444#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2448#    jr $ra # return
    
2452:  doReadCh:

1504#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
1508#    lw $t2,-8($s7)   # data words in target string
1512#    sll $t2,$t2,2    # data bytes in target string
1516#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
256:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
256#    lw $t0,-8($s2) # get word with hash bits from this
260#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
264#    addu $t0,$t1

268#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
272:mth_equals_Object:
272#    move $t0,$s2 # first pointer (this)
276#    lw $t1,($sp) # second pointer
280#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
281##...subu $at,$t0,$t1
285##...sltiu $t0,$at,1

288#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
292:mth_hashCode_String:
292#    move $t0,$s2 # put this pointer in t0

296#    li $t2,0 # current hash value
300#    lw $t1,-4($t0) # negative of number of characters in string
304#    beq $t1,$zero,done_hashCode_String # if zero length => done
308#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
312#    and $t0,0xfffffffc # adjust for padding
313##...lui $at,65535
317##...ori $at,$at,0xfffc
321##...and $t0,$t0,$at
324#    subu $t1,$t0,$t1 # address at end of string +12
328:loop_hashCode_String:    
328#    sll $t4,$t2,5 # multiply by 32
332#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
336#    lbu $t3,-12($t0) # current character
340#    addu $t2,$t3 # add in current character
344#    addu $t0,1 # go to next character's address
348#    bne $t0,$t1,loop_hashCode_String # loop back if more
352:done_hashCode_String:    

    # push int on stack
352#    move $t0, $t2 # put $t2 in return slot
356#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
360:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
360#    subu $sp,4
364#    sw $ra,($sp)
    
    # get hash value
368#    lw $t2,-12($s2) # vtable address
372#    lw $t0,($t2) # method address
376#    jalr $t0
380#    subu $sp,8 # push result (int in $t0) on stack
384#    sw $s5,4($sp)
388#    sw $t0,($sp)

    # compute print-size of hash value
392#    li $t0, 1
396#    lw $t1, ($sp)
400#    srl $t1,$t1,4
404#    beq $t1,$zero,toString_skip_loop
408:toString_loop_top:
408#    addu $t0,1
412#    srl $t1,$t1,4
416#    bne $t1,$zero,toString_loop_top
420:toString_skip_loop:
420#    subu $sp,8
424#    sw $s5,4($sp)
428#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
432#    lw $t2,-12($s2) # vtable address
436#    move $t0,$t2
440:toString_checkTagBit:
440#    subu $t0,1
444#    lb $t1,($t0)
448#    and $t1,0x80
449##...lui $at,0
453##...ori $at,$at,0x80
457##...and $t1,$t1,$at
460#    beq $t1,$zero,toString_checkTagBit
464#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
468#    subu $sp,8
472#    sw $t1,($sp)
476#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
480#    move $s7,$zero # -4 offset header word
484#    lw $t4,8($sp) # bytes for hash value
488#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
492#    addu $t4,8
496#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
500#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

504#    li $t0,CLASS_String # store string vtable address into ...
508#    sw $t0,-12($s7) # ... -12 offset in object header
512#    lw $t2,-12($s2) # our object's vtable address
516#    lw $t5,4($sp) # number characters in prefix
520#    lw $t1,12($sp) # number of characters in hashcode
524#    addu $t3,$t1,$t5 # number of characters in string ...
528#    addu $t3,1 # ... including the '@' character
532#    subu $t0,$zero,$t3 # store negated length into ...
536#    sw $t0,-4($s7) # ... -4 offset header word
540#    lw $t0,-8($s7) # get -8 offset header-word
544#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
545##...slt $at,$t0,$zero
549##...beq $at,$zero,568
552#    and $t0,0xff # mask off object's hash value ...
553##...lui $at,0
557##...ori $at,$at,0xff
561##...and $t0,$t0,$at
564#    sw $t0,-8($s7) # ... and store back into -8 header-word
568:skipMask_toString:
568#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
572#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
576#    subu $t4,$t2,$t5
580:toString_copyLoop:    
580#    lb $t3,($t4)
584#    and $t3,0x7f # mask off sign bit (in case first word)
585##...lui $at,0
589##...ori $at,$at,0x7f
593##...and $t3,$t3,$at
596#    sb $t3,-8($t0)
600#    addu $t4,1
604#    addu $t0,1
608#    blt $t4,$t2,toString_copyLoop
609##...slt $at,$t4,$t2
613##...bne $at,$zero,580

    # copy the '@' sign
616#    li $t3,'@'
620#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
624#    addu $t2,$t0,$t1 # address of last byte in string to store +8
628#    lw $t3,20($sp) # hash code to print
632:toString_hashCopyLoop:
632#    and $t4,$t3,0xf
636#    srl $t3,4
640#    lb $t4,hexChars($t4)
644#    sb $t4,-8($t2)
648#    subu $t2,$t2,1
652#    bgt $t2,$t0,toString_hashCopyLoop
653##...slt $at,$t0,$t2
657##...bne $at,$zero,632

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
660#    addu $sp,28
664#    lw $ra,($sp)
668#    addu $sp,4
672#    move $t0, $s7 # return string we created
676#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
680:mth_equals_String:
    
    # quick test for obvious false
680#    lw $t0,($sp) # second parameter
684#    beq $t0,$zero,goEsFalse # go return false if null
688#    lw $t1,-12($t0) # vtable pointer
692#    la $t2,CLASS_String # string vtable pointer
696#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
700#    subu $sp,12
704#    sw $ra,8($sp)
708#    sw $s2,4($sp)
712#    sw $t0,($sp)
716#    jal mth_compareTo_String
720#    lw $s2, 4($sp) #restore this pointer and pop parameters
724#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
728#    seq $t0,$t0,$zero
729##...subu $at,$t0,$zero
733##...sltiu $t0,$at,1

    # pop return address and return $t0
736#    lw $ra,($sp)
740#    addu $sp,4

744#    jr $ra # return
    
748:goEsFalse:
    # put 0 in $t0 and return
748#    li $t0, 0
752#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
756:mth_toString_String:
    #we are a string, so return this.
756#    move $t0, $s2
760#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
764:mth_readLine_Lib:
    
764#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
768#    sw $ra, 4($sp) # save $ra
772#    move $t1,$sp # save "original" sp

776:  doRead:

    # read the character
776#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
780#    subu $t2,$v0,13
784#    bne $t2,$zero,notReturnRL
788#    jal readLogicalChar
792#    subu $t2,$v0,10 # check for newline
796#    beq $t2,$zero,foundNewLine
800#    sw $v0,lastCharRead # push back character into queue
804#    j foundNewLine # go process the line

808:  notReturnRL:

    # at this point, $v0 has our character

808#    subu $t0,$v0,10
812#    beq $t0,$zero,foundNewLine
816#    blt $v0,$zero,foundEof
817##...slt $at,$v0,$zero
821##...bne $at,$zero,836

    # we have a character, so push it onto stack
824#    subu $sp,$sp,4
828#    sw $v0,($sp)

    # loop back up to get next character
832#    j doRead

836:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
836#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
840#    li $s7, 0 # return-value: null
844#    j rlReturn # return

848:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
848#    subu $t0,$t1,$sp # number of chars we read (times 4)
852#    srl $s6,$t0,2 # number of words on stack with chars
856#    subu $sp,$sp,4 # push char-count ...
860#    sw $s6,($sp) # ... onto stack
864#    addu $t2,$t0,5 # GC tag, incl. for count-word
868#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
872#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
876#    srl $s6,$s6,2  # data words in object
880#    move $s7,$zero # object words in object
884#    jal newObject  # allocate space
    
    # store header words
888#    la $t0,CLASS_String
892#    sw $t0,-12($s7)# store class tag (String) into object
896#    lw $t2,4($sp) # char-count
900#    sll $t1,$t2,2 # 4 times number of chars
904#    subu $t2,$zero,$t2 # negative of char-count
908#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
912#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
916#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
917##...slt $at,$t0,$zero
921##...beq $at,$zero,940
924#    and $t0,0xff # mask off object's hash value ...
925##...lui $at,0
929##...ori $at,$at,0xff
933##...and $t0,$t0,$at
936#    sw $t0,-8($s7) # ... and store back into -8 header-word
940:  skipMask_readLine:

940#    sll $t0,$t0,2 # data bytes in object
944#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
948#    subu $t0,$t0,$t2 # place to store last character (plus 9)
952#    addu $sp,$sp,8 # pop redundant object-pointer and count
956#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

960#    beq $sp,$t1,rlReturn
964:  charCopyLoop:
964#    lw $t2,($sp)
968#    sb $t2,-9($t0)
972#    addu $sp,$sp,4
976#    subu $t0,$t0,1
980#    bne $sp,$t1,charCopyLoop
984:  rlReturn:

984#    lw $ra, 4($sp)
988#    addu $sp, 8   # pop $ra and pointless word off stack
992#    move $t0, $s7 # return string we allocated in $s7
996#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1000:mth_readInt_Lib:

    # save $ra by pushing onto stack
1000#    subu $sp,$sp,4
1004#    sw $ra,($sp)

1008:  riSkipWhiteLoop:
    # read a character
1008#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1012#    subu $t0,$v0,32
1016#    bgt $t0,$zero,nonWhite
1017##...slt $at,$zero,$t0
1021##...bne $at,$zero,1064
1024#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1028#    subu $t0,$v0,10
1032#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1036#    subu $t0,$v0,9
1040#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1044#    subu $t0,$v0,13
1048#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1052#    subu $t0,$v0,12
1056#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1060#    j badIntegerFormat # illegal integer char: abort program

1064:  nonWhite:
1064#    subu $t0,$v0,'-'
1068#    li $t4,1 # final multiplier
1072#    bne $t0,$zero,helpReadInt # go read
1076#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1080#    jal readLogicalChar

1084:  helpReadInt:
1084#    li $t2,10
1088#    subu $t1,$v0,'0' # convert digit to 0-9 value
1092#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1093##...sltu $at,$t1,$t2
1097##...beq $at,$zero,3344
1100#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1104:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1104#    jal readLogicalChar # read next character
1108#    subu $t1,$v0,'0' # convert digit to 0-9 value
1112#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1113##...sltu $at,$t1,$t2
1117##...beq $at,$zero,1136

1120#    mul $t3,$t3,$t2 # multiply old value by 10
1121##...mult $t3,$t2
1125##...mflo $t3
1128#    addu $t3,$t3,$t1 # add in value of new digit
1132#    j digitLoop

1136:  doneDigitLoop:

    # "push back" unused character into queue
1136#    sw $v0,lastCharRead

    # restore return address
1140#    lw $ra,($sp)
1144#    addu $sp, 4

    # multiply by sign and put return value in $t0
1148#    mult $t3,$t4 # multiply to account for poss. minus sign
1152#    mflo $t3
1156#    move $t0, $t3
    
    # return
1160#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer

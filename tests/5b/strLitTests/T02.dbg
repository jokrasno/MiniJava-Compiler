    # get pointers set up in preparation for copy
1488#    lw $t4,-8($t3) # data words in source string
1492#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
1496#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)

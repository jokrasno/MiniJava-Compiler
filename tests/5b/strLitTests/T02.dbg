    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
1592#    lw $t0,-4($t0) # negative size of second object
1596#    lw $t1,-4($t1) # negative size of first object
1600#    addu $s6,$t0,$t1 # sum of negative sizes
1604#    sra $s6,$s6,2 # negative word-size of char part
1608#    subu $s6,$zero,$s6 # word size of char part

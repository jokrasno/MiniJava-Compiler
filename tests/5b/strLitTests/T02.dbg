1616#    move $s7,$zero
1620#    jal newObject

    # store String vtable address in vtable address field
1624#    la $t0,CLASS_String
1628#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
1632#    lw $t4,-8($s7) # # data words in source string
1636#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
1637##...slt $at,$t4,$zero
1641##...beq $at,$zero,1660
1644#    and $t4,0xff # mask off object's hash value ...
1645##...lui $at,0
1649##...ori $at,$at,0xff
1653##...and $t4,$t4,$at
1656#    sw $t4,-8($s7) # ... and store back into -8 header-word
1660:skipMask_concat:

1660#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
1664#    move $t1,$s2   # first object
1668#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
1672#    lw $t2,-4($t0) # negative length of second object
1676#    lw $t3,-4($t1) # negative length of first object
1680#    addu $t4,$t2,$t3 # sum of negative lengths
1684#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################

    # compute addresses for moving data from first string
1688#    lw $t4,-8($t1) # # data words in first string
1692#    sll $t4,$t4,2 # # data bytes in first string
1696#    subu $t1,$t1,$t4 # addr. (+8) of first byte in first string
1700#    lw $t4,-8($s7) # # data words in new string
1704#    sll $t4,$t4,2 # # data bytes in new string
1708#    subu $s7,$s7,$t4 # addr. (+8) of first byte in new string
1712#    beq $zero,$t3,doneConcatLoop1zz # skip first loop is no bytes to copy
1716#    subu $t3,$t1,$t3 # limit (+8) address for first string

    #########################################################

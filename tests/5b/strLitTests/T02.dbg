1441##...slt $at,$t4,$zero
1445##...beq $at,$zero,1464
1448#    and $t4,0xff # mask off object's hash value ...
1449##...lui $at,0
1453##...ori $at,$at,0xff
1457##...and $t4,$t4,$at
1460#    sw $t4,-8($s7) # ... and store back into -8 header-word
1464:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1464#    lw $t1,8($sp) # k
1468#    lw $t2,16($sp) # n
1472#    subu $t0,$t2,$t1 # value to store
1476#    sw $t0,-4($s7) # store value

    # allocate memory
1408#    subu $s6,$t1,$t2 # # chars in target-string
1412#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1416#    srl $s6,$s6,2 # convert bytes-count to word-count
1420#    move $s7,$zero # (no object-bytes in string)
1424#    jal newObject

    # store "String" tag in object-type field
1428#    la $t0,CLASS_String
1432#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
1436#    lw $t4,-8($s7) # data words in source string

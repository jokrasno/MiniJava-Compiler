########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3108:vm_init:

    # mark bottom of stack
3108#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3112#    move $s2,$zero

    #set up the "five" register
3116#    li $s5,5

3120#    la $s3,seg0_start
3124#    la $s4,seg0_end
3125##...lui $s4,16
3129##...addiu $s4,$s4,3920
    
    # return
3132#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3136:divide:
    # get parameters; abort if divisor zero
3136#    lw $t0,($sp)
3140#    lw $t1,8($sp)
3144#    beq $t0,$zero,divByZeroError
    
    # perform division
3148#    div $t1,$t0
3152#    mflo $t0

    # store result, adjust stack and return
3156#    addu $sp,$sp,8 # adjust stack
3160#    sw $t0,($sp) # store result
3164#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3168:remainder:
    # get parameters; abort if divisor zero
3168#    lw $t0,($sp)
3172#    lw $t1,8($sp)
3176#    beq $t0,$zero,divByZeroError
    
    # perform division
3180#    div $t1,$t0
3184#    mfhi $t0

    # store result, adjust stack and return
3188#    addu $sp,$sp,8 # adjust stack
3192#    sw $t0,($sp) # store result
3196#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3200:checkCast:
    # get object, allow immediately if null
3200#    lw $t2,($sp)
3204#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3208#    lw $t2,-12($t2) # vtable address
3212#    bge $t2,$t1,castException
3213##...slt $at,$t2,$t1
3217##...beq $at,$zero,3352
3220#    blt $t2,$t0,castException
3221##...slt $at,$t2,$t0
3225##...bne $at,$zero,3352
    
    # return, leaving object unchanged on stack
3228:  checkCastReturn:    
3228#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3232:instanceOf:
    # get object, go return false if null
3232#    lw $t2,($sp)
3236#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3240#    lw $t2,-12($t2) # vtable address
3244#    sge $t0,$t2,$t0 # are we >= the lower limit?
3245##...slt $t0,$t2,$t0
3249##...xori $t0,$t0,0x1
3252#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3256#    and $t2,$t0,$t1
3260#    sw $t2,($sp)
3264:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3264#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3268:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3268#    li $v0,4 # syscall-code for print-string
3272#    syscall
3276:exit:
    # print termination message
3276#    li $v0,4 # syscall-code for print-string
3280#    la $a0,exitString
3284#    syscall

    # terminate execution
3288#    li $v0,10 #syscall-code for "exit"
3292#    syscall

3296:outOfHeapMemory:
3296#    la $a0,heapMemoryMsg
3300#    j exitError
3304:divByZeroError:
3304#    la $a0,divByZeroMsg
3308#    j exitError
3312:strIndexOutOfBounds:
3312#    la $a0,strIndexOutOfBoundsMsg
3316#    j exitError
3320:arrayIndexOutOfBounds:
3320#    la $a0,arrayIndexOutOfBoundsMsg
3324#    j exitError
3328:arraySizeOutOfBounds:
3328#    la $a0,arraySizeOutOfBoundsMsg
3332#    j exitError
3336:nullPtrException:
3336#    la $a0,nullPtrExceptionMsg
3340#    j exitError
3344:badIntegerFormat:
3344#    la $a0,badIntegerFormatMsg
3348#    j exitError
3352:castException:
3352#    la $a0,castExceptionMsg
3356#    j exitError
############## data section ################
    .data
3556:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3572:cur_seg:
    .word 0

3576:lastCharRead:
    .word -2 # -2 => no buffered character
3580:prevHashConstant:
    .word 0x2785173c
3584:gcCount:
    .word 0

3588:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3615:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3638:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3673:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3707:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3740:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3771:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3819:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3840:gcMsg: 
      .asciiz "\nGC!\n"
3846:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3878:nullStr:
    .asciiz "null"
3883:trueString:
    .asciiz "true"
3888:falseString:
    .asciiz "false"
3894:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3913:newlineString:
    .asciiz "\n"
    
    .align 2
3916:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3920:seg0_start:
    .space 0x100000
1052496:seg0_end:
1052496:seg1_start:

2624#    addu $t0,$s6,$s7
2628#    sll $t0,$t0,2
2632#    addu $t0,$t0,8 # amount of memory needed
2636#    addu $t1,$t0,$s3
2640#    bgtu $t1,$s4,doGC
2641##...sltu $at,$s4,$t1
2645##...bne $at,$zero,2768

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
2648#    move $t2,$s3

3340#    sw $zero,-8($t1) # 0 in first header-slot
3344#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3348#    sw $t8,($t0)

3352:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3352#    addu $t0,$t0,4
3356#    bltu $t0,$s1,gcNextPointerInObject
3357##...sltu $at,$t0,$s1
3361##...bne $at,$zero,3200

3364:  gcTestIterDone2:
3364#    bltu $t0,$s3,gcHeapCopyLoop
3365##...sltu $at,$t0,$s3
3369##...bne $at,$zero,3084

    ###### end outer loop to copy all non-stack-direct objects ######

3372:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3372#    lw $s2,($sp)
3376#    addu $sp,$sp,4

    # mark us as having already GC'd
3380#    move $t5,$s5

    # go try and allocate again
3384#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3388:vm_init:

    # mark bottom of stack
3388#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3392#    move $s2,$zero

    #set up the "five" register
3396#    li $s5,5

3400#    la $s3,seg0_start
3404#    la $s4,seg0_end
3405##...lui $s4,16
3409##...addiu $s4,$s4,4240
    
    # return
3412#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3416:divide:
    # get parameters; abort if divisor zero
3416#    lw $t0,($sp)
3420#    lw $t1,8($sp)
3424#    beq $t0,$zero,divByZeroError
    
    # perform division
3428#    div $t1,$t0
3432#    mflo $t0

    # store result, adjust stack and return
3436#    addu $sp,$sp,8 # adjust stack
3440#    sw $t0,($sp) # store result
3444#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3448:remainder:
    # get parameters; abort if divisor zero
3448#    lw $t0,($sp)
3452#    lw $t1,8($sp)
3456#    beq $t0,$zero,divByZeroError
    
    # perform division
3460#    div $t1,$t0
3464#    mfhi $t0

    # store result, adjust stack and return
3468#    addu $sp,$sp,8 # adjust stack
3472#    sw $t0,($sp) # store result
3476#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3480:checkCast:
    # get object, allow immediately if null
3480#    lw $t2,($sp)
3484#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3488#    lw $t2,-12($t2) # vtable address
3492#    bge $t2,$t1,castException
3493##...slt $at,$t2,$t1
3497##...beq $at,$zero,3632
3500#    blt $t2,$t0,castException
3501##...slt $at,$t2,$t0
3505##...bne $at,$zero,3632
    
    # return, leaving object unchanged on stack
3508:  checkCastReturn:    
3508#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3512:instanceOf:
    # get object, go return false if null
3512#    lw $t2,($sp)
3516#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3520#    lw $t2,-12($t2) # vtable address
3524#    sge $t0,$t2,$t0 # are we >= the lower limit?
3525##...slt $t0,$t2,$t0
3529##...xori $t0,$t0,0x1
3532#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3536#    and $t2,$t0,$t1
3540#    sw $t2,($sp)
3544:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3544#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3548:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3548#    li $v0,4 # syscall-code for print-string
3552#    syscall
3556:exit:
    # print termination message
3556#    li $v0,4 # syscall-code for print-string
3560#    la $a0,exitString
3564#    syscall

    # terminate execution
3568#    li $v0,10 #syscall-code for "exit"
3572#    syscall

3576:outOfHeapMemory:
3576#    la $a0,heapMemoryMsg
3580#    j exitError
3584:divByZeroError:
3584#    la $a0,divByZeroMsg
3588#    j exitError
3592:strIndexOutOfBounds:
3592#    la $a0,strIndexOutOfBoundsMsg
3596#    j exitError
3600:arrayIndexOutOfBounds:
3600#    la $a0,arrayIndexOutOfBoundsMsg
3604#    j exitError
3608:arraySizeOutOfBounds:
3608#    la $a0,arraySizeOutOfBoundsMsg
3612#    j exitError
3616:nullPtrException:
3616#    la $a0,nullPtrExceptionMsg
3620#    j exitError
3624:badIntegerFormat:
3624#    la $a0,badIntegerFormatMsg
3628#    j exitError
3632:castException:
3632#    la $a0,castExceptionMsg
3636#    j exitError
############## data section ################
    .data
3876:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3892:cur_seg:
    .word 0

3896:lastCharRead:
    .word -2 # -2 => no buffered character
3900:prevHashConstant:
    .word 0x2785173c
3904:gcCount:
    .word 0

3908:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3935:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3958:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3993:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4027:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4060:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4091:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4139:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4160:gcMsg: 
      .asciiz "\nGC!\n"
4166:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4198:nullStr:
    .asciiz "null"
4203:trueString:
    .asciiz "true"
4208:falseString:
    .asciiz "false"
4214:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4233:newlineString:
    .asciiz "\n"
    
    .align 2
4236:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4240:seg0_start:
    .space 0x100000
1052816:seg0_end:
1052816:seg1_start:
    .space 0x100000
2101392:seg1_end:

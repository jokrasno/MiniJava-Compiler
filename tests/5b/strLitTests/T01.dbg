##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
536:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
536#    lw $t0,-8($s2) # get word with hash bits from this
540#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
544#    addu $t0,$t1

548#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
552:mth_equals_Object:
552#    move $t0,$s2 # first pointer (this)
556#    lw $t1,($sp) # second pointer
560#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
561##...subu $at,$t0,$t1
565##...sltiu $t0,$at,1

568#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
572:mth_hashCode_String:
572#    move $t0,$s2 # put this pointer in t0

576#    li $t2,0 # current hash value
580#    lw $t1,-4($t0) # negative of number of characters in string
584#    beq $t1,$zero,done_hashCode_String # if zero length => done
588#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
592#    and $t0,0xfffffffc # adjust for padding
593##...lui $at,65535
597##...ori $at,$at,0xfffc
601##...and $t0,$t0,$at
604#    subu $t1,$t0,$t1 # address at end of string +12
608:loop_hashCode_String:    
608#    sll $t4,$t2,5 # multiply by 32
612#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
616#    lbu $t3,-12($t0) # current character
620#    addu $t2,$t3 # add in current character
624#    addu $t0,1 # go to next character's address
628#    bne $t0,$t1,loop_hashCode_String # loop back if more
632:done_hashCode_String:    

    # push int on stack
632#    move $t0, $t2 # put $t2 in return slot
636#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
640:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
640#    subu $sp,4
644#    sw $ra,($sp)
    
    # get hash value
648#    lw $t2,-12($s2) # vtable address
652#    lw $t0,($t2) # method address
656#    jalr $t0
660#    subu $sp,8 # push result (int in $t0) on stack
664#    sw $s5,4($sp)
668#    sw $t0,($sp)

    # compute print-size of hash value
672#    li $t0, 1
676#    lw $t1, ($sp)
680#    srl $t1,$t1,4
684#    beq $t1,$zero,toString_skip_loop
688:toString_loop_top:
688#    addu $t0,1
692#    srl $t1,$t1,4
696#    bne $t1,$zero,toString_loop_top
700:toString_skip_loop:
700#    subu $sp,8
704#    sw $s5,4($sp)
708#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
712#    lw $t2,-12($s2) # vtable address
716#    move $t0,$t2
720:toString_checkTagBit:
720#    subu $t0,1
724#    lb $t1,($t0)
728#    and $t1,0x80
729##...lui $at,0
733##...ori $at,$at,0x80
737##...and $t1,$t1,$at
740#    beq $t1,$zero,toString_checkTagBit
744#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
748#    subu $sp,8
752#    sw $t1,($sp)
756#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
760#    move $s7,$zero # -4 offset header word
764#    lw $t4,8($sp) # bytes for hash value
768#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
772#    addu $t4,8
776#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
780#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

784#    li $t0,CLASS_String # store string vtable address into ...
788#    sw $t0,-12($s7) # ... -12 offset in object header
792#    lw $t2,-12($s2) # our object's vtable address
796#    lw $t5,4($sp) # number characters in prefix
800#    lw $t1,12($sp) # number of characters in hashcode
804#    addu $t3,$t1,$t5 # number of characters in string ...
808#    addu $t3,1 # ... including the '@' character
812#    subu $t0,$zero,$t3 # store negated length into ...
816#    sw $t0,-4($s7) # ... -4 offset header word
820#    lw $t0,-8($s7) # get -8 offset header-word
824#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
825##...slt $at,$t0,$zero
829##...beq $at,$zero,848
832#    and $t0,0xff # mask off object's hash value ...
833##...lui $at,0
837##...ori $at,$at,0xff
841##...and $t0,$t0,$at
844#    sw $t0,-8($s7) # ... and store back into -8 header-word
848:skipMask_toString:
848#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
852#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
856#    subu $t4,$t2,$t5
860:toString_copyLoop:    
860#    lb $t3,($t4)
864#    and $t3,0x7f # mask off sign bit (in case first word)
865##...lui $at,0
869##...ori $at,$at,0x7f
873##...and $t3,$t3,$at
876#    sb $t3,-8($t0)
880#    addu $t4,1
884#    addu $t0,1
888#    blt $t4,$t2,toString_copyLoop
889##...slt $at,$t4,$t2
893##...bne $at,$zero,860

    # copy the '@' sign
896#    li $t3,'@'
900#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called

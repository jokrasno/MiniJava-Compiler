1009##...subu $at,$t0,$zero
1013##...sltiu $t0,$at,1

    # pop return address and return $t0
1016#    lw $ra,($sp)
1020#    addu $sp,4

1024#    jr $ra # return
    
1028:goEsFalse:
    # put 0 in $t0 and return
1028#    li $t0, 0
1032#    jr $ra # return

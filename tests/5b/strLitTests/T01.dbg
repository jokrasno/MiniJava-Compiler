###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1044:mth_readLine_Lib:
    
1044#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1048#    sw $ra, 4($sp) # save $ra
1052#    move $t1,$sp # save "original" sp

1056:  doRead:

    # read the character
1056#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1060#    subu $t2,$v0,13
1064#    bne $t2,$zero,notReturnRL
1068#    jal readLogicalChar
1072#    subu $t2,$v0,10 # check for newline
1076#    beq $t2,$zero,foundNewLine
1080#    sw $v0,lastCharRead # push back character into queue
1084#    j foundNewLine # go process the line

1088:  notReturnRL:

    # at this point, $v0 has our character

1088#    subu $t0,$v0,10
1092#    beq $t0,$zero,foundNewLine
1096#    blt $v0,$zero,foundEof
1097##...slt $at,$v0,$zero
1101##...bne $at,$zero,1116

    # we have a character, so push it onto stack
1104#    subu $sp,$sp,4
1108#    sw $v0,($sp)

    # loop back up to get next character
1112#    j doRead

1116:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1116#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1120#    li $s7, 0 # return-value: null
1124#    j rlReturn # return

1128:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1128#    subu $t0,$t1,$sp # number of chars we read (times 4)
1132#    srl $s6,$t0,2 # number of words on stack with chars
1136#    subu $sp,$sp,4 # push char-count ...
1140#    sw $s6,($sp) # ... onto stack
1144#    addu $t2,$t0,5 # GC tag, incl. for count-word
1148#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1152#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1156#    srl $s6,$s6,2  # data words in object
1160#    move $s7,$zero # object words in object
1164#    jal newObject  # allocate space
    
    # store header words
1168#    la $t0,CLASS_String
1172#    sw $t0,-12($s7)# store class tag (String) into object
1176#    lw $t2,4($sp) # char-count
1180#    sll $t1,$t2,2 # 4 times number of chars
1184#    subu $t2,$zero,$t2 # negative of char-count
1188#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1192#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1196#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1197##...slt $at,$t0,$zero
1201##...beq $at,$zero,1220
1204#    and $t0,0xff # mask off object's hash value ...
1205##...lui $at,0
1209##...ori $at,$at,0xff
1213##...and $t0,$t0,$at
1216#    sw $t0,-8($s7) # ... and store back into -8 header-word
1220:  skipMask_readLine:

1220#    sll $t0,$t0,2 # data bytes in object
1224#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1228#    subu $t0,$t0,$t2 # place to store last character (plus 9)

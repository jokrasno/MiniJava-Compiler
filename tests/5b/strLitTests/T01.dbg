2805##...addiu $t6,$t6,4240
2808#    la $s3,seg0_start
2812#    la $s4,seg0_end
2813##...lui $s4,16
2817##...addiu $s4,$s4,4240
2820#    sw $zero,cur_seg
2824#    bne $t0,$zero,skipGc1
2828#    la $t6,seg0_start
2832#    la $s3,seg1_start
2833##...lui $s3,16
2837##...addiu $s3,$s3,4240
2840#    la $s4,seg1_end
2841##...lui $s4,32
2845##...addiu $s4,$s4,4240
2848#    sw $s5,cur_seg
2852:  skipGc1:
2852#    li $t5,0x80000000
2856#    lw $t0,stack_bottom
2860#    subu $t0,4

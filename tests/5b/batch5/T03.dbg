    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
3920#    lw $t1,-12($t2) # vtable pointer
3924#    li $t0,dataArrayVTableStart # address of vtable for first data array
3928#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
3929##...slt $at,$t1,$t0
3933##...bne $at,$zero,3952

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
3936:  skipToNextObj:
3936#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
3940#    sll $t1,$t1,2 # convert to byte-count
3944#    addu $t0,$t2,$t1 # skip over object
3948#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
3952:  gcNotDataArray:
3952#    lw $t3,-4($t2) # # object words (negative treated as zero)
3956#    bge $t3,$zero,gcH2Neg2
3957##...slt $at,$t3,$zero
3961##...beq $at,$zero,3968
3964#    move $t3,$zero
3968:  gcH2Neg2:
3968#    sll $t3,$t3,2 # # object bytes
3972#    move $t0,$t2 # address of first pointer in object
3976#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
3980#    beq $t0,$s1,gcTestIterDone2
    
3984:  gcNextPointerInObject:
    # get pointer from object
3984#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
3988#    bleu $t1,$t6,gcGoNextPointerSlot
3989##...sltu $at,$t6,$t1
3993##...beq $at,$zero,4136
3996#    bgtu $t1,$t7,gcGoNextPointerSlot
3997##...sltu $at,$t7,$t1
4001##...bne $at,$zero,4136

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4004#    lw $t8,-8($t1) # possible forwarding tag
4008#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
4012#    lw $t8,-4($t1) # forwarding pointer: object's new address
4016#    sw $t8,($t0) # update pointer in object
4020#    j gcGoNextPointerSlot # do next iteration

4024:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
4024#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
4025##...slt $at,$t8,$zero
4029##...beq $at,$zero,4044
4032#    and $t8,0xff # mask off hash bits
4033##...lui $at,0
4037##...ori $at,$at,0xff
4041##...and $t8,$t8,$at

4044:  gcSkip5:
4044#    sll $t8,$t8,2 # bytes in negative-offset portion ...
4048#    addu $t8,$t8,8 # ... add in bytes for header-words
4052#    subu $t4,$t1,$t8 # address of first word of source object
4056#    lw $t3,-4($t1) # # words in positive-offset portion
4060#    bge $t3,$zero,gcNoNeg
4061##...slt $at,$t3,$zero
4065##...beq $at,$zero,4072
4068#    move $t3,$zero # negative treated as zero
4072:  gcNoNeg:
4072#    sll $t3,$t3,2 # bytes in negative-offset portion
4076#    addu $t3,$t3,$t1 # address one word past last word of source

4080#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
4084#    lw $s0,($t4)
4088#    lw $t9,-8($t1)
4092#    sw $t9,($t4)
4096#    sw $s0,-8($t1)

    # copy all source bytes to the target
4100:  gCinnerCopy2:
4100#    lw $s0,($t4)
4104#    sw $s0,($s3)
4108#    addu $t4,$t4,4
4112#    addu $s3,$s3,4
4116#    bltu $t4,$t3,gCinnerCopy2
4117##...sltu $at,$t4,$t3
4121##...bne $at,$zero,4100

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
4124#    sw $zero,-8($t1) # 0 in first header-slot
4128#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
4132#    sw $t8,($t0)

4136:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
4136#    addu $t0,$t0,4
4140#    bltu $t0,$s1,gcNextPointerInObject
4141##...sltu $at,$t0,$s1
4145##...bne $at,$zero,3984

4148:  gcTestIterDone2:
4148#    bltu $t0,$s3,gcHeapCopyLoop
4149##...sltu $at,$t0,$s3
4153##...bne $at,$zero,3868

    ###### end outer loop to copy all non-stack-direct objects ######

4156:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
4156#    lw $s2,($sp)
4160#    addu $sp,$sp,4

    # mark us as having already GC'd
4164#    move $t5,$s5

    # go try and allocate again
4168#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
4172:vm_init:

    # mark bottom of stack
4172#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
4176#    move $s2,$zero

    #set up the "five" register
4180#    li $s5,5

4184#    la $s3,seg0_start
4188#    la $s4,seg0_end
4189##...lui $s4,16
4193##...addiu $s4,$s4,4984
    
    # return
4196#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4200:divide:
    # get parameters; abort if divisor zero
4200#    lw $t0,($sp)
4204#    lw $t1,8($sp)
4208#    beq $t0,$zero,divByZeroError
    
    # perform division
4212#    div $t1,$t0
4216#    mflo $t0

    # store result, adjust stack and return
4220#    addu $sp,$sp,8 # adjust stack
4224#    sw $t0,($sp) # store result
4228#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
4232:remainder:
    # get parameters; abort if divisor zero
4232#    lw $t0,($sp)
4236#    lw $t1,8($sp)
4240#    beq $t0,$zero,divByZeroError
    
    # perform division
4244#    div $t1,$t0
4248#    mfhi $t0

    # store result, adjust stack and return
4252#    addu $sp,$sp,8 # adjust stack
4256#    sw $t0,($sp) # store result
4260#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
4264:checkCast:
    # get object, allow immediately if null
4264#    lw $t2,($sp)
4268#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
4272#    lw $t2,-12($t2) # vtable address
4276#    bge $t2,$t1,castException
4277##...slt $at,$t2,$t1
4281##...beq $at,$zero,4416
4284#    blt $t2,$t0,castException
4285##...slt $at,$t2,$t0
4289##...bne $at,$zero,4416
    
    # return, leaving object unchanged on stack
4292:  checkCastReturn:    
4292#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
4296:instanceOf:
    # get object, go return false if null
4296#    lw $t2,($sp)
4300#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
4304#    lw $t2,-12($t2) # vtable address
4308#    sge $t0,$t2,$t0 # are we >= the lower limit?
4309##...slt $t0,$t2,$t0
4313##...xori $t0,$t0,0x1
4316#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
4320#    and $t2,$t0,$t1
4324#    sw $t2,($sp)
4328:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4328#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4332:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4332#    li $v0,4 # syscall-code for print-string
4336#    syscall
4340:exit:
    # print termination message
4340#    li $v0,4 # syscall-code for print-string
4344#    la $a0,exitString
4348#    syscall

    # terminate execution
4352#    li $v0,10 #syscall-code for "exit"
4356#    syscall

4360:outOfHeapMemory:
4360#    la $a0,heapMemoryMsg
4364#    j exitError
4368:divByZeroError:
4368#    la $a0,divByZeroMsg
4372#    j exitError
4376:strIndexOutOfBounds:
4376#    la $a0,strIndexOutOfBoundsMsg
4380#    j exitError
4384:arrayIndexOutOfBounds:
4384#    la $a0,arrayIndexOutOfBoundsMsg
4388#    j exitError
4392:arraySizeOutOfBounds:
4392#    la $a0,arraySizeOutOfBoundsMsg
4396#    j exitError
4400:nullPtrException:
4400#    la $a0,nullPtrExceptionMsg
4404#    j exitError
4408:badIntegerFormat:
4408#    la $a0,badIntegerFormatMsg
4412#    j exitError
4416:castException:
4416#    la $a0,castExceptionMsg
4420#    j exitError
############## data section ################
    .data
4620:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4636:cur_seg:
    .word 0

4640:lastCharRead:
    .word -2 # -2 => no buffered character
4644:prevHashConstant:
    .word 0x2785173c
4648:gcCount:
    .word 0

4652:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4679:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4702:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4737:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4771:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4804:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4835:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4883:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4904:gcMsg: 
      .asciiz "\nGC!\n"
4910:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4942:nullStr:
    .asciiz "null"
4947:trueString:
    .asciiz "true"
4952:falseString:
    .asciiz "false"
4958:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4977:newlineString:
    .asciiz "\n"
    
    .align 2
4980:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4984:seg0_start:
    .space 0x100000
1053560:seg0_end:
1053560:seg1_start:
    .space 0x100000
2102136:seg1_end:

    ################################################################

    # store the hex version of the hash value
1688#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1692#    lw $t3,20($sp) # hash code to print
1696:toString_hashCopyLoop:
1696#    and $t4,$t3,0xf
1700#    srl $t3,4
1704#    lb $t4,hexChars($t4)
1708#    sb $t4,-8($t2)

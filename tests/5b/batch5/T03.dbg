###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1828:mth_readLine_Lib:
    
1828#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1832#    sw $ra, 4($sp) # save $ra
1836#    move $t1,$sp # save "original" sp

1840:  doRead:

    # read the character
1840#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1844#    subu $t2,$v0,13
1848#    bne $t2,$zero,notReturnRL
1852#    jal readLogicalChar
1856#    subu $t2,$v0,10 # check for newline
1860#    beq $t2,$zero,foundNewLine
1864#    sw $v0,lastCharRead # push back character into queue
1868#    j foundNewLine # go process the line

1872:  notReturnRL:

    # at this point, $v0 has our character

1872#    subu $t0,$v0,10
1876#    beq $t0,$zero,foundNewLine
1880#    blt $v0,$zero,foundEof
1881##...slt $at,$v0,$zero
1885##...bne $at,$zero,1900

    # we have a character, so push it onto stack
1888#    subu $sp,$sp,4
1892#    sw $v0,($sp)

    # loop back up to get next character
1896#    j doRead

1900:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1900#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1904#    li $s7, 0 # return-value: null
1908#    j rlReturn # return

1912:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1912#    subu $t0,$t1,$sp # number of chars we read (times 4)
1916#    srl $s6,$t0,2 # number of words on stack with chars
1920#    subu $sp,$sp,4 # push char-count ...
1924#    sw $s6,($sp) # ... onto stack
1928#    addu $t2,$t0,5 # GC tag, incl. for count-word
1932#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1936#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1940#    srl $s6,$s6,2  # data words in object
1944#    move $s7,$zero # object words in object
1948#    jal newObject  # allocate space
    
    # store header words
1952#    la $t0,CLASS_String
1956#    sw $t0,-12($s7)# store class tag (String) into object
1960#    lw $t2,4($sp) # char-count
1964#    sll $t1,$t2,2 # 4 times number of chars
1968#    subu $t2,$zero,$t2 # negative of char-count
1972#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1976#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1980#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1981##...slt $at,$t0,$zero
1985##...beq $at,$zero,2004
1988#    and $t0,0xff # mask off object's hash value ...
1989##...lui $at,0
1993##...ori $at,$at,0xff
1997##...and $t0,$t0,$at
2000#    sw $t0,-8($s7) # ... and store back into -8 header-word
2004:  skipMask_readLine:

2004#    sll $t0,$t0,2 # data bytes in object
2008#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
2012#    subu $t0,$t0,$t2 # place to store last character (plus 9)
2016#    addu $sp,$sp,8 # pop redundant object-pointer and count
2020#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

2024#    beq $sp,$t1,rlReturn
2028:  charCopyLoop:
2028#    lw $t2,($sp)
2032#    sb $t2,-9($t0)
2036#    addu $sp,$sp,4
2040#    subu $t0,$t0,1
2044#    bne $sp,$t1,charCopyLoop
2048:  rlReturn:

2048#    lw $ra, 4($sp)
2052#    addu $sp, 8   # pop $ra and pointless word off stack
2056#    move $t0, $s7 # return string we allocated in $s7
2060#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2064:mth_readInt_Lib:

    # save $ra by pushing onto stack
2064#    subu $sp,$sp,4
2068#    sw $ra,($sp)

2072:  riSkipWhiteLoop:
    # read a character
2072#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
2076#    subu $t0,$v0,32
2080#    bgt $t0,$zero,nonWhite
2081##...slt $at,$zero,$t0
2085##...bne $at,$zero,2128
2088#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2092#    subu $t0,$v0,10
2096#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2100#    subu $t0,$v0,9
2104#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2108#    subu $t0,$v0,13
2112#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2116#    subu $t0,$v0,12
2120#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2124#    j badIntegerFormat # illegal integer char: abort program

2128:  nonWhite:
2128#    subu $t0,$v0,'-'
2132#    li $t4,1 # final multiplier
2136#    bne $t0,$zero,helpReadInt # go read
2140#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
2144#    jal readLogicalChar

2148:  helpReadInt:
2148#    li $t2,10
2152#    subu $t1,$v0,'0' # convert digit to 0-9 value
2156#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
2157##...sltu $at,$t1,$t2
2161##...beq $at,$zero,4408
2164#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

2168:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

2168#    jal readLogicalChar # read next character
2172#    subu $t1,$v0,'0' # convert digit to 0-9 value
2176#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
2177##...sltu $at,$t1,$t2
2181##...beq $at,$zero,2200

2184#    mul $t3,$t3,$t2 # multiply old value by 10
2185##...mult $t3,$t2
2189##...mflo $t3
2192#    addu $t3,$t3,$t1 # add in value of new digit
2196#    j digitLoop

2200:  doneDigitLoop:

    # "push back" unused character into queue
2200#    sw $v0,lastCharRead

    # restore return address
2204#    lw $ra,($sp)
2208#    addu $sp, 4

    # multiply by sign and put return value in $t0
2212#    mult $t3,$t4 # multiply to account for poss. minus sign
2216#    mflo $t3
2220#    move $t0, $t3
    
    # return
2224#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2228:mth_readChar_Lib:

    # save $ra by pushing onto stack
2228#    subu $sp,$sp,4
2232#    sw $ra,($sp)

      # read the character
2236#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
2240#    lw $ra,($sp)
2244#    addu $sp, 4
2248#    move $t0, $v0

    # return
2252#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
2256:mth_printStr_Lib:
    # check for null, printing "(null)", if so
2256#    lw $t0,($sp)
2260#    bne $t0,$zero,psNotNull

    # print "(null)"
2264#    la $a0,nullStr
2268#    li $v0,4
2272#    syscall
2276#    j donePrintStr
    
2280:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte

1636#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
1640#    subu $t4,$t2,$t5
1644:toString_copyLoop:    
1644#    lb $t3,($t4)
1648#    and $t3,0x7f # mask off sign bit (in case first word)
1649##...lui $at,0
1653##...ori $at,$at,0x7f
1657##...and $t3,$t3,$at
1660#    sb $t3,-8($t0)

1524#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
1528#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
1532#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
1536#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)

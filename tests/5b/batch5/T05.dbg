    
    # set "this" pointer to be null, for now
3144#    move $s2,$zero

    #set up the "five" register
3148#    li $s5,5

3152#    la $s3,seg0_start
3156#    la $s4,seg0_end
3157##...lui $s4,16
3161##...addiu $s4,$s4,4020
    
    # return
3164#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3168:divide:
    # get parameters; abort if divisor zero
3168#    lw $t0,($sp)
3172#    lw $t1,8($sp)
3176#    beq $t0,$zero,divByZeroError
    
    # perform division
3180#    div $t1,$t0
3184#    mflo $t0

    # store result, adjust stack and return
3188#    addu $sp,$sp,8 # adjust stack
3192#    sw $t0,($sp) # store result
3196#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3200:remainder:
    # get parameters; abort if divisor zero
3200#    lw $t0,($sp)
3204#    lw $t1,8($sp)
3208#    beq $t0,$zero,divByZeroError
    
    # perform division
3212#    div $t1,$t0
3216#    mfhi $t0

    # store result, adjust stack and return
3220#    addu $sp,$sp,8 # adjust stack
3224#    sw $t0,($sp) # store result
3228#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3232:checkCast:
    # get object, allow immediately if null
3232#    lw $t2,($sp)
3236#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3240#    lw $t2,-12($t2) # vtable address
3244#    bge $t2,$t1,castException
3245##...slt $at,$t2,$t1
3249##...beq $at,$zero,3384
3252#    blt $t2,$t0,castException
3253##...slt $at,$t2,$t0
3257##...bne $at,$zero,3384
    
    # return, leaving object unchanged on stack
3260:  checkCastReturn:    
3260#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3264:instanceOf:
    # get object, go return false if null
3264#    lw $t2,($sp)
3268#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3272#    lw $t2,-12($t2) # vtable address
3276#    sge $t0,$t2,$t0 # are we >= the lower limit?
3277##...slt $t0,$t2,$t0
3281##...xori $t0,$t0,0x1
3284#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3288#    and $t2,$t0,$t1
3292#    sw $t2,($sp)
3296:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3296#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3300:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3300#    li $v0,4 # syscall-code for print-string
3304#    syscall
3308:exit:
    # print termination message
3308#    li $v0,4 # syscall-code for print-string
3312#    la $a0,exitString
3316#    syscall

    # terminate execution
3320#    li $v0,10 #syscall-code for "exit"
3324#    syscall

3328:outOfHeapMemory:
3328#    la $a0,heapMemoryMsg
3332#    j exitError
3336:divByZeroError:
3336#    la $a0,divByZeroMsg
3340#    j exitError
3344:strIndexOutOfBounds:
3344#    la $a0,strIndexOutOfBoundsMsg
3348#    j exitError
3352:arrayIndexOutOfBounds:
3352#    la $a0,arrayIndexOutOfBoundsMsg
3356#    j exitError
3360:arraySizeOutOfBounds:
3360#    la $a0,arraySizeOutOfBoundsMsg
3364#    j exitError
3368:nullPtrException:
3368#    la $a0,nullPtrExceptionMsg
3372#    j exitError
3376:badIntegerFormat:
3376#    la $a0,badIntegerFormatMsg
3380#    j exitError
3384:castException:
3384#    la $a0,castExceptionMsg
3388#    j exitError
############## data section ################
    .data
3656:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3672:cur_seg:
    .word 0

3676:lastCharRead:
    .word -2 # -2 => no buffered character
3680:prevHashConstant:
    .word 0x2785173c
3684:gcCount:
    .word 0

3688:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3715:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3738:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3773:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3807:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3840:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3871:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3919:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3940:gcMsg: 
      .asciiz "\nGC!\n"
3946:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3978:nullStr:
    .asciiz "null"
3983:trueString:
    .asciiz "true"
3988:falseString:
    .asciiz "false"
3994:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4013:newlineString:
    .asciiz "\n"
    
    .align 2
4016:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4020:seg0_start:
    .space 0x100000
1052596:seg0_end:
1052596:seg1_start:
    .space 0x100000
2101172:seg1_end:

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
288:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
288#    lw $t0,-8($s2) # get word with hash bits from this
292#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
296#    addu $t0,$t1

300#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
304:mth_equals_Object:
304#    move $t0,$s2 # first pointer (this)
308#    lw $t1,($sp) # second pointer
312#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
313##...subu $at,$t0,$t1
317##...sltiu $t0,$at,1

320#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
324:mth_hashCode_String:
324#    move $t0,$s2 # put this pointer in t0

328#    li $t2,0 # current hash value
332#    lw $t1,-4($t0) # negative of number of characters in string
336#    beq $t1,$zero,done_hashCode_String # if zero length => done
340#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
344#    and $t0,0xfffffffc # adjust for padding
345##...lui $at,65535
349##...ori $at,$at,0xfffc
353##...and $t0,$t0,$at
356#    subu $t1,$t0,$t1 # address at end of string +12
360:loop_hashCode_String:    
360#    sll $t4,$t2,5 # multiply by 32
364#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
368#    lbu $t3,-12($t0) # current character
372#    addu $t2,$t3 # add in current character
376#    addu $t0,1 # go to next character's address
380#    bne $t0,$t1,loop_hashCode_String # loop back if more
384:done_hashCode_String:    

    # push int on stack
384#    move $t0, $t2 # put $t2 in return slot
388#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
392:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
392#    subu $sp,4
396#    sw $ra,($sp)
    
    # get hash value
400#    lw $t2,-12($s2) # vtable address
404#    lw $t0,($t2) # method address
408#    jalr $t0
412#    subu $sp,8 # push result (int in $t0) on stack
416#    sw $s5,4($sp)
420#    sw $t0,($sp)

    # compute print-size of hash value
424#    li $t0, 1
428#    lw $t1, ($sp)
432#    srl $t1,$t1,4
436#    beq $t1,$zero,toString_skip_loop
440:toString_loop_top:
440#    addu $t0,1
444#    srl $t1,$t1,4
448#    bne $t1,$zero,toString_loop_top
452:toString_skip_loop:
452#    subu $sp,8
456#    sw $s5,4($sp)
460#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
464#    lw $t2,-12($s2) # vtable address
468#    move $t0,$t2
472:toString_checkTagBit:
472#    subu $t0,1
476#    lb $t1,($t0)
480#    and $t1,0x80
481##...lui $at,0
485##...ori $at,$at,0x80
489##...and $t1,$t1,$at
492#    beq $t1,$zero,toString_checkTagBit
496#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
500#    subu $sp,8
504#    sw $t1,($sp)
508#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
512#    move $s7,$zero # -4 offset header word
516#    lw $t4,8($sp) # bytes for hash value
520#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
524#    addu $t4,8
528#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
532#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

536#    li $t0,CLASS_String # store string vtable address into ...
540#    sw $t0,-12($s7) # ... -12 offset in object header
544#    lw $t2,-12($s2) # our object's vtable address
548#    lw $t5,4($sp) # number characters in prefix
552#    lw $t1,12($sp) # number of characters in hashcode
556#    addu $t3,$t1,$t5 # number of characters in string ...
560#    addu $t3,1 # ... including the '@' character
564#    subu $t0,$zero,$t3 # store negated length into ...
568#    sw $t0,-4($s7) # ... -4 offset header word
572#    lw $t0,-8($s7) # get -8 offset header-word
576#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
577##...slt $at,$t0,$zero
581##...beq $at,$zero,600
584#    and $t0,0xff # mask off object's hash value ...
585##...lui $at,0
589##...ori $at,$at,0xff
593##...and $t0,$t0,$at
596#    sw $t0,-8($s7) # ... and store back into -8 header-word
600:skipMask_toString:
600#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
604#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
608#    subu $t4,$t2,$t5
612:toString_copyLoop:    
612#    lb $t3,($t4)
616#    and $t3,0x7f # mask off sign bit (in case first word)
617##...lui $at,0
621##...ori $at,$at,0x7f
625##...and $t3,$t3,$at
628#    sb $t3,-8($t0)
632#    addu $t4,1
636#    addu $t0,1
640#    blt $t4,$t2,toString_copyLoop
641##...slt $at,$t4,$t2
645##...bne $at,$zero,612

    # copy the '@' sign
648#    li $t3,'@'
652#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
656#    addu $t2,$t0,$t1 # address of last byte in string to store +8
660#    lw $t3,20($sp) # hash code to print
664:toString_hashCopyLoop:
664#    and $t4,$t3,0xf
668#    srl $t3,4
672#    lb $t4,hexChars($t4)
676#    sb $t4,-8($t2)
680#    subu $t2,$t2,1
684#    bgt $t2,$t0,toString_hashCopyLoop
685##...slt $at,$t0,$t2
689##...bne $at,$zero,664

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
692#    addu $sp,28
696#    lw $ra,($sp)
700#    addu $sp,4
704#    move $t0, $s7 # return string we created
708#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
712:mth_equals_String:

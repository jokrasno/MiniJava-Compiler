1416#    bgt $zero,$t2,strIndexOutOfBounds
1417##...slt $at,$t2,$zero
1421##...bne $at,$zero,3344
1424#    bgt $t2,$t1,strIndexOutOfBounds
1425##...slt $at,$t1,$t2
1429##...bne $at,$zero,3344

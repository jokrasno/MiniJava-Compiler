###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
796:mth_readLine_Lib:
    
796#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
800#    sw $ra, 4($sp) # save $ra
804#    move $t1,$sp # save "original" sp

808:  doRead:

    # read the character
808#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
812#    subu $t2,$v0,13
816#    bne $t2,$zero,notReturnRL
820#    jal readLogicalChar
824#    subu $t2,$v0,10 # check for newline
828#    beq $t2,$zero,foundNewLine
832#    sw $v0,lastCharRead # push back character into queue
836#    j foundNewLine # go process the line

840:  notReturnRL:

    # at this point, $v0 has our character

840#    subu $t0,$v0,10
844#    beq $t0,$zero,foundNewLine
848#    blt $v0,$zero,foundEof
849##...slt $at,$v0,$zero
853##...bne $at,$zero,868

    # we have a character, so push it onto stack
856#    subu $sp,$sp,4
860#    sw $v0,($sp)

    # loop back up to get next character
864#    j doRead

868:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
868#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
872#    li $s7, 0 # return-value: null
876#    j rlReturn # return

880:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
880#    subu $t0,$t1,$sp # number of chars we read (times 4)
884#    srl $s6,$t0,2 # number of words on stack with chars
888#    subu $sp,$sp,4 # push char-count ...
892#    sw $s6,($sp) # ... onto stack
896#    addu $t2,$t0,5 # GC tag, incl. for count-word
900#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
904#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
908#    srl $s6,$s6,2  # data words in object
912#    move $s7,$zero # object words in object
916#    jal newObject  # allocate space
    
    # store header words
920#    la $t0,CLASS_String
924#    sw $t0,-12($s7)# store class tag (String) into object
928#    lw $t2,4($sp) # char-count
932#    sll $t1,$t2,2 # 4 times number of chars
936#    subu $t2,$zero,$t2 # negative of char-count
940#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
944#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
948#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
949##...slt $at,$t0,$zero
953##...beq $at,$zero,972
956#    and $t0,0xff # mask off object's hash value ...
957##...lui $at,0
961##...ori $at,$at,0xff
965##...and $t0,$t0,$at
968#    sw $t0,-8($s7) # ... and store back into -8 header-word
972:  skipMask_readLine:

972#    sll $t0,$t0,2 # data bytes in object
976#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
980#    subu $t0,$t0,$t2 # place to store last character (plus 9)
984#    addu $sp,$sp,8 # pop redundant object-pointer and count
988#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

992#    beq $sp,$t1,rlReturn
996:  charCopyLoop:
996#    lw $t2,($sp)
1000#    sb $t2,-9($t0)
1004#    addu $sp,$sp,4
1008#    subu $t0,$t0,1
1012#    bne $sp,$t1,charCopyLoop
1016:  rlReturn:

1016#    lw $ra, 4($sp)
1020#    addu $sp, 8   # pop $ra and pointless word off stack
1024#    move $t0, $s7 # return string we allocated in $s7
1028#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1032:mth_readInt_Lib:

    # save $ra by pushing onto stack
1032#    subu $sp,$sp,4
1036#    sw $ra,($sp)

1040:  riSkipWhiteLoop:
    # read a character
1040#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1044#    subu $t0,$v0,32
1048#    bgt $t0,$zero,nonWhite
1049##...slt $at,$zero,$t0
1053##...bne $at,$zero,1096
1056#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1060#    subu $t0,$v0,10
1064#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1068#    subu $t0,$v0,9
1072#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1076#    subu $t0,$v0,13
1080#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1084#    subu $t0,$v0,12
1088#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1092#    j badIntegerFormat # illegal integer char: abort program

1096:  nonWhite:
1096#    subu $t0,$v0,'-'
1100#    li $t4,1 # final multiplier
1104#    bne $t0,$zero,helpReadInt # go read
1108#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1112#    jal readLogicalChar

1116:  helpReadInt:
1116#    li $t2,10
1120#    subu $t1,$v0,'0' # convert digit to 0-9 value
1124#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1125##...sltu $at,$t1,$t2
1129##...beq $at,$zero,3376
1132#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1136:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1136#    jal readLogicalChar # read next character
1140#    subu $t1,$v0,'0' # convert digit to 0-9 value
1144#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1145##...sltu $at,$t1,$t2
1149##...beq $at,$zero,1168

1152#    mul $t3,$t3,$t2 # multiply old value by 10
1153##...mult $t3,$t2
1157##...mflo $t3
1160#    addu $t3,$t3,$t1 # add in value of new digit
1164#    j digitLoop

1168:  doneDigitLoop:

    # "push back" unused character into queue
1168#    sw $v0,lastCharRead

    # restore return address
1172#    lw $ra,($sp)
1176#    addu $sp, 4

    # multiply by sign and put return value in $t0
1180#    mult $t3,$t4 # multiply to account for poss. minus sign
1184#    mflo $t3
1188#    move $t0, $t3
    
    # return
1192#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input

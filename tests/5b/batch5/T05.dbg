1473##...slt $at,$t4,$zero
1477##...beq $at,$zero,1496
1480#    and $t4,0xff # mask off object's hash value ...
1481##...lui $at,0
1485##...ori $at,$at,0xff
1489##...and $t4,$t4,$at
1492#    sw $t4,-8($s7) # ... and store back into -8 header-word
1496:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1496#    lw $t1,8($sp) # k
1500#    lw $t2,16($sp) # n
1504#    subu $t0,$t2,$t1 # value to store
1508#    sw $t0,-4($s7) # store value
    
1512#    move $t3,$s2 # source string pointer

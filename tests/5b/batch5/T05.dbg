    # allocate memory
1440#    subu $s6,$t1,$t2 # # chars in target-string
1444#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1448#    srl $s6,$s6,2 # convert bytes-count to word-count
1452#    move $s7,$zero # (no object-bytes in string)
1456#    jal newObject

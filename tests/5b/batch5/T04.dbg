    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
3156#    addu $t4,8
3160#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
3164#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

3168#    li $t0,CLASS_String # store string vtable address into ...
3172#    sw $t0,-12($s7) # ... -12 offset in object header
3176#    lw $t2,-12($s2) # our object's vtable address
3180#    lw $t5,4($sp) # number characters in prefix
3184#    lw $t1,12($sp) # number of characters in hashcode
3188#    addu $t3,$t1,$t5 # number of characters in string ...
3192#    addu $t3,1 # ... including the '@' character
3196#    subu $t0,$zero,$t3 # store negated length into ...
3200#    sw $t0,-4($s7) # ... -4 offset header word
3204#    lw $t0,-8($s7) # get -8 offset header-word
3208#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
3209##...slt $at,$t0,$zero
3213##...beq $at,$zero,3232
3216#    and $t0,0xff # mask off object's hash value ...
3217##...lui $at,0
3221##...ori $at,$at,0xff
3225##...and $t0,$t0,$at
3228#    sw $t0,-8($s7) # ... and store back into -8 header-word

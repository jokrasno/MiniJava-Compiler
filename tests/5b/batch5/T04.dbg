########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
4516:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
4516#    subu $sp,$sp,8
4520#    sw $ra,4($sp)

    # save current sp
4524#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
4528#    li $t3,10

    # get argument, negate if negative
4532#    lw $t1,8($sp)
4536#    bge $t1,$zero,itsNonNegLoop
4537##...slt $at,$t1,$zero
4541##...beq $at,$zero,4548
4544#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
4548:  itsNonNegLoop:
4548#    divu $t1,$t3
4552#    mflo $t1 # quotient
4556#    mfhi $t4 # remainder
4560#    addu $t4,$t4,'0' # turn remainder into digit
4564#    subu $sp,$sp,4
4568#    sw $t4,($sp) # push digit onto stack
4572#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
4576#    lw $t4,8($t0)
4580#    bge $t4,$zero,itsSkipNeg
4581##...slt $at,$t4,$zero
4585##...beq $at,$zero,4600
4588#    li $t4,'-'
4592#    subu $sp,$sp,4
4596#    sw $t4,($sp)
4600:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
4600#    subu $s6,$t0,$sp
4604#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
4608#    sw $t3,($t0)
4612#    srl $s6,$s6,2
4616#    subu $sp,$sp,4
4620#    sw $s6,($sp)
    
    # allocate memory
4624#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
4628#    srl $s6,$s6,2
4632#    move $s7,$zero # no "object" words in object
4636#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
4640#    lw $t0,4($sp)
4644#    addu $sp,$sp,8

    # store "String" tag into class field
4648#    subu $s7,$s7,8 # address of header-1 word
4652#    la $t1,CLASS_String
4656#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
4660#    lw $t4,($s7) # # data words in source string
4664#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
4665##...slt $at,$t4,$zero
4669##...beq $at,$zero,4688
4672#    and $t4,0xff # mask off object's hash value ...
4673##...lui $at,0
4677##...ori $at,$at,0xff
4681##...and $t4,$t4,$at
4684#    sw $t4,($s7) # ... and store back into -8 header-word
4688:skipMask_intToString:
    
    # store negative of char-count into header-2 word
4688#    subu $t0,$zero,$t0
4692#    sw $t0,4($s7)

4696#    lw $t1,($s7) # number of data words in string
4700#    sll $t1,$t1,2 # number data bytes in string
4704#    subu $t1,$s7,$t1 # first location to store chars in string
4708#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
4712:  itsLoop:
4712#    lw $t2,($sp)
4716#    addu $sp,$sp,4
4720#    sb $t2,($t1)

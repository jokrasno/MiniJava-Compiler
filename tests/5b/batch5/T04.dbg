    # store "String" tag in object-type field
4092#    la $t0,CLASS_String
4096#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
4100#    lw $t4,-8($s7) # data words in source string
4104#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
4105##...slt $at,$t4,$zero
4109##...beq $at,$zero,4128
4112#    and $t4,0xff # mask off object's hash value ...
4113##...lui $at,0
4117##...ori $at,$at,0xff
4121##...and $t4,$t4,$at
4124#    sw $t4,-8($s7) # ... and store back into -8 header-word
4128:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
4128#    lw $t1,8($sp) # k
4132#    lw $t2,16($sp) # n
4136#    subu $t0,$t2,$t1 # value to store
4140#    sw $t0,-4($s7) # store value
    
4144#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
4148#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
4152#    lw $t4,-8($t3) # data words in source string
4156#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
4160#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
4164#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
4168#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
4172#    lw $t2,-8($s7)   # data words in target string
4176#    sll $t2,$t2,2    # data bytes in target string
4180#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target

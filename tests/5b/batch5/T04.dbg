4065##...slt $at,$t0,$t1
4069##...bne $at,$zero,5976

    # allocate memory
4072#    subu $s6,$t1,$t2 # # chars in target-string
4076#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
4080#    srl $s6,$s6,2 # convert bytes-count to word-count
4084#    move $s7,$zero # (no object-bytes in string)
4088#    jal newObject

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
3428:mth_readLine_Lib:
    
3428#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
3432#    sw $ra, 4($sp) # save $ra
3436#    move $t1,$sp # save "original" sp

3440:  doRead:

    # read the character
3440#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
3444#    subu $t2,$v0,13
3448#    bne $t2,$zero,notReturnRL
3452#    jal readLogicalChar
3456#    subu $t2,$v0,10 # check for newline
3460#    beq $t2,$zero,foundNewLine
3464#    sw $v0,lastCharRead # push back character into queue
3468#    j foundNewLine # go process the line

3472:  notReturnRL:

    # at this point, $v0 has our character

3472#    subu $t0,$v0,10
3476#    beq $t0,$zero,foundNewLine
3480#    blt $v0,$zero,foundEof
3481##...slt $at,$v0,$zero
3485##...bne $at,$zero,3500

    # we have a character, so push it onto stack
3488#    subu $sp,$sp,4
3492#    sw $v0,($sp)

    # loop back up to get next character
3496#    j doRead

3500:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
3500#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
3504#    li $s7, 0 # return-value: null
3508#    j rlReturn # return

3512:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
3512#    subu $t0,$t1,$sp # number of chars we read (times 4)
3516#    srl $s6,$t0,2 # number of words on stack with chars
3520#    subu $sp,$sp,4 # push char-count ...
3524#    sw $s6,($sp) # ... onto stack
3528#    addu $t2,$t0,5 # GC tag, incl. for count-word
3532#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
3536#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
3540#    srl $s6,$s6,2  # data words in object
3544#    move $s7,$zero # object words in object
3548#    jal newObject  # allocate space
    
    # store header words
3552#    la $t0,CLASS_String
3556#    sw $t0,-12($s7)# store class tag (String) into object
3560#    lw $t2,4($sp) # char-count
3564#    sll $t1,$t2,2 # 4 times number of chars
3568#    subu $t2,$zero,$t2 # negative of char-count
3572#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3576#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3580#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3581##...slt $at,$t0,$zero
3585##...beq $at,$zero,3604
3588#    and $t0,0xff # mask off object's hash value ...
3589##...lui $at,0
3593##...ori $at,$at,0xff
3597##...and $t0,$t0,$at
3600#    sw $t0,-8($s7) # ... and store back into -8 header-word
3604:  skipMask_readLine:

3604#    sll $t0,$t0,2 # data bytes in object
3608#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
3612#    subu $t0,$t0,$t2 # place to store last character (plus 9)
3616#    addu $sp,$sp,8 # pop redundant object-pointer and count
3620#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

3624#    beq $sp,$t1,rlReturn
3628:  charCopyLoop:
3628#    lw $t2,($sp)
3632#    sb $t2,-9($t0)
3636#    addu $sp,$sp,4
3640#    subu $t0,$t0,1
3644#    bne $sp,$t1,charCopyLoop
3648:  rlReturn:

3648#    lw $ra, 4($sp)
3652#    addu $sp, 8   # pop $ra and pointless word off stack
3656#    move $t0, $s7 # return string we allocated in $s7
3660#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3664:mth_readInt_Lib:

    # save $ra by pushing onto stack
3664#    subu $sp,$sp,4
3668#    sw $ra,($sp)

3672:  riSkipWhiteLoop:
    # read a character
3672#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
3676#    subu $t0,$v0,32
3680#    bgt $t0,$zero,nonWhite
3681##...slt $at,$zero,$t0
3685##...bne $at,$zero,3728
3688#    beq $t0,$zero,riSkipWhiteLoop # start over if space
3692#    subu $t0,$v0,10
3696#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
3700#    subu $t0,$v0,9
3704#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
3708#    subu $t0,$v0,13
3712#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
3716#    subu $t0,$v0,12
3720#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
3724#    j badIntegerFormat # illegal integer char: abort program

3728:  nonWhite:
3728#    subu $t0,$v0,'-'
3732#    li $t4,1 # final multiplier
3736#    bne $t0,$zero,helpReadInt # go read
3740#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
3744#    jal readLogicalChar

3748:  helpReadInt:
3748#    li $t2,10
3752#    subu $t1,$v0,'0' # convert digit to 0-9 value
3756#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
3757##...sltu $at,$t1,$t2
3761##...beq $at,$zero,6008
3764#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

3768:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

3768#    jal readLogicalChar # read next character
3772#    subu $t1,$v0,'0' # convert digit to 0-9 value
3776#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
3777##...sltu $at,$t1,$t2
3781##...beq $at,$zero,3800

3784#    mul $t3,$t3,$t2 # multiply old value by 10
3785##...mult $t3,$t2
3789##...mflo $t3
3792#    addu $t3,$t3,$t1 # add in value of new digit
3796#    j digitLoop

3800:  doneDigitLoop:

    # "push back" unused character into queue
3800#    sw $v0,lastCharRead

    # restore return address
3804#    lw $ra,($sp)
3808#    addu $sp, 4

    # multiply by sign and put return value in $t0
3812#    mult $t3,$t4 # multiply to account for poss. minus sign
3816#    mflo $t3
3820#    move $t0, $t3
    
    # return
3824#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3828:mth_readChar_Lib:

    # save $ra by pushing onto stack
3828#    subu $sp,$sp,4
3832#    sw $ra,($sp)

      # read the character
3836#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
3840#    lw $ra,($sp)
3844#    addu $sp, 4
3848#    move $t0, $v0

    # return
3852#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
3856:mth_printStr_Lib:
    # check for null, printing "(null)", if so
3856#    lw $t0,($sp)
3860#    bne $t0,$zero,psNotNull

    # print "(null)"
3864#    la $a0,nullStr
3868#    li $v0,4
3872#    syscall
3876#    j donePrintStr
    
3880:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
3880#    subu $t0,$t0,8
3884#    lw $t1,($t0) # number of data words, but needs modification
3888#    blt $t1,$zero,skipPrintStr1
3889##...slt $at,$t1,$zero
3893##...bne $at,$zero,3912
3896#    and $t1,0xff # mask out all but low byte
3897##...lui $at,0
3901##...ori $at,$at,0xff
3905##...and $t1,$t1,$at
3908#    b skipPrintStr2
3912:skipPrintStr1:
3912#    and $t1,0x7ffffff
3913##...lui $at,2047
3917##...ori $at,$at,0xffff
3921##...and $t1,$t1,$at
3924:skipPrintStr2:    
3924#    sll $t1,$t1,2
3928#    subu $t1,$t0,$t1 # first word in string
3932#    lw $t0,4($t0) # negative of string-length
3936#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
3940#    beq $t0,$t1,donePrintStr
3944:  psLoop:
3944#    lb $a0,($t1) # next byte
3948#    li $v0,11 # code for printing char
3952#        syscall # print the char
3956#    addu $t1,$t1,1 # go to next char
3960#    blt $t1,$t0,psLoop
3961##...slt $at,$t1,$t0
3965##...bne $at,$zero,3944

3968:  donePrintStr:
3968#    jr $ra

########################################################
# printInt(n) - library method (class Lib)
# - prints integer in decimal format to standard output
# - parameters:
#   - ($sp) - the integer to print
#   - 4($sp) - GC tag

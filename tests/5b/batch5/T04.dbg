    # access element
4492#    lw $t1,-8($t0) # # data words in object
4496#    sll $t1,$t1,2 # - byte-offset from end of chars
4500#    subu $t1,$t2,$t1 # - address of first char in string, offset by 8
4504#    addu $t0,$t0,$t1 # - address of our char, offset by 8
4508#    lb $t0,-8($t0) # our char

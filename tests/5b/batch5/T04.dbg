# - returns:
#   - $t0 - pointer to concatenated string
########################################################
4236:mth_concat_String:
    # save $ra by pushing onto stack
4236#    subu $sp,$sp,4
4240#    sw $ra, ($sp)

    # get string pointers and check parameter for null
4244#    lw $t0,4($sp)
4248#    beq $t0,$zero,nullPtrException
4252#    move $t1,$s2
    
    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
4256#    lw $t0,-4($t0) # negative size of second object
4260#    lw $t1,-4($t1) # negative size of first object
4264#    addu $s6,$t0,$t1 # sum of negative sizes
4268#    sra $s6,$s6,2 # negative word-size of char part
4272#    subu $s6,$zero,$s6 # word size of char part
4276#    addu $s6,$s6,1 # data word size, including v-table word
4280#    move $s7,$zero
4284#    jal newObject

    # store String vtable address in vtable address field
4288#    la $t0,CLASS_String
4292#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
4296#    lw $t4,-8($s7) # # data words in source string
4300#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
4301##...slt $at,$t4,$zero
4305##...beq $at,$zero,4324
4308#    and $t4,0xff # mask off object's hash value ...
4309##...lui $at,0
4313##...ori $at,$at,0xff
4317##...and $t4,$t4,$at
4320#    sw $t4,-8($s7) # ... and store back into -8 header-word
4324:skipMask_concat:

4324#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
4328#    move $t1,$s2   # first object
4332#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
4336#    lw $t2,-4($t0) # negative length of second object
4340#    lw $t3,-4($t1) # negative length of first object
4344#    addu $t4,$t2,$t3 # sum of negative lengths
4348#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################

    # compute addresses for moving data from first string
4352#    lw $t4,-8($t1) # # data words in first string
4356#    sll $t4,$t4,2 # # data bytes in first string
4360#    subu $t1,$t1,$t4 # addr. (+8) of first byte in first string
4364#    lw $t4,-8($s7) # # data words in new string
4368#    sll $t4,$t4,2 # # data bytes in new string
4372#    subu $s7,$s7,$t4 # addr. (+8) of first byte in new string
4376#    beq $zero,$t3,doneConcatLoop1zz # skip first loop is no bytes to copy
4380#    subu $t3,$t1,$t3 # limit (+8) address for first string

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is address (+8) of first byte in first object
    # - $t2 is negated length of second object
    # - $t3 is limit-address (+8) of data in first object
    # - $s7 is address (+8) of first byte in new object
    # - note: if data-length of first object is zero, then
    #   we skip over this part, and go to 'doneConcatLoop1'
    #########################################################

    # copy the bytes from first source to target
4384:  concatLoop1zz:
4384#    lb $t4,-8($t1)
4388#    sb $t4,-8($s7)
4392#    addu $s7,$s7,1

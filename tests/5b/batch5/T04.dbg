3988#    lw $t0,($sp)

    # print either 'true' or 'false', depending on the value
3992#    la $a0,falseString
3996#    beq $t0,$zero,skipPB
4000#    la $a0,trueString
4004:  skipPB:
4004#    li $v0,4 # code for print-string
4008#    syscall

    # return
4012#    jr $ra

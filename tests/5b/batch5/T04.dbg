    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
5624#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
5625##...slt $at,$t8,$zero
5629##...beq $at,$zero,5644
5632#    and $t8,0xff # mask off hash bits
5633##...lui $at,0
5637##...ori $at,$at,0xff
5641##...and $t8,$t8,$at

5644:  gcSkip5:
5644#    sll $t8,$t8,2 # bytes in negative-offset portion ...
5648#    addu $t8,$t8,8 # ... add in bytes for header-words
5652#    subu $t4,$t1,$t8 # address of first word of source object
5656#    lw $t3,-4($t1) # # words in positive-offset portion
5660#    bge $t3,$zero,gcNoNeg
5661##...slt $at,$t3,$zero
5665##...beq $at,$zero,5672
5668#    move $t3,$zero # negative treated as zero
5672:  gcNoNeg:
5672#    sll $t3,$t3,2 # bytes in negative-offset portion
5676#    addu $t3,$t3,$t1 # address one word past last word of source

5680#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
5684#    lw $s0,($t4)
5688#    lw $t9,-8($t1)
5692#    sw $t9,($t4)
5696#    sw $s0,-8($t1)

    # copy all source bytes to the target
5700:  gCinnerCopy2:
5700#    lw $s0,($t4)
5704#    sw $s0,($s3)
5708#    addu $t4,$t4,4
5712#    addu $s3,$s3,4
5716#    bltu $t4,$t3,gCinnerCopy2
5717##...sltu $at,$t4,$t3
5721##...bne $at,$zero,5700

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
5724#    sw $zero,-8($t1) # 0 in first header-slot
5728#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
5732#    sw $t8,($t0)

5736:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
5736#    addu $t0,$t0,4
5740#    bltu $t0,$s1,gcNextPointerInObject
5741##...sltu $at,$t0,$s1
5745##...bne $at,$zero,5584

5748:  gcTestIterDone2:
5748#    bltu $t0,$s3,gcHeapCopyLoop
5749##...sltu $at,$t0,$s3
5753##...bne $at,$zero,5468

    ###### end outer loop to copy all non-stack-direct objects ######

5756:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
5756#    lw $s2,($sp)
5760#    addu $sp,$sp,4

    # mark us as having already GC'd
5764#    move $t5,$s5

    # go try and allocate again
5768#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
5772:vm_init:

    # mark bottom of stack
5772#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
5776#    move $s2,$zero

    #set up the "five" register
5780#    li $s5,5

5784#    la $s3,seg0_start
5788#    la $s4,seg0_end
5789##...lui $s4,16
5793##...addiu $s4,$s4,6628
    
    # return
5796#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5800:divide:
    # get parameters; abort if divisor zero
5800#    lw $t0,($sp)
5804#    lw $t1,8($sp)
5808#    beq $t0,$zero,divByZeroError
    
    # perform division
5812#    div $t1,$t0
5816#    mflo $t0

    # store result, adjust stack and return
5820#    addu $sp,$sp,8 # adjust stack
5824#    sw $t0,($sp) # store result
5828#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5832:remainder:
    # get parameters; abort if divisor zero
5832#    lw $t0,($sp)
5836#    lw $t1,8($sp)
5840#    beq $t0,$zero,divByZeroError
    
    # perform division
5844#    div $t1,$t0
5848#    mfhi $t0

    # store result, adjust stack and return
5852#    addu $sp,$sp,8 # adjust stack
5856#    sw $t0,($sp) # store result
5860#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
5864:checkCast:
    # get object, allow immediately if null
5864#    lw $t2,($sp)
5868#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
5872#    lw $t2,-12($t2) # vtable address
5876#    bge $t2,$t1,castException
5877##...slt $at,$t2,$t1
5881##...beq $at,$zero,6016
5884#    blt $t2,$t0,castException
5885##...slt $at,$t2,$t0
5889##...bne $at,$zero,6016
    
    # return, leaving object unchanged on stack
5892:  checkCastReturn:    
5892#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
5896:instanceOf:
    # get object, go return false if null
5896#    lw $t2,($sp)
5900#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
5904#    lw $t2,-12($t2) # vtable address
5908#    sge $t0,$t2,$t0 # are we >= the lower limit?
5909##...slt $t0,$t2,$t0
5913##...xori $t0,$t0,0x1
5916#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
5920#    and $t2,$t0,$t1
5924#    sw $t2,($sp)
5928:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
5928#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

5932:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
5932#    li $v0,4 # syscall-code for print-string
5936#    syscall
5940:exit:
    # print termination message
5940#    li $v0,4 # syscall-code for print-string
5944#    la $a0,exitString
5948#    syscall

    # terminate execution
5952#    li $v0,10 #syscall-code for "exit"
5956#    syscall

5960:outOfHeapMemory:
5960#    la $a0,heapMemoryMsg
5964#    j exitError
5968:divByZeroError:
5968#    la $a0,divByZeroMsg
5972#    j exitError
5976:strIndexOutOfBounds:
5976#    la $a0,strIndexOutOfBoundsMsg
5980#    j exitError
5984:arrayIndexOutOfBounds:
5984#    la $a0,arrayIndexOutOfBoundsMsg
5988#    j exitError
5992:arraySizeOutOfBounds:
5992#    la $a0,arraySizeOutOfBoundsMsg
5996#    j exitError
6000:nullPtrException:
6000#    la $a0,nullPtrExceptionMsg
6004#    j exitError
6008:badIntegerFormat:
6008#    la $a0,badIntegerFormatMsg
6012#    j exitError
6016:castException:
6016#    la $a0,castExceptionMsg
6020#    j exitError
############## data section ################
    .data
6264:hexChars:
    .ascii "0123456789abcdef"
    .align 2
6280:cur_seg:
    .word 0

6284:lastCharRead:
    .word -2 # -2 => no buffered character
6288:prevHashConstant:
    .word 0x2785173c
6292:gcCount:
    .word 0

6296:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
6323:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
6346:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
6381:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
6415:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
6448:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
6479:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
6527:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
6548:gcMsg: 
      .asciiz "\nGC!\n"
6554:gcCountMsg: 
      .asciiz "Number of garbage collections: "

6586:nullStr:
    .asciiz "null"
6591:trueString:
    .asciiz "true"
6596:falseString:
    .asciiz "false"
6602:exitString:
    .ascii "Program terminated."
    #### "falls through" here
6621:newlineString:
    .asciiz "\n"
    
    .align 2
6624:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

6628:seg0_start:
    .space 0x100000
1055204:seg0_end:
1055204:seg1_start:
    .space 0x100000
2103780:seg1_end:

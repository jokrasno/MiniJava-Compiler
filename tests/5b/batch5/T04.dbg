##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2920:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
2920#    lw $t0,-8($s2) # get word with hash bits from this
2924#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
2928#    addu $t0,$t1

2932#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2936:mth_equals_Object:
2936#    move $t0,$s2 # first pointer (this)
2940#    lw $t1,($sp) # second pointer
2944#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
2945##...subu $at,$t0,$t1
2949##...sltiu $t0,$at,1

2952#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2956:mth_hashCode_String:
2956#    move $t0,$s2 # put this pointer in t0

2960#    li $t2,0 # current hash value
2964#    lw $t1,-4($t0) # negative of number of characters in string
2968#    beq $t1,$zero,done_hashCode_String # if zero length => done
2972#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
2976#    and $t0,0xfffffffc # adjust for padding
2977##...lui $at,65535
2981##...ori $at,$at,0xfffc
2985##...and $t0,$t0,$at
2988#    subu $t1,$t0,$t1 # address at end of string +12
2992:loop_hashCode_String:    
2992#    sll $t4,$t2,5 # multiply by 32
2996#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
3000#    lbu $t3,-12($t0) # current character
3004#    addu $t2,$t3 # add in current character
3008#    addu $t0,1 # go to next character's address
3012#    bne $t0,$t1,loop_hashCode_String # loop back if more
3016:done_hashCode_String:    

    # push int on stack
3016#    move $t0, $t2 # put $t2 in return slot
3020#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
3024:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
3024#    subu $sp,4
3028#    sw $ra,($sp)
    
    # get hash value
3032#    lw $t2,-12($s2) # vtable address
3036#    lw $t0,($t2) # method address
3040#    jalr $t0
3044#    subu $sp,8 # push result (int in $t0) on stack
3048#    sw $s5,4($sp)
3052#    sw $t0,($sp)

    # compute print-size of hash value
3056#    li $t0, 1
3060#    lw $t1, ($sp)
3064#    srl $t1,$t1,4
3068#    beq $t1,$zero,toString_skip_loop
3072:toString_loop_top:
3072#    addu $t0,1
3076#    srl $t1,$t1,4
3080#    bne $t1,$zero,toString_loop_top
3084:toString_skip_loop:
3084#    subu $sp,8
3088#    sw $s5,4($sp)
3092#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
3096#    lw $t2,-12($s2) # vtable address
3100#    move $t0,$t2
3104:toString_checkTagBit:
3104#    subu $t0,1

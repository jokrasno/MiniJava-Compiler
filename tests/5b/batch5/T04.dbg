    # allocate object
4768#    li $s6,2
4772#    move $s7,$zero
4776#    jal newObject

    # get n from string.
4780#    lw $t1,8($sp)

    # store "String" tag into class field
4784#    la $t0,CLASS_String
4788#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
4792#    lw $t4,-8($s7) # # data words in source string
4796#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there

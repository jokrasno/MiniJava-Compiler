4816#    sw $t4,-8($s7) # ... and store back into -8 header-word
4820:  skipMask_intToChar:

    # store data in string
4820#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
4824#    li $t0,-1
4828#    sw $t0,-4($s7)

    # we're returning $s7
4832#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
4836#    lw $ra,4($sp)
4840#    addu $sp,$sp,8

    # return
4844#    jr $ra

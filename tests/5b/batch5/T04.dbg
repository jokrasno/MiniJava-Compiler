5097##...lui $at,32768
5101##...or $t1,$at,$t1
5104#    and $t1,0xffffff00 # clear low bit
5105##...lui $at,65535
5109##...ori $at,$at,0xff00
5113##...and $t1,$t1,$at
5116#    or $s6,$t1

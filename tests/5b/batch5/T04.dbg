# - returns:
#   - $t0 - the character found.
########################################################
4468:mth_charAt_String:
    # get string
4468#    move $t0,$s2

    # check that index is in bounds
4472#    lw $t1,-4($t0) # negative of # data words in string
4476#    subu $t3,$zero,$t1 # # chars in string

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
3344:mth_equals_String:
    
    # quick test for obvious false
3344#    lw $t0,($sp) # second parameter
3348#    beq $t0,$zero,goEsFalse # go return false if null
3352#    lw $t1,-12($t0) # vtable pointer
3356#    la $t2,CLASS_String # string vtable pointer
3360#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
3364#    subu $sp,12
3368#    sw $ra,8($sp)
3372#    sw $s2,4($sp)
3376#    sw $t0,($sp)
3380#    jal mth_compareTo_String
3384#    lw $s2, 4($sp) #restore this pointer and pop parameters
3388#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
3392#    seq $t0,$t0,$zero
3393##...subu $at,$t0,$zero
3397##...sltiu $t0,$at,1

    # pop return address and return $t0
3400#    lw $ra,($sp)
3404#    addu $sp,4

3408#    jr $ra # return
    
3412:goEsFalse:
    # put 0 in $t0 and return
3412#    li $t0, 0
3416#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object

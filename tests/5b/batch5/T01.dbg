1277##...slt $at,$t1,$zero
1281##...bne $at,$zero,1300
1284#    and $t1,0xff # mask out all but low byte
1285##...lui $at,0
1289##...ori $at,$at,0xff
1293##...and $t1,$t1,$at
1296#    b skipPrintStr2
1300:skipPrintStr1:

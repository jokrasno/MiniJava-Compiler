########################################################
# length() - library method (class String)
# returns length of a string: Java: str.length()
# - parameters:
#   - ($sp) - old this pointer
# - return-value:
#   - $t0 - length of string
########################################################
1612:mth_length_String:

    # the length is the negative of 4($s2)
1612#    lw $t0,-4($s2) # -length
1616#    subu $t0,$zero,$t0

    # return
1620#    jr $ra


########################################################
# str1.concat(str2) - library method (class String)
# (as in Java)
# - parameters:
#   - ($sp) - the second string
#   - 4($sp) - old this pointer
#   - $s2 - the first string (this)
# - returns:
#   - $t0 - pointer to concatenated string
########################################################
1624:mth_concat_String:
    # save $ra by pushing onto stack
1624#    subu $sp,$sp,4
1628#    sw $ra, ($sp)

    # get string pointers and check parameter for null
1632#    lw $t0,4($sp)
1636#    beq $t0,$zero,nullPtrException
1640#    move $t1,$s2
    
    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
1644#    lw $t0,-4($t0) # negative size of second object
1648#    lw $t1,-4($t1) # negative size of first object
1652#    addu $s6,$t0,$t1 # sum of negative sizes
1656#    sra $s6,$s6,2 # negative word-size of char part
1660#    subu $s6,$zero,$s6 # word size of char part
1664#    addu $s6,$s6,1 # data word size, including v-table word
1668#    move $s7,$zero
1672#    jal newObject

    # store String vtable address in vtable address field
1676#    la $t0,CLASS_String
1680#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
1684#    lw $t4,-8($s7) # # data words in source string
1688#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
1689##...slt $at,$t4,$zero
1693##...beq $at,$zero,1712
1696#    and $t4,0xff # mask off object's hash value ...
1697##...lui $at,0
1701##...ori $at,$at,0xff
1705##...and $t4,$t4,$at
1708#    sw $t4,-8($s7) # ... and store back into -8 header-word
1712:skipMask_concat:

1712#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
1716#    move $t1,$s2   # first object
1720#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
1724#    lw $t2,-4($t0) # negative length of second object
1728#    lw $t3,-4($t1) # negative length of first object
1732#    addu $t4,$t2,$t3 # sum of negative lengths
1736#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object

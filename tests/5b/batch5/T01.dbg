##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
308:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
308#    lw $t0,-8($s2) # get word with hash bits from this
312#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
316#    addu $t0,$t1

320#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
324:mth_equals_Object:
324#    move $t0,$s2 # first pointer (this)
328#    lw $t1,($sp) # second pointer
332#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
333##...subu $at,$t0,$t1
337##...sltiu $t0,$at,1

340#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
344:mth_hashCode_String:
344#    move $t0,$s2 # put this pointer in t0

348#    li $t2,0 # current hash value
352#    lw $t1,-4($t0) # negative of number of characters in string
356#    beq $t1,$zero,done_hashCode_String # if zero length => done
360#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
364#    and $t0,0xfffffffc # adjust for padding
365##...lui $at,65535
369##...ori $at,$at,0xfffc
373##...and $t0,$t0,$at
376#    subu $t1,$t0,$t1 # address at end of string +12
380:loop_hashCode_String:    
380#    sll $t4,$t2,5 # multiply by 32
384#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
388#    lbu $t3,-12($t0) # current character
392#    addu $t2,$t3 # add in current character
396#    addu $t0,1 # go to next character's address
400#    bne $t0,$t1,loop_hashCode_String # loop back if more
404:done_hashCode_String:    

    # push int on stack
404#    move $t0, $t2 # put $t2 in return slot
408#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
412:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
412#    subu $sp,4
416#    sw $ra,($sp)
    
    # get hash value
420#    lw $t2,-12($s2) # vtable address
424#    lw $t0,($t2) # method address
428#    jalr $t0
432#    subu $sp,8 # push result (int in $t0) on stack
436#    sw $s5,4($sp)
440#    sw $t0,($sp)

    # compute print-size of hash value
444#    li $t0, 1
448#    lw $t1, ($sp)
452#    srl $t1,$t1,4
456#    beq $t1,$zero,toString_skip_loop
460:toString_loop_top:
460#    addu $t0,1
464#    srl $t1,$t1,4
468#    bne $t1,$zero,toString_loop_top
472:toString_skip_loop:
472#    subu $sp,8
476#    sw $s5,4($sp)
480#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
484#    lw $t2,-12($s2) # vtable address
488#    move $t0,$t2
492:toString_checkTagBit:
492#    subu $t0,1
496#    lb $t1,($t0)
500#    and $t1,0x80
501##...lui $at,0
505##...ori $at,$at,0x80
509##...and $t1,$t1,$at
512#    beq $t1,$zero,toString_checkTagBit
516#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
520#    subu $sp,8
524#    sw $t1,($sp)
528#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
532#    move $s7,$zero # -4 offset header word
536#    lw $t4,8($sp) # bytes for hash value
540#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
544#    addu $t4,8
548#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
552#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

556#    li $t0,CLASS_String # store string vtable address into ...
560#    sw $t0,-12($s7) # ... -12 offset in object header
564#    lw $t2,-12($s2) # our object's vtable address
568#    lw $t5,4($sp) # number characters in prefix
572#    lw $t1,12($sp) # number of characters in hashcode
576#    addu $t3,$t1,$t5 # number of characters in string ...
580#    addu $t3,1 # ... including the '@' character
584#    subu $t0,$zero,$t3 # store negated length into ...
588#    sw $t0,-4($s7) # ... -4 offset header word
592#    lw $t0,-8($s7) # get -8 offset header-word
596#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
597##...slt $at,$t0,$zero
601##...beq $at,$zero,620
604#    and $t0,0xff # mask off object's hash value ...
605##...lui $at,0
609##...ori $at,$at,0xff
613##...and $t0,$t0,$at
616#    sw $t0,-8($s7) # ... and store back into -8 header-word
620:skipMask_toString:
620#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
624#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
628#    subu $t4,$t2,$t5
632:toString_copyLoop:    
632#    lb $t3,($t4)
636#    and $t3,0x7f # mask off sign bit (in case first word)
637##...lui $at,0
641##...ori $at,$at,0x7f
645##...and $t3,$t3,$at
648#    sb $t3,-8($t0)
652#    addu $t4,1
656#    addu $t0,1
660#    blt $t4,$t2,toString_copyLoop
661##...slt $at,$t4,$t2
665##...bne $at,$zero,632

    # copy the '@' sign
668#    li $t3,'@'
672#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
676#    addu $t2,$t0,$t1 # address of last byte in string to store +8
680#    lw $t3,20($sp) # hash code to print
684:toString_hashCopyLoop:
684#    and $t4,$t3,0xf
688#    srl $t3,4
692#    lb $t4,hexChars($t4)
696#    sb $t4,-8($t2)
700#    subu $t2,$t2,1
704#    bgt $t2,$t0,toString_hashCopyLoop
705##...slt $at,$t0,$t2
709##...bne $at,$zero,684

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
712#    addu $sp,28
716#    lw $ra,($sp)
720#    addu $sp,4
724#    move $t0, $s7 # return string we created
728#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
732:mth_equals_String:
    
    # quick test for obvious false
732#    lw $t0,($sp) # second parameter
736#    beq $t0,$zero,goEsFalse # go return false if null
740#    lw $t1,-12($t0) # vtable pointer
744#    la $t2,CLASS_String # string vtable pointer
748#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
752#    subu $sp,12
756#    sw $ra,8($sp)
760#    sw $s2,4($sp)
764#    sw $t0,($sp)
768#    jal mth_compareTo_String
772#    lw $s2, 4($sp) #restore this pointer and pop parameters
776#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
780#    seq $t0,$t0,$zero
781##...subu $at,$t0,$zero
785##...sltiu $t0,$at,1

    # pop return address and return $t0
788#    lw $ra,($sp)
792#    addu $sp,4

796#    jr $ra # return
    
800:goEsFalse:
    # put 0 in $t0 and return
800#    li $t0, 0
804#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
808:mth_toString_String:
    #we are a string, so return this.
808#    move $t0, $s2
812#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
816:mth_readLine_Lib:
    
816#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
820#    sw $ra, 4($sp) # save $ra
824#    move $t1,$sp # save "original" sp

828:  doRead:

    # read the character
828#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
832#    subu $t2,$v0,13
836#    bne $t2,$zero,notReturnRL
840#    jal readLogicalChar
844#    subu $t2,$v0,10 # check for newline
848#    beq $t2,$zero,foundNewLine
852#    sw $v0,lastCharRead # push back character into queue
856#    j foundNewLine # go process the line

860:  notReturnRL:

    # at this point, $v0 has our character

860#    subu $t0,$v0,10
864#    beq $t0,$zero,foundNewLine
868#    blt $v0,$zero,foundEof
869##...slt $at,$v0,$zero
873##...bne $at,$zero,888

    # we have a character, so push it onto stack
876#    subu $sp,$sp,4
880#    sw $v0,($sp)

    # loop back up to get next character
884#    j doRead

888:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
888#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
892#    li $s7, 0 # return-value: null
896#    j rlReturn # return

900:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
900#    subu $t0,$t1,$sp # number of chars we read (times 4)
904#    srl $s6,$t0,2 # number of words on stack with chars
908#    subu $sp,$sp,4 # push char-count ...
912#    sw $s6,($sp) # ... onto stack
916#    addu $t2,$t0,5 # GC tag, incl. for count-word
920#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
924#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
928#    srl $s6,$s6,2  # data words in object
932#    move $s7,$zero # object words in object
936#    jal newObject  # allocate space
    
    # store header words
940#    la $t0,CLASS_String
944#    sw $t0,-12($s7)# store class tag (String) into object
948#    lw $t2,4($sp) # char-count
952#    sll $t1,$t2,2 # 4 times number of chars
956#    subu $t2,$zero,$t2 # negative of char-count
960#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
964#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
968#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
969##...slt $at,$t0,$zero
973##...beq $at,$zero,992
976#    and $t0,0xff # mask off object's hash value ...
977##...lui $at,0
981##...ori $at,$at,0xff
985##...and $t0,$t0,$at
988#    sw $t0,-8($s7) # ... and store back into -8 header-word
992:  skipMask_readLine:

992#    sll $t0,$t0,2 # data bytes in object
996#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1000#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1004#    addu $sp,$sp,8 # pop redundant object-pointer and count
1008#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1012#    beq $sp,$t1,rlReturn
1016:  charCopyLoop:
1016#    lw $t2,($sp)
1020#    sb $t2,-9($t0)
1024#    addu $sp,$sp,4
1028#    subu $t0,$t0,1
1032#    bne $sp,$t1,charCopyLoop
1036:  rlReturn:

1036#    lw $ra, 4($sp)
1040#    addu $sp, 8   # pop $ra and pointless word off stack
1044#    move $t0, $s7 # return string we allocated in $s7
1048#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1052:mth_readInt_Lib:

    # save $ra by pushing onto stack
1052#    subu $sp,$sp,4
1056#    sw $ra,($sp)

1060:  riSkipWhiteLoop:
    # read a character
1060#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1064#    subu $t0,$v0,32
1068#    bgt $t0,$zero,nonWhite
1069##...slt $at,$zero,$t0
1073##...bne $at,$zero,1116
1076#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1080#    subu $t0,$v0,10
1084#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1088#    subu $t0,$v0,9
1092#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1096#    subu $t0,$v0,13
1100#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1104#    subu $t0,$v0,12
1108#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1112#    j badIntegerFormat # illegal integer char: abort program

1116:  nonWhite:
1116#    subu $t0,$v0,'-'
1120#    li $t4,1 # final multiplier
1124#    bne $t0,$zero,helpReadInt # go read
1128#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1132#    jal readLogicalChar

1136:  helpReadInt:
1136#    li $t2,10
1140#    subu $t1,$v0,'0' # convert digit to 0-9 value
1144#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1145##...sltu $at,$t1,$t2
1149##...beq $at,$zero,3396
1152#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1156:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1156#    jal readLogicalChar # read next character
1160#    subu $t1,$v0,'0' # convert digit to 0-9 value
1164#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1165##...sltu $at,$t1,$t2
1169##...beq $at,$zero,1188

1172#    mul $t3,$t3,$t2 # multiply old value by 10
1173##...mult $t3,$t2
1177##...mflo $t3
1180#    addu $t3,$t3,$t1 # add in value of new digit
1184#    j digitLoop

1188:  doneDigitLoop:

    # "push back" unused character into queue
1188#    sw $v0,lastCharRead

    # restore return address
1192#    lw $ra,($sp)
1196#    addu $sp, 4

    # multiply by sign and put return value in $t0
1200#    mult $t3,$t4 # multiply to account for poss. minus sign
1204#    mflo $t3
1208#    move $t0, $t3
    
    # return
1212#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1216:mth_readChar_Lib:

    # save $ra by pushing onto stack
1216#    subu $sp,$sp,4
1220#    sw $ra,($sp)

      # read the character
1224#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1228#    lw $ra,($sp)
1232#    addu $sp, 4
1236#    move $t0, $v0

    # return
1240#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
1244:mth_printStr_Lib:
    # check for null, printing "(null)", if so
1244#    lw $t0,($sp)
1248#    bne $t0,$zero,psNotNull

    # print "(null)"
1252#    la $a0,nullStr
1256#    li $v0,4
1260#    syscall
1264#    j donePrintStr
    
1268:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
1268#    subu $t0,$t0,8
1272#    lw $t1,($t0) # number of data words, but needs modification

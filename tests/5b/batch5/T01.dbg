########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
1404:mth_substring_String:

    # save $ra by pushing onto stack
1404#    subu $sp,$sp,4
1408#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
1412#    move $t0,$s2
1416#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
1420#    lw $t0,-4($t0) # negative of string length
1424#    subu $t0,$zero,$t0 # string length
1428#    lw $t1,4($sp) # k
1432#    lw $t2,12($sp) # n
1436#    bgt $zero,$t2,strIndexOutOfBounds
1437##...slt $at,$t2,$zero
1441##...bne $at,$zero,3364
1444#    bgt $t2,$t1,strIndexOutOfBounds
1445##...slt $at,$t1,$t2
1449##...bne $at,$zero,3364
1452#    bgt $t1,$t0,strIndexOutOfBounds
1453##...slt $at,$t0,$t1
1457##...bne $at,$zero,3364

    # allocate memory
1460#    subu $s6,$t1,$t2 # # chars in target-string
1464#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1468#    srl $s6,$s6,2 # convert bytes-count to word-count
1472#    move $s7,$zero # (no object-bytes in string)
1476#    jal newObject

    # store "String" tag in object-type field
1480#    la $t0,CLASS_String
1484#    sw $t0,-12($s7)

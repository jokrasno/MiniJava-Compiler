1493##...slt $at,$t4,$zero
1497##...beq $at,$zero,1516
1500#    and $t4,0xff # mask off object's hash value ...
1501##...lui $at,0
1505##...ori $at,$at,0xff
1509##...and $t4,$t4,$at
1512#    sw $t4,-8($s7) # ... and store back into -8 header-word
1516:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1516#    lw $t1,8($sp) # k
1520#    lw $t2,16($sp) # n
1524#    subu $t0,$t2,$t1 # value to store
1528#    sw $t0,-4($s7) # store value
    
1532#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
1536#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
1540#    lw $t4,-8($t3) # data words in source string
1544#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
1548#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
1552#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
1556#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)

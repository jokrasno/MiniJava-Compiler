1305##...ori $at,$at,0xffff
1309##...and $t1,$t1,$at
1312:skipPrintStr2:    
1312#    sll $t1,$t1,2
1316#    subu $t1,$t0,$t1 # first word in string
1320#    lw $t0,4($t0) # negative of string-length
1324#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
1328#    beq $t0,$t1,donePrintStr

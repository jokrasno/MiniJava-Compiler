########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3160:vm_init:

    # mark bottom of stack
3160#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3164#    move $s2,$zero

    #set up the "five" register
3168#    li $s5,5

3172#    la $s3,seg0_start
3176#    la $s4,seg0_end
3177##...lui $s4,16
3181##...addiu $s4,$s4,3988
    
    # return
3184#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3188:divide:
    # get parameters; abort if divisor zero
3188#    lw $t0,($sp)
3192#    lw $t1,8($sp)
3196#    beq $t0,$zero,divByZeroError
    
    # perform division
3200#    div $t1,$t0
3204#    mflo $t0

    # store result, adjust stack and return
3208#    addu $sp,$sp,8 # adjust stack
3212#    sw $t0,($sp) # store result
3216#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3220:remainder:
    # get parameters; abort if divisor zero
3220#    lw $t0,($sp)
3224#    lw $t1,8($sp)
3228#    beq $t0,$zero,divByZeroError
    
    # perform division
3232#    div $t1,$t0
3236#    mfhi $t0

    # store result, adjust stack and return
3240#    addu $sp,$sp,8 # adjust stack
3244#    sw $t0,($sp) # store result
3248#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3252:checkCast:
    # get object, allow immediately if null
3252#    lw $t2,($sp)
3256#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3260#    lw $t2,-12($t2) # vtable address
3264#    bge $t2,$t1,castException
3265##...slt $at,$t2,$t1
3269##...beq $at,$zero,3404
3272#    blt $t2,$t0,castException
3273##...slt $at,$t2,$t0
3277##...bne $at,$zero,3404
    
    # return, leaving object unchanged on stack
3280:  checkCastReturn:    
3280#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3284:instanceOf:
    # get object, go return false if null
3284#    lw $t2,($sp)
3288#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3292#    lw $t2,-12($t2) # vtable address
3296#    sge $t0,$t2,$t0 # are we >= the lower limit?
3297##...slt $t0,$t2,$t0
3301##...xori $t0,$t0,0x1
3304#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3308#    and $t2,$t0,$t1
3312#    sw $t2,($sp)
3316:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3316#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3320:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3320#    li $v0,4 # syscall-code for print-string
3324#    syscall
3328:exit:
    # print termination message
3328#    li $v0,4 # syscall-code for print-string
3332#    la $a0,exitString
3336#    syscall

    # terminate execution
3340#    li $v0,10 #syscall-code for "exit"
3344#    syscall

3348:outOfHeapMemory:
3348#    la $a0,heapMemoryMsg
3352#    j exitError
3356:divByZeroError:
3356#    la $a0,divByZeroMsg
3360#    j exitError
3364:strIndexOutOfBounds:
3364#    la $a0,strIndexOutOfBoundsMsg
3368#    j exitError
3372:arrayIndexOutOfBounds:
3372#    la $a0,arrayIndexOutOfBoundsMsg
3376#    j exitError
3380:arraySizeOutOfBounds:
3380#    la $a0,arraySizeOutOfBoundsMsg
3384#    j exitError
3388:nullPtrException:
3388#    la $a0,nullPtrExceptionMsg
3392#    j exitError
3396:badIntegerFormat:
3396#    la $a0,badIntegerFormatMsg
3400#    j exitError
3404:castException:
3404#    la $a0,castExceptionMsg
3408#    j exitError
############## data section ################
    .data
3624:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3640:cur_seg:
    .word 0

3644:lastCharRead:
    .word -2 # -2 => no buffered character
3648:prevHashConstant:
    .word 0x2785173c
3652:gcCount:
    .word 0

3656:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3683:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3706:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3741:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3775:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3808:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3839:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3887:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3908:gcMsg: 
      .asciiz "\nGC!\n"
3914:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3946:nullStr:
    .asciiz "null"
3951:trueString:
    .asciiz "true"
3956:falseString:
    .asciiz "false"
3962:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3981:newlineString:
    .asciiz "\n"
    
    .align 2
3984:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3988:seg0_start:
    .space 0x100000
1052564:seg0_end:
1052564:seg1_start:
    .space 0x100000
2101140:seg1_end:

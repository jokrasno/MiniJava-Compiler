1596#    lw $ra,4($sp) # restore $ra
1600#    addu $sp,$sp,8 # pop ra, and allocated newObject
1604#    move $t0, $s7 # we're returning the string we got back
                  # from newObject
    
    # return
1608#    jr $ra

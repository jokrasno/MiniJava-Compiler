########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
1416:mth_substring_String:

    # save $ra by pushing onto stack
1416#    subu $sp,$sp,4
1420#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
1424#    move $t0,$s2
1428#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
1432#    lw $t0,-4($t0) # negative of string length
1436#    subu $t0,$zero,$t0 # string length
1440#    lw $t1,4($sp) # k
1444#    lw $t2,12($sp) # n
1448#    bgt $zero,$t2,strIndexOutOfBounds
1449##...slt $at,$t2,$zero
1453##...bne $at,$zero,3376
1456#    bgt $t2,$t1,strIndexOutOfBounds
1457##...slt $at,$t1,$t2
1461##...bne $at,$zero,3376
1464#    bgt $t1,$t0,strIndexOutOfBounds
1465##...slt $at,$t0,$t1
1469##...bne $at,$zero,3376

    # allocate memory
1472#    subu $s6,$t1,$t2 # # chars in target-string
1476#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1480#    srl $s6,$s6,2 # convert bytes-count to word-count
1484#    move $s7,$zero # (no object-bytes in string)
1488#    jal newObject

    # store "String" tag in object-type field
1492#    la $t0,CLASS_String
1496#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
1500#    lw $t4,-8($s7) # data words in source string
1504#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
1505##...slt $at,$t4,$zero
1509##...beq $at,$zero,1528
1512#    and $t4,0xff # mask off object's hash value ...
1513##...lui $at,0
1517##...ori $at,$at,0xff
1521##...and $t4,$t4,$at
1524#    sw $t4,-8($s7) # ... and store back into -8 header-word
1528:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1528#    lw $t1,8($sp) # k
1532#    lw $t2,16($sp) # n
1536#    subu $t0,$t2,$t1 # value to store
1540#    sw $t0,-4($s7) # store value
    
1544#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
1548#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
1552#    lw $t4,-8($t3) # data words in source string
1556#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
1560#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
1564#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
1568#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
1572#    lw $t2,-8($s7)   # data words in target string
1576#    sll $t2,$t2,2    # data bytes in target string
1580#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target
1584:  subCopyLoopzz:
1584#    lb $t4,-8($t3)
1588#    sb $t4,-8($t2)
1592#    addu $t2,$t2,1
1596#    addu $t3,$t3,1
1600#    blt $t3,$t1,subCopyLoopzz
1601##...slt $at,$t3,$t1
1605##...bne $at,$zero,1584
    
1608:  doneSubCopyzz:
    # restore return address, store return value, pop stack
1608#    lw $ra,4($sp) # restore $ra
1612#    addu $sp,$sp,8 # pop ra, and allocated newObject
1616#    move $t0, $s7 # we're returning the string we got back
                  # from newObject
    
    # return
1620#    jr $ra

########################################################
# length() - library method (class String)
# returns length of a string: Java: str.length()
# - parameters:
#   - ($sp) - old this pointer
# - return-value:
#   - $t0 - length of string
########################################################
1624:mth_length_String:

    # the length is the negative of 4($s2)
1624#    lw $t0,-4($s2) # -length
1628#    subu $t0,$zero,$t0

    # return
1632#    jr $ra


########################################################
# str1.concat(str2) - library method (class String)
# (as in Java)
# - parameters:
#   - ($sp) - the second string
#   - 4($sp) - old this pointer
#   - $s2 - the first string (this)
# - returns:
#   - $t0 - pointer to concatenated string
########################################################
1636:mth_concat_String:
    # save $ra by pushing onto stack
1636#    subu $sp,$sp,4
1640#    sw $ra, ($sp)

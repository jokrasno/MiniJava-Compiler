#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3172:vm_init:

    # mark bottom of stack
3172#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3176#    move $s2,$zero

    #set up the "five" register
3180#    li $s5,5

3184#    la $s3,seg0_start
3188#    la $s4,seg0_end
3189##...lui $s4,16
3193##...addiu $s4,$s4,4052
    
    # return
3196#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3200:divide:
    # get parameters; abort if divisor zero
3200#    lw $t0,($sp)
3204#    lw $t1,8($sp)
3208#    beq $t0,$zero,divByZeroError
    
    # perform division
3212#    div $t1,$t0
3216#    mflo $t0

    # store result, adjust stack and return
3220#    addu $sp,$sp,8 # adjust stack
3224#    sw $t0,($sp) # store result
3228#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3232:remainder:
    # get parameters; abort if divisor zero
3232#    lw $t0,($sp)
3236#    lw $t1,8($sp)
3240#    beq $t0,$zero,divByZeroError
    
    # perform division
3244#    div $t1,$t0
3248#    mfhi $t0

    # store result, adjust stack and return
3252#    addu $sp,$sp,8 # adjust stack
3256#    sw $t0,($sp) # store result
3260#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3264:checkCast:
    # get object, allow immediately if null
3264#    lw $t2,($sp)
3268#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3272#    lw $t2,-12($t2) # vtable address
3276#    bge $t2,$t1,castException
3277##...slt $at,$t2,$t1
3281##...beq $at,$zero,3416
3284#    blt $t2,$t0,castException
3285##...slt $at,$t2,$t0
3289##...bne $at,$zero,3416
    
    # return, leaving object unchanged on stack
3292:  checkCastReturn:    
3292#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3296:instanceOf:
    # get object, go return false if null
3296#    lw $t2,($sp)
3300#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3304#    lw $t2,-12($t2) # vtable address
3308#    sge $t0,$t2,$t0 # are we >= the lower limit?
3309##...slt $t0,$t2,$t0
3313##...xori $t0,$t0,0x1
3316#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3320#    and $t2,$t0,$t1
3324#    sw $t2,($sp)
3328:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3328#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3332:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3332#    li $v0,4 # syscall-code for print-string
3336#    syscall
3340:exit:
    # print termination message
3340#    li $v0,4 # syscall-code for print-string
3344#    la $a0,exitString
3348#    syscall

    # terminate execution
3352#    li $v0,10 #syscall-code for "exit"
3356#    syscall

3360:outOfHeapMemory:
3360#    la $a0,heapMemoryMsg
3364#    j exitError
3368:divByZeroError:
3368#    la $a0,divByZeroMsg
3372#    j exitError
3376:strIndexOutOfBounds:
3376#    la $a0,strIndexOutOfBoundsMsg
3380#    j exitError
3384:arrayIndexOutOfBounds:
3384#    la $a0,arrayIndexOutOfBoundsMsg
3388#    j exitError
3392:arraySizeOutOfBounds:
3392#    la $a0,arraySizeOutOfBoundsMsg
3396#    j exitError
3400:nullPtrException:
3400#    la $a0,nullPtrExceptionMsg
3404#    j exitError
3408:badIntegerFormat:
3408#    la $a0,badIntegerFormatMsg
3412#    j exitError
3416:castException:
3416#    la $a0,castExceptionMsg
3420#    j exitError
############## data section ################
    .data
3688:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3704:cur_seg:
    .word 0

3708:lastCharRead:
    .word -2 # -2 => no buffered character
3712:prevHashConstant:
    .word 0x2785173c
3716:gcCount:
    .word 0

3720:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3747:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3770:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3805:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3839:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3872:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3903:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3951:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3972:gcMsg: 
      .asciiz "\nGC!\n"
3978:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4010:nullStr:
    .asciiz "null"
4015:trueString:
    .asciiz "true"
4020:falseString:
    .asciiz "false"
4026:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4045:newlineString:
    .asciiz "\n"
    
    .align 2
4048:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4052:seg0_start:
    .space 0x100000
1052628:seg0_end:
1052628:seg1_start:
    .space 0x100000
2101204:seg1_end:

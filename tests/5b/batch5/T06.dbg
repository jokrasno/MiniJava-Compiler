##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
320:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
320#    lw $t0,-8($s2) # get word with hash bits from this
324#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
328#    addu $t0,$t1

332#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
336:mth_equals_Object:
336#    move $t0,$s2 # first pointer (this)
340#    lw $t1,($sp) # second pointer
344#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
345##...subu $at,$t0,$t1
349##...sltiu $t0,$at,1

352#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
356:mth_hashCode_String:
356#    move $t0,$s2 # put this pointer in t0

360#    li $t2,0 # current hash value
364#    lw $t1,-4($t0) # negative of number of characters in string
368#    beq $t1,$zero,done_hashCode_String # if zero length => done
372#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
376#    and $t0,0xfffffffc # adjust for padding
377##...lui $at,65535
381##...ori $at,$at,0xfffc
385##...and $t0,$t0,$at
388#    subu $t1,$t0,$t1 # address at end of string +12
392:loop_hashCode_String:    
392#    sll $t4,$t2,5 # multiply by 32
396#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
400#    lbu $t3,-12($t0) # current character
404#    addu $t2,$t3 # add in current character
408#    addu $t0,1 # go to next character's address
412#    bne $t0,$t1,loop_hashCode_String # loop back if more
416:done_hashCode_String:    

    # push int on stack
416#    move $t0, $t2 # put $t2 in return slot
420#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
424:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
424#    subu $sp,4
428#    sw $ra,($sp)
    
    # get hash value
432#    lw $t2,-12($s2) # vtable address
436#    lw $t0,($t2) # method address
440#    jalr $t0
444#    subu $sp,8 # push result (int in $t0) on stack
448#    sw $s5,4($sp)
452#    sw $t0,($sp)

    # compute print-size of hash value
456#    li $t0, 1
460#    lw $t1, ($sp)
464#    srl $t1,$t1,4
468#    beq $t1,$zero,toString_skip_loop
472:toString_loop_top:
472#    addu $t0,1
476#    srl $t1,$t1,4
480#    bne $t1,$zero,toString_loop_top
484:toString_skip_loop:
484#    subu $sp,8
488#    sw $s5,4($sp)
492#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
496#    lw $t2,-12($s2) # vtable address
500#    move $t0,$t2
504:toString_checkTagBit:
504#    subu $t0,1
508#    lb $t1,($t0)
512#    and $t1,0x80
513##...lui $at,0
517##...ori $at,$at,0x80
521##...and $t1,$t1,$at
524#    beq $t1,$zero,toString_checkTagBit
528#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
532#    subu $sp,8
536#    sw $t1,($sp)
540#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
544#    move $s7,$zero # -4 offset header word
548#    lw $t4,8($sp) # bytes for hash value
552#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
556#    addu $t4,8
560#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
564#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

568#    li $t0,CLASS_String # store string vtable address into ...
572#    sw $t0,-12($s7) # ... -12 offset in object header
576#    lw $t2,-12($s2) # our object's vtable address
580#    lw $t5,4($sp) # number characters in prefix
584#    lw $t1,12($sp) # number of characters in hashcode
588#    addu $t3,$t1,$t5 # number of characters in string ...
592#    addu $t3,1 # ... including the '@' character
596#    subu $t0,$zero,$t3 # store negated length into ...
600#    sw $t0,-4($s7) # ... -4 offset header word
604#    lw $t0,-8($s7) # get -8 offset header-word
608#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
609##...slt $at,$t0,$zero
613##...beq $at,$zero,632
616#    and $t0,0xff # mask off object's hash value ...
617##...lui $at,0
621##...ori $at,$at,0xff
625##...and $t0,$t0,$at
628#    sw $t0,-8($s7) # ... and store back into -8 header-word
632:skipMask_toString:
632#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
636#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
640#    subu $t4,$t2,$t5
644:toString_copyLoop:    
644#    lb $t3,($t4)
648#    and $t3,0x7f # mask off sign bit (in case first word)
649##...lui $at,0
653##...ori $at,$at,0x7f
657##...and $t3,$t3,$at
660#    sb $t3,-8($t0)
664#    addu $t4,1
668#    addu $t0,1
672#    blt $t4,$t2,toString_copyLoop
673##...slt $at,$t4,$t2
677##...bne $at,$zero,644

    # copy the '@' sign
680#    li $t3,'@'
684#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
688#    addu $t2,$t0,$t1 # address of last byte in string to store +8
692#    lw $t3,20($sp) # hash code to print
696:toString_hashCopyLoop:
696#    and $t4,$t3,0xf
700#    srl $t3,4
704#    lb $t4,hexChars($t4)
708#    sb $t4,-8($t2)
712#    subu $t2,$t2,1
716#    bgt $t2,$t0,toString_hashCopyLoop
717##...slt $at,$t0,$t2
721##...bne $at,$zero,696

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
724#    addu $sp,28
728#    lw $ra,($sp)
732#    addu $sp,4
736#    move $t0, $s7 # return string we created
740#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
744:mth_equals_String:
    
    # quick test for obvious false
744#    lw $t0,($sp) # second parameter
748#    beq $t0,$zero,goEsFalse # go return false if null
752#    lw $t1,-12($t0) # vtable pointer
756#    la $t2,CLASS_String # string vtable pointer
760#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
764#    subu $sp,12
768#    sw $ra,8($sp)
772#    sw $s2,4($sp)
776#    sw $t0,($sp)
780#    jal mth_compareTo_String
784#    lw $s2, 4($sp) #restore this pointer and pop parameters
788#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
792#    seq $t0,$t0,$zero
793##...subu $at,$t0,$zero
797##...sltiu $t0,$at,1

    # pop return address and return $t0
800#    lw $ra,($sp)
804#    addu $sp,4

808#    jr $ra # return
    
812:goEsFalse:
    # put 0 in $t0 and return
812#    li $t0, 0
816#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
820:mth_toString_String:
    #we are a string, so return this.
820#    move $t0, $s2
824#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
828:mth_readLine_Lib:
    
828#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
832#    sw $ra, 4($sp) # save $ra
836#    move $t1,$sp # save "original" sp

840:  doRead:

    # read the character
840#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
844#    subu $t2,$v0,13
848#    bne $t2,$zero,notReturnRL
852#    jal readLogicalChar
856#    subu $t2,$v0,10 # check for newline
860#    beq $t2,$zero,foundNewLine
864#    sw $v0,lastCharRead # push back character into queue
868#    j foundNewLine # go process the line

872:  notReturnRL:

    # at this point, $v0 has our character

872#    subu $t0,$v0,10
876#    beq $t0,$zero,foundNewLine
880#    blt $v0,$zero,foundEof
881##...slt $at,$v0,$zero
885##...bne $at,$zero,900

    # we have a character, so push it onto stack
888#    subu $sp,$sp,4
892#    sw $v0,($sp)

    # loop back up to get next character
896#    j doRead

900:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
900#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
904#    li $s7, 0 # return-value: null
908#    j rlReturn # return

912:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
912#    subu $t0,$t1,$sp # number of chars we read (times 4)
916#    srl $s6,$t0,2 # number of words on stack with chars
920#    subu $sp,$sp,4 # push char-count ...
924#    sw $s6,($sp) # ... onto stack
928#    addu $t2,$t0,5 # GC tag, incl. for count-word
932#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
936#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
940#    srl $s6,$s6,2  # data words in object
944#    move $s7,$zero # object words in object
948#    jal newObject  # allocate space
    
    # store header words
952#    la $t0,CLASS_String
956#    sw $t0,-12($s7)# store class tag (String) into object
960#    lw $t2,4($sp) # char-count
964#    sll $t1,$t2,2 # 4 times number of chars
968#    subu $t2,$zero,$t2 # negative of char-count
972#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
976#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
980#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
981##...slt $at,$t0,$zero
985##...beq $at,$zero,1004
988#    and $t0,0xff # mask off object's hash value ...
989##...lui $at,0
993##...ori $at,$at,0xff
997##...and $t0,$t0,$at
1000#    sw $t0,-8($s7) # ... and store back into -8 header-word
1004:  skipMask_readLine:

1004#    sll $t0,$t0,2 # data bytes in object
1008#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1012#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1016#    addu $sp,$sp,8 # pop redundant object-pointer and count
1020#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1024#    beq $sp,$t1,rlReturn
1028:  charCopyLoop:
1028#    lw $t2,($sp)
1032#    sb $t2,-9($t0)
1036#    addu $sp,$sp,4
1040#    subu $t0,$t0,1
1044#    bne $sp,$t1,charCopyLoop
1048:  rlReturn:

1048#    lw $ra, 4($sp)
1052#    addu $sp, 8   # pop $ra and pointless word off stack
1056#    move $t0, $s7 # return string we allocated in $s7
1060#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1064:mth_readInt_Lib:

    # save $ra by pushing onto stack
1064#    subu $sp,$sp,4
1068#    sw $ra,($sp)

1072:  riSkipWhiteLoop:
    # read a character
1072#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1076#    subu $t0,$v0,32
1080#    bgt $t0,$zero,nonWhite
1081##...slt $at,$zero,$t0
1085##...bne $at,$zero,1128
1088#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1092#    subu $t0,$v0,10
1096#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1100#    subu $t0,$v0,9
1104#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1108#    subu $t0,$v0,13
1112#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1116#    subu $t0,$v0,12
1120#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1124#    j badIntegerFormat # illegal integer char: abort program

1128:  nonWhite:
1128#    subu $t0,$v0,'-'
1132#    li $t4,1 # final multiplier
1136#    bne $t0,$zero,helpReadInt # go read
1140#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1144#    jal readLogicalChar

1148:  helpReadInt:
1148#    li $t2,10
1152#    subu $t1,$v0,'0' # convert digit to 0-9 value
1156#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1157##...sltu $at,$t1,$t2
1161##...beq $at,$zero,3408
1164#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1168:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1168#    jal readLogicalChar # read next character
1172#    subu $t1,$v0,'0' # convert digit to 0-9 value
1176#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1177##...sltu $at,$t1,$t2
1181##...beq $at,$zero,1200

1184#    mul $t3,$t3,$t2 # multiply old value by 10
1185##...mult $t3,$t2
1189##...mflo $t3
1192#    addu $t3,$t3,$t1 # add in value of new digit
1196#    j digitLoop

1200:  doneDigitLoop:

    # "push back" unused character into queue
1200#    sw $v0,lastCharRead

    # restore return address
1204#    lw $ra,($sp)
1208#    addu $sp, 4

    # multiply by sign and put return value in $t0
1212#    mult $t3,$t4 # multiply to account for poss. minus sign
1216#    mflo $t3
1220#    move $t0, $t3
    
    # return
1224#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1228:mth_readChar_Lib:

    # save $ra by pushing onto stack
1228#    subu $sp,$sp,4
1232#    sw $ra,($sp)

      # read the character
1236#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1240#    lw $ra,($sp)
1244#    addu $sp, 4
1248#    move $t0, $v0

    # return
1252#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
1256:mth_printStr_Lib:
    # check for null, printing "(null)", if so
1256#    lw $t0,($sp)
1260#    bne $t0,$zero,psNotNull

    # print "(null)"
1264#    la $a0,nullStr
1268#    li $v0,4
1272#    syscall
1276#    j donePrintStr
    
1280:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
1280#    subu $t0,$t0,8
1284#    lw $t1,($t0) # number of data words, but needs modification
1288#    blt $t1,$zero,skipPrintStr1
1289##...slt $at,$t1,$zero
1293##...bne $at,$zero,1312
1296#    and $t1,0xff # mask out all but low byte
1297##...lui $at,0
1301##...ori $at,$at,0xff
1305##...and $t1,$t1,$at
1308#    b skipPrintStr2
1312:skipPrintStr1:
1312#    and $t1,0x7ffffff
1313##...lui $at,2047
1317##...ori $at,$at,0xffff
1321##...and $t1,$t1,$at
1324:skipPrintStr2:    
1324#    sll $t1,$t1,2
1328#    subu $t1,$t0,$t1 # first word in string
1332#    lw $t0,4($t0) # negative of string-length
1336#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
1340#    beq $t0,$t1,donePrintStr
1344:  psLoop:
1344#    lb $a0,($t1) # next byte
1348#    li $v0,11 # code for printing char
1352#        syscall # print the char
1356#    addu $t1,$t1,1 # go to next char
1360#    blt $t1,$t0,psLoop
1361##...slt $at,$t1,$t0
1365##...bne $at,$zero,1344

1368:  donePrintStr:
1368#    jr $ra

########################################################
# printInt(n) - library method (class Lib)
# - prints integer in decimal format to standard output
# - parameters:
#   - ($sp) - the integer to print

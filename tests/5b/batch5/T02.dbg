    # is their sum divided by 4 (rounded up) plus 1
1628#    lw $t0,-4($t0) # negative size of second object
1632#    lw $t1,-4($t1) # negative size of first object
1636#    addu $s6,$t0,$t1 # sum of negative sizes
1640#    sra $s6,$s6,2 # negative word-size of char part

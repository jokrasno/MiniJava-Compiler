    # store String vtable address in vtable address field
1660#    la $t0,CLASS_String
1664#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
1668#    lw $t4,-8($s7) # # data words in source string
1672#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
1673##...slt $at,$t4,$zero
1677##...beq $at,$zero,1696
1680#    and $t4,0xff # mask off object's hash value ...
1681##...lui $at,0
1685##...ori $at,$at,0xff
1689##...and $t4,$t4,$at
1692#    sw $t4,-8($s7) # ... and store back into -8 header-word
1696:skipMask_concat:

1696#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
1700#    move $t1,$s2   # first object
1704#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
1708#    lw $t2,-4($t0) # negative length of second object
1712#    lw $t3,-4($t1) # negative length of first object
1716#    addu $t4,$t2,$t3 # sum of negative lengths
1720#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################

    # compute addresses for moving data from first string
1724#    lw $t4,-8($t1) # # data words in first string
1728#    sll $t4,$t4,2 # # data bytes in first string

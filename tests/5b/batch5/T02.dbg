      # read the character
1208#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1212#    lw $ra,($sp)
1216#    addu $sp, 4
1220#    move $t0, $v0

    # return
1224#    jr $ra

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
292:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
292#    lw $t0,-8($s2) # get word with hash bits from this
296#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
300#    addu $t0,$t1

304#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
308:mth_equals_Object:
308#    move $t0,$s2 # first pointer (this)
312#    lw $t1,($sp) # second pointer
316#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
317##...subu $at,$t0,$t1
321##...sltiu $t0,$at,1

324#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
328:mth_hashCode_String:
328#    move $t0,$s2 # put this pointer in t0

332#    li $t2,0 # current hash value
336#    lw $t1,-4($t0) # negative of number of characters in string
340#    beq $t1,$zero,done_hashCode_String # if zero length => done
344#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
348#    and $t0,0xfffffffc # adjust for padding
349##...lui $at,65535
353##...ori $at,$at,0xfffc
357##...and $t0,$t0,$at
360#    subu $t1,$t0,$t1 # address at end of string +12
364:loop_hashCode_String:    
364#    sll $t4,$t2,5 # multiply by 32
368#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
372#    lbu $t3,-12($t0) # current character
376#    addu $t2,$t3 # add in current character
380#    addu $t0,1 # go to next character's address
384#    bne $t0,$t1,loop_hashCode_String # loop back if more
388:done_hashCode_String:    

    # push int on stack
388#    move $t0, $t2 # put $t2 in return slot
392#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
396:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
396#    subu $sp,4
400#    sw $ra,($sp)
    
    # get hash value
404#    lw $t2,-12($s2) # vtable address
408#    lw $t0,($t2) # method address
412#    jalr $t0
416#    subu $sp,8 # push result (int in $t0) on stack
420#    sw $s5,4($sp)
424#    sw $t0,($sp)

    # compute print-size of hash value
428#    li $t0, 1
432#    lw $t1, ($sp)
436#    srl $t1,$t1,4
440#    beq $t1,$zero,toString_skip_loop
444:toString_loop_top:
444#    addu $t0,1
448#    srl $t1,$t1,4
452#    bne $t1,$zero,toString_loop_top
456:toString_skip_loop:
456#    subu $sp,8
460#    sw $s5,4($sp)
464#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
468#    lw $t2,-12($s2) # vtable address
472#    move $t0,$t2
476:toString_checkTagBit:
476#    subu $t0,1
480#    lb $t1,($t0)
484#    and $t1,0x80
485##...lui $at,0
489##...ori $at,$at,0x80
493##...and $t1,$t1,$at
496#    beq $t1,$zero,toString_checkTagBit
500#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
504#    subu $sp,8
508#    sw $t1,($sp)
512#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
516#    move $s7,$zero # -4 offset header word
520#    lw $t4,8($sp) # bytes for hash value
524#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
528#    addu $t4,8
532#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
536#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

540#    li $t0,CLASS_String # store string vtable address into ...
544#    sw $t0,-12($s7) # ... -12 offset in object header
548#    lw $t2,-12($s2) # our object's vtable address
552#    lw $t5,4($sp) # number characters in prefix
556#    lw $t1,12($sp) # number of characters in hashcode
560#    addu $t3,$t1,$t5 # number of characters in string ...
564#    addu $t3,1 # ... including the '@' character
568#    subu $t0,$zero,$t3 # store negated length into ...
572#    sw $t0,-4($s7) # ... -4 offset header word
576#    lw $t0,-8($s7) # get -8 offset header-word
580#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
581##...slt $at,$t0,$zero
585##...beq $at,$zero,604
588#    and $t0,0xff # mask off object's hash value ...
589##...lui $at,0
593##...ori $at,$at,0xff
597##...and $t0,$t0,$at
600#    sw $t0,-8($s7) # ... and store back into -8 header-word
604:skipMask_toString:
604#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
608#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
612#    subu $t4,$t2,$t5
616:toString_copyLoop:    
616#    lb $t3,($t4)
620#    and $t3,0x7f # mask off sign bit (in case first word)
621##...lui $at,0
625##...ori $at,$at,0x7f
629##...and $t3,$t3,$at
632#    sb $t3,-8($t0)
636#    addu $t4,1
640#    addu $t0,1
644#    blt $t4,$t2,toString_copyLoop
645##...slt $at,$t4,$t2
649##...bne $at,$zero,616

    # copy the '@' sign
652#    li $t3,'@'
656#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
660#    addu $t2,$t0,$t1 # address of last byte in string to store +8
664#    lw $t3,20($sp) # hash code to print
668:toString_hashCopyLoop:
668#    and $t4,$t3,0xf
672#    srl $t3,4
676#    lb $t4,hexChars($t4)
680#    sb $t4,-8($t2)
684#    subu $t2,$t2,1
688#    bgt $t2,$t0,toString_hashCopyLoop
689##...slt $at,$t0,$t2
693##...bne $at,$zero,668

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
696#    addu $sp,28
700#    lw $ra,($sp)
704#    addu $sp,4
708#    move $t0, $s7 # return string we created
712#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
716:mth_equals_String:
    
    # quick test for obvious false
716#    lw $t0,($sp) # second parameter
720#    beq $t0,$zero,goEsFalse # go return false if null
724#    lw $t1,-12($t0) # vtable pointer
728#    la $t2,CLASS_String # string vtable pointer
732#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
736#    subu $sp,12
740#    sw $ra,8($sp)
744#    sw $s2,4($sp)
748#    sw $t0,($sp)
752#    jal mth_compareTo_String
756#    lw $s2, 4($sp) #restore this pointer and pop parameters
760#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
764#    seq $t0,$t0,$zero
765##...subu $at,$t0,$zero
769##...sltiu $t0,$at,1

    # pop return address and return $t0
772#    lw $ra,($sp)
776#    addu $sp,4

780#    jr $ra # return
    
784:goEsFalse:
    # put 0 in $t0 and return
784#    li $t0, 0
788#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
792:mth_toString_String:
    #we are a string, so return this.
792#    move $t0, $s2
796#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
800:mth_readLine_Lib:
    
800#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
804#    sw $ra, 4($sp) # save $ra
808#    move $t1,$sp # save "original" sp

812:  doRead:

    # read the character
812#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
816#    subu $t2,$v0,13
820#    bne $t2,$zero,notReturnRL
824#    jal readLogicalChar
828#    subu $t2,$v0,10 # check for newline
832#    beq $t2,$zero,foundNewLine
836#    sw $v0,lastCharRead # push back character into queue
840#    j foundNewLine # go process the line

844:  notReturnRL:

    # at this point, $v0 has our character

844#    subu $t0,$v0,10
848#    beq $t0,$zero,foundNewLine
852#    blt $v0,$zero,foundEof
853##...slt $at,$v0,$zero
857##...bne $at,$zero,872

    # we have a character, so push it onto stack
860#    subu $sp,$sp,4
864#    sw $v0,($sp)

    # loop back up to get next character
868#    j doRead

872:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
872#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
876#    li $s7, 0 # return-value: null
880#    j rlReturn # return

884:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
884#    subu $t0,$t1,$sp # number of chars we read (times 4)
888#    srl $s6,$t0,2 # number of words on stack with chars
892#    subu $sp,$sp,4 # push char-count ...
896#    sw $s6,($sp) # ... onto stack
900#    addu $t2,$t0,5 # GC tag, incl. for count-word
904#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
908#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
912#    srl $s6,$s6,2  # data words in object
916#    move $s7,$zero # object words in object
920#    jal newObject  # allocate space
    
    # store header words
924#    la $t0,CLASS_String
928#    sw $t0,-12($s7)# store class tag (String) into object
932#    lw $t2,4($sp) # char-count
936#    sll $t1,$t2,2 # 4 times number of chars
940#    subu $t2,$zero,$t2 # negative of char-count
944#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
948#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
952#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
953##...slt $at,$t0,$zero
957##...beq $at,$zero,976
960#    and $t0,0xff # mask off object's hash value ...
961##...lui $at,0
965##...ori $at,$at,0xff
969##...and $t0,$t0,$at
972#    sw $t0,-8($s7) # ... and store back into -8 header-word
976:  skipMask_readLine:

976#    sll $t0,$t0,2 # data bytes in object
980#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
984#    subu $t0,$t0,$t2 # place to store last character (plus 9)
988#    addu $sp,$sp,8 # pop redundant object-pointer and count
992#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

996#    beq $sp,$t1,rlReturn
1000:  charCopyLoop:
1000#    lw $t2,($sp)
1004#    sb $t2,-9($t0)
1008#    addu $sp,$sp,4
1012#    subu $t0,$t0,1
1016#    bne $sp,$t1,charCopyLoop
1020:  rlReturn:

1020#    lw $ra, 4($sp)
1024#    addu $sp, 8   # pop $ra and pointless word off stack
1028#    move $t0, $s7 # return string we allocated in $s7
1032#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1036:mth_readInt_Lib:

    # save $ra by pushing onto stack
1036#    subu $sp,$sp,4
1040#    sw $ra,($sp)

1044:  riSkipWhiteLoop:
    # read a character
1044#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1048#    subu $t0,$v0,32
1052#    bgt $t0,$zero,nonWhite
1053##...slt $at,$zero,$t0
1057##...bne $at,$zero,1100
1060#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1064#    subu $t0,$v0,10
1068#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1072#    subu $t0,$v0,9
1076#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1080#    subu $t0,$v0,13
1084#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1088#    subu $t0,$v0,12
1092#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1096#    j badIntegerFormat # illegal integer char: abort program

1100:  nonWhite:
1100#    subu $t0,$v0,'-'
1104#    li $t4,1 # final multiplier
1108#    bne $t0,$zero,helpReadInt # go read
1112#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1116#    jal readLogicalChar

1120:  helpReadInt:
1120#    li $t2,10
1124#    subu $t1,$v0,'0' # convert digit to 0-9 value
1128#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1129##...sltu $at,$t1,$t2
1133##...beq $at,$zero,3380
1136#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1140:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1140#    jal readLogicalChar # read next character
1144#    subu $t1,$v0,'0' # convert digit to 0-9 value
1148#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1149##...sltu $at,$t1,$t2
1153##...beq $at,$zero,1172

1156#    mul $t3,$t3,$t2 # multiply old value by 10
1157##...mult $t3,$t2
1161##...mflo $t3
1164#    addu $t3,$t3,$t1 # add in value of new digit
1168#    j digitLoop

1172:  doneDigitLoop:

    # "push back" unused character into queue
1172#    sw $v0,lastCharRead

    # restore return address
1176#    lw $ra,($sp)
1180#    addu $sp, 4

    # multiply by sign and put return value in $t0
1184#    mult $t3,$t4 # multiply to account for poss. minus sign
1188#    mflo $t3
1192#    move $t0, $t3
    
    # return
1196#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3144:vm_init:

    # mark bottom of stack
3144#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3148#    move $s2,$zero

    #set up the "five" register
3152#    li $s5,5

3156#    la $s3,seg0_start
3160#    la $s4,seg0_end
3161##...lui $s4,16
3165##...addiu $s4,$s4,3956
    
    # return
3168#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3172:divide:
    # get parameters; abort if divisor zero
3172#    lw $t0,($sp)
3176#    lw $t1,8($sp)
3180#    beq $t0,$zero,divByZeroError
    
    # perform division
3184#    div $t1,$t0
3188#    mflo $t0

    # store result, adjust stack and return
3192#    addu $sp,$sp,8 # adjust stack
3196#    sw $t0,($sp) # store result
3200#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3204:remainder:
    # get parameters; abort if divisor zero
3204#    lw $t0,($sp)
3208#    lw $t1,8($sp)
3212#    beq $t0,$zero,divByZeroError
    
    # perform division
3216#    div $t1,$t0
3220#    mfhi $t0

    # store result, adjust stack and return
3224#    addu $sp,$sp,8 # adjust stack
3228#    sw $t0,($sp) # store result
3232#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3236:checkCast:
    # get object, allow immediately if null
3236#    lw $t2,($sp)
3240#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3244#    lw $t2,-12($t2) # vtable address
3248#    bge $t2,$t1,castException
3249##...slt $at,$t2,$t1
3253##...beq $at,$zero,3388
3256#    blt $t2,$t0,castException
3257##...slt $at,$t2,$t0
3261##...bne $at,$zero,3388
    
    # return, leaving object unchanged on stack
3264:  checkCastReturn:    
3264#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3268:instanceOf:
    # get object, go return false if null
3268#    lw $t2,($sp)
3272#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3276#    lw $t2,-12($t2) # vtable address
3280#    sge $t0,$t2,$t0 # are we >= the lower limit?
3281##...slt $t0,$t2,$t0
3285##...xori $t0,$t0,0x1
3288#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3292#    and $t2,$t0,$t1
3296#    sw $t2,($sp)
3300:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3300#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3304:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3304#    li $v0,4 # syscall-code for print-string
3308#    syscall
3312:exit:
    # print termination message
3312#    li $v0,4 # syscall-code for print-string
3316#    la $a0,exitString
3320#    syscall

    # terminate execution
3324#    li $v0,10 #syscall-code for "exit"
3328#    syscall

3332:outOfHeapMemory:
3332#    la $a0,heapMemoryMsg
3336#    j exitError
3340:divByZeroError:
3340#    la $a0,divByZeroMsg
3344#    j exitError
3348:strIndexOutOfBounds:
3348#    la $a0,strIndexOutOfBoundsMsg
3352#    j exitError
3356:arrayIndexOutOfBounds:
3356#    la $a0,arrayIndexOutOfBoundsMsg
3360#    j exitError
3364:arraySizeOutOfBounds:
3364#    la $a0,arraySizeOutOfBoundsMsg
3368#    j exitError
3372:nullPtrException:
3372#    la $a0,nullPtrExceptionMsg
3376#    j exitError
3380:badIntegerFormat:
3380#    la $a0,badIntegerFormatMsg
3384#    j exitError
3388:castException:
3388#    la $a0,castExceptionMsg
3392#    j exitError
############## data section ################
    .data
3592:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3608:cur_seg:
    .word 0

3612:lastCharRead:
    .word -2 # -2 => no buffered character
3616:prevHashConstant:
    .word 0x2785173c
3620:gcCount:
    .word 0

3624:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3651:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3674:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3709:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3743:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3776:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3807:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3855:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3876:gcMsg: 
      .asciiz "\nGC!\n"
3882:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3914:nullStr:
    .asciiz "null"
3919:trueString:
    .asciiz "true"
3924:falseString:
    .asciiz "false"
3930:exitString:
    .ascii "Program terminated."
    #### "falls through" here
3949:newlineString:
    .asciiz "\n"
    
    .align 2
3952:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3956:seg0_start:
    .space 0x100000
1052532:seg0_end:
1052532:seg1_start:
    .space 0x100000
2101108:seg1_end:

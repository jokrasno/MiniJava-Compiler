2660#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2664#    subu $t0,$v0,9
2668#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2672#    subu $t0,$v0,13
2676#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2680#    subu $t0,$v0,12

3568#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
3572#    sw $t3,($t0)
3576#    srl $s6,$s6,2
3580#    subu $sp,$sp,4
3584#    sw $s6,($sp)
    
    # allocate memory
3588#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
3592#    srl $s6,$s6,2
3596#    move $s7,$zero # no "object" words in object
3600#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
3604#    lw $t0,4($sp)
3608#    addu $sp,$sp,8

    # store "String" tag into class field
3612#    subu $s7,$s7,8 # address of header-1 word
3616#    la $t1,CLASS_String
3620#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
3624#    lw $t4,($s7) # # data words in source string

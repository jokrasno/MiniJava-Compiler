##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1884:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1884#    lw $t0,-8($s2) # get word with hash bits from this
1888#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1892#    addu $t0,$t1

1896#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1900:mth_equals_Object:
1900#    move $t0,$s2 # first pointer (this)
1904#    lw $t1,($sp) # second pointer
1908#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1909##...subu $at,$t0,$t1
1913##...sltiu $t0,$at,1

1916#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1920:mth_hashCode_String:
1920#    move $t0,$s2 # put this pointer in t0

1924#    li $t2,0 # current hash value
1928#    lw $t1,-4($t0) # negative of number of characters in string
1932#    beq $t1,$zero,done_hashCode_String # if zero length => done
1936#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1940#    and $t0,0xfffffffc # adjust for padding
1941##...lui $at,65535
1945##...ori $at,$at,0xfffc
1949##...and $t0,$t0,$at
1952#    subu $t1,$t0,$t1 # address at end of string +12
1956:loop_hashCode_String:    
1956#    sll $t4,$t2,5 # multiply by 32
1960#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1964#    lbu $t3,-12($t0) # current character
1968#    addu $t2,$t3 # add in current character
1972#    addu $t0,1 # go to next character's address
1976#    bne $t0,$t1,loop_hashCode_String # loop back if more
1980:done_hashCode_String:    

    # push int on stack
1980#    move $t0, $t2 # put $t2 in return slot
1984#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1988:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1988#    subu $sp,4
1992#    sw $ra,($sp)
    
    # get hash value
1996#    lw $t2,-12($s2) # vtable address
2000#    lw $t0,($t2) # method address
2004#    jalr $t0
2008#    subu $sp,8 # push result (int in $t0) on stack
2012#    sw $s5,4($sp)
2016#    sw $t0,($sp)

    # compute print-size of hash value
2020#    li $t0, 1
2024#    lw $t1, ($sp)
2028#    srl $t1,$t1,4
2032#    beq $t1,$zero,toString_skip_loop
2036:toString_loop_top:
2036#    addu $t0,1
2040#    srl $t1,$t1,4
2044#    bne $t1,$zero,toString_loop_top
2048:toString_skip_loop:
2048#    subu $sp,8
2052#    sw $s5,4($sp)
2056#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
2060#    lw $t2,-12($s2) # vtable address
2064#    move $t0,$t2
2068:toString_checkTagBit:
2068#    subu $t0,1
2072#    lb $t1,($t0)
2076#    and $t1,0x80
2077##...lui $at,0
2081##...ori $at,$at,0x80
2085##...and $t1,$t1,$at
2088#    beq $t1,$zero,toString_checkTagBit
2092#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
2096#    subu $sp,8
2100#    sw $t1,($sp)
2104#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
2108#    move $s7,$zero # -4 offset header word
2112#    lw $t4,8($sp) # bytes for hash value
2116#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
2120#    addu $t4,8
2124#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
2128#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

2132#    li $t0,CLASS_String # store string vtable address into ...
2136#    sw $t0,-12($s7) # ... -12 offset in object header
2140#    lw $t2,-12($s2) # our object's vtable address
2144#    lw $t5,4($sp) # number characters in prefix
2148#    lw $t1,12($sp) # number of characters in hashcode
2152#    addu $t3,$t1,$t5 # number of characters in string ...
2156#    addu $t3,1 # ... including the '@' character
2160#    subu $t0,$zero,$t3 # store negated length into ...
2164#    sw $t0,-4($s7) # ... -4 offset header word
2168#    lw $t0,-8($s7) # get -8 offset header-word
2172#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2173##...slt $at,$t0,$zero
2177##...beq $at,$zero,2196
2180#    and $t0,0xff # mask off object's hash value ...
2181##...lui $at,0
2185##...ori $at,$at,0xff
2189##...and $t0,$t0,$at
2192#    sw $t0,-8($s7) # ... and store back into -8 header-word
2196:skipMask_toString:
2196#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2200#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2204#    subu $t4,$t2,$t5
2208:toString_copyLoop:    
2208#    lb $t3,($t4)
2212#    and $t3,0x7f # mask off sign bit (in case first word)
2213##...lui $at,0
2217##...ori $at,$at,0x7f
2221##...and $t3,$t3,$at
2224#    sb $t3,-8($t0)
2228#    addu $t4,1
2232#    addu $t0,1
2236#    blt $t4,$t2,toString_copyLoop
2237##...slt $at,$t4,$t2
2241##...bne $at,$zero,2208

    # copy the '@' sign
2244#    li $t3,'@'
2248#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2252#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2256#    lw $t3,20($sp) # hash code to print
2260:toString_hashCopyLoop:
2260#    and $t4,$t3,0xf
2264#    srl $t3,4
2268#    lb $t4,hexChars($t4)
2272#    sb $t4,-8($t2)
2276#    subu $t2,$t2,1
2280#    bgt $t2,$t0,toString_hashCopyLoop
2281##...slt $at,$t0,$t2
2285##...bne $at,$zero,2260

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2288#    addu $sp,28
2292#    lw $ra,($sp)
2296#    addu $sp,4
2300#    move $t0, $s7 # return string we created
2304#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2308:mth_equals_String:
    
    # quick test for obvious false
2308#    lw $t0,($sp) # second parameter
2312#    beq $t0,$zero,goEsFalse # go return false if null
2316#    lw $t1,-12($t0) # vtable pointer
2320#    la $t2,CLASS_String # string vtable pointer
2324#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2328#    subu $sp,12
2332#    sw $ra,8($sp)
2336#    sw $s2,4($sp)
2340#    sw $t0,($sp)
2344#    jal mth_compareTo_String
2348#    lw $s2, 4($sp) #restore this pointer and pop parameters
2352#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2356#    seq $t0,$t0,$zero
2357##...subu $at,$t0,$zero
2361##...sltiu $t0,$at,1

    # pop return address and return $t0
2364#    lw $ra,($sp)
2368#    addu $sp,4

2372#    jr $ra # return
    
2376:goEsFalse:
    # put 0 in $t0 and return
2376#    li $t0, 0
2380#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2384:mth_toString_String:
    #we are a string, so return this.
2384#    move $t0, $s2
2388#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2392:mth_readLine_Lib:
    
2392#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2396#    sw $ra, 4($sp) # save $ra
2400#    move $t1,$sp # save "original" sp

2404:  doRead:

    # read the character
2404#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2408#    subu $t2,$v0,13
2412#    bne $t2,$zero,notReturnRL
2416#    jal readLogicalChar
2420#    subu $t2,$v0,10 # check for newline
2424#    beq $t2,$zero,foundNewLine
2428#    sw $v0,lastCharRead # push back character into queue
2432#    j foundNewLine # go process the line

2436:  notReturnRL:

    # at this point, $v0 has our character

2436#    subu $t0,$v0,10
2440#    beq $t0,$zero,foundNewLine
2444#    blt $v0,$zero,foundEof
2445##...slt $at,$v0,$zero
2449##...bne $at,$zero,2464

    # we have a character, so push it onto stack
2452#    subu $sp,$sp,4
2456#    sw $v0,($sp)

    # loop back up to get next character
2460#    j doRead

2464:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2464#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2468#    li $s7, 0 # return-value: null
2472#    j rlReturn # return

2476:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2476#    subu $t0,$t1,$sp # number of chars we read (times 4)
2480#    srl $s6,$t0,2 # number of words on stack with chars
2484#    subu $sp,$sp,4 # push char-count ...
2488#    sw $s6,($sp) # ... onto stack
2492#    addu $t2,$t0,5 # GC tag, incl. for count-word
2496#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2500#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2504#    srl $s6,$s6,2  # data words in object
2508#    move $s7,$zero # object words in object
2512#    jal newObject  # allocate space
    
    # store header words
2516#    la $t0,CLASS_String
2520#    sw $t0,-12($s7)# store class tag (String) into object
2524#    lw $t2,4($sp) # char-count
2528#    sll $t1,$t2,2 # 4 times number of chars
2532#    subu $t2,$zero,$t2 # negative of char-count
2536#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
2540#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
2544#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
2545##...slt $at,$t0,$zero
2549##...beq $at,$zero,2568
2552#    and $t0,0xff # mask off object's hash value ...
2553##...lui $at,0
2557##...ori $at,$at,0xff
2561##...and $t0,$t0,$at

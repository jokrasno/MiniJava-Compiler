3637##...lui $at,0
3641##...ori $at,$at,0xff
3645##...and $t4,$t4,$at
3648#    sw $t4,($s7) # ... and store back into -8 header-word
3652:skipMask_intToString:
    
    # store negative of char-count into header-2 word
3652#    subu $t0,$zero,$t0


    # get argument, negate if negative
3496#    lw $t1,8($sp)
3500#    bge $t1,$zero,itsNonNegLoop
3501##...slt $at,$t1,$zero
3505##...beq $at,$zero,3512
3508#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
3512:  itsNonNegLoop:
3512#    divu $t1,$t3
3516#    mflo $t1 # quotient
3520#    mfhi $t4 # remainder
3524#    addu $t4,$t4,'0' # turn remainder into digit
3528#    subu $sp,$sp,4
3532#    sw $t4,($sp) # push digit onto stack
3536#    bne $t1,$zero,itsNonNegLoop

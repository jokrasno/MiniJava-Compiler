4845##...beq $at,$zero,4980
4848#    blt $t2,$t0,castException
4849##...slt $at,$t2,$t0
4853##...bne $at,$zero,4980
    
    # return, leaving object unchanged on stack
4856:  checkCastReturn:    
4856#    jr $ra    

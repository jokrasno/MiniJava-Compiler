4896#    li $v0,4 # syscall-code for print-string
4900#    syscall
4904:exit:
    # print termination message
4904#    li $v0,4 # syscall-code for print-string
4908#    la $a0,exitString
4912#    syscall

    # terminate execution
4916#    li $v0,10 #syscall-code for "exit"
4920#    syscall

4924:outOfHeapMemory:
4924#    la $a0,heapMemoryMsg
4928#    j exitError
4932:divByZeroError:
4932#    la $a0,divByZeroMsg
4936#    j exitError
4940:strIndexOutOfBounds:
4940#    la $a0,strIndexOutOfBoundsMsg
4944#    j exitError
4948:arrayIndexOutOfBounds:
4948#    la $a0,arrayIndexOutOfBoundsMsg
4952#    j exitError
4956:arraySizeOutOfBounds:
4956#    la $a0,arraySizeOutOfBoundsMsg
4960#    j exitError
4964:nullPtrException:
4964#    la $a0,nullPtrExceptionMsg
4968#    j exitError
4972:badIntegerFormat:
4972#    la $a0,badIntegerFormatMsg
4976#    j exitError
4980:castException:
4980#    la $a0,castExceptionMsg
4984#    j exitError
############## data section ################
    .data
5200:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5216:cur_seg:
    .word 0

5220:lastCharRead:
    .word -2 # -2 => no buffered character
5224:prevHashConstant:
    .word 0x2785173c
5228:gcCount:
    .word 0

5232:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5259:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5282:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5317:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5351:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5384:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5415:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5463:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5484:gcMsg: 
      .asciiz "\nGC!\n"
5490:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5522:nullStr:
    .asciiz "null"
5527:trueString:
    .asciiz "true"
5532:falseString:
    .asciiz "false"
5538:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5557:newlineString:
    .asciiz "\n"
    
    .align 2
5560:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5564:seg0_start:
    .space 0x100000
1054140:seg0_end:
1054140:seg1_start:
    .space 0x100000
2102716:seg1_end:

5216#    addu $t1,0x12b68fd2
5217##...lui $at,4791
5221##...addiu $at,$at,-28718
5225##...addu $t1,$at,$t1
5228#    sw $t1,prevHashConstant # update hash constant
5232#    or $t1,0x80000000 # set top bit
5233##...lui $at,32768
5237##...or $t1,$at,$t1
5240#    and $t1,0xffffff00 # clear low bit
5241##...lui $at,65535
5245##...ori $at,$at,0xff00
5249##...and $t1,$t1,$at
5252#    or $s6,$t1
5256:firstHeaderLarge:
5256#    sw $s6,-8($t0) # store header-1 value
5260#    lw $zero,-8($t0)

    # store second header-value
5264#    sw $s7,-4($t0)   # second header-word
5268#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
5272#    move $s7,$t0
5276#    subu $sp,$sp,4
5280#    sw $t0,($sp)

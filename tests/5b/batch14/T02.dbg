5632:gcSkip4a:    
5632#    sll $t2,$t2,2 # # data bytes
5636#    addu $t2,$t2,8 # to skip header words
5640#    addu $t2,$t0,$t2 # pointer to new object
5644#    lw $t3,-8($t2) # word to swap
5648#    sw $t1,-8($t2) # store header word
5652#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
5656#    lw $t1,-12($t2) # vtable pointer
5660#    li $t0,dataArrayVTableStart # address of vtable for first data array
5664#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
5665##...slt $at,$t1,$t0
5669##...bne $at,$zero,5688

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
5672:  skipToNextObj:
5672#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
5676#    sll $t1,$t1,2 # convert to byte-count
5680#    addu $t0,$t2,$t1 # skip over object
5684#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
5688:  gcNotDataArray:
5688#    lw $t3,-4($t2) # # object words (negative treated as zero)
5692#    bge $t3,$zero,gcH2Neg2
5693##...slt $at,$t3,$zero
5697##...beq $at,$zero,5704
5700#    move $t3,$zero
5704:  gcH2Neg2:
5704#    sll $t3,$t3,2 # # object bytes
5708#    move $t0,$t2 # address of first pointer in object
5712#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
5716#    beq $t0,$s1,gcTestIterDone2
    
5720:  gcNextPointerInObject:
    # get pointer from object
5720#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
5724#    bleu $t1,$t6,gcGoNextPointerSlot
5725##...sltu $at,$t6,$t1
5729##...beq $at,$zero,5872
5732#    bgtu $t1,$t7,gcGoNextPointerSlot
5733##...sltu $at,$t7,$t1
5737##...bne $at,$zero,5872

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
5740#    lw $t8,-8($t1) # possible forwarding tag
5744#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
5748#    lw $t8,-4($t1) # forwarding pointer: object's new address
5752#    sw $t8,($t0) # update pointer in object
5756#    j gcGoNextPointerSlot # do next iteration

5760:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
5760#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
5761##...slt $at,$t8,$zero
5765##...beq $at,$zero,5780
5768#    and $t8,0xff # mask off hash bits
5769##...lui $at,0
5773##...ori $at,$at,0xff
5777##...and $t8,$t8,$at

5780:  gcSkip5:
5780#    sll $t8,$t8,2 # bytes in negative-offset portion ...
5784#    addu $t8,$t8,8 # ... add in bytes for header-words
5788#    subu $t4,$t1,$t8 # address of first word of source object
5792#    lw $t3,-4($t1) # # words in positive-offset portion
5796#    bge $t3,$zero,gcNoNeg
5797##...slt $at,$t3,$zero
5801##...beq $at,$zero,5808
5804#    move $t3,$zero # negative treated as zero
5808:  gcNoNeg:
5808#    sll $t3,$t3,2 # bytes in negative-offset portion
5812#    addu $t3,$t3,$t1 # address one word past last word of source

5816#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
5820#    lw $s0,($t4)
5824#    lw $t9,-8($t1)
5828#    sw $t9,($t4)
5832#    sw $s0,-8($t1)

    # copy all source bytes to the target
5836:  gCinnerCopy2:
5836#    lw $s0,($t4)
5840#    sw $s0,($s3)
5844#    addu $t4,$t4,4
5848#    addu $s3,$s3,4
5852#    bltu $t4,$t3,gCinnerCopy2
5853##...sltu $at,$t4,$t3
5857##...bne $at,$zero,5836

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
5860#    sw $zero,-8($t1) # 0 in first header-slot
5864#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
5868#    sw $t8,($t0)

5872:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
5872#    addu $t0,$t0,4
5876#    bltu $t0,$s1,gcNextPointerInObject
5877##...sltu $at,$t0,$s1
5881##...bne $at,$zero,5720

5884:  gcTestIterDone2:
5884#    bltu $t0,$s3,gcHeapCopyLoop
5885##...sltu $at,$t0,$s3
5889##...bne $at,$zero,5604

    ###### end outer loop to copy all non-stack-direct objects ######

5892:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
5892#    lw $s2,($sp)
5896#    addu $sp,$sp,4

    # mark us as having already GC'd
5900#    move $t5,$s5

    # go try and allocate again
5904#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
5908:vm_init:

    # mark bottom of stack
5908#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
5912#    move $s2,$zero

    #set up the "five" register
5916#    li $s5,5

5920#    la $s3,seg0_start
5924#    la $s4,seg0_end
5925##...lui $s4,16
5929##...addiu $s4,$s4,6828
    
    # return
5932#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5936:divide:
    # get parameters; abort if divisor zero
5936#    lw $t0,($sp)
5940#    lw $t1,8($sp)
5944#    beq $t0,$zero,divByZeroError
    
    # perform division
5948#    div $t1,$t0
5952#    mflo $t0

    # store result, adjust stack and return
5956#    addu $sp,$sp,8 # adjust stack
5960#    sw $t0,($sp) # store result
5964#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5968:remainder:
    # get parameters; abort if divisor zero
5968#    lw $t0,($sp)
5972#    lw $t1,8($sp)
5976#    beq $t0,$zero,divByZeroError
    
    # perform division
5980#    div $t1,$t0
5984#    mfhi $t0

    # store result, adjust stack and return
5988#    addu $sp,$sp,8 # adjust stack
5992#    sw $t0,($sp) # store result
5996#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
6000:checkCast:
    # get object, allow immediately if null
6000#    lw $t2,($sp)
6004#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
6008#    lw $t2,-12($t2) # vtable address
6012#    bge $t2,$t1,castException
6013##...slt $at,$t2,$t1
6017##...beq $at,$zero,6152
6020#    blt $t2,$t0,castException
6021##...slt $at,$t2,$t0
6025##...bne $at,$zero,6152
    
    # return, leaving object unchanged on stack
6028:  checkCastReturn:    
6028#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
6032:instanceOf:
    # get object, go return false if null
6032#    lw $t2,($sp)
6036#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
6040#    lw $t2,-12($t2) # vtable address
6044#    sge $t0,$t2,$t0 # are we >= the lower limit?
6045##...slt $t0,$t2,$t0
6049##...xori $t0,$t0,0x1
6052#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
6056#    and $t2,$t0,$t1
6060#    sw $t2,($sp)
6064:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
6064#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

6068:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
6068#    li $v0,4 # syscall-code for print-string
6072#    syscall
6076:exit:
    # print termination message
6076#    li $v0,4 # syscall-code for print-string
6080#    la $a0,exitString
6084#    syscall

    # terminate execution
6088#    li $v0,10 #syscall-code for "exit"
6092#    syscall

6096:outOfHeapMemory:
6096#    la $a0,heapMemoryMsg
6100#    j exitError
6104:divByZeroError:
6104#    la $a0,divByZeroMsg
6108#    j exitError
6112:strIndexOutOfBounds:
6112#    la $a0,strIndexOutOfBoundsMsg
6116#    j exitError
6120:arrayIndexOutOfBounds:
6120#    la $a0,arrayIndexOutOfBoundsMsg
6124#    j exitError
6128:arraySizeOutOfBounds:
6128#    la $a0,arraySizeOutOfBoundsMsg
6132#    j exitError
6136:nullPtrException:
6136#    la $a0,nullPtrExceptionMsg
6140#    j exitError
6144:badIntegerFormat:
6144#    la $a0,badIntegerFormatMsg
6148#    j exitError
6152:castException:
6152#    la $a0,castExceptionMsg
6156#    j exitError
############## data section ################
    .data
6464:hexChars:
    .ascii "0123456789abcdef"
    .align 2
6480:cur_seg:
    .word 0

6484:lastCharRead:
    .word -2 # -2 => no buffered character
6488:prevHashConstant:
    .word 0x2785173c
6492:gcCount:
    .word 0

6496:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
6523:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
6546:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
6581:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
6615:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
6648:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
6679:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
6727:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
6748:gcMsg: 
      .asciiz "\nGC!\n"
6754:gcCountMsg: 
      .asciiz "Number of garbage collections: "

6786:nullStr:
    .asciiz "null"
6791:trueString:
    .asciiz "true"
6796:falseString:
    .asciiz "false"
6802:exitString:
    .ascii "Program terminated."
    #### "falls through" here
6821:newlineString:
    .asciiz "\n"
    
    .align 2
6824:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

6828:seg0_start:
    .space 0x100000
1055404:seg0_end:
1055404:seg1_start:
    .space 0x100000
2103980:seg1_end:

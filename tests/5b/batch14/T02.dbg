5144#    addu $t0,$s6,$s7
5148#    sll $t0,$t0,2
5152#    addu $t0,$t0,8 # amount of memory needed
5156#    addu $t1,$t0,$s3
5160#    bgtu $t1,$s4,doGC
5161##...sltu $at,$s4,$t1
5165##...bne $at,$zero,5288

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # we have our character from the buffer. Wipe out
    # buffer and return
5112#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
5116#    jr $ra # return
    
5120:  doReadCh:
    # we need to actually read a character: read and return
5120#    li $v0,12 # use system call to read a character
5124#    syscall
5128#    jr $ra # return

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3056:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
3056#    lw $t0,-8($s2) # get word with hash bits from this
3060#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
3064#    addu $t0,$t1

3068#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3072:mth_equals_Object:
3072#    move $t0,$s2 # first pointer (this)
3076#    lw $t1,($sp) # second pointer
3080#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
3081##...subu $at,$t0,$t1
3085##...sltiu $t0,$at,1

3088#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3092:mth_hashCode_String:
3092#    move $t0,$s2 # put this pointer in t0

3096#    li $t2,0 # current hash value
3100#    lw $t1,-4($t0) # negative of number of characters in string
3104#    beq $t1,$zero,done_hashCode_String # if zero length => done
3108#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
3112#    and $t0,0xfffffffc # adjust for padding
3113##...lui $at,65535
3117##...ori $at,$at,0xfffc
3121##...and $t0,$t0,$at
3124#    subu $t1,$t0,$t1 # address at end of string +12
3128:loop_hashCode_String:    
3128#    sll $t4,$t2,5 # multiply by 32
3132#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
3136#    lbu $t3,-12($t0) # current character
3140#    addu $t2,$t3 # add in current character
3144#    addu $t0,1 # go to next character's address
3148#    bne $t0,$t1,loop_hashCode_String # loop back if more
3152:done_hashCode_String:    

    # push int on stack
3152#    move $t0, $t2 # put $t2 in return slot
3156#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
3160:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
3160#    subu $sp,4
3164#    sw $ra,($sp)
    
    # get hash value
3168#    lw $t2,-12($s2) # vtable address
3172#    lw $t0,($t2) # method address
3176#    jalr $t0
3180#    subu $sp,8 # push result (int in $t0) on stack
3184#    sw $s5,4($sp)
3188#    sw $t0,($sp)

    # compute print-size of hash value
3192#    li $t0, 1
3196#    lw $t1, ($sp)
3200#    srl $t1,$t1,4
3204#    beq $t1,$zero,toString_skip_loop
3208:toString_loop_top:
3208#    addu $t0,1
3212#    srl $t1,$t1,4
3216#    bne $t1,$zero,toString_loop_top
3220:toString_skip_loop:
3220#    subu $sp,8
3224#    sw $s5,4($sp)
3228#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
3232#    lw $t2,-12($s2) # vtable address
3236#    move $t0,$t2
3240:toString_checkTagBit:
3240#    subu $t0,1
3244#    lb $t1,($t0)
3248#    and $t1,0x80
3249##...lui $at,0
3253##...ori $at,$at,0x80
3257##...and $t1,$t1,$at
3260#    beq $t1,$zero,toString_checkTagBit
3264#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
3268#    subu $sp,8
3272#    sw $t1,($sp)
3276#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
3280#    move $s7,$zero # -4 offset header word
3284#    lw $t4,8($sp) # bytes for hash value
3288#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
3292#    addu $t4,8
3296#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
3300#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

3304#    li $t0,CLASS_String # store string vtable address into ...
3308#    sw $t0,-12($s7) # ... -12 offset in object header
3312#    lw $t2,-12($s2) # our object's vtable address
3316#    lw $t5,4($sp) # number characters in prefix
3320#    lw $t1,12($sp) # number of characters in hashcode
3324#    addu $t3,$t1,$t5 # number of characters in string ...
3328#    addu $t3,1 # ... including the '@' character
3332#    subu $t0,$zero,$t3 # store negated length into ...
3336#    sw $t0,-4($s7) # ... -4 offset header word
3340#    lw $t0,-8($s7) # get -8 offset header-word
3344#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
3345##...slt $at,$t0,$zero
3349##...beq $at,$zero,3368
3352#    and $t0,0xff # mask off object's hash value ...
3353##...lui $at,0
3357##...ori $at,$at,0xff
3361##...and $t0,$t0,$at
3364#    sw $t0,-8($s7) # ... and store back into -8 header-word
3368:skipMask_toString:
3368#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
3372#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
3376#    subu $t4,$t2,$t5
3380:toString_copyLoop:    
3380#    lb $t3,($t4)
3384#    and $t3,0x7f # mask off sign bit (in case first word)
3385##...lui $at,0
3389##...ori $at,$at,0x7f
3393##...and $t3,$t3,$at
3396#    sb $t3,-8($t0)
3400#    addu $t4,1
3404#    addu $t0,1
3408#    blt $t4,$t2,toString_copyLoop
3409##...slt $at,$t4,$t2
3413##...bne $at,$zero,3380

    # copy the '@' sign
3416#    li $t3,'@'
3420#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
3424#    addu $t2,$t0,$t1 # address of last byte in string to store +8
3428#    lw $t3,20($sp) # hash code to print
3432:toString_hashCopyLoop:
3432#    and $t4,$t3,0xf
3436#    srl $t3,4
3440#    lb $t4,hexChars($t4)
3444#    sb $t4,-8($t2)
3448#    subu $t2,$t2,1
3452#    bgt $t2,$t0,toString_hashCopyLoop
3453##...slt $at,$t0,$t2
3457##...bne $at,$zero,3432

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
3460#    addu $sp,28
3464#    lw $ra,($sp)
3468#    addu $sp,4
3472#    move $t0, $s7 # return string we created
3476#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
3480:mth_equals_String:
    
    # quick test for obvious false
3480#    lw $t0,($sp) # second parameter
3484#    beq $t0,$zero,goEsFalse # go return false if null
3488#    lw $t1,-12($t0) # vtable pointer
3492#    la $t2,CLASS_String # string vtable pointer
3496#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
3500#    subu $sp,12
3504#    sw $ra,8($sp)
3508#    sw $s2,4($sp)
3512#    sw $t0,($sp)
3516#    jal mth_compareTo_String
3520#    lw $s2, 4($sp) #restore this pointer and pop parameters
3524#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
3528#    seq $t0,$t0,$zero
3529##...subu $at,$t0,$zero
3533##...sltiu $t0,$at,1

    # pop return address and return $t0
3536#    lw $ra,($sp)
3540#    addu $sp,4

3544#    jr $ra # return
    
3548:goEsFalse:
    # put 0 in $t0 and return
3548#    li $t0, 0
3552#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
3556:mth_toString_String:
    #we are a string, so return this.
3556#    move $t0, $s2
3560#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
3564:mth_readLine_Lib:
    
3564#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
3568#    sw $ra, 4($sp) # save $ra
3572#    move $t1,$sp # save "original" sp

3576:  doRead:

    # read the character
3576#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
3580#    subu $t2,$v0,13
3584#    bne $t2,$zero,notReturnRL
3588#    jal readLogicalChar
3592#    subu $t2,$v0,10 # check for newline
3596#    beq $t2,$zero,foundNewLine
3600#    sw $v0,lastCharRead # push back character into queue
3604#    j foundNewLine # go process the line

3608:  notReturnRL:

    # at this point, $v0 has our character

3608#    subu $t0,$v0,10
3612#    beq $t0,$zero,foundNewLine
3616#    blt $v0,$zero,foundEof
3617##...slt $at,$v0,$zero
3621##...bne $at,$zero,3636

    # we have a character, so push it onto stack
3624#    subu $sp,$sp,4
3628#    sw $v0,($sp)

    # loop back up to get next character
3632#    j doRead

3636:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
3636#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
3640#    li $s7, 0 # return-value: null
3644#    j rlReturn # return

3648:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
3648#    subu $t0,$t1,$sp # number of chars we read (times 4)
3652#    srl $s6,$t0,2 # number of words on stack with chars
3656#    subu $sp,$sp,4 # push char-count ...
3660#    sw $s6,($sp) # ... onto stack
3664#    addu $t2,$t0,5 # GC tag, incl. for count-word
3668#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
3672#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
3676#    srl $s6,$s6,2  # data words in object
3680#    move $s7,$zero # object words in object
3684#    jal newObject  # allocate space
    
    # store header words
3688#    la $t0,CLASS_String
3692#    sw $t0,-12($s7)# store class tag (String) into object
3696#    lw $t2,4($sp) # char-count
3700#    sll $t1,$t2,2 # 4 times number of chars
3704#    subu $t2,$zero,$t2 # negative of char-count
3708#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3712#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3716#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3717##...slt $at,$t0,$zero
3721##...beq $at,$zero,3740
3724#    and $t0,0xff # mask off object's hash value ...
3725##...lui $at,0
3729##...ori $at,$at,0xff
3733##...and $t0,$t0,$at
3736#    sw $t0,-8($s7) # ... and store back into -8 header-word
3740:  skipMask_readLine:

3740#    sll $t0,$t0,2 # data bytes in object
3744#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
3748#    subu $t0,$t0,$t2 # place to store last character (plus 9)
3752#    addu $sp,$sp,8 # pop redundant object-pointer and count
3756#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

3760#    beq $sp,$t1,rlReturn
3764:  charCopyLoop:
3764#    lw $t2,($sp)
3768#    sb $t2,-9($t0)
3772#    addu $sp,$sp,4
3776#    subu $t0,$t0,1
3780#    bne $sp,$t1,charCopyLoop
3784:  rlReturn:

3784#    lw $ra, 4($sp)
3788#    addu $sp, 8   # pop $ra and pointless word off stack
3792#    move $t0, $s7 # return string we allocated in $s7
3796#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3800:mth_readInt_Lib:

    # save $ra by pushing onto stack
3800#    subu $sp,$sp,4
3804#    sw $ra,($sp)

3808:  riSkipWhiteLoop:
    # read a character
3808#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
3812#    subu $t0,$v0,32
3816#    bgt $t0,$zero,nonWhite
3817##...slt $at,$zero,$t0
3821##...bne $at,$zero,3864
3824#    beq $t0,$zero,riSkipWhiteLoop # start over if space
3828#    subu $t0,$v0,10
3832#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
3836#    subu $t0,$v0,9
3840#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
3844#    subu $t0,$v0,13
3848#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
3852#    subu $t0,$v0,12
3856#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
3860#    j badIntegerFormat # illegal integer char: abort program

3864:  nonWhite:
3864#    subu $t0,$v0,'-'
3868#    li $t4,1 # final multiplier
3872#    bne $t0,$zero,helpReadInt # go read
3876#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
3880#    jal readLogicalChar

3884:  helpReadInt:
3884#    li $t2,10
3888#    subu $t1,$v0,'0' # convert digit to 0-9 value
3892#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
3893##...sltu $at,$t1,$t2
3897##...beq $at,$zero,6144
3900#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

3904:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

3904#    jal readLogicalChar # read next character
3908#    subu $t1,$v0,'0' # convert digit to 0-9 value
3912#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
3913##...sltu $at,$t1,$t2
3917##...beq $at,$zero,3936

3920#    mul $t3,$t3,$t2 # multiply old value by 10
3921##...mult $t3,$t2
3925##...mflo $t3
3928#    addu $t3,$t3,$t1 # add in value of new digit
3932#    j digitLoop

3936:  doneDigitLoop:

    # "push back" unused character into queue
3936#    sw $v0,lastCharRead

    # restore return address
3940#    lw $ra,($sp)
3944#    addu $sp, 4

    # multiply by sign and put return value in $t0
3948#    mult $t3,$t4 # multiply to account for poss. minus sign
3952#    mflo $t3
3956#    move $t0, $t3
    
    # return
3960#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3964:mth_readChar_Lib:

    # save $ra by pushing onto stack
3964#    subu $sp,$sp,4
3968#    sw $ra,($sp)

      # read the character
3972#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
3976#    lw $ra,($sp)
3980#    addu $sp, 4
3984#    move $t0, $v0

    # return
3988#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
3992:mth_printStr_Lib:
    # check for null, printing "(null)", if so
3992#    lw $t0,($sp)
3996#    bne $t0,$zero,psNotNull

    # print "(null)"
4000#    la $a0,nullStr
4004#    li $v0,4
4008#    syscall
4012#    j donePrintStr

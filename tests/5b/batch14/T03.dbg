7576#    bleu $t1,$t6,gcTestIterDone1
7577##...sltu $at,$t6,$t1
7581##...beq $at,$zero,7744
7584#    bgtu $t1,$t7,gcTestIterDone1
7585##...sltu $at,$t7,$t1
7589##...bne $at,$zero,7744

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
7592#    lw $t2,-8($t1) # possible forwarding tag
7596#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
7600#    lw $t2,-4($t1) # forwarding pointer: object's new address
7604#    sw $t2,4($t0) # update stack value
7608#    j gcTestIterDone1 # do next iteration

7612:  gcNoForward1:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

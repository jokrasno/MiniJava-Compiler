###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
5268:mth_hashCode_String:
5268#    move $t0,$s2 # put this pointer in t0

5272#    li $t2,0 # current hash value
5276#    lw $t1,-4($t0) # negative of number of characters in string
5280#    beq $t1,$zero,done_hashCode_String # if zero length => done
5284#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
5288#    and $t0,0xfffffffc # adjust for padding
5289##...lui $at,65535
5293##...ori $at,$at,0xfffc
5297##...and $t0,$t0,$at
5300#    subu $t1,$t0,$t1 # address at end of string +12
5304:loop_hashCode_String:    
5304#    sll $t4,$t2,5 # multiply by 32
5308#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
5312#    lbu $t3,-12($t0) # current character
5316#    addu $t2,$t3 # add in current character
5320#    addu $t0,1 # go to next character's address
5324#    bne $t0,$t1,loop_hashCode_String # loop back if more
5328:done_hashCode_String:    

    # push int on stack
5328#    move $t0, $t2 # put $t2 in return slot
5332#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
5336:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
5336#    subu $sp,4
5340#    sw $ra,($sp)
    
    # get hash value
5344#    lw $t2,-12($s2) # vtable address
5348#    lw $t0,($t2) # method address
5352#    jalr $t0
5356#    subu $sp,8 # push result (int in $t0) on stack
5360#    sw $s5,4($sp)
5364#    sw $t0,($sp)

    # compute print-size of hash value
5368#    li $t0, 1
5372#    lw $t1, ($sp)
5376#    srl $t1,$t1,4
5380#    beq $t1,$zero,toString_skip_loop
5384:toString_loop_top:
5384#    addu $t0,1
5388#    srl $t1,$t1,4
5392#    bne $t1,$zero,toString_loop_top
5396:toString_skip_loop:
5396#    subu $sp,8
5400#    sw $s5,4($sp)
5404#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
5408#    lw $t2,-12($s2) # vtable address
5412#    move $t0,$t2
5416:toString_checkTagBit:
5416#    subu $t0,1
5420#    lb $t1,($t0)
5424#    and $t1,0x80
5425##...lui $at,0
5429##...ori $at,$at,0x80
5433##...and $t1,$t1,$at
5436#    beq $t1,$zero,toString_checkTagBit
5440#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
5444#    subu $sp,8
5448#    sw $t1,($sp)
5452#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
5456#    move $s7,$zero # -4 offset header word
5460#    lw $t4,8($sp) # bytes for hash value
5464#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
5468#    addu $t4,8
5472#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
5476#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

5480#    li $t0,CLASS_String # store string vtable address into ...
5484#    sw $t0,-12($s7) # ... -12 offset in object header
5488#    lw $t2,-12($s2) # our object's vtable address
5492#    lw $t5,4($sp) # number characters in prefix
5496#    lw $t1,12($sp) # number of characters in hashcode
5500#    addu $t3,$t1,$t5 # number of characters in string ...
5504#    addu $t3,1 # ... including the '@' character
5508#    subu $t0,$zero,$t3 # store negated length into ...
5512#    sw $t0,-4($s7) # ... -4 offset header word
5516#    lw $t0,-8($s7) # get -8 offset header-word
5520#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
5521##...slt $at,$t0,$zero
5525##...beq $at,$zero,5544
5528#    and $t0,0xff # mask off object's hash value ...
5529##...lui $at,0
5533##...ori $at,$at,0xff
5537##...and $t0,$t0,$at
5540#    sw $t0,-8($s7) # ... and store back into -8 header-word
5544:skipMask_toString:
5544#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
5548#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
5552#    subu $t4,$t2,$t5
5556:toString_copyLoop:    
5556#    lb $t3,($t4)
5560#    and $t3,0x7f # mask off sign bit (in case first word)
5561##...lui $at,0
5565##...ori $at,$at,0x7f
5569##...and $t3,$t3,$at
5572#    sb $t3,-8($t0)
5576#    addu $t4,1
5580#    addu $t0,1
5584#    blt $t4,$t2,toString_copyLoop
5585##...slt $at,$t4,$t2
5589##...bne $at,$zero,5556

    # copy the '@' sign
5592#    li $t3,'@'
5596#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
5600#    addu $t2,$t0,$t1 # address of last byte in string to store +8
5604#    lw $t3,20($sp) # hash code to print
5608:toString_hashCopyLoop:
5608#    and $t4,$t3,0xf
5612#    srl $t3,4
5616#    lb $t4,hexChars($t4)
5620#    sb $t4,-8($t2)
5624#    subu $t2,$t2,1
5628#    bgt $t2,$t0,toString_hashCopyLoop
5629##...slt $at,$t0,$t2
5633##...bne $at,$zero,5608

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
5636#    addu $sp,28
5640#    lw $ra,($sp)
5644#    addu $sp,4
5648#    move $t0, $s7 # return string we created
5652#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
5656:mth_equals_String:
    
    # quick test for obvious false
5656#    lw $t0,($sp) # second parameter
5660#    beq $t0,$zero,goEsFalse # go return false if null
5664#    lw $t1,-12($t0) # vtable pointer
5668#    la $t2,CLASS_String # string vtable pointer
5672#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
5676#    subu $sp,12
5680#    sw $ra,8($sp)
5684#    sw $s2,4($sp)
5688#    sw $t0,($sp)
5692#    jal mth_compareTo_String
5696#    lw $s2, 4($sp) #restore this pointer and pop parameters
5700#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
5704#    seq $t0,$t0,$zero
5705##...subu $at,$t0,$zero
5709##...sltiu $t0,$at,1

    # pop return address and return $t0
5712#    lw $ra,($sp)
5716#    addu $sp,4

5720#    jr $ra # return
    
5724:goEsFalse:
    # put 0 in $t0 and return
5724#    li $t0, 0
5728#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
5732:mth_toString_String:
    #we are a string, so return this.
5732#    move $t0, $s2
5736#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
5740:mth_readLine_Lib:
    
5740#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
5744#    sw $ra, 4($sp) # save $ra
5748#    move $t1,$sp # save "original" sp

5752:  doRead:

    # read the character
5752#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
5756#    subu $t2,$v0,13
5760#    bne $t2,$zero,notReturnRL
5764#    jal readLogicalChar
5768#    subu $t2,$v0,10 # check for newline
5772#    beq $t2,$zero,foundNewLine
5776#    sw $v0,lastCharRead # push back character into queue
5780#    j foundNewLine # go process the line

5784:  notReturnRL:

    # at this point, $v0 has our character

5784#    subu $t0,$v0,10
5788#    beq $t0,$zero,foundNewLine
5792#    blt $v0,$zero,foundEof
5793##...slt $at,$v0,$zero
5797##...bne $at,$zero,5812

    # we have a character, so push it onto stack
5800#    subu $sp,$sp,4
5804#    sw $v0,($sp)

    # loop back up to get next character
5808#    j doRead

5812:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
5812#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
5816#    li $s7, 0 # return-value: null
5820#    j rlReturn # return

5824:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
5824#    subu $t0,$t1,$sp # number of chars we read (times 4)
5828#    srl $s6,$t0,2 # number of words on stack with chars
5832#    subu $sp,$sp,4 # push char-count ...
5836#    sw $s6,($sp) # ... onto stack
5840#    addu $t2,$t0,5 # GC tag, incl. for count-word
5844#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
5848#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
5852#    srl $s6,$s6,2  # data words in object
5856#    move $s7,$zero # object words in object
5860#    jal newObject  # allocate space
    
    # store header words
5864#    la $t0,CLASS_String
5868#    sw $t0,-12($s7)# store class tag (String) into object
5872#    lw $t2,4($sp) # char-count
5876#    sll $t1,$t2,2 # 4 times number of chars
5880#    subu $t2,$zero,$t2 # negative of char-count
5884#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
5888#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
5892#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
5893##...slt $at,$t0,$zero
5897##...beq $at,$zero,5916
5900#    and $t0,0xff # mask off object's hash value ...
5901##...lui $at,0
5905##...ori $at,$at,0xff
5909##...and $t0,$t0,$at
5912#    sw $t0,-8($s7) # ... and store back into -8 header-word
5916:  skipMask_readLine:

5916#    sll $t0,$t0,2 # data bytes in object
5920#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
5924#    subu $t0,$t0,$t2 # place to store last character (plus 9)
5928#    addu $sp,$sp,8 # pop redundant object-pointer and count
5932#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

5936#    beq $sp,$t1,rlReturn
5940:  charCopyLoop:
5940#    lw $t2,($sp)
5944#    sb $t2,-9($t0)
5948#    addu $sp,$sp,4
5952#    subu $t0,$t0,1
5956#    bne $sp,$t1,charCopyLoop
5960:  rlReturn:

5960#    lw $ra, 4($sp)
5964#    addu $sp, 8   # pop $ra and pointless word off stack
5968#    move $t0, $s7 # return string we allocated in $s7
5972#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
5976:mth_readInt_Lib:

    # save $ra by pushing onto stack
5976#    subu $sp,$sp,4
5980#    sw $ra,($sp)

5984:  riSkipWhiteLoop:
    # read a character
5984#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
5988#    subu $t0,$v0,32
5992#    bgt $t0,$zero,nonWhite
5993##...slt $at,$zero,$t0
5997##...bne $at,$zero,6040
6000#    beq $t0,$zero,riSkipWhiteLoop # start over if space
6004#    subu $t0,$v0,10
6008#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
6012#    subu $t0,$v0,9
6016#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
6020#    subu $t0,$v0,13
6024#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
6028#    subu $t0,$v0,12
6032#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
6036#    j badIntegerFormat # illegal integer char: abort program

6040:  nonWhite:
6040#    subu $t0,$v0,'-'
6044#    li $t4,1 # final multiplier
6048#    bne $t0,$zero,helpReadInt # go read
6052#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
6056#    jal readLogicalChar

6060:  helpReadInt:
6060#    li $t2,10
6064#    subu $t1,$v0,'0' # convert digit to 0-9 value
6068#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
6069##...sltu $at,$t1,$t2
6073##...beq $at,$zero,8320
6076#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

6080:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

6080#    jal readLogicalChar # read next character
6084#    subu $t1,$v0,'0' # convert digit to 0-9 value
6088#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
6089##...sltu $at,$t1,$t2
6093##...beq $at,$zero,6112

6096#    mul $t3,$t3,$t2 # multiply old value by 10
6097##...mult $t3,$t2
6101##...mflo $t3
6104#    addu $t3,$t3,$t1 # add in value of new digit
6108#    j digitLoop

6112:  doneDigitLoop:

    # "push back" unused character into queue
6112#    sw $v0,lastCharRead

    # restore return address
6116#    lw $ra,($sp)
6120#    addu $sp, 4

    # multiply by sign and put return value in $t0
6124#    mult $t3,$t4 # multiply to account for poss. minus sign
6128#    mflo $t3
6132#    move $t0, $t3
    
    # return
6136#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
6140:mth_readChar_Lib:

    # save $ra by pushing onto stack
6140#    subu $sp,$sp,4
6144#    sw $ra,($sp)

      # read the character
6148#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
7276:readLogicalChar:

    # check if we already have a character
7276#    lw $v0,lastCharRead
7280#    li $t0,-2
7284#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
7288#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
7292#    jr $ra # return
    
7296:  doReadCh:
    # we need to actually read a character: read and return
7296#    li $v0,12 # use system call to read a character
7300#    syscall
7304#    jr $ra # return

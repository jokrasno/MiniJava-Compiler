7376#    li $t2,255
7380#    bgeu $s6,$t2 firstHeaderLarge
7381##...sltu $at,$s6,$t2
7385##...beq $at,$zero,7432
7388#    lw $t1,prevHashConstant
7392#    addu $t1,0x12b68fd2
7393##...lui $at,4791
7397##...addiu $at,$at,-28718
7401##...addu $t1,$at,$t1
7404#    sw $t1,prevHashConstant # update hash constant
7408#    or $t1,0x80000000 # set top bit
7409##...lui $at,32768
7413##...or $t1,$at,$t1
7416#    and $t1,0xffffff00 # clear low bit
7417##...lui $at,65535
7421##...ori $at,$at,0xff00
7425##...and $t1,$t1,$at
7428#    or $s6,$t1
7432:firstHeaderLarge:
7432#    sw $s6,-8($t0) # store header-1 value
7436#    lw $zero,-8($t0)

    # store second header-value
7440#    sw $s7,-4($t0)   # second header-word
7444#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
7448#    move $s7,$t0
7452#    subu $sp,$sp,4
7456#    sw $t0,($sp)

7460#    jr $ra

########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
7072:mth_intToChar_Lib:
    # save return address
7072#    subu $sp,$sp,4
7076#    sw $ra,($sp)

    # allocate object
7080#    li $s6,2
7084#    move $s7,$zero
7088#    jal newObject

    # get n from string.
7092#    lw $t1,8($sp)

    # store "String" tag into class field
7096#    la $t0,CLASS_String
7100#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
7104#    lw $t4,-8($s7) # # data words in source string
7108#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
7109##...slt $at,$t4,$zero
7113##...beq $at,$zero,7132
7116#    and $t4,0xff # mask off object's hash value ...
7117##...lui $at,0
7121##...ori $at,$at,0xff
7125##...and $t4,$t4,$at
7128#    sw $t4,-8($s7) # ... and store back into -8 header-word
7132:  skipMask_intToChar:

    # store data in string
7132#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
7136#    li $t0,-1
7140#    sw $t0,-4($s7)

    # we're returning $s7
7144#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
7148#    lw $ra,4($sp)
7152#    addu $sp,$sp,8

    # return
7156#    jr $ra

########################################################
# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
7160:mth_compareTo_String:
    # get string pointers and check parameter for null
7160#    lw $t0,($sp) # second string
7164#    beq $t0,$zero,nullPtrException
7168#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
7172#    lw $t2,-4($t0) # negative length of second string
7176#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
7180#    slt $t4,$t3,$t2
7184#    slt $t5,$t2,$t3
7188#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
7192#    lw $t2,-8($t0) # # data words in second string
7196#    lw $t3,-8($t1) # # data words in first string
7200#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
7204#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
7208#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
7212#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
7216#    beq $zero,$t5,skipStrCmpLenzz
7220#    move $t2,$t3
7224:  skipStrCmpLenzz:
7224#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
7228:  cmpLoopzz:
7228#    lw $t3,-8($t1) # word from str2
7232#    lw $t4,-8($t0) # word from str1
7236#    bne $t3,$t4,cmpNotEqualzz
7240#    addu $t1,$t1,4
7244#    addu $t0,$t0,4
7248#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
7252#    j cmpHitLimitzz

7256:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
7256#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
7260#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
7264#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
7268:  cmpHitLimitzz:
7268#    move $t0, $t5 # store return value
7272#    jr $ra # return

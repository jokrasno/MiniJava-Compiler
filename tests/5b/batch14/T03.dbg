7621##...lui $at,0
7625##...ori $at,$at,0xff
7629##...and $t2,$t2,$at
    #### OLD
    #### subu $t2,$zero,$t2 # set to 1 if -1 (number of data words)

7632:  gcSkip2:
7632#    sll $t2,$t2,2
7636#    addu $t2,$t2,8
7640#    subu $t4,$t1,$t2 # address of first word of source
7644#    lw $t3,-4($t1) # number of object words (negative means zero)

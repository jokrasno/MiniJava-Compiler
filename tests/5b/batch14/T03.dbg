7649##...slt $at,$t3,$zero
7653##...beq $at,$zero,7660
7656#    move $t3,$zero
7660:  gcH2Neg1:
7660#    sll $t3,$t3,2
7664#    addu $t3,$t3,$t1 # address one word past last word of source

7668#    addu $t2,$s3,$t2 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object (i.e., the address just beyond the object's header)
    # - $t2 contains the pointer to the target object
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0-2
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger" in the target space
7672#    lw $s0,($t4)
7676#    lw $s1,-8($t1)
7680#    sw $s1,($t4)
7684#    sw $s0,-8($t1)
    
    # copy all source bytes to the target
7688:  gCinnerCopy1:
7688#    lw $s0,($t4)
7692#    sw $s0,($s3)
7696#    addu $t4,$t4,4
7700#    addu $s3,$s3,4
7704#    bltu $t4,$t3,gCinnerCopy1
7705##...sltu $at,$t4,$t3
7709##...bne $at,$zero,7688

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
7712#    sw $zero,-8($t1) # 0 in first header-slot
7716#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
7720#    sw $t2,4($t0)
7724#    lw $zero,-8($t2)
7728#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
7732#    j gcTestIterDone1

7736:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
7736#    subu $t0,$t0,$t1
7740#    subu $t0,$t0,3

7744:  gcTestIterDone1:
7744#    bgeu $t0,$sp,gcStackCopyLoop
7745##...sltu $at,$t0,$sp
7749##...beq $at,$zero,7560

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
7752#    lw $t1,cur_seg
7756#    la $t0,seg0_start
7760#    beq $t1,$zero,gcSkip4
7764#    la $t0,seg1_start
7765##...lui $t0,16
7769##...addiu $t0,$t0,8960


7772:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
7772#    bgeu $t0,$s3,gcFinishUp
7773##...sltu $at,$t0,$s3
7777##...beq $at,$zero,8068

    ###### begin outer loop to copy all non-stack-direct objects ######

7780:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
7780#    lw $t1,($t0) # (what will be) first header word for current object
7784#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
7788#    bge $t2,$zero,gcSkip4a # are there hash bits?
7789##...slt $at,$t2,$zero
7793##...beq $at,$zero,7808
7796#    and $t2,0xff # mask off hash bits
7797##...lui $at,0
7801##...ori $at,$at,0xff
7805##...and $t2,$t2,$at
7808:gcSkip4a:    
7808#    sll $t2,$t2,2 # # data bytes
7812#    addu $t2,$t2,8 # to skip header words
7816#    addu $t2,$t0,$t2 # pointer to new object
7820#    lw $t3,-8($t2) # word to swap
7824#    sw $t1,-8($t2) # store header word
7828#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
7832#    lw $t1,-12($t2) # vtable pointer
7836#    li $t0,dataArrayVTableStart # address of vtable for first data array
7840#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
7841##...slt $at,$t1,$t0
7845##...bne $at,$zero,7864

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
7848:  skipToNextObj:
7848#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
7852#    sll $t1,$t1,2 # convert to byte-count
7856#    addu $t0,$t2,$t1 # skip over object
7860#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
7864:  gcNotDataArray:
7864#    lw $t3,-4($t2) # # object words (negative treated as zero)
7868#    bge $t3,$zero,gcH2Neg2
7869##...slt $at,$t3,$zero
7873##...beq $at,$zero,7880
7876#    move $t3,$zero
7880:  gcH2Neg2:
7880#    sll $t3,$t3,2 # # object bytes
7884#    move $t0,$t2 # address of first pointer in object
7888#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
7892#    beq $t0,$s1,gcTestIterDone2
    
7896:  gcNextPointerInObject:
    # get pointer from object
7896#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
7900#    bleu $t1,$t6,gcGoNextPointerSlot
7901##...sltu $at,$t6,$t1
7905##...beq $at,$zero,8048
7908#    bgtu $t1,$t7,gcGoNextPointerSlot
7909##...sltu $at,$t7,$t1
7913##...bne $at,$zero,8048

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
7916#    lw $t8,-8($t1) # possible forwarding tag
7920#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
7924#    lw $t8,-4($t1) # forwarding pointer: object's new address
7928#    sw $t8,($t0) # update pointer in object
7932#    j gcGoNextPointerSlot # do next iteration

7936:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
7936#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
7937##...slt $at,$t8,$zero
7941##...beq $at,$zero,7956
7944#    and $t8,0xff # mask off hash bits
7945##...lui $at,0
7949##...ori $at,$at,0xff
7953##...and $t8,$t8,$at

7956:  gcSkip5:
7956#    sll $t8,$t8,2 # bytes in negative-offset portion ...
7960#    addu $t8,$t8,8 # ... add in bytes for header-words
7964#    subu $t4,$t1,$t8 # address of first word of source object
7968#    lw $t3,-4($t1) # # words in positive-offset portion
7972#    bge $t3,$zero,gcNoNeg
7973##...slt $at,$t3,$zero
7977##...beq $at,$zero,7984
7980#    move $t3,$zero # negative treated as zero
7984:  gcNoNeg:
7984#    sll $t3,$t3,2 # bytes in negative-offset portion
7988#    addu $t3,$t3,$t1 # address one word past last word of source

7992#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
7996#    lw $s0,($t4)
8000#    lw $t9,-8($t1)
8004#    sw $t9,($t4)
8008#    sw $s0,-8($t1)

    # copy all source bytes to the target
8012:  gCinnerCopy2:
8012#    lw $s0,($t4)
8016#    sw $s0,($s3)
8020#    addu $t4,$t4,4
8024#    addu $s3,$s3,4
8028#    bltu $t4,$t3,gCinnerCopy2
8029##...sltu $at,$t4,$t3
8033##...bne $at,$zero,8012

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
8036#    sw $zero,-8($t1) # 0 in first header-slot
8040#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
8044#    sw $t8,($t0)

8048:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
8048#    addu $t0,$t0,4
8052#    bltu $t0,$s1,gcNextPointerInObject
8053##...sltu $at,$t0,$s1
8057##...bne $at,$zero,7896

8060:  gcTestIterDone2:
8060#    bltu $t0,$s3,gcHeapCopyLoop
8061##...sltu $at,$t0,$s3
8065##...bne $at,$zero,7780

    ###### end outer loop to copy all non-stack-direct objects ######

8068:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
8068#    lw $s2,($sp)
8072#    addu $sp,$sp,4

    # mark us as having already GC'd
8076#    move $t5,$s5

    # go try and allocate again
8080#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
8084:vm_init:

    # mark bottom of stack
8084#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
8088#    move $s2,$zero

    #set up the "five" register
8092#    li $s5,5

8096#    la $s3,seg0_start
8100#    la $s4,seg0_end
8101##...lui $s4,16
8105##...addiu $s4,$s4,8960
    
    # return
8108#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
8112:divide:
    # get parameters; abort if divisor zero
8112#    lw $t0,($sp)
8116#    lw $t1,8($sp)
8120#    beq $t0,$zero,divByZeroError
    
    # perform division
8124#    div $t1,$t0
8128#    mflo $t0

    # store result, adjust stack and return
8132#    addu $sp,$sp,8 # adjust stack
8136#    sw $t0,($sp) # store result
8140#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
8144:remainder:
    # get parameters; abort if divisor zero
8144#    lw $t0,($sp)
8148#    lw $t1,8($sp)
8152#    beq $t0,$zero,divByZeroError
    
    # perform division
8156#    div $t1,$t0
8160#    mfhi $t0

    # store result, adjust stack and return
8164#    addu $sp,$sp,8 # adjust stack
8168#    sw $t0,($sp) # store result
8172#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
8176:checkCast:
    # get object, allow immediately if null
8176#    lw $t2,($sp)
8180#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
8184#    lw $t2,-12($t2) # vtable address
8188#    bge $t2,$t1,castException
8189##...slt $at,$t2,$t1
8193##...beq $at,$zero,8328
8196#    blt $t2,$t0,castException
8197##...slt $at,$t2,$t0
8201##...bne $at,$zero,8328
    
    # return, leaving object unchanged on stack
8204:  checkCastReturn:    
8204#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
8208:instanceOf:
    # get object, go return false if null
8208#    lw $t2,($sp)
8212#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
8216#    lw $t2,-12($t2) # vtable address
8220#    sge $t0,$t2,$t0 # are we >= the lower limit?
8221##...slt $t0,$t2,$t0
8225##...xori $t0,$t0,0x1
8228#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
8232#    and $t2,$t0,$t1
8236#    sw $t2,($sp)
8240:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
8240#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

8244:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
8244#    li $v0,4 # syscall-code for print-string
8248#    syscall
8252:exit:
    # print termination message
8252#    li $v0,4 # syscall-code for print-string
8256#    la $a0,exitString
8260#    syscall

    # terminate execution
8264#    li $v0,10 #syscall-code for "exit"
8268#    syscall

8272:outOfHeapMemory:
8272#    la $a0,heapMemoryMsg
8276#    j exitError
8280:divByZeroError:
8280#    la $a0,divByZeroMsg
8284#    j exitError
8288:strIndexOutOfBounds:
8288#    la $a0,strIndexOutOfBoundsMsg
8292#    j exitError
8296:arrayIndexOutOfBounds:
8296#    la $a0,arrayIndexOutOfBoundsMsg
8300#    j exitError
8304:arraySizeOutOfBounds:
8304#    la $a0,arraySizeOutOfBoundsMsg
8308#    j exitError
8312:nullPtrException:
8312#    la $a0,nullPtrExceptionMsg
8316#    j exitError
8320:badIntegerFormat:
8320#    la $a0,badIntegerFormatMsg
8324#    j exitError
8328:castException:
8328#    la $a0,castExceptionMsg
8332#    j exitError
############## data section ################
    .data
8596:hexChars:
    .ascii "0123456789abcdef"
    .align 2
8612:cur_seg:
    .word 0

8616:lastCharRead:
    .word -2 # -2 => no buffered character
8620:prevHashConstant:
    .word 0x2785173c
8624:gcCount:
    .word 0

8628:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
8655:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
8678:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
8713:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
8747:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
8780:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
8811:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
8859:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
8880:gcMsg: 
      .asciiz "\nGC!\n"
8886:gcCountMsg: 
      .asciiz "Number of garbage collections: "

8918:nullStr:
    .asciiz "null"
8923:trueString:
    .asciiz "true"
8928:falseString:
    .asciiz "false"
8934:exitString:
    .ascii "Program terminated."
    #### "falls through" here
8953:newlineString:
    .asciiz "\n"
    
    .align 2
8956:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

8960:seg0_start:
    .space 0x100000
1057536:seg0_end:
1057536:seg1_start:
    .space 0x100000
2106112:seg1_end:

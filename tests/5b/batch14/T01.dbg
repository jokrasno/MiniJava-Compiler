    # bump $t0 to next slot in object; if not done, loop back
3280#    addu $t0,$t0,4
3284#    bltu $t0,$s1,gcNextPointerInObject
3285##...sltu $at,$t0,$s1
3289##...bne $at,$zero,3128

3292:  gcTestIterDone2:
3292#    bltu $t0,$s3,gcHeapCopyLoop
3293##...sltu $at,$t0,$s3
3297##...bne $at,$zero,3012

    ###### end outer loop to copy all non-stack-direct objects ######

3300:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3300#    lw $s2,($sp)
3304#    addu $sp,$sp,4

    # mark us as having already GC'd
3308#    move $t5,$s5

    # go try and allocate again
3312#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3316:vm_init:

    # mark bottom of stack
3316#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3320#    move $s2,$zero

    #set up the "five" register
3324#    li $s5,5

3328#    la $s3,seg0_start
3332#    la $s4,seg0_end
3333##...lui $s4,16
3337##...addiu $s4,$s4,4180
    
    # return
3340#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3344:divide:
    # get parameters; abort if divisor zero
3344#    lw $t0,($sp)
3348#    lw $t1,8($sp)
3352#    beq $t0,$zero,divByZeroError
    
    # perform division
3356#    div $t1,$t0
3360#    mflo $t0

    # store result, adjust stack and return
3364#    addu $sp,$sp,8 # adjust stack
3368#    sw $t0,($sp) # store result
3372#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3376:remainder:
    # get parameters; abort if divisor zero
3376#    lw $t0,($sp)
3380#    lw $t1,8($sp)
3384#    beq $t0,$zero,divByZeroError
    
    # perform division
3388#    div $t1,$t0
3392#    mfhi $t0

    # store result, adjust stack and return
3396#    addu $sp,$sp,8 # adjust stack
3400#    sw $t0,($sp) # store result
3404#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3408:checkCast:
    # get object, allow immediately if null
3408#    lw $t2,($sp)
3412#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3416#    lw $t2,-12($t2) # vtable address
3420#    bge $t2,$t1,castException
3421##...slt $at,$t2,$t1
3425##...beq $at,$zero,3560
3428#    blt $t2,$t0,castException
3429##...slt $at,$t2,$t0
3433##...bne $at,$zero,3560
    
    # return, leaving object unchanged on stack
3436:  checkCastReturn:    
3436#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3440:instanceOf:
    # get object, go return false if null
3440#    lw $t2,($sp)
3444#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3448#    lw $t2,-12($t2) # vtable address
3452#    sge $t0,$t2,$t0 # are we >= the lower limit?
3453##...slt $t0,$t2,$t0
3457##...xori $t0,$t0,0x1
3460#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3464#    and $t2,$t0,$t1
3468#    sw $t2,($sp)
3472:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3472#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3476:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3476#    li $v0,4 # syscall-code for print-string
3480#    syscall
3484:exit:
    # print termination message
3484#    li $v0,4 # syscall-code for print-string
3488#    la $a0,exitString
3492#    syscall

    # terminate execution
3496#    li $v0,10 #syscall-code for "exit"
3500#    syscall

3504:outOfHeapMemory:
3504#    la $a0,heapMemoryMsg
3508#    j exitError
3512:divByZeroError:
3512#    la $a0,divByZeroMsg
3516#    j exitError
3520:strIndexOutOfBounds:
3520#    la $a0,strIndexOutOfBoundsMsg
3524#    j exitError
3528:arrayIndexOutOfBounds:
3528#    la $a0,arrayIndexOutOfBoundsMsg
3532#    j exitError
3536:arraySizeOutOfBounds:
3536#    la $a0,arraySizeOutOfBoundsMsg
3540#    j exitError
3544:nullPtrException:
3544#    la $a0,nullPtrExceptionMsg
3548#    j exitError
3552:badIntegerFormat:
3552#    la $a0,badIntegerFormatMsg
3556#    j exitError
3560:castException:
3560#    la $a0,castExceptionMsg
3564#    j exitError
############## data section ################
    .data
3816:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3832:cur_seg:
    .word 0

3836:lastCharRead:
    .word -2 # -2 => no buffered character
3840:prevHashConstant:
    .word 0x2785173c
3844:gcCount:
    .word 0

3848:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3875:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3898:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3933:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3967:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4000:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4031:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4079:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4100:gcMsg: 
      .asciiz "\nGC!\n"
4106:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4138:nullStr:
    .asciiz "null"
4143:trueString:
    .asciiz "true"
4148:falseString:
    .asciiz "false"
4154:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4173:newlineString:
    .asciiz "\n"
    
    .align 2
4176:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4180:seg0_start:
    .space 0x100000
1052756:seg0_end:
1052756:seg1_start:
    .space 0x100000
2101332:seg1_end:

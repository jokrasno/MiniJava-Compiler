1472#    subu $t1,$t0,$t1 # first word in string
1476#    lw $t0,4($t0) # negative of string-length
1480#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
1484#    beq $t0,$t1,donePrintStr
1488:  psLoop:
1488#    lb $a0,($t1) # next byte
1492#    li $v0,11 # code for printing char
1496#        syscall # print the char
1500#    addu $t1,$t1,1 # go to next char
1504#    blt $t1,$t0,psLoop
1505##...slt $at,$t1,$t0
1509##...bne $at,$zero,1488

1512:  donePrintStr:

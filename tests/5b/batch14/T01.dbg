###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
972:mth_readLine_Lib:
    
972#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
976#    sw $ra, 4($sp) # save $ra
980#    move $t1,$sp # save "original" sp

984:  doRead:

    # read the character
984#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
988#    subu $t2,$v0,13
992#    bne $t2,$zero,notReturnRL
996#    jal readLogicalChar
1000#    subu $t2,$v0,10 # check for newline
1004#    beq $t2,$zero,foundNewLine
1008#    sw $v0,lastCharRead # push back character into queue
1012#    j foundNewLine # go process the line

1016:  notReturnRL:

    # at this point, $v0 has our character

1016#    subu $t0,$v0,10
1020#    beq $t0,$zero,foundNewLine
1024#    blt $v0,$zero,foundEof
1025##...slt $at,$v0,$zero
1029##...bne $at,$zero,1044

    # we have a character, so push it onto stack
1032#    subu $sp,$sp,4
1036#    sw $v0,($sp)

    # loop back up to get next character
1040#    j doRead

1044:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1044#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1048#    li $s7, 0 # return-value: null
1052#    j rlReturn # return

1056:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1056#    subu $t0,$t1,$sp # number of chars we read (times 4)
1060#    srl $s6,$t0,2 # number of words on stack with chars
1064#    subu $sp,$sp,4 # push char-count ...
1068#    sw $s6,($sp) # ... onto stack
1072#    addu $t2,$t0,5 # GC tag, incl. for count-word
1076#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1080#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1084#    srl $s6,$s6,2  # data words in object
1088#    move $s7,$zero # object words in object
1092#    jal newObject  # allocate space
    
    # store header words
1096#    la $t0,CLASS_String
1100#    sw $t0,-12($s7)# store class tag (String) into object
1104#    lw $t2,4($sp) # char-count
1108#    sll $t1,$t2,2 # 4 times number of chars
1112#    subu $t2,$zero,$t2 # negative of char-count
1116#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1120#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1124#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1125##...slt $at,$t0,$zero
1129##...beq $at,$zero,1148
1132#    and $t0,0xff # mask off object's hash value ...
1133##...lui $at,0
1137##...ori $at,$at,0xff
1141##...and $t0,$t0,$at
1144#    sw $t0,-8($s7) # ... and store back into -8 header-word
1148:  skipMask_readLine:

1148#    sll $t0,$t0,2 # data bytes in object
1152#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1156#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1160#    addu $sp,$sp,8 # pop redundant object-pointer and count
1164#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1168#    beq $sp,$t1,rlReturn
1172:  charCopyLoop:
1172#    lw $t2,($sp)
1176#    sb $t2,-9($t0)
1180#    addu $sp,$sp,4
1184#    subu $t0,$t0,1
1188#    bne $sp,$t1,charCopyLoop
1192:  rlReturn:

1192#    lw $ra, 4($sp)
1196#    addu $sp, 8   # pop $ra and pointless word off stack
1200#    move $t0, $s7 # return string we allocated in $s7
1204#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1208:mth_readInt_Lib:

    # save $ra by pushing onto stack
1208#    subu $sp,$sp,4
1212#    sw $ra,($sp)

1216:  riSkipWhiteLoop:
    # read a character
1216#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1220#    subu $t0,$v0,32
1224#    bgt $t0,$zero,nonWhite
1225##...slt $at,$zero,$t0
1229##...bne $at,$zero,1272
1232#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1236#    subu $t0,$v0,10
1240#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1244#    subu $t0,$v0,9
1248#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1252#    subu $t0,$v0,13
1256#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1260#    subu $t0,$v0,12
1264#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1268#    j badIntegerFormat # illegal integer char: abort program

1272:  nonWhite:
1272#    subu $t0,$v0,'-'
1276#    li $t4,1 # final multiplier
1280#    bne $t0,$zero,helpReadInt # go read
1284#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1288#    jal readLogicalChar

1292:  helpReadInt:
1292#    li $t2,10
1296#    subu $t1,$v0,'0' # convert digit to 0-9 value
1300#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1301##...sltu $at,$t1,$t2
1305##...beq $at,$zero,3552
1308#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1312:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1312#    jal readLogicalChar # read next character
1316#    subu $t1,$v0,'0' # convert digit to 0-9 value
1320#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1321##...sltu $at,$t1,$t2
1325##...beq $at,$zero,1344

1328#    mul $t3,$t3,$t2 # multiply old value by 10
1329##...mult $t3,$t2
1333##...mflo $t3
1336#    addu $t3,$t3,$t1 # add in value of new digit
1340#    j digitLoop

1344:  doneDigitLoop:

    # "push back" unused character into queue
1344#    sw $v0,lastCharRead

    # restore return address
1348#    lw $ra,($sp)
1352#    addu $sp, 4

    # multiply by sign and put return value in $t0
1356#    mult $t3,$t4 # multiply to account for poss. minus sign
1360#    mflo $t3
1364#    move $t0, $t3
    
    # return
1368#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1372:mth_readChar_Lib:

    # save $ra by pushing onto stack
1372#    subu $sp,$sp,4
1376#    sw $ra,($sp)

      # read the character
1380#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
1384#    lw $ra,($sp)
1388#    addu $sp, 4
1392#    move $t0, $v0

    # return
1396#    jr $ra

########################################################
# printStr(str) - library method (class Lib)

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
464:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
464#    lw $t0,-8($s2) # get word with hash bits from this
468#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
472#    addu $t0,$t1

476#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
480:mth_equals_Object:
480#    move $t0,$s2 # first pointer (this)
484#    lw $t1,($sp) # second pointer
488#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
489##...subu $at,$t0,$t1
493##...sltiu $t0,$at,1

496#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
500:mth_hashCode_String:
500#    move $t0,$s2 # put this pointer in t0

504#    li $t2,0 # current hash value
508#    lw $t1,-4($t0) # negative of number of characters in string
512#    beq $t1,$zero,done_hashCode_String # if zero length => done
516#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
520#    and $t0,0xfffffffc # adjust for padding
521##...lui $at,65535
525##...ori $at,$at,0xfffc
529##...and $t0,$t0,$at
532#    subu $t1,$t0,$t1 # address at end of string +12
536:loop_hashCode_String:    
536#    sll $t4,$t2,5 # multiply by 32
540#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
544#    lbu $t3,-12($t0) # current character
548#    addu $t2,$t3 # add in current character
552#    addu $t0,1 # go to next character's address
556#    bne $t0,$t1,loop_hashCode_String # loop back if more
560:done_hashCode_String:    

    # push int on stack
560#    move $t0, $t2 # put $t2 in return slot
564#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
568:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
568#    subu $sp,4
572#    sw $ra,($sp)
    
    # get hash value
576#    lw $t2,-12($s2) # vtable address
580#    lw $t0,($t2) # method address
584#    jalr $t0
588#    subu $sp,8 # push result (int in $t0) on stack
592#    sw $s5,4($sp)
596#    sw $t0,($sp)

    # compute print-size of hash value
600#    li $t0, 1
604#    lw $t1, ($sp)
608#    srl $t1,$t1,4
612#    beq $t1,$zero,toString_skip_loop
616:toString_loop_top:
616#    addu $t0,1
620#    srl $t1,$t1,4
624#    bne $t1,$zero,toString_loop_top
628:toString_skip_loop:
628#    subu $sp,8
632#    sw $s5,4($sp)
636#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
640#    lw $t2,-12($s2) # vtable address
644#    move $t0,$t2
648:toString_checkTagBit:
648#    subu $t0,1
652#    lb $t1,($t0)
656#    and $t1,0x80
657##...lui $at,0
661##...ori $at,$at,0x80
665##...and $t1,$t1,$at
668#    beq $t1,$zero,toString_checkTagBit
672#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
676#    subu $sp,8
680#    sw $t1,($sp)
684#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
688#    move $s7,$zero # -4 offset header word
692#    lw $t4,8($sp) # bytes for hash value
696#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
700#    addu $t4,8
704#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
708#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

712#    li $t0,CLASS_String # store string vtable address into ...
716#    sw $t0,-12($s7) # ... -12 offset in object header
720#    lw $t2,-12($s2) # our object's vtable address
724#    lw $t5,4($sp) # number characters in prefix
728#    lw $t1,12($sp) # number of characters in hashcode
732#    addu $t3,$t1,$t5 # number of characters in string ...
736#    addu $t3,1 # ... including the '@' character
740#    subu $t0,$zero,$t3 # store negated length into ...
744#    sw $t0,-4($s7) # ... -4 offset header word
748#    lw $t0,-8($s7) # get -8 offset header-word
752#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
753##...slt $at,$t0,$zero
757##...beq $at,$zero,776
760#    and $t0,0xff # mask off object's hash value ...
761##...lui $at,0
765##...ori $at,$at,0xff
769##...and $t0,$t0,$at
772#    sw $t0,-8($s7) # ... and store back into -8 header-word
776:skipMask_toString:
776#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
780#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
784#    subu $t4,$t2,$t5
788:toString_copyLoop:    
788#    lb $t3,($t4)
792#    and $t3,0x7f # mask off sign bit (in case first word)
793##...lui $at,0
797##...ori $at,$at,0x7f
801##...and $t3,$t3,$at
804#    sb $t3,-8($t0)
808#    addu $t4,1
812#    addu $t0,1
816#    blt $t4,$t2,toString_copyLoop
817##...slt $at,$t4,$t2
821##...bne $at,$zero,788

    # copy the '@' sign
824#    li $t3,'@'
828#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
832#    addu $t2,$t0,$t1 # address of last byte in string to store +8
836#    lw $t3,20($sp) # hash code to print
840:toString_hashCopyLoop:

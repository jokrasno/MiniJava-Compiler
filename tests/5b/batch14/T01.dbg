###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
888:mth_equals_String:
    
    # quick test for obvious false
888#    lw $t0,($sp) # second parameter
892#    beq $t0,$zero,goEsFalse # go return false if null
896#    lw $t1,-12($t0) # vtable pointer
900#    la $t2,CLASS_String # string vtable pointer
904#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
908#    subu $sp,12
912#    sw $ra,8($sp)
916#    sw $s2,4($sp)
920#    sw $t0,($sp)
924#    jal mth_compareTo_String
928#    lw $s2, 4($sp) #restore this pointer and pop parameters
932#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
936#    seq $t0,$t0,$zero
937##...subu $at,$t0,$zero
941##...sltiu $t0,$at,1

    # pop return address and return $t0
944#    lw $ra,($sp)
948#    addu $sp,4

952#    jr $ra # return
    
956:goEsFalse:
    # put 0 in $t0 and return
956#    li $t0, 0
960#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
964:mth_toString_String:
    #we are a string, so return this.
964#    move $t0, $s2
968#    jr $ra

########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
1560:mth_substring_String:

    # save $ra by pushing onto stack
1560#    subu $sp,$sp,4
1564#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
1568#    move $t0,$s2
1572#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
1576#    lw $t0,-4($t0) # negative of string length
1580#    subu $t0,$zero,$t0 # string length
1584#    lw $t1,4($sp) # k
1588#    lw $t2,12($sp) # n
1592#    bgt $zero,$t2,strIndexOutOfBounds
1593##...slt $at,$t2,$zero
1597##...bne $at,$zero,3520
1600#    bgt $t2,$t1,strIndexOutOfBounds
1601##...slt $at,$t1,$t2
1605##...bne $at,$zero,3520
1608#    bgt $t1,$t0,strIndexOutOfBounds
1609##...slt $at,$t0,$t1
1613##...bne $at,$zero,3520

    # allocate memory
1616#    subu $s6,$t1,$t2 # # chars in target-string
1620#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
1624#    srl $s6,$s6,2 # convert bytes-count to word-count
1628#    move $s7,$zero # (no object-bytes in string)
1632#    jal newObject

    # store "String" tag in object-type field
1636#    la $t0,CLASS_String
1640#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
1644#    lw $t4,-8($s7) # data words in source string
1648#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
1649##...slt $at,$t4,$zero
1653##...beq $at,$zero,1672
1656#    and $t4,0xff # mask off object's hash value ...
1657##...lui $at,0
1661##...ori $at,$at,0xff
1665##...and $t4,$t4,$at
1668#    sw $t4,-8($s7) # ... and store back into -8 header-word
1672:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
1672#    lw $t1,8($sp) # k
1676#    lw $t2,16($sp) # n
1680#    subu $t0,$t2,$t1 # value to store
1684#    sw $t0,-4($s7) # store value
    
1688#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
1692#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
1696#    lw $t4,-8($t3) # data words in source string
1700#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
1704#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
1708#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
1712#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
1716#    lw $t2,-8($s7)   # data words in target string
1720#    sll $t2,$t2,2    # data bytes in target string
1724#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target
1728:  subCopyLoopzz:
1728#    lb $t4,-8($t3)
1732#    sb $t4,-8($t2)
1736#    addu $t2,$t2,1
1740#    addu $t3,$t3,1
1744#    blt $t3,$t1,subCopyLoopzz
1745##...slt $at,$t3,$t1
1749##...bne $at,$zero,1728
    
1752:  doneSubCopyzz:
    # restore return address, store return value, pop stack
1752#    lw $ra,4($sp) # restore $ra
1756#    addu $sp,$sp,8 # pop ra, and allocated newObject
1760#    move $t0, $s7 # we're returning the string we got back
                  # from newObject
    
    # return
1764#    jr $ra

########################################################
# length() - library method (class String)
# returns length of a string: Java: str.length()
# - parameters:
#   - ($sp) - old this pointer
# - return-value:
#   - $t0 - length of string
########################################################
1768:mth_length_String:

    # the length is the negative of 4($s2)
1768#    lw $t0,-4($s2) # -length
1772#    subu $t0,$zero,$t0

    # return
1776#    jr $ra


########################################################
# str1.concat(str2) - library method (class String)
# (as in Java)
# - parameters:
#   - ($sp) - the second string
#   - 4($sp) - old this pointer
#   - $s2 - the first string (this)
# - returns:
#   - $t0 - pointer to concatenated string
########################################################
1780:mth_concat_String:
    # save $ra by pushing onto stack
1780#    subu $sp,$sp,4
1784#    sw $ra, ($sp)

    # get string pointers and check parameter for null
1788#    lw $t0,4($sp)
1792#    beq $t0,$zero,nullPtrException
1796#    move $t1,$s2
    
    # get lengths of two strings; allocate object whose size
    # is their sum divided by 4 (rounded up) plus 1
1800#    lw $t0,-4($t0) # negative size of second object
1804#    lw $t1,-4($t1) # negative size of first object
1808#    addu $s6,$t0,$t1 # sum of negative sizes
1812#    sra $s6,$s6,2 # negative word-size of char part
1816#    subu $s6,$zero,$s6 # word size of char part
1820#    addu $s6,$s6,1 # data word size, including v-table word
1824#    move $s7,$zero
1828#    jal newObject

    # store String vtable address in vtable address field
1832#    la $t0,CLASS_String
1836#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
1840#    lw $t4,-8($s7) # # data words in source string
1844#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
1845##...slt $at,$t4,$zero
1849##...beq $at,$zero,1868
1852#    and $t4,0xff # mask off object's hash value ...
1853##...lui $at,0
1857##...ori $at,$at,0xff
1861##...and $t4,$t4,$at
1864#    sw $t4,-8($s7) # ... and store back into -8 header-word
1868:skipMask_concat:

1868#    move $t9, $s7 # store return string in unused (I hope) t9 register

    #restore $t0, and $t1 after they were potentially blown
    #away by newObject
1872#    move $t1,$s2   # first object
1876#    lw $t0,8($sp) # second object
    
    # get negative sizes; sum and store in new object size-field
1880#    lw $t2,-4($t0) # negative length of second object
1884#    lw $t3,-4($t1) # negative length of first object
1888#    addu $t4,$t2,$t3 # sum of negative lengths
1892#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is pointer to first object
    # - $t2 is negated length of second object
    # - $t3 is negated length of first object
    # - $s7 is pointer to new object
    #########################################################

    # compute addresses for moving data from first string
1896#    lw $t4,-8($t1) # # data words in first string
1900#    sll $t4,$t4,2 # # data bytes in first string
1904#    subu $t1,$t1,$t4 # addr. (+8) of first byte in first string
1908#    lw $t4,-8($s7) # # data words in new string
1912#    sll $t4,$t4,2 # # data bytes in new string
1916#    subu $s7,$s7,$t4 # addr. (+8) of first byte in new string
1920#    beq $zero,$t3,doneConcatLoop1zz # skip first loop is no bytes to copy
1924#    subu $t3,$t1,$t3 # limit (+8) address for first string

    #########################################################
    # at this point:
    # - $t0 is pointer to second object
    # - $t1 is address (+8) of first byte in first object
    # - $t2 is negated length of second object
    # - $t3 is limit-address (+8) of data in first object
    # - $s7 is address (+8) of first byte in new object
    # - note: if data-length of first object is zero, then
    #   we skip over this part, and go to 'doneConcatLoop1'
    #########################################################

    # copy the bytes from first source to target
1928:  concatLoop1zz:
1928#    lb $t4,-8($t1)
1932#    sb $t4,-8($s7)
1936#    addu $s7,$s7,1
1940#    addu $t1,$t1,1
1944#    blt $t1,$t3,concatLoop1zz
1945##...slt $at,$t1,$t3
1949##...bne $at,$zero,1928
1952:  doneConcatLoop1zz:
  
    # if second string is empty, skip rest of copy
1952#    beq $zero,$t2,doneConcatLoop2zz

      # compute addresses for moving data from second string
1956#    lw $t4,-8($t0) # # data words in second string
1960#    sll $t4,$t4,2 # # data bytes in second string
1964#    subu $t1,$t0,$t4 # addr. (+8) of first byte in second string
1968#    subu $t3,$t1,$t2 # limit (+8) address for second string

    #########################################################
    # at this point:
    # - $t1 is address (+8) of first byte in second object
    # - $t3 is limit-address (+8) of data in second object
    # - $s7 is address (+8) of next byte to write new object
    # - note: if data-length of second object is zero, then
    #   we skip over this part, and go to 'doneConcatLoop2'
    #########################################################

    # copy the bytes from first source to target
1972:  concatLoop2zz:
1972#    lb $t4,-8($t1)
1976#    sb $t4,-8($s7)
1980#    addu $s7,$s7,1
1984#    addu $t1,$t1,1
1988#    blt $t1,$t3,concatLoop2zz
1989##...slt $at,$t1,$t3
1993##...bne $at,$zero,1972
1996:  doneConcatLoop2zz:
 
1996:  concatRtnzz:
    # return
1996#    move $t0, $t9 # put saved return string in $t0
2000#    lw $ra, 4($sp)
2004#    addu $sp, 8 # pop ra and allocated newObject
2008#    jr $ra

########################################################
# str.charAt(n) - library method (class String)
# accesses a character in a string, as in Java
# - parameters:
#   - ($sp) - the index, n
#   - 4($sp) - GC tag
#   - 8($sp) - old this pointer
#   - $s2    - this pointer
# - returns:
#   - $t0 - the character found.
########################################################
2012:mth_charAt_String:
    # get string
2012#    move $t0,$s2

    # check that index is in bounds
2016#    lw $t1,-4($t0) # negative of # data words in string
2020#    subu $t3,$zero,$t1 # # chars in string
2024#    lw $t2,($sp) # index
2028#    bgeu $t2,$t3,strIndexOutOfBounds
2029##...sltu $at,$t2,$t3
2033##...beq $at,$zero,3520

    # access element
2036#    lw $t1,-8($t0) # # data words in object
2040#    sll $t1,$t1,2 # - byte-offset from end of chars
2044#    subu $t1,$t2,$t1 # - address of first char in string, offset by 8
2048#    addu $t0,$t0,$t1 # - address of our char, offset by 8
2052#    lb $t0,-8($t0) # our char

    # return
2056#    jr $ra

########################################################
# intToString(n) - library method (class Lib)
# converts int to string: Java: ""+n
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
#   - $s2 - this-pointer
# - returns:
#   - $t0 - the string, which is the string representation of
#     the integer
########################################################
2060:mth_intToString_Lib:

    # save return address on stack; allocate space for dummy GC tag
2060#    subu $sp,$sp,8
2064#    sw $ra,4($sp)

    # save current sp
2068#    move $t0,$sp

    # move constant 10 into $t3 
    # (Good, I didn't know what li did, I'm glad this comment was here)
    # * slams head through wall *
2072#    li $t3,10

    # get argument, negate if negative
2076#    lw $t1,8($sp)
2080#    bge $t1,$zero,itsNonNegLoop
2081##...slt $at,$t1,$zero
2085##...beq $at,$zero,2092
2088#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
2092:  itsNonNegLoop:
2092#    divu $t1,$t3
2096#    mflo $t1 # quotient
2100#    mfhi $t4 # remainder
2104#    addu $t4,$t4,'0' # turn remainder into digit
2108#    subu $sp,$sp,4
2112#    sw $t4,($sp) # push digit onto stack
2116#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
2120#    lw $t4,8($t0)
2124#    bge $t4,$zero,itsSkipNeg
2125##...slt $at,$t4,$zero
2129##...beq $at,$zero,2144
2132#    li $t4,'-'
2136#    subu $sp,$sp,4
2140#    sw $t4,($sp)
2144:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
2144#    subu $s6,$t0,$sp
2148#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
2152#    sw $t3,($t0)
2156#    srl $s6,$s6,2
2160#    subu $sp,$sp,4
2164#    sw $s6,($sp)
    
    # allocate memory
2168#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
2172#    srl $s6,$s6,2
2176#    move $s7,$zero # no "object" words in object
2180#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
2184#    lw $t0,4($sp)
2188#    addu $sp,$sp,8

    # store "String" tag into class field
2192#    subu $s7,$s7,8 # address of header-1 word
2196#    la $t1,CLASS_String
2200#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
2204#    lw $t4,($s7) # # data words in source string
2208#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
2209##...slt $at,$t4,$zero
2213##...beq $at,$zero,2232
2216#    and $t4,0xff # mask off object's hash value ...
2217##...lui $at,0
2221##...ori $at,$at,0xff
2225##...and $t4,$t4,$at
2228#    sw $t4,($s7) # ... and store back into -8 header-word
2232:skipMask_intToString:
    
    # store negative of char-count into header-2 word
2232#    subu $t0,$zero,$t0
2236#    sw $t0,4($s7)

2240#    lw $t1,($s7) # number of data words in string
2244#    sll $t1,$t1,2 # number data bytes in string
2248#    subu $t1,$s7,$t1 # first location to store chars in string
2252#    subu $t0,$t1,$t0 # limit address for chars in string

    ####################################################
    # at this point:
    # - $sp contains first source character address
    # - $t1 contains first target character address
    # - $t0 contains target-limit address
    ####################################################

    # loop through and copy all elements as we pop them off the stack.
    # (In this case, we know that there is it least one.)
2256:  itsLoop:
2256#    lw $t2,($sp)
2260#    addu $sp,$sp,4
2264#    sb $t2,($t1)
2268#    addu $t1,$t1,1
2272#    bne $t1,$t0,itsLoop

    ####################################################
    # At this point
    # - ($t0+15)&0xfffffffe is our return value
    # - ($sp) contains garbage (old GC tag)
    # - 4($sp) contains return address
    ####################################################

    # adjust stack, restore return address; return
2276#    lw $ra,4($sp)
2280#    addu $sp,$sp,8
2284#    addu $t0,$t0,15
2288#    and $t0,$t0,0xfffffffc
2289##...lui $at,65535
2293##...ori $at,$at,0xfffc
2297##...and $t0,$t0,$at
2300#    jr $ra

########################################################
# intToChar(n) - library method (class Lib)
# converts int to a one-character string: Java: ""+(char)(n&0xff)
# - parameters:
#   - ($sp) - the value to convert, n
#   - 4($sp) - GC tag
#   - 8($sp) - old-this-pointer
# - returns:
#   - $t0 - the string, which is the converted character
# - note: only the low 8 bits of the value n are used
########################################################
2304:mth_intToChar_Lib:
    # save return address
2304#    subu $sp,$sp,4
2308#    sw $ra,($sp)

    # allocate object
2312#    li $s6,2
2316#    move $s7,$zero
2320#    jal newObject

    # get n from string.
2324#    lw $t1,8($sp)

    # store "String" tag into class field
2328#    la $t0,CLASS_String
2332#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
2336#    lw $t4,-8($s7) # # data words in source string
2340#    bge $t4,$zero,skipMask_intToChar # don't strip hash code if not there
2341##...slt $at,$t4,$zero
2345##...beq $at,$zero,2364
2348#    and $t4,0xff # mask off object's hash value ...
2349##...lui $at,0
2353##...ori $at,$at,0xff
2357##...and $t4,$t4,$at
2360#    sw $t4,-8($s7) # ... and store back into -8 header-word
2364:  skipMask_intToChar:

    # store data in string
2364#    sb $t1,-16($s7)
    
    # store negative of size in header-word 2
2368#    li $t0,-1
2372#    sw $t0,-4($s7)

    # we're returning $s7
2376#    move $t0, $s7

    # restore $ra, and pop return address and return string off stack
2380#    lw $ra,4($sp)
2384#    addu $sp,$sp,8

    # return
2388#    jr $ra

########################################################
# str1.compareTo(str2) - library method (class String)
# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
2392:mth_compareTo_String:
    # get string pointers and check parameter for null
2392#    lw $t0,($sp) # second string
2396#    beq $t0,$zero,nullPtrException
2400#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
2404#    lw $t2,-4($t0) # negative length of second string
2408#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
2412#    slt $t4,$t3,$t2
2416#    slt $t5,$t2,$t3
2420#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
2424#    lw $t2,-8($t0) # # data words in second string
2428#    lw $t3,-8($t1) # # data words in first string
2432#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
2436#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
2440#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
2444#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
2448#    beq $zero,$t5,skipStrCmpLenzz
2452#    move $t2,$t3
2456:  skipStrCmpLenzz:
2456#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
2460:  cmpLoopzz:
2460#    lw $t3,-8($t1) # word from str2
2464#    lw $t4,-8($t0) # word from str1
2468#    bne $t3,$t4,cmpNotEqualzz
2472#    addu $t1,$t1,4
2476#    addu $t0,$t0,4
2480#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
2484#    j cmpHitLimitzz

2488:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
2488#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
2492#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
2496#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
2500:  cmpHitLimitzz:
2500#    move $t0, $t5 # store return value
2504#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
2508:readLogicalChar:

    # check if we already have a character
2508#    lw $v0,lastCharRead
2512#    li $t0,-2
2516#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
2520#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2524#    jr $ra # return
    
2528:  doReadCh:
    # we need to actually read a character: read and return
2528#    li $v0,12 # use system call to read a character
2532#    syscall
2536#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
2540:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
2540#    blt $s7,$zero arraySizeOutOfBounds
2541##...slt $at,$s7,$zero
2545##...bne $at,$zero,3536

    # mark the fact that we have not yet GC'd for this allocation
2548#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

2552:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation


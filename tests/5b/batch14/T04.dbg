2472#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
2476#    li $t2,255
2480#    bgeu $s6,$t2 firstHeaderLarge
2481##...sltu $at,$s6,$t2
2485##...beq $at,$zero,2532
2488#    lw $t1,prevHashConstant
2492#    addu $t1,0x12b68fd2
2493##...lui $at,4791
2497##...addiu $at,$at,-28718
2501##...addu $t1,$at,$t1
2504#    sw $t1,prevHashConstant # update hash constant
2508#    or $t1,0x80000000 # set top bit
2509##...lui $at,32768
2513##...or $t1,$at,$t1
2516#    and $t1,0xffffff00 # clear low bit
2517##...lui $at,65535
2521##...ori $at,$at,0xff00
2525##...and $t1,$t1,$at
2528#    or $s6,$t1
2532:firstHeaderLarge:
2532#    sw $s6,-8($t0) # store header-1 value
2536#    lw $zero,-8($t0)

    # store second header-value
2540#    sw $s7,-4($t0)   # second header-word
2544#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
2548#    move $s7,$t0
2552#    subu $sp,$sp,4
2556#    sw $t0,($sp)

2560#    jr $ra
    
2564:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
2564#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
2568#    lw $t5,gcCount
2572#    addu $t5,1
2576#    sw $t5,gcCount

    # save $s2 (our only rooted register) on the stack
    # so that the garbage collector processes it
2580#    subu $sp,$sp,4
2584#    sw $s2,($sp)

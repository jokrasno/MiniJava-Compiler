804#    seq $t0,$t0,$zero
805##...subu $at,$t0,$zero
809##...sltiu $t0,$at,1

    # pop return address and return $t0
812#    lw $ra,($sp)
816#    addu $sp,4

820#    jr $ra # return
    
824:goEsFalse:
    # put 0 in $t0 and return
824#    li $t0, 0
828#    jr $ra # return

3140#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3144#    sw $t8,($t0)

3148:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3148#    addu $t0,$t0,4
3152#    bltu $t0,$s1,gcNextPointerInObject
3153##...sltu $at,$t0,$s1
3157##...bne $at,$zero,2996

3160:  gcTestIterDone2:
3160#    bltu $t0,$s3,gcHeapCopyLoop
3161##...sltu $at,$t0,$s3
3165##...bne $at,$zero,2880

    ###### end outer loop to copy all non-stack-direct objects ######

3168:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3168#    lw $s2,($sp)
3172#    addu $sp,$sp,4

    # mark us as having already GC'd
3176#    move $t5,$s5

    # go try and allocate again
3180#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3184:vm_init:

    # mark bottom of stack
3184#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3188#    move $s2,$zero

    #set up the "five" register
3192#    li $s5,5

3196#    la $s3,seg0_start
3200#    la $s4,seg0_end
3201##...lui $s4,16
3205##...addiu $s4,$s4,4100
    
    # return
3208#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3212:divide:
    # get parameters; abort if divisor zero
3212#    lw $t0,($sp)
3216#    lw $t1,8($sp)
3220#    beq $t0,$zero,divByZeroError
    
    # perform division
3224#    div $t1,$t0
3228#    mflo $t0

    # store result, adjust stack and return
3232#    addu $sp,$sp,8 # adjust stack
3236#    sw $t0,($sp) # store result
3240#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3244:remainder:
    # get parameters; abort if divisor zero
3244#    lw $t0,($sp)
3248#    lw $t1,8($sp)
3252#    beq $t0,$zero,divByZeroError
    
    # perform division
3256#    div $t1,$t0
3260#    mfhi $t0

    # store result, adjust stack and return
3264#    addu $sp,$sp,8 # adjust stack
3268#    sw $t0,($sp) # store result
3272#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3276:checkCast:
    # get object, allow immediately if null
3276#    lw $t2,($sp)
3280#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3284#    lw $t2,-12($t2) # vtable address
3288#    bge $t2,$t1,castException
3289##...slt $at,$t2,$t1
3293##...beq $at,$zero,3428
3296#    blt $t2,$t0,castException
3297##...slt $at,$t2,$t0
3301##...bne $at,$zero,3428
    
    # return, leaving object unchanged on stack
3304:  checkCastReturn:    
3304#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3308:instanceOf:
    # get object, go return false if null
3308#    lw $t2,($sp)
3312#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3316#    lw $t2,-12($t2) # vtable address
3320#    sge $t0,$t2,$t0 # are we >= the lower limit?
3321##...slt $t0,$t2,$t0
3325##...xori $t0,$t0,0x1
3328#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3332#    and $t2,$t0,$t1
3336#    sw $t2,($sp)
3340:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3340#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3344:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3344#    li $v0,4 # syscall-code for print-string
3348#    syscall
3352:exit:
    # print termination message
3352#    li $v0,4 # syscall-code for print-string
3356#    la $a0,exitString
3360#    syscall

    # terminate execution
3364#    li $v0,10 #syscall-code for "exit"
3368#    syscall

3372:outOfHeapMemory:
3372#    la $a0,heapMemoryMsg
3376#    j exitError
3380:divByZeroError:
3380#    la $a0,divByZeroMsg
3384#    j exitError
3388:strIndexOutOfBounds:
3388#    la $a0,strIndexOutOfBoundsMsg
3392#    j exitError
3396:arrayIndexOutOfBounds:
3396#    la $a0,arrayIndexOutOfBoundsMsg
3400#    j exitError
3404:arraySizeOutOfBounds:
3404#    la $a0,arraySizeOutOfBoundsMsg
3408#    j exitError
3412:nullPtrException:
3412#    la $a0,nullPtrExceptionMsg
3416#    j exitError
3420:badIntegerFormat:
3420#    la $a0,badIntegerFormatMsg
3424#    j exitError
3428:castException:
3428#    la $a0,castExceptionMsg
3432#    j exitError
############## data section ################
    .data
3736:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3752:cur_seg:
    .word 0

3756:lastCharRead:
    .word -2 # -2 => no buffered character
3760:prevHashConstant:
    .word 0x2785173c
3764:gcCount:
    .word 0

3768:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3795:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3818:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3853:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3887:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3920:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3951:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3999:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4020:gcMsg: 
      .asciiz "\nGC!\n"
4026:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4058:nullStr:
    .asciiz "null"
4063:trueString:
    .asciiz "true"
4068:falseString:
    .asciiz "false"
4074:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4093:newlineString:
    .asciiz "\n"
    
    .align 2
4096:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4100:seg0_start:
    .space 0x100000
1052676:seg0_end:
1052676:seg1_start:
    .space 0x100000
2101252:seg1_end:

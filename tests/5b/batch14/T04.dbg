###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
756:mth_equals_String:
    
    # quick test for obvious false
756#    lw $t0,($sp) # second parameter
760#    beq $t0,$zero,goEsFalse # go return false if null
764#    lw $t1,-12($t0) # vtable pointer
768#    la $t2,CLASS_String # string vtable pointer
772#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
776#    subu $sp,12
780#    sw $ra,8($sp)
784#    sw $s2,4($sp)
788#    sw $t0,($sp)
792#    jal mth_compareTo_String
796#    lw $s2, 4($sp) #restore this pointer and pop parameters
800#    addu $sp, 8 # pop parameters


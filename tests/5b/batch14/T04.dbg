1044#    sb $t2,-9($t0)
1048#    addu $sp,$sp,4
1052#    subu $t0,$t0,1
1056#    bne $sp,$t1,charCopyLoop
1060:  rlReturn:

1060#    lw $ra, 4($sp)
1064#    addu $sp, 8   # pop $ra and pointless word off stack
1068#    move $t0, $s7 # return string we allocated in $s7
1072#    jr $ra

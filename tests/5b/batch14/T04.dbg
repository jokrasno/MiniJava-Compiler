2597##...lui $t6,16
2601##...addiu $t6,$t6,4100
2604#    la $s3,seg0_start
2608#    la $s4,seg0_end
2609##...lui $s4,16
2613##...addiu $s4,$s4,4100
2616#    sw $zero,cur_seg
2620#    bne $t0,$zero,skipGc1
2624#    la $t6,seg0_start
2628#    la $s3,seg1_start
2629##...lui $s3,16
2633##...addiu $s3,$s3,4100
2636#    la $s4,seg1_end
2637##...lui $s4,32
2641##...addiu $s4,$s4,4100
2644#    sw $s5,cur_seg
2648:  skipGc1:
2648#    li $t5,0x80000000
2652#    lw $t0,stack_bottom
2656#    subu $t0,4

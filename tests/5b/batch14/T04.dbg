1104#    subu $t0,$v0,10
1108#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1112#    subu $t0,$v0,9
1116#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1120#    subu $t0,$v0,13
1124#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1128#    subu $t0,$v0,12

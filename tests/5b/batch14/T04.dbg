84:mth_main_Main:
84#  subu $sp,$sp,4
88#  sw $ra,($sp)
92#  move $t0, $zero
96#  subu $sp,$sp,4
100#  sw $t0,($sp)
104#  lw $t0,0($sp)
108#  subu $sp,$sp,4
112#  sw $t0,($sp)
116#  la $t0, CLASS_C3

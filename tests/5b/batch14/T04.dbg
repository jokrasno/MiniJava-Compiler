###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
840:mth_readLine_Lib:
    
840#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
844#    sw $ra, 4($sp) # save $ra
848#    move $t1,$sp # save "original" sp

852:  doRead:

    # read the character
852#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
856#    subu $t2,$v0,13
860#    bne $t2,$zero,notReturnRL
864#    jal readLogicalChar
868#    subu $t2,$v0,10 # check for newline
872#    beq $t2,$zero,foundNewLine
876#    sw $v0,lastCharRead # push back character into queue
880#    j foundNewLine # go process the line

884:  notReturnRL:

    # at this point, $v0 has our character

884#    subu $t0,$v0,10
888#    beq $t0,$zero,foundNewLine
892#    blt $v0,$zero,foundEof
893##...slt $at,$v0,$zero
897##...bne $at,$zero,912

    # we have a character, so push it onto stack
900#    subu $sp,$sp,4
904#    sw $v0,($sp)

    # loop back up to get next character
908#    j doRead

912:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
912#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
916#    li $s7, 0 # return-value: null
920#    j rlReturn # return

924:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
924#    subu $t0,$t1,$sp # number of chars we read (times 4)
928#    srl $s6,$t0,2 # number of words on stack with chars
932#    subu $sp,$sp,4 # push char-count ...
936#    sw $s6,($sp) # ... onto stack
940#    addu $t2,$t0,5 # GC tag, incl. for count-word
944#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
948#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
952#    srl $s6,$s6,2  # data words in object
956#    move $s7,$zero # object words in object
960#    jal newObject  # allocate space
    
    # store header words
964#    la $t0,CLASS_String
968#    sw $t0,-12($s7)# store class tag (String) into object
972#    lw $t2,4($sp) # char-count
976#    sll $t1,$t2,2 # 4 times number of chars
980#    subu $t2,$zero,$t2 # negative of char-count
984#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
988#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
992#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
993##...slt $at,$t0,$zero
997##...beq $at,$zero,1016
1000#    and $t0,0xff # mask off object's hash value ...
1001##...lui $at,0
1005##...ori $at,$at,0xff
1009##...and $t0,$t0,$at
1012#    sw $t0,-8($s7) # ... and store back into -8 header-word
1016:  skipMask_readLine:

1016#    sll $t0,$t0,2 # data bytes in object
1020#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1024#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1028#    addu $sp,$sp,8 # pop redundant object-pointer and count
1032#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character


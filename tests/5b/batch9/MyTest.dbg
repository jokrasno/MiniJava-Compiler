###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3180:mth_hashCode_String:
3180#    move $t0,$s2 # put this pointer in t0

3184#    li $t2,0 # current hash value
3188#    lw $t1,-4($t0) # negative of number of characters in string
3192#    beq $t1,$zero,done_hashCode_String # if zero length => done
3196#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
3200#    and $t0,0xfffffffc # adjust for padding
3201##...lui $at,65535
3205##...ori $at,$at,0xfffc
3209##...and $t0,$t0,$at
3212#    subu $t1,$t0,$t1 # address at end of string +12
3216:loop_hashCode_String:    
3216#    sll $t4,$t2,5 # multiply by 32
3220#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
3224#    lbu $t3,-12($t0) # current character
3228#    addu $t2,$t3 # add in current character
3232#    addu $t0,1 # go to next character's address
3236#    bne $t0,$t1,loop_hashCode_String # loop back if more
3240:done_hashCode_String:    

    # push int on stack
3240#    move $t0, $t2 # put $t2 in return slot
3244#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
3248:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
3248#    subu $sp,4
3252#    sw $ra,($sp)
    
    # get hash value
3256#    lw $t2,-12($s2) # vtable address
3260#    lw $t0,($t2) # method address
3264#    jalr $t0
3268#    subu $sp,8 # push result (int in $t0) on stack
3272#    sw $s5,4($sp)
3276#    sw $t0,($sp)

    # compute print-size of hash value
3280#    li $t0, 1
3284#    lw $t1, ($sp)
3288#    srl $t1,$t1,4
3292#    beq $t1,$zero,toString_skip_loop
3296:toString_loop_top:
3296#    addu $t0,1
3300#    srl $t1,$t1,4
3304#    bne $t1,$zero,toString_loop_top
3308:toString_skip_loop:
3308#    subu $sp,8
3312#    sw $s5,4($sp)
3316#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
3320#    lw $t2,-12($s2) # vtable address
3324#    move $t0,$t2
3328:toString_checkTagBit:
3328#    subu $t0,1
3332#    lb $t1,($t0)
3336#    and $t1,0x80
3337##...lui $at,0
3341##...ori $at,$at,0x80
3345##...and $t1,$t1,$at
3348#    beq $t1,$zero,toString_checkTagBit
3352#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
3356#    subu $sp,8
3360#    sw $t1,($sp)
3364#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
3368#    move $s7,$zero # -4 offset header word
3372#    lw $t4,8($sp) # bytes for hash value
3376#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
3380#    addu $t4,8
3384#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
3388#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

3392#    li $t0,CLASS_String # store string vtable address into ...
3396#    sw $t0,-12($s7) # ... -12 offset in object header
3400#    lw $t2,-12($s2) # our object's vtable address
3404#    lw $t5,4($sp) # number characters in prefix
3408#    lw $t1,12($sp) # number of characters in hashcode
3412#    addu $t3,$t1,$t5 # number of characters in string ...
3416#    addu $t3,1 # ... including the '@' character
3420#    subu $t0,$zero,$t3 # store negated length into ...
3424#    sw $t0,-4($s7) # ... -4 offset header word
3428#    lw $t0,-8($s7) # get -8 offset header-word
3432#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
3433##...slt $at,$t0,$zero
3437##...beq $at,$zero,3456
3440#    and $t0,0xff # mask off object's hash value ...
3441##...lui $at,0
3445##...ori $at,$at,0xff
3449##...and $t0,$t0,$at
3452#    sw $t0,-8($s7) # ... and store back into -8 header-word
3456:skipMask_toString:
3456#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
3460#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
3464#    subu $t4,$t2,$t5
3468:toString_copyLoop:    
3468#    lb $t3,($t4)
3472#    and $t3,0x7f # mask off sign bit (in case first word)
3473##...lui $at,0
3477##...ori $at,$at,0x7f
3481##...and $t3,$t3,$at
3484#    sb $t3,-8($t0)
3488#    addu $t4,1
3492#    addu $t0,1
3496#    blt $t4,$t2,toString_copyLoop
3497##...slt $at,$t4,$t2
3501##...bne $at,$zero,3468

    # copy the '@' sign
3504#    li $t3,'@'
3508#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
3512#    addu $t2,$t0,$t1 # address of last byte in string to store +8
3516#    lw $t3,20($sp) # hash code to print
3520:toString_hashCopyLoop:
3520#    and $t4,$t3,0xf
3524#    srl $t3,4
3528#    lb $t4,hexChars($t4)
3532#    sb $t4,-8($t2)
3536#    subu $t2,$t2,1
3540#    bgt $t2,$t0,toString_hashCopyLoop
3541##...slt $at,$t0,$t2
3545##...bne $at,$zero,3520

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
3548#    addu $sp,28
3552#    lw $ra,($sp)
3556#    addu $sp,4
3560#    move $t0, $s7 # return string we created
3564#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
3568:mth_equals_String:
    
    # quick test for obvious false
3568#    lw $t0,($sp) # second parameter
3572#    beq $t0,$zero,goEsFalse # go return false if null
3576#    lw $t1,-12($t0) # vtable pointer
3580#    la $t2,CLASS_String # string vtable pointer
3584#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
3588#    subu $sp,12
3592#    sw $ra,8($sp)
3596#    sw $s2,4($sp)
3600#    sw $t0,($sp)
3604#    jal mth_compareTo_String
3608#    lw $s2, 4($sp) #restore this pointer and pop parameters
3612#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
3616#    seq $t0,$t0,$zero
3617##...subu $at,$t0,$zero
3621##...sltiu $t0,$at,1

    # pop return address and return $t0
3624#    lw $ra,($sp)
3628#    addu $sp,4

3632#    jr $ra # return
    
3636:goEsFalse:
    # put 0 in $t0 and return
3636#    li $t0, 0
3640#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
3644:mth_toString_String:
    #we are a string, so return this.
3644#    move $t0, $s2
3648#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
3652:mth_readLine_Lib:
    
3652#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
3656#    sw $ra, 4($sp) # save $ra
3660#    move $t1,$sp # save "original" sp

3664:  doRead:

    # read the character
3664#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
3668#    subu $t2,$v0,13
3672#    bne $t2,$zero,notReturnRL
3676#    jal readLogicalChar
3680#    subu $t2,$v0,10 # check for newline
3684#    beq $t2,$zero,foundNewLine
3688#    sw $v0,lastCharRead # push back character into queue
3692#    j foundNewLine # go process the line

3696:  notReturnRL:

    # at this point, $v0 has our character

3696#    subu $t0,$v0,10
3700#    beq $t0,$zero,foundNewLine
3704#    blt $v0,$zero,foundEof
3705##...slt $at,$v0,$zero
3709##...bne $at,$zero,3724

    # we have a character, so push it onto stack
3712#    subu $sp,$sp,4
3716#    sw $v0,($sp)

    # loop back up to get next character
3720#    j doRead

3724:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
3724#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
3728#    li $s7, 0 # return-value: null
3732#    j rlReturn # return

3736:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
3736#    subu $t0,$t1,$sp # number of chars we read (times 4)
3740#    srl $s6,$t0,2 # number of words on stack with chars
3744#    subu $sp,$sp,4 # push char-count ...
3748#    sw $s6,($sp) # ... onto stack
3752#    addu $t2,$t0,5 # GC tag, incl. for count-word
3756#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
3760#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
3764#    srl $s6,$s6,2  # data words in object
3768#    move $s7,$zero # object words in object
3772#    jal newObject  # allocate space
    
    # store header words
3776#    la $t0,CLASS_String
3780#    sw $t0,-12($s7)# store class tag (String) into object
3784#    lw $t2,4($sp) # char-count
3788#    sll $t1,$t2,2 # 4 times number of chars
3792#    subu $t2,$zero,$t2 # negative of char-count
3796#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3800#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3804#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3805##...slt $at,$t0,$zero
3809##...beq $at,$zero,3828
3812#    and $t0,0xff # mask off object's hash value ...
3813##...lui $at,0
3817##...ori $at,$at,0xff
3821##...and $t0,$t0,$at
3824#    sw $t0,-8($s7) # ... and store back into -8 header-word
3828:  skipMask_readLine:

3828#    sll $t0,$t0,2 # data bytes in object
3832#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
3836#    subu $t0,$t0,$t2 # place to store last character (plus 9)
3840#    addu $sp,$sp,8 # pop redundant object-pointer and count
3844#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

3848#    beq $sp,$t1,rlReturn
3852:  charCopyLoop:
3852#    lw $t2,($sp)
3856#    sb $t2,-9($t0)
3860#    addu $sp,$sp,4
3864#    subu $t0,$t0,1
3868#    bne $sp,$t1,charCopyLoop
3872:  rlReturn:

3872#    lw $ra, 4($sp)
3876#    addu $sp, 8   # pop $ra and pointless word off stack
3880#    move $t0, $s7 # return string we allocated in $s7
3884#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3888:mth_readInt_Lib:

    # save $ra by pushing onto stack
3888#    subu $sp,$sp,4
3892#    sw $ra,($sp)

3896:  riSkipWhiteLoop:
    # read a character
3896#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
3900#    subu $t0,$v0,32
3904#    bgt $t0,$zero,nonWhite
3905##...slt $at,$zero,$t0
3909##...bne $at,$zero,3952
3912#    beq $t0,$zero,riSkipWhiteLoop # start over if space
3916#    subu $t0,$v0,10
3920#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
3924#    subu $t0,$v0,9
3928#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
3932#    subu $t0,$v0,13
3936#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
3940#    subu $t0,$v0,12
3944#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
3948#    j badIntegerFormat # illegal integer char: abort program

3952:  nonWhite:
3952#    subu $t0,$v0,'-'
3956#    li $t4,1 # final multiplier
3960#    bne $t0,$zero,helpReadInt # go read
3964#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
3968#    jal readLogicalChar

3972:  helpReadInt:
3972#    li $t2,10
3976#    subu $t1,$v0,'0' # convert digit to 0-9 value
3980#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
3981##...sltu $at,$t1,$t2
3985##...beq $at,$zero,6232
3988#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

3992:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

3992#    jal readLogicalChar # read next character
3996#    subu $t1,$v0,'0' # convert digit to 0-9 value
4000#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
4001##...sltu $at,$t1,$t2
4005##...beq $at,$zero,4024

4008#    mul $t3,$t3,$t2 # multiply old value by 10
4009##...mult $t3,$t2
4013##...mflo $t3
4016#    addu $t3,$t3,$t1 # add in value of new digit
4020#    j digitLoop

4024:  doneDigitLoop:

    # "push back" unused character into queue
4024#    sw $v0,lastCharRead

    # restore return address
4028#    lw $ra,($sp)
4032#    addu $sp, 4

    # multiply by sign and put return value in $t0
4036#    mult $t3,$t4 # multiply to account for poss. minus sign
4040#    mflo $t3
4044#    move $t0, $t3
    
    # return
4048#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
4052:mth_readChar_Lib:

    # save $ra by pushing onto stack
4052#    subu $sp,$sp,4
4056#    sw $ra,($sp)

      # read the character
4060#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
4064#    lw $ra,($sp)

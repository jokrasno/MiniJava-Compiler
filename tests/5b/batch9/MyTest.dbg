    # * slams head through wall *
4752#    li $t3,10

    # get argument, negate if negative
4756#    lw $t1,8($sp)
4760#    bge $t1,$zero,itsNonNegLoop
4761##...slt $at,$t1,$zero
4765##...beq $at,$zero,4772
4768#    subu $t1,$zero,$t1

    # loop through, computing unsigned remainder by 10, and
    # storing digits on stack until we reach 0
4772:  itsNonNegLoop:
4772#    divu $t1,$t3
4776#    mflo $t1 # quotient
4780#    mfhi $t4 # remainder
4784#    addu $t4,$t4,'0' # turn remainder into digit
4788#    subu $sp,$sp,4
4792#    sw $t4,($sp) # push digit onto stack
4796#    bne $t1,$zero,itsNonNegLoop

    # push '-' if negative
4800#    lw $t4,8($t0)
4804#    bge $t4,$zero,itsSkipNeg
4805##...slt $at,$t4,$zero
4809##...beq $at,$zero,4824
4812#    li $t4,'-'

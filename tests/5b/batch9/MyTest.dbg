5668#    la $t0,seg0_start
5672#    beq $t1,$zero,gcSkip4
5676#    la $t0,seg1_start
5677##...lui $t0,16
5681##...addiu $t0,$t0,6852


5684:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
5684#    bgeu $t0,$s3,gcFinishUp
5685##...sltu $at,$t0,$s3
5689##...beq $at,$zero,5980

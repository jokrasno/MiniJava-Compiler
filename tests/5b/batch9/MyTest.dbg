4820#    sw $t4,($sp)
4824:  itsSkipNeg:

    ################################################
    # At this point, all of our digits have been pushed
    # onto the stack.  $sp points to the first one;
    # $t0 contains the limit-pointer (into which we need to
    # write a GC tag).
    ################################################

    # compute number of characters on stack (one word per character);
    # write GC tag onto stack; push char-count onto stack
4824#    subu $s6,$t0,$sp
4828#    addu $t3,$s6,5 # GC tag (including for count-word, about to be pushed)
4832#    sw $t3,($t0)
4836#    srl $s6,$s6,2
4840#    subu $sp,$sp,4
4844#    sw $s6,($sp)
    
    # allocate memory
4848#    addu $s6,$s6,7 # 3 to round up, plus 4 for vtable word
4852#    srl $s6,$s6,2
4856#    move $s7,$zero # no "object" words in object
4860#    jal newObject

    # restore char-count; pop it and return value from 'newObject'
4864#    lw $t0,4($sp)
4868#    addu $sp,$sp,8

    # store "String" tag into class field
4872#    subu $s7,$s7,8 # address of header-1 word
4876#    la $t1,CLASS_String
4880#    sw $t1,-4($s7)
        
    # mask off hash bits, if needed
4884#    lw $t4,($s7) # # data words in source string
4888#    bge $t4,$zero,skipMask_intToString # don't strip hash code if not there
4889##...slt $at,$t4,$zero
4893##...beq $at,$zero,4912
4896#    and $t4,0xff # mask off object's hash value ...
4897##...lui $at,0
4901##...ori $at,$at,0xff

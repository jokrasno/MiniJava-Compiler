    ###### begin outer loop to copy all non-stack-direct objects ######

5692:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
5692#    lw $t1,($t0) # (what will be) first header word for current object
5696#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
5700#    bge $t2,$zero,gcSkip4a # are there hash bits?
5701##...slt $at,$t2,$zero
5705##...beq $at,$zero,5720
5708#    and $t2,0xff # mask off hash bits
5709##...lui $at,0
5713##...ori $at,$at,0xff
5717##...and $t2,$t2,$at
5720:gcSkip4a:    
5720#    sll $t2,$t2,2 # # data bytes
5724#    addu $t2,$t2,8 # to skip header words
5728#    addu $t2,$t0,$t2 # pointer to new object
5732#    lw $t3,-8($t2) # word to swap
5736#    sw $t1,-8($t2) # store header word
5740#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
5744#    lw $t1,-12($t2) # vtable pointer
5748#    li $t0,dataArrayVTableStart # address of vtable for first data array
5752#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
5753##...slt $at,$t1,$t0
5757##...bne $at,$zero,5776

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
5760:  skipToNextObj:
5760#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
5764#    sll $t1,$t1,2 # convert to byte-count
5768#    addu $t0,$t2,$t1 # skip over object
5772#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
5776:  gcNotDataArray:
5776#    lw $t3,-4($t2) # # object words (negative treated as zero)
5780#    bge $t3,$zero,gcH2Neg2
5781##...slt $at,$t3,$zero
5785##...beq $at,$zero,5792
5788#    move $t3,$zero
5792:  gcH2Neg2:
5792#    sll $t3,$t3,2 # # object bytes
5796#    move $t0,$t2 # address of first pointer in object
5800#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
5804#    beq $t0,$s1,gcTestIterDone2
    
5808:  gcNextPointerInObject:
    # get pointer from object
5808#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
5812#    bleu $t1,$t6,gcGoNextPointerSlot
5813##...sltu $at,$t6,$t1
5817##...beq $at,$zero,5960
5820#    bgtu $t1,$t7,gcGoNextPointerSlot
5821##...sltu $at,$t7,$t1
5825##...bne $at,$zero,5960

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
5828#    lw $t8,-8($t1) # possible forwarding tag
5832#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
5836#    lw $t8,-4($t1) # forwarding pointer: object's new address
5840#    sw $t8,($t0) # update pointer in object
5844#    j gcGoNextPointerSlot # do next iteration

5848:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
5848#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
5849##...slt $at,$t8,$zero
5853##...beq $at,$zero,5868
5856#    and $t8,0xff # mask off hash bits
5857##...lui $at,0
5861##...ori $at,$at,0xff
5865##...and $t8,$t8,$at

5868:  gcSkip5:
5868#    sll $t8,$t8,2 # bytes in negative-offset portion ...
5872#    addu $t8,$t8,8 # ... add in bytes for header-words
5876#    subu $t4,$t1,$t8 # address of first word of source object
5880#    lw $t3,-4($t1) # # words in positive-offset portion
5884#    bge $t3,$zero,gcNoNeg
5885##...slt $at,$t3,$zero
5889##...beq $at,$zero,5896
5892#    move $t3,$zero # negative treated as zero
5896:  gcNoNeg:
5896#    sll $t3,$t3,2 # bytes in negative-offset portion
5900#    addu $t3,$t3,$t1 # address one word past last word of source

5904#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
5908#    lw $s0,($t4)
5912#    lw $t9,-8($t1)
5916#    sw $t9,($t4)
5920#    sw $s0,-8($t1)

    # copy all source bytes to the target
5924:  gCinnerCopy2:
5924#    lw $s0,($t4)
5928#    sw $s0,($s3)
5932#    addu $t4,$t4,4
5936#    addu $s3,$s3,4
5940#    bltu $t4,$t3,gCinnerCopy2
5941##...sltu $at,$t4,$t3
5945##...bne $at,$zero,5924

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
5948#    sw $zero,-8($t1) # 0 in first header-slot
5952#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
5956#    sw $t8,($t0)

5960:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
5960#    addu $t0,$t0,4
5964#    bltu $t0,$s1,gcNextPointerInObject
5965##...sltu $at,$t0,$s1
5969##...bne $at,$zero,5808

5972:  gcTestIterDone2:
5972#    bltu $t0,$s3,gcHeapCopyLoop
5973##...sltu $at,$t0,$s3
5977##...bne $at,$zero,5692

    ###### end outer loop to copy all non-stack-direct objects ######

5980:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
5980#    lw $s2,($sp)
5984#    addu $sp,$sp,4

    # mark us as having already GC'd
5988#    move $t5,$s5

    # go try and allocate again
5992#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
5996:vm_init:

    # mark bottom of stack
5996#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
6000#    move $s2,$zero

    #set up the "five" register
6004#    li $s5,5

6008#    la $s3,seg0_start
6012#    la $s4,seg0_end
6013##...lui $s4,16
6017##...addiu $s4,$s4,6852
    
    # return
6020#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
6024:divide:
    # get parameters; abort if divisor zero
6024#    lw $t0,($sp)
6028#    lw $t1,8($sp)
6032#    beq $t0,$zero,divByZeroError
    
    # perform division
6036#    div $t1,$t0
6040#    mflo $t0

    # store result, adjust stack and return
6044#    addu $sp,$sp,8 # adjust stack
6048#    sw $t0,($sp) # store result
6052#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
6056:remainder:
    # get parameters; abort if divisor zero
6056#    lw $t0,($sp)
6060#    lw $t1,8($sp)
6064#    beq $t0,$zero,divByZeroError
    
    # perform division
6068#    div $t1,$t0
6072#    mfhi $t0

    # store result, adjust stack and return
6076#    addu $sp,$sp,8 # adjust stack
6080#    sw $t0,($sp) # store result
6084#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
6088:checkCast:
    # get object, allow immediately if null
6088#    lw $t2,($sp)
6092#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
6096#    lw $t2,-12($t2) # vtable address
6100#    bge $t2,$t1,castException
6101##...slt $at,$t2,$t1
6105##...beq $at,$zero,6240
6108#    blt $t2,$t0,castException
6109##...slt $at,$t2,$t0
6113##...bne $at,$zero,6240
    
    # return, leaving object unchanged on stack
6116:  checkCastReturn:    
6116#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
6120:instanceOf:
    # get object, go return false if null
6120#    lw $t2,($sp)
6124#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
6128#    lw $t2,-12($t2) # vtable address
6132#    sge $t0,$t2,$t0 # are we >= the lower limit?
6133##...slt $t0,$t2,$t0
6137##...xori $t0,$t0,0x1
6140#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
6144#    and $t2,$t0,$t1
6148#    sw $t2,($sp)
6152:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
6152#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

6156:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
6156#    li $v0,4 # syscall-code for print-string
6160#    syscall
6164:exit:
    # print termination message
6164#    li $v0,4 # syscall-code for print-string
6168#    la $a0,exitString
6172#    syscall

    # terminate execution
6176#    li $v0,10 #syscall-code for "exit"
6180#    syscall

6184:outOfHeapMemory:
6184#    la $a0,heapMemoryMsg
6188#    j exitError
6192:divByZeroError:
6192#    la $a0,divByZeroMsg
6196#    j exitError
6200:strIndexOutOfBounds:
6200#    la $a0,strIndexOutOfBoundsMsg
6204#    j exitError
6208:arrayIndexOutOfBounds:
6208#    la $a0,arrayIndexOutOfBoundsMsg
6212#    j exitError
6216:arraySizeOutOfBounds:
6216#    la $a0,arraySizeOutOfBoundsMsg
6220#    j exitError
6224:nullPtrException:
6224#    la $a0,nullPtrExceptionMsg
6228#    j exitError
6232:badIntegerFormat:
6232#    la $a0,badIntegerFormatMsg
6236#    j exitError
6240:castException:
6240#    la $a0,castExceptionMsg
6244#    j exitError
############## data section ################
    .data
6488:hexChars:
    .ascii "0123456789abcdef"
    .align 2
6504:cur_seg:
    .word 0

6508:lastCharRead:
    .word -2 # -2 => no buffered character
6512:prevHashConstant:
    .word 0x2785173c
6516:gcCount:
    .word 0

6520:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
6547:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
6570:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
6605:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
6639:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
6672:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
6703:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
6751:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
6772:gcMsg: 
      .asciiz "\nGC!\n"
6778:gcCountMsg: 
      .asciiz "Number of garbage collections: "

6810:nullStr:
    .asciiz "null"
6815:trueString:
    .asciiz "true"
6820:falseString:
    .asciiz "false"
6826:exitString:
    .ascii "Program terminated."
    #### "falls through" here
6845:newlineString:
    .asciiz "\n"
    
    .align 2
6848:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

6852:seg0_start:
    .space 0x100000
1055428:seg0_end:
1055428:seg1_start:
    .space 0x100000
2104004:seg1_end:

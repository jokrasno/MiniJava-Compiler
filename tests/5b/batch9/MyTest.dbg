5440#    la $s3,seg1_start
5441##...lui $s3,16
5445##...addiu $s3,$s3,6852
5448#    la $s4,seg1_end
5449##...lui $s4,32
5453##...addiu $s4,$s4,6852
5456#    sw $s5,cur_seg
5460:  skipGc1:
5460#    li $t5,0x80000000

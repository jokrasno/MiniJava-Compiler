    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
5792#    lw $t1,($t0) # (what will be) first header word for current object
5796#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
5800#    bge $t2,$zero,gcSkip4a # are there hash bits?
5801##...slt $at,$t2,$zero
5805##...beq $at,$zero,5820
5808#    and $t2,0xff # mask off hash bits
5809##...lui $at,0
5813##...ori $at,$at,0xff
5817##...and $t2,$t2,$at
5820:gcSkip4a:    
5820#    sll $t2,$t2,2 # # data bytes
5824#    addu $t2,$t2,8 # to skip header words
5828#    addu $t2,$t0,$t2 # pointer to new object
5832#    lw $t3,-8($t2) # word to swap
5836#    sw $t1,-8($t2) # store header word
5840#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
5844#    lw $t1,-12($t2) # vtable pointer
5848#    li $t0,dataArrayVTableStart # address of vtable for first data array
5852#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
5853##...slt $at,$t1,$t0
5857##...bne $at,$zero,5876

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
5860:  skipToNextObj:
5860#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
5864#    sll $t1,$t1,2 # convert to byte-count
5868#    addu $t0,$t2,$t1 # skip over object
5872#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
5876:  gcNotDataArray:
5876#    lw $t3,-4($t2) # # object words (negative treated as zero)
5880#    bge $t3,$zero,gcH2Neg2
5881##...slt $at,$t3,$zero
5885##...beq $at,$zero,5892
5888#    move $t3,$zero
5892:  gcH2Neg2:
5892#    sll $t3,$t3,2 # # object bytes
5896#    move $t0,$t2 # address of first pointer in object
5900#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
5904#    beq $t0,$s1,gcTestIterDone2
    
5908:  gcNextPointerInObject:
    # get pointer from object
5908#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
5912#    bleu $t1,$t6,gcGoNextPointerSlot
5913##...sltu $at,$t6,$t1
5917##...beq $at,$zero,6060
5920#    bgtu $t1,$t7,gcGoNextPointerSlot
5921##...sltu $at,$t7,$t1
5925##...bne $at,$zero,6060

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
5928#    lw $t8,-8($t1) # possible forwarding tag
5932#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
5936#    lw $t8,-4($t1) # forwarding pointer: object's new address
5940#    sw $t8,($t0) # update pointer in object
5944#    j gcGoNextPointerSlot # do next iteration

5948:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
5948#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
5949##...slt $at,$t8,$zero
5953##...beq $at,$zero,5968
5956#    and $t8,0xff # mask off hash bits
5957##...lui $at,0
5961##...ori $at,$at,0xff
5965##...and $t8,$t8,$at

5968:  gcSkip5:
5968#    sll $t8,$t8,2 # bytes in negative-offset portion ...
5972#    addu $t8,$t8,8 # ... add in bytes for header-words
5976#    subu $t4,$t1,$t8 # address of first word of source object
5980#    lw $t3,-4($t1) # # words in positive-offset portion
5984#    bge $t3,$zero,gcNoNeg
5985##...slt $at,$t3,$zero
5989##...beq $at,$zero,5996
5992#    move $t3,$zero # negative treated as zero
5996:  gcNoNeg:
5996#    sll $t3,$t3,2 # bytes in negative-offset portion
6000#    addu $t3,$t3,$t1 # address one word past last word of source

6004#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
6008#    lw $s0,($t4)
6012#    lw $t9,-8($t1)
6016#    sw $t9,($t4)
6020#    sw $s0,-8($t1)

    # copy all source bytes to the target
6024:  gCinnerCopy2:
6024#    lw $s0,($t4)
6028#    sw $s0,($s3)
6032#    addu $t4,$t4,4
6036#    addu $s3,$s3,4
6040#    bltu $t4,$t3,gCinnerCopy2
6041##...sltu $at,$t4,$t3
6045##...bne $at,$zero,6024

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
6048#    sw $zero,-8($t1) # 0 in first header-slot
6052#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
6056#    sw $t8,($t0)

6060:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
6060#    addu $t0,$t0,4
6064#    bltu $t0,$s1,gcNextPointerInObject
6065##...sltu $at,$t0,$s1
6069##...bne $at,$zero,5908

6072:  gcTestIterDone2:
6072#    bltu $t0,$s3,gcHeapCopyLoop
6073##...sltu $at,$t0,$s3
6077##...bne $at,$zero,5792

    ###### end outer loop to copy all non-stack-direct objects ######

6080:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
6080#    lw $s2,($sp)
6084#    addu $sp,$sp,4

    # mark us as having already GC'd
6088#    move $t5,$s5

    # go try and allocate again
6092#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
6096:vm_init:

    # mark bottom of stack
6096#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
6100#    move $s2,$zero

    #set up the "five" register
6104#    li $s5,5

6108#    la $s3,seg0_start
6112#    la $s4,seg0_end
6113##...lui $s4,16
6117##...addiu $s4,$s4,6932
    
    # return
6120#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
6124:divide:
    # get parameters; abort if divisor zero
6124#    lw $t0,($sp)
6128#    lw $t1,8($sp)
6132#    beq $t0,$zero,divByZeroError
    
    # perform division
6136#    div $t1,$t0
6140#    mflo $t0

    # store result, adjust stack and return
6144#    addu $sp,$sp,8 # adjust stack
6148#    sw $t0,($sp) # store result
6152#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
6156:remainder:
    # get parameters; abort if divisor zero
6156#    lw $t0,($sp)
6160#    lw $t1,8($sp)
6164#    beq $t0,$zero,divByZeroError
    
    # perform division
6168#    div $t1,$t0
6172#    mfhi $t0

    # store result, adjust stack and return
6176#    addu $sp,$sp,8 # adjust stack
6180#    sw $t0,($sp) # store result
6184#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
6188:checkCast:
    # get object, allow immediately if null
6188#    lw $t2,($sp)
6192#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
6196#    lw $t2,-12($t2) # vtable address
6200#    bge $t2,$t1,castException
6201##...slt $at,$t2,$t1
6205##...beq $at,$zero,6340
6208#    blt $t2,$t0,castException
6209##...slt $at,$t2,$t0
6213##...bne $at,$zero,6340
    
    # return, leaving object unchanged on stack
6216:  checkCastReturn:    
6216#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
6220:instanceOf:
    # get object, go return false if null
6220#    lw $t2,($sp)
6224#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
6228#    lw $t2,-12($t2) # vtable address
6232#    sge $t0,$t2,$t0 # are we >= the lower limit?
6233##...slt $t0,$t2,$t0
6237##...xori $t0,$t0,0x1
6240#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
6244#    and $t2,$t0,$t1
6248#    sw $t2,($sp)
6252:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
6252#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

6256:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
6256#    li $v0,4 # syscall-code for print-string
6260#    syscall
6264:exit:
    # print termination message
6264#    li $v0,4 # syscall-code for print-string
6268#    la $a0,exitString
6272#    syscall

    # terminate execution
6276#    li $v0,10 #syscall-code for "exit"
6280#    syscall

6284:outOfHeapMemory:
6284#    la $a0,heapMemoryMsg
6288#    j exitError
6292:divByZeroError:
6292#    la $a0,divByZeroMsg
6296#    j exitError
6300:strIndexOutOfBounds:
6300#    la $a0,strIndexOutOfBoundsMsg
6304#    j exitError
6308:arrayIndexOutOfBounds:
6308#    la $a0,arrayIndexOutOfBoundsMsg
6312#    j exitError
6316:arraySizeOutOfBounds:
6316#    la $a0,arraySizeOutOfBoundsMsg
6320#    j exitError
6324:nullPtrException:
6324#    la $a0,nullPtrExceptionMsg
6328#    j exitError
6332:badIntegerFormat:
6332#    la $a0,badIntegerFormatMsg
6336#    j exitError
6340:castException:
6340#    la $a0,castExceptionMsg
6344#    j exitError
############## data section ################
    .data
6568:hexChars:
    .ascii "0123456789abcdef"
    .align 2
6584:cur_seg:
    .word 0

6588:lastCharRead:
    .word -2 # -2 => no buffered character
6592:prevHashConstant:
    .word 0x2785173c
6596:gcCount:
    .word 0

6600:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
6627:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
6650:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
6685:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
6719:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
6752:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
6783:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
6831:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
6852:gcMsg: 
      .asciiz "\nGC!\n"
6858:gcCountMsg: 
      .asciiz "Number of garbage collections: "

6890:nullStr:
    .asciiz "null"
6895:trueString:
    .asciiz "true"
6900:falseString:
    .asciiz "false"
6906:exitString:
    .ascii "Program terminated."
    #### "falls through" here
6925:newlineString:
    .asciiz "\n"
    
    .align 2
6928:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

6932:seg0_start:
    .space 0x100000
1055508:seg0_end:
1055508:seg1_start:
    .space 0x100000
2104084:seg1_end:

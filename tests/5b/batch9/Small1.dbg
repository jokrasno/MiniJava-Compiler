##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3244:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
3244#    lw $t0,-8($s2) # get word with hash bits from this
3248#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
3252#    addu $t0,$t1

3256#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3260:mth_equals_Object:
3260#    move $t0,$s2 # first pointer (this)
3264#    lw $t1,($sp) # second pointer
3268#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
3269##...subu $at,$t0,$t1
3273##...sltiu $t0,$at,1

3276#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3280:mth_hashCode_String:
3280#    move $t0,$s2 # put this pointer in t0

3284#    li $t2,0 # current hash value
3288#    lw $t1,-4($t0) # negative of number of characters in string
3292#    beq $t1,$zero,done_hashCode_String # if zero length => done
3296#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
3300#    and $t0,0xfffffffc # adjust for padding
3301##...lui $at,65535
3305##...ori $at,$at,0xfffc
3309##...and $t0,$t0,$at
3312#    subu $t1,$t0,$t1 # address at end of string +12
3316:loop_hashCode_String:    
3316#    sll $t4,$t2,5 # multiply by 32
3320#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
3324#    lbu $t3,-12($t0) # current character
3328#    addu $t2,$t3 # add in current character
3332#    addu $t0,1 # go to next character's address
3336#    bne $t0,$t1,loop_hashCode_String # loop back if more
3340:done_hashCode_String:    

    # push int on stack
3340#    move $t0, $t2 # put $t2 in return slot
3344#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
3348:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
3348#    subu $sp,4
3352#    sw $ra,($sp)
    
    # get hash value
3356#    lw $t2,-12($s2) # vtable address
3360#    lw $t0,($t2) # method address
3364#    jalr $t0
3368#    subu $sp,8 # push result (int in $t0) on stack
3372#    sw $s5,4($sp)
3376#    sw $t0,($sp)

    # compute print-size of hash value
3380#    li $t0, 1
3384#    lw $t1, ($sp)
3388#    srl $t1,$t1,4
3392#    beq $t1,$zero,toString_skip_loop
3396:toString_loop_top:
3396#    addu $t0,1
3400#    srl $t1,$t1,4
3404#    bne $t1,$zero,toString_loop_top
3408:toString_skip_loop:
3408#    subu $sp,8
3412#    sw $s5,4($sp)
3416#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
3420#    lw $t2,-12($s2) # vtable address
3424#    move $t0,$t2
3428:toString_checkTagBit:
3428#    subu $t0,1
3432#    lb $t1,($t0)
3436#    and $t1,0x80
3437##...lui $at,0
3441##...ori $at,$at,0x80
3445##...and $t1,$t1,$at
3448#    beq $t1,$zero,toString_checkTagBit
3452#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
3456#    subu $sp,8
3460#    sw $t1,($sp)
3464#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
3468#    move $s7,$zero # -4 offset header word
3472#    lw $t4,8($sp) # bytes for hash value
3476#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
3480#    addu $t4,8
3484#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
3488#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

3492#    li $t0,CLASS_String # store string vtable address into ...
3496#    sw $t0,-12($s7) # ... -12 offset in object header
3500#    lw $t2,-12($s2) # our object's vtable address
3504#    lw $t5,4($sp) # number characters in prefix
3508#    lw $t1,12($sp) # number of characters in hashcode
3512#    addu $t3,$t1,$t5 # number of characters in string ...
3516#    addu $t3,1 # ... including the '@' character
3520#    subu $t0,$zero,$t3 # store negated length into ...
3524#    sw $t0,-4($s7) # ... -4 offset header word
3528#    lw $t0,-8($s7) # get -8 offset header-word
3532#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
3533##...slt $at,$t0,$zero
3537##...beq $at,$zero,3556
3540#    and $t0,0xff # mask off object's hash value ...
3541##...lui $at,0
3545##...ori $at,$at,0xff
3549##...and $t0,$t0,$at
3552#    sw $t0,-8($s7) # ... and store back into -8 header-word
3556:skipMask_toString:
3556#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
3560#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
3564#    subu $t4,$t2,$t5
3568:toString_copyLoop:    
3568#    lb $t3,($t4)
3572#    and $t3,0x7f # mask off sign bit (in case first word)
3573##...lui $at,0
3577##...ori $at,$at,0x7f
3581##...and $t3,$t3,$at
3584#    sb $t3,-8($t0)
3588#    addu $t4,1
3592#    addu $t0,1
3596#    blt $t4,$t2,toString_copyLoop
3597##...slt $at,$t4,$t2
3601##...bne $at,$zero,3568

    # copy the '@' sign
3604#    li $t3,'@'
3608#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
3612#    addu $t2,$t0,$t1 # address of last byte in string to store +8
3616#    lw $t3,20($sp) # hash code to print
3620:toString_hashCopyLoop:
3620#    and $t4,$t3,0xf
3624#    srl $t3,4
3628#    lb $t4,hexChars($t4)
3632#    sb $t4,-8($t2)
3636#    subu $t2,$t2,1
3640#    bgt $t2,$t0,toString_hashCopyLoop
3641##...slt $at,$t0,$t2
3645##...bne $at,$zero,3620

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
3648#    addu $sp,28
3652#    lw $ra,($sp)
3656#    addu $sp,4
3660#    move $t0, $s7 # return string we created
3664#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
3668:mth_equals_String:
    
    # quick test for obvious false
3668#    lw $t0,($sp) # second parameter
3672#    beq $t0,$zero,goEsFalse # go return false if null
3676#    lw $t1,-12($t0) # vtable pointer
3680#    la $t2,CLASS_String # string vtable pointer
3684#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
3688#    subu $sp,12
3692#    sw $ra,8($sp)
3696#    sw $s2,4($sp)
3700#    sw $t0,($sp)
3704#    jal mth_compareTo_String
3708#    lw $s2, 4($sp) #restore this pointer and pop parameters
3712#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
3716#    seq $t0,$t0,$zero
3717##...subu $at,$t0,$zero
3721##...sltiu $t0,$at,1

    # pop return address and return $t0
3724#    lw $ra,($sp)
3728#    addu $sp,4

3732#    jr $ra # return
    
3736:goEsFalse:
    # put 0 in $t0 and return
3736#    li $t0, 0
3740#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
3744:mth_toString_String:
    #we are a string, so return this.
3744#    move $t0, $s2
3748#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
3752:mth_readLine_Lib:
    
3752#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
3756#    sw $ra, 4($sp) # save $ra
3760#    move $t1,$sp # save "original" sp

3764:  doRead:

    # read the character
3764#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
3768#    subu $t2,$v0,13
3772#    bne $t2,$zero,notReturnRL
3776#    jal readLogicalChar
3780#    subu $t2,$v0,10 # check for newline
3784#    beq $t2,$zero,foundNewLine
3788#    sw $v0,lastCharRead # push back character into queue
3792#    j foundNewLine # go process the line

3796:  notReturnRL:

    # at this point, $v0 has our character

3796#    subu $t0,$v0,10
3800#    beq $t0,$zero,foundNewLine
3804#    blt $v0,$zero,foundEof
3805##...slt $at,$v0,$zero
3809##...bne $at,$zero,3824

    # we have a character, so push it onto stack
3812#    subu $sp,$sp,4
3816#    sw $v0,($sp)

    # loop back up to get next character
3820#    j doRead

3824:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
3824#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
3828#    li $s7, 0 # return-value: null
3832#    j rlReturn # return

3836:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
3836#    subu $t0,$t1,$sp # number of chars we read (times 4)
3840#    srl $s6,$t0,2 # number of words on stack with chars
3844#    subu $sp,$sp,4 # push char-count ...
3848#    sw $s6,($sp) # ... onto stack
3852#    addu $t2,$t0,5 # GC tag, incl. for count-word
3856#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
3860#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
3864#    srl $s6,$s6,2  # data words in object
3868#    move $s7,$zero # object words in object
3872#    jal newObject  # allocate space
    
    # store header words
3876#    la $t0,CLASS_String
3880#    sw $t0,-12($s7)# store class tag (String) into object
3884#    lw $t2,4($sp) # char-count
3888#    sll $t1,$t2,2 # 4 times number of chars
3892#    subu $t2,$zero,$t2 # negative of char-count
3896#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3900#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3904#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3905##...slt $at,$t0,$zero
3909##...beq $at,$zero,3928
3912#    and $t0,0xff # mask off object's hash value ...
3913##...lui $at,0
3917##...ori $at,$at,0xff
3921##...and $t0,$t0,$at
3924#    sw $t0,-8($s7) # ... and store back into -8 header-word
3928:  skipMask_readLine:

3928#    sll $t0,$t0,2 # data bytes in object
3932#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
3936#    subu $t0,$t0,$t2 # place to store last character (plus 9)
3940#    addu $sp,$sp,8 # pop redundant object-pointer and count
3944#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

3948#    beq $sp,$t1,rlReturn
3952:  charCopyLoop:
3952#    lw $t2,($sp)
3956#    sb $t2,-9($t0)
3960#    addu $sp,$sp,4
3964#    subu $t0,$t0,1
3968#    bne $sp,$t1,charCopyLoop
3972:  rlReturn:

3972#    lw $ra, 4($sp)
3976#    addu $sp, 8   # pop $ra and pointless word off stack
3980#    move $t0, $s7 # return string we allocated in $s7
3984#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3988:mth_readInt_Lib:

    # save $ra by pushing onto stack
3988#    subu $sp,$sp,4
3992#    sw $ra,($sp)

3996:  riSkipWhiteLoop:
    # read a character
3996#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
4000#    subu $t0,$v0,32
4004#    bgt $t0,$zero,nonWhite
4005##...slt $at,$zero,$t0
4009##...bne $at,$zero,4052
4012#    beq $t0,$zero,riSkipWhiteLoop # start over if space
4016#    subu $t0,$v0,10
4020#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
4024#    subu $t0,$v0,9
4028#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
4032#    subu $t0,$v0,13
4036#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
4040#    subu $t0,$v0,12
4044#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
4048#    j badIntegerFormat # illegal integer char: abort program

4052:  nonWhite:
4052#    subu $t0,$v0,'-'
4056#    li $t4,1 # final multiplier
4060#    bne $t0,$zero,helpReadInt # go read
4064#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
4068#    jal readLogicalChar

4072:  helpReadInt:
4072#    li $t2,10
4076#    subu $t1,$v0,'0' # convert digit to 0-9 value
4080#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
4081##...sltu $at,$t1,$t2
4085##...beq $at,$zero,6332
4088#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

4092:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

4092#    jal readLogicalChar # read next character
4096#    subu $t1,$v0,'0' # convert digit to 0-9 value
4100#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
4101##...sltu $at,$t1,$t2
4105##...beq $at,$zero,4124

4108#    mul $t3,$t3,$t2 # multiply old value by 10
4109##...mult $t3,$t2
4113##...mflo $t3
4116#    addu $t3,$t3,$t1 # add in value of new digit
4120#    j digitLoop

4124:  doneDigitLoop:

    # "push back" unused character into queue
4124#    sw $v0,lastCharRead

    # restore return address
4128#    lw $ra,($sp)
4132#    addu $sp, 4

    # multiply by sign and put return value in $t0
4136#    mult $t3,$t4 # multiply to account for poss. minus sign
4140#    mflo $t3
4144#    move $t0, $t3
    
    # return
4148#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
4152:mth_readChar_Lib:

    # save $ra by pushing onto stack
4152#    subu $sp,$sp,4
4156#    sw $ra,($sp)

      # read the character
4160#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
4164#    lw $ra,($sp)
4168#    addu $sp, 4
4172#    move $t0, $v0

    # return
4176#    jr $ra


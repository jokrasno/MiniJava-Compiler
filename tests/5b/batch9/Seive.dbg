4141##...sltu $at,$t6,$t1
4145##...beq $at,$zero,4308
4148#    bgtu $t1,$t7,gcTestIterDone1
4149##...sltu $at,$t7,$t1
4153##...bne $at,$zero,4308

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
4156#    lw $t2,-8($t1) # possible forwarding tag
4160#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
4164#    lw $t2,-4($t1) # forwarding pointer: object's new address
4168#    sw $t2,4($t0) # update stack value
4172#    j gcTestIterDone1 # do next iteration

4176:  gcNoForward1:
    #########################################################
    # we actually need to copy the object into the new space

2564#    beq $t0,$zero,riSkipWhiteLoop # start over if space
2568#    subu $t0,$v0,10
2572#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
2576#    subu $t0,$v0,9
2580#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
2584#    subu $t0,$v0,13
2588#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
2592#    subu $t0,$v0,12
2596#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
2600#    j badIntegerFormat # illegal integer char: abort program

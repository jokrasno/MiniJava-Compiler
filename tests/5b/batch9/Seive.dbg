
    # determine if we have enough memory available
3884#    addu $t0,$s6,$s7
3888#    sll $t0,$t0,2
3892#    addu $t0,$t0,8 # amount of memory needed
3896#    addu $t1,$t0,$s3
3900#    bgtu $t1,$s4,doGC

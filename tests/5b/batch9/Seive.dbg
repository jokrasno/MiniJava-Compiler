4804:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
4804#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

4808:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
4808#    li $v0,4 # syscall-code for print-string
4812#    syscall
4816:exit:
    # print termination message
4816#    li $v0,4 # syscall-code for print-string
4820#    la $a0,exitString
4824#    syscall

    # terminate execution
4828#    li $v0,10 #syscall-code for "exit"
4832#    syscall

4836:outOfHeapMemory:
4836#    la $a0,heapMemoryMsg
4840#    j exitError
4844:divByZeroError:
4844#    la $a0,divByZeroMsg
4848#    j exitError
4852:strIndexOutOfBounds:
4852#    la $a0,strIndexOutOfBoundsMsg
4856#    j exitError
4860:arrayIndexOutOfBounds:
4860#    la $a0,arrayIndexOutOfBoundsMsg
4864#    j exitError
4868:arraySizeOutOfBounds:
4868#    la $a0,arraySizeOutOfBoundsMsg
4872#    j exitError
4876:nullPtrException:
4876#    la $a0,nullPtrExceptionMsg
4880#    j exitError
4884:badIntegerFormat:
4884#    la $a0,badIntegerFormatMsg
4888#    j exitError
4892:castException:
4892#    la $a0,castExceptionMsg
4896#    j exitError
############## data section ################
    .data
5120:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5136:cur_seg:
    .word 0

5140:lastCharRead:
    .word -2 # -2 => no buffered character
5144:prevHashConstant:
    .word 0x2785173c
5148:gcCount:
    .word 0

5152:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5179:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5202:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5237:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5271:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5304:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5335:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5383:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5404:gcMsg: 
      .asciiz "\nGC!\n"
5410:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5442:nullStr:
    .asciiz "null"
5447:trueString:
    .asciiz "true"
5452:falseString:
    .asciiz "false"
5458:exitString:
    .ascii "Program terminated."
    #### "falls through" here
5477:newlineString:
    .asciiz "\n"
    
    .align 2
5480:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

5484:seg0_start:
    .space 0x100000
1054060:seg0_end:
1054060:seg1_start:
    .space 0x100000
2102636:seg1_end:

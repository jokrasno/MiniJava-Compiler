



###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1796:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
1796#    lw $t0,-8($s2) # get word with hash bits from this
1800#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
1804#    addu $t0,$t1

1808#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1812:mth_equals_Object:
1812#    move $t0,$s2 # first pointer (this)
1816#    lw $t1,($sp) # second pointer
1820#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
1821##...subu $at,$t0,$t1
1825##...sltiu $t0,$at,1

1828#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
1832:mth_hashCode_String:
1832#    move $t0,$s2 # put this pointer in t0

1836#    li $t2,0 # current hash value
1840#    lw $t1,-4($t0) # negative of number of characters in string
1844#    beq $t1,$zero,done_hashCode_String # if zero length => done
1848#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
1852#    and $t0,0xfffffffc # adjust for padding
1853##...lui $at,65535
1857##...ori $at,$at,0xfffc
1861##...and $t0,$t0,$at
1864#    subu $t1,$t0,$t1 # address at end of string +12
1868:loop_hashCode_String:    
1868#    sll $t4,$t2,5 # multiply by 32
1872#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
1876#    lbu $t3,-12($t0) # current character
1880#    addu $t2,$t3 # add in current character
1884#    addu $t0,1 # go to next character's address
1888#    bne $t0,$t1,loop_hashCode_String # loop back if more
1892:done_hashCode_String:    

    # push int on stack
1892#    move $t0, $t2 # put $t2 in return slot
1896#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
1900:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
1900#    subu $sp,4
1904#    sw $ra,($sp)
    
    # get hash value
1908#    lw $t2,-12($s2) # vtable address
1912#    lw $t0,($t2) # method address
1916#    jalr $t0
1920#    subu $sp,8 # push result (int in $t0) on stack
1924#    sw $s5,4($sp)
1928#    sw $t0,($sp)

    # compute print-size of hash value
1932#    li $t0, 1
1936#    lw $t1, ($sp)
1940#    srl $t1,$t1,4
1944#    beq $t1,$zero,toString_skip_loop
1948:toString_loop_top:
1948#    addu $t0,1
1952#    srl $t1,$t1,4
1956#    bne $t1,$zero,toString_loop_top
1960:toString_skip_loop:
1960#    subu $sp,8
1964#    sw $s5,4($sp)
1968#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
1972#    lw $t2,-12($s2) # vtable address
1976#    move $t0,$t2
1980:toString_checkTagBit:
1980#    subu $t0,1
1984#    lb $t1,($t0)
1988#    and $t1,0x80
1989##...lui $at,0
1993##...ori $at,$at,0x80
1997##...and $t1,$t1,$at
2000#    beq $t1,$zero,toString_checkTagBit
2004#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
2008#    subu $sp,8
2012#    sw $t1,($sp)
2016#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
2020#    move $s7,$zero # -4 offset header word
2024#    lw $t4,8($sp) # bytes for hash value
2028#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
2032#    addu $t4,8
2036#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
2040#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

2044#    li $t0,CLASS_String # store string vtable address into ...
2048#    sw $t0,-12($s7) # ... -12 offset in object header
2052#    lw $t2,-12($s2) # our object's vtable address
2056#    lw $t5,4($sp) # number characters in prefix
2060#    lw $t1,12($sp) # number of characters in hashcode
2064#    addu $t3,$t1,$t5 # number of characters in string ...
2068#    addu $t3,1 # ... including the '@' character
2072#    subu $t0,$zero,$t3 # store negated length into ...
2076#    sw $t0,-4($s7) # ... -4 offset header word
2080#    lw $t0,-8($s7) # get -8 offset header-word
2084#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2085##...slt $at,$t0,$zero
2089##...beq $at,$zero,2108
2092#    and $t0,0xff # mask off object's hash value ...
2093##...lui $at,0
2097##...ori $at,$at,0xff
2101##...and $t0,$t0,$at
2104#    sw $t0,-8($s7) # ... and store back into -8 header-word
2108:skipMask_toString:
2108#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2112#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2116#    subu $t4,$t2,$t5
2120:toString_copyLoop:    
2120#    lb $t3,($t4)
2124#    and $t3,0x7f # mask off sign bit (in case first word)
2125##...lui $at,0
2129##...ori $at,$at,0x7f
2133##...and $t3,$t3,$at
2136#    sb $t3,-8($t0)
2140#    addu $t4,1
2144#    addu $t0,1
2148#    blt $t4,$t2,toString_copyLoop
2149##...slt $at,$t4,$t2
2153##...bne $at,$zero,2120

    # copy the '@' sign
2156#    li $t3,'@'
2160#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2164#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2168#    lw $t3,20($sp) # hash code to print
2172:toString_hashCopyLoop:
2172#    and $t4,$t3,0xf
2176#    srl $t3,4
2180#    lb $t4,hexChars($t4)
2184#    sb $t4,-8($t2)
2188#    subu $t2,$t2,1
2192#    bgt $t2,$t0,toString_hashCopyLoop
2193##...slt $at,$t0,$t2
2197##...bne $at,$zero,2172

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2200#    addu $sp,28
2204#    lw $ra,($sp)
2208#    addu $sp,4
2212#    move $t0, $s7 # return string we created
2216#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2220:mth_equals_String:
    
    # quick test for obvious false
2220#    lw $t0,($sp) # second parameter
2224#    beq $t0,$zero,goEsFalse # go return false if null
2228#    lw $t1,-12($t0) # vtable pointer
2232#    la $t2,CLASS_String # string vtable pointer
2236#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2240#    subu $sp,12
2244#    sw $ra,8($sp)
2248#    sw $s2,4($sp)
2252#    sw $t0,($sp)
2256#    jal mth_compareTo_String
2260#    lw $s2, 4($sp) #restore this pointer and pop parameters
2264#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2268#    seq $t0,$t0,$zero
2269##...subu $at,$t0,$zero
2273##...sltiu $t0,$at,1

    # pop return address and return $t0
2276#    lw $ra,($sp)
2280#    addu $sp,4

2284#    jr $ra # return
    
2288:goEsFalse:
    # put 0 in $t0 and return
2288#    li $t0, 0
2292#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2296:mth_toString_String:
    #we are a string, so return this.
2296#    move $t0, $s2
2300#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2304:mth_readLine_Lib:
    
2304#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2308#    sw $ra, 4($sp) # save $ra
2312#    move $t1,$sp # save "original" sp

2316:  doRead:

    # read the character
2316#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2320#    subu $t2,$v0,13
2324#    bne $t2,$zero,notReturnRL
2328#    jal readLogicalChar
2332#    subu $t2,$v0,10 # check for newline
2336#    beq $t2,$zero,foundNewLine
2340#    sw $v0,lastCharRead # push back character into queue
2344#    j foundNewLine # go process the line

2348:  notReturnRL:

    # at this point, $v0 has our character

2348#    subu $t0,$v0,10
2352#    beq $t0,$zero,foundNewLine
2356#    blt $v0,$zero,foundEof
2357##...slt $at,$v0,$zero
2361##...bne $at,$zero,2376

    # we have a character, so push it onto stack
2364#    subu $sp,$sp,4
2368#    sw $v0,($sp)

    # loop back up to get next character
2372#    j doRead

2376:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2376#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2380#    li $s7, 0 # return-value: null
2384#    j rlReturn # return

2388:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2388#    subu $t0,$t1,$sp # number of chars we read (times 4)
2392#    srl $s6,$t0,2 # number of words on stack with chars
2396#    subu $sp,$sp,4 # push char-count ...
2400#    sw $s6,($sp) # ... onto stack
2404#    addu $t2,$t0,5 # GC tag, incl. for count-word
2408#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2412#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2416#    srl $s6,$s6,2  # data words in object
2420#    move $s7,$zero # object words in object
2424#    jal newObject  # allocate space
    
    # store header words
2428#    la $t0,CLASS_String
2432#    sw $t0,-12($s7)# store class tag (String) into object
2436#    lw $t2,4($sp) # char-count
2440#    sll $t1,$t2,2 # 4 times number of chars
2444#    subu $t2,$zero,$t2 # negative of char-count
2448#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object

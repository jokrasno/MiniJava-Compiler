# compares two strings as in Java
# - parameters:
#   - ($sp) - second string
#   - 4($sp) - old this pointer
#   - $s2 - first string (this)
# - returns:
#   - $t0 - -1, 0, or 1 depending on whether str1 is
#       lexographically less than, equal to or greater than str2
########################################################
6336:mth_compareTo_String:
    # get string pointers and check parameter for null
6336#    lw $t0,($sp) # second string
6340#    beq $t0,$zero,nullPtrException
6344#    move $t1,$s2 # first string
    
    # get (negatives of) respective byte-lengths
6348#    lw $t2,-4($t0) # negative length of second string
6352#    lw $t3,-4($t1) # negative length of first string

    # put tentative return value in $t5.
    # The tentative return value is the one that we will use if we get
    # to the end of the shorter string during our comparison-loop.
6356#    slt $t4,$t3,$t2
6360#    slt $t5,$t2,$t3
6364#    subu $t5,$t5,$t4
    
    # at this point:
    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
6368#    lw $t2,-8($t0) # # data words in second string
6372#    lw $t3,-8($t1) # # data words in first string
6376#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
6380#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
6384#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
6388#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2
6392#    beq $zero,$t5,skipStrCmpLenzz
6396#    move $t2,$t3
6400:  skipStrCmpLenzz:
6400#    add $t2,$t1,$t2
    
    # at this point:
    # - $t0 contains 8 plus the address of the first data-byte of str2
    # - $t1 contains 8 plus the address of the first data-byte of str1
    # - $t2 contains 8 plus the address of the last data-type of str1
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    #######################################################
    # at this point, we have
    # - $t5 containing the tentative return-value
    # - $t1 containing address of first char in str2
    # - $t2 containing limit for $t1
    # - $t0 containing address of first char in str1
    #######################################################

    # loop through, until we find unequal words or we hit
    # our limit    
6404:  cmpLoopzz:
6404#    lw $t3,-8($t1) # word from str2
6408#    lw $t4,-8($t0) # word from str1
6412#    bne $t3,$t4,cmpNotEqualzz
6416#    addu $t1,$t1,4
6420#    addu $t0,$t0,4
6424#    bne $t1,$t2,cmpLoopzz

    # # got to the end of one string: go set up return
6428#    j cmpHitLimitzz

6432:  cmpNotEqualzz:
    # found unequal characters: return -1 or 1, depending on which is
    # greater
6432#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
6436#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
6440#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
6444:  cmpHitLimitzz:
6444#    move $t0, $t5 # store return value
6448#    jr $ra # return

########################################################
# readLogicalChar (millicode)
#  - logically reads a character from standard input
#  - first checks character buffer, consuming it if possible
#  - return-result:
#    - returns character in $v0
#  - side-effects:
#    - reads a character
#    - clobbers $t0
########################################################
6452:readLogicalChar:

    # check if we already have a character
6452#    lw $v0,lastCharRead
6456#    li $t0,-2
6460#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
6464#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
6468#    jr $ra # return
    
6472:  doReadCh:
    # we need to actually read a character: read and return
6472#    li $v0,12 # use system call to read a character
6476#    syscall
6480#    jr $ra # return

########################################################
# newObject (millicode)
#  - allocates a new object on the heap
#  - two-word header is set up properly
#  - all non-header words in object are set to zero
#  - parameters:
#    - $s6 = the number of data words in the negative-offset portion of
#      the object (including the vtable pointer); this value is 1 if the
#      object is an array; this should always be at least 1
#    - $s7 - second header-word, which is the number of object
#      words in the object
#      - $s7 may not be negative (this is checked); if so, the program is
#        aborted with an "array size of out bounds" error message
#      is treated as if it were zero
#  - return-result:
#    - returned in $s7
#    - and pushed on the stack
#  - side-effects:
#  - may trash all $tx registers and all $sx registers, except the
#    "permanent" ones, which get updated with values that are
#    consistent with the new space
########################################################
6484:newObject:
    # $s6 = # data words
    # $s7 = # object words (# data words if data-array allocation,
    # where a negative number is treated as 0)
    # $ra = return address
    # on return, pointer to new memory in two places:
    # - pushed onto top of stack
    # - in $s7
    
    # if the object-portion size is negative, abort with error
6484#    blt $s7,$zero arraySizeOutOfBounds
6485##...slt $at,$s7,$zero
6489##...bne $at,$zero,7480

    # mark the fact that we have not yet GC'd for this allocation
6492#    move $t5,$zero

    ###### TEMPORARY #######
    # for now, go a GC unconditionally, so that a full GC occurs
    # every time we allocate an object
    ### let's not do that for now
    # j doGC

6496:  gcJoin:

    # at this point:
    #  $s6 contains the before-header word count
    #  $s7 contains the second header word, which is also the
    #    after-header word count
    #  $t5 is zero iff we have not GC'd for this allocation

    # determine if we have enough memory available
6496#    addu $t0,$s6,$s7
6500#    sll $t0,$t0,2
6504#    addu $t0,$t0,8 # amount of memory needed
6508#    addu $t1,$t0,$s3
6512#    bgtu $t1,$s4,doGC
6513##...sltu $at,$s4,$t1
6517##...bne $at,$zero,6640

    # at this point:
    #  $s3 points to beginning of segment, and
    #  $t1 points just past the end

    # zero out the memory
6520#    move $t2,$s3
6524:  zeroObjLoop:
6524#    sw $zero,($s3)
6528#    lw $zero,($s3)

6532#    addu $s3,4
6536#    bltu $s3,$t1,zeroObjLoop
6537##...sltu $at,$s3,$t1
6541##...bne $at,$zero,6524

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
6544#    sll $t0,$s7,2    # number of post-header bytes
6548#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
6552#    li $t2,255
6556#    bgeu $s6,$t2 firstHeaderLarge
6557##...sltu $at,$s6,$t2
6561##...beq $at,$zero,6608
6564#    lw $t1,prevHashConstant
6568#    addu $t1,0x12b68fd2
6569##...lui $at,4791
6573##...addiu $at,$at,-28718
6577##...addu $t1,$at,$t1
6580#    sw $t1,prevHashConstant # update hash constant
6584#    or $t1,0x80000000 # set top bit
6585##...lui $at,32768
6589##...or $t1,$at,$t1
6592#    and $t1,0xffffff00 # clear low bit
6593##...lui $at,65535
6597##...ori $at,$at,0xff00
6601##...and $t1,$t1,$at
6604#    or $s6,$t1
6608:firstHeaderLarge:
6608#    sw $s6,-8($t0) # store header-1 value
6612#    lw $zero,-8($t0)

    # store second header-value
6616#    sw $s7,-4($t0)   # second header-word
6620#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
6624#    move $s7,$t0
6628#    subu $sp,$sp,4
6632#    sw $t0,($sp)

6636#    jr $ra
    
6640:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
6640#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
6644#    lw $t5,gcCount
6648#    addu $t5,1
6652#    sw $t5,gcCount

    # save $s2 (our only rooted register) on the stack
    # so that the garbage collector processes it
6656#    subu $sp,$sp,4
6660#    sw $s2,($sp)

    # set $s3 to the address of the new segment and the
    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
6664#    lw $t0,cur_seg
6668#    move $t7,$s4
6672#    la $t6,seg1_start
6673##...lui $t6,16
6677##...addiu $t6,$t6,8308
6680#    la $s3,seg0_start
6684#    la $s4,seg0_end
6685##...lui $s4,16
6689##...addiu $s4,$s4,8308
6692#    sw $zero,cur_seg
6696#    bne $t0,$zero,skipGc1
6700#    la $t6,seg0_start
6704#    la $s3,seg1_start
6705##...lui $s3,16
6709##...addiu $s3,$s3,8308
6712#    la $s4,seg1_end
6713##...lui $s4,32
6717##...addiu $s4,$s4,8308
6720#    sw $s5,cur_seg
6724:  skipGc1:
6724#    li $t5,0x80000000
6728#    lw $t0,stack_bottom
6732#    subu $t0,4


    ###############################################################
    # at this point:
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first address of the target space
    # - $s4 contains the limit address of the target space
    # - cur_seg has been updated to refer to the target space
    # - $t0 contains the address of the deepest stack element
    # - $sp contains the address of the top stack element
    # - $s2 is available for use, having been pushed onto the stack
    # - $t5 contains the value 0x80000000
    ###############################################################

    ###### begin outer loop to copy all stack-direct objects ######

6736:  gcStackCopyLoop:
6736#    lw $t1,($t0) # current stack element

    # test if we have a GC tag
6740#    sll $t2,$t1,31 # zero iff low bit was zero
6744#    bne $t2,$zero,gcBump # go skip data values if low bit not zero

    # bump stack-address pointer
6748#    subu $t0,$t0,4

    # if value is out of range (which includes null=0), and is
    # therefore does not refer to an object on the heap, just go
    # loop back and do the next one
6752#    bleu $t1,$t6,gcTestIterDone1
6753##...sltu $at,$t6,$t1
6757##...beq $at,$zero,6920
6760#    bgtu $t1,$t7,gcTestIterDone1
6761##...sltu $at,$t7,$t1
6765##...bne $at,$zero,6920

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
6768#    lw $t2,-8($t1) # possible forwarding tag
6772#    bne $t2,$zero,gcNoForward1 # if not forwarding tag, go copy
6776#    lw $t2,-4($t1) # forwarding pointer: object's new address
6780#    sw $t2,4($t0) # update stack value
6784#    j gcTestIterDone1 # do next iteration

6788:  gcNoForward1:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    # compute the amount of space that is needed
6788#    bge $t2,$zero,gcSkip2
6789##...slt $at,$t2,$zero
6793##...beq $at,$zero,6808
6796#    and $t2,0xff #### mask off hash value
6797##...lui $at,0
6801##...ori $at,$at,0xff
6805##...and $t2,$t2,$at
    #### OLD
    #### subu $t2,$zero,$t2 # set to 1 if -1 (number of data words)

6808:  gcSkip2:
6808#    sll $t2,$t2,2
6812#    addu $t2,$t2,8
6816#    subu $t4,$t1,$t2 # address of first word of source
6820#    lw $t3,-4($t1) # number of object words (negative means zero)
6824#    bge $t3,$zero,gcH2Neg1
6825##...slt $at,$t3,$zero
6829##...beq $at,$zero,6836
6832#    move $t3,$zero
6836:  gcH2Neg1:
6836#    sll $t3,$t3,2
6840#    addu $t3,$t3,$t1 # address one word past last word of source

6844#    addu $t2,$s3,$t2 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object (i.e., the address just beyond the object's header)
    # - $t2 contains the pointer to the target object
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0-2
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger" in the target space
6848#    lw $s0,($t4)
6852#    lw $s1,-8($t1)
6856#    sw $s1,($t4)
6860#    sw $s0,-8($t1)
    
    # copy all source bytes to the target
6864:  gCinnerCopy1:
6864#    lw $s0,($t4)
6868#    sw $s0,($s3)
6872#    addu $t4,$t4,4
6876#    addu $s3,$s3,4
6880#    bltu $t4,$t3,gCinnerCopy1
6881##...sltu $at,$t4,$t3
6885##...bne $at,$zero,6864

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
6888#    sw $zero,-8($t1) # 0 in first header-slot
6892#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
6896#    sw $t2,4($t0)
6900#    lw $zero,-8($t2)
6904#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
6908#    j gcTestIterDone1

6912:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
6912#    subu $t0,$t0,$t1
6916#    subu $t0,$t0,3

6920:  gcTestIterDone1:
6920#    bgeu $t0,$sp,gcStackCopyLoop
6921##...sltu $at,$t0,$sp
6925##...beq $at,$zero,6736

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
6928#    lw $t1,cur_seg
6932#    la $t0,seg0_start
6936#    beq $t1,$zero,gcSkip4
6940#    la $t0,seg1_start
6941##...lui $t0,16
6945##...addiu $t0,$t0,8308


6948:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
6948#    bgeu $t0,$s3,gcFinishUp
6949##...sltu $at,$t0,$s3
6953##...beq $at,$zero,7244

    ###### begin outer loop to copy all non-stack-direct objects ######

6956:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
6956#    lw $t1,($t0) # (what will be) first header word for current object
6960#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
6964#    bge $t2,$zero,gcSkip4a # are there hash bits?
6965##...slt $at,$t2,$zero
6969##...beq $at,$zero,6984
6972#    and $t2,0xff # mask off hash bits
6973##...lui $at,0
6977##...ori $at,$at,0xff
6981##...and $t2,$t2,$at
6984:gcSkip4a:    
6984#    sll $t2,$t2,2 # # data bytes
6988#    addu $t2,$t2,8 # to skip header words
6992#    addu $t2,$t0,$t2 # pointer to new object
6996#    lw $t3,-8($t2) # word to swap
7000#    sw $t1,-8($t2) # store header word
7004#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
7008#    lw $t1,-12($t2) # vtable pointer
7012#    li $t0,dataArrayVTableStart # address of vtable for first data array
7016#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
7017##...slt $at,$t1,$t0
7021##...bne $at,$zero,7040

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
7024:  skipToNextObj:
7024#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
7028#    sll $t1,$t1,2 # convert to byte-count
7032#    addu $t0,$t2,$t1 # skip over object
7036#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
7040:  gcNotDataArray:
7040#    lw $t3,-4($t2) # # object words (negative treated as zero)
7044#    bge $t3,$zero,gcH2Neg2
7045##...slt $at,$t3,$zero
7049##...beq $at,$zero,7056
7052#    move $t3,$zero
7056:  gcH2Neg2:
7056#    sll $t3,$t3,2 # # object bytes
7060#    move $t0,$t2 # address of first pointer in object
7064#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
7068#    beq $t0,$s1,gcTestIterDone2
    
7072:  gcNextPointerInObject:
    # get pointer from object
7072#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
7076#    bleu $t1,$t6,gcGoNextPointerSlot
7077##...sltu $at,$t6,$t1
7081##...beq $at,$zero,7224
7084#    bgtu $t1,$t7,gcGoNextPointerSlot
7085##...sltu $at,$t7,$t1
7089##...bne $at,$zero,7224

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
7092#    lw $t8,-8($t1) # possible forwarding tag
7096#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
7100#    lw $t8,-4($t1) # forwarding pointer: object's new address
7104#    sw $t8,($t0) # update pointer in object
7108#    j gcGoNextPointerSlot # do next iteration

7112:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
7112#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
7113##...slt $at,$t8,$zero
7117##...beq $at,$zero,7132
7120#    and $t8,0xff # mask off hash bits
7121##...lui $at,0
7125##...ori $at,$at,0xff
7129##...and $t8,$t8,$at

7132:  gcSkip5:
7132#    sll $t8,$t8,2 # bytes in negative-offset portion ...
7136#    addu $t8,$t8,8 # ... add in bytes for header-words
7140#    subu $t4,$t1,$t8 # address of first word of source object
7144#    lw $t3,-4($t1) # # words in positive-offset portion
7148#    bge $t3,$zero,gcNoNeg
7149##...slt $at,$t3,$zero
7153##...beq $at,$zero,7160
7156#    move $t3,$zero # negative treated as zero
7160:  gcNoNeg:
7160#    sll $t3,$t3,2 # bytes in negative-offset portion
7164#    addu $t3,$t3,$t1 # address one word past last word of source

7168#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
7172#    lw $s0,($t4)
7176#    lw $t9,-8($t1)
7180#    sw $t9,($t4)
7184#    sw $s0,-8($t1)

    # copy all source bytes to the target
7188:  gCinnerCopy2:
7188#    lw $s0,($t4)
7192#    sw $s0,($s3)
7196#    addu $t4,$t4,4
7200#    addu $s3,$s3,4
7204#    bltu $t4,$t3,gCinnerCopy2
7205##...sltu $at,$t4,$t3
7209##...bne $at,$zero,7188

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
7212#    sw $zero,-8($t1) # 0 in first header-slot
7216#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
7220#    sw $t8,($t0)

7224:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
7224#    addu $t0,$t0,4
7228#    bltu $t0,$s1,gcNextPointerInObject
7229##...sltu $at,$t0,$s1
7233##...bne $at,$zero,7072

7236:  gcTestIterDone2:
7236#    bltu $t0,$s3,gcHeapCopyLoop
7237##...sltu $at,$t0,$s3
7241##...bne $at,$zero,6956

    ###### end outer loop to copy all non-stack-direct objects ######

7244:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
7244#    lw $s2,($sp)
7248#    addu $sp,$sp,4

    # mark us as having already GC'd
7252#    move $t5,$s5

    # go try and allocate again
7256#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
7260:vm_init:

    # mark bottom of stack
7260#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
7264#    move $s2,$zero

    #set up the "five" register
7268#    li $s5,5

7272#    la $s3,seg0_start
7276#    la $s4,seg0_end
7277##...lui $s4,16
7281##...addiu $s4,$s4,8308
    
    # return
7284#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
7288:divide:
    # get parameters; abort if divisor zero
7288#    lw $t0,($sp)
7292#    lw $t1,8($sp)
7296#    beq $t0,$zero,divByZeroError
    
    # perform division
7300#    div $t1,$t0
7304#    mflo $t0

    # store result, adjust stack and return
7308#    addu $sp,$sp,8 # adjust stack
7312#    sw $t0,($sp) # store result
7316#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
7320:remainder:
    # get parameters; abort if divisor zero
7320#    lw $t0,($sp)
7324#    lw $t1,8($sp)
7328#    beq $t0,$zero,divByZeroError
    
    # perform division
7332#    div $t1,$t0
7336#    mfhi $t0

    # store result, adjust stack and return
7340#    addu $sp,$sp,8 # adjust stack
7344#    sw $t0,($sp) # store result
7348#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
7352:checkCast:
    # get object, allow immediately if null
7352#    lw $t2,($sp)
7356#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
7360#    lw $t2,-12($t2) # vtable address
7364#    bge $t2,$t1,castException
7365##...slt $at,$t2,$t1
7369##...beq $at,$zero,7504
7372#    blt $t2,$t0,castException
7373##...slt $at,$t2,$t0
7377##...bne $at,$zero,7504
    
    # return, leaving object unchanged on stack
7380:  checkCastReturn:    
7380#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
7384:instanceOf:
    # get object, go return false if null
7384#    lw $t2,($sp)
7388#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
7392#    lw $t2,-12($t2) # vtable address
7396#    sge $t0,$t2,$t0 # are we >= the lower limit?
7397##...slt $t0,$t2,$t0
7401##...xori $t0,$t0,0x1
7404#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
7408#    and $t2,$t0,$t1
7412#    sw $t2,($sp)
7416:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
7416#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

7420:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
7420#    li $v0,4 # syscall-code for print-string
7424#    syscall
7428:exit:
    # print termination message
7428#    li $v0,4 # syscall-code for print-string
7432#    la $a0,exitString
7436#    syscall

    # terminate execution
7440#    li $v0,10 #syscall-code for "exit"
7444#    syscall

7448:outOfHeapMemory:
7448#    la $a0,heapMemoryMsg
7452#    j exitError
7456:divByZeroError:
7456#    la $a0,divByZeroMsg
7460#    j exitError
7464:strIndexOutOfBounds:
7464#    la $a0,strIndexOutOfBoundsMsg
7468#    j exitError
7472:arrayIndexOutOfBounds:
7472#    la $a0,arrayIndexOutOfBoundsMsg
7476#    j exitError
7480:arraySizeOutOfBounds:
7480#    la $a0,arraySizeOutOfBoundsMsg
7484#    j exitError
7488:nullPtrException:
7488#    la $a0,nullPtrExceptionMsg
7492#    j exitError
7496:badIntegerFormat:
7496#    la $a0,badIntegerFormatMsg
7500#    j exitError
7504:castException:
7504#    la $a0,castExceptionMsg
7508#    j exitError
############## data section ################
    .data
7944:hexChars:
    .ascii "0123456789abcdef"
    .align 2
7960:cur_seg:
    .word 0

7964:lastCharRead:
    .word -2 # -2 => no buffered character
7968:prevHashConstant:
    .word 0x2785173c
7972:gcCount:
    .word 0

7976:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
8003:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
8026:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
8061:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
8095:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
8128:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
8159:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
8207:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
8228:gcMsg: 
      .asciiz "\nGC!\n"
8234:gcCountMsg: 
      .asciiz "Number of garbage collections: "

8266:nullStr:
    .asciiz "null"
8271:trueString:
    .asciiz "true"
8276:falseString:
    .asciiz "false"
8282:exitString:
    .ascii "Program terminated."
    #### "falls through" here
8301:newlineString:
    .asciiz "\n"
    
    .align 2
8304:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

8308:seg0_start:
    .space 0x100000
1056884:seg0_end:
1056884:seg1_start:
    .space 0x100000
2105460:seg1_end:

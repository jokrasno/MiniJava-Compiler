##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
4408:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
4408#    lw $t0,-8($s2) # get word with hash bits from this
4412#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
4416#    addu $t0,$t1

4420#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
4424:mth_equals_Object:
4424#    move $t0,$s2 # first pointer (this)
4428#    lw $t1,($sp) # second pointer
4432#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
4433##...subu $at,$t0,$t1
4437##...sltiu $t0,$at,1

4440#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
4444:mth_hashCode_String:
4444#    move $t0,$s2 # put this pointer in t0

4448#    li $t2,0 # current hash value
4452#    lw $t1,-4($t0) # negative of number of characters in string
4456#    beq $t1,$zero,done_hashCode_String # if zero length => done
4460#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
4464#    and $t0,0xfffffffc # adjust for padding
4465##...lui $at,65535
4469##...ori $at,$at,0xfffc
4473##...and $t0,$t0,$at
4476#    subu $t1,$t0,$t1 # address at end of string +12
4480:loop_hashCode_String:    
4480#    sll $t4,$t2,5 # multiply by 32
4484#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
4488#    lbu $t3,-12($t0) # current character
4492#    addu $t2,$t3 # add in current character
4496#    addu $t0,1 # go to next character's address
4500#    bne $t0,$t1,loop_hashCode_String # loop back if more
4504:done_hashCode_String:    

    # push int on stack
4504#    move $t0, $t2 # put $t2 in return slot
4508#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
4512:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
4512#    subu $sp,4
4516#    sw $ra,($sp)
    
    # get hash value
4520#    lw $t2,-12($s2) # vtable address
4524#    lw $t0,($t2) # method address
4528#    jalr $t0
4532#    subu $sp,8 # push result (int in $t0) on stack
4536#    sw $s5,4($sp)
4540#    sw $t0,($sp)

    # compute print-size of hash value
4544#    li $t0, 1
4548#    lw $t1, ($sp)
4552#    srl $t1,$t1,4
4556#    beq $t1,$zero,toString_skip_loop
4560:toString_loop_top:
4560#    addu $t0,1
4564#    srl $t1,$t1,4
4568#    bne $t1,$zero,toString_loop_top
4572:toString_skip_loop:
4572#    subu $sp,8
4576#    sw $s5,4($sp)
4580#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
4584#    lw $t2,-12($s2) # vtable address
4588#    move $t0,$t2
4592:toString_checkTagBit:
4592#    subu $t0,1
4596#    lb $t1,($t0)
4600#    and $t1,0x80
4601##...lui $at,0
4605##...ori $at,$at,0x80
4609##...and $t1,$t1,$at
4612#    beq $t1,$zero,toString_checkTagBit
4616#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
4620#    subu $sp,8
4624#    sw $t1,($sp)
4628#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
4632#    move $s7,$zero # -4 offset header word
4636#    lw $t4,8($sp) # bytes for hash value
4640#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
4644#    addu $t4,8
4648#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
4652#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

4656#    li $t0,CLASS_String # store string vtable address into ...
4660#    sw $t0,-12($s7) # ... -12 offset in object header
4664#    lw $t2,-12($s2) # our object's vtable address
4668#    lw $t5,4($sp) # number characters in prefix
4672#    lw $t1,12($sp) # number of characters in hashcode
4676#    addu $t3,$t1,$t5 # number of characters in string ...
4680#    addu $t3,1 # ... including the '@' character
4684#    subu $t0,$zero,$t3 # store negated length into ...
4688#    sw $t0,-4($s7) # ... -4 offset header word
4692#    lw $t0,-8($s7) # get -8 offset header-word
4696#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
4697##...slt $at,$t0,$zero
4701##...beq $at,$zero,4720
4704#    and $t0,0xff # mask off object's hash value ...
4705##...lui $at,0
4709##...ori $at,$at,0xff
4713##...and $t0,$t0,$at
4716#    sw $t0,-8($s7) # ... and store back into -8 header-word
4720:skipMask_toString:
4720#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
4724#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
4728#    subu $t4,$t2,$t5
4732:toString_copyLoop:    
4732#    lb $t3,($t4)
4736#    and $t3,0x7f # mask off sign bit (in case first word)
4737##...lui $at,0
4741##...ori $at,$at,0x7f
4745##...and $t3,$t3,$at
4748#    sb $t3,-8($t0)
4752#    addu $t4,1
4756#    addu $t0,1
4760#    blt $t4,$t2,toString_copyLoop
4761##...slt $at,$t4,$t2
4765##...bne $at,$zero,4732

    # copy the '@' sign
4768#    li $t3,'@'
4772#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
4776#    addu $t2,$t0,$t1 # address of last byte in string to store +8
4780#    lw $t3,20($sp) # hash code to print
4784:toString_hashCopyLoop:
4784#    and $t4,$t3,0xf
4788#    srl $t3,4
4792#    lb $t4,hexChars($t4)
4796#    sb $t4,-8($t2)
4800#    subu $t2,$t2,1
4804#    bgt $t2,$t0,toString_hashCopyLoop
4805##...slt $at,$t0,$t2
4809##...bne $at,$zero,4784

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
4812#    addu $sp,28
4816#    lw $ra,($sp)
4820#    addu $sp,4
4824#    move $t0, $s7 # return string we created
4828#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
4832:mth_equals_String:
    
    # quick test for obvious false
4832#    lw $t0,($sp) # second parameter
4836#    beq $t0,$zero,goEsFalse # go return false if null
4840#    lw $t1,-12($t0) # vtable pointer
4844#    la $t2,CLASS_String # string vtable pointer
4848#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
4852#    subu $sp,12
4856#    sw $ra,8($sp)
4860#    sw $s2,4($sp)
4864#    sw $t0,($sp)
4868#    jal mth_compareTo_String
4872#    lw $s2, 4($sp) #restore this pointer and pop parameters
4876#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
4880#    seq $t0,$t0,$zero
4881##...subu $at,$t0,$zero
4885##...sltiu $t0,$at,1

    # pop return address and return $t0
4888#    lw $ra,($sp)
4892#    addu $sp,4

4896#    jr $ra # return
    
4900:goEsFalse:
    # put 0 in $t0 and return
4900#    li $t0, 0
4904#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
4908:mth_toString_String:
    #we are a string, so return this.
4908#    move $t0, $s2
4912#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
4916:mth_readLine_Lib:
    
4916#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
4920#    sw $ra, 4($sp) # save $ra
4924#    move $t1,$sp # save "original" sp

4928:  doRead:

    # read the character
4928#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
4932#    subu $t2,$v0,13
4936#    bne $t2,$zero,notReturnRL
4940#    jal readLogicalChar
4944#    subu $t2,$v0,10 # check for newline
4948#    beq $t2,$zero,foundNewLine
4952#    sw $v0,lastCharRead # push back character into queue
4956#    j foundNewLine # go process the line

4960:  notReturnRL:

    # at this point, $v0 has our character

4960#    subu $t0,$v0,10
4964#    beq $t0,$zero,foundNewLine
4968#    blt $v0,$zero,foundEof
4969##...slt $at,$v0,$zero
4973##...bne $at,$zero,4988

    # we have a character, so push it onto stack
4976#    subu $sp,$sp,4
4980#    sw $v0,($sp)

    # loop back up to get next character
4984#    j doRead

4988:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
4988#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
4992#    li $s7, 0 # return-value: null
4996#    j rlReturn # return

5000:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
5000#    subu $t0,$t1,$sp # number of chars we read (times 4)
5004#    srl $s6,$t0,2 # number of words on stack with chars
5008#    subu $sp,$sp,4 # push char-count ...
5012#    sw $s6,($sp) # ... onto stack
5016#    addu $t2,$t0,5 # GC tag, incl. for count-word
5020#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
5024#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
5028#    srl $s6,$s6,2  # data words in object
5032#    move $s7,$zero # object words in object
5036#    jal newObject  # allocate space
    
    # store header words
5040#    la $t0,CLASS_String
5044#    sw $t0,-12($s7)# store class tag (String) into object
5048#    lw $t2,4($sp) # char-count
5052#    sll $t1,$t2,2 # 4 times number of chars
5056#    subu $t2,$zero,$t2 # negative of char-count
5060#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
5064#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
5068#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
5069##...slt $at,$t0,$zero
5073##...beq $at,$zero,5092
5076#    and $t0,0xff # mask off object's hash value ...
5077##...lui $at,0
5081##...ori $at,$at,0xff
5085##...and $t0,$t0,$at
5088#    sw $t0,-8($s7) # ... and store back into -8 header-word
5092:  skipMask_readLine:

5092#    sll $t0,$t0,2 # data bytes in object
5096#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
5100#    subu $t0,$t0,$t2 # place to store last character (plus 9)
5104#    addu $sp,$sp,8 # pop redundant object-pointer and count
5108#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

5112#    beq $sp,$t1,rlReturn
5116:  charCopyLoop:
5116#    lw $t2,($sp)
5120#    sb $t2,-9($t0)
5124#    addu $sp,$sp,4
5128#    subu $t0,$t0,1
5132#    bne $sp,$t1,charCopyLoop
5136:  rlReturn:

5136#    lw $ra, 4($sp)
5140#    addu $sp, 8   # pop $ra and pointless word off stack
5144#    move $t0, $s7 # return string we allocated in $s7
5148#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
5152:mth_readInt_Lib:

    # save $ra by pushing onto stack
5152#    subu $sp,$sp,4
5156#    sw $ra,($sp)

5160:  riSkipWhiteLoop:
    # read a character
5160#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
5164#    subu $t0,$v0,32
5168#    bgt $t0,$zero,nonWhite
5169##...slt $at,$zero,$t0
5173##...bne $at,$zero,5216
5176#    beq $t0,$zero,riSkipWhiteLoop # start over if space
5180#    subu $t0,$v0,10
5184#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
5188#    subu $t0,$v0,9
5192#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
5196#    subu $t0,$v0,13
5200#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
5204#    subu $t0,$v0,12
5208#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
5212#    j badIntegerFormat # illegal integer char: abort program

5216:  nonWhite:
5216#    subu $t0,$v0,'-'
5220#    li $t4,1 # final multiplier
5224#    bne $t0,$zero,helpReadInt # go read
5228#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
5232#    jal readLogicalChar

5236:  helpReadInt:
5236#    li $t2,10
5240#    subu $t1,$v0,'0' # convert digit to 0-9 value
5244#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
5245##...sltu $at,$t1,$t2
5249##...beq $at,$zero,7496
5252#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

5256:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

5256#    jal readLogicalChar # read next character
5260#    subu $t1,$v0,'0' # convert digit to 0-9 value
5264#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
5265##...sltu $at,$t1,$t2
5269##...beq $at,$zero,5288

5272#    mul $t3,$t3,$t2 # multiply old value by 10
5273##...mult $t3,$t2
5277##...mflo $t3
5280#    addu $t3,$t3,$t1 # add in value of new digit
5284#    j digitLoop

5288:  doneDigitLoop:

    # "push back" unused character into queue
5288#    sw $v0,lastCharRead

    # restore return address
5292#    lw $ra,($sp)
5296#    addu $sp, 4

    # multiply by sign and put return value in $t0
5300#    mult $t3,$t4 # multiply to account for poss. minus sign
5304#    mflo $t3
5308#    move $t0, $t3
    
    # return
5312#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
5316:mth_readChar_Lib:

    # save $ra by pushing onto stack
5316#    subu $sp,$sp,4
5320#    sw $ra,($sp)

      # read the character
5324#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
5328#    lw $ra,($sp)
5332#    addu $sp, 4
5336#    move $t0, $v0

    # return
5340#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
5344:mth_printStr_Lib:
    # check for null, printing "(null)", if so
5344#    lw $t0,($sp)
5348#    bne $t0,$zero,psNotNull

    # print "(null)"
5352#    la $a0,nullStr
5356#    li $v0,4
5360#    syscall
5364#    j donePrintStr
    
5368:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
5368#    subu $t0,$t0,8
5372#    lw $t1,($t0) # number of data words, but needs modification
5376#    blt $t1,$zero,skipPrintStr1
5377##...slt $at,$t1,$zero
5381##...bne $at,$zero,5400
5384#    and $t1,0xff # mask out all but low byte
5385##...lui $at,0
5389##...ori $at,$at,0xff
5393##...and $t1,$t1,$at
5396#    b skipPrintStr2
5400:skipPrintStr1:
5400#    and $t1,0x7ffffff
5401##...lui $at,2047
5405##...ori $at,$at,0xffff
5409##...and $t1,$t1,$at
5412:skipPrintStr2:    
5412#    sll $t1,$t1,2
5416#    subu $t1,$t0,$t1 # first word in string
5420#    lw $t0,4($t0) # negative of string-length
5424#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
5428#    beq $t0,$t1,donePrintStr
5432:  psLoop:
5432#    lb $a0,($t1) # next byte
5436#    li $v0,11 # code for printing char
5440#        syscall # print the char

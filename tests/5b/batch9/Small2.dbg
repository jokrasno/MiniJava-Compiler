3349##...bne $at,$zero,3368
3352#    and $t1,0xff # mask out all but low byte
3353##...lui $at,0
3357##...ori $at,$at,0xff
3361##...and $t1,$t1,$at
3364#    b skipPrintStr2
3368:skipPrintStr1:
3368#    and $t1,0x7ffffff
3369##...lui $at,2047
3373##...ori $at,$at,0xffff
3377##...and $t1,$t1,$at
3380:skipPrintStr2:    
3380#    sll $t1,$t1,2
3384#    subu $t1,$t0,$t1 # first word in string
3388#    lw $t0,4($t0) # negative of string-length
3392#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
3396#    beq $t0,$t1,donePrintStr
3400:  psLoop:
3400#    lb $a0,($t1) # next byte
3404#    li $v0,11 # code for printing char
3408#        syscall # print the char
3412#    addu $t1,$t1,1 # go to next char
3416#    blt $t1,$t0,psLoop
3417##...slt $at,$t1,$t0
3421##...bne $at,$zero,3400

3424:  donePrintStr:

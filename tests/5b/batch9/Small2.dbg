########################################################
# str.substring(n, k) - library method (class String)
# takes a substring of a string: Java: str.substring(n, k)
# - parameters after pushing RA:
#   - ($sp) - k: one beyond index of last char in subrange
#   - 4($sp) - GC tag
#   - 8($sp) - n: index of first char in subrange
#   - 12($sp) - GC tag
#   - 16($sp) - old this pointer
# - return value:
#  - $t0 - substring
########################################################
3472:mth_substring_String:

    # save $ra by pushing onto stack
3472#    subu $sp,$sp,4
3476#    sw $ra,($sp)

    # get string from this, we probably don't need the null check.
3480#    move $t0,$s2
3484#    beq $t0,$zero,nullPtrException

    # get both indices and string length, and ensure that
    #   0 <= n <= k <= length
3488#    lw $t0,-4($t0) # negative of string length
3492#    subu $t0,$zero,$t0 # string length
3496#    lw $t1,4($sp) # k
3500#    lw $t2,12($sp) # n
3504#    bgt $zero,$t2,strIndexOutOfBounds
3505##...slt $at,$t2,$zero
3509##...bne $at,$zero,5432
3512#    bgt $t2,$t1,strIndexOutOfBounds
3513##...slt $at,$t1,$t2
3517##...bne $at,$zero,5432
3520#    bgt $t1,$t0,strIndexOutOfBounds
3521##...slt $at,$t0,$t1
3525##...bne $at,$zero,5432

    # allocate memory
3528#    subu $s6,$t1,$t2 # # chars in target-string
3532#    addu $s6,$s6,7 # account for extra "class" (4) word + 3 to round up
3536#    srl $s6,$s6,2 # convert bytes-count to word-count
3540#    move $s7,$zero # (no object-bytes in string)
3544#    jal newObject

    # store "String" tag in object-type field
3548#    la $t0,CLASS_String
3552#    sw $t0,-12($s7)
    
    # mask off hash bits, if needed
3556#    lw $t4,-8($s7) # data words in source string
3560#    bge $t4,$zero,skipMask_substring # don't strip hash code if not there
3561##...slt $at,$t4,$zero
3565##...beq $at,$zero,3584
3568#    and $t4,0xff # mask off object's hash value ...
3569##...lui $at,0
3573##...ori $at,$at,0xff
3577##...and $t4,$t4,$at
3580#    sw $t4,-8($s7) # ... and store back into -8 header-word
3584:skipMask_substring:

    # store negative of count (=n-k) into object-length header-word
    # indicies have changed, because newObject is on stack
3584#    lw $t1,8($sp) # k
3588#    lw $t2,16($sp) # n
3592#    subu $t0,$t2,$t1 # value to store
3596#    sw $t0,-4($s7) # store value
    
3600#    move $t3,$s2 # source string pointer
    
    # skip byte-copy loop if length is zero
3604#    beq $zero,$t0,doneSubCopyzz

    # get pointers set up in preparation for copy
3608#    lw $t4,-8($t3) # data words in source string
3612#    sll $t4,$t4,2 # data bytes in source string (incl. padding)
3616#    subu $t3,$t3,$t4 # addr. of first data word of source string (+8)
3620#    addu $t3,$t3,$t2 # addr. of first source data byte to be copied (+8)
3624#    subu $t1,$t3,$t0 # addr. beyond last source data byte to be copied (+8)
3628#    lw $t2,-8($s7)   # data words in target string
3632#    sll $t2,$t2,2    # data bytes in target string
3636#    subu $t2,$s7,$t2 # addr. of first target data byte (+8)
    
    ############################################
    # at this point:
    # - we know that the string has a positive length
    # - $t3 contains 8 + address of the first source-byte
    # - $t1 contains 8 + limit-address of the first source-byte
    # - $t2 contains 8 + address first target byte
    ############################################

    # copy the bytes from source to target
3640:  subCopyLoopzz:
3640#    lb $t4,-8($t3)
3644#    sb $t4,-8($t2)
3648#    addu $t2,$t2,1
3652#    addu $t3,$t3,1
3656#    blt $t3,$t1,subCopyLoopzz
3657##...slt $at,$t3,$t1
3661##...bne $at,$zero,3640
    
3664:  doneSubCopyzz:
    # restore return address, store return value, pop stack
3664#    lw $ra,4($sp) # restore $ra
3668#    addu $sp,$sp,8 # pop ra, and allocated newObject
3672#    move $t0, $s7 # we're returning the string we got back
                  # from newObject
    
    # return
3676#    jr $ra

########################################################
# length() - library method (class String)
# returns length of a string: Java: str.length()
# - parameters:
#   - ($sp) - old this pointer
# - return-value:
#   - $t0 - length of string
########################################################
3680:mth_length_String:

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
5228:vm_init:

    # mark bottom of stack
5228#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
5232#    move $s2,$zero

    #set up the "five" register
5236#    li $s5,5

5240#    la $s3,seg0_start
5244#    la $s4,seg0_end
5245##...lui $s4,16
5249##...addiu $s4,$s4,6024
    
    # return
5252#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5256:divide:
    # get parameters; abort if divisor zero
5256#    lw $t0,($sp)
5260#    lw $t1,8($sp)
5264#    beq $t0,$zero,divByZeroError
    
    # perform division
5268#    div $t1,$t0
5272#    mflo $t0

    # store result, adjust stack and return
5276#    addu $sp,$sp,8 # adjust stack
5280#    sw $t0,($sp) # store result
5284#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
5288:remainder:
    # get parameters; abort if divisor zero
5288#    lw $t0,($sp)
5292#    lw $t1,8($sp)
5296#    beq $t0,$zero,divByZeroError
    
    # perform division
5300#    div $t1,$t0
5304#    mfhi $t0

    # store result, adjust stack and return
5308#    addu $sp,$sp,8 # adjust stack
5312#    sw $t0,($sp) # store result
5316#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
5320:checkCast:
    # get object, allow immediately if null
5320#    lw $t2,($sp)
5324#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
5328#    lw $t2,-12($t2) # vtable address
5332#    bge $t2,$t1,castException
5333##...slt $at,$t2,$t1
5337##...beq $at,$zero,5472
5340#    blt $t2,$t0,castException
5341##...slt $at,$t2,$t0
5345##...bne $at,$zero,5472
    
    # return, leaving object unchanged on stack
5348:  checkCastReturn:    
5348#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
5352:instanceOf:
    # get object, go return false if null
5352#    lw $t2,($sp)
5356#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
5360#    lw $t2,-12($t2) # vtable address
5364#    sge $t0,$t2,$t0 # are we >= the lower limit?
5365##...slt $t0,$t2,$t0
5369##...xori $t0,$t0,0x1
5372#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
5376#    and $t2,$t0,$t1
5380#    sw $t2,($sp)
5384:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
5384#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

5388:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
5388#    li $v0,4 # syscall-code for print-string
5392#    syscall
5396:exit:
    # print termination message
5396#    li $v0,4 # syscall-code for print-string
5400#    la $a0,exitString
5404#    syscall

    # terminate execution
5408#    li $v0,10 #syscall-code for "exit"
5412#    syscall

5416:outOfHeapMemory:
5416#    la $a0,heapMemoryMsg
5420#    j exitError
5424:divByZeroError:
5424#    la $a0,divByZeroMsg
5428#    j exitError
5432:strIndexOutOfBounds:
5432#    la $a0,strIndexOutOfBoundsMsg
5436#    j exitError
5440:arrayIndexOutOfBounds:
5440#    la $a0,arrayIndexOutOfBoundsMsg
5444#    j exitError
5448:arraySizeOutOfBounds:
5448#    la $a0,arraySizeOutOfBoundsMsg
5452#    j exitError
5456:nullPtrException:
5456#    la $a0,nullPtrExceptionMsg
5460#    j exitError
5464:badIntegerFormat:
5464#    la $a0,badIntegerFormatMsg
5468#    j exitError
5472:castException:
5472#    la $a0,castExceptionMsg
5476#    j exitError
############## data section ################
    .data
5660:hexChars:
    .ascii "0123456789abcdef"
    .align 2
5676:cur_seg:
    .word 0

5680:lastCharRead:
    .word -2 # -2 => no buffered character
5684:prevHashConstant:
    .word 0x2785173c
5688:gcCount:
    .word 0

5692:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
5719:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
5742:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
5777:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
5811:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
5844:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
5875:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
5923:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
5944:gcMsg: 
      .asciiz "\nGC!\n"
5950:gcCountMsg: 
      .asciiz "Number of garbage collections: "

5982:nullStr:
    .asciiz "null"
5987:trueString:
    .asciiz "true"
5992:falseString:
    .asciiz "false"
5998:exitString:
    .ascii "Program terminated."
    #### "falls through" here
6017:newlineString:
    .asciiz "\n"
    
    .align 2
6020:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

6024:seg0_start:
    .space 0x100000
1054600:seg0_end:
1054600:seg1_start:
    .space 0x100000
2103176:seg1_end:

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2376:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
2376#    lw $t0,-8($s2) # get word with hash bits from this
2380#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
2384#    addu $t0,$t1

2388#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2392:mth_equals_Object:
2392#    move $t0,$s2 # first pointer (this)
2396#    lw $t1,($sp) # second pointer
2400#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
2401##...subu $at,$t0,$t1
2405##...sltiu $t0,$at,1

2408#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
2412:mth_hashCode_String:
2412#    move $t0,$s2 # put this pointer in t0

2416#    li $t2,0 # current hash value
2420#    lw $t1,-4($t0) # negative of number of characters in string
2424#    beq $t1,$zero,done_hashCode_String # if zero length => done
2428#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
2432#    and $t0,0xfffffffc # adjust for padding
2433##...lui $at,65535
2437##...ori $at,$at,0xfffc
2441##...and $t0,$t0,$at
2444#    subu $t1,$t0,$t1 # address at end of string +12
2448:loop_hashCode_String:    
2448#    sll $t4,$t2,5 # multiply by 32
2452#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
2456#    lbu $t3,-12($t0) # current character
2460#    addu $t2,$t3 # add in current character
2464#    addu $t0,1 # go to next character's address
2468#    bne $t0,$t1,loop_hashCode_String # loop back if more
2472:done_hashCode_String:    

    # push int on stack
2472#    move $t0, $t2 # put $t2 in return slot
2476#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
2480:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
2480#    subu $sp,4
2484#    sw $ra,($sp)
    
    # get hash value
2488#    lw $t2,-12($s2) # vtable address
2492#    lw $t0,($t2) # method address
2496#    jalr $t0
2500#    subu $sp,8 # push result (int in $t0) on stack
2504#    sw $s5,4($sp)
2508#    sw $t0,($sp)

    # compute print-size of hash value
2512#    li $t0, 1
2516#    lw $t1, ($sp)
2520#    srl $t1,$t1,4
2524#    beq $t1,$zero,toString_skip_loop
2528:toString_loop_top:
2528#    addu $t0,1
2532#    srl $t1,$t1,4
2536#    bne $t1,$zero,toString_loop_top
2540:toString_skip_loop:
2540#    subu $sp,8
2544#    sw $s5,4($sp)
2548#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
2552#    lw $t2,-12($s2) # vtable address
2556#    move $t0,$t2
2560:toString_checkTagBit:
2560#    subu $t0,1
2564#    lb $t1,($t0)
2568#    and $t1,0x80
2569##...lui $at,0
2573##...ori $at,$at,0x80
2577##...and $t1,$t1,$at
2580#    beq $t1,$zero,toString_checkTagBit
2584#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
2588#    subu $sp,8
2592#    sw $t1,($sp)
2596#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
2600#    move $s7,$zero # -4 offset header word
2604#    lw $t4,8($sp) # bytes for hash value
2608#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
2612#    addu $t4,8
2616#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
2620#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

2624#    li $t0,CLASS_String # store string vtable address into ...
2628#    sw $t0,-12($s7) # ... -12 offset in object header
2632#    lw $t2,-12($s2) # our object's vtable address
2636#    lw $t5,4($sp) # number characters in prefix
2640#    lw $t1,12($sp) # number of characters in hashcode
2644#    addu $t3,$t1,$t5 # number of characters in string ...
2648#    addu $t3,1 # ... including the '@' character
2652#    subu $t0,$zero,$t3 # store negated length into ...
2656#    sw $t0,-4($s7) # ... -4 offset header word
2660#    lw $t0,-8($s7) # get -8 offset header-word
2664#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
2665##...slt $at,$t0,$zero
2669##...beq $at,$zero,2688
2672#    and $t0,0xff # mask off object's hash value ...
2673##...lui $at,0
2677##...ori $at,$at,0xff
2681##...and $t0,$t0,$at
2684#    sw $t0,-8($s7) # ... and store back into -8 header-word
2688:skipMask_toString:
2688#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
2692#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
2696#    subu $t4,$t2,$t5
2700:toString_copyLoop:    
2700#    lb $t3,($t4)
2704#    and $t3,0x7f # mask off sign bit (in case first word)
2705##...lui $at,0
2709##...ori $at,$at,0x7f
2713##...and $t3,$t3,$at
2716#    sb $t3,-8($t0)
2720#    addu $t4,1
2724#    addu $t0,1
2728#    blt $t4,$t2,toString_copyLoop
2729##...slt $at,$t4,$t2
2733##...bne $at,$zero,2700

    # copy the '@' sign
2736#    li $t3,'@'
2740#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
2744#    addu $t2,$t0,$t1 # address of last byte in string to store +8
2748#    lw $t3,20($sp) # hash code to print
2752:toString_hashCopyLoop:
2752#    and $t4,$t3,0xf
2756#    srl $t3,4
2760#    lb $t4,hexChars($t4)
2764#    sb $t4,-8($t2)
2768#    subu $t2,$t2,1
2772#    bgt $t2,$t0,toString_hashCopyLoop
2773##...slt $at,$t0,$t2
2777##...bne $at,$zero,2752

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
2780#    addu $sp,28
2784#    lw $ra,($sp)
2788#    addu $sp,4
2792#    move $t0, $s7 # return string we created
2796#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
2800:mth_equals_String:
    
    # quick test for obvious false
2800#    lw $t0,($sp) # second parameter
2804#    beq $t0,$zero,goEsFalse # go return false if null
2808#    lw $t1,-12($t0) # vtable pointer
2812#    la $t2,CLASS_String # string vtable pointer
2816#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
2820#    subu $sp,12
2824#    sw $ra,8($sp)
2828#    sw $s2,4($sp)
2832#    sw $t0,($sp)
2836#    jal mth_compareTo_String
2840#    lw $s2, 4($sp) #restore this pointer and pop parameters
2844#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
2848#    seq $t0,$t0,$zero
2849##...subu $at,$t0,$zero
2853##...sltiu $t0,$at,1

    # pop return address and return $t0
2856#    lw $ra,($sp)
2860#    addu $sp,4

2864#    jr $ra # return
    
2868:goEsFalse:
    # put 0 in $t0 and return
2868#    li $t0, 0
2872#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
2876:mth_toString_String:
    #we are a string, so return this.
2876#    move $t0, $s2
2880#    jr $ra

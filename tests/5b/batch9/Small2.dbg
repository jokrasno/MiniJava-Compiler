###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
2884:mth_readLine_Lib:
    
2884#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
2888#    sw $ra, 4($sp) # save $ra
2892#    move $t1,$sp # save "original" sp

2896:  doRead:

    # read the character
2896#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
2900#    subu $t2,$v0,13
2904#    bne $t2,$zero,notReturnRL
2908#    jal readLogicalChar
2912#    subu $t2,$v0,10 # check for newline
2916#    beq $t2,$zero,foundNewLine
2920#    sw $v0,lastCharRead # push back character into queue
2924#    j foundNewLine # go process the line

2928:  notReturnRL:

    # at this point, $v0 has our character

2928#    subu $t0,$v0,10
2932#    beq $t0,$zero,foundNewLine
2936#    blt $v0,$zero,foundEof
2937##...slt $at,$v0,$zero
2941##...bne $at,$zero,2956

    # we have a character, so push it onto stack
2944#    subu $sp,$sp,4
2948#    sw $v0,($sp)

    # loop back up to get next character
2952#    j doRead

2956:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
2956#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
2960#    li $s7, 0 # return-value: null
2964#    j rlReturn # return

2968:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
2968#    subu $t0,$t1,$sp # number of chars we read (times 4)
2972#    srl $s6,$t0,2 # number of words on stack with chars
2976#    subu $sp,$sp,4 # push char-count ...
2980#    sw $s6,($sp) # ... onto stack
2984#    addu $t2,$t0,5 # GC tag, incl. for count-word
2988#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
2992#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
2996#    srl $s6,$s6,2  # data words in object
3000#    move $s7,$zero # object words in object
3004#    jal newObject  # allocate space
    
    # store header words
3008#    la $t0,CLASS_String
3012#    sw $t0,-12($s7)# store class tag (String) into object
3016#    lw $t2,4($sp) # char-count
3020#    sll $t1,$t2,2 # 4 times number of chars
3024#    subu $t2,$zero,$t2 # negative of char-count
3028#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
3032#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
3036#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
3037##...slt $at,$t0,$zero
3041##...beq $at,$zero,3060
3044#    and $t0,0xff # mask off object's hash value ...
3045##...lui $at,0
3049##...ori $at,$at,0xff
3053##...and $t0,$t0,$at
3056#    sw $t0,-8($s7) # ... and store back into -8 header-word
3060:  skipMask_readLine:

3060#    sll $t0,$t0,2 # data bytes in object
3064#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
3068#    subu $t0,$t0,$t2 # place to store last character (plus 9)
3072#    addu $sp,$sp,8 # pop redundant object-pointer and count
3076#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

3080#    beq $sp,$t1,rlReturn
3084:  charCopyLoop:
3084#    lw $t2,($sp)
3088#    sb $t2,-9($t0)
3092#    addu $sp,$sp,4
3096#    subu $t0,$t0,1
3100#    bne $sp,$t1,charCopyLoop
3104:  rlReturn:

3104#    lw $ra, 4($sp)
3108#    addu $sp, 8   # pop $ra and pointless word off stack
3112#    move $t0, $s7 # return string we allocated in $s7
3116#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3120:mth_readInt_Lib:

    # save $ra by pushing onto stack
3120#    subu $sp,$sp,4
3124#    sw $ra,($sp)

3128:  riSkipWhiteLoop:
    # read a character
3128#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
3132#    subu $t0,$v0,32
3136#    bgt $t0,$zero,nonWhite
3137##...slt $at,$zero,$t0
3141##...bne $at,$zero,3184
3144#    beq $t0,$zero,riSkipWhiteLoop # start over if space
3148#    subu $t0,$v0,10
3152#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
3156#    subu $t0,$v0,9
3160#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
3164#    subu $t0,$v0,13
3168#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
3172#    subu $t0,$v0,12
3176#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
3180#    j badIntegerFormat # illegal integer char: abort program

3184:  nonWhite:
3184#    subu $t0,$v0,'-'
3188#    li $t4,1 # final multiplier
3192#    bne $t0,$zero,helpReadInt # go read
3196#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
3200#    jal readLogicalChar

3204:  helpReadInt:
3204#    li $t2,10
3208#    subu $t1,$v0,'0' # convert digit to 0-9 value
3212#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
3213##...sltu $at,$t1,$t2
3217##...beq $at,$zero,5464
3220#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

3224:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

3224#    jal readLogicalChar # read next character
3228#    subu $t1,$v0,'0' # convert digit to 0-9 value
3232#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
3233##...sltu $at,$t1,$t2
3237##...beq $at,$zero,3256

3240#    mul $t3,$t3,$t2 # multiply old value by 10
3241##...mult $t3,$t2
3245##...mflo $t3
3248#    addu $t3,$t3,$t1 # add in value of new digit
3252#    j digitLoop

3256:  doneDigitLoop:

    # "push back" unused character into queue
3256#    sw $v0,lastCharRead

    # restore return address
3260#    lw $ra,($sp)
3264#    addu $sp, 4

    # multiply by sign and put return value in $t0
3268#    mult $t3,$t4 # multiply to account for poss. minus sign
3272#    mflo $t3
3276#    move $t0, $t3
    
    # return
3280#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
3284:mth_readChar_Lib:

    # save $ra by pushing onto stack
3284#    subu $sp,$sp,4
3288#    sw $ra,($sp)

      # read the character
3292#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
3296#    lw $ra,($sp)
3300#    addu $sp, 4
3304#    move $t0, $v0

    # return
3308#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
3312:mth_printStr_Lib:
    # check for null, printing "(null)", if so
3312#    lw $t0,($sp)
3316#    bne $t0,$zero,psNotNull

    # print "(null)"
3320#    la $a0,nullStr
3324#    li $v0,4
3328#    syscall
3332#    j donePrintStr
    
3336:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
3336#    subu $t0,$t0,8
3340#    lw $t1,($t0) # number of data words, but needs modification
3344#    blt $t1,$zero,skipPrintStr1

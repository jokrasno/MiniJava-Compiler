3796#    lw $t3,-4($t1) # negative length of first object
3800#    addu $t4,$t2,$t3 # sum of negative lengths
3804#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object

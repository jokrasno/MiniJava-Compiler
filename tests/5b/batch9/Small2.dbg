    # is their sum divided by 4 (rounded up) plus 1
3712#    lw $t0,-4($t0) # negative size of second object
3716#    lw $t1,-4($t1) # negative size of first object
3720#    addu $s6,$t0,$t1 # sum of negative sizes
3724#    sra $s6,$s6,2 # negative word-size of char part
3728#    subu $s6,$zero,$s6 # word size of char part
3732#    addu $s6,$s6,1 # data word size, including v-table word
3736#    move $s7,$zero
3740#    jal newObject

    # store String vtable address in vtable address field
3744#    la $t0,CLASS_String
3748#    sw $t0,-12($s7)
        
    # mask off hash bits, if needed
3752#    lw $t4,-8($s7) # # data words in source string
3756#    bge $t4,$zero,skipMask_concat # don't strip hash code if not there
3757##...slt $at,$t4,$zero
3761##...beq $at,$zero,3780
3764#    and $t4,0xff # mask off object's hash value ...
3765##...lui $at,0
3769##...ori $at,$at,0xff
3773##...and $t4,$t4,$at
3776#    sw $t4,-8($s7) # ... and store back into -8 header-word
3780:skipMask_concat:

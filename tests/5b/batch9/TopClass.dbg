    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
3352#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3353##...slt $at,$t8,$zero
3357##...beq $at,$zero,3372
3360#    and $t8,0xff # mask off hash bits
3361##...lui $at,0
3365##...ori $at,$at,0xff
3369##...and $t8,$t8,$at

3372:  gcSkip5:
3372#    sll $t8,$t8,2 # bytes in negative-offset portion ...
3376#    addu $t8,$t8,8 # ... add in bytes for header-words
3380#    subu $t4,$t1,$t8 # address of first word of source object
3384#    lw $t3,-4($t1) # # words in positive-offset portion
3388#    bge $t3,$zero,gcNoNeg
3389##...slt $at,$t3,$zero
3393##...beq $at,$zero,3400
3396#    move $t3,$zero # negative treated as zero
3400:  gcNoNeg:
3400#    sll $t3,$t3,2 # bytes in negative-offset portion
3404#    addu $t3,$t3,$t1 # address one word past last word of source

3408#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
3412#    lw $s0,($t4)
3416#    lw $t9,-8($t1)
3420#    sw $t9,($t4)
3424#    sw $s0,-8($t1)

    # copy all source bytes to the target
3428:  gCinnerCopy2:
3428#    lw $s0,($t4)
3432#    sw $s0,($s3)
3436#    addu $t4,$t4,4
3440#    addu $s3,$s3,4
3444#    bltu $t4,$t3,gCinnerCopy2
3445##...sltu $at,$t4,$t3
3449##...bne $at,$zero,3428

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
3452#    sw $zero,-8($t1) # 0 in first header-slot
3456#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
3460#    sw $t8,($t0)

3464:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
3464#    addu $t0,$t0,4
3468#    bltu $t0,$s1,gcNextPointerInObject
3469##...sltu $at,$t0,$s1
3473##...bne $at,$zero,3312

3476:  gcTestIterDone2:
3476#    bltu $t0,$s3,gcHeapCopyLoop
3477##...sltu $at,$t0,$s3
3481##...bne $at,$zero,3196

    ###### end outer loop to copy all non-stack-direct objects ######

3484:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
3484#    lw $s2,($sp)
3488#    addu $sp,$sp,4

    # mark us as having already GC'd
3492#    move $t5,$s5

    # go try and allocate again
3496#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3500:vm_init:

    # mark bottom of stack
3500#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3504#    move $s2,$zero

    #set up the "five" register
3508#    li $s5,5

3512#    la $s3,seg0_start
3516#    la $s4,seg0_end
3517##...lui $s4,16
3521##...addiu $s4,$s4,4448
    
    # return
3524#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3528:divide:
    # get parameters; abort if divisor zero
3528#    lw $t0,($sp)
3532#    lw $t1,8($sp)
3536#    beq $t0,$zero,divByZeroError
    
    # perform division
3540#    div $t1,$t0
3544#    mflo $t0

    # store result, adjust stack and return
3548#    addu $sp,$sp,8 # adjust stack
3552#    sw $t0,($sp) # store result
3556#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3560:remainder:
    # get parameters; abort if divisor zero
3560#    lw $t0,($sp)
3564#    lw $t1,8($sp)
3568#    beq $t0,$zero,divByZeroError
    
    # perform division
3572#    div $t1,$t0
3576#    mfhi $t0

    # store result, adjust stack and return
3580#    addu $sp,$sp,8 # adjust stack
3584#    sw $t0,($sp) # store result
3588#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3592:checkCast:
    # get object, allow immediately if null
3592#    lw $t2,($sp)
3596#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3600#    lw $t2,-12($t2) # vtable address
3604#    bge $t2,$t1,castException
3605##...slt $at,$t2,$t1
3609##...beq $at,$zero,3744
3612#    blt $t2,$t0,castException
3613##...slt $at,$t2,$t0
3617##...bne $at,$zero,3744
    
    # return, leaving object unchanged on stack
3620:  checkCastReturn:    
3620#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3624:instanceOf:
    # get object, go return false if null
3624#    lw $t2,($sp)
3628#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3632#    lw $t2,-12($t2) # vtable address
3636#    sge $t0,$t2,$t0 # are we >= the lower limit?
3637##...slt $t0,$t2,$t0
3641##...xori $t0,$t0,0x1
3644#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3648#    and $t2,$t0,$t1
3652#    sw $t2,($sp)
3656:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3656#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3660:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3660#    li $v0,4 # syscall-code for print-string
3664#    syscall
3668:exit:
    # print termination message
3668#    li $v0,4 # syscall-code for print-string
3672#    la $a0,exitString
3676#    syscall

    # terminate execution
3680#    li $v0,10 #syscall-code for "exit"
3684#    syscall

3688:outOfHeapMemory:
3688#    la $a0,heapMemoryMsg
3692#    j exitError
3696:divByZeroError:
3696#    la $a0,divByZeroMsg
3700#    j exitError
3704:strIndexOutOfBounds:
3704#    la $a0,strIndexOutOfBoundsMsg
3708#    j exitError
3712:arrayIndexOutOfBounds:
3712#    la $a0,arrayIndexOutOfBoundsMsg
3716#    j exitError
3720:arraySizeOutOfBounds:
3720#    la $a0,arraySizeOutOfBoundsMsg
3724#    j exitError
3728:nullPtrException:
3728#    la $a0,nullPtrExceptionMsg
3732#    j exitError
3736:badIntegerFormat:
3736#    la $a0,badIntegerFormatMsg
3740#    j exitError
3744:castException:
3744#    la $a0,castExceptionMsg
3748#    j exitError
############## data section ################
    .data
4084:hexChars:
    .ascii "0123456789abcdef"
    .align 2
4100:cur_seg:
    .word 0

4104:lastCharRead:
    .word -2 # -2 => no buffered character
4108:prevHashConstant:
    .word 0x2785173c
4112:gcCount:
    .word 0

4116:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
4143:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
4166:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
4201:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
4235:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
4268:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4299:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4347:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4368:gcMsg: 
      .asciiz "\nGC!\n"
4374:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4406:nullStr:
    .asciiz "null"
4411:trueString:
    .asciiz "true"
4416:falseString:
    .asciiz "false"
4422:exitString:
    .ascii "Program terminated."
    #### "falls through" here
4441:newlineString:
    .asciiz "\n"
    
    .align 2
4444:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4448:seg0_start:
    .space 0x100000
1053024:seg0_end:
1053024:seg1_start:
    .space 0x100000
2101600:seg1_end:

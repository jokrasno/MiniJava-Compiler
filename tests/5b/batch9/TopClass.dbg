1352#    beq $sp,$t1,rlReturn
1356:  charCopyLoop:
1356#    lw $t2,($sp)
1360#    sb $t2,-9($t0)
1364#    addu $sp,$sp,4
1368#    subu $t0,$t0,1
1372#    bne $sp,$t1,charCopyLoop
1376:  rlReturn:

1376#    lw $ra, 4($sp)
1380#    addu $sp, 8   # pop $ra and pointless word off stack
1384#    move $t0, $s7 # return string we allocated in $s7
1388#    jr $ra

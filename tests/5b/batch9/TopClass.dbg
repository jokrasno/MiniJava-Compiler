##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
648:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
648#    lw $t0,-8($s2) # get word with hash bits from this
652#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
656#    addu $t0,$t1

660#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
664:mth_equals_Object:
664#    move $t0,$s2 # first pointer (this)
668#    lw $t1,($sp) # second pointer
672#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
673##...subu $at,$t0,$t1
677##...sltiu $t0,$at,1

680#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
684:mth_hashCode_String:
684#    move $t0,$s2 # put this pointer in t0

688#    li $t2,0 # current hash value
692#    lw $t1,-4($t0) # negative of number of characters in string
696#    beq $t1,$zero,done_hashCode_String # if zero length => done
700#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
704#    and $t0,0xfffffffc # adjust for padding
705##...lui $at,65535
709##...ori $at,$at,0xfffc
713##...and $t0,$t0,$at
716#    subu $t1,$t0,$t1 # address at end of string +12
720:loop_hashCode_String:    
720#    sll $t4,$t2,5 # multiply by 32
724#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
728#    lbu $t3,-12($t0) # current character
732#    addu $t2,$t3 # add in current character
736#    addu $t0,1 # go to next character's address
740#    bne $t0,$t1,loop_hashCode_String # loop back if more
744:done_hashCode_String:    

    # push int on stack
744#    move $t0, $t2 # put $t2 in return slot
748#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
752:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
752#    subu $sp,4
756#    sw $ra,($sp)
    
    # get hash value
760#    lw $t2,-12($s2) # vtable address
764#    lw $t0,($t2) # method address
768#    jalr $t0
772#    subu $sp,8 # push result (int in $t0) on stack
776#    sw $s5,4($sp)
780#    sw $t0,($sp)

    # compute print-size of hash value
784#    li $t0, 1
788#    lw $t1, ($sp)
792#    srl $t1,$t1,4
796#    beq $t1,$zero,toString_skip_loop
800:toString_loop_top:
800#    addu $t0,1
804#    srl $t1,$t1,4
808#    bne $t1,$zero,toString_loop_top
812:toString_skip_loop:
812#    subu $sp,8
816#    sw $s5,4($sp)
820#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
824#    lw $t2,-12($s2) # vtable address
828#    move $t0,$t2
832:toString_checkTagBit:
832#    subu $t0,1
836#    lb $t1,($t0)
840#    and $t1,0x80
841##...lui $at,0
845##...ori $at,$at,0x80
849##...and $t1,$t1,$at
852#    beq $t1,$zero,toString_checkTagBit
856#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
860#    subu $sp,8
864#    sw $t1,($sp)
868#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
872#    move $s7,$zero # -4 offset header word
876#    lw $t4,8($sp) # bytes for hash value
880#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
884#    addu $t4,8
888#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
892#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

896#    li $t0,CLASS_String # store string vtable address into ...
900#    sw $t0,-12($s7) # ... -12 offset in object header
904#    lw $t2,-12($s2) # our object's vtable address
908#    lw $t5,4($sp) # number characters in prefix
912#    lw $t1,12($sp) # number of characters in hashcode
916#    addu $t3,$t1,$t5 # number of characters in string ...
920#    addu $t3,1 # ... including the '@' character
924#    subu $t0,$zero,$t3 # store negated length into ...
928#    sw $t0,-4($s7) # ... -4 offset header word
932#    lw $t0,-8($s7) # get -8 offset header-word
936#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
937##...slt $at,$t0,$zero
941##...beq $at,$zero,960
944#    and $t0,0xff # mask off object's hash value ...
945##...lui $at,0
949##...ori $at,$at,0xff
953##...and $t0,$t0,$at
956#    sw $t0,-8($s7) # ... and store back into -8 header-word
960:skipMask_toString:
960#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
964#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
968#    subu $t4,$t2,$t5
972:toString_copyLoop:    
972#    lb $t3,($t4)
976#    and $t3,0x7f # mask off sign bit (in case first word)
977##...lui $at,0
981##...ori $at,$at,0x7f
985##...and $t3,$t3,$at
988#    sb $t3,-8($t0)
992#    addu $t4,1
996#    addu $t0,1
1000#    blt $t4,$t2,toString_copyLoop
1001##...slt $at,$t4,$t2
1005##...bne $at,$zero,972

    # copy the '@' sign
1008#    li $t3,'@'
1012#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
1016#    addu $t2,$t0,$t1 # address of last byte in string to store +8
1020#    lw $t3,20($sp) # hash code to print
1024:toString_hashCopyLoop:
1024#    and $t4,$t3,0xf
1028#    srl $t3,4
1032#    lb $t4,hexChars($t4)
1036#    sb $t4,-8($t2)
1040#    subu $t2,$t2,1
1044#    bgt $t2,$t0,toString_hashCopyLoop
1045##...slt $at,$t0,$t2
1049##...bne $at,$zero,1024

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
1052#    addu $sp,28
1056#    lw $ra,($sp)
1060#    addu $sp,4
1064#    move $t0, $s7 # return string we created
1068#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
1072:mth_equals_String:
    
    # quick test for obvious false
1072#    lw $t0,($sp) # second parameter
1076#    beq $t0,$zero,goEsFalse # go return false if null
1080#    lw $t1,-12($t0) # vtable pointer
1084#    la $t2,CLASS_String # string vtable pointer
1088#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
1092#    subu $sp,12
1096#    sw $ra,8($sp)
1100#    sw $s2,4($sp)
1104#    sw $t0,($sp)
1108#    jal mth_compareTo_String
1112#    lw $s2, 4($sp) #restore this pointer and pop parameters
1116#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
1120#    seq $t0,$t0,$zero
1121##...subu $at,$t0,$zero
1125##...sltiu $t0,$at,1

    # pop return address and return $t0
1128#    lw $ra,($sp)
1132#    addu $sp,4

1136#    jr $ra # return
    
1140:goEsFalse:
    # put 0 in $t0 and return
1140#    li $t0, 0
1144#    jr $ra # return

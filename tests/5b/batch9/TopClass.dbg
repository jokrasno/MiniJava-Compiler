1485##...sltu $at,$t1,$t2
1489##...beq $at,$zero,3736
1492#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1496:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1496#    jal readLogicalChar # read next character
1500#    subu $t1,$v0,'0' # convert digit to 0-9 value
1504#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1505##...sltu $at,$t1,$t2
1509##...beq $at,$zero,1528

1512#    mul $t3,$t3,$t2 # multiply old value by 10
1513##...mult $t3,$t2
1517##...mflo $t3
1520#    addu $t3,$t3,$t1 # add in value of new digit
1524#    j digitLoop

1528:  doneDigitLoop:

    # "push back" unused character into queue

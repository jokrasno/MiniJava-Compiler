1416#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1420#    subu $t0,$v0,10
1424#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1428#    subu $t0,$v0,9
1432#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1436#    subu $t0,$v0,13
1440#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1444#    subu $t0,$v0,12
1448#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1452#    j badIntegerFormat # illegal integer char: abort program

1456:  nonWhite:
1456#    subu $t0,$v0,'-'
1460#    li $t4,1 # final multiplier
1464#    bne $t0,$zero,helpReadInt # go read
1468#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1472#    jal readLogicalChar

1476:  helpReadInt:
1476#    li $t2,10
1480#    subu $t1,$v0,'0' # convert digit to 0-9 value

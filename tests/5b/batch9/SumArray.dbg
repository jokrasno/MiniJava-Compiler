###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
1624:mth_readLine_Lib:
    
1624#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
1628#    sw $ra, 4($sp) # save $ra
1632#    move $t1,$sp # save "original" sp

1636:  doRead:

    # read the character
1636#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
1640#    subu $t2,$v0,13
1644#    bne $t2,$zero,notReturnRL
1648#    jal readLogicalChar
1652#    subu $t2,$v0,10 # check for newline
1656#    beq $t2,$zero,foundNewLine
1660#    sw $v0,lastCharRead # push back character into queue
1664#    j foundNewLine # go process the line

1668:  notReturnRL:

    # at this point, $v0 has our character

1668#    subu $t0,$v0,10
1672#    beq $t0,$zero,foundNewLine
1676#    blt $v0,$zero,foundEof
1677##...slt $at,$v0,$zero
1681##...bne $at,$zero,1696

    # we have a character, so push it onto stack
1684#    subu $sp,$sp,4
1688#    sw $v0,($sp)

    # loop back up to get next character
1692#    j doRead

1696:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1696#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1700#    li $s7, 0 # return-value: null
1704#    j rlReturn # return

1708:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1708#    subu $t0,$t1,$sp # number of chars we read (times 4)
1712#    srl $s6,$t0,2 # number of words on stack with chars
1716#    subu $sp,$sp,4 # push char-count ...
1720#    sw $s6,($sp) # ... onto stack
1724#    addu $t2,$t0,5 # GC tag, incl. for count-word
1728#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1732#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1736#    srl $s6,$s6,2  # data words in object
1740#    move $s7,$zero # object words in object
1744#    jal newObject  # allocate space
    
    # store header words
1748#    la $t0,CLASS_String
1752#    sw $t0,-12($s7)# store class tag (String) into object
1756#    lw $t2,4($sp) # char-count
1760#    sll $t1,$t2,2 # 4 times number of chars
1764#    subu $t2,$zero,$t2 # negative of char-count
1768#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1772#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1776#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1777##...slt $at,$t0,$zero
1781##...beq $at,$zero,1800
1784#    and $t0,0xff # mask off object's hash value ...
1785##...lui $at,0
1789##...ori $at,$at,0xff
1793##...and $t0,$t0,$at
1796#    sw $t0,-8($s7) # ... and store back into -8 header-word
1800:  skipMask_readLine:

1800#    sll $t0,$t0,2 # data bytes in object
1804#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1808#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1812#    addu $sp,$sp,8 # pop redundant object-pointer and count
1816#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1820#    beq $sp,$t1,rlReturn
1824:  charCopyLoop:
1824#    lw $t2,($sp)
1828#    sb $t2,-9($t0)
1832#    addu $sp,$sp,4
1836#    subu $t0,$t0,1
1840#    bne $sp,$t1,charCopyLoop
1844:  rlReturn:

1844#    lw $ra, 4($sp)
1848#    addu $sp, 8   # pop $ra and pointless word off stack
1852#    move $t0, $s7 # return string we allocated in $s7
1856#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1860:mth_readInt_Lib:

    # save $ra by pushing onto stack
1860#    subu $sp,$sp,4
1864#    sw $ra,($sp)

1868:  riSkipWhiteLoop:
    # read a character
1868#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1872#    subu $t0,$v0,32
1876#    bgt $t0,$zero,nonWhite
1877##...slt $at,$zero,$t0
1881##...bne $at,$zero,1924
1884#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1888#    subu $t0,$v0,10
1892#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1896#    subu $t0,$v0,9
1900#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1904#    subu $t0,$v0,13
1908#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1912#    subu $t0,$v0,12
1916#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1920#    j badIntegerFormat # illegal integer char: abort program

1924:  nonWhite:
1924#    subu $t0,$v0,'-'
1928#    li $t4,1 # final multiplier
1932#    bne $t0,$zero,helpReadInt # go read
1936#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1940#    jal readLogicalChar

1944:  helpReadInt:
1944#    li $t2,10
1948#    subu $t1,$v0,'0' # convert digit to 0-9 value
1952#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1953##...sltu $at,$t1,$t2
1957##...beq $at,$zero,4204
1960#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1964:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1964#    jal readLogicalChar # read next character
1968#    subu $t1,$v0,'0' # convert digit to 0-9 value
1972#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1973##...sltu $at,$t1,$t2
1977##...beq $at,$zero,1996

1980#    mul $t3,$t3,$t2 # multiply old value by 10
1981##...mult $t3,$t2
1985##...mflo $t3
1988#    addu $t3,$t3,$t1 # add in value of new digit
1992#    j digitLoop

1996:  doneDigitLoop:

    # "push back" unused character into queue
1996#    sw $v0,lastCharRead

    # restore return address
2000#    lw $ra,($sp)
2004#    addu $sp, 4

    # multiply by sign and put return value in $t0
2008#    mult $t3,$t4 # multiply to account for poss. minus sign
2012#    mflo $t3
2016#    move $t0, $t3
    
    # return
2020#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input
# - returns the integer that is the encoding of the character
# - returns -1 if end of file was encountered
# - parameter:
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
2024:mth_readChar_Lib:

    # save $ra by pushing onto stack
2024#    subu $sp,$sp,4
2028#    sw $ra,($sp)

      # read the character
2032#    jal readLogicalChar

    # restore return address; put value in $t0
    # replacing this-pointer saved return address
2036#    lw $ra,($sp)
2040#    addu $sp, 4
2044#    move $t0, $v0

    # return
2048#    jr $ra

########################################################
# printStr(str) - library method (class Lib)
# - prints string to standard output
# parameters:
#   - ($sp) - the string to print
#   - 4($sp) - old-this-pointer
########################################################
2052:mth_printStr_Lib:
    # check for null, printing "(null)", if so
2052#    lw $t0,($sp)
2056#    bne $t0,$zero,psNotNull

    # print "(null)"
2060#    la $a0,nullStr
2064#    li $v0,4
2068#    syscall
2072#    j donePrintStr
    
2076:  psNotNull:
    ##### we have a non-null string #####
    # this means that:
    # - number of data words in -8($t0):
    #   - if the sign bit is 1, the low 31 bits
    #   - if the sign bit is 0, the low 8 bits
    # - negative of number of characters in string is in -4($t0)
    # - string begins at $t0-8-(#dataWords*4), stored 1 char per byte
2076#    subu $t0,$t0,8
2080#    lw $t1,($t0) # number of data words, but needs modification
2084#    blt $t1,$zero,skipPrintStr1

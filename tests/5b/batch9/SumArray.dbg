2093##...lui $at,0
2097##...ori $at,$at,0xff
2101##...and $t1,$t1,$at
2104#    b skipPrintStr2
2108:skipPrintStr1:
2108#    and $t1,0x7ffffff
2109##...lui $at,2047
2113##...ori $at,$at,0xffff
2117##...and $t1,$t1,$at
2120:skipPrintStr2:    

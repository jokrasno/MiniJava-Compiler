2144#    li $v0,11 # code for printing char
2148#        syscall # print the char
2152#    addu $t1,$t1,1 # go to next char
2156#    blt $t1,$t0,psLoop
2157##...slt $at,$t1,$t0
2161##...bne $at,$zero,2140

2164:  donePrintStr:
2164#    jr $ra

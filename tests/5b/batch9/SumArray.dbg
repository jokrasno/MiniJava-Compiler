2124#    subu $t1,$t0,$t1 # first word in string
2128#    lw $t0,4($t0) # negative of string-length
2132#    subu $t0,$t1,$t0 # byte just beyond last char in string

    # print the chars in the string
2136#    beq $t0,$t1,donePrintStr
2140:  psLoop:

5917##...slt $at,$t3,$zero
5921##...beq $at,$zero,5928
5924#    move $t3,$zero
5928:  gcH2Neg1:
5928#    sll $t3,$t3,2
5932#    addu $t3,$t3,$t1 # address one word past last word of source

5936#    addu $t2,$s3,$t2 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object (i.e., the address just beyond the object's header)
    # - $t2 contains the pointer to the target object
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0-2
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger" in the target space
5940#    lw $s0,($t4)
5944#    lw $s1,-8($t1)
5948#    sw $s1,($t4)
5952#    sw $s0,-8($t1)
    
    # copy all source bytes to the target
5956:  gCinnerCopy1:
5956#    lw $s0,($t4)
5960#    sw $s0,($s3)
5964#    addu $t4,$t4,4
5968#    addu $s3,$s3,4
5972#    bltu $t4,$t3,gCinnerCopy1
5973##...sltu $at,$t4,$t3
5977##...bne $at,$zero,5956

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
5980#    sw $zero,-8($t1) # 0 in first header-slot
5984#    sw $t2,-4($t1) # forwarding pointer in second header-slot

    # update the stack slot with the address in the target space
5988#    sw $t2,4($t0)
5992#    lw $zero,-8($t2)
5996#    lw $zero,-4($t2)

    # go handle next stack slot (testing if done)
6000#    j gcTestIterDone1

6004:  gcBump:
    #### we have a GC tag.  Bytes to skip: tag value + 3.
6004#    subu $t0,$t0,$t1
6008#    subu $t0,$t0,3

6012:  gcTestIterDone1:
6012#    bgeu $t0,$sp,gcStackCopyLoop
6013##...sltu $at,$t0,$sp
6017##...beq $at,$zero,5828

    ###### end outer loop to copy all stack-direct objects ######

    #############################################################
    # We have finished processing the stack elements.  Now we need
    # to update elements in the heap itself. This may itself involve
    # moving additional objects
    #############################################################

    #########################################################
    # At this point:
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # We want to set things up so that in addition:
    # - $t0 is the "trailing finger", containing the address
    #   of the first slot in target space that we have yet
    #   to process.
    # Then during processing:
    # - $t1 will contain the contents of the heap slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # And when we're actually copying an object:
    # - $t2 will contain pointer to the target object
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - available for use: $s0
    ##########################################################

    # set $t0 to be at the beginning of target-space
6020#    lw $t1,cur_seg
6024#    la $t0,seg0_start
6028#    beq $t1,$zero,gcSkip4
6032#    la $t0,seg1_start
6033##...lui $t0,16
6037##...addiu $t0,$t0,7188


6040:  gcSkip4:

    # if there were no objects put into the heap during stack
    # processing, we're done, so go finish up
6040#    bgeu $t0,$s3,gcFinishUp
6041##...sltu $at,$t0,$s3
6045##...beq $at,$zero,6336

    ###### begin outer loop to copy all non-stack-direct objects ######

6048:  gcHeapCopyLoop:
    # get data count for object; swap header-word with first word
    # of object so that they're back in the right place
6048#    lw $t1,($t0) # (what will be) first header word for current object
6052#    move $t2,$t1 # number data bytes in object (poss. w/hash bits)
6056#    bge $t2,$zero,gcSkip4a # are there hash bits?
6057##...slt $at,$t2,$zero
6061##...beq $at,$zero,6076
6064#    and $t2,0xff # mask off hash bits
6065##...lui $at,0
6069##...ori $at,$at,0xff
6073##...and $t2,$t2,$at
6076:gcSkip4a:    
6076#    sll $t2,$t2,2 # # data bytes
6080#    addu $t2,$t2,8 # to skip header words
6084#    addu $t2,$t0,$t2 # pointer to new object
6088#    lw $t3,-8($t2) # word to swap
6092#    sw $t1,-8($t2) # store header word
6096#    sw $t3,($t0) # restore first word of object

    ################################################
    # at this point:
    # - $t2 contains the pointer to our new object
    ################################################

    # check if we have a data array
6100#    lw $t1,-12($t2) # vtable pointer
6104#    li $t0,dataArrayVTableStart # address of vtable for first data array
6108#    blt $t1,$t0,gcNotDataArray # if data array, no more xforming to do
6109##...slt $at,$t1,$t0
6113##...bne $at,$zero,6132

    # We have a vtable address that is a data array.
    # we need skip over it then loop back to do next object.
6116:  skipToNextObj:
6116#    lw $t1,-4($t2) # data words in (object position of) array
    #### note: we know that it's not a string, so the value will
    #### not be artificially negative
6120#    sll $t1,$t1,2 # convert to byte-count
6124#    addu $t0,$t2,$t1 # skip over object
6128#    j gcTestIterDone2 # go do next object, if any

    ###################################################
    # at this point:
    # - the object has been restored to normal status--that is, the
    #   word-swap has been done
    # - $t2 contains a pointer to the object
    ###################################################
    
6132:  gcNotDataArray:
6132#    lw $t3,-4($t2) # # object words (negative treated as zero)
6136#    bge $t3,$zero,gcH2Neg2
6137##...slt $at,$t3,$zero
6141##...beq $at,$zero,6148
6144#    move $t3,$zero
6148:  gcH2Neg2:
6148#    sll $t3,$t3,2 # # object bytes
6152#    move $t0,$t2 # address of first pointer in object
6156#    add $s1,$t2,$t3 # limit address for this object

    #####################################################
    # At this point, we have to "translate" all pointers,
    # starting at $t0 to (but not including) $s1
    #####################################################

    # if there are no pointer-slots (i.e., $t0=$s1), skip this
    # part
6160#    beq $t0,$s1,gcTestIterDone2
    
6164:  gcNextPointerInObject:
    # get pointer from object
6164#    lw $t1,($t0)

    # if value is out of range, and is therefore does not refer
    # to an object, just go loop back and do the next one
6168#    bleu $t1,$t6,gcGoNextPointerSlot
6169##...sltu $at,$t6,$t1
6173##...beq $at,$zero,6316
6176#    bgtu $t1,$t7,gcGoNextPointerSlot
6177##...sltu $at,$t7,$t1
6181##...bne $at,$zero,6316

    # if the object has already been moved, update the stack-value
    # via the forwarding pointer
6184#    lw $t8,-8($t1) # possible forwarding tag
6188#    bne $t8,$zero,gcNoForward2 # if not forwarding tag, go copy
6192#    lw $t8,-4($t1) # forwarding pointer: object's new address
6196#    sw $t8,($t0) # update pointer in object
6200#    j gcGoNextPointerSlot # do next iteration

6204:  gcNoForward2:
    #########################################################
    # we actually need to copy the object into the new space
    #########################################################

    #########################################################
    # At this point:
    # - $t0 contains the address of the heap-slot we're translating
    # - $t1 will contain the contents of the heap-slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $s3 contains the first unallocated address of the
    #   target space, which will also be the first address
    #   of the target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # Then during processing:
    # And when we're actually copying an object:
    # - $t3 will contain the limit address of the source object
    # - $t4 will contain the first address of the source object
    # - $s1 will contain the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $t8 will contain a pointer to the target object
    # - available for use: $s0, $t8, $t9
    ##########################################################

    # compute the amount of space that is needed
6204#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
6205##...slt $at,$t8,$zero
6209##...beq $at,$zero,6224
6212#    and $t8,0xff # mask off hash bits
6213##...lui $at,0
6217##...ori $at,$at,0xff
6221##...and $t8,$t8,$at

6224:  gcSkip5:
6224#    sll $t8,$t8,2 # bytes in negative-offset portion ...
6228#    addu $t8,$t8,8 # ... add in bytes for header-words
6232#    subu $t4,$t1,$t8 # address of first word of source object
6236#    lw $t3,-4($t1) # # words in positive-offset portion
6240#    bge $t3,$zero,gcNoNeg
6241##...slt $at,$t3,$zero
6245##...beq $at,$zero,6252
6248#    move $t3,$zero # negative treated as zero
6252:  gcNoNeg:
6252#    sll $t3,$t3,2 # bytes in negative-offset portion
6256#    addu $t3,$t3,$t1 # address one word past last word of source

6260#    addu $t8,$s3,$t8 # pointer to target object

    #########################################################
    # At this point:
    # - $t0 contains the address of the stack slot we'll
    #   process next
    # - $t1 contains the contents of the stack slot we're
    #   currently working on, which is a pointer to the source
    #   object
    # - $t2 will contains pointer to the object we're in the
    #   middle of translating
    # - $t3 contains the limit address of the source object
    # - $t4 contains the first address of the source object
    # - $t5 contains the value 0x80000000
    # - $t6 contains the first address of the source space
    # - $t7 contains the limit address of the source space
    # - $t8 contains the pointer to the target object
    # - $s1 contains the the limit address for the current
    #   object that tells where the pointers in the object end
    # - $s3 contains the first unallocated address of the
    #   target space, which is also the first address of the
    #   target object
    # - $s4 contains the limit address of the target space
    # - $s5 contains the value 5
    # - $s6-7 contain the original parameters to the call to
    #   'newObject'
    # - $sp contains the address of the top stack element
    # - available for use: $s0, $t9
    #########################################################

    # swap first header word and first data word so that header
        # can be found by "trailing finger"
6264#    lw $s0,($t4)
6268#    lw $t9,-8($t1)
6272#    sw $t9,($t4)
6276#    sw $s0,-8($t1)

    # copy all source bytes to the target
6280:  gCinnerCopy2:
6280#    lw $s0,($t4)
6284#    sw $s0,($s3)
6288#    addu $t4,$t4,4
6292#    addu $s3,$s3,4
6296#    bltu $t4,$t3,gCinnerCopy2
6297##...sltu $at,$t4,$t3
6301##...bne $at,$zero,6280

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
6304#    sw $zero,-8($t1) # 0 in first header-slot
6308#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
6312#    sw $t8,($t0)

6316:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
6316#    addu $t0,$t0,4
6320#    bltu $t0,$s1,gcNextPointerInObject
6321##...sltu $at,$t0,$s1
6325##...bne $at,$zero,6164

6328:  gcTestIterDone2:
6328#    bltu $t0,$s3,gcHeapCopyLoop
6329##...sltu $at,$t0,$s3
6333##...bne $at,$zero,6048

    ###### end outer loop to copy all non-stack-direct objects ######

6336:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
6336#    lw $s2,($sp)
6340#    addu $sp,$sp,4

    # mark us as having already GC'd
6344#    move $t5,$s5

    # go try and allocate again
6348#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
6352:vm_init:

    # mark bottom of stack
6352#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
6356#    move $s2,$zero

    #set up the "five" register
6360#    li $s5,5

6364#    la $s3,seg0_start
6368#    la $s4,seg0_end
6369##...lui $s4,16
6373##...addiu $s4,$s4,7188
    
    # return
6376#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
6380:divide:
    # get parameters; abort if divisor zero
6380#    lw $t0,($sp)
6384#    lw $t1,8($sp)
6388#    beq $t0,$zero,divByZeroError
    
    # perform division
6392#    div $t1,$t0
6396#    mflo $t0

    # store result, adjust stack and return
6400#    addu $sp,$sp,8 # adjust stack
6404#    sw $t0,($sp) # store result
6408#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
6412:remainder:
    # get parameters; abort if divisor zero
6412#    lw $t0,($sp)
6416#    lw $t1,8($sp)
6420#    beq $t0,$zero,divByZeroError
    
    # perform division
6424#    div $t1,$t0
6428#    mfhi $t0

    # store result, adjust stack and return
6432#    addu $sp,$sp,8 # adjust stack
6436#    sw $t0,($sp) # store result
6440#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
6444:checkCast:
    # get object, allow immediately if null
6444#    lw $t2,($sp)
6448#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
6452#    lw $t2,-12($t2) # vtable address
6456#    bge $t2,$t1,castException
6457##...slt $at,$t2,$t1
6461##...beq $at,$zero,6596
6464#    blt $t2,$t0,castException
6465##...slt $at,$t2,$t0
6469##...bne $at,$zero,6596
    
    # return, leaving object unchanged on stack
6472:  checkCastReturn:    
6472#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
6476:instanceOf:
    # get object, go return false if null
6476#    lw $t2,($sp)
6480#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
6484#    lw $t2,-12($t2) # vtable address
6488#    sge $t0,$t2,$t0 # are we >= the lower limit?
6489##...slt $t0,$t2,$t0
6493##...xori $t0,$t0,0x1
6496#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
6500#    and $t2,$t0,$t1
6504#    sw $t2,($sp)
6508:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
6508#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

6512:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
6512#    li $v0,4 # syscall-code for print-string
6516#    syscall
6520:exit:
    # print termination message
6520#    li $v0,4 # syscall-code for print-string
6524#    la $a0,exitString
6528#    syscall

    # terminate execution
6532#    li $v0,10 #syscall-code for "exit"
6536#    syscall

6540:outOfHeapMemory:
6540#    la $a0,heapMemoryMsg
6544#    j exitError
6548:divByZeroError:
6548#    la $a0,divByZeroMsg
6552#    j exitError
6556:strIndexOutOfBounds:
6556#    la $a0,strIndexOutOfBoundsMsg
6560#    j exitError
6564:arrayIndexOutOfBounds:
6564#    la $a0,arrayIndexOutOfBoundsMsg
6568#    j exitError
6572:arraySizeOutOfBounds:
6572#    la $a0,arraySizeOutOfBoundsMsg
6576#    j exitError
6580:nullPtrException:
6580#    la $a0,nullPtrExceptionMsg
6584#    j exitError
6588:badIntegerFormat:
6588#    la $a0,badIntegerFormatMsg
6592#    j exitError
6596:castException:
6596#    la $a0,castExceptionMsg
6600#    j exitError
############## data section ################
    .data
6824:hexChars:
    .ascii "0123456789abcdef"
    .align 2
6840:cur_seg:
    .word 0

6844:lastCharRead:
    .word -2 # -2 => no buffered character
6848:prevHashConstant:
    .word 0x2785173c
6852:gcCount:
    .word 0

6856:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
6883:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"

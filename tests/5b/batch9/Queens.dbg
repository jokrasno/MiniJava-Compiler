5472#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
5476#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
5480#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    

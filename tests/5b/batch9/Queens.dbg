
5900:  gcSkip2:
5900#    sll $t2,$t2,2
5904#    addu $t2,$t2,8
5908#    subu $t4,$t1,$t2 # address of first word of source
5912#    lw $t3,-4($t1) # number of object words (negative means zero)

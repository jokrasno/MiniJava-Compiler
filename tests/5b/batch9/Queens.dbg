# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3500:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
3500#    lw $t0,-8($s2) # get word with hash bits from this
3504#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
3508#    addu $t0,$t1

3512#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3516:mth_equals_Object:
3516#    move $t0,$s2 # first pointer (this)
3520#    lw $t1,($sp) # second pointer
3524#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
3525##...subu $at,$t0,$t1
3529##...sltiu $t0,$at,1

3532#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
3536:mth_hashCode_String:
3536#    move $t0,$s2 # put this pointer in t0

3540#    li $t2,0 # current hash value
3544#    lw $t1,-4($t0) # negative of number of characters in string
3548#    beq $t1,$zero,done_hashCode_String # if zero length => done
3552#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
3556#    and $t0,0xfffffffc # adjust for padding
3557##...lui $at,65535
3561##...ori $at,$at,0xfffc
3565##...and $t0,$t0,$at
3568#    subu $t1,$t0,$t1 # address at end of string +12
3572:loop_hashCode_String:    
3572#    sll $t4,$t2,5 # multiply by 32
3576#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
3580#    lbu $t3,-12($t0) # current character
3584#    addu $t2,$t3 # add in current character
3588#    addu $t0,1 # go to next character's address
3592#    bne $t0,$t1,loop_hashCode_String # loop back if more
3596:done_hashCode_String:    

    # push int on stack
3596#    move $t0, $t2 # put $t2 in return slot
3600#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
3604:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
3604#    subu $sp,4
3608#    sw $ra,($sp)
    
    # get hash value
3612#    lw $t2,-12($s2) # vtable address
3616#    lw $t0,($t2) # method address
3620#    jalr $t0
3624#    subu $sp,8 # push result (int in $t0) on stack
3628#    sw $s5,4($sp)
3632#    sw $t0,($sp)

    # compute print-size of hash value
3636#    li $t0, 1
3640#    lw $t1, ($sp)
3644#    srl $t1,$t1,4
3648#    beq $t1,$zero,toString_skip_loop
3652:toString_loop_top:
3652#    addu $t0,1
3656#    srl $t1,$t1,4
3660#    bne $t1,$zero,toString_loop_top
3664:toString_skip_loop:
3664#    subu $sp,8
3668#    sw $s5,4($sp)
3672#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
3676#    lw $t2,-12($s2) # vtable address
3680#    move $t0,$t2
3684:toString_checkTagBit:
3684#    subu $t0,1
3688#    lb $t1,($t0)
3692#    and $t1,0x80
3693##...lui $at,0
3697##...ori $at,$at,0x80
3701##...and $t1,$t1,$at
3704#    beq $t1,$zero,toString_checkTagBit
3708#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
3712#    subu $sp,8
3716#    sw $t1,($sp)
3720#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
3724#    move $s7,$zero # -4 offset header word
3728#    lw $t4,8($sp) # bytes for hash value
3732#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
3736#    addu $t4,8
3740#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
3744#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

3748#    li $t0,CLASS_String # store string vtable address into ...
3752#    sw $t0,-12($s7) # ... -12 offset in object header
3756#    lw $t2,-12($s2) # our object's vtable address
3760#    lw $t5,4($sp) # number characters in prefix
3764#    lw $t1,12($sp) # number of characters in hashcode
3768#    addu $t3,$t1,$t5 # number of characters in string ...
3772#    addu $t3,1 # ... including the '@' character
3776#    subu $t0,$zero,$t3 # store negated length into ...
3780#    sw $t0,-4($s7) # ... -4 offset header word
3784#    lw $t0,-8($s7) # get -8 offset header-word
3788#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
3789##...slt $at,$t0,$zero
3793##...beq $at,$zero,3812
3796#    and $t0,0xff # mask off object's hash value ...
3797##...lui $at,0
3801##...ori $at,$at,0xff
3805##...and $t0,$t0,$at
3808#    sw $t0,-8($s7) # ... and store back into -8 header-word
3812:skipMask_toString:
3812#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
3816#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
3820#    subu $t4,$t2,$t5
3824:toString_copyLoop:    
3824#    lb $t3,($t4)
3828#    and $t3,0x7f # mask off sign bit (in case first word)
3829##...lui $at,0
3833##...ori $at,$at,0x7f
3837##...and $t3,$t3,$at
3840#    sb $t3,-8($t0)
3844#    addu $t4,1
3848#    addu $t0,1
3852#    blt $t4,$t2,toString_copyLoop
3853##...slt $at,$t4,$t2
3857##...bne $at,$zero,3824

    # copy the '@' sign
3860#    li $t3,'@'
3864#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
3868#    addu $t2,$t0,$t1 # address of last byte in string to store +8
3872#    lw $t3,20($sp) # hash code to print
3876:toString_hashCopyLoop:
3876#    and $t4,$t3,0xf
3880#    srl $t3,4
3884#    lb $t4,hexChars($t4)
3888#    sb $t4,-8($t2)
3892#    subu $t2,$t2,1
3896#    bgt $t2,$t0,toString_hashCopyLoop
3897##...slt $at,$t0,$t2
3901##...bne $at,$zero,3876

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
3904#    addu $sp,28
3908#    lw $ra,($sp)
3912#    addu $sp,4
3916#    move $t0, $s7 # return string we created
3920#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
3924:mth_equals_String:
    
    # quick test for obvious false
3924#    lw $t0,($sp) # second parameter
3928#    beq $t0,$zero,goEsFalse # go return false if null
3932#    lw $t1,-12($t0) # vtable pointer
3936#    la $t2,CLASS_String # string vtable pointer
3940#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
3944#    subu $sp,12
3948#    sw $ra,8($sp)
3952#    sw $s2,4($sp)
3956#    sw $t0,($sp)
3960#    jal mth_compareTo_String
3964#    lw $s2, 4($sp) #restore this pointer and pop parameters
3968#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
3972#    seq $t0,$t0,$zero
3973##...subu $at,$t0,$zero
3977##...sltiu $t0,$at,1

    # pop return address and return $t0
3980#    lw $ra,($sp)
3984#    addu $sp,4

3988#    jr $ra # return
    
3992:goEsFalse:
    # put 0 in $t0 and return
3992#    li $t0, 0
3996#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
4000:mth_toString_String:
    #we are a string, so return this.
4000#    move $t0, $s2
4004#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
4008:mth_readLine_Lib:
    
4008#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
4012#    sw $ra, 4($sp) # save $ra
4016#    move $t1,$sp # save "original" sp

4020:  doRead:

    # read the character
4020#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
4024#    subu $t2,$v0,13
4028#    bne $t2,$zero,notReturnRL
4032#    jal readLogicalChar
4036#    subu $t2,$v0,10 # check for newline
4040#    beq $t2,$zero,foundNewLine
4044#    sw $v0,lastCharRead # push back character into queue
4048#    j foundNewLine # go process the line

4052:  notReturnRL:

    # at this point, $v0 has our character

4052#    subu $t0,$v0,10
4056#    beq $t0,$zero,foundNewLine
4060#    blt $v0,$zero,foundEof
4061##...slt $at,$v0,$zero
4065##...bne $at,$zero,4080

    # we have a character, so push it onto stack
4068#    subu $sp,$sp,4
4072#    sw $v0,($sp)

    # loop back up to get next character
4076#    j doRead

4080:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
4080#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
4084#    li $s7, 0 # return-value: null
4088#    j rlReturn # return

4092:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
4092#    subu $t0,$t1,$sp # number of chars we read (times 4)
4096#    srl $s6,$t0,2 # number of words on stack with chars
4100#    subu $sp,$sp,4 # push char-count ...
4104#    sw $s6,($sp) # ... onto stack
4108#    addu $t2,$t0,5 # GC tag, incl. for count-word
4112#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
4116#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
4120#    srl $s6,$s6,2  # data words in object
4124#    move $s7,$zero # object words in object
4128#    jal newObject  # allocate space
    
    # store header words
4132#    la $t0,CLASS_String
4136#    sw $t0,-12($s7)# store class tag (String) into object
4140#    lw $t2,4($sp) # char-count
4144#    sll $t1,$t2,2 # 4 times number of chars
4148#    subu $t2,$zero,$t2 # negative of char-count
4152#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
4156#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
4160#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
4161##...slt $at,$t0,$zero
4165##...beq $at,$zero,4184
4168#    and $t0,0xff # mask off object's hash value ...
4169##...lui $at,0
4173##...ori $at,$at,0xff
4177##...and $t0,$t0,$at
4180#    sw $t0,-8($s7) # ... and store back into -8 header-word
4184:  skipMask_readLine:

4184#    sll $t0,$t0,2 # data bytes in object
4188#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
4192#    subu $t0,$t0,$t2 # place to store last character (plus 9)
4196#    addu $sp,$sp,8 # pop redundant object-pointer and count
4200#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

4204#    beq $sp,$t1,rlReturn
4208:  charCopyLoop:
4208#    lw $t2,($sp)
4212#    sb $t2,-9($t0)
4216#    addu $sp,$sp,4
4220#    subu $t0,$t0,1
4224#    bne $sp,$t1,charCopyLoop
4228:  rlReturn:

4228#    lw $ra, 4($sp)
4232#    addu $sp, 8   # pop $ra and pointless word off stack
4236#    move $t0, $s7 # return string we allocated in $s7
4240#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
4244:mth_readInt_Lib:

    # save $ra by pushing onto stack
4244#    subu $sp,$sp,4
4248#    sw $ra,($sp)

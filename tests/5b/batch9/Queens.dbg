    # storing digits on stack until we reach 0
5128:  itsNonNegLoop:
5128#    divu $t1,$t3
5132#    mflo $t1 # quotient
5136#    mfhi $t4 # remainder
5140#    addu $t4,$t4,'0' # turn remainder into digit

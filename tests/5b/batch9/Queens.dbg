    # get negative sizes; sum and store in new object size-field
4916#    lw $t2,-4($t0) # negative length of second object
4920#    lw $t3,-4($t1) # negative length of first object
4924#    addu $t4,$t2,$t3 # sum of negative lengths
4928#    sw $t4,-4($s7) # store sum as negated target-string length

    #########################################################
    # at this point:
    # - $t0 is pointer to second object

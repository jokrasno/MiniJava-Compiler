##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
9748:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
9748#    lw $t0,-8($s2) # get word with hash bits from this
9752#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
9756#    addu $t0,$t1

9760#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
9764:mth_equals_Object:
9764#    move $t0,$s2 # first pointer (this)
9768#    lw $t1,($sp) # second pointer
9772#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
9773##...subu $at,$t0,$t1
9777##...sltiu $t0,$at,1

9780#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
9784:mth_hashCode_String:
9784#    move $t0,$s2 # put this pointer in t0

9788#    li $t2,0 # current hash value
9792#    lw $t1,-4($t0) # negative of number of characters in string
9796#    beq $t1,$zero,done_hashCode_String # if zero length => done
9800#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
9804#    and $t0,0xfffffffc # adjust for padding
9805##...lui $at,65535
9809##...ori $at,$at,0xfffc
9813##...and $t0,$t0,$at
9816#    subu $t1,$t0,$t1 # address at end of string +12
9820:loop_hashCode_String:    
9820#    sll $t4,$t2,5 # multiply by 32
9824#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
9828#    lbu $t3,-12($t0) # current character
9832#    addu $t2,$t3 # add in current character
9836#    addu $t0,1 # go to next character's address
9840#    bne $t0,$t1,loop_hashCode_String # loop back if more
9844:done_hashCode_String:    

    # push int on stack
9844#    move $t0, $t2 # put $t2 in return slot
9848#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
9852:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
9852#    subu $sp,4
9856#    sw $ra,($sp)
    
    # get hash value
9860#    lw $t2,-12($s2) # vtable address
9864#    lw $t0,($t2) # method address
9868#    jalr $t0
9872#    subu $sp,8 # push result (int in $t0) on stack
9876#    sw $s5,4($sp)
9880#    sw $t0,($sp)

    # compute print-size of hash value
9884#    li $t0, 1
9888#    lw $t1, ($sp)
9892#    srl $t1,$t1,4
9896#    beq $t1,$zero,toString_skip_loop
9900:toString_loop_top:
9900#    addu $t0,1
9904#    srl $t1,$t1,4
9908#    bne $t1,$zero,toString_loop_top
9912:toString_skip_loop:
9912#    subu $sp,8
9916#    sw $s5,4($sp)
9920#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
9924#    lw $t2,-12($s2) # vtable address
9928#    move $t0,$t2
9932:toString_checkTagBit:
9932#    subu $t0,1
9936#    lb $t1,($t0)
9940#    and $t1,0x80
9941##...lui $at,0
9945##...ori $at,$at,0x80
9949##...and $t1,$t1,$at
9952#    beq $t1,$zero,toString_checkTagBit
9956#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
9960#    subu $sp,8
9964#    sw $t1,($sp)
9968#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
9972#    move $s7,$zero # -4 offset header word
9976#    lw $t4,8($sp) # bytes for hash value
9980#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
9984#    addu $t4,8
9988#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
9992#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

9996#    li $t0,CLASS_String # store string vtable address into ...
10000#    sw $t0,-12($s7) # ... -12 offset in object header
10004#    lw $t2,-12($s2) # our object's vtable address
10008#    lw $t5,4($sp) # number characters in prefix
10012#    lw $t1,12($sp) # number of characters in hashcode
10016#    addu $t3,$t1,$t5 # number of characters in string ...
10020#    addu $t3,1 # ... including the '@' character
10024#    subu $t0,$zero,$t3 # store negated length into ...
10028#    sw $t0,-4($s7) # ... -4 offset header word
10032#    lw $t0,-8($s7) # get -8 offset header-word
10036#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
10037##...slt $at,$t0,$zero
10041##...beq $at,$zero,10060
10044#    and $t0,0xff # mask off object's hash value ...
10045##...lui $at,0
10049##...ori $at,$at,0xff
10053##...and $t0,$t0,$at
10056#    sw $t0,-8($s7) # ... and store back into -8 header-word
10060:skipMask_toString:
10060#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
10064#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
10068#    subu $t4,$t2,$t5
10072:toString_copyLoop:    
10072#    lb $t3,($t4)
10076#    and $t3,0x7f # mask off sign bit (in case first word)
10077##...lui $at,0
10081##...ori $at,$at,0x7f
10085##...and $t3,$t3,$at
10088#    sb $t3,-8($t0)
10092#    addu $t4,1
10096#    addu $t0,1
10100#    blt $t4,$t2,toString_copyLoop
10101##...slt $at,$t4,$t2
10105##...bne $at,$zero,10072

    # copy the '@' sign
10108#    li $t3,'@'
10112#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
10116#    addu $t2,$t0,$t1 # address of last byte in string to store +8
10120#    lw $t3,20($sp) # hash code to print
10124:toString_hashCopyLoop:
10124#    and $t4,$t3,0xf
10128#    srl $t3,4
10132#    lb $t4,hexChars($t4)
10136#    sb $t4,-8($t2)
10140#    subu $t2,$t2,1
10144#    bgt $t2,$t0,toString_hashCopyLoop
10145##...slt $at,$t0,$t2
10149##...bne $at,$zero,10124

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
10152#    addu $sp,28
10156#    lw $ra,($sp)
10160#    addu $sp,4
10164#    move $t0, $s7 # return string we created
10168#    jr $ra

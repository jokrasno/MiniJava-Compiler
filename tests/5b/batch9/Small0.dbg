###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
10172:mth_equals_String:
    
    # quick test for obvious false
10172#    lw $t0,($sp) # second parameter
10176#    beq $t0,$zero,goEsFalse # go return false if null
10180#    lw $t1,-12($t0) # vtable pointer
10184#    la $t2,CLASS_String # string vtable pointer
10188#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
10192#    subu $sp,12
10196#    sw $ra,8($sp)
10200#    sw $s2,4($sp)
10204#    sw $t0,($sp)
10208#    jal mth_compareTo_String
10212#    lw $s2, 4($sp) #restore this pointer and pop parameters
10216#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
10220#    seq $t0,$t0,$zero
10221##...subu $at,$t0,$zero
10225##...sltiu $t0,$at,1

    # pop return address and return $t0
10228#    lw $ra,($sp)
10232#    addu $sp,4

10236#    jr $ra # return
    
10240:goEsFalse:
    # put 0 in $t0 and return
10240#    li $t0, 0
10244#    jr $ra # return

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
10256:mth_readLine_Lib:
    
10256#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
10260#    sw $ra, 4($sp) # save $ra
10264#    move $t1,$sp # save "original" sp

10268:  doRead:

    # read the character
10268#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
10272#    subu $t2,$v0,13
10276#    bne $t2,$zero,notReturnRL
10280#    jal readLogicalChar
10284#    subu $t2,$v0,10 # check for newline
10288#    beq $t2,$zero,foundNewLine
10292#    sw $v0,lastCharRead # push back character into queue
10296#    j foundNewLine # go process the line

10300:  notReturnRL:

    # at this point, $v0 has our character

10300#    subu $t0,$v0,10
10304#    beq $t0,$zero,foundNewLine
10308#    blt $v0,$zero,foundEof
10309##...slt $at,$v0,$zero
10313##...bne $at,$zero,10328

    # we have a character, so push it onto stack
10316#    subu $sp,$sp,4
10320#    sw $v0,($sp)

    # loop back up to get next character
10324#    j doRead

10328:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
10328#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
10332#    li $s7, 0 # return-value: null
10336#    j rlReturn # return

10340:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
10340#    subu $t0,$t1,$sp # number of chars we read (times 4)
10344#    srl $s6,$t0,2 # number of words on stack with chars
10348#    subu $sp,$sp,4 # push char-count ...
10352#    sw $s6,($sp) # ... onto stack
10356#    addu $t2,$t0,5 # GC tag, incl. for count-word
10360#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
10364#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
10368#    srl $s6,$s6,2  # data words in object
10372#    move $s7,$zero # object words in object
10376#    jal newObject  # allocate space
    
    # store header words
10380#    la $t0,CLASS_String
10384#    sw $t0,-12($s7)# store class tag (String) into object
10388#    lw $t2,4($sp) # char-count
10392#    sll $t1,$t2,2 # 4 times number of chars
10396#    subu $t2,$zero,$t2 # negative of char-count
10400#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
10404#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
10408#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
10409##...slt $at,$t0,$zero
10413##...beq $at,$zero,10432
10416#    and $t0,0xff # mask off object's hash value ...
10417##...lui $at,0
10421##...ori $at,$at,0xff
10425##...and $t0,$t0,$at
10428#    sw $t0,-8($s7) # ... and store back into -8 header-word
10432:  skipMask_readLine:

10432#    sll $t0,$t0,2 # data bytes in object
10436#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
10440#    subu $t0,$t0,$t2 # place to store last character (plus 9)
10444#    addu $sp,$sp,8 # pop redundant object-pointer and count
10448#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

10452#    beq $sp,$t1,rlReturn
10456:  charCopyLoop:
10456#    lw $t2,($sp)
10460#    sb $t2,-9($t0)
10464#    addu $sp,$sp,4
10468#    subu $t0,$t0,1
10472#    bne $sp,$t1,charCopyLoop
10476:  rlReturn:

10476#    lw $ra, 4($sp)
10480#    addu $sp, 8   # pop $ra and pointless word off stack
10484#    move $t0, $s7 # return string we allocated in $s7
10488#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
10492:mth_readInt_Lib:

    # save $ra by pushing onto stack
10492#    subu $sp,$sp,4
10496#    sw $ra,($sp)

10500:  riSkipWhiteLoop:
    # read a character
10500#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
10504#    subu $t0,$v0,32
10508#    bgt $t0,$zero,nonWhite
10509##...slt $at,$zero,$t0
10513##...bne $at,$zero,10556
10516#    beq $t0,$zero,riSkipWhiteLoop # start over if space
10520#    subu $t0,$v0,10
10524#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
10528#    subu $t0,$v0,9
10532#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
10536#    subu $t0,$v0,13
10540#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
10544#    subu $t0,$v0,12
10548#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
10552#    j badIntegerFormat # illegal integer char: abort program

10556:  nonWhite:
10556#    subu $t0,$v0,'-'
10560#    li $t4,1 # final multiplier
10564#    bne $t0,$zero,helpReadInt # go read
10568#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
10572#    jal readLogicalChar

10576:  helpReadInt:
10576#    li $t2,10
10580#    subu $t1,$v0,'0' # convert digit to 0-9 value
10584#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
10585##...sltu $at,$t1,$t2
10589##...beq $at,$zero,12836
10592#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

10596:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

10596#    jal readLogicalChar # read next character
10600#    subu $t1,$v0,'0' # convert digit to 0-9 value
10604#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
10605##...sltu $at,$t1,$t2
10609##...beq $at,$zero,10628

10612#    mul $t3,$t3,$t2 # multiply old value by 10
10613##...mult $t3,$t2
10617##...mflo $t3
10620#    addu $t3,$t3,$t1 # add in value of new digit
10624#    j digitLoop

10628:  doneDigitLoop:

    # "push back" unused character into queue
10628#    sw $v0,lastCharRead

    # restore return address
10632#    lw $ra,($sp)
10636#    addu $sp, 4

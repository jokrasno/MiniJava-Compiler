12532#    sw $s0,($s3)
12536#    addu $t4,$t4,4
12540#    addu $s3,$s3,4
12544#    bltu $t4,$t3,gCinnerCopy2
12545##...sltu $at,$t4,$t3
12549##...bne $at,$zero,12528

    ###########################################################
    # All bytes have been copied to the target space.  We still
    # need to:
    # - set up forwarding pointer in source object
    # - update the pointer in the current stack slot
    ###########################################################

    # set up the forwarding pointer
12552#    sw $zero,-8($t1) # 0 in first header-slot
12556#    sw $t8,-4($t1) # forwarding pointer in second header-slot

    # update the heap-slot with the address in the target space
12560#    sw $t8,($t0)

12564:  gcGoNextPointerSlot:
    # bump $t0 to next slot in object; if not done, loop back
12564#    addu $t0,$t0,4
12568#    bltu $t0,$s1,gcNextPointerInObject
12569##...sltu $at,$t0,$s1
12573##...bne $at,$zero,12412

12576:  gcTestIterDone2:
12576#    bltu $t0,$s3,gcHeapCopyLoop
12577##...sltu $at,$t0,$s3
12581##...bne $at,$zero,12296

    ###### end outer loop to copy all non-stack-direct objects ######

12584:  gcFinishUp:
    # restore $s2 to its updated value by popping off stack
12584#    lw $s2,($sp)
12588#    addu $sp,$sp,4

    # mark us as having already GC'd
12592#    move $t5,$s5

    # go try and allocate again
12596#    j gcJoin
        

########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
12600:vm_init:

    # mark bottom of stack
12600#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
12604#    move $s2,$zero

    #set up the "five" register
12608#    li $s5,5

12612#    la $s3,seg0_start
12616#    la $s4,seg0_end
12617##...lui $s4,16
12621##...addiu $s4,$s4,13616
    
    # return
12624#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
12628:divide:
    # get parameters; abort if divisor zero
12628#    lw $t0,($sp)
12632#    lw $t1,8($sp)
12636#    beq $t0,$zero,divByZeroError
    
    # perform division
12640#    div $t1,$t0
12644#    mflo $t0

    # store result, adjust stack and return
12648#    addu $sp,$sp,8 # adjust stack
12652#    sw $t0,($sp) # store result
12656#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
12660:remainder:
    # get parameters; abort if divisor zero
12660#    lw $t0,($sp)
12664#    lw $t1,8($sp)
12668#    beq $t0,$zero,divByZeroError
    
    # perform division
12672#    div $t1,$t0
12676#    mfhi $t0

    # store result, adjust stack and return
12680#    addu $sp,$sp,8 # adjust stack
12684#    sw $t0,($sp) # store result
12688#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
12692:checkCast:
    # get object, allow immediately if null
12692#    lw $t2,($sp)
12696#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
12700#    lw $t2,-12($t2) # vtable address
12704#    bge $t2,$t1,castException
12705##...slt $at,$t2,$t1
12709##...beq $at,$zero,12844
12712#    blt $t2,$t0,castException
12713##...slt $at,$t2,$t0
12717##...bne $at,$zero,12844
    
    # return, leaving object unchanged on stack
12720:  checkCastReturn:    
12720#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
12724:instanceOf:
    # get object, go return false if null
12724#    lw $t2,($sp)
12728#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
12732#    lw $t2,-12($t2) # vtable address
12736#    sge $t0,$t2,$t0 # are we >= the lower limit?
12737##...slt $t0,$t2,$t0
12741##...xori $t0,$t0,0x1
12744#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
12748#    and $t2,$t0,$t1
12752#    sw $t2,($sp)
12756:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
12756#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

12760:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
12760#    li $v0,4 # syscall-code for print-string
12764#    syscall
12768:exit:
    # print termination message
12768#    li $v0,4 # syscall-code for print-string
12772#    la $a0,exitString
12776#    syscall

    # terminate execution
12780#    li $v0,10 #syscall-code for "exit"
12784#    syscall

12788:outOfHeapMemory:
12788#    la $a0,heapMemoryMsg
12792#    j exitError
12796:divByZeroError:
12796#    la $a0,divByZeroMsg
12800#    j exitError
12804:strIndexOutOfBounds:
12804#    la $a0,strIndexOutOfBoundsMsg
12808#    j exitError
12812:arrayIndexOutOfBounds:
12812#    la $a0,arrayIndexOutOfBoundsMsg
12816#    j exitError
12820:arraySizeOutOfBounds:
12820#    la $a0,arraySizeOutOfBoundsMsg
12824#    j exitError
12828:nullPtrException:
12828#    la $a0,nullPtrExceptionMsg
12832#    j exitError
12836:badIntegerFormat:
12836#    la $a0,badIntegerFormatMsg
12840#    j exitError
12844:castException:
12844#    la $a0,castExceptionMsg
12848#    j exitError
############## data section ################
    .data
13252:hexChars:
    .ascii "0123456789abcdef"
    .align 2
13268:cur_seg:
    .word 0

13272:lastCharRead:
    .word -2 # -2 => no buffered character
13276:prevHashConstant:
    .word 0x2785173c
13280:gcCount:
    .word 0

13284:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
13311:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
13334:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
13369:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
13403:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
13436:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
13467:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
13515:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
13536:gcMsg: 
      .asciiz "\nGC!\n"
13542:gcCountMsg: 
      .asciiz "Number of garbage collections: "

13574:nullStr:
    .asciiz "null"
13579:trueString:
    .asciiz "true"
13584:falseString:
    .asciiz "false"
13590:exitString:
    .ascii "Program terminated."
    #### "falls through" here
13609:newlineString:
    .asciiz "\n"
    
    .align 2
13612:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

13616:seg0_start:
    .space 0x100000
1062192:seg0_end:
1062192:seg1_start:
    .space 0x100000
2110768:seg1_end:

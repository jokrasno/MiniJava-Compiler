##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
104:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
104#    lw $t0,-8($s2) # get word with hash bits from this
108#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
112#    addu $t0,$t1

116#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
120:mth_equals_Object:
120#    move $t0,$s2 # first pointer (this)
124#    lw $t1,($sp) # second pointer
128#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
129##...subu $at,$t0,$t1
133##...sltiu $t0,$at,1

136#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
140:mth_hashCode_String:
140#    move $t0,$s2 # put this pointer in t0

144#    li $t2,0 # current hash value
148#    lw $t1,-4($t0) # negative of number of characters in string
152#    beq $t1,$zero,done_hashCode_String # if zero length => done
156#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
160#    and $t0,0xfffffffc # adjust for padding
161##...lui $at,65535
165##...ori $at,$at,0xfffc
169##...and $t0,$t0,$at
172#    subu $t1,$t0,$t1 # address at end of string +12
176:loop_hashCode_String:    
176#    sll $t4,$t2,5 # multiply by 32
180#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
184#    lbu $t3,-12($t0) # current character
188#    addu $t2,$t3 # add in current character
192#    addu $t0,1 # go to next character's address
196#    bne $t0,$t1,loop_hashCode_String # loop back if more
200:done_hashCode_String:    

    # push int on stack
200#    move $t0, $t2 # put $t2 in return slot
204#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
208:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
208#    subu $sp,4
212#    sw $ra,($sp)
    
    # get hash value
216#    lw $t2,-12($s2) # vtable address
220#    lw $t0,($t2) # method address
224#    jalr $t0
228#    subu $sp,8 # push result (int in $t0) on stack
232#    sw $s5,4($sp)
236#    sw $t0,($sp)

    # compute print-size of hash value
240#    li $t0, 1
244#    lw $t1, ($sp)
248#    srl $t1,$t1,4
252#    beq $t1,$zero,toString_skip_loop
256:toString_loop_top:
256#    addu $t0,1
260#    srl $t1,$t1,4
264#    bne $t1,$zero,toString_loop_top
268:toString_skip_loop:
268#    subu $sp,8
272#    sw $s5,4($sp)
276#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
280#    lw $t2,-12($s2) # vtable address
284#    move $t0,$t2
288:toString_checkTagBit:
288#    subu $t0,1
292#    lb $t1,($t0)
296#    and $t1,0x80
297##...lui $at,0
301##...ori $at,$at,0x80
305##...and $t1,$t1,$at
308#    beq $t1,$zero,toString_checkTagBit
312#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
316#    subu $sp,8
320#    sw $t1,($sp)
324#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
328#    move $s7,$zero # -4 offset header word
332#    lw $t4,8($sp) # bytes for hash value
336#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
340#    addu $t4,8
344#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
348#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

352#    li $t0,CLASS_String # store string vtable address into ...
356#    sw $t0,-12($s7) # ... -12 offset in object header
360#    lw $t2,-12($s2) # our object's vtable address
364#    lw $t5,4($sp) # number characters in prefix
368#    lw $t1,12($sp) # number of characters in hashcode
372#    addu $t3,$t1,$t5 # number of characters in string ...
376#    addu $t3,1 # ... including the '@' character
380#    subu $t0,$zero,$t3 # store negated length into ...
384#    sw $t0,-4($s7) # ... -4 offset header word
388#    lw $t0,-8($s7) # get -8 offset header-word
392#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
393##...slt $at,$t0,$zero
397##...beq $at,$zero,416
400#    and $t0,0xff # mask off object's hash value ...
401##...lui $at,0
405##...ori $at,$at,0xff
409##...and $t0,$t0,$at
412#    sw $t0,-8($s7) # ... and store back into -8 header-word
416:skipMask_toString:
416#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
420#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
424#    subu $t4,$t2,$t5
428:toString_copyLoop:    
428#    lb $t3,($t4)
432#    and $t3,0x7f # mask off sign bit (in case first word)
433##...lui $at,0
437##...ori $at,$at,0x7f
441##...and $t3,$t3,$at
444#    sb $t3,-8($t0)
448#    addu $t4,1
452#    addu $t0,1
456#    blt $t4,$t2,toString_copyLoop
457##...slt $at,$t4,$t2
461##...bne $at,$zero,428

    # copy the '@' sign
464#    li $t3,'@'
468#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
472#    addu $t2,$t0,$t1 # address of last byte in string to store +8
476#    lw $t3,20($sp) # hash code to print
480:toString_hashCopyLoop:
480#    and $t4,$t3,0xf
484#    srl $t3,4
488#    lb $t4,hexChars($t4)
492#    sb $t4,-8($t2)
496#    subu $t2,$t2,1
500#    bgt $t2,$t0,toString_hashCopyLoop
501##...slt $at,$t0,$t2
505##...bne $at,$zero,480

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
508#    addu $sp,28
512#    lw $ra,($sp)
516#    addu $sp,4
520#    move $t0, $s7 # return string we created
524#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
528:mth_equals_String:
    
    # quick test for obvious false
528#    lw $t0,($sp) # second parameter
532#    beq $t0,$zero,goEsFalse # go return false if null
536#    lw $t1,-12($t0) # vtable pointer
540#    la $t2,CLASS_String # string vtable pointer
544#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
548#    subu $sp,12
552#    sw $ra,8($sp)
556#    sw $s2,4($sp)
560#    sw $t0,($sp)
564#    jal mth_compareTo_String
568#    lw $s2, 4($sp) #restore this pointer and pop parameters
572#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
576#    seq $t0,$t0,$zero
577##...subu $at,$t0,$zero
581##...sltiu $t0,$at,1

    # pop return address and return $t0
584#    lw $ra,($sp)
588#    addu $sp,4

592#    jr $ra # return
    
596:goEsFalse:
    # put 0 in $t0 and return
596#    li $t0, 0
600#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
604:mth_toString_String:
    #we are a string, so return this.
604#    move $t0, $s2
608#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
612:mth_readLine_Lib:
    
612#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
616#    sw $ra, 4($sp) # save $ra
620#    move $t1,$sp # save "original" sp

624:  doRead:

    # read the character
624#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
628#    subu $t2,$v0,13
632#    bne $t2,$zero,notReturnRL
636#    jal readLogicalChar
640#    subu $t2,$v0,10 # check for newline
644#    beq $t2,$zero,foundNewLine
648#    sw $v0,lastCharRead # push back character into queue
652#    j foundNewLine # go process the line

656:  notReturnRL:

    # at this point, $v0 has our character

656#    subu $t0,$v0,10
660#    beq $t0,$zero,foundNewLine
664#    blt $v0,$zero,foundEof
665##...slt $at,$v0,$zero
669##...bne $at,$zero,684

    # we have a character, so push it onto stack
672#    subu $sp,$sp,4
676#    sw $v0,($sp)

    # loop back up to get next character
680#    j doRead

684:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
684#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
688#    li $s7, 0 # return-value: null
692#    j rlReturn # return

696:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
696#    subu $t0,$t1,$sp # number of chars we read (times 4)
700#    srl $s6,$t0,2 # number of words on stack with chars
704#    subu $sp,$sp,4 # push char-count ...
708#    sw $s6,($sp) # ... onto stack
712#    addu $t2,$t0,5 # GC tag, incl. for count-word
716#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
720#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
724#    srl $s6,$s6,2  # data words in object
728#    move $s7,$zero # object words in object
732#    jal newObject  # allocate space
    
    # store header words
736#    la $t0,CLASS_String
740#    sw $t0,-12($s7)# store class tag (String) into object
744#    lw $t2,4($sp) # char-count
748#    sll $t1,$t2,2 # 4 times number of chars
752#    subu $t2,$zero,$t2 # negative of char-count
756#    sw $t2,-4($s7) # store negative char-count as header-word 2

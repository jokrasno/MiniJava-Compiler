3093##...slt $t0,$t2,$t0
3097##...xori $t0,$t0,0x1
3100#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3104#    and $t2,$t0,$t1
3108#    sw $t2,($sp)
3112:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3112#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3116:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3116#    li $v0,4 # syscall-code for print-string
3120#    syscall
3124:exit:
    # print termination message
3124#    li $v0,4 # syscall-code for print-string
3128#    la $a0,exitString
3132#    syscall

    # print number of garbage collections
3136#    li $v0,4 # syscall-code for print-string
3140#    la $a0,gcCountMsg
3144#    syscall # print "Number of ..."
3148#    lw $a0,gcCount # number of GC's
3152#    li $v0,1 # code for print-int
3156#    syscall
3160#    li $v0,4 # syscall-code for print-string
3164#    la $a0,newlineString
3168#    syscall # print newline

    # terminate execution
3172#    li $v0,10 #syscall-code for "exit"
3176#    syscall

3180:outOfHeapMemory:
3180#    la $a0,heapMemoryMsg
3184#    j exitError
3188:divByZeroError:
3188#    la $a0,divByZeroMsg
3192#    j exitError
3196:strIndexOutOfBounds:
3196#    la $a0,strIndexOutOfBoundsMsg
3200#    j exitError
3204:arrayIndexOutOfBounds:
3204#    la $a0,arrayIndexOutOfBoundsMsg
3208#    j exitError
3212:arraySizeOutOfBounds:
3212#    la $a0,arraySizeOutOfBoundsMsg
3216#    j exitError
3220:nullPtrException:
3220#    la $a0,nullPtrExceptionMsg
3224#    j exitError
3228:badIntegerFormat:
3228#    la $a0,badIntegerFormatMsg
3232#    j exitError
3236:castException:
3236#    la $a0,castExceptionMsg
3240#    j exitError
############## data section ################
    .data
3392:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3408:cur_seg:
    .word 0

3412:lastCharRead:
    .word -2 # -2 => no buffered character
3416:prevHashConstant:
    .word 0x2785173c
3420:gcCount:
    .word 0

3424:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3451:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3474:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3509:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3543:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3576:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3607:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3655:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3676:gcMsg: 
      .asciiz "\nGC!\n"
3682:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3714:nullStr:
    .asciiz "null"
3719:trueString:
    .asciiz "true"
3724:falseString:
    .asciiz "false"
3730:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
3758:newlineString:
    .asciiz "\n"
    
    .align 2
3760:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3764:seg0_start:
    .space 0x100000
1052340:seg0_end:
1052340:seg1_start:
    .space 0x100000
2100916:seg1_end:

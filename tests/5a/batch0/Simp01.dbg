    # greater
2128#    slt $t5,$t4,$t3 # 1 if str2 > str1, else 0
2132#    sll $t5,$t5,1 # 2 if str2 > str1, else 0
2136#    subu $t5,$t5,1 # 1 if str2 > str1, else -1
2140:  cmpHitLimitzz:
2140#    move $t0, $t5 # store return value
2144#    jr $ra # return

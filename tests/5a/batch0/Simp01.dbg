945##...beq $at,$zero,3228
948#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

952:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

952#    jal readLogicalChar # read next character
956#    subu $t1,$v0,'0' # convert digit to 0-9 value
960#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
961##...sltu $at,$t1,$t2
965##...beq $at,$zero,984

968#    mul $t3,$t3,$t2 # multiply old value by 10
969##...mult $t3,$t2
973##...mflo $t3
976#    addu $t3,$t3,$t1 # add in value of new digit
980#    j digitLoop

984:  doneDigitLoop:

    # "push back" unused character into queue
984#    sw $v0,lastCharRead

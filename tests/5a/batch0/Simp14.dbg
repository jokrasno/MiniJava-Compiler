    
    # return
3328#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3332:divide:
    # get parameters; abort if divisor zero
3332#    lw $t0,($sp)
3336#    lw $t1,8($sp)
3340#    beq $t0,$zero,divByZeroError
    
    # perform division
3344#    div $t1,$t0
3348#    mflo $t0

    # store result, adjust stack and return
3352#    addu $sp,$sp,8 # adjust stack
3356#    sw $t0,($sp) # store result
3360#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3364:remainder:
    # get parameters; abort if divisor zero
3364#    lw $t0,($sp)
3368#    lw $t1,8($sp)
3372#    beq $t0,$zero,divByZeroError
    
    # perform division
3376#    div $t1,$t0
3380#    mfhi $t0

    # store result, adjust stack and return
3384#    addu $sp,$sp,8 # adjust stack
3388#    sw $t0,($sp) # store result
3392#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3396:checkCast:
    # get object, allow immediately if null
3396#    lw $t2,($sp)
3400#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3404#    lw $t2,-12($t2) # vtable address
3408#    bge $t2,$t1,castException
3409##...slt $at,$t2,$t1
3413##...beq $at,$zero,3584
3416#    blt $t2,$t0,castException
3417##...slt $at,$t2,$t0
3421##...bne $at,$zero,3584
    
    # return, leaving object unchanged on stack
3424:  checkCastReturn:    
3424#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3428:instanceOf:
    # get object, go return false if null
3428#    lw $t2,($sp)
3432#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3436#    lw $t2,-12($t2) # vtable address
3440#    sge $t0,$t2,$t0 # are we >= the lower limit?
3441##...slt $t0,$t2,$t0
3445##...xori $t0,$t0,0x1
3448#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3452#    and $t2,$t0,$t1
3456#    sw $t2,($sp)
3460:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3460#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3464:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3464#    li $v0,4 # syscall-code for print-string
3468#    syscall
3472:exit:
    # print termination message
3472#    li $v0,4 # syscall-code for print-string
3476#    la $a0,exitString
3480#    syscall

    # print number of garbage collections
3484#    li $v0,4 # syscall-code for print-string
3488#    la $a0,gcCountMsg
3492#    syscall # print "Number of ..."
3496#    lw $a0,gcCount # number of GC's
3500#    li $v0,1 # code for print-int
3504#    syscall
3508#    li $v0,4 # syscall-code for print-string
3512#    la $a0,newlineString
3516#    syscall # print newline

    # terminate execution
3520#    li $v0,10 #syscall-code for "exit"
3524#    syscall

3528:outOfHeapMemory:
3528#    la $a0,heapMemoryMsg
3532#    j exitError
3536:divByZeroError:
3536#    la $a0,divByZeroMsg
3540#    j exitError
3544:strIndexOutOfBounds:
3544#    la $a0,strIndexOutOfBoundsMsg
3548#    j exitError
3552:arrayIndexOutOfBounds:
3552#    la $a0,arrayIndexOutOfBoundsMsg
3556#    j exitError
3560:arraySizeOutOfBounds:
3560#    la $a0,arraySizeOutOfBoundsMsg
3564#    j exitError
3568:nullPtrException:
3568#    la $a0,nullPtrExceptionMsg
3572#    j exitError
3576:badIntegerFormat:
3576#    la $a0,badIntegerFormatMsg
3580#    j exitError
3584:castException:
3584#    la $a0,castExceptionMsg
3588#    j exitError
############## data section ################
    .data
3792:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3808:cur_seg:
    .word 0

3812:lastCharRead:
    .word -2 # -2 => no buffered character
3816:prevHashConstant:
    .word 0x2785173c
3820:gcCount:
    .word 0

3824:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3851:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3874:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3909:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3943:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3976:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4007:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4055:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4076:gcMsg: 
      .asciiz "\nGC!\n"
4082:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4114:nullStr:
    .asciiz "null"
4119:trueString:
    .asciiz "true"
4124:falseString:
    .asciiz "false"
4130:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
4158:newlineString:
    .asciiz "\n"
    
    .align 2
4160:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4164:seg0_start:
    .space 0x100000
1052740:seg0_end:
1052740:seg1_start:
    .space 0x100000
2101316:seg1_end:

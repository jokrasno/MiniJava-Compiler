###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
960:mth_readLine_Lib:
    
960#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
964#    sw $ra, 4($sp) # save $ra
968#    move $t1,$sp # save "original" sp

972:  doRead:

    # read the character
972#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
976#    subu $t2,$v0,13
980#    bne $t2,$zero,notReturnRL
984#    jal readLogicalChar
988#    subu $t2,$v0,10 # check for newline
992#    beq $t2,$zero,foundNewLine
996#    sw $v0,lastCharRead # push back character into queue
1000#    j foundNewLine # go process the line

1004:  notReturnRL:

    # at this point, $v0 has our character

1004#    subu $t0,$v0,10
1008#    beq $t0,$zero,foundNewLine
1012#    blt $v0,$zero,foundEof
1013##...slt $at,$v0,$zero
1017##...bne $at,$zero,1032

    # we have a character, so push it onto stack
1020#    subu $sp,$sp,4
1024#    sw $v0,($sp)

    # loop back up to get next character
1028#    j doRead

1032:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1032#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1036#    li $s7, 0 # return-value: null
1040#    j rlReturn # return

1044:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1044#    subu $t0,$t1,$sp # number of chars we read (times 4)
1048#    srl $s6,$t0,2 # number of words on stack with chars
1052#    subu $sp,$sp,4 # push char-count ...
1056#    sw $s6,($sp) # ... onto stack
1060#    addu $t2,$t0,5 # GC tag, incl. for count-word
1064#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1068#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1072#    srl $s6,$s6,2  # data words in object
1076#    move $s7,$zero # object words in object
1080#    jal newObject  # allocate space
    
    # store header words
1084#    la $t0,CLASS_String
1088#    sw $t0,-12($s7)# store class tag (String) into object
1092#    lw $t2,4($sp) # char-count
1096#    sll $t1,$t2,2 # 4 times number of chars
1100#    subu $t2,$zero,$t2 # negative of char-count
1104#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1108#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1112#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1113##...slt $at,$t0,$zero
1117##...beq $at,$zero,1136
1120#    and $t0,0xff # mask off object's hash value ...
1121##...lui $at,0
1125##...ori $at,$at,0xff
1129##...and $t0,$t0,$at
1132#    sw $t0,-8($s7) # ... and store back into -8 header-word
1136:  skipMask_readLine:

1136#    sll $t0,$t0,2 # data bytes in object
1140#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1144#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1148#    addu $sp,$sp,8 # pop redundant object-pointer and count
1152#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1156#    beq $sp,$t1,rlReturn
1160:  charCopyLoop:
1160#    lw $t2,($sp)
1164#    sb $t2,-9($t0)
1168#    addu $sp,$sp,4
1172#    subu $t0,$t0,1
1176#    bne $sp,$t1,charCopyLoop
1180:  rlReturn:

1180#    lw $ra, 4($sp)
1184#    addu $sp, 8   # pop $ra and pointless word off stack
1188#    move $t0, $s7 # return string we allocated in $s7
1192#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1196:mth_readInt_Lib:

    # save $ra by pushing onto stack
1196#    subu $sp,$sp,4
1200#    sw $ra,($sp)

1204:  riSkipWhiteLoop:
    # read a character
1204#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1208#    subu $t0,$v0,32
1212#    bgt $t0,$zero,nonWhite
1213##...slt $at,$zero,$t0
1217##...bne $at,$zero,1260
1220#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1224#    subu $t0,$v0,10
1228#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1232#    subu $t0,$v0,9
1236#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1240#    subu $t0,$v0,13
1244#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1248#    subu $t0,$v0,12
1252#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1256#    j badIntegerFormat # illegal integer char: abort program

1260:  nonWhite:
1260#    subu $t0,$v0,'-'
1264#    li $t4,1 # final multiplier
1268#    bne $t0,$zero,helpReadInt # go read
1272#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1276#    jal readLogicalChar

1280:  helpReadInt:
1280#    li $t2,10
1284#    subu $t1,$v0,'0' # convert digit to 0-9 value
1288#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1289##...sltu $at,$t1,$t2
1293##...beq $at,$zero,3576
1296#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1300:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1300#    jal readLogicalChar # read next character
1304#    subu $t1,$v0,'0' # convert digit to 0-9 value
1308#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1309##...sltu $at,$t1,$t2
1313##...beq $at,$zero,1332

1316#    mul $t3,$t3,$t2 # multiply old value by 10
1317##...mult $t3,$t2
1321##...mflo $t3
1324#    addu $t3,$t3,$t1 # add in value of new digit
1328#    j digitLoop

1332:  doneDigitLoop:

    # "push back" unused character into queue
1332#    sw $v0,lastCharRead

    # restore return address
1336#    lw $ra,($sp)
1340#    addu $sp, 4

    # multiply by sign and put return value in $t0
1344#    mult $t3,$t4 # multiply to account for poss. minus sign
1348#    mflo $t3
1352#    move $t0, $t3
    
    # return
1356#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input

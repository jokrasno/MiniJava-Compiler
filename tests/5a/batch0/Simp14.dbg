##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
452:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
452#    lw $t0,-8($s2) # get word with hash bits from this
456#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
460#    addu $t0,$t1

464#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
468:mth_equals_Object:
468#    move $t0,$s2 # first pointer (this)
472#    lw $t1,($sp) # second pointer
476#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
477##...subu $at,$t0,$t1
481##...sltiu $t0,$at,1

484#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
488:mth_hashCode_String:
488#    move $t0,$s2 # put this pointer in t0

492#    li $t2,0 # current hash value
496#    lw $t1,-4($t0) # negative of number of characters in string
500#    beq $t1,$zero,done_hashCode_String # if zero length => done
504#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
508#    and $t0,0xfffffffc # adjust for padding
509##...lui $at,65535
513##...ori $at,$at,0xfffc
517##...and $t0,$t0,$at
520#    subu $t1,$t0,$t1 # address at end of string +12
524:loop_hashCode_String:    
524#    sll $t4,$t2,5 # multiply by 32
528#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
532#    lbu $t3,-12($t0) # current character
536#    addu $t2,$t3 # add in current character
540#    addu $t0,1 # go to next character's address
544#    bne $t0,$t1,loop_hashCode_String # loop back if more
548:done_hashCode_String:    

    # push int on stack
548#    move $t0, $t2 # put $t2 in return slot
552#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
556:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
556#    subu $sp,4
560#    sw $ra,($sp)
    
    # get hash value
564#    lw $t2,-12($s2) # vtable address
568#    lw $t0,($t2) # method address
572#    jalr $t0
576#    subu $sp,8 # push result (int in $t0) on stack
580#    sw $s5,4($sp)
584#    sw $t0,($sp)

    # compute print-size of hash value
588#    li $t0, 1
592#    lw $t1, ($sp)
596#    srl $t1,$t1,4
600#    beq $t1,$zero,toString_skip_loop
604:toString_loop_top:
604#    addu $t0,1
608#    srl $t1,$t1,4
612#    bne $t1,$zero,toString_loop_top
616:toString_skip_loop:
616#    subu $sp,8
620#    sw $s5,4($sp)
624#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
628#    lw $t2,-12($s2) # vtable address
632#    move $t0,$t2
636:toString_checkTagBit:
636#    subu $t0,1
640#    lb $t1,($t0)
644#    and $t1,0x80
645##...lui $at,0
649##...ori $at,$at,0x80
653##...and $t1,$t1,$at
656#    beq $t1,$zero,toString_checkTagBit
660#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
664#    subu $sp,8
668#    sw $t1,($sp)
672#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
676#    move $s7,$zero # -4 offset header word
680#    lw $t4,8($sp) # bytes for hash value
684#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
688#    addu $t4,8
692#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
696#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

700#    li $t0,CLASS_String # store string vtable address into ...
704#    sw $t0,-12($s7) # ... -12 offset in object header
708#    lw $t2,-12($s2) # our object's vtable address
712#    lw $t5,4($sp) # number characters in prefix
716#    lw $t1,12($sp) # number of characters in hashcode
720#    addu $t3,$t1,$t5 # number of characters in string ...
724#    addu $t3,1 # ... including the '@' character
728#    subu $t0,$zero,$t3 # store negated length into ...
732#    sw $t0,-4($s7) # ... -4 offset header word
736#    lw $t0,-8($s7) # get -8 offset header-word
740#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
741##...slt $at,$t0,$zero
745##...beq $at,$zero,764
748#    and $t0,0xff # mask off object's hash value ...
749##...lui $at,0
753##...ori $at,$at,0xff
757##...and $t0,$t0,$at
760#    sw $t0,-8($s7) # ... and store back into -8 header-word
764:skipMask_toString:
764#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
768#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
772#    subu $t4,$t2,$t5
776:toString_copyLoop:    
776#    lb $t3,($t4)
780#    and $t3,0x7f # mask off sign bit (in case first word)
781##...lui $at,0
785##...ori $at,$at,0x7f
789##...and $t3,$t3,$at
792#    sb $t3,-8($t0)
796#    addu $t4,1
800#    addu $t0,1
804#    blt $t4,$t2,toString_copyLoop
805##...slt $at,$t4,$t2
809##...bne $at,$zero,776

    # copy the '@' sign
812#    li $t3,'@'
816#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
820#    addu $t2,$t0,$t1 # address of last byte in string to store +8
824#    lw $t3,20($sp) # hash code to print
828:toString_hashCopyLoop:
828#    and $t4,$t3,0xf
832#    srl $t3,4
836#    lb $t4,hexChars($t4)
840#    sb $t4,-8($t2)
844#    subu $t2,$t2,1
848#    bgt $t2,$t0,toString_hashCopyLoop
849##...slt $at,$t0,$t2
853##...bne $at,$zero,828

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
856#    addu $sp,28
860#    lw $ra,($sp)
864#    addu $sp,4
868#    move $t0, $s7 # return string we created
872#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
876:mth_equals_String:
    
    # quick test for obvious false
876#    lw $t0,($sp) # second parameter
880#    beq $t0,$zero,goEsFalse # go return false if null
884#    lw $t1,-12($t0) # vtable pointer
888#    la $t2,CLASS_String # string vtable pointer
892#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
896#    subu $sp,12

905##...slt $at,$t0,$zero
909##...beq $at,$zero,928
912#    and $t0,0xff # mask off object's hash value ...
913##...lui $at,0
917##...ori $at,$at,0xff
921##...and $t0,$t0,$at
924#    sw $t0,-8($s7) # ... and store back into -8 header-word
928:  skipMask_readLine:

928#    sll $t0,$t0,2 # data bytes in object
932#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
936#    subu $t0,$t0,$t2 # place to store last character (plus 9)
940#    addu $sp,$sp,8 # pop redundant object-pointer and count

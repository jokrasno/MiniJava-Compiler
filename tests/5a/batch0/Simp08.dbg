1081##...sltu $at,$t1,$t2
1085##...beq $at,$zero,3368
1088#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1092:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1092#    jal readLogicalChar # read next character
1096#    subu $t1,$v0,'0' # convert digit to 0-9 value

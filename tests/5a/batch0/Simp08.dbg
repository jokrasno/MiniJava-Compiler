###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
988:mth_readInt_Lib:

    # save $ra by pushing onto stack
988#    subu $sp,$sp,4
992#    sw $ra,($sp)

996:  riSkipWhiteLoop:
    # read a character
996#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1000#    subu $t0,$v0,32
1004#    bgt $t0,$zero,nonWhite
1005##...slt $at,$zero,$t0
1009##...bne $at,$zero,1052
1012#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1016#    subu $t0,$v0,10
1020#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1024#    subu $t0,$v0,9
1028#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1032#    subu $t0,$v0,13
1036#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1040#    subu $t0,$v0,12
1044#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1048#    j badIntegerFormat # illegal integer char: abort program

1052:  nonWhite:
1052#    subu $t0,$v0,'-'
1056#    li $t4,1 # final multiplier
1060#    bne $t0,$zero,helpReadInt # go read
1064#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1068#    jal readLogicalChar

1072:  helpReadInt:
1072#    li $t2,10

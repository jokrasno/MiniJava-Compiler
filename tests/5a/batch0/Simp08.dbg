84:mth_main_Main:
84#  subu $sp,$sp,4
88#  sw $ra,($sp)
92#  li $t0,27
96#  subu $sp,$sp,8
100#  sw $s5,4($sp)
104#  sw $t0,($sp)
108#  subu $sp,$sp,4
112#  sw $s2,($sp)
116#  lw $t0,4($sp)
120#  subu $sp,$sp,8
124#  sw $s5,4($sp)
128#  sw $t0,($sp)
132#  li $t0,263
136#  subu $sp,$sp,8
140#  sw $s5,4($sp)
144#  sw $t0,($sp)
148#  lw $t2,($sp)
152#  addu $sp,$sp,8
156#  lw $t1,($sp)
160#  addu $sp,$sp,8
164#  addu $t0,$t1,$t2
168#  subu $sp,$sp,8
172#  sw $s5,4($sp)
176#  sw $t0,($sp)
180#  lw $t0,8($sp)
184#  sw $s2,8($sp)
188#  move $s2,$t0
192#  beq $s2,$zero,nullPtrException
196#  jal mth_printInt_Lib

    # limit
3196#    lw $t2,-12($t2) # vtable address
3200#    bge $t2,$t1,castException
3201##...slt $at,$t2,$t1
3205##...beq $at,$zero,3376
3208#    blt $t2,$t0,castException
3209##...slt $at,$t2,$t0
3213##...bne $at,$zero,3376
    
    # return, leaving object unchanged on stack
3216:  checkCastReturn:    
3216#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3220:instanceOf:
    # get object, go return false if null
3220#    lw $t2,($sp)
3224#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3228#    lw $t2,-12($t2) # vtable address
3232#    sge $t0,$t2,$t0 # are we >= the lower limit?
3233##...slt $t0,$t2,$t0
3237##...xori $t0,$t0,0x1
3240#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3244#    and $t2,$t0,$t1
3248#    sw $t2,($sp)
3252:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3252#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3256:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3256#    li $v0,4 # syscall-code for print-string
3260#    syscall
3264:exit:
    # print termination message
3264#    li $v0,4 # syscall-code for print-string
3268#    la $a0,exitString
3272#    syscall

    # print number of garbage collections
3276#    li $v0,4 # syscall-code for print-string
3280#    la $a0,gcCountMsg
3284#    syscall # print "Number of ..."
3288#    lw $a0,gcCount # number of GC's
3292#    li $v0,1 # code for print-int
3296#    syscall
3300#    li $v0,4 # syscall-code for print-string
3304#    la $a0,newlineString
3308#    syscall # print newline

    # terminate execution
3312#    li $v0,10 #syscall-code for "exit"
3316#    syscall

3320:outOfHeapMemory:
3320#    la $a0,heapMemoryMsg
3324#    j exitError
3328:divByZeroError:
3328#    la $a0,divByZeroMsg
3332#    j exitError
3336:strIndexOutOfBounds:
3336#    la $a0,strIndexOutOfBoundsMsg
3340#    j exitError
3344:arrayIndexOutOfBounds:
3344#    la $a0,arrayIndexOutOfBoundsMsg
3348#    j exitError
3352:arraySizeOutOfBounds:
3352#    la $a0,arraySizeOutOfBoundsMsg
3356#    j exitError
3360:nullPtrException:
3360#    la $a0,nullPtrExceptionMsg
3364#    j exitError
3368:badIntegerFormat:
3368#    la $a0,badIntegerFormatMsg
3372#    j exitError
3376:castException:
3376#    la $a0,castExceptionMsg
3380#    j exitError
############## data section ################
    .data
3564:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3580:cur_seg:
    .word 0

3584:lastCharRead:
    .word -2 # -2 => no buffered character
3588:prevHashConstant:
    .word 0x2785173c
3592:gcCount:
    .word 0

3596:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3623:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3646:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3681:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3715:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3748:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3779:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3827:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3848:gcMsg: 
      .asciiz "\nGC!\n"
3854:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3886:nullStr:
    .asciiz "null"
3891:trueString:
    .asciiz "true"
3896:falseString:
    .asciiz "false"
3902:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
3930:newlineString:
    .asciiz "\n"
    
    .align 2
3932:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3936:seg0_start:
    .space 0x100000
1052512:seg0_end:
1052512:seg1_start:
    .space 0x100000
2101088:seg1_end:

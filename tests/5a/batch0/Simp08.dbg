1101##...sltu $at,$t1,$t2
1105##...beq $at,$zero,1124

1108#    mul $t3,$t3,$t2 # multiply old value by 10
1109##...mult $t3,$t2
1113##...mflo $t3
1116#    addu $t3,$t3,$t1 # add in value of new digit
1120#    j digitLoop

1124:  doneDigitLoop:

    # "push back" unused character into queue

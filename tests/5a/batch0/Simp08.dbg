    # end-limit of the new segment, respectively,
    # Also, update cur_seg to refer to the other segment
2500#    lw $t0,cur_seg
2504#    move $t7,$s4
2508#    la $t6,seg1_start
2509##...lui $t6,16
2513##...addiu $t6,$t6,3936
2516#    la $s3,seg0_start
2520#    la $s4,seg0_end
2521##...lui $s4,16
2525##...addiu $s4,$s4,3936
2528#    sw $zero,cur_seg
2532#    bne $t0,$zero,skipGc1
2536#    la $t6,seg0_start

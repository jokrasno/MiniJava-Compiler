##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
244:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
244#    lw $t0,-8($s2) # get word with hash bits from this
248#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
252#    addu $t0,$t1

256#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
260:mth_equals_Object:
260#    move $t0,$s2 # first pointer (this)
264#    lw $t1,($sp) # second pointer
268#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
269##...subu $at,$t0,$t1
273##...sltiu $t0,$at,1

276#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
280:mth_hashCode_String:
280#    move $t0,$s2 # put this pointer in t0

284#    li $t2,0 # current hash value
288#    lw $t1,-4($t0) # negative of number of characters in string
292#    beq $t1,$zero,done_hashCode_String # if zero length => done
296#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
300#    and $t0,0xfffffffc # adjust for padding
301##...lui $at,65535
305##...ori $at,$at,0xfffc
309##...and $t0,$t0,$at
312#    subu $t1,$t0,$t1 # address at end of string +12
316:loop_hashCode_String:    
316#    sll $t4,$t2,5 # multiply by 32
320#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
324#    lbu $t3,-12($t0) # current character
328#    addu $t2,$t3 # add in current character
332#    addu $t0,1 # go to next character's address
336#    bne $t0,$t1,loop_hashCode_String # loop back if more
340:done_hashCode_String:    

    # push int on stack
340#    move $t0, $t2 # put $t2 in return slot
344#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
348:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
348#    subu $sp,4
352#    sw $ra,($sp)
    
    # get hash value
356#    lw $t2,-12($s2) # vtable address
360#    lw $t0,($t2) # method address
364#    jalr $t0
368#    subu $sp,8 # push result (int in $t0) on stack
372#    sw $s5,4($sp)
376#    sw $t0,($sp)

    # compute print-size of hash value
380#    li $t0, 1
384#    lw $t1, ($sp)
388#    srl $t1,$t1,4
392#    beq $t1,$zero,toString_skip_loop
396:toString_loop_top:
396#    addu $t0,1
400#    srl $t1,$t1,4
404#    bne $t1,$zero,toString_loop_top
408:toString_skip_loop:
408#    subu $sp,8
412#    sw $s5,4($sp)
416#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
420#    lw $t2,-12($s2) # vtable address
424#    move $t0,$t2
428:toString_checkTagBit:
428#    subu $t0,1
432#    lb $t1,($t0)
436#    and $t1,0x80
437##...lui $at,0
441##...ori $at,$at,0x80
445##...and $t1,$t1,$at
448#    beq $t1,$zero,toString_checkTagBit
452#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
456#    subu $sp,8
460#    sw $t1,($sp)
464#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
468#    move $s7,$zero # -4 offset header word
472#    lw $t4,8($sp) # bytes for hash value
476#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
480#    addu $t4,8
484#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
488#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

492#    li $t0,CLASS_String # store string vtable address into ...
496#    sw $t0,-12($s7) # ... -12 offset in object header
500#    lw $t2,-12($s2) # our object's vtable address
504#    lw $t5,4($sp) # number characters in prefix
508#    lw $t1,12($sp) # number of characters in hashcode
512#    addu $t3,$t1,$t5 # number of characters in string ...
516#    addu $t3,1 # ... including the '@' character
520#    subu $t0,$zero,$t3 # store negated length into ...
524#    sw $t0,-4($s7) # ... -4 offset header word
528#    lw $t0,-8($s7) # get -8 offset header-word
532#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
533##...slt $at,$t0,$zero
537##...beq $at,$zero,556
540#    and $t0,0xff # mask off object's hash value ...
541##...lui $at,0
545##...ori $at,$at,0xff
549##...and $t0,$t0,$at
552#    sw $t0,-8($s7) # ... and store back into -8 header-word
556:skipMask_toString:
556#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
560#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
564#    subu $t4,$t2,$t5
568:toString_copyLoop:    
568#    lb $t3,($t4)
572#    and $t3,0x7f # mask off sign bit (in case first word)
573##...lui $at,0
577##...ori $at,$at,0x7f
581##...and $t3,$t3,$at
584#    sb $t3,-8($t0)
588#    addu $t4,1
592#    addu $t0,1
596#    blt $t4,$t2,toString_copyLoop
597##...slt $at,$t4,$t2
601##...bne $at,$zero,568

    # copy the '@' sign
604#    li $t3,'@'
608#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
612#    addu $t2,$t0,$t1 # address of last byte in string to store +8
616#    lw $t3,20($sp) # hash code to print
620:toString_hashCopyLoop:
620#    and $t4,$t3,0xf
624#    srl $t3,4
628#    lb $t4,hexChars($t4)
632#    sb $t4,-8($t2)
636#    subu $t2,$t2,1
640#    bgt $t2,$t0,toString_hashCopyLoop
641##...slt $at,$t0,$t2
645##...bne $at,$zero,620

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
648#    addu $sp,28
652#    lw $ra,($sp)
656#    addu $sp,4
660#    move $t0, $s7 # return string we created
664#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
668:mth_equals_String:
    
    # quick test for obvious false
668#    lw $t0,($sp) # second parameter
672#    beq $t0,$zero,goEsFalse # go return false if null
676#    lw $t1,-12($t0) # vtable pointer
680#    la $t2,CLASS_String # string vtable pointer
684#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
688#    subu $sp,12
692#    sw $ra,8($sp)
696#    sw $s2,4($sp)
700#    sw $t0,($sp)
704#    jal mth_compareTo_String
708#    lw $s2, 4($sp) #restore this pointer and pop parameters
712#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
716#    seq $t0,$t0,$zero
717##...subu $at,$t0,$zero
721##...sltiu $t0,$at,1

    # pop return address and return $t0
724#    lw $ra,($sp)
728#    addu $sp,4

732#    jr $ra # return
    
736:goEsFalse:
    # put 0 in $t0 and return
736#    li $t0, 0
740#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
744:mth_toString_String:
    #we are a string, so return this.
744#    move $t0, $s2
748#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
752:mth_readLine_Lib:
    
752#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
756#    sw $ra, 4($sp) # save $ra
760#    move $t1,$sp # save "original" sp

764:  doRead:

    # read the character
764#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
768#    subu $t2,$v0,13
772#    bne $t2,$zero,notReturnRL
776#    jal readLogicalChar
780#    subu $t2,$v0,10 # check for newline
784#    beq $t2,$zero,foundNewLine

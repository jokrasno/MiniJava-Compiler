    # return
3120#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3124:divide:
    # get parameters; abort if divisor zero
3124#    lw $t0,($sp)
3128#    lw $t1,8($sp)
3132#    beq $t0,$zero,divByZeroError
    
    # perform division
3136#    div $t1,$t0
3140#    mflo $t0

    # store result, adjust stack and return
3144#    addu $sp,$sp,8 # adjust stack
3148#    sw $t0,($sp) # store result
3152#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3156:remainder:
    # get parameters; abort if divisor zero
3156#    lw $t0,($sp)
3160#    lw $t1,8($sp)
3164#    beq $t0,$zero,divByZeroError
    
    # perform division
3168#    div $t1,$t0
3172#    mfhi $t0

    # store result, adjust stack and return
3176#    addu $sp,$sp,8 # adjust stack
3180#    sw $t0,($sp) # store result
3184#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################

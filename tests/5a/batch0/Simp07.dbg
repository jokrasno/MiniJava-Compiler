#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3180:instanceOf:
    # get object, go return false if null
3180#    lw $t2,($sp)
3184#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3188#    lw $t2,-12($t2) # vtable address
3192#    sge $t0,$t2,$t0 # are we >= the lower limit?
3193##...slt $t0,$t2,$t0
3197##...xori $t0,$t0,0x1
3200#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3204#    and $t2,$t0,$t1
3208#    sw $t2,($sp)
3212:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3212#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3216:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3216#    li $v0,4 # syscall-code for print-string
3220#    syscall
3224:exit:
    # print termination message
3224#    li $v0,4 # syscall-code for print-string
3228#    la $a0,exitString
3232#    syscall

    # print number of garbage collections
3236#    li $v0,4 # syscall-code for print-string
3240#    la $a0,gcCountMsg
3244#    syscall # print "Number of ..."
3248#    lw $a0,gcCount # number of GC's
3252#    li $v0,1 # code for print-int
3256#    syscall
3260#    li $v0,4 # syscall-code for print-string
3264#    la $a0,newlineString
3268#    syscall # print newline

    # terminate execution
3272#    li $v0,10 #syscall-code for "exit"
3276#    syscall

3280:outOfHeapMemory:
3280#    la $a0,heapMemoryMsg
3284#    j exitError
3288:divByZeroError:
3288#    la $a0,divByZeroMsg
3292#    j exitError
3296:strIndexOutOfBounds:
3296#    la $a0,strIndexOutOfBoundsMsg
3300#    j exitError
3304:arrayIndexOutOfBounds:
3304#    la $a0,arrayIndexOutOfBoundsMsg
3308#    j exitError
3312:arraySizeOutOfBounds:
3312#    la $a0,arraySizeOutOfBoundsMsg
3316#    j exitError
3320:nullPtrException:
3320#    la $a0,nullPtrExceptionMsg
3324#    j exitError
3328:badIntegerFormat:
3328#    la $a0,badIntegerFormatMsg
3332#    j exitError
3336:castException:
3336#    la $a0,castExceptionMsg
3340#    j exitError
############## data section ################
    .data
3524:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3540:cur_seg:
    .word 0

3544:lastCharRead:
    .word -2 # -2 => no buffered character
3548:prevHashConstant:
    .word 0x2785173c
3552:gcCount:
    .word 0

3556:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3583:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3606:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3641:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3675:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3708:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3739:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3787:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3808:gcMsg: 
      .asciiz "\nGC!\n"
3814:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3846:nullStr:
    .asciiz "null"
3851:trueString:
    .asciiz "true"
3856:falseString:
    .asciiz "false"
3862:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
3890:newlineString:
    .asciiz "\n"
    
    .align 2
3892:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3896:seg0_start:
    .space 0x100000
1052472:seg0_end:
1052472:seg1_start:
    .space 0x100000
2101048:seg1_end:

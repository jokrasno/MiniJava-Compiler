##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
204:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
204#    lw $t0,-8($s2) # get word with hash bits from this
208#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
212#    addu $t0,$t1

216#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
220:mth_equals_Object:
220#    move $t0,$s2 # first pointer (this)
224#    lw $t1,($sp) # second pointer
228#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
229##...subu $at,$t0,$t1
233##...sltiu $t0,$at,1

236#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
240:mth_hashCode_String:
240#    move $t0,$s2 # put this pointer in t0

244#    li $t2,0 # current hash value
248#    lw $t1,-4($t0) # negative of number of characters in string
252#    beq $t1,$zero,done_hashCode_String # if zero length => done
256#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
260#    and $t0,0xfffffffc # adjust for padding
261##...lui $at,65535
265##...ori $at,$at,0xfffc
269##...and $t0,$t0,$at
272#    subu $t1,$t0,$t1 # address at end of string +12
276:loop_hashCode_String:    
276#    sll $t4,$t2,5 # multiply by 32
280#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
284#    lbu $t3,-12($t0) # current character
288#    addu $t2,$t3 # add in current character
292#    addu $t0,1 # go to next character's address
296#    bne $t0,$t1,loop_hashCode_String # loop back if more
300:done_hashCode_String:    

    # push int on stack
300#    move $t0, $t2 # put $t2 in return slot
304#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
308:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
308#    subu $sp,4
312#    sw $ra,($sp)
    
    # get hash value
316#    lw $t2,-12($s2) # vtable address
320#    lw $t0,($t2) # method address
324#    jalr $t0
328#    subu $sp,8 # push result (int in $t0) on stack
332#    sw $s5,4($sp)
336#    sw $t0,($sp)

    # compute print-size of hash value
340#    li $t0, 1
344#    lw $t1, ($sp)
348#    srl $t1,$t1,4
352#    beq $t1,$zero,toString_skip_loop
356:toString_loop_top:
356#    addu $t0,1
360#    srl $t1,$t1,4
364#    bne $t1,$zero,toString_loop_top
368:toString_skip_loop:
368#    subu $sp,8
372#    sw $s5,4($sp)
376#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
380#    lw $t2,-12($s2) # vtable address
384#    move $t0,$t2
388:toString_checkTagBit:
388#    subu $t0,1
392#    lb $t1,($t0)
396#    and $t1,0x80
397##...lui $at,0
401##...ori $at,$at,0x80
405##...and $t1,$t1,$at
408#    beq $t1,$zero,toString_checkTagBit
412#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
416#    subu $sp,8
420#    sw $t1,($sp)
424#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
428#    move $s7,$zero # -4 offset header word
432#    lw $t4,8($sp) # bytes for hash value
436#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
440#    addu $t4,8
444#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
448#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

452#    li $t0,CLASS_String # store string vtable address into ...
456#    sw $t0,-12($s7) # ... -12 offset in object header
460#    lw $t2,-12($s2) # our object's vtable address
464#    lw $t5,4($sp) # number characters in prefix
468#    lw $t1,12($sp) # number of characters in hashcode
472#    addu $t3,$t1,$t5 # number of characters in string ...
476#    addu $t3,1 # ... including the '@' character
480#    subu $t0,$zero,$t3 # store negated length into ...
484#    sw $t0,-4($s7) # ... -4 offset header word
488#    lw $t0,-8($s7) # get -8 offset header-word
492#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
493##...slt $at,$t0,$zero
497##...beq $at,$zero,516
500#    and $t0,0xff # mask off object's hash value ...
501##...lui $at,0
505##...ori $at,$at,0xff
509##...and $t0,$t0,$at
512#    sw $t0,-8($s7) # ... and store back into -8 header-word
516:skipMask_toString:
516#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
520#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
524#    subu $t4,$t2,$t5
528:toString_copyLoop:    
528#    lb $t3,($t4)
532#    and $t3,0x7f # mask off sign bit (in case first word)
533##...lui $at,0
537##...ori $at,$at,0x7f
541##...and $t3,$t3,$at
544#    sb $t3,-8($t0)
548#    addu $t4,1
552#    addu $t0,1
556#    blt $t4,$t2,toString_copyLoop
557##...slt $at,$t4,$t2
561##...bne $at,$zero,528

    # copy the '@' sign
564#    li $t3,'@'
568#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
572#    addu $t2,$t0,$t1 # address of last byte in string to store +8
576#    lw $t3,20($sp) # hash code to print
580:toString_hashCopyLoop:
580#    and $t4,$t3,0xf
584#    srl $t3,4
588#    lb $t4,hexChars($t4)
592#    sb $t4,-8($t2)
596#    subu $t2,$t2,1
600#    bgt $t2,$t0,toString_hashCopyLoop
601##...slt $at,$t0,$t2
605##...bne $at,$zero,580

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
608#    addu $sp,28
612#    lw $ra,($sp)
616#    addu $sp,4
620#    move $t0, $s7 # return string we created
624#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
628:mth_equals_String:
    
    # quick test for obvious false
628#    lw $t0,($sp) # second parameter
632#    beq $t0,$zero,goEsFalse # go return false if null
636#    lw $t1,-12($t0) # vtable pointer
640#    la $t2,CLASS_String # string vtable pointer
644#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
648#    subu $sp,12
652#    sw $ra,8($sp)
656#    sw $s2,4($sp)
660#    sw $t0,($sp)
664#    jal mth_compareTo_String
668#    lw $s2, 4($sp) #restore this pointer and pop parameters
672#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
676#    seq $t0,$t0,$zero
677##...subu $at,$t0,$zero
681##...sltiu $t0,$at,1

    # pop return address and return $t0
684#    lw $ra,($sp)
688#    addu $sp,4

692#    jr $ra # return
    
696:goEsFalse:
    # put 0 in $t0 and return
696#    li $t0, 0
700#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
704:mth_toString_String:
    #we are a string, so return this.
704#    move $t0, $s2
708#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
712:mth_readLine_Lib:
    
712#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
716#    sw $ra, 4($sp) # save $ra
720#    move $t1,$sp # save "original" sp

724:  doRead:

    # read the character
724#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
728#    subu $t2,$v0,13
732#    bne $t2,$zero,notReturnRL
736#    jal readLogicalChar
740#    subu $t2,$v0,10 # check for newline
744#    beq $t2,$zero,foundNewLine
748#    sw $v0,lastCharRead # push back character into queue
752#    j foundNewLine # go process the line

756:  notReturnRL:

    # at this point, $v0 has our character

756#    subu $t0,$v0,10
760#    beq $t0,$zero,foundNewLine
764#    blt $v0,$zero,foundEof
765##...slt $at,$v0,$zero
769##...bne $at,$zero,784


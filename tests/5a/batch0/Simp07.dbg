84:mth_main_Main:
84#  subu $sp,$sp,4
88#  sw $ra,($sp)
92#  li $t0,27
96#  subu $sp,$sp,8
100#  sw $s5,4($sp)
104#  sw $t0,($sp)
108#  subu $sp,$sp,4
112#  sw $s2,($sp)
116#  lw $t0,4($sp)
120#  subu $sp,$sp,8
124#  sw $s5,4($sp)
128#  sw $t0,($sp)
132#  lw $t0,8($sp)
136#  sw $s2,8($sp)
140#  move $s2,$t0
144#  beq $s2,$zero,nullPtrException
148#  lw $t0,-12($s2)
152#  lw $t0,32($t0)
156#  jalr $t0
160#  addu $sp,$sp,8
164#  lw $s2,($sp)
168#  addu $sp,$sp,4

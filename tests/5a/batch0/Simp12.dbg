###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
884:mth_readLine_Lib:
    
884#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
888#    sw $ra, 4($sp) # save $ra
892#    move $t1,$sp # save "original" sp

896:  doRead:

    # read the character
896#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
900#    subu $t2,$v0,13
904#    bne $t2,$zero,notReturnRL
908#    jal readLogicalChar
912#    subu $t2,$v0,10 # check for newline
916#    beq $t2,$zero,foundNewLine
920#    sw $v0,lastCharRead # push back character into queue
924#    j foundNewLine # go process the line

928:  notReturnRL:

    # at this point, $v0 has our character

928#    subu $t0,$v0,10
932#    beq $t0,$zero,foundNewLine
936#    blt $v0,$zero,foundEof
937##...slt $at,$v0,$zero
941##...bne $at,$zero,956

    # we have a character, so push it onto stack
944#    subu $sp,$sp,4
948#    sw $v0,($sp)

    # loop back up to get next character
952#    j doRead

956:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
956#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
960#    li $s7, 0 # return-value: null
964#    j rlReturn # return

968:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
968#    subu $t0,$t1,$sp # number of chars we read (times 4)
972#    srl $s6,$t0,2 # number of words on stack with chars
976#    subu $sp,$sp,4 # push char-count ...
980#    sw $s6,($sp) # ... onto stack
984#    addu $t2,$t0,5 # GC tag, incl. for count-word
988#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
992#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
996#    srl $s6,$s6,2  # data words in object
1000#    move $s7,$zero # object words in object
1004#    jal newObject  # allocate space
    
    # store header words
1008#    la $t0,CLASS_String
1012#    sw $t0,-12($s7)# store class tag (String) into object
1016#    lw $t2,4($sp) # char-count
1020#    sll $t1,$t2,2 # 4 times number of chars
1024#    subu $t2,$zero,$t2 # negative of char-count
1028#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1032#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1036#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1037##...slt $at,$t0,$zero
1041##...beq $at,$zero,1060
1044#    and $t0,0xff # mask off object's hash value ...
1045##...lui $at,0
1049##...ori $at,$at,0xff
1053##...and $t0,$t0,$at
1056#    sw $t0,-8($s7) # ... and store back into -8 header-word
1060:  skipMask_readLine:

1060#    sll $t0,$t0,2 # data bytes in object
1064#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1068#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1072#    addu $sp,$sp,8 # pop redundant object-pointer and count
1076#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1080#    beq $sp,$t1,rlReturn
1084:  charCopyLoop:
1084#    lw $t2,($sp)
1088#    sb $t2,-9($t0)
1092#    addu $sp,$sp,4
1096#    subu $t0,$t0,1
1100#    bne $sp,$t1,charCopyLoop
1104:  rlReturn:

1104#    lw $ra, 4($sp)
1108#    addu $sp, 8   # pop $ra and pointless word off stack
1112#    move $t0, $s7 # return string we allocated in $s7
1116#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1120:mth_readInt_Lib:

    # save $ra by pushing onto stack
1120#    subu $sp,$sp,4
1124#    sw $ra,($sp)

1128:  riSkipWhiteLoop:
    # read a character
1128#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1132#    subu $t0,$v0,32
1136#    bgt $t0,$zero,nonWhite
1137##...slt $at,$zero,$t0
1141##...bne $at,$zero,1184
1144#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1148#    subu $t0,$v0,10
1152#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1156#    subu $t0,$v0,9
1160#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1164#    subu $t0,$v0,13
1168#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1172#    subu $t0,$v0,12
1176#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1180#    j badIntegerFormat # illegal integer char: abort program

1184:  nonWhite:
1184#    subu $t0,$v0,'-'
1188#    li $t4,1 # final multiplier
1192#    bne $t0,$zero,helpReadInt # go read
1196#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1200#    jal readLogicalChar

1204:  helpReadInt:
1204#    li $t2,10
1208#    subu $t1,$v0,'0' # convert digit to 0-9 value
1212#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1213##...sltu $at,$t1,$t2
1217##...beq $at,$zero,3500
1220#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1224:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1224#    jal readLogicalChar # read next character
1228#    subu $t1,$v0,'0' # convert digit to 0-9 value
1232#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1233##...sltu $at,$t1,$t2
1237##...beq $at,$zero,1256

1240#    mul $t3,$t3,$t2 # multiply old value by 10
1241##...mult $t3,$t2
1245##...mflo $t3
1248#    addu $t3,$t3,$t1 # add in value of new digit
1252#    j digitLoop

1256:  doneDigitLoop:

    # "push back" unused character into queue
1256#    sw $v0,lastCharRead

    # restore return address
1260#    lw $ra,($sp)
1264#    addu $sp, 4

    # multiply by sign and put return value in $t0
1268#    mult $t3,$t4 # multiply to account for poss. minus sign
1272#    mflo $t3
1276#    move $t0, $t3
    
    # return
1280#    jr $ra

###################################################################
# readChar() - library method (class Lib)
# - reads a single character from standard input

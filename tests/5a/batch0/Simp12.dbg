##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
376:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
376#    lw $t0,-8($s2) # get word with hash bits from this
380#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
384#    addu $t0,$t1

388#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
392:mth_equals_Object:
392#    move $t0,$s2 # first pointer (this)
396#    lw $t1,($sp) # second pointer
400#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
401##...subu $at,$t0,$t1
405##...sltiu $t0,$at,1

408#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
412:mth_hashCode_String:
412#    move $t0,$s2 # put this pointer in t0

416#    li $t2,0 # current hash value
420#    lw $t1,-4($t0) # negative of number of characters in string
424#    beq $t1,$zero,done_hashCode_String # if zero length => done
428#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
432#    and $t0,0xfffffffc # adjust for padding
433##...lui $at,65535
437##...ori $at,$at,0xfffc
441##...and $t0,$t0,$at
444#    subu $t1,$t0,$t1 # address at end of string +12
448:loop_hashCode_String:    
448#    sll $t4,$t2,5 # multiply by 32
452#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
456#    lbu $t3,-12($t0) # current character
460#    addu $t2,$t3 # add in current character
464#    addu $t0,1 # go to next character's address
468#    bne $t0,$t1,loop_hashCode_String # loop back if more
472:done_hashCode_String:    

    # push int on stack
472#    move $t0, $t2 # put $t2 in return slot
476#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
480:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
480#    subu $sp,4
484#    sw $ra,($sp)
    
    # get hash value
488#    lw $t2,-12($s2) # vtable address
492#    lw $t0,($t2) # method address
496#    jalr $t0
500#    subu $sp,8 # push result (int in $t0) on stack
504#    sw $s5,4($sp)
508#    sw $t0,($sp)

    # compute print-size of hash value
512#    li $t0, 1
516#    lw $t1, ($sp)
520#    srl $t1,$t1,4
524#    beq $t1,$zero,toString_skip_loop
528:toString_loop_top:
528#    addu $t0,1
532#    srl $t1,$t1,4
536#    bne $t1,$zero,toString_loop_top
540:toString_skip_loop:
540#    subu $sp,8
544#    sw $s5,4($sp)
548#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
552#    lw $t2,-12($s2) # vtable address
556#    move $t0,$t2
560:toString_checkTagBit:
560#    subu $t0,1
564#    lb $t1,($t0)
568#    and $t1,0x80
569##...lui $at,0
573##...ori $at,$at,0x80
577##...and $t1,$t1,$at
580#    beq $t1,$zero,toString_checkTagBit
584#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
588#    subu $sp,8
592#    sw $t1,($sp)
596#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
600#    move $s7,$zero # -4 offset header word
604#    lw $t4,8($sp) # bytes for hash value
608#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
612#    addu $t4,8
616#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
620#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

624#    li $t0,CLASS_String # store string vtable address into ...
628#    sw $t0,-12($s7) # ... -12 offset in object header
632#    lw $t2,-12($s2) # our object's vtable address
636#    lw $t5,4($sp) # number characters in prefix
640#    lw $t1,12($sp) # number of characters in hashcode
644#    addu $t3,$t1,$t5 # number of characters in string ...
648#    addu $t3,1 # ... including the '@' character
652#    subu $t0,$zero,$t3 # store negated length into ...
656#    sw $t0,-4($s7) # ... -4 offset header word
660#    lw $t0,-8($s7) # get -8 offset header-word
664#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
665##...slt $at,$t0,$zero
669##...beq $at,$zero,688
672#    and $t0,0xff # mask off object's hash value ...
673##...lui $at,0
677##...ori $at,$at,0xff
681##...and $t0,$t0,$at
684#    sw $t0,-8($s7) # ... and store back into -8 header-word
688:skipMask_toString:
688#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
692#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
696#    subu $t4,$t2,$t5
700:toString_copyLoop:    
700#    lb $t3,($t4)
704#    and $t3,0x7f # mask off sign bit (in case first word)
705##...lui $at,0
709##...ori $at,$at,0x7f
713##...and $t3,$t3,$at
716#    sb $t3,-8($t0)
720#    addu $t4,1
724#    addu $t0,1
728#    blt $t4,$t2,toString_copyLoop
729##...slt $at,$t4,$t2
733##...bne $at,$zero,700

    # copy the '@' sign
736#    li $t3,'@'
740#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
744#    addu $t2,$t0,$t1 # address of last byte in string to store +8
748#    lw $t3,20($sp) # hash code to print
752:toString_hashCopyLoop:
752#    and $t4,$t3,0xf
756#    srl $t3,4
760#    lb $t4,hexChars($t4)
764#    sb $t4,-8($t2)
768#    subu $t2,$t2,1
772#    bgt $t2,$t0,toString_hashCopyLoop
773##...slt $at,$t0,$t2
777##...bne $at,$zero,752

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
780#    addu $sp,28
784#    lw $ra,($sp)
788#    addu $sp,4
792#    move $t0, $s7 # return string we created
796#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
800:mth_equals_String:
    
    # quick test for obvious false
800#    lw $t0,($sp) # second parameter
804#    beq $t0,$zero,goEsFalse # go return false if null
808#    lw $t1,-12($t0) # vtable pointer
812#    la $t2,CLASS_String # string vtable pointer
816#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
820#    subu $sp,12
824#    sw $ra,8($sp)
828#    sw $s2,4($sp)
832#    sw $t0,($sp)
836#    jal mth_compareTo_String
840#    lw $s2, 4($sp) #restore this pointer and pop parameters
844#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
848#    seq $t0,$t0,$zero
849##...subu $at,$t0,$zero
853##...sltiu $t0,$at,1

    # pop return address and return $t0
856#    lw $ra,($sp)
860#    addu $sp,4

864#    jr $ra # return
    
868:goEsFalse:
    # put 0 in $t0 and return
868#    li $t0, 0
872#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################

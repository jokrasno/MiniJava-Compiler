########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
3228:vm_init:

    # mark bottom of stack
3228#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
3232#    move $s2,$zero

    #set up the "five" register
3236#    li $s5,5

3240#    la $s3,seg0_start
3244#    la $s4,seg0_end
3245##...lui $s4,16
3249##...addiu $s4,$s4,4084
    
    # return
3252#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3256:divide:
    # get parameters; abort if divisor zero
3256#    lw $t0,($sp)
3260#    lw $t1,8($sp)
3264#    beq $t0,$zero,divByZeroError
    
    # perform division
3268#    div $t1,$t0
3272#    mflo $t0

    # store result, adjust stack and return
3276#    addu $sp,$sp,8 # adjust stack
3280#    sw $t0,($sp) # store result
3284#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3288:remainder:
    # get parameters; abort if divisor zero
3288#    lw $t0,($sp)
3292#    lw $t1,8($sp)
3296#    beq $t0,$zero,divByZeroError
    
    # perform division
3300#    div $t1,$t0
3304#    mfhi $t0

    # store result, adjust stack and return
3308#    addu $sp,$sp,8 # adjust stack
3312#    sw $t0,($sp) # store result
3316#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3320:checkCast:
    # get object, allow immediately if null
3320#    lw $t2,($sp)
3324#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3328#    lw $t2,-12($t2) # vtable address
3332#    bge $t2,$t1,castException
3333##...slt $at,$t2,$t1
3337##...beq $at,$zero,3508
3340#    blt $t2,$t0,castException
3341##...slt $at,$t2,$t0
3345##...bne $at,$zero,3508
    
    # return, leaving object unchanged on stack
3348:  checkCastReturn:    
3348#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3352:instanceOf:
    # get object, go return false if null
3352#    lw $t2,($sp)
3356#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3360#    lw $t2,-12($t2) # vtable address
3364#    sge $t0,$t2,$t0 # are we >= the lower limit?
3365##...slt $t0,$t2,$t0
3369##...xori $t0,$t0,0x1
3372#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3376#    and $t2,$t0,$t1
3380#    sw $t2,($sp)
3384:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3384#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3388:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3388#    li $v0,4 # syscall-code for print-string
3392#    syscall
3396:exit:
    # print termination message
3396#    li $v0,4 # syscall-code for print-string
3400#    la $a0,exitString
3404#    syscall

    # print number of garbage collections
3408#    li $v0,4 # syscall-code for print-string
3412#    la $a0,gcCountMsg
3416#    syscall # print "Number of ..."
3420#    lw $a0,gcCount # number of GC's
3424#    li $v0,1 # code for print-int
3428#    syscall
3432#    li $v0,4 # syscall-code for print-string
3436#    la $a0,newlineString
3440#    syscall # print newline

    # terminate execution
3444#    li $v0,10 #syscall-code for "exit"
3448#    syscall

3452:outOfHeapMemory:
3452#    la $a0,heapMemoryMsg
3456#    j exitError
3460:divByZeroError:
3460#    la $a0,divByZeroMsg
3464#    j exitError
3468:strIndexOutOfBounds:
3468#    la $a0,strIndexOutOfBoundsMsg
3472#    j exitError
3476:arrayIndexOutOfBounds:
3476#    la $a0,arrayIndexOutOfBoundsMsg
3480#    j exitError
3484:arraySizeOutOfBounds:
3484#    la $a0,arraySizeOutOfBoundsMsg
3488#    j exitError
3492:nullPtrException:
3492#    la $a0,nullPtrExceptionMsg
3496#    j exitError
3500:badIntegerFormat:
3500#    la $a0,badIntegerFormatMsg
3504#    j exitError
3508:castException:
3508#    la $a0,castExceptionMsg
3512#    j exitError
############## data section ################
    .data
3712:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3728:cur_seg:
    .word 0

3732:lastCharRead:
    .word -2 # -2 => no buffered character
3736:prevHashConstant:
    .word 0x2785173c
3740:gcCount:
    .word 0

3744:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3771:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3794:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3829:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3863:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3896:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3927:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3975:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3996:gcMsg: 
      .asciiz "\nGC!\n"
4002:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4034:nullStr:
    .asciiz "null"
4039:trueString:
    .asciiz "true"
4044:falseString:
    .asciiz "false"
4050:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
4078:newlineString:
    .asciiz "\n"
    
    .align 2
4080:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4084:seg0_start:
    .space 0x100000
1052660:seg0_end:
1052660:seg1_start:
    .space 0x100000
2101236:seg1_end:

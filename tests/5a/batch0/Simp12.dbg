    # compute the amount of space that is needed
3080#    bge $t8,$zero,gcSkip5 # # words in negative-offset portion
3081##...slt $at,$t8,$zero
3085##...beq $at,$zero,3100
3088#    and $t8,0xff # mask off hash bits
3089##...lui $at,0
3093##...ori $at,$at,0xff
3097##...and $t8,$t8,$at

2509##...bne $at,$zero,2492

    # at this point:
    #  $s3 has been updated to point to the next free slot,
    #    which is also the points just past our object

    # compute pointer value and set up header-words
2512#    sll $t0,$s7,2    # number of post-header bytes
2516#    subu $t0,$s3,$t0 # pointer that we will return

    # determine the value to store in the first header-word:
    # if <= 255 (unsigned):
    #  - it goes into low byte
    #  - hash bits go into high three bytes, with top bit being 1
    # if >255 (unsigned)
    #  - it goes into full word (with a 0 in the high bit)
    
2520#    li $t2,255
2524#    bgeu $s6,$t2 firstHeaderLarge
2525##...sltu $at,$s6,$t2
2529##...beq $at,$zero,2576
2532#    lw $t1,prevHashConstant
2536#    addu $t1,0x12b68fd2
2537##...lui $at,4791
2541##...addiu $at,$at,-28718
2545##...addu $t1,$at,$t1
2548#    sw $t1,prevHashConstant # update hash constant
2552#    or $t1,0x80000000 # set top bit
2553##...lui $at,32768
2557##...or $t1,$at,$t1
2560#    and $t1,0xffffff00 # clear low bit
2561##...lui $at,65535
2565##...ori $at,$at,0xff00
2569##...and $t1,$t1,$at
2572#    or $s6,$t1
2576:firstHeaderLarge:
2576#    sw $s6,-8($t0) # store header-1 value
2580#    lw $zero,-8($t0)

    # store second header-value
2584#    sw $s7,-4($t0)   # second header-word
2588#    lw $zero,-4($t0)
    
    # put return-value into $s7 and also push it onto top of stack
2592#    move $s7,$t0
2596#    subu $sp,$sp,4
2600#    sw $t0,($sp)

2604#    jr $ra
    
2608:  doGC:
    #####################################################
    # We need to do a garbage-collect
    #####################################################
 
     ####### print that we are doing a GC ########
     ####### THESE THREE LINES WILL NORMALLY BE COMMENTED OUT #######
#         la $a0,gcMsg # prints message: "GC!" 
#         li $v0,4 # syscall-code for print-string 
#         syscall 
       

    # if we've already done a GC for this allocation, then
    # we are actually out heap-memory: abort program
2608#    bne $t5,$zero,outOfHeapMemory
      
    # increment the number of times we've done a GC, for later reporting
2612#    lw $t5,gcCount
2616#    addu $t5,1
2620#    sw $t5,gcCount

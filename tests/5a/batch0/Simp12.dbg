    # - $t0 contains the pointer to the second string object
    # - $t1 contains the pointer to the first string object
    # - $t5 contains the value to return if the strings compare equal up
    #   to the length of the shortest word

    # get begin-of-string addresses
2336#    lw $t2,-8($t0) # # data words in second string
2340#    lw $t3,-8($t1) # # data words in first string
2344#    sll $t2,$t2,2 # byte-offset to beginning of str2 (+8)
2348#    sll $t3,$t3,2 # byte-offset to beginning of str1 (+8)
2352#    subu $t0,$t0,$t2 # beginning of str1 address (+8)
2356#    subu $t1,$t1,$t3 # beginning of str2 address (+8)
    
    # put $t1-limit into $t2

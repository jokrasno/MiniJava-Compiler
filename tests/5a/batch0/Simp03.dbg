3145##...beq $at,$zero,3316
3148#    blt $t2,$t0,castException
3149##...slt $at,$t2,$t0
3153##...bne $at,$zero,3316
    
    # return, leaving object unchanged on stack
3156:  checkCastReturn:    
3156#    jr $ra    

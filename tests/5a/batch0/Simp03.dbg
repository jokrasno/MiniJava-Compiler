###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
928:mth_readInt_Lib:

    # save $ra by pushing onto stack
928#    subu $sp,$sp,4
932#    sw $ra,($sp)

936:  riSkipWhiteLoop:
    # read a character
936#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
940#    subu $t0,$v0,32
944#    bgt $t0,$zero,nonWhite
945##...slt $at,$zero,$t0
949##...bne $at,$zero,992
952#    beq $t0,$zero,riSkipWhiteLoop # start over if space
956#    subu $t0,$v0,10
960#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
964#    subu $t0,$v0,9
968#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
972#    subu $t0,$v0,13
976#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
980#    subu $t0,$v0,12
984#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
988#    j badIntegerFormat # illegal integer char: abort program

992:  nonWhite:
992#    subu $t0,$v0,'-'
996#    li $t4,1 # final multiplier
1000#    bne $t0,$zero,helpReadInt # go read
1004#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1008#    jal readLogicalChar

1012:  helpReadInt:
1012#    li $t2,10
1016#    subu $t1,$v0,'0' # convert digit to 0-9 value
1020#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1021##...sltu $at,$t1,$t2
1025##...beq $at,$zero,3308
1028#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1032:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1032#    jal readLogicalChar # read next character
1036#    subu $t1,$v0,'0' # convert digit to 0-9 value
1040#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1041##...sltu $at,$t1,$t2
1045##...beq $at,$zero,1064

1048#    mul $t3,$t3,$t2 # multiply old value by 10
1049##...mult $t3,$t2
1053##...mflo $t3
1056#    addu $t3,$t3,$t1 # add in value of new digit
1060#    j digitLoop

1064:  doneDigitLoop:

    # "push back" unused character into queue
1064#    sw $v0,lastCharRead

    # restore return address
1068#    lw $ra,($sp)
1072#    addu $sp, 4

    # multiply by sign and put return value in $t0
1076#    mult $t3,$t4 # multiply to account for poss. minus sign
1080#    mflo $t3
1084#    move $t0, $t3
    
    # return
1088#    jr $ra

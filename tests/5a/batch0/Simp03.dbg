3052#    la $s4,seg0_end
3053##...lui $s4,16
3057##...addiu $s4,$s4,3876
    
    # return
3060#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3064:divide:
    # get parameters; abort if divisor zero
3064#    lw $t0,($sp)
3068#    lw $t1,8($sp)
3072#    beq $t0,$zero,divByZeroError
    
    # perform division
3076#    div $t1,$t0
3080#    mflo $t0

    # store result, adjust stack and return
3084#    addu $sp,$sp,8 # adjust stack
3088#    sw $t0,($sp) # store result
3092#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3096:remainder:
    # get parameters; abort if divisor zero
3096#    lw $t0,($sp)
3100#    lw $t1,8($sp)
3104#    beq $t0,$zero,divByZeroError
    
    # perform division
3108#    div $t1,$t0
3112#    mfhi $t0

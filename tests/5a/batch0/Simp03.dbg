0:main:
0#  jal vm_init
4#  li $s6,1
8#  li $s7,0
12#  jal newObject
16#  la $t0,CLASS_Main
20#  sw $t0,-12($s7)
24#  lw $t0,0($sp)
28#  sw $s2,0($sp)
32#  move $s2,$t0
36#  beq $s2,$zero,nullPtrException
40#  lw $t0,-12($s2)
44#  lw $t0,44($t0)
48#  jalr $t0
52#  lw $s2,($sp)
56#  addu $sp,$sp,4
60#  move $t0,$zero
64#  subu $sp,$sp,4
68#  sw $t0,($sp)
72#  addu $sp,$sp,4
76#  li $v0, 10
80#  syscall
84:mth_main_Main:
84#  subu $sp,$sp,4
88#  sw $ra,($sp)
92#  subu $sp,$sp,4
96#  sw $s2,($sp)
100#  li $t0,345
104#  subu $sp,$sp,8
108#  sw $s5,4($sp)
112#  sw $t0,($sp)
116#  lw $t0,8($sp)
120#  sw $s2,8($sp)
124#  move $s2,$t0
128#  beq $s2,$zero,nullPtrException
132#  lw $t0,-12($s2)
136#  lw $t0,32($t0)
140#  jalr $t0
144#  addu $sp,$sp,8
148#  lw $s2,($sp)
152#  addu $sp,$sp,4
156#  move $t0,$zero
160#  subu $sp,$sp,4
164#  sw $t0,($sp)
168#  addu $sp,$sp,4
172#  lw $ra,($sp)
176#  addu $sp,$sp,4
180#  jr $ra
##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
184:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
184#    lw $t0,-8($s2) # get word with hash bits from this
188#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
192#    addu $t0,$t1

196#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
200:mth_equals_Object:
200#    move $t0,$s2 # first pointer (this)
204#    lw $t1,($sp) # second pointer
208#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
209##...subu $at,$t0,$t1
213##...sltiu $t0,$at,1

216#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
220:mth_hashCode_String:
220#    move $t0,$s2 # put this pointer in t0

224#    li $t2,0 # current hash value
228#    lw $t1,-4($t0) # negative of number of characters in string
232#    beq $t1,$zero,done_hashCode_String # if zero length => done
236#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
240#    and $t0,0xfffffffc # adjust for padding
241##...lui $at,65535
245##...ori $at,$at,0xfffc
249##...and $t0,$t0,$at
252#    subu $t1,$t0,$t1 # address at end of string +12
256:loop_hashCode_String:    
256#    sll $t4,$t2,5 # multiply by 32
260#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
264#    lbu $t3,-12($t0) # current character
268#    addu $t2,$t3 # add in current character
272#    addu $t0,1 # go to next character's address
276#    bne $t0,$t1,loop_hashCode_String # loop back if more
280:done_hashCode_String:    

    # push int on stack
280#    move $t0, $t2 # put $t2 in return slot
284#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
288:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
288#    subu $sp,4
292#    sw $ra,($sp)
    
    # get hash value
296#    lw $t2,-12($s2) # vtable address
300#    lw $t0,($t2) # method address
304#    jalr $t0
308#    subu $sp,8 # push result (int in $t0) on stack
312#    sw $s5,4($sp)
316#    sw $t0,($sp)

    # compute print-size of hash value
320#    li $t0, 1
324#    lw $t1, ($sp)
328#    srl $t1,$t1,4
332#    beq $t1,$zero,toString_skip_loop
336:toString_loop_top:
336#    addu $t0,1
340#    srl $t1,$t1,4
344#    bne $t1,$zero,toString_loop_top
348:toString_skip_loop:
348#    subu $sp,8
352#    sw $s5,4($sp)
356#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
360#    lw $t2,-12($s2) # vtable address
364#    move $t0,$t2
368:toString_checkTagBit:
368#    subu $t0,1
372#    lb $t1,($t0)
376#    and $t1,0x80
377##...lui $at,0
381##...ori $at,$at,0x80
385##...and $t1,$t1,$at
388#    beq $t1,$zero,toString_checkTagBit
392#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
396#    subu $sp,8
400#    sw $t1,($sp)
404#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
408#    move $s7,$zero # -4 offset header word
412#    lw $t4,8($sp) # bytes for hash value
416#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
420#    addu $t4,8
424#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
428#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

432#    li $t0,CLASS_String # store string vtable address into ...
436#    sw $t0,-12($s7) # ... -12 offset in object header
440#    lw $t2,-12($s2) # our object's vtable address
444#    lw $t5,4($sp) # number characters in prefix
448#    lw $t1,12($sp) # number of characters in hashcode
452#    addu $t3,$t1,$t5 # number of characters in string ...
456#    addu $t3,1 # ... including the '@' character
460#    subu $t0,$zero,$t3 # store negated length into ...
464#    sw $t0,-4($s7) # ... -4 offset header word
468#    lw $t0,-8($s7) # get -8 offset header-word
472#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
473##...slt $at,$t0,$zero
477##...beq $at,$zero,496
480#    and $t0,0xff # mask off object's hash value ...
481##...lui $at,0
485##...ori $at,$at,0xff
489##...and $t0,$t0,$at
492#    sw $t0,-8($s7) # ... and store back into -8 header-word
496:skipMask_toString:
496#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
500#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
504#    subu $t4,$t2,$t5
508:toString_copyLoop:    
508#    lb $t3,($t4)
512#    and $t3,0x7f # mask off sign bit (in case first word)
513##...lui $at,0
517##...ori $at,$at,0x7f
521##...and $t3,$t3,$at
524#    sb $t3,-8($t0)
528#    addu $t4,1
532#    addu $t0,1
536#    blt $t4,$t2,toString_copyLoop
537##...slt $at,$t4,$t2
541##...bne $at,$zero,508

    # copy the '@' sign
544#    li $t3,'@'
548#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
552#    addu $t2,$t0,$t1 # address of last byte in string to store +8
556#    lw $t3,20($sp) # hash code to print
560:toString_hashCopyLoop:
560#    and $t4,$t3,0xf
564#    srl $t3,4
568#    lb $t4,hexChars($t4)
572#    sb $t4,-8($t2)
576#    subu $t2,$t2,1
580#    bgt $t2,$t0,toString_hashCopyLoop
581##...slt $at,$t0,$t2
585##...bne $at,$zero,560

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
588#    addu $sp,28
592#    lw $ra,($sp)
596#    addu $sp,4
600#    move $t0, $s7 # return string we created
604#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
608:mth_equals_String:
    
    # quick test for obvious false
608#    lw $t0,($sp) # second parameter
612#    beq $t0,$zero,goEsFalse # go return false if null
616#    lw $t1,-12($t0) # vtable pointer
620#    la $t2,CLASS_String # string vtable pointer
624#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
628#    subu $sp,12
632#    sw $ra,8($sp)
636#    sw $s2,4($sp)
640#    sw $t0,($sp)
644#    jal mth_compareTo_String
648#    lw $s2, 4($sp) #restore this pointer and pop parameters
652#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
656#    seq $t0,$t0,$zero
657##...subu $at,$t0,$zero
661##...sltiu $t0,$at,1

    # pop return address and return $t0
664#    lw $ra,($sp)
668#    addu $sp,4

672#    jr $ra # return
    
676:goEsFalse:
    # put 0 in $t0 and return
676#    li $t0, 0
680#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
684:mth_toString_String:
    #we are a string, so return this.
684#    move $t0, $s2
688#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
692:mth_readLine_Lib:
    
692#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
696#    sw $ra, 4($sp) # save $ra
700#    move $t1,$sp # save "original" sp

704:  doRead:

    # read the character
704#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
708#    subu $t2,$v0,13
712#    bne $t2,$zero,notReturnRL
716#    jal readLogicalChar
720#    subu $t2,$v0,10 # check for newline
724#    beq $t2,$zero,foundNewLine
728#    sw $v0,lastCharRead # push back character into queue
732#    j foundNewLine # go process the line

736:  notReturnRL:

    # at this point, $v0 has our character

736#    subu $t0,$v0,10
740#    beq $t0,$zero,foundNewLine
744#    blt $v0,$zero,foundEof
745##...slt $at,$v0,$zero
749##...bne $at,$zero,764

    # we have a character, so push it onto stack
752#    subu $sp,$sp,4
756#    sw $v0,($sp)

    # loop back up to get next character
760#    j doRead

764:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
764#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
768#    li $s7, 0 # return-value: null
772#    j rlReturn # return

776:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
776#    subu $t0,$t1,$sp # number of chars we read (times 4)
780#    srl $s6,$t0,2 # number of words on stack with chars
784#    subu $sp,$sp,4 # push char-count ...
788#    sw $s6,($sp) # ... onto stack
792#    addu $t2,$t0,5 # GC tag, incl. for count-word
796#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
800#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
804#    srl $s6,$s6,2  # data words in object
808#    move $s7,$zero # object words in object
812#    jal newObject  # allocate space
    
    # store header words
816#    la $t0,CLASS_String
820#    sw $t0,-12($s7)# store class tag (String) into object
824#    lw $t2,4($sp) # char-count
828#    sll $t1,$t2,2 # 4 times number of chars
832#    subu $t2,$zero,$t2 # negative of char-count
836#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
840#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
844#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
845##...slt $at,$t0,$zero
849##...beq $at,$zero,868
852#    and $t0,0xff # mask off object's hash value ...
853##...lui $at,0
857##...ori $at,$at,0xff
861##...and $t0,$t0,$at
864#    sw $t0,-8($s7) # ... and store back into -8 header-word
868:  skipMask_readLine:

868#    sll $t0,$t0,2 # data bytes in object
872#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
876#    subu $t0,$t0,$t2 # place to store last character (plus 9)
880#    addu $sp,$sp,8 # pop redundant object-pointer and count
884#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

888#    beq $sp,$t1,rlReturn
892:  charCopyLoop:
892#    lw $t2,($sp)
896#    sb $t2,-9($t0)
900#    addu $sp,$sp,4
904#    subu $t0,$t0,1
908#    bne $sp,$t1,charCopyLoop
912:  rlReturn:

912#    lw $ra, 4($sp)
916#    addu $sp, 8   # pop $ra and pointless word off stack
920#    move $t0, $s7 # return string we allocated in $s7
924#    jr $ra

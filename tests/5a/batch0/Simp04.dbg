944#    subu $t0,$v0,10
948#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
952#    subu $t0,$v0,9
956#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
960#    subu $t0,$v0,13
964#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
968#    subu $t0,$v0,12
972#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
976#    j badIntegerFormat # illegal integer char: abort program

980:  nonWhite:
980#    subu $t0,$v0,'-'
984#    li $t4,1 # final multiplier
988#    bne $t0,$zero,helpReadInt # go read
992#    li $t4,-1 # -1 in final multiplier

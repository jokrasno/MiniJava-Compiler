#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3148:instanceOf:
    # get object, go return false if null
3148#    lw $t2,($sp)
3152#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3156#    lw $t2,-12($t2) # vtable address
3160#    sge $t0,$t2,$t0 # are we >= the lower limit?
3161##...slt $t0,$t2,$t0
3165##...xori $t0,$t0,0x1
3168#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3172#    and $t2,$t0,$t1
3176#    sw $t2,($sp)
3180:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3180#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3184:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3184#    li $v0,4 # syscall-code for print-string
3188#    syscall
3192:exit:
    # print termination message
3192#    li $v0,4 # syscall-code for print-string
3196#    la $a0,exitString
3200#    syscall

    # print number of garbage collections
3204#    li $v0,4 # syscall-code for print-string
3208#    la $a0,gcCountMsg
3212#    syscall # print "Number of ..."
3216#    lw $a0,gcCount # number of GC's
3220#    li $v0,1 # code for print-int
3224#    syscall
3228#    li $v0,4 # syscall-code for print-string
3232#    la $a0,newlineString
3236#    syscall # print newline

    # terminate execution
3240#    li $v0,10 #syscall-code for "exit"
3244#    syscall

3248:outOfHeapMemory:
3248#    la $a0,heapMemoryMsg
3252#    j exitError
3256:divByZeroError:
3256#    la $a0,divByZeroMsg
3260#    j exitError
3264:strIndexOutOfBounds:
3264#    la $a0,strIndexOutOfBoundsMsg
3268#    j exitError
3272:arrayIndexOutOfBounds:
3272#    la $a0,arrayIndexOutOfBoundsMsg
3276#    j exitError
3280:arraySizeOutOfBounds:
3280#    la $a0,arraySizeOutOfBoundsMsg
3284#    j exitError
3288:nullPtrException:
3288#    la $a0,nullPtrExceptionMsg
3292#    j exitError
3296:badIntegerFormat:
3296#    la $a0,badIntegerFormatMsg
3300#    j exitError
3304:castException:
3304#    la $a0,castExceptionMsg
3308#    j exitError
############## data section ################
    .data
3512:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3528:cur_seg:
    .word 0

3532:lastCharRead:
    .word -2 # -2 => no buffered character
3536:prevHashConstant:
    .word 0x2785173c
3540:gcCount:
    .word 0

3544:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3571:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3594:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3629:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3663:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3696:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3727:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3775:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3796:gcMsg: 
      .asciiz "\nGC!\n"
3802:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3834:nullStr:
    .asciiz "null"
3839:trueString:
    .asciiz "true"
3844:falseString:
    .asciiz "false"
3850:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
3878:newlineString:
    .asciiz "\n"
    
    .align 2
3880:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

3884:seg0_start:
    .space 0x100000
1052460:seg0_end:
1052460:seg1_start:
    .space 0x100000
2101036:seg1_end:

2216#    lw $v0,lastCharRead
2220#    li $t0,-2
2224#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
2228#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2232#    jr $ra # return
    
2236:  doReadCh:

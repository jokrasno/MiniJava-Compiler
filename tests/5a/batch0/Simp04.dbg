837##...beq $at,$zero,856
840#    and $t0,0xff # mask off object's hash value ...
841##...lui $at,0
845##...ori $at,$at,0xff
849##...and $t0,$t0,$at
852#    sw $t0,-8($s7) # ... and store back into -8 header-word
856:  skipMask_readLine:

856#    sll $t0,$t0,2 # data bytes in object
860#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
864#    subu $t0,$t0,$t2 # place to store last character (plus 9)

764:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
764#    subu $t0,$t1,$sp # number of chars we read (times 4)
768#    srl $s6,$t0,2 # number of words on stack with chars
772#    subu $sp,$sp,4 # push char-count ...
776#    sw $s6,($sp) # ... onto stack
780#    addu $t2,$t0,5 # GC tag, incl. for count-word
784#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
788#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
792#    srl $s6,$s6,2  # data words in object
796#    move $s7,$zero # object words in object
800#    jal newObject  # allocate space
    
    # store header words
804#    la $t0,CLASS_String
808#    sw $t0,-12($s7)# store class tag (String) into object
812#    lw $t2,4($sp) # char-count
816#    sll $t1,$t2,2 # 4 times number of chars
820#    subu $t2,$zero,$t2 # negative of char-count
824#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
828#    lw $t0,-8($s7) # data words in object, possibly must mask off hash

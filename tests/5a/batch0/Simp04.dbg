##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
172:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
172#    lw $t0,-8($s2) # get word with hash bits from this
176#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
180#    addu $t0,$t1

184#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
188:mth_equals_Object:
188#    move $t0,$s2 # first pointer (this)
192#    lw $t1,($sp) # second pointer
196#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
197##...subu $at,$t0,$t1
201##...sltiu $t0,$at,1

204#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
208:mth_hashCode_String:
208#    move $t0,$s2 # put this pointer in t0

212#    li $t2,0 # current hash value
216#    lw $t1,-4($t0) # negative of number of characters in string
220#    beq $t1,$zero,done_hashCode_String # if zero length => done
224#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
228#    and $t0,0xfffffffc # adjust for padding
229##...lui $at,65535
233##...ori $at,$at,0xfffc
237##...and $t0,$t0,$at
240#    subu $t1,$t0,$t1 # address at end of string +12
244:loop_hashCode_String:    
244#    sll $t4,$t2,5 # multiply by 32
248#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
252#    lbu $t3,-12($t0) # current character
256#    addu $t2,$t3 # add in current character
260#    addu $t0,1 # go to next character's address
264#    bne $t0,$t1,loop_hashCode_String # loop back if more
268:done_hashCode_String:    

    # push int on stack
268#    move $t0, $t2 # put $t2 in return slot
272#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
276:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
276#    subu $sp,4
280#    sw $ra,($sp)
    
    # get hash value
284#    lw $t2,-12($s2) # vtable address
288#    lw $t0,($t2) # method address
292#    jalr $t0
296#    subu $sp,8 # push result (int in $t0) on stack
300#    sw $s5,4($sp)
304#    sw $t0,($sp)

    # compute print-size of hash value
308#    li $t0, 1
312#    lw $t1, ($sp)
316#    srl $t1,$t1,4
320#    beq $t1,$zero,toString_skip_loop
324:toString_loop_top:
324#    addu $t0,1
328#    srl $t1,$t1,4
332#    bne $t1,$zero,toString_loop_top
336:toString_skip_loop:
336#    subu $sp,8
340#    sw $s5,4($sp)
344#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
348#    lw $t2,-12($s2) # vtable address
352#    move $t0,$t2
356:toString_checkTagBit:
356#    subu $t0,1
360#    lb $t1,($t0)
364#    and $t1,0x80
365##...lui $at,0
369##...ori $at,$at,0x80
373##...and $t1,$t1,$at
376#    beq $t1,$zero,toString_checkTagBit
380#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
384#    subu $sp,8
388#    sw $t1,($sp)
392#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
396#    move $s7,$zero # -4 offset header word
400#    lw $t4,8($sp) # bytes for hash value
404#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
408#    addu $t4,8
412#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
416#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

420#    li $t0,CLASS_String # store string vtable address into ...
424#    sw $t0,-12($s7) # ... -12 offset in object header
428#    lw $t2,-12($s2) # our object's vtable address
432#    lw $t5,4($sp) # number characters in prefix
436#    lw $t1,12($sp) # number of characters in hashcode
440#    addu $t3,$t1,$t5 # number of characters in string ...
444#    addu $t3,1 # ... including the '@' character
448#    subu $t0,$zero,$t3 # store negated length into ...
452#    sw $t0,-4($s7) # ... -4 offset header word
456#    lw $t0,-8($s7) # get -8 offset header-word
460#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
461##...slt $at,$t0,$zero
465##...beq $at,$zero,484
468#    and $t0,0xff # mask off object's hash value ...
469##...lui $at,0
473##...ori $at,$at,0xff
477##...and $t0,$t0,$at
480#    sw $t0,-8($s7) # ... and store back into -8 header-word
484:skipMask_toString:
484#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
488#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
492#    subu $t4,$t2,$t5
496:toString_copyLoop:    
496#    lb $t3,($t4)
500#    and $t3,0x7f # mask off sign bit (in case first word)
501##...lui $at,0
505##...ori $at,$at,0x7f
509##...and $t3,$t3,$at
512#    sb $t3,-8($t0)
516#    addu $t4,1
520#    addu $t0,1
524#    blt $t4,$t2,toString_copyLoop
525##...slt $at,$t4,$t2
529##...bne $at,$zero,496

    # copy the '@' sign
532#    li $t3,'@'
536#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
540#    addu $t2,$t0,$t1 # address of last byte in string to store +8
544#    lw $t3,20($sp) # hash code to print
548:toString_hashCopyLoop:
548#    and $t4,$t3,0xf
552#    srl $t3,4
556#    lb $t4,hexChars($t4)
560#    sb $t4,-8($t2)
564#    subu $t2,$t2,1
568#    bgt $t2,$t0,toString_hashCopyLoop
569##...slt $at,$t0,$t2
573##...bne $at,$zero,548

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
576#    addu $sp,28
580#    lw $ra,($sp)
584#    addu $sp,4
588#    move $t0, $s7 # return string we created
592#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
596:mth_equals_String:
    
    # quick test for obvious false
596#    lw $t0,($sp) # second parameter
600#    beq $t0,$zero,goEsFalse # go return false if null
604#    lw $t1,-12($t0) # vtable pointer
608#    la $t2,CLASS_String # string vtable pointer
612#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
616#    subu $sp,12
620#    sw $ra,8($sp)
624#    sw $s2,4($sp)
628#    sw $t0,($sp)
632#    jal mth_compareTo_String
636#    lw $s2, 4($sp) #restore this pointer and pop parameters
640#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
644#    seq $t0,$t0,$zero
645##...subu $at,$t0,$zero
649##...sltiu $t0,$at,1

    # pop return address and return $t0
652#    lw $ra,($sp)
656#    addu $sp,4

660#    jr $ra # return
    
664:goEsFalse:
    # put 0 in $t0 and return
664#    li $t0, 0
668#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
672:mth_toString_String:
    #we are a string, so return this.
672#    move $t0, $s2
676#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
680:mth_readLine_Lib:
    
680#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
684#    sw $ra, 4($sp) # save $ra
688#    move $t1,$sp # save "original" sp

692:  doRead:

    # read the character
692#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
696#    subu $t2,$v0,13
700#    bne $t2,$zero,notReturnRL
704#    jal readLogicalChar
708#    subu $t2,$v0,10 # check for newline
712#    beq $t2,$zero,foundNewLine
716#    sw $v0,lastCharRead # push back character into queue
720#    j foundNewLine # go process the line

724:  notReturnRL:

    # at this point, $v0 has our character

724#    subu $t0,$v0,10

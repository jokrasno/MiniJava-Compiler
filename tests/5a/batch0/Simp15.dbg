###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
976:mth_readLine_Lib:
    
976#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
980#    sw $ra, 4($sp) # save $ra
984#    move $t1,$sp # save "original" sp

988:  doRead:

    # read the character
988#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
992#    subu $t2,$v0,13
996#    bne $t2,$zero,notReturnRL
1000#    jal readLogicalChar
1004#    subu $t2,$v0,10 # check for newline
1008#    beq $t2,$zero,foundNewLine
1012#    sw $v0,lastCharRead # push back character into queue
1016#    j foundNewLine # go process the line

1020:  notReturnRL:

    # at this point, $v0 has our character

1020#    subu $t0,$v0,10
1024#    beq $t0,$zero,foundNewLine
1028#    blt $v0,$zero,foundEof
1029##...slt $at,$v0,$zero
1033##...bne $at,$zero,1048

    # we have a character, so push it onto stack
1036#    subu $sp,$sp,4
1040#    sw $v0,($sp)

    # loop back up to get next character
1044#    j doRead

1048:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
1048#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
1052#    li $s7, 0 # return-value: null
1056#    j rlReturn # return

1060:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
1060#    subu $t0,$t1,$sp # number of chars we read (times 4)
1064#    srl $s6,$t0,2 # number of words on stack with chars
1068#    subu $sp,$sp,4 # push char-count ...
1072#    sw $s6,($sp) # ... onto stack
1076#    addu $t2,$t0,5 # GC tag, incl. for count-word
1080#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
1084#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
1088#    srl $s6,$s6,2  # data words in object
1092#    move $s7,$zero # object words in object
1096#    jal newObject  # allocate space
    
    # store header words
1100#    la $t0,CLASS_String
1104#    sw $t0,-12($s7)# store class tag (String) into object
1108#    lw $t2,4($sp) # char-count
1112#    sll $t1,$t2,2 # 4 times number of chars
1116#    subu $t2,$zero,$t2 # negative of char-count
1120#    sw $t2,-4($s7) # store negative char-count as header-word 2

    # set up pointers to various parts of stack and object
1124#    lw $t0,-8($s7) # data words in object, possibly must mask off hash
1128#    bge $t0,$zero,skipMask_readLine # don't strip hash code if not there
1129##...slt $at,$t0,$zero
1133##...beq $at,$zero,1152
1136#    and $t0,0xff # mask off object's hash value ...
1137##...lui $at,0
1141##...ori $at,$at,0xff
1145##...and $t0,$t0,$at
1148#    sw $t0,-8($s7) # ... and store back into -8 header-word
1152:  skipMask_readLine:

1152#    sll $t0,$t0,2 # data bytes in object
1156#    subu $t0,$s7,$t0 # place to store first character (plus 8)    
1160#    subu $t0,$t0,$t2 # place to store last character (plus 9)
1164#    addu $sp,$sp,8 # pop redundant object-pointer and count
1168#    addu $t1,$t1,$sp # first non-char spot on stack

    # at this point:
    #  $t0 points to the target-spot for the last character (plus 9)
    #  $t1 contains top spot on the stack not containing a char
    #  $sp points to the word with the last source character

    # copy the characters, popping each off the stack

1172#    beq $sp,$t1,rlReturn
1176:  charCopyLoop:
1176#    lw $t2,($sp)
1180#    sb $t2,-9($t0)
1184#    addu $sp,$sp,4
1188#    subu $t0,$t0,1
1192#    bne $sp,$t1,charCopyLoop
1196:  rlReturn:

1196#    lw $ra, 4($sp)
1200#    addu $sp, 8   # pop $ra and pointless word off stack
1204#    move $t0, $s7 # return string we allocated in $s7
1208#    jr $ra

###################################################################
# readInt() - library method (class Lib)
# - skips whitespace
# - then attempts to read a base-10 integer from standard input
# - aborts program if a valid integer is not found
# - returns the integer that is read
# - truncates on overflow
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - value that was read
###################################################################
1212:mth_readInt_Lib:

    # save $ra by pushing onto stack
1212#    subu $sp,$sp,4
1216#    sw $ra,($sp)

1220:  riSkipWhiteLoop:
    # read a character
1220#    jal readLogicalChar

    # if character <= 32 ascii, check for whitespace; if not
    # whitespace, abort 
1224#    subu $t0,$v0,32
1228#    bgt $t0,$zero,nonWhite
1229##...slt $at,$zero,$t0
1233##...bne $at,$zero,1276
1236#    beq $t0,$zero,riSkipWhiteLoop # start over if space
1240#    subu $t0,$v0,10
1244#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
1248#    subu $t0,$v0,9
1252#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
1256#    subu $t0,$v0,13
1260#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
1264#    subu $t0,$v0,12
1268#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
1272#    j badIntegerFormat # illegal integer char: abort program

1276:  nonWhite:
1276#    subu $t0,$v0,'-'
1280#    li $t4,1 # final multiplier
1284#    bne $t0,$zero,helpReadInt # go read
1288#    li $t4,-1 # -1 in final multiplier

    # read another character to make up for the '-'
1292#    jal readLogicalChar

1296:  helpReadInt:
1296#    li $t2,10
1300#    subu $t1,$v0,'0' # convert digit to 0-9 value
1304#    bgeu $t1,$t2,badIntegerFormat # abort if not digit
1305##...sltu $at,$t1,$t2
1309##...beq $at,$zero,3592
1312#    move $t3,$t1 #

    #### at this point, $t3 contains value of the first digit read,
    #### and $t2 contains the value 10

1316:  digitLoop:
    # loop invariants:
    # - $t3 contains the value of the number we've read so far
    # - $t2 contains the value 10

1316#    jal readLogicalChar # read next character
1320#    subu $t1,$v0,'0' # convert digit to 0-9 value
1324#    bgeu $t1,$t2,doneDigitLoop # abort if not digit
1325##...sltu $at,$t1,$t2
1329##...beq $at,$zero,1348

1332#    mul $t3,$t3,$t2 # multiply old value by 10
1333##...mult $t3,$t2
1337##...mflo $t3
1340#    addu $t3,$t3,$t1 # add in value of new digit
1344#    j digitLoop

1348:  doneDigitLoop:

    # "push back" unused character into queue
1348#    sw $v0,lastCharRead

    # restore return address
1352#    lw $ra,($sp)
1356#    addu $sp, 4

    # multiply by sign and put return value in $t0
1360#    mult $t3,$t4 # multiply to account for poss. minus sign
1364#    mflo $t3
1368#    move $t0, $t3
    
    # return
1372#    jr $ra

###################################################################
# readChar() - library method (class Lib)

##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
468:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
468#    lw $t0,-8($s2) # get word with hash bits from this
472#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
476#    addu $t0,$t1

480#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
484:mth_equals_Object:
484#    move $t0,$s2 # first pointer (this)
488#    lw $t1,($sp) # second pointer
492#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
493##...subu $at,$t0,$t1
497##...sltiu $t0,$at,1

500#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
504:mth_hashCode_String:
504#    move $t0,$s2 # put this pointer in t0

508#    li $t2,0 # current hash value
512#    lw $t1,-4($t0) # negative of number of characters in string
516#    beq $t1,$zero,done_hashCode_String # if zero length => done
520#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
524#    and $t0,0xfffffffc # adjust for padding
525##...lui $at,65535
529##...ori $at,$at,0xfffc
533##...and $t0,$t0,$at
536#    subu $t1,$t0,$t1 # address at end of string +12
540:loop_hashCode_String:    
540#    sll $t4,$t2,5 # multiply by 32
544#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
548#    lbu $t3,-12($t0) # current character
552#    addu $t2,$t3 # add in current character
556#    addu $t0,1 # go to next character's address
560#    bne $t0,$t1,loop_hashCode_String # loop back if more
564:done_hashCode_String:    

    # push int on stack
564#    move $t0, $t2 # put $t2 in return slot
568#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
572:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
572#    subu $sp,4
576#    sw $ra,($sp)
    
    # get hash value
580#    lw $t2,-12($s2) # vtable address
584#    lw $t0,($t2) # method address
588#    jalr $t0
592#    subu $sp,8 # push result (int in $t0) on stack
596#    sw $s5,4($sp)
600#    sw $t0,($sp)

    # compute print-size of hash value
604#    li $t0, 1
608#    lw $t1, ($sp)
612#    srl $t1,$t1,4
616#    beq $t1,$zero,toString_skip_loop
620:toString_loop_top:
620#    addu $t0,1
624#    srl $t1,$t1,4
628#    bne $t1,$zero,toString_loop_top
632:toString_skip_loop:
632#    subu $sp,8
636#    sw $s5,4($sp)
640#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
644#    lw $t2,-12($s2) # vtable address
648#    move $t0,$t2
652:toString_checkTagBit:
652#    subu $t0,1
656#    lb $t1,($t0)
660#    and $t1,0x80
661##...lui $at,0
665##...ori $at,$at,0x80
669##...and $t1,$t1,$at
672#    beq $t1,$zero,toString_checkTagBit
676#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
680#    subu $sp,8
684#    sw $t1,($sp)
688#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
692#    move $s7,$zero # -4 offset header word
696#    lw $t4,8($sp) # bytes for hash value
700#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
704#    addu $t4,8
708#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
712#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

716#    li $t0,CLASS_String # store string vtable address into ...
720#    sw $t0,-12($s7) # ... -12 offset in object header
724#    lw $t2,-12($s2) # our object's vtable address
728#    lw $t5,4($sp) # number characters in prefix
732#    lw $t1,12($sp) # number of characters in hashcode
736#    addu $t3,$t1,$t5 # number of characters in string ...
740#    addu $t3,1 # ... including the '@' character
744#    subu $t0,$zero,$t3 # store negated length into ...
748#    sw $t0,-4($s7) # ... -4 offset header word
752#    lw $t0,-8($s7) # get -8 offset header-word
756#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
757##...slt $at,$t0,$zero
761##...beq $at,$zero,780
764#    and $t0,0xff # mask off object's hash value ...
765##...lui $at,0
769##...ori $at,$at,0xff
773##...and $t0,$t0,$at
776#    sw $t0,-8($s7) # ... and store back into -8 header-word
780:skipMask_toString:
780#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
784#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
788#    subu $t4,$t2,$t5
792:toString_copyLoop:    
792#    lb $t3,($t4)
796#    and $t3,0x7f # mask off sign bit (in case first word)
797##...lui $at,0
801##...ori $at,$at,0x7f
805##...and $t3,$t3,$at
808#    sb $t3,-8($t0)
812#    addu $t4,1
816#    addu $t0,1
820#    blt $t4,$t2,toString_copyLoop
821##...slt $at,$t4,$t2
825##...bne $at,$zero,792

    # copy the '@' sign
828#    li $t3,'@'
832#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
836#    addu $t2,$t0,$t1 # address of last byte in string to store +8
840#    lw $t3,20($sp) # hash code to print
844:toString_hashCopyLoop:
844#    and $t4,$t3,0xf
848#    srl $t3,4
852#    lb $t4,hexChars($t4)
856#    sb $t4,-8($t2)
860#    subu $t2,$t2,1
864#    bgt $t2,$t0,toString_hashCopyLoop
865##...slt $at,$t0,$t2
869##...bne $at,$zero,844

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
872#    addu $sp,28
876#    lw $ra,($sp)
880#    addu $sp,4
884#    move $t0, $s7 # return string we created
888#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
892:mth_equals_String:
    
    # quick test for obvious false
892#    lw $t0,($sp) # second parameter
896#    beq $t0,$zero,goEsFalse # go return false if null
900#    lw $t1,-12($t0) # vtable pointer
904#    la $t2,CLASS_String # string vtable pointer
908#    bne $t1,$t2,goEsFalse # go return false if not a string


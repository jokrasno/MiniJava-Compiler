3336#    la $s4,seg0_end
3337##...lui $s4,16
3341##...addiu $s4,$s4,4180
    
    # return
3344#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3348:divide:
    # get parameters; abort if divisor zero
3348#    lw $t0,($sp)
3352#    lw $t1,8($sp)
3356#    beq $t0,$zero,divByZeroError
    
    # perform division
3360#    div $t1,$t0
3364#    mflo $t0

    # store result, adjust stack and return
3368#    addu $sp,$sp,8 # adjust stack
3372#    sw $t0,($sp) # store result
3376#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
3380:remainder:
    # get parameters; abort if divisor zero
3380#    lw $t0,($sp)
3384#    lw $t1,8($sp)
3388#    beq $t0,$zero,divByZeroError
    
    # perform division
3392#    div $t1,$t0
3396#    mfhi $t0

    # store result, adjust stack and return
3400#    addu $sp,$sp,8 # adjust stack
3404#    sw $t0,($sp) # store result
3408#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3412:checkCast:
    # get object, allow immediately if null
3412#    lw $t2,($sp)
3416#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3420#    lw $t2,-12($t2) # vtable address
3424#    bge $t2,$t1,castException
3425##...slt $at,$t2,$t1
3429##...beq $at,$zero,3600
3432#    blt $t2,$t0,castException
3433##...slt $at,$t2,$t0
3437##...bne $at,$zero,3600
    
    # return, leaving object unchanged on stack
3440:  checkCastReturn:    
3440#    jr $ra    

# checkCast:
#     # get object, allow immediately if null
#     lw $t2,($sp)
#     beq $t2,$zero,checkCastReturn
#     
#     # get vtable address of object (using Object vtable
#     # address for arrays)
#     lw $t3,-8($t2) # <= 0 if array
#     lw $t2,-12($t2) # vtable address (unless array)
#     bgt $t3,$zero,skipArrayCast
#     la $t2,CLASS_Object
#     
#     # get vtable address of object, abort if less than
#     # lower limit or greater then or equal to higher
#     # limit
#   skipArrayCast:
#     bge $t2,$t1,castException
#     blt $t2,$t0,castException
#     
#     # return, leaving object unchanged on stack
#   checkCastReturn:    
#     jr $ra    

########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3444:instanceOf:
    # get object, go return false if null
3444#    lw $t2,($sp)
3448#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3452#    lw $t2,-12($t2) # vtable address
3456#    sge $t0,$t2,$t0 # are we >= the lower limit?
3457##...slt $t0,$t2,$t0
3461##...xori $t0,$t0,0x1
3464#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3468#    and $t2,$t0,$t1
3472#    sw $t2,($sp)
3476:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3476#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3480:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3480#    li $v0,4 # syscall-code for print-string
3484#    syscall
3488:exit:
    # print termination message
3488#    li $v0,4 # syscall-code for print-string
3492#    la $a0,exitString
3496#    syscall

    # print number of garbage collections
3500#    li $v0,4 # syscall-code for print-string
3504#    la $a0,gcCountMsg
3508#    syscall # print "Number of ..."
3512#    lw $a0,gcCount # number of GC's
3516#    li $v0,1 # code for print-int
3520#    syscall
3524#    li $v0,4 # syscall-code for print-string
3528#    la $a0,newlineString
3532#    syscall # print newline

    # terminate execution
3536#    li $v0,10 #syscall-code for "exit"
3540#    syscall

3544:outOfHeapMemory:
3544#    la $a0,heapMemoryMsg
3548#    j exitError
3552:divByZeroError:
3552#    la $a0,divByZeroMsg
3556#    j exitError
3560:strIndexOutOfBounds:
3560#    la $a0,strIndexOutOfBoundsMsg
3564#    j exitError
3568:arrayIndexOutOfBounds:
3568#    la $a0,arrayIndexOutOfBoundsMsg
3572#    j exitError
3576:arraySizeOutOfBounds:
3576#    la $a0,arraySizeOutOfBoundsMsg
3580#    j exitError
3584:nullPtrException:
3584#    la $a0,nullPtrExceptionMsg
3588#    j exitError
3592:badIntegerFormat:
3592#    la $a0,badIntegerFormatMsg
3596#    j exitError
3600:castException:
3600#    la $a0,castExceptionMsg
3604#    j exitError
############## data section ################
    .data
3808:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3824:cur_seg:
    .word 0

3828:lastCharRead:
    .word -2 # -2 => no buffered character
3832:prevHashConstant:
    .word 0x2785173c
3836:gcCount:
    .word 0

3840:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3867:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3890:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3925:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3959:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3992:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
4023:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
4071:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
4092:gcMsg: 
      .asciiz "\nGC!\n"
4098:gcCountMsg: 
      .asciiz "Number of garbage collections: "

4130:nullStr:
    .asciiz "null"
4135:trueString:
    .asciiz "true"
4140:falseString:
    .asciiz "false"
4146:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
4174:newlineString:
    .asciiz "\n"
    
    .align 2
4176:stack_bottom:
    .word 0

# heapFudge: # temporary fudge amount to exercise GC
#     .word 0

4180:seg0_start:
    .space 0x100000
1052756:seg0_end:
1052756:seg1_start:

########################################################
2512:readLogicalChar:

    # check if we already have a character
2512#    lw $v0,lastCharRead
2516#    li $t0,-2
2520#    beq $t0,$v0 doReadCh

    # we have our character from the buffer. Wipe out
    # buffer and return
2524#    sw $t0,lastCharRead # store -2 into buffer (i.e. "empty")
2528#    jr $ra # return
    
2532:  doReadCh:
